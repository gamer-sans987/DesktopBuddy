	public abstract class MaterialProviderBase<A> : DynamicAssetProvider<A>, IMaterialProviderBase where A : DynamicRendererAsset<A>, new()
	{
		private bool updateRunning;

		private bool needsUpdating;

		private bool wasCreated;

		protected static readonly Action<SyncElement> _markWasChanged = MarkWasChanged;

		public abstract bool PropertiesInitialized { get; protected set; }

		public bool IsLoaded
		{
			get
			{
				bool loaded = true;
				ForeachSyncMember(delegate(IAssetRef r)
				{
					if (r.Target is IAssetProvider { IsAssetAvailable: false })
					{
						loaded = false;
					}
				});
				return loaded;
			}
		}

		protected AssetIntegrated assetUpdatedCallback { get; private set; }

		private static void MarkWasChanged(SyncElement element)
		{
			element.WasChanged = true;
		}

		protected sealed override void AssetCreated(A asset)
		{
			if (assetUpdatedCallback == null)
			{
				assetUpdatedCallback = MaterialAssetUpdated;
			}
			if (wasCreated)
			{
				ForeachSyncMember(_markWasChanged);
				Reinitialize();
				OnMaterialReinitialize();
			}
			wasCreated = true;
		}

		protected sealed override void UpdateAsset(A asset)
		{
			if (!base.Engine.RenderSystem.HasRenderer)
			{
				return;
			}
			needsUpdating = true;
			if (!updateRunning)
			{
				needsUpdating = false;
				updateRunning = true;
				if (!PropertiesInitialized)
				{
					base.Engine.RenderSystem.Materials.RequestPropertyInitialization(this);
				}
				else
				{
					RegisterUpdate();
				}
			}
		}

		protected override void ClearAsset()
		{
		}

		internal void MaterialAssetUpdated(bool assetInstanceChanged)
		{
			updateRunning = false;
			if (assetInstanceChanged)
			{
				AssetCreated();
			}
			else
			{
				AssetUpdated();
			}
			if (needsUpdating)
			{
				MarkChangeDirty();
			}
		}

		internal void ClearUpdateStatus()
		{
			updateRunning = false;
			needsUpdating = false;
		}

		protected abstract void RegisterUpdate();

		protected abstract void Reinitialize();

		protected virtual void OnMaterialReinitialize()
		{
		}

		public virtual List<MaterialProperty> GetMaterialProperties()
		{
			List<MaterialProperty> list = new List<MaterialProperty>();
			GetMaterialPropertiesByReflection(GetType(), list);
			return list;
		}

		public void PropertyInitializationComplete()
		{
			PropertiesInitialized = true;
			RegisterUpdate();
		}

		private static void GetMaterialPropertiesByReflection(Type type, List<MaterialProperty> properties)
		{
			FieldInfo[] fields = type.GetFields(BindingFlags.Static | BindingFlags.NonPublic);
			foreach (FieldInfo fieldInfo in fields)
			{
				if (fieldInfo.FieldType == typeof(MaterialProperty) && fieldInfo.GetValue(null) is MaterialProperty { Initialized: false } materialProperty)
				{
					properties.Add(materialProperty);
				}
			}
			if (!type.IsGenericType || !(type.GetGenericTypeDefinition() == typeof(MaterialProviderBase<>)))
			{
				GetMaterialPropertiesByReflection(type.BaseType, properties);
			}
		}

