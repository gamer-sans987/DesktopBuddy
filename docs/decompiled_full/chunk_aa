		protected virtual void SetBlendMode(ref MaterialUpdateWriter writer, BlendMode mode, ZWrite zwrite = ZWrite.Auto, int renderQueue = -1)
		{
			int renderQueue2;
			switch (mode)
			{
			case BlendMode.Opaque:
				renderQueue2 = OverrideOpaqueRenderQueue ?? (UseLateRenderQueue ? 2550 : 2000);
				writer.SetRenderType(MaterialRenderType.Opaque);
				writer.SetFloat(SrcBlendProp, 1f);
				writer.SetFloat(DstBlendProp, 0f);
				if (MultipassLighting)
				{
					writer.SetFloat(SrcAddBlendProp, 1f);
					writer.SetFloat(DstAddBlendProp, 1f);
				}
				break;
			case BlendMode.Cutout:
				renderQueue2 = OverrideCutoutRenderQueue ?? (UseLateRenderQueue ? 2750 : 2450);
				writer.SetRenderType(MaterialRenderType.TransparentCutout);
				writer.SetFloat(SrcBlendProp, 1f);
				writer.SetFloat(DstBlendProp, 0f);
				if (MultipassLighting)
				{
					writer.SetFloat(SrcAddBlendProp, 1f);
					writer.SetFloat(DstAddBlendProp, 1f);
				}
				break;
			case BlendMode.Alpha:
				renderQueue2 = OverrideTransparentRenderQueue ?? 3000;
				writer.SetRenderType(MaterialRenderType.Transparent);
				writer.SetFloat(SrcBlendProp, 5f);
				writer.SetFloat(DstBlendProp, 10f);
				if (MultipassLighting)
				{
					writer.SetFloat(SrcAddBlendProp, 5f);
					writer.SetFloat(DstAddBlendProp, 1f);
				}
				break;
			case BlendMode.Transparent:
				renderQueue2 = OverrideTransparentRenderQueue ?? 3000;
				writer.SetRenderType(MaterialRenderType.Transparent);
				writer.SetFloat(SrcBlendProp, 1f);
				writer.SetFloat(DstBlendProp, 10f);
				if (MultipassLighting)
				{
					writer.SetFloat(SrcAddBlendProp, 5f);
					writer.SetFloat(DstAddBlendProp, 1f);
				}
				break;
			case BlendMode.Additive:
				renderQueue2 = OverrideTransparentRenderQueue ?? 3000;
				writer.SetRenderType(MaterialRenderType.Transparent);
				writer.SetFloat(SrcBlendProp, 1f);
				writer.SetFloat(DstBlendProp, 1f);
				if (MultipassLighting)
				{
					writer.SetFloat(SrcAddBlendProp, 1f);
					writer.SetFloat(DstAddBlendProp, 1f);
				}
				break;
			case BlendMode.Multiply:
				renderQueue2 = OverrideTransparentRenderQueue ?? 3000;
				writer.SetRenderType(MaterialRenderType.Transparent);
				writer.SetFloat(SrcBlendProp, 2f);
				writer.SetFloat(DstBlendProp, 0f);
				if (MultipassLighting)
				{
					writer.SetFloat(SrcAddBlendProp, 2f);
					writer.SetFloat(DstAddBlendProp, 0f);
				}
				break;
			default:
				base.Debug.Warning("Unsupported BlendMode: " + mode);
				goto case BlendMode.Opaque;
			}
			if (ZWriteProp != null)
			{
				writer.SetFloat(ZWriteProp, zwrite.GetZWrite(mode, OpaqueAutoZWrite) ? 1 : 0);
			}
			if (renderQueue < 0)
			{
				writer.SetRenderQueue(renderQueue2);
			}
			else
			{
				writer.SetRenderQueue(renderQueue);
			}
		}

