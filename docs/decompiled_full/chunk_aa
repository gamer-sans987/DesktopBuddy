			});
		}

		public void Update()
		{
			if (enabled && ValidateConnection())
			{
				for (ITransportMessage transportMessage = RetrieveMessage(); transportMessage != null; transportMessage = RetrieveMessage())
				{
					HandleMessage(transportMessage);
				}
			}
		}

		public void Dispose()
		{
			m_gliaValCache?.Stop();
