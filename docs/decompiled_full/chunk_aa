				{
					HeartRate obj2 = m_gliaClient.Connection.Build<HeartRate>(msg);
					this.OnHeartRate(obj2);
				}
				break;
			case 36u:
				if (this.OnHeartRateVariability != null)
				{
					HeartRateVariability obj6 = m_gliaClient.Connection.Build<HeartRateVariability>(msg);
					this.OnHeartRateVariability(obj6);
				}
				break;
			case 18u:
				if (this.OnPPGEvent != null)
				{
					PPGFrame obj8 = m_gliaClient.Connection.Build<PPGFrame>(msg);
					this.OnPPGEvent(obj8);
				}
				break;
			case 9u:
				if (this.OnEyeTracking != null)
				{
					EyeTracking obj4 = m_gliaClient.Connection.Build<EyeTracking>(msg);
					this.OnEyeTracking(obj4);
				}
				break;
			case 28u:
				if (this.OnVSync != null)
				{
					VSync obj9 = m_gliaClient.Connection.Build<VSync>(msg);
					this.OnVSync(obj9);
				}
				break;
			case 21u:
				if (this.OnCognitiveLoad != null)
				{
					CognitiveLoad obj7 = m_gliaClient.Connection.Build<CognitiveLoad>(msg);
					this.OnCognitiveLoad(obj7);
				}
				break;
			case 37u:
				if (this.OnCameraImage != null)
				{
					CameraImage obj5 = m_gliaClient.Connection.Build<CameraImage>(msg);
					this.OnCameraImage(obj5);
				}
				break;
			case 32u:
				if (this.OnDataVaultResult != null)
				{
					DataVaultResult obj3 = m_gliaClient.Connection.Build<DataVaultResult>(msg);
					this.OnDataVaultResult(obj3);
				}
				break;
			case 39u:
				if (this.OnIMUEvent != null)
				{
					IMUFrame obj = m_gliaClient.Connection.Build<IMUFrame>(msg);
					this.OnIMUEvent(obj);
				}
				break;
			}
			m_lastValues[msg.Header.MessageType] = msg;
		}

		public void Initialize()
		{
			SessionLicense sessionLicense = new SessionLicense(null, null, LicensingModel.Core, isRunningInEditor: false);
			m_isConnected = false;
