namespace HP.Omnicept
{
	public class GliaHandler : IDisposable
	{
		protected Glia m_gliaClient;

		protected GliaValueCache m_gliaValCache;

		protected Dictionary<uint, ITransportMessage> m_lastValues = new Dictionary<uint, ITransportMessage>();

		protected Task m_connectTask;

		protected bool m_isConnected;

		private bool enabled = true;

		public bool IsConnected => m_isConnected;

		public event Action<HeartRate> OnHeartRate;

		public event Action<HeartRateVariability> OnHeartRateVariability;

		public event Action<PPGFrame> OnPPGEvent;

		public event Action<EyeTracking> OnEyeTracking;

		public event Action<VSync> OnVSync;

		public event Action<CognitiveLoad> OnCognitiveLoad;

		public event Action<GliaHandler> OnConnect;

		public event Action<string> OnDisconnect;

		public event Action<ClientHandshakeError> OnConnectionFailure;

		public event Action<CameraImage> OnCameraImage;

		public event Action<DataVaultResult> OnDataVaultResult;

		public event Action<IMUFrame> OnIMUEvent;

		public void DataVaultStartRecording()
		{
			DataVaultAction message = new DataVaultAction(DataVaultAction.DataVaultActionType.Start_Recording);
			m_gliaClient.Connection.Send(message);
		}

		public void DataVaultStopRecording()
		{
			DataVaultAction message = new DataVaultAction(DataVaultAction.DataVaultActionType.Stop_Recording);
			m_gliaClient.Connection.Send(message);
		}

		private bool ValidateConnection()
		{
			if (!m_isConnected)
			{
				if (m_connectTask.Status == TaskStatus.Faulted)
				{
					enabled = false;
					m_connectTask.Exception.Handle(delegate(Exception x)
					{
						if (x is ClientHandshakeError)
						{
							if (this.OnConnectionFailure != null)
							{
								this.OnConnectionFailure((ClientHandshakeError)x);
							}
							else
							{
								UniLog.Error("Omnicept Driver failed: " + x.Message);
							}
						}
						else
						{
							UniLog.Error(x.Message);
						}
						return true;
					});
				}
				else if (m_connectTask.Status == TaskStatus.RanToCompletion)
				{
					m_isConnected = true;
					this.OnConnect?.Invoke(this);
				}
			}
			return m_isConnected;
		}

		private ITransportMessage RetrieveMessage()
		{
			ITransportMessage result = null;
			if (m_gliaValCache != null)
			{
				try
				{
					result = m_gliaValCache.GetNext();
				}
				catch (TransportError transportError)
				{
					enabled = false;
					if (this.OnDisconnect != null)
					{
						this.OnDisconnect(transportError.Message);
					}
					else
					{
						UniLog.Error(transportError.Message);
					}
				}
			}
			return result;
		}

		private void HandleMessage(ITransportMessage msg)
		{
