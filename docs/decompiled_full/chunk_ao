		public ProtoFluxNode SpawnNode(Type nodeType, Action<ProtoFluxNode> setup = null)
		{
			ProtoFluxNode protoFluxNode = (ProtoFluxNode)GenerateSlotNode(nodeType).AttachComponent(nodeType);
			setup?.Invoke(protoFluxNode);
			protoFluxNode.EnsureVisual();
			return protoFluxNode;
		}

		public T SpawnNode<T>(Action<T> setup = null) where T : ProtoFluxNode, new()
		{
			T val = GenerateSlotNode(typeof(T)).AttachComponent<T>();
			setup?.Invoke(val);
			val.EnsureVisual();
			return val;
		}

		private Slot GenerateSlotNode(Type type)
		{
			Slot slot = base.LocalUserSpace.AddSlot(type.Name);
			slot.GlobalPosition = InteractionPointPosition;
			slot.GlobalRotation = InteractionPointOrientation;
			slot.GlobalScale = base.LocalUserRoot.GlobalScale * Elements.Core.float3.One;
			return slot;
		}

