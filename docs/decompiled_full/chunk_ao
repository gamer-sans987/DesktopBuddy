					if (outputList2.Count == k)
					{
						nodeOutput.MappedOutput = outputList2.AddOutput();
					}
					else
					{
						nodeOutput.MappedOutput = outputList2.GetOutput(k);
					}
				}
				while (outputList2.Count > outputList.Count)
				{
					outputList2.RemoveOutput();
				}
			}
		}

