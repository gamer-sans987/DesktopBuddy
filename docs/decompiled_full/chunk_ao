		{
			startNode.Group.Pack(root);
		}

		public static void Pack(this ProtoFluxNodeGroup group, Slot root)
		{
			foreach (ProtoFluxNode node in group.Nodes)
			{
				if (node.Slot.Parent != root)
				{
					node.Slot.Parent = root;
				}
				node.RemoveVisual();
			}
		}

		public static void PackInPlace(this ProtoFluxNode startNode)
		{
			startNode.Group.AsSingleItemEnumerable().PackInPlace(startNode);
		}

		public static void PackInPlace(this IEnumerable<ProtoFluxNodeGroup> groups, ProtoFluxNode startNode)
		{
			KeyCounter<Slot> keyCounter = new KeyCounter<Slot>();
			foreach (ProtoFluxNodeGroup group in groups)
			{
				foreach (ProtoFluxNode node in group.Nodes)
				{
					Slot parent = node.Slot.Parent;
					if (!parent.IsRootSlot && parent != startNode.LocalUserSpace)
					{
						keyCounter.Increment(parent);
					}
				}
			}
			Slot slot = null;
			slot = ((keyCounter.KeyCount != 0) ? keyCounter.FindItemWithHighestCount() : startNode.Slot.Parent);
			foreach (ProtoFluxNodeGroup group2 in groups)
			{
				group2.Pack(slot);
			}
		}

		public static void UnpackNodes(this Slot root)
		{
			foreach (ProtoFluxNode componentsInChild in root.GetComponentsInChildren<ProtoFluxNode>())
			{
				componentsInChild.EnsureVisual();
			}
		}
	}
