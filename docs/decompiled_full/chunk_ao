		public bool TryConnectInput(ProtoFluxNode node, ISyncRef input, INodeOutput output, bool allowExplicitCast, bool undoable)
		{
			if (!IsValid)
			{
				return false;
			}
			if (node.NodeInstance == null)
			{
				return false;
			}
			ElementRef? inputElementRef = node.GetInputElementRef(input);
			if (!inputElementRef.HasValue)
			{
