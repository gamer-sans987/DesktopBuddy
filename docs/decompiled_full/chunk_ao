			frooxEngineContext.SharedScope = nodeGroup.SharedScope;
			frooxEngineContext.SetEventDispatcher(nodeGroup.EventDispatcher);
			frooxEngineContext.Updates = nodeGroup.UpdatesDispatcher;
			frooxEngineContext.Changes = nodeGroup.ChangesDispatcher;
