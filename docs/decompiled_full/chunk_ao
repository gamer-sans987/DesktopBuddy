			Engine.AudioSystem.GlobalVolumesChanged -= AudioSystem_GlobalVolumesChanged;
			Engine.AudioSystem.DefaultAudioInputChanged -= InputInterface_DefaultAudioInputChanged;
			if (Session != null)
