	public abstract class ProtoFluxEngineProxy : Component
	{
		public readonly SyncRef<IProtoFluxNode> Node;

		public readonly SyncRefList<IProtoFluxNode> Path;

		internal INode AssociatedInstance;

		public bool Matches(IProtoFluxNode node, List<IProtoFluxNode> enginePath)
		{
			if (Node.Target != node)
			{
				return false;
			}
			if (Path.Count != enginePath.Count)
			{
				return false;
			}
			for (int i = 0; i < Path.Count; i++)
			{
				if (Path[i] != enginePath[i])
				{
					return false;
				}
			}
			return true;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Node = new SyncRef<IProtoFluxNode>();
			Path = new SyncRefList<IProtoFluxNode>();
		}
	}
