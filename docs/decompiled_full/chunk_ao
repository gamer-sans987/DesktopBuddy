			if (node.NodeInstance == null)
			{
				return false;
			}
			if (targetNode.NodeInstance == null)
			{
				return false;
			}
			int referenceIndex = node.GetReferenceIndex(reference);
			if (referenceIndex < 0)
			{
				return false;
			}
			ConnectionResult result = executionRuntime.SetReference(node.NodeInstance, referenceIndex, targetNode.NodeInstance, overload: true, allowMergingGroups: true);
			if (!result.connected)
			{
				return false;
			}
			MapCastsAndOverloads(node, targetNode, result, undoable);
