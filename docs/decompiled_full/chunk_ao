		public void RebuildChangeTracking()
		{
			if (_groupsToRebuildTracking.Count == 0)
			{
				return;
			}
			foreach (ProtoFluxNodeGroup item in _groupsToRebuildTracking)
			{
				item.RebuildChangeTracking();
			}
			_groupsToRebuildTracking.Clear();
		}

		public void Rebuild()
		{
			if (_groupsToRebuild.Count == 0 && _dirtyNodes.Count == 0 && _dirtyGroups.Count == 0)
			{
				return;
			}
			Stopwatch stopwatch = Stopwatch.StartNew();
			foreach (ProtoFluxNodeGroup item in _groupsToRebuild)
			{
				item.MarkNodesForRebuild();
			}
			_groupsToRebuild.Clear();
			for (int i = 0; i < _dirtyNodes.Count; i++)
			{
				ProtoFluxNode protoFluxNode = _dirtyNodes[i];
				if (!protoFluxNode.IsDisposed && !protoFluxNode.IsBuilt)
				{
					ProtoFluxNodeGroup currentGroup = null;
					protoFluxNode.Rebuild(ref currentGroup);
				}
			}
			int num = 0;
			for (int j = 0; j < _dirtyGroups.Count; j++)
			{
				ProtoFluxNodeGroup protoFluxNodeGroup = _dirtyGroups[j];
				if (!protoFluxNodeGroup.ShouldBeRemoved)
				{
					protoFluxNodeGroup.Rebuild();
					num++;
				}
				else
				{
					_removeGroups = true;
				}
			}
			stopwatch.Stop();
			UniLog.Log($"Rebuild: {stopwatch.GetElapsedMilliseconds():F4} ms, Nodes: {_dirtyNodes.Count}, Groups: {_dirtyGroups.Count}");
			World.LastDirtyNodes += _dirtyNodes.Count;
			World.LastRebuiltNodeGroups += num;
			_dirtyGroups.Clear();
			_dirtyNodes.Clear();
		}

		public void RebuildAndCleanup()
		{
			RebuildChangeTracking();
			Rebuild();
			if (_removeGroups)
			{
				_groups.RemoveAll(delegate(ProtoFluxNodeGroup g)
				{
					if (g.ShouldBeRemoved)
					{
						g.Dispose();
						return true;
					}
					return false;
				});
				_removeGroups = false;
			}
			foreach (ProtoFluxEngineProxy item in _proxiesToCleanup)
			{
				if (item.AssociatedInstance == null)
				{
					item.Destroy();
				}
			}
			_proxiesToCleanup.Clear();
		}

		public void RunNodeUpdates()
		{
			lock (_groupsToUpdate)
			{
				int count = _groupsToUpdate.Count;
				for (int i = 0; i < count; i++)
				{
					_groupsToUpdate[i].RunNodeUpdates();
				}
				World.LastUpdatedNodeGroups = count;
			}
		}

		public void RunNodeEvents()
		{
			lock (_eventDispatchGroups)
			{
				int count = _eventDispatchGroups.Count;
				for (int i = 0; i < count; i++)
				{
					_eventDispatchGroups[i].RunNodeEvents();
				}
				_eventDispatchGroups.RemoveRange(0, count);
				World.LastNodeEvents = count;
			}
		}

		public void RunContinuousChanges()
		{
			lock (_groupsWithContinuousChanges)
			{
				int count = _groupsWithContinuousChanges.Count;
				for (int i = 0; i < count; i++)
				{
					_groupsWithContinuousChanges[i].RunNodeChanges();
				}
				World.LastContinuousChangeNodeGroups = count;
			}
		}

		public void RunDiscreteChanges()
		{
			int count = _changedGroups.Count;
			for (int i = 0; i < count; i++)
			{
				if (!_changedGroups[i].RegisteredForContinuousChanges)
				{
					_changedGroups[i].RunNodeChanges();
				}
			}
			World.LastChangedNodeGroups = count;
			_changedGroups.RemoveRange(0, count);
		}

		public void AbortAllContexts()
		{
			if (World.IsRunningLongBlockingTask)
			{
				return;
			}
			try
			{
				foreach (KeyValuePair<FrooxEngineContext, byte> activeContext in _activeContexts)
				{
					activeContext.Key.AbortExecution = true;
				}
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception aborting execution:\n" + ex);
			}
		}

