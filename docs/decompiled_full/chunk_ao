			type.GetMethod("Initialize", BindingFlags.Static | BindingFlags.Public)?.Invoke(null, null);
			MethodInfo method = type.GetMethod("MapNode", BindingFlags.Static | BindingFlags.Public);
			nodeMappers.Add((NodeMapper)method.CreateDelegate(typeof(NodeMapper)));
			Type? type2 = AppDomain.CurrentDomain.GetAssemblies().First((Assembly a) => a.FullName.Contains("ProtoFluxBindings")).GetType("ProtoFluxBindings.ProtoFluxMapper");
			type2.GetMethod("Initialize", BindingFlags.Static | BindingFlags.Public)?.Invoke(null, null);
			method = type2.GetMethod("MapNode", BindingFlags.Static | BindingFlags.Public);
			nodeMappers.Add((NodeMapper)method.CreateDelegate(typeof(NodeMapper)));
			Configuration.ActiveCultureProvider = (ICultureProvider)(Configuration.ToStringWrapper = new ProtoFluxConfig());
			int num = 0;
			foreach (Type type3 in workers)
			{
				if (type3.IsAbstract || !typeof(ProtoFluxNode).IsAssignableFrom(type3))
				{
					continue;
				}
				string text = type3.Name;
				int num3 = text.IndexOf('`');
				if (num3 > 0)
				{
					if (text.Contains("MethodProxy") || text.Contains("FunctionProxy"))
					{
						continue;
					}
					text = text.Substring(0, num3);
				}
				switch (text)
				{
				case "ValueIndirectWriteLatch":
				case "FireOnLocalObjectChange":
				case "ValueWriteLatch":
				case "FireOnLocalTrue":
				case "ObjectWriteLatch":
				case "FireOnLocalFalse":
				case "ValueWrite":
				case "DelayValue":
				case "ValueIncrement":
				case "ValueDecrement":
				case "ValueIndirectDecrement":
				case "ValueIndirectIncrement":
				case "ExternalImpulseDisplay":
				case "FireOnLocalValueChange":
				case "NewLine":
				case "ToLower":
				case "ToUpper":
				case "ObjectIndirectWriteLatch":
				case "ValueIndirectWrite":
				case "ObjectIndirectWrite":
				case "ObjectWrite":
				case "DynamicImpulseReceiverWithValue":
				case "DynamicImpulseTriggerWithValue":
				case "UpdatesDelayWithValue":
					continue;
				}
				num++;
				text = text.ToLower();
				if (!protoFluxNodes.ContainsKey(text))
				{
					protoFluxNodes.Add(text, type3);
					continue;
				}
				Type type4 = protoFluxNodes[text];
