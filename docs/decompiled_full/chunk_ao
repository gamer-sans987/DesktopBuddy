						protoFluxNode.Destroy();
					}
					hashSet2.Add(protoFluxNode2);
				}
				foreach (INode affectedEvaluatingNode in result.overload.AffectedEvaluatingNodes)
				{
					hashSet.Add(dictionary[affectedEvaluatingNode]);
				}
				foreach (INode affectedImpulsingNode in result.overload.AffectedImpulsingNodes)
				{
					hashSet.Add(dictionary[affectedImpulsingNode]);
				}
			}
			if (result.conversions != null)
			{
				foreach (InsertedConversion conversion in result.conversions)
				{
					ProtoFluxNode protoFluxNode3 = dictionary[conversion.targetNode];
					Type bindingForNode = ProtoFluxHelper.GetBindingForNode(conversion.conversion.GetType());
					Slot slot = protoFluxNode3.Slot.Parent.AddSlot(conversion.conversion.GetType().GetNiceName());
					ProtoFluxNode protoFluxNode4 = (ProtoFluxNode)slot.AttachComponent(bindingForNode);
					protoFluxNode4.AssociateInstance(GetGroup(conversion.conversion.Runtime), conversion.conversion);
					ProtoFluxNodeVisual visual = protoFluxNode3.GetVisual();
					Elements.Core.float3 globalPosition = protoFluxNode3.Slot.LocalPointToGlobal(Elements.Core.float3.Left * 128f * 0.75f * 0.00093750004f);
					if (visual != null)
					{
						protoFluxNode4.EnsureVisual();
						ProtoFluxInputProxy protoFluxInputProxy = ((!conversion.targetInput.IsDynamic) ? visual.GetFixedInputProxy(protoFluxNode3.NodeInstance.GetInputName(conversion.targetInput.index)) : visual.GetDynamicInputProxy(protoFluxNode3.NodeInstance.GetInputListName(conversion.targetInput.listIndex), conversion.targetInput.index));
