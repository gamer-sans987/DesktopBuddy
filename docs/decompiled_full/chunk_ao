	public static class ProtoFluxEngineProxyHelper
	{
		public static T GetProxy<T>(this IProtoFluxEngineProxyNode node, FrooxEngineContext context, bool createIfNotExists) where T : ProtoFluxEngineProxy, new()
		{
			List<IProtoFluxNode> path = Pool.BorrowList<IProtoFluxNode>();
			List<T> list = Pool.BorrowList<T>();
			context.CaptureEnginePath(path);
			Component rootContainer = context.GetRootContainer(node);
			IProtoFluxNode engineProxy = (IProtoFluxNode)rootContainer;
			rootContainer.Slot.GetComponents(list, (T p) => p.Matches(engineProxy, path));
			if (list.Count > 1)
			{
				list.Sort((T a, T b) => a.ReferenceID.CompareTo(b.ReferenceID));
			}
			T val = null;
			if (list.Count > 0)
			{
				val = list[0];
			}
			else if (createIfNotExists)
			{
				val = rootContainer.Slot.AttachComponent<T>();
				val.Node.Target = engineProxy;
				foreach (IProtoFluxNode item in path)
				{
					val.Path.Add(item);
				}
			}
			Pool.Return(ref path);
			Pool.Return(ref list);
			return val;
		}
	}
