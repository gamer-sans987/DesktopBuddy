		public static Elements.Core.colorX GetTypeColor(this Type type)
		{
			if (type == null)
			{
				return Elements.Core.colorX.Black;
			}
			if (type == typeof(bool))
			{
				return new Elements.Core.colorX(0.3f);
			}
			if (type == typeof(char))
			{
				return new Elements.Core.colorX(0.6392157f, 37f / 85f, 7f / 85f);
			}
			if (type == typeof(string))
			{
				return new Elements.Core.colorX(0.6392157f, 7f / 85f, 7f / 85f);
			}
			if (type == typeof(Elements.Core.color))
			{
				return COLOR_BASE_COLOR;
			}
			if (type == typeof(Elements.Core.colorX))
			{
				return COLORX_BASE_COLOR;
			}
			PrimitiveClass primitiveClass = type.ClassifyPrimitive();
			if (primitiveClass != PrimitiveClass.NONE)
			{
				if (type == typeof(decimal))
				{
					return DECIMAL_BASE_COLOR;
				}
				int primitiveClassRank = type.GetPrimitiveClassRank();
				int primitiveClassMaxRank = primitiveClass.GetPrimitiveClassMaxRank();
				float rankLerp = MathX.InverseLerp(0, primitiveClassMaxRank, primitiveClassRank);
				return LerpPrimitiveColor(primitiveClass switch
				{
					PrimitiveClass.SignedInteger => SIGNED_INT_BASE_COLOR, 
					PrimitiveClass.UnsignedInteger => UNSIGNED_INT_BASE_COLOR, 
					PrimitiveClass.FloatingPoint => FLOAT_BASE_COLOR, 
					_ => throw new ArgumentException("Invalid primitive class: " + primitiveClass), 
				}, rankLerp);
			}
			Type baseType = GetBaseType(type, typeof(IVector), typeof(IVector<>));
			if (baseType != null)
			{
				return baseType.GetTypeColor();
			}
			Type baseType2 = GetBaseType(type, typeof(IQuaternion), typeof(IQuaternion<>));
			if (baseType2 != null)
			{
				return LerpPrimitiveColor(in QUATERNION_BASE_COLOR, (baseType2 == typeof(double)) ? 1f : 0f);
			}
			Type baseType3 = GetBaseType(type, typeof(IMatrix), typeof(IMatrix<>));
			if (baseType3 != null)
			{
				return baseType3.GetTypeColor();
			}
			if (type == typeof(Slot))
			{
				return new Elements.Core.colorX(0.75f, 1f, 0.5f);
			}
			if (type == typeof(User))
			{
				return new Elements.Core.colorX(1f, 0.5f, 1f);
			}
			if (type.IsGenericType && type.IsValueType && type.GetGenericTypeDefinition() == typeof(Nullable<>))
			{
				return type.GetGenericArguments()[0].GetTypeColor().MulA(0.5f);
			}
			Crc32 crc = new Crc32();
			for (int i = 0; i < type.Name.Length; i++)
			{
				crc.Update(type.Name[i]);
			}
			long value = crc.Value;
			float h = (float)(value & 0xFF) / 255f;
			float lerp = (float)((value >> 8) & 0xFF) / 255f;
			float lerp2 = (float)((value >> 16) & 0xFF) / 255f;
			return (Elements.Core.colorX)new ColorHSV(h, MathX.LerpUnclamped(0.25f, 0.75f, lerp), MathX.LerpUnclamped(0.25f, 1f, lerp2)).ToRGB();
		}

		public static Type GetBaseType(Type type, Type interfaceBase, Type interfaceGeneric)
		{
			if (interfaceBase.IsAssignableFrom(type))
			{
				Type[] interfaces = type.GetInterfaces();
				foreach (Type type2 in interfaces)
				{
					if (type2.IsGenericType && type2.GetGenericTypeDefinition() == interfaceGeneric)
					{
						return type2.GetGenericArguments()[0];
					}
				}
			}
			return null;
		}

		private static Elements.Core.colorX LerpPrimitiveColor(in Elements.Core.colorX baseColor, float rankLerp)
		{
			return MathX.Lerp(Elements.Core.colorX.Black, in baseColor, 0.75f + rankLerp * 0.25f);
		}
	}
