		public static void AlignUsers(World world, bool parent = false)
		{
			List<UserRoot> list = (from u in world.AllUsers
				select u.Root into root
				where root != null && root.Slot.FindChild("Bases") != null
				select root).ToList();
			while (list.Count > 0)
			{
				Slot slot = list[0].Slot.FindChild("Bases");
				Slot slot2 = slot.FindChild("Base 0");
				Slot slot3 = slot.FindChild("Base 1");
				float num = MathX.Distance(slot2.LocalPosition, slot3.LocalPosition);
				for (int num2 = list.Count - 1; num2 > 0; num2--)
				{
					Slot slot4 = list[num2].Slot.FindChild("Bases");
					Slot slot5 = slot4.FindChild("Base 0");
					Slot slot6 = slot4.FindChild("Base 1");
					float num3 = MathX.Distance(slot5.LocalPosition, slot6.LocalPosition);
					if (MathX.Abs(num - num3) < 0.05f)
					{
						if (parent)
						{
							list[num2].Slot.SetParent(list[0].Slot);
						}
						Elements.Core.float3 @float = MathX.Abs(slot3.GlobalPointToLocal(slot2.GlobalPosition) - slot6.GlobalPointToLocal(slot5.GlobalPosition));
						Slot slot7 = ((!(@float.x > 0.1f) && !(@float.y > 0.1f) && !(@float.z > 0.1f)) ? slot5 : slot6);
						Elements.Core.float3 to = slot2.Forward.x_z.Normalized;
						Elements.Core.float3 from = slot7.Forward.x_z.Normalized;
						list[num2].Slot.GlobalRotation = Elements.Core.floatQ.FromToRotation(in from, in to) * list[num2].Slot.GlobalRotation;
						Elements.Core.float3 b = slot7.GlobalPosition - slot2.GlobalPosition;
						Slot slot8 = list[num2].Slot;
						slot8.GlobalPosition -= b;
						list.RemoveAt(num2);
					}
				}
				list.RemoveAt(0);
			}
		}
	}
