		[SyncMethod(typeof(Delegate), null)]
		private void OnCreateDelegateProxy(IButton button, ButtonEventData eventData, Delegate target)
		{
			MethodInfo methodInfo = target.GetMethodInfo();
			ParameterInfo[] parameters = methodInfo.GetParameters();
			if (parameters.Length > 8)
			{
				throw new NotSupportedException("Methods with more than 8 parameters are not supported");
			}
			Type type = methodInfo.ReturnType;
			Type type2;
			if (type == typeof(void))
			{
				type2 = typeof(SyncMethodProxy);
			}
			else if (type == typeof(Task))
			{
				type2 = typeof(AsyncMethodProxy);
				type = typeof(void);
			}
			else if (!type.IsGenericType || !(type.GetGenericTypeDefinition() == typeof(Task<>)))
			{
				type2 = ((!type.IsUnmanaged()) ? typeof(SyncObjectFunctionProxy<>) : typeof(SyncValueFunctionProxy<>));
			}
			else
			{
				Type obj = type.GetGenericArguments()[0];
				type2 = ((!obj.IsUnmanaged()) ? typeof(AsyncObjectFunctionProxy<>) : typeof(AsyncValueFunctionProxy<>));
				type = obj;
			}
			if (parameters.Length != 0)
			{
				int num = 0;
				for (int i = 0; i < parameters.Length; i++)
				{
					if (!parameters[i].ParameterType.IsUnmanaged())
					{
						num |= 1 << i;
					}
				}
				List<Type> list = new List<Type>(parameters.Select((ParameterInfo p) => p.ParameterType));
				if (type != typeof(void))
				{
					list.Add(type);
				}
				Type type3 = type2;
				string text = type3.FullName;
				int num2 = text.IndexOf('`');
				if (num2 >= 0)
				{
					text = text.Substring(0, num2);
				}
				string text2 = text.Replace("Proxy", $"Proxy_{num:X4}`{list.Count}");
				type2 = Type.GetType(text2);
				if (type2 == null)
				{
					throw new InvalidOperationException($"Proxy node not found for parameter mask: {num:X4}\nBaseType: {type3}, \nReturn Type: {type}\nFullName: {text2}");
				}
				type2 = type2.MakeGenericType(list.ToArray());
			}
			else if (type2.IsGenericType)
			{
				type2 = type2.MakeGenericType(type);
			}
			Type bindingForNode = ProtoFluxHelper.GetBindingForNode(type2);
			ProtoFluxNode protoFluxNode = SpawnNode(bindingForNode);
			Type type4 = (Type)type2.GetProperty("DelegateType", BindingFlags.Static | BindingFlags.Public | BindingFlags.FlattenHierarchy).GetValue(null);
			if (type4 == null)
			{
				throw new NullReferenceException("Could not determine delegate type");
			}
			Type type5 = typeof(GlobalDelegate<>).MakeGenericType(type4);
			IGlobalValueProxy globalValueProxy = (IGlobalValueProxy)protoFluxNode.Slot.AttachComponent(type5);
			globalValueProxy.TrySetValue(target);
			protoFluxNode.GetGlobalRef(0).TrySet(globalValueProxy);
			base.ActiveHandler?.CloseContextMenu();
		}

