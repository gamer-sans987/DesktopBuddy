		{
			if (target is ProtoFluxNode protoFluxNode)
			{
				ProtoFluxNodeVisual visual = protoFluxNode.EnsureVisual();
				TProxy fixedProxy = GetFixedProxy(visual, "*");
				if (fixedProxy == null)
				{
					throw new ArgumentNullException($"Proxy for implicit element node on {GetType()} is null. Node:\n{protoFluxNode}");
				}
				SetupWire(wire, protoFluxNode, fixedProxy);
			}
			else if (target.Parent is ProtoFluxNode protoFluxNode2)
			{
				ProtoFluxNodeVisual visual2 = protoFluxNode2.EnsureVisual();
				TProxy fixedProxy2 = GetFixedProxy(visual2, target.Name);
				if (fixedProxy2 == null)
				{
					throw new ArgumentNullException($"Proxy for element {target.Name} node on {GetType()} is null. Node:\n{protoFluxNode2}");
				}
				SetupWire(wire, protoFluxNode2, fixedProxy2);
			}
			else if (target.Parent is ISyncList syncList)
			{
				int num = syncList.IndexOfElement((ISyncMember)target);
				ProtoFluxNode protoFluxNode3 = (ProtoFluxNode)syncList.Parent;
				ProtoFluxNodeVisual visual3 = protoFluxNode3.EnsureVisual();
				TProxy dynamicProxy = GetDynamicProxy(visual3, syncList.Name, num);
