		private static Type MapReference(Type argument)
		{
			if (argument.IsGenericType)
			{
				Type genericTypeDefinition = argument.GetGenericTypeDefinition();
				if (genericTypeDefinition == typeof(IValue<>) || genericTypeDefinition == typeof(IField<>))
				{
					Type type = argument.GenericTypeArguments[0];
					if (type == typeof(User))
					{
						return typeof(UserRefSource);
					}
					if (type == typeof(Slot))
					{
						return typeof(SlotRefSource);
					}
					if (typeof(IWorldElement).IsAssignableFrom(type))
					{
						return typeof(ReferenceSource<>).MakeGenericType(argument);
					}
				}
			}
			if (argument == typeof(Slot))
			{
				return typeof(SlotSource);
			}
			if (argument == typeof(UserRef))
			{
				return typeof(UserRefSource);
			}
			return typeof(ElementSource<>).MakeGenericType(argument);
		}

		public static ProtoFluxTypeMapping MapNode(string name, string @namespace)
		{
			if (name == "ImpulseRelay")
			{
				return typeof(ContinuationRelay);
			}
			if (name.StartsWith("Equals_floatQ"))
			{
				return typeof(Approximately_FloatQ);
			}
			if (name.StartsWith("NotEquals_floatQ"))
			{
				return typeof(ApproximatelyNot_FloatQ);
			}
			if (name.StartsWith("Equals_doubleQ"))
			{
				return typeof(Approximately_DoubleQ);
			}
			if (name.StartsWith("NotEquals_doubleQ"))
			{
				return typeof(ApproximatelyNot_DoubleQ);
			}
			switch (name)
			{
			case "ZeroOne":
				return typeof(ZeroOneFloat);
			case "SigmoidNode":
				return typeof(SigmoidFloat);
			case "TrajectoryNode":
				return typeof(TrajectoryPosition);
			case "EmptyBoundingBox":
				return typeof(Empty);
			case "BoundingBoxFromCenterSize":
				return typeof(FromCenterSize);
			case "DrivePlaybackNode":
				return typeof(PlaybackDrive);
			default:
				name = name.Replace("SmallerOrEqual", "LessOrEqual");
				switch (name)
				{
				case "SequenceImpulse":
					return typeof(Sequence);
				case "Cast_string_To_Uri":
					return typeof(StringToAbsoluteURI);
				case "Cast_char_To_string":
					return typeof(CharToString);
				case "Add_DateTimeTimeSpan":
					return typeof(Add_DateTime_TimeSpan);
				case "Sub_DateTimeTimeSpan":
					return typeof(Sub_DateTime_TimeSpan);
				default:
					foreach (KeyValuePair<string, ProtoFluxTypeMapping> genericMapping in genericMappings)
					{
						if (name.StartsWith(genericMapping.Key))
						{
							return genericMapping.Value;
						}
					}
					if (name.StartsWith("RelayNode") || name.StartsWith("CacheNode"))
					{
						return new ProtoFluxTypeMapping(typeof(ValueRelay<>), typeof(ObjectRelay<>));
					}
					if (name.StartsWith("UpdatingRelayNode"))
					{
						return new ProtoFluxTypeMapping(typeof(ContinuouslyChangingValueRelay<>), typeof(ContinuouslyChangingObjectRelay<>));
					}
					return null;
				}
			}
		}
	}
