		public void RemoveElement(IButton button, ButtonEventData eventData)
		{
			if (List.Target != null && List.Target.Count != 0)
			{
				List.Target.RemoveElement(List.Target.Count - 1);
			}
		}

		internal void GenerateList(ProtoFluxNodeVisual visual, UIBuilder ui, ISyncList list)
		{
			ui.Style.MinHeight = 32f;
			ui.NestInto(base.Slot);
			for (int i = 0; i < list.Count; i++)
			{
				Slot slot;
				if (_elements.Count <= i)
				{
					slot = GenerateElement(visual, ui, i);
					_elements.Add(slot);
				}
				else
				{
					slot = _elements[i];
				}
				slot.OrderOffset = i;
			}
			while (_elements.Count > list.Count)
			{
				_elements[_elements.Count - 1].Destroy();
				_elements.RemoveAt(_elements.Count - 1);
			}
			ui.NestOut();
			AddButtonEnabled.Target.Value = true;
			RemoveButtonEnabled.Target.Value = list.Count > MinElements.Value;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			ISyncList target = List.Target;
			if (target != null)
			{
				ProtoFluxNodeVisual target2 = Visual.Target;
				if (target2 != null)
				{
					UIBuilder localUIBuilder = target2.LocalUIBuilder;
					GenerateList(target2, localUIBuilder, target);
				}
			}
		}

		protected abstract Slot GenerateElement(ProtoFluxNodeVisual visual, UIBuilder ui, int index);

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Visual = new SyncRef<ProtoFluxNodeVisual>();
			List = new RelayRef<ISyncList>();
			MinElements = new Sync<int>();
			AddButtonEnabled = new FieldDrive<bool>();
			RemoveButtonEnabled = new FieldDrive<bool>();
			_elements = new SyncRefList<Slot>();
		}
