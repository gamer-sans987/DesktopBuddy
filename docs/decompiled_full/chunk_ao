			if (_currentTempWire.Target != null || _initialPressSpace == null)
			{
				return;
			}
			if (_initialPressSpace != base.LocalUserSpace)
			{
				_initialPressSpace = null;
				return;
			}
			if (_currentCutLine.Target == null)
			{
				Elements.Core.float3 b = base.LocalUserSpace.GlobalPointToLocal(WireDeletionPoint);
				if (MathX.Distance(in _initialPressPoint, in b) / (base.LocalUser.Root?.LocalScale ?? 1f) > 0.02f)
				{
					Slot slot = base.LocalUserSpace.AddSlot("WireCutLine", persistent: false);
					CylinderMesh sharedComponentOrCreate = base.World.GetSharedComponentOrCreate("ProtoFluxCylinderMesh", delegate(CylinderMesh c)
					{
						c.Radius.Value = 0.0025f;
						c.Height.Value = 1f;
					});
					FresnelMaterial sharedComponentOrCreate2 = base.World.GetSharedComponentOrCreate("ProtoFluxWireCutMaterial", delegate(FresnelMaterial c)
					{
						c.NearColor.Value = new Elements.Core.colorX(1.5f, 1f, 1f);
						c.FarColor.Value = new Elements.Core.colorX(1.5f, 0f, 0f);
						c.Exponent.Value = 0.5f;
						c.BlendMode.Value = BlendMode.Opaque;
					});
					Slot slot2 = slot.AddSlot("Mesh");
					slot2.AttachMesh(sharedComponentOrCreate, sharedComponentOrCreate2);
					slot2.LocalPosition = Elements.Core.float3.Forward * 0.5f;
					slot2.LocalRotation = Elements.Core.floatQ.AxisAngle(Elements.Core.float3.Right, 90f);
					slot.LocalPosition = b;
					this.DestroyWhenDestroyed(slot, cleanupProxy: true, persistent: false);
					_currentCutLine.Target = slot;
					_cutLineOrientation.Target = slot.Rotation_Field;
					_cutLineScale.Target = slot.Scale_Field;
				}
				return;
			}
			UpdateInteractionDistance((ICollider c) => c.Slot.GetComponent<ProtoFluxWireManager>() != null);
			if (_cutWires == null)
			{
				_cutWires = Pool.BorrowHashSet<ProtoFluxWireManager>();
			}
			HashSet<ProtoFluxWireManager> toRemove = Pool.BorrowHashSet<ProtoFluxWireManager>();
			foreach (ProtoFluxWireManager cutWire in _cutWires)
			{
				toRemove.Add(cutWire);
			}
			if (RaycastWireDeletion)
			{
				Elements.Core.float3 b2 = _initialPressSpace.LocalPointToGlobal(in _initialPressPoint);
				float magnitude;
				Elements.Core.float3 direction = (base.Tip - b2).GetNormalized(out magnitude);
				if (!MathX.Approximately(magnitude, 0f))
				{
					List<RaycastHit> list = Pool.BorrowList<RaycastHit>();
					base.Physics.RaycastAll(in b2, in direction, magnitude, list);
					foreach (RaycastHit item in list)
					{
						ProcessCollider(item.Collider);
					}
					Pool.Return(ref list);
				}
			}
			else
			{
				Elements.Core.float3 v = _initialPressSpace.LocalPointToGlobal(in _initialPressPoint) - base.World.LocalUserViewPosition;
				v = base.World.LocalUserViewRotation.Inverted * v;
				float z = base.InteractionDistance ?? v.z;
				v = new Elements.Core.float3(v.xy, z);
				v = base.World.LocalUserViewRotation * v + base.World.LocalUserViewPosition;
				Elements.Core.float3 v2 = InteractionPointPosition - base.World.LocalUserViewPosition;
				v2 = new Elements.Core.float3((base.World.LocalUserViewRotation.Inverted * v2).xy, z);
				v2 = base.World.LocalUserViewRotation * v2 + base.World.LocalUserViewPosition;
				_ = v2 - v;
				List<ICollider> list2 = Pool.BorrowList<ICollider>();
				Elements.Core.float3 origin = (v + v2) * 0.5f;
				float magnitude2;
				Elements.Core.float3 up = (v2 - v).GetNormalized(out magnitude2);
				Elements.Core.float3 size = new Elements.Core.float3(0.002f, magnitude2, 0.1f) * base.LocalUserRoot.GlobalScale;
				Elements.Core.floatQ orientation = Elements.Core.floatQ.LookRotation(base.World.LocalUserViewRotation * Elements.Core.float3.Forward, in up);
				base.Physics.BoxOverlap(in origin, in orientation, in size, list2);
				foreach (ICollider item2 in list2)
				{
					ProcessCollider(item2);
				}
				Pool.Return(ref list2);
			}
			foreach (ProtoFluxWireManager item3 in toRemove)
			{
				item3.DeleteHighlight.Value = false;
				_cutWires.Remove(item3);
			}
			Pool.Return(ref toRemove);
			void ProcessCollider(ICollider collider)
			{
				ProtoFluxWireManager component = collider.Slot.GetComponent<ProtoFluxWireManager>();
				if (component != null && !toRemove.Remove(component))
				{
					component.DeleteHighlight.Value = true;
					_cutWires.Add(component);
				}
			}
		}

		public override void OnSecondaryPress()
		{
			base.OnSecondaryPress();
			if (_currentProxy.Target != null)
			{
				ProtoFluxElementProxy target = _currentProxy.Target;
				if (!(target is ProtoFluxInputProxy protoFluxInputProxy))
				{
					if (!(target is ProtoFluxOutputProxy protoFluxOutputProxy))
					{
						if (!(target is ProtoFluxOperationProxy protoFluxOperationProxy))
						{
							if (target is ProtoFluxImpulseProxy protoFluxImpulseProxy)
							{
								ProtoFluxNode protoFluxNode = SpawnNode(ProtoFluxHelper.CallDisplay);
								protoFluxImpulseProxy.Node.Target.TryConnectImpulse(protoFluxImpulseProxy.NodeImpulse.Target, protoFluxNode.GetOperation(0), undoable: true);
							}
						}
						else
						{
							ProtoFluxNode protoFluxNode = SpawnNode(protoFluxOperationProxy.IsAsync.Value ? ProtoFluxHelper.AsyncCallInput : ProtoFluxHelper.SyncCallInput);
							protoFluxNode.TryConnectImpulse(protoFluxNode.GetImpulse(0), protoFluxOperationProxy.NodeOperation.Target, undoable: true);
							CleanupDraggedWire();
						}
					}
					else
					{
						Type displayNode = ProtoFluxHelper.GetDisplayNode(protoFluxOutputProxy.OutputType.Value);
						if (displayNode != null)
						{
							ProtoFluxNode protoFluxNode = SpawnNode(displayNode);
							protoFluxNode.TryConnectInput(protoFluxNode.GetInput(0), protoFluxOutputProxy.NodeOutput.Target, allowExplicitCast: false, undoable: true);
							CleanupDraggedWire();
						}
					}
				}
				else
				{
					Type inputNode = ProtoFluxHelper.GetInputNode(protoFluxInputProxy.InputType.Value);
					if (inputNode != null)
					{
						ProtoFluxNode protoFluxNode = SpawnNode(inputNode);
						if (protoFluxInputProxy.Node.Target.TryConnectInput(protoFluxInputProxy.NodeInput.Target, protoFluxNode.GetOutput(0), allowExplicitCast: false, undoable: true))
						{
							((IInput)protoFluxNode).BoxedValue = protoFluxInputProxy.DefaultValue;
						}
						CleanupDraggedWire();
					}
				}
				CleanupDraggedWire();
			}
			else
			{
				_lastSecondaryPress = DateTime.UtcNow;
			}
		}

		public override void OnSecondaryHold()
		{
			base.OnSecondaryHold();
			SelectionProgress.Value = ActivateSelectionProgress;
			if (!ActivateSelection)
			{
				return;
			}
			_lastSecondaryPress = null;
			RaycastHit? hit = GetHit();
			if (!hit.HasValue)
			{
				return;
			}
			ProtoFluxNodeVisual componentInParents = hit.Value.Collider.Slot.GetComponentInParents<ProtoFluxNodeVisual>();
			ProtoFluxNodeGroup protoFluxNodeGroup = componentInParents?.Node.Target?.Group;
			if (protoFluxNodeGroup == null)
			{
				return;
			}
			List<ProtoFluxNodeVisual> list = Pool.BorrowList<ProtoFluxNodeVisual>();
			foreach (ProtoFluxNodeVisual selectedNode in _selectedNodes)
			{
				list.Add(selectedNode);
			}
			if (list.Contains(componentInParents))
			{
				foreach (ProtoFluxNode node in protoFluxNodeGroup.Nodes)
				{
					ProtoFluxNodeVisual visual = node.GetVisual();
					if (visual != null)
					{
						visual.IsSelected.Value = false;
						_selectedNodes.Remove(visual);
					}
				}
			}
			else
			{
				foreach (ProtoFluxNode node2 in protoFluxNodeGroup.Nodes)
				{
					ProtoFluxNodeVisual protoFluxNodeVisual = node2.EnsureVisual();
					if (!list.Contains(protoFluxNodeVisual))
					{
						_selectedNodes.Add(protoFluxNodeVisual);
					}
				}
			}
			Pool.Return(ref list);
			MarkSelection();
		}

		public override void OnSecondaryRelease()
		{
			SelectionProgress.Value = 0f;
			if (_lastSecondaryPress.HasValue)
			{
				RaycastHit? hit = GetHit();
				if (hit.HasValue)
				{
					ProtoFluxNode componentInParents = hit.Value.Collider.Slot.GetComponentInParents<ProtoFluxNode>();
					if (componentInParents != null)
					{
						SpawnNodeType.Value = componentInParents.GetType();
					}
				}
			}
			_lastSecondaryPress = null;
		}

		public override void OnPrimaryRelease()
		{
			base.OnPrimaryRelease();
			ResetIntractionDistance();
			if (_currentCutLine.Target != null)
			{
				_currentCutLine.Target.Destroy();
				if (_cutWires != null)
				{
					if (_cutWires.Count > 0)
					{
						base.World.BeginUndoBatch("Cut ProtoFlux Wires");
						foreach (ProtoFluxWireManager cutWire in _cutWires)
						{
							cutWire.Slot.GetComponentInParents<ProtoFluxElementProxy>()?.Disconnect(undoable: true);
						}
						base.World.EndUndoBatch();
					}
					Pool.Return(ref _cutWires);
				}
			}
			if (_currentProxy.Target != null)
			{
				ProtoFluxElementProxy target = _currentProxy.Target;
				if (!(target is ProtoFluxInputProxy input))
				{
					ProtoFluxOutputProxy protoFluxOutputProxy = target as ProtoFluxOutputProxy;
					if (protoFluxOutputProxy == null)
					{
						if (!(target is ProtoFluxOperationProxy operation))
						{
							if (target is ProtoFluxImpulseProxy impulse)
							{
								ProtoFluxOperationProxy protoFluxOperationProxy = FindProxy<ProtoFluxOperationProxy>();
								if (protoFluxOperationProxy != null)
								{
									TryConnect(impulse, protoFluxOperationProxy);
								}
							}
						}
						else
						{
							ProtoFluxImpulseProxy protoFluxImpulseProxy = FindProxy<ProtoFluxImpulseProxy>();
							if (protoFluxImpulseProxy != null)
							{
								TryConnect(protoFluxImpulseProxy, operation);
							}
						}
					}
					else
					{
						IProtoFluxOutputReceiver protoFluxOutputReceiver = FindProxy<IProtoFluxOutputReceiver>();
						if (protoFluxOutputReceiver != null)
						{
							if (protoFluxOutputReceiver is ProtoFluxInputProxy input2)
							{
								TryConnect(input2, protoFluxOutputProxy);
							}
							else
							{
								ProtoFluxGlobalRefProxy globalRefProxy = protoFluxOutputReceiver as ProtoFluxGlobalRefProxy;
								if (globalRefProxy != null)
								{
									StartTask(async delegate
									{
										ContextMenu obj = await base.LocalUser.OpenContextMenu(this, base.ActiveHandler?.Slot);
										ContextMenuItem contextMenuItem = obj.AddItem("Tools.ProtoFlux.Drive".AsLocaleKey(), OfficialAssets.Graphics.Icons.Tool.Drive, (Elements.Core.colorX?)null);
										ContextMenuItem contextMenuItem2 = obj.AddItem("Tools.ProtoFlux.Write".AsLocaleKey(), OfficialAssets.Graphics.Icons.Tool.Drive, (Elements.Core.colorX?)null);
										contextMenuItem.Button.LocalPressed += [SyncMethod(typeof(Delegate), null)] (IButton button, ButtonEventData data) =>
										{
											OnDriveGlobalRef(button, data, globalRefProxy, protoFluxOutputProxy);
										};
										contextMenuItem2.Button.LocalPressed += [SyncMethod(typeof(Delegate), null)] (IButton button, ButtonEventData data) =>
										{
											OnWriteGlobalRef(button, data, globalRefProxy, protoFluxOutputProxy);
										};
									});
								}
								else
								{
									if (!(protoFluxOutputReceiver is ProtoFluxReferenceProxy reference))
									{
										throw new NotImplementedException($"Unsupported outout receiver: {protoFluxOutputReceiver}");
									}
									TryConnect(reference, protoFluxOutputProxy.Slot.GetComponentInParents<ProtoFluxNodeVisual>());
								}
							}
						}
					}
				}
				else
				{
					ProtoFluxOutputProxy protoFluxOutputProxy2 = FindProxy<ProtoFluxOutputProxy>();
					if (protoFluxOutputProxy2 != null)
					{
						TryConnect(input, protoFluxOutputProxy2);
					}
				}
				CleanupDraggedWire();
			}
			_initialPressSpace = null;
		}

		public override bool OnGrabbing(bool isLaserGrab, List<ICollider> colliders)
		{
			if (!isLaserGrab)
			{
				return false;
			}
			RaycastHit? hit = GetHit();
			if (hit?.Collider == null)
			{
				return false;
			}
			if (_selectedNodes.Count > 0)
			{
				ProtoFluxNodeVisual component = hit.Value.Collider.Slot.GetComponent<ProtoFluxNodeVisual>();
				if (component != null && _selectedNodes.Contains(component))
				{
					foreach (ProtoFluxNodeVisual selectedNode in _selectedNodes)
					{
						if (selectedNode != null)
						{
							ICollider component2 = selectedNode.Slot.GetComponent<ICollider>();
							if (component2 != null)
							{
								colliders.Add(component2);
							}
						}
					}
					return true;
				}
			}
			ProtoFluxElementProxy componentInParents = hit.Value.Collider.Slot.GetComponentInParents<ProtoFluxElementProxy>();
			if (componentInParents == null)
			{
				return false;
			}
			ProtoFluxNode protoFluxNode = componentInParents.InsertRelay();
			if (protoFluxNode == null)
			{
				return false;
			}
			protoFluxNode.Slot.Parent = base.LocalUserSpace;
			if (RaycastWireDeletion)
			{
				protoFluxNode.Slot.GlobalPosition = hit.Value.Point;
			}
			else
			{
				protoFluxNode.Slot.GlobalPosition = InteractionPointPosition;
			}
			protoFluxNode.Slot.GlobalRotation = InteractionPointOrientation;
			protoFluxNode.Slot.GlobalScale = Elements.Core.float3.One * base.LocalUserRoot.GlobalScale;
			Elements.Core.float3 a = protoFluxNode.Slot.GlobalPointToLocal(componentInParents.ConnectPoint.Target.GlobalPosition);
			if (componentInParents is ProtoFluxImpulseProxy || componentInParents is ProtoFluxOperationProxy)
			{
				a *= new Elements.Core.float3(-1f, 1f, 1f);
			}
			if (a.x < 0f)
			{
				protoFluxNode.Slot.Forward = -protoFluxNode.Slot.Forward;
			}
			protoFluxNode.EnsureVisual();
			colliders.Add(protoFluxNode.Slot.GetComponentInChildren<ICollider>());
			return true;
		}

