		public void StartDraggingWire(ProtoFluxElementProxy proxy)
		{
			_currentProxy.Target = proxy;
			proxy.Slot.GetComponentInParents<Canvas>();
			Slot slot = proxy.ConnectPoint.Target.AddSlot("TempWire", persistent: false);
			this.DestroyWhenDestroyed(slot, cleanupProxy: true, persistent: false);
			ProtoFluxWireManager protoFluxWireManager = slot.AttachComponent<ProtoFluxWireManager>();
			protoFluxWireManager.ConnectPoint.Target = WirePoint.Target;
			protoFluxWireManager.Setup(proxy.IsOutput ? WireType.Output : WireType.Input, proxy.WireWidth, proxy.WireColor, proxy.AtlasIndex, collider: false, !proxy.IsOutput);
			protoFluxWireManager.EndColor.Value = proxy.WireColor;
			_currentTempWire.Target = slot;
		}

