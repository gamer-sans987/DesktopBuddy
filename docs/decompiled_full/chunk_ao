	public class ProtoFluxWireManager : Component
	{
		public static int WIRE_ATLAS_IMAGE_COUNT = 5;

		public static float WIRE_ATLAS_RATIO = 1f / (float)WIRE_ATLAS_IMAGE_COUNT;

		public static float TANGENT_MAGNITUDE = 128f;

		public static readonly Elements.Core.floatQ WIRE_ORIENTATION_INPUT = Elements.Core.floatQ.AxisAngleRad(Elements.Core.float3.Forward, MathF.PI / 2f);

		public static readonly Elements.Core.floatQ WIRE_ORIENTATION_OUTPUT = Elements.Core.floatQ.AxisAngleRad(Elements.Core.float3.Backward, MathF.PI / 2f);

		public static readonly Elements.Core.floatQ WIRE_ORIENTATION_REFERENCE = Elements.Core.floatQ.Identity;

		public readonly TransformRelayRef ConnectPoint;

		public readonly Sync<WireType> Type;

		public readonly Sync<float> Width;

		public readonly Sync<Elements.Core.colorX> StartColor;

		public readonly Sync<Elements.Core.colorX> EndColor;

		[NonPersistent]
		public readonly Sync<bool> DeleteHighlight;

		protected readonly SyncRef<StripeWireMesh> _wireMesh;

		protected readonly SyncRef<MeshRenderer> _renderer;

		protected readonly SyncRef<MeshCollider> _collider;

		protected readonly FieldDrive<Elements.Core.float3> _targetPosition;

		protected readonly FieldDrive<Elements.Core.float3> _targetTangent;

		protected readonly FieldDrive<Elements.Core.floatQ> _targetOrientation;

		protected readonly FieldDrive<float> _targetWidth;

		public static Elements.Core.floatQ GetWireOrientation(WireType wireType)
		{
			return wireType switch
			{
				WireType.Input => WIRE_ORIENTATION_INPUT, 
				WireType.Output => WIRE_ORIENTATION_OUTPUT, 
				WireType.Reference => WIRE_ORIENTATION_REFERENCE, 
				_ => throw new ArgumentException("Invalid wire type: " + wireType), 
			};
		}

		public static Elements.Core.float3 GetWireTangent(WireType wireType)
		{
			return wireType switch
			{
				WireType.Input => Elements.Core.float3.Right, 
				WireType.Output => Elements.Core.float3.Left, 
				WireType.Reference => Elements.Core.float3.Down, 
				_ => throw new ArgumentException("Invalid wire type: " + wireType), 
			};
		}

		public void Setup(WireType type, float width, Elements.Core.colorX startColor, int atlasOffset, bool collider = true, bool reverseTexture = false)
		{
			try
			{
				base.World.UpdateManager.NestCurrentlyUpdating(this);
				Type.Value = type;
				StripeWireMesh target = _wireMesh.Target;
				target.Tangent0.Value = ((type == WireType.Output) ? Elements.Core.float3.Right : Elements.Core.float3.Left) * TANGENT_MAGNITUDE;
				target.Orientation0.Value = ((type == WireType.Output) ? WIRE_ORIENTATION_OUTPUT : WIRE_ORIENTATION_INPUT);
				target.Orientation1.Value = GetWireOrientation(type);
				target.Width0.Value = width;
				Width.Value = width;
				StartColor.Value = startColor;
				target.Color0.Value = startColor;
				target.Color1.Value = startColor;
				if (collider)
				{
					if (_collider.Target == null)
					{
						_collider.Target = base.Slot.AttachComponent<MeshCollider>();
						_collider.Target.Sidedness.Value = MeshColliderSidedness.DualSided;
						_collider.Target.Mesh.Target = _wireMesh.Target;
					}
				}
				else
				{
					_collider.Target?.Destroy();
				}
				target.UVScale.Value = new Elements.Core.float2(reverseTexture ? (-1f) : 1f, WIRE_ATLAS_RATIO);
				target.UVOffset.Value = new Elements.Core.float2(0f, (float)(WIRE_ATLAS_IMAGE_COUNT - 1 - atlasOffset) * WIRE_ATLAS_RATIO);
			}
			finally
			{
				base.World.UpdateManager.PopCurrentlyUpdating(this);
			}
		}

		protected override void OnAwake()
		{
			base.Slot.WorldTransformChanged += Slot_WorldTransformChanged;
			base.OnAwake();
		}

		private void Slot_WorldTransformChanged(Slot slot)
		{
			MarkChangeDirty();
		}

		protected override void OnDispose()
		{
			base.Slot.WorldTransformChanged -= Slot_WorldTransformChanged;
			base.OnDispose();
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			FresnelMaterial sharedComponentOrCreate = base.World.GetSharedComponentOrCreate("ProtoFlux_WireMaterial", delegate(FresnelMaterial fresnel)
			{
				fresnel.NearColor.Value = new Elements.Core.colorX(0.8f);
				fresnel.FarColor.Value = new Elements.Core.colorX(1.4f);
				fresnel.Sidedness.Value = Sidedness.Double;
				fresnel.UseVertexColors.Value = true;
				fresnel.BlendMode.Value = BlendMode.Alpha;
				fresnel.ZWrite.Value = ZWrite.On;
				StaticTexture2D target = fresnel.Slot.AttachTexture(OfficialAssets.Graphics.ProtoFlux.Wire_Atlas);
				fresnel.NearTexture.Target = target;
				fresnel.FarTexture.Target = target;
			});
			MeshRenderer renderer;
			StripeWireMesh stripeWireMesh = base.Slot.AttachMesh<StripeWireMesh>(sharedComponentOrCreate, out renderer);
			stripeWireMesh.Steps.Value = 16;
			_wireMesh.Target = stripeWireMesh;
			_renderer.Target = renderer;
			_targetPosition.Target = stripeWireMesh.Point1;
			_targetTangent.Target = stripeWireMesh.Tangent1;
			_targetOrientation.Target = stripeWireMesh.Orientation1;
			_targetWidth.Target = stripeWireMesh.Width1;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			Slot target = ConnectPoint.Target;
			if (target == null)
			{
				Destroy();
				return;
			}
			Elements.Core.float3 b = base.Slot.GlobalPointToLocal(target.GlobalPosition);
			Elements.Core.float3 b2 = base.Slot.SpaceVectorToLocal(GetWireTangent(Type) * TANGENT_MAGNITUDE, target);
			Elements.Core.floatQ b3 = base.Slot.SpaceRotationToLocal(GetWireOrientation(Type), target);
			float num = base.Slot.SpaceScaleToLocal(Width.Value, target);
			if (FrooxEngine.Engine.IsAprilFools)
			{
				MysterySettings? activeSetting = Settings.GetActiveSetting<MysterySettings>();
				if (activeSetting != null && activeSetting.Difficulty.Value == MysterySettings.ResoniteDifficulty.Hard)
				{
					num *= 0.25f;
				}
			}
			if (ShouldUpdate(_targetPosition.Target.Value, in b) || ShouldUpdate(_targetTangent.Target.Value, in b2) || ShouldUpdate(_targetOrientation.Target.Value, in b3) || Shouldupdate(_targetWidth.Target.Value, num))
			{
				if (_targetPosition.IsLinkValid)
				{
					_targetPosition.Target.Value = b;
				}
				if (_targetTangent.IsLinkValid)
				{
					_targetTangent.Target.Value = b2;
				}
				if (_targetOrientation.IsLinkValid)
				{
					_targetOrientation.Target.Value = b3;
				}
				if (_targetWidth.IsLinkValid)
				{
					_targetWidth.Target.Value = num;
				}
			}
			Elements.Core.colorX value;
			Elements.Core.colorX value2;
			if (DeleteHighlight.Value)
			{
				value = (value2 = Elements.Core.colorX.Red.SetA(0.5f));
			}
			else
			{
				value = StartColor.Value;
				value2 = EndColor.Value;
			}
			_wireMesh.Target.Color0.Value = value;
			_wireMesh.Target.Color1.Value = value2;
		}

		private bool ShouldUpdate(in Elements.Core.floatQ a, in Elements.Core.floatQ b)
		{
			return MathX.DistanceSqr((Elements.Core.float4)a, (Elements.Core.float4)b) > 0.025f;
		}

		private bool ShouldUpdate(in Elements.Core.float3 a, in Elements.Core.float3 b)
		{
			return MathX.DistanceSqr(in a, in b) >= 0.025f;
		}

		private bool Shouldupdate(float a, float b)
		{
			return MathX.Abs(a - b) >= 0.025f;
		}

