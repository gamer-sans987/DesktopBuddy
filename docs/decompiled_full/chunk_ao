		private void OnElementsRemoving(SyncElementList<SyncRef<Slot>> list, int startIndex, int count)
		{
			for (int i = 0; i < count; i++)
			{
				Slot target = list[startIndex + i].Target;
				target?.RunSynchronously(target.Destroy);
			}
		}

		[SyncMethod(typeof(ButtonEventHandler), new string[] { })]
		public void AddElement(IButton button, ButtonEventData eventData)
		{
			if (List.Target != null)
			{
				List.Target.AddElement();
			}
		}

