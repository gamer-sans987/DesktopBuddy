				}
				if (scopePoint != null)
				{
					executionRuntime.RestoreSharedScope(scopePoint, context, valuesStore, objectsStore);
				}
				if (protoFluxBuildContext.GlobalsCount > 0)
				{
					_globalsMap = protoFluxBuildContext.GetGlobalsMap();
