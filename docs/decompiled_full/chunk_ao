		private void MapCastsAndOverloads(ProtoFluxNode sourceNode, ProtoFluxNode targetNode, ConnectionResult result, bool undoable)
		{
			if (!result.connected)
			{
				throw new InvalidOperationException("Connection failed, cannot map casts and overloads");
			}
			Dictionary<INode, ProtoFluxNode> dictionary = new Dictionary<INode, ProtoFluxNode>();
			foreach (ProtoFluxNode node in sourceNode.Group.nodes)
			{
				dictionary.Add(node.NodeInstance, node);
			}
			if (sourceNode.Group != targetNode.Group)
			{
				foreach (ProtoFluxNode node2 in targetNode.Group.nodes)
				{
					dictionary.Add(node2.NodeInstance, node2);
				}
			}
			HashSet<ProtoFluxNode> hashSet = new HashSet<ProtoFluxNode>();
			HashSet<ProtoFluxNode> hashSet2 = new HashSet<ProtoFluxNode>();
			ProtoFluxNodeGroup sourceGroup = sourceNode.Group;
			ProtoFluxNodeGroup targetGroup = targetNode.Group;
			ExecutionRuntime<FrooxEngineContext> sourceRuntime = sourceGroup.executionRuntime;
			_ = targetGroup.executionRuntime;
			if (result.overload != null)
			{
				foreach (KeyValuePair<INode, INode> swappedNode in result.overload.SwappedNodes)
				{
					ProtoFluxNode protoFluxNode = dictionary[swappedNode.Key];
					ProtoFluxNode protoFluxNode2 = (ProtoFluxNode)protoFluxNode.Slot.AttachComponent(ProtoFluxHelper.GetBindingForNode(swappedNode.Value.GetType()));
					dictionary.Add(swappedNode.Value, protoFluxNode2);
					protoFluxNode2.AssociateInstance(GetGroup(swappedNode.Value.Runtime), swappedNode.Value);
					hashSet.Add(protoFluxNode2);
					Slot visualSlot = protoFluxNode.GetVisualSlot();
					if (visualSlot != null)
