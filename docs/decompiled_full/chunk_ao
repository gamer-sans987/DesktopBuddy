		private P FindProxy<P>() where P : class
		{
			Canvas canvas;
			if (base.InputInterface.VR_Active)
			{
				List<ICollider> list = Pool.BorrowList<ICollider>();
				base.Physics.SphereOverlap(base.Tip, 0.05f, list, (ICollider c) => c.Slot.GetComponent<ProtoFluxNodeVisual>() != null);
				DistanceResult<P> distanceResult = default(DistanceResult<P>);
				foreach (ICollider item in list)
				{
					canvas = item.Slot.GetComponent<Canvas>();
					if (canvas != null && !IsNodeGrabbed())
					{
						Elements.Core.float3 @float = canvas.Slot.GlobalPointToLocal(base.Tip);
						DistanceResult<P> distanceResult2 = canvas.FindNearest<P>(@float.xy);
						if (distanceResult2.value != null && (distanceResult.value == null || distanceResult.distance > distanceResult2.distance))
						{
							distanceResult = distanceResult2;
						}
					}
					bool IsNodeGrabbed()
					{
						return canvas.Slot.GetComponentInParents<Grabbable>()?.IsGrabbed ?? false;
					}
				}
				Pool.Return(ref list);
				if (distanceResult.value != null && distanceResult.distance <= (float)MaxConnectDistance)
				{
					return distanceResult.value;
				}
			}
			RaycastHit? hit = GetHit();
			canvas = hit?.Collider.Slot.GetComponent<Canvas>();
			if (canvas != null && canvas.Slot.GetComponent<ProtoFluxNodeVisual>() != null)
			{
				if (IsNodeGrabbed())
				{
					return null;
				}
				Slot slot = canvas.Slot;
				RaycastHit value = hit.Value;
				Elements.Core.float3 float2 = slot.GlobalPointToLocal(in value.Point);
				DistanceResult<P> distanceResult3 = canvas.FindNearest<P>(float2.xy);
				if (distanceResult3.value != null && distanceResult3.distance <= (float)MaxConnectDistance)
				{
					return distanceResult3.value;
				}
			}
			return null;
		}

