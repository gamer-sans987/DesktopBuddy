		public static Task<List<AssetInfo>> GatherStaticAssetInfos(World w)
		{
			return w.Coroutines.StartTask(async delegate
			{
				await default(ToWorld);
				List<IStaticAssetProvider> providers = w.RootSlot.GetComponentsInChildren<IStaticAssetProvider>();
				List<VideoTextureProvider> videoTextures = w.RootSlot.GetComponentsInChildren<VideoTextureProvider>();
				await default(ToBackground);
				List<AssetInfo> list = new List<AssetInfo>();
				foreach (IStaticAssetProvider provider in providers)
				{
					Uri url = provider.URL;
					if (!(url == null))
					{
						long size = 0L;
						Type type = provider.GetType();
						string text = (await w.Engine.LocalDB.TryFetchAssetRecordAsync(url))?.path;
						if (!string.IsNullOrWhiteSpace(text))
						{
							FileInfo fileInfo = new FileInfo(text);
							if (fileInfo.Exists)
							{
								size = fileInfo.Length;
							}
						}
						list.Add(new AssetInfo
						{
							LocalFile = text,
							URL = url,
							Size = size,
							Type = type,
							IsAvailable = provider.IsAvailable,
							ReferenceCount = provider.AssetReferenceCount
						});
					}
				}
				foreach (VideoTextureProvider video in videoTextures)
				{
					Uri url = video.URL.Value;
					if (!(url == null))
					{
						long size = 0L;
						Type type = video.GetType();
						string text2 = (await w.Engine.LocalDB.TryFetchAssetRecordAsync(url))?.path;
						if (!string.IsNullOrWhiteSpace(text2))
						{
							FileInfo fileInfo2 = new FileInfo(text2);
							if (fileInfo2.Exists)
							{
								size = fileInfo2.Length;
							}
						}
						list.Add(new AssetInfo
						{
							LocalFile = text2,
							URL = url,
							Size = size,
							Type = type,
							IsAvailable = video.IsAssetAvailable,
							ReferenceCount = video.AssetReferenceCount
						});
					}
				}
				return list.Distinct().ToList();
			});
		}
	}
