			base.OnDestroy();
			_arrowMesh.Target?.Destroy();
			_renderer.Target?.Destroy();
		}

		protected override void OnDispose()
		{
			base.Slot.WorldTransformChanged -= Slot_WorldTransformChanged;
			base.OnDispose();
		}

		public void DriveActiveFrom(IField<bool> source)
		{
			EnabledField.DriveFrom(source);
			_renderer.Target.EnabledField.DriveFrom(source);
		}

		public void Setup(Elements.Core.colorX baseColor, Elements.Core.colorX endColor)
		{
			ArrowMesh target = _arrowMesh.Target;
			target.BaseColor.Value = baseColor;
			target.TopColor.Value = endColor;
			target.HeadColor.Value = endColor;
		}

		public void SetTarget(ProtoFluxNodeVisual visual)
		{
			ConnectNode.Target = visual.Slot;
			BoxCollider component = visual.Slot.GetComponent<BoxCollider>();
			TargetSize.Target = component.Size;
			TargetOffset.Target = component.Offset;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			Slot target = ConnectNode.Target;
			if (target == null)
			{
				Destroy();
				return;
			}
			if (TargetSize.Target == null)
			{
				Destroy();
				return;
			}
			if (TargetOffset.Target == null)
			{
				Destroy();
				return;
			}
			Elements.Core.float3 value = TargetSize.Target.Value;
			Elements.Core.float3 value2 = TargetOffset.Target.Value;
			Elements.Core.float2 origin = target.SpacePointToLocal(Elements.Core.float3.Zero, base.Slot).xy;
			Elements.Core.float2 @float = MathX.FindRayRectangleIntersection(new Elements.Core.Rect(value2.xy - value.xy * 0.5f, value.xy), in origin, -origin.Normalized) ?? Elements.Core.float2.Zero;
			Elements.Core.float3 value3 = base.Slot.SpacePointToLocal(@float.xy_, target);
			_targetVector.Target.Value = value3;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			ConnectNode = new TransformRelayRef();
			TargetSize = new RelayRef<IValue<Elements.Core.float3>>();
			TargetOffset = new RelayRef<IValue<Elements.Core.float3>>();
			_arrowMesh = new SyncRef<ArrowMesh>();
			_renderer = new SyncRef<MeshRenderer>();
			_targetVector = new FieldDrive<Elements.Core.float3>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => ConnectNode, 
				4 => TargetSize, 
				5 => TargetOffset, 
				6 => _arrowMesh, 
				7 => _renderer, 
				8 => _targetVector, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static ProtofluxArrowManager __New()
		{
			return new ProtofluxArrowManager();
		}
	}
