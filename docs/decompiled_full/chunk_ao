		public static ProtoFluxTypeMapping MapNode(string name, string @namespace)
		{
			string name2 = name;
			if (protoFluxNodes.TryGetValue(name.ToLower(), out Type value))
			{
				return value;
			}
			int num = name.IndexOf('`');
			if (num > 0)
			{
				name = name.Substring(0, num);
			}
			name = name.Replace("SmallerOrEqual", "LessOrEqual");
			if (name.StartsWith("Construct"))
			{
				name = name.Replace("Construct", "Pack");
			}
			if (name.StartsWith("Deconstruct"))
			{
				name = name.Replace("Deconstruct", "Unpack");
			}
			if (name.Contains("MouseButton"))
			{
				name = name.Replace("MouseButton", "Mouse");
			}
			if (name.EndsWith("_Node"))
			{
				name = name.Substring(0, name.Length - 5);
			}
			if (name.EndsWith("Node"))
			{
				name = name.Substring(0, name.Length - 4);
			}
			if (name.EndsWith("Constant"))
			{
				name = name.Replace("Constant", "");
			}
			if (name.StartsWith("Playback"))
			{
				name = name.Replace("Playback", "");
			}
			if (name.Contains("Collision"))
			{
				name = name.Replace("Collision", "Contact");
			}
			name = name.Replace("Tooltip", "Tool");
			if (protoFluxNodes.TryGetValue(name.ToLower(), out value))
			{
				return value;
			}
			foreach (NodeMapper nodeMapper in nodeMappers)
			{
				ProtoFluxTypeMapping result = nodeMapper(name2, @namespace);
				if (!result.IsNull)
				{
					return result;
				}
			}
			return default(ProtoFluxTypeMapping);
		}

