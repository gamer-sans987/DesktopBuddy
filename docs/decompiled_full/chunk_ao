	public readonly struct ProtoFluxTypeMapping
	{
		private readonly Type _singleType;

		private readonly Type[] _multipleTypes;

		private readonly Func<Type, Type> _customMapper;

		public bool IsNull
		{
			get
			{
				if (_singleType == null && _multipleTypes == null)
				{
					return _customMapper == null;
				}
				return false;
			}
		}

		public bool IsGenericDefinition
		{
			get
			{
				if (_singleType != null)
				{
					return _singleType.IsGenericTypeDefinition;
				}
				return true;
			}
		}

		public ProtoFluxTypeMapping(Type type)
		{
			_singleType = type;
			_multipleTypes = null;
			_customMapper = null;
		}

		public ProtoFluxTypeMapping(params Type[] types)
		{
			_singleType = null;
			_multipleTypes = types;
			_customMapper = null;
		}

		public ProtoFluxTypeMapping(Func<Type, Type> mapper)
		{
			_singleType = null;
			_multipleTypes = null;
			_customMapper = mapper;
		}

		public Type GetNodeType()
		{
			if (_singleType == null)
			{
				throw new Exception("Cannot call GetType() on a node with multiple types");
			}
			return ProcessType(_singleType);
		}

		public Type MakeGenericType(Type genericArgument)
		{
			if (_singleType != null)
			{
				return MakeGeneric(_singleType, genericArgument);
			}
			if (_multipleTypes != null)
			{
				Type[] multipleTypes = _multipleTypes;
				foreach (Type genericBase in multipleTypes)
				{
					try
					{
						return MakeGeneric(genericBase, genericArgument);
					}
					catch
					{
					}
				}
				throw new ArgumentException($"Cannot map generic parameter: {genericArgument} to any types");
			}
			return ProcessType(_customMapper(genericArgument));
		}

		private Type MakeGeneric(Type genericBase, Type genericArgument)
		{
			genericBase = ProcessType(genericBase);
			Type[] genericArguments = genericBase.GetGenericArguments();
			Type type = null;
			if (genericArguments.Length == 1)
			{
				type = genericBase.MakeGenericType(genericArgument);
			}
			if (genericArguments.Length == 2 && genericArguments[0].GetGenericParameterConstraints().Any((Type t) => typeof(global::ProtoFlux.Runtimes.Execution.ExecutionContext).IsAssignableFrom(t)))
			{
				type = genericBase.MakeGenericType(typeof(FrooxEngineContext), genericArgument);
			}
			if (type != null && type.IsValidGenericType(validForInstantiation: true))
			{
				return type;
			}
			throw new InvalidOperationException("Cannot make generic instance from a single argument for generic base: " + genericBase);
		}

		private Type ProcessType(Type type)
		{
			if (!typeof(ProtoFluxNode).IsAssignableFrom(type))
			{
				if (type.IsGenericType && !type.IsGenericTypeDefinition)
				{
					return ProtoFluxHelper.GetBindingForNode(type.GetGenericTypeDefinition()).MakeGenericType(type.GetGenericArguments());
				}
				return ProtoFluxHelper.GetBindingForNode(type);
			}
			return type;
		}

		public static implicit operator ProtoFluxTypeMapping(Type type)
		{
			return new ProtoFluxTypeMapping(type);
		}

		public override string ToString()
		{
			if (IsNull)
			{
				return "NULL";
			}
			if (_singleType != null)
			{
				return _singleType.ToString();
			}
			if (_multipleTypes != null)
			{
				return string.Join(", ", _multipleTypes.Select((Type t) => t.ToString()));
			}
			return "Custom mapper: " + _customMapper;
		}
	}
