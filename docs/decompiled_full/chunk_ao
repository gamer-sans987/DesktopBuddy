	internal class ProtoFluxBuildContext
	{
		private ProtoFluxNodeGroup group;

		private ExecutionRuntime<FrooxEngineContext> runtime;

		private Dictionary<IGlobalValueProxy, IGlobalProxyManager> _mappedGlobals = new Dictionary<IGlobalValueProxy, IGlobalProxyManager>();

		private List<IGlobalProxyManager> _managers = new List<IGlobalProxyManager>();

		public int GlobalsCount => _mappedGlobals.Count;

		public ProtoFluxBuildContext(ProtoFluxNodeGroup group, ExecutionRuntime<FrooxEngineContext> runtime)
		{
			this.group = group;
			this.runtime = runtime;
		}

		public Global MapGlobal(IGlobalValueProxy proxy)
		{
			if (proxy == null)
			{
				return null;
			}
			if (!_mappedGlobals.TryGetValue(proxy, out IGlobalProxyManager value))
			{
				value = proxy.SetupProxyManager(group, runtime);
				_mappedGlobals.Add(proxy, value);
				_managers.Add(value);
			}
			return value.Global;
		}

		public IGlobalValue[] GetGlobalsMap()
		{
			return _managers.Select((IGlobalProxyManager g) => g.GlobalValue).ToArray();
		}

		public List<IGlobalProxyManager> GetGlobalManagers()
		{
			if (_managers.Count == 0)
			{
				return null;
			}
			List<IGlobalProxyManager> managers = _managers;
			_managers = null;
			return managers;
		}
	}
