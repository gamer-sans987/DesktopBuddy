		private T GenerateDynamicElement<T>(UIBuilder ui, ProtoFluxNode node, ISyncList list, string name, bool isOutput, Action<T> postprocess) where T : ProtoFluxDynamicElementManager, new()
		{
			ui.Style.SupressLayoutElement = true;
			VerticalLayout verticalLayout = ui.VerticalLayout(0f, 0f, Alignment.TopLeft);
			verticalLayout.ForceExpandHeight.Value = false;
			verticalLayout.Slot.Name = name;
			LayoutElement layoutElement = ui.Root.AttachComponent<LayoutElement>();
			layoutElement.MinHeight.Value = 64f;
			layoutElement.Priority.Value = 0;
			T val = ui.Root.AttachComponent<T>();
			val.Visual.Target = this;
			val.List.Target = list;
			postprocess(val);
			if (!node.SupressLabels)
			{
				Text text = ui.Text((LocaleString)name, bestFit: true, isOutput ? Alignment.BottomRight : Alignment.TopLeft);
				ui.IgnoreLayout();
				text.Slot.OrderOffset = 32767L;
				if (isOutput)
				{
					text.RectTransform.OffsetMin.Value = new Elements.Core.float2(16f, -32f);
					text.RectTransform.OffsetMax.Value = new Elements.Core.float2(-16f, -16f);
				}
				else
				{
					text.RectTransform.OffsetMin.Value = new Elements.Core.float2(16f, -16f);
					text.RectTransform.OffsetMax.Value = new Elements.Core.float2(-16f);
				}
				text.RectTransform.AnchorMin.Value = new Elements.Core.float2(0f, 1f);
				text.RectTransform.AnchorMax.Value = new Elements.Core.float2(1f, 1f);
				text.RectTransform.AddFixedPadding(1f);
			}
			FrooxEngine.UIX.Image image = ui.Image(Elements.Core.colorX.White.SetA(0.25f));
			ui.IgnoreLayout();
			image.Slot.OrderOffset = 32768L;
			if (isOutput)
			{
				image.RectTransform.OffsetMin.Value = new Elements.Core.float2(-30.5f, 19.2f);
				image.RectTransform.OffsetMax.Value = new Elements.Core.float2(-27.5f, -19.2f);
				image.RectTransform.AnchorMin.Value = new Elements.Core.float2(1f);
				image.RectTransform.AnchorMax.Value = new Elements.Core.float2(1f, 1f);
			}
			else
			{
				image.RectTransform.OffsetMin.Value = new Elements.Core.float2(30.5f, 19.2f);
				image.RectTransform.OffsetMax.Value = new Elements.Core.float2(33.5f, -19.2f);
				image.RectTransform.AnchorMin.Value = new Elements.Core.float2(0f, 0f);
				image.RectTransform.AnchorMax.Value = new Elements.Core.float2(0f, 1f);
			}
			RectTransform rectTransform = ui.Panel();
			ui.IgnoreLayout();
			rectTransform.Slot.OrderOffset = 32769L;
			rectTransform.OffsetMin.Value = new Elements.Core.float2(16f);
			rectTransform.OffsetMax.Value = new Elements.Core.float2(-16f, 16f);
