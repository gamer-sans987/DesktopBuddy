	public class EyeRotationDriver : Component
	{
		public class Eye : SyncObject, ICustomInspector, IWorker, IWorldElement
		{
			public readonly Sync<EyeSide> Side;

			public readonly SyncRef<Slot> Root;

			public readonly Sync<Elements.Core.float3> Up;

			public readonly Sync<Elements.Core.float3> ForwardDirection;

			public readonly FieldDrive<Elements.Core.floatQ> Rotation;

			internal Elements.Core.float3 globalDir;

			internal Elements.Core.float3 globalUp;

			internal float baseAngle;

			internal float angle;

			internal Elements.Core.float3 globalForward;

			public bool IsValidEye
			{
				get
				{
					if (Root.Target != null)
					{
						return Rotation.Target != null;
					}
					return false;
				}
			}

			protected override void OnAwake()
			{
				base.OnAwake();
				ForwardDirection.Value = Elements.Core.float3.Forward;
				Up.Value = Elements.Core.float3.Up;
			}

			public void BuildInspectorUI(UIBuilder ui)
			{
				WorkerInspector.BuildInspectorUI(this, ui);
				ui.Button((LocaleString)"Setup From Root", SetupFromRoot);
			}

			[SyncMethod(typeof(Delegate), null)]
			private void SetupFromRoot(IButton button, ButtonEventData eventData)
			{
				if (Root.Target != null)
				{
					SetupFromRoot();
				}
			}

			public void SetupFromRoot()
			{
				Rotation.Target = Root.Target.Rotation_Field;
				Up.Value = Root.Target.LocalRotation * Elements.Core.float3.Up;
				ForwardDirection.Value = Root.Target.LocalRotation * Elements.Core.float3.Forward;
			}

			protected override void InitializeSyncMembers()
			{
				base.InitializeSyncMembers();
				Side = new Sync<EyeSide>();
				Root = new SyncRef<Slot>();
				Up = new Sync<Elements.Core.float3>();
				ForwardDirection = new Sync<Elements.Core.float3>();
				Rotation = new FieldDrive<Elements.Core.floatQ>();
			}

			public override ISyncMember GetSyncMember(int index)
			{
				return index switch
				{
					0 => Side, 
					1 => Root, 
					2 => Up, 
					3 => ForwardDirection, 
					4 => Rotation, 
					_ => throw new ArgumentOutOfRangeException(), 
				};
			}

			public static Eye __New()
			{
				return new Eye();
			}
		}

		public readonly SyncRef<EyeManager> EyeManager;

		public readonly Sync<float> EyeMotionScale;

		public readonly Sync<float> EyeMotionExp;

		public readonly Sync<float> MaxSwing;

		public readonly SyncList<Eye> Eyes;

		public override int Version => 1;

		protected override void OnAwake()
		{
			base.OnAwake();
			MaxSwing.Value = 15f;
			EyeMotionScale.Value = 1f;
			EyeMotionExp.Value = 1f;
		}

		protected override void OnCommonUpdate()
		{
			if (EyeManager.Target == null)
			{
				return;
			}
			foreach (Eye eye in Eyes)
			{
				if (eye.IsValidEye)
				{
					Elements.Core.float3 b = eye.Root.Target.GlobalPosition;
					Slot parent = eye.Root.Target.Parent;
					eye.globalDir = (GetTargetPoint(eye.Side) - b).Normalized;
					eye.globalForward = parent.LocalDirectionToGlobal((Elements.Core.float3)eye.ForwardDirection);
					eye.globalUp = parent.LocalDirectionToGlobal((Elements.Core.float3)eye.Up);
					eye.baseAngle = MathX.Angle(in eye.globalForward, in eye.globalDir);
					eye.angle = eye.baseAngle / (float)MaxSwing;
					eye.angle = MathX.Pow(eye.angle, EyeMotionExp) * (float)EyeMotionScale;
					eye.angle *= MaxSwing;
				}
			}
			float num = 1f;
			foreach (Eye eye2 in Eyes)
			{
				if (eye2.IsValidEye)
				{
					num = MathX.Min((float)MaxSwing / eye2.angle, num);
				}
			}
			foreach (Eye eye3 in Eyes)
			{
				Elements.Core.floatQ globalRotation = Elements.Core.floatQ.LookRotation(MathX.Slerp(eye3.globalForward, in eye3.globalDir, num * (eye3.angle / eye3.baseAngle)), in eye3.globalUp);
				eye3.Rotation.Target.Value = eye3.Root.Target.Parent.GlobalRotationToLocal(in globalRotation);
			}
		}

		private Elements.Core.float3 GetTargetPoint(EyeSide side)
		{
			return side switch
			{
				EyeSide.Left => EyeManager.Target.LeftEyeTargetPoint.Value, 
				EyeSide.Right => EyeManager.Target.RightEyeTargetPoint.Value, 
				EyeSide.Combined => EyeManager.Target.TargetPoint.Value, 
				_ => throw new ArgumentException("side"), 
			};
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			if (control.GetTypeVersion<EyeRotationDriver>() != 0)
			{
				return;
			}
			RunSynchronously(delegate
			{
				if (EyeManager.Target != null && Eyes.Count == 2 && !Eyes.Any((Eye eye) => eye.Side.Value != EyeSide.Combined || eye.Rotation.Target == null))
				{
					UniLog.Log("Auto classifying eyes from old version");
					Slot slot = Eyes[0].Rotation.Target.FindNearestParent<Slot>();
					Slot slot2 = Eyes[1].Rotation.Target.FindNearestParent<Slot>();
					Elements.Core.float3 @float = EyeManager.Slot.GlobalPointToLocal(slot.GlobalPosition);
					Elements.Core.float3 float2 = EyeManager.Slot.GlobalPointToLocal(slot2.GlobalPosition);
					if (@float.x < float2.x)
					{
						Eyes[0].Side.Value = EyeSide.Left;
						Eyes[1].Side.Value = EyeSide.Right;
					}
					else
					{
						Eyes[0].Side.Value = EyeSide.Right;
						Eyes[1].Side.Value = EyeSide.Left;
					}
				}
			});
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			EyeManager = new SyncRef<EyeManager>();
			EyeMotionScale = new Sync<float>();
			EyeMotionExp = new Sync<float>();
			MaxSwing = new Sync<float>();
			Eyes = new SyncList<Eye>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => EyeManager, 
				4 => EyeMotionScale, 
				5 => EyeMotionExp, 
				6 => MaxSwing, 
				7 => Eyes, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

