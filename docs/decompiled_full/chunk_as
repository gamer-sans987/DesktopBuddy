						}
						else
						{
							UniLog.Warning("Failed restoring target asset, component type failed to resolve: " + workerData2.workerTypename);
						}
					}
				}
			}
			_savedObject.Value = null;
			_referenceTable.Target?.Destroy();
			_onRestored.Target?.Invoke(Target.Target);
		}

