		{
			base.OnAwake();
			Rate.Value = 10f;
			_lastEmissionTime = base.Time.WorldTime;
			base.Slot.WorldTransformChanged += OnWorldTransformChanged;
		}

		private void OnWorldTransformChanged(Slot slot)
		{
			this.ParametersUpdated?.Invoke(this);
		}

