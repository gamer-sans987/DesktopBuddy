		private void SyncActiveStateListeners<S>(HashSet<IParticleSystemSubsystem> activeStateListeners, Action<IParticleSystemSubsystem> activeStateEvent, IEnumerable<S> subsystems) where S : IParticleSystemSubsystem
		{
			HashSet<IParticleSystemSubsystem> hashSet = Pool.BorrowHashSet<IParticleSystemSubsystem>();
			foreach (IParticleSystemSubsystem activeStateListener in activeStateListeners)
			{
				hashSet.Add(activeStateListener);
			}
			foreach (S subsystem in subsystems)
			{
				S current2 = subsystem;
				if (current2 != null && !hashSet.Remove(current2))
				{
					activeStateListeners.Add(current2);
					current2.ActiveStateChanged += activeStateEvent;
				}
			}
			foreach (IParticleSystemSubsystem item in hashSet)
			{
				item.ActiveStateChanged -= activeStateEvent;
				activeStateListeners.Remove(item);
			}
			Pool.Return(ref hashSet);
		}

		private void SyncSubsystemMapping<M, S>(Dictionary<IParticleSystemSubsystem, M> subsystemMapping, IEnumerable<S> subsystems, bool removeDisabled) where M : ParticleSubsystemBindingManager where S : IParticleSystemSubsystem
		{
			foreach (KeyValuePair<IParticleSystemSubsystem, M> item in subsystemMapping)
			{
				item.Value.IsInUse = false;
			}
			int num = 0;
			foreach (S subsystem in subsystems)
			{
				if (subsystem == null || subsystem.IsRemoved || (removeDisabled && !subsystem.Enabled))
				{
					continue;
				}
				if (!subsystemMapping.TryGetValue(subsystem, out M value))
				{
					value = (M)subsystem.AllocateModule(this);
					subsystemMapping.Add(subsystem, value);
					if (subsystem.RequiresContinuousUpdates)
					{
						continuousUpdateSubsystems.Add(value);
					}
					if (subsystem is IParticleRenderer particleRenderer)
					{
						Slot slot = particleRenderer.SetupVisuals(this);
						slot.ActiveSelf = BindingSystem.ShouldBeActive;
						rendererModules.Add(particleRenderer, slot);
					}
				}
				value.IsInUse = true;
				value.Index = num++;
			}
			List<IParticleSystemSubsystem> list = null;
			foreach (KeyValuePair<IParticleSystemSubsystem, M> item2 in subsystemMapping)
			{
				if (!item2.Value.IsInUse)
				{
					if (list == null)
					{
						list = Pool.BorrowList<IParticleSystemSubsystem>();
					}
					list.Add(item2.Key);
					if (item2.Key.RequiresContinuousUpdates)
					{
						continuousUpdateSubsystems.Remove(item2.Value);
					}
					if (item2.Key is IParticleRenderer particleRenderer2)
					{
						particleRenderer2.Unregister(this);
						rendererModules.Remove(particleRenderer2);
					}
					item2.Value.Remove();
				}
			}
			if (list == null)
			{
				return;
			}
			foreach (IParticleSystemSubsystem item3 in list)
			{
				subsystemMapping.Remove(item3);
			}
			Pool.Return(ref list);
		}

		private void ClearAllSubsystems<M>(Dictionary<IParticleSystemSubsystem, M> subsystemMapping, HashSet<IParticleSystemSubsystem> stateListeners, Action<IParticleSystemSubsystem> activeStateEvent) where M : ParticleSubsystemBindingManager
		{
			if (stateListeners != null)
			{
				foreach (IParticleSystemSubsystem stateListener in stateListeners)
				{
					stateListener.ActiveStateChanged -= activeStateEvent;
				}
			}
			foreach (KeyValuePair<IParticleSystemSubsystem, M> item in subsystemMapping)
			{
				item.Value.Remove();
			}
			stateListeners?.Clear();
			subsystemMapping.Clear();
		}

		private void ClearAllModules()
		{
			ClearAllSubsystems(moduleMapping, moduleActiveStateListeners, ModuleActiveStateChanged);
		}

		private void ClearAllEmitters()
		{
			ClearAllSubsystems(emitterMapping, null, null);
		}

