			_locomotionOffset.Target = ik.Solver.LocomotionPositionOffset;
			_locomotionWeight.Target = ik.Solver.locomotion.Weight;
			_chestWeight.Target = ik.Solver.spine.ChestGoalWeight;
			_leftElbowBendWeight.Target = ik.Solver.leftArm.BendGoalWeight;
			_rightElbowBendWeight.Target = ik.Solver.rightArm.BendGoalWeight;
			_leftLegPositionWeight.Target = ik.Solver.leftLeg.PositionWeight;
