		protected override void OnStart()
		{
			base.Input.RegisterInputEventReceiver(this);
			RandomizeTransitionSpeed();
			if (_leftFootNode.Target == null || _rightFootNode.Target == null || _leftHandNode.Target == null || _rightHandNode.Target == null || _pelvisNode.Target == null || _headNode.Target == null)
			{
				_leftHandNode.Target = _leftHandProxy.Target.Parent.GetComponent<AvatarPoseNode>();
				_rightHandNode.Target = _rightHandProxy.Target.Parent.GetComponent<AvatarPoseNode>();
				_leftFootNode.Target = _leftFootProxy.Target.Parent.GetComponent<AvatarPoseNode>();
				_rightFootNode.Target = _rightFootProxy.Target.Parent.GetComponent<AvatarPoseNode>();
				_headNode.Target = _headProxy.Target.Parent.GetComponent<AvatarPoseNode>();
				_pelvisNode.Target = _pelvisProxy.Target.Parent.GetComponent<AvatarPoseNode>();
			}
			if (_leftHandNode.Target != null)
			{
				_leftHandNode.Target.Node.Value = BodyNode.LeftHand;
			}
			if (_rightFootNode.Target != null)
			{
				_rightHandNode.Target.Node.Value = BodyNode.RightHand;
			}
			if ((_pelvisPositionWeight.Target == null || _pelvisRotationWeight.Target == null) && IK.Target != null)
			{
				_pelvisPositionWeight.Target = IK.Target.Solver.spine.PelvisPositionWeight;
				_pelvisRotationWeight.Target = IK.Target.Solver.spine.PelvisRotationWeight;
			}
			if (IK.Target != null && !IK.Target.Solver.ForceRootHeight.Value.HasValue)
			{
				IK.Target.Solver.ForceRootHeight.Value = 0f;
			}
		}

		private void EnsurePoseNodes()
		{
			EnsurePoseNode(_headProxy, _headNode, BodyNode.Head);
			EnsurePoseNode(_pelvisProxy, _pelvisNode, BodyNode.Hips);
			EnsurePoseNode(_chestProxy, _chestNode, BodyNode.Chest);
			EnsurePoseNode(_leftHandProxy, _leftHandNode, BodyNode.LeftHand);
			EnsurePoseNode(_rightHandProxy, _rightHandNode, BodyNode.RightHand);
			EnsurePoseNode(_leftElbowProxy, _leftElbowNode, BodyNode.LeftLowerArm);
			EnsurePoseNode(_rightElbowProxy, _rightElbowNode, BodyNode.RightLowerArm);
			EnsurePoseNode(_leftFootProxy, _leftFootNode, BodyNode.LeftFoot);
			EnsurePoseNode(_rightFootProxy, _rightFootNode, BodyNode.RightFoot);
			EnsurePoseNode(_leftKneeProxy, _leftKneeNode, BodyNode.LeftLowerLeg);
			EnsurePoseNode(_rightKneeProxy, _rightKneeNode, BodyNode.RightLowerLeg);
			EnsureDefaultKneeProxies();
		}

		private string NodeName(BodyNode node)
		{
			return node switch
			{
				BodyNode.LeftLowerArm => "Left Elbow", 
				BodyNode.RightLowerArm => "Right Elbow", 
				BodyNode.LeftLowerLeg => "Left Knee", 
				BodyNode.RightLowerLeg => "Right Knee", 
				_ => node.ToString().BeautifyName(), 
			};
		}

		private AvatarPoseNode EnsurePoseNode(SyncRef<Slot> proxy, SyncRef<AvatarPoseNode> poseNode, BodyNode node)
		{
			if (proxy.Target == null)
			{
				proxy.Target = base.Slot.AddSlot(NodeName(node) + " Proxy").AddSlot("Target");
			}
			if (poseNode.Target == null)
			{
				poseNode.Target = proxy.Target.Parent.AttachComponent<AvatarPoseNode>();
			}
			poseNode.Target.Node.Value = node;
			return poseNode.Target;
		}

		private void RandomizeTransitionSpeed()
		{
			leftFootTransitionSpeed = RandomX.Range(MinFeetTransitionSpeed, MaxFeetTransitionSpeed);
			rightFootTransitionSpeed = RandomX.Range(MinFeetTransitionSpeed, MaxFeetTransitionSpeed);
		}

		public void Setup(VRIK ik, BipedRig rig, Slot hmdReference, Slot leftHandReference, Slot rightHandReferece, Slot leftFootReference, Slot rightFootReference, Slot pelvisReference)
		{
			if (IK.Target != null)
			{
				throw new Exception("VRIKAvatar is already setup");
			}
			ik.AutoUpdate.Value = false;
			ik.Solver.ForceRootHeight.Value = 0f;
			IK.Target = ik;
			IK.Target.Solver.SimulationSpace.Target = base.Slot;
			IK.Target.Solver.OffsetSpace.Target = base.Slot;
			ik.Solver.OnPreUpdate.Target = OnPreSolve;
			ik.Solver.OnPostUpdate.Target = OnPostSolve;
			AssignDrives(ik);
			EnsurePoseNodes();
			SetReference(_headProxy.Target, ik.Solver.BoneReferences.head, hmdReference);
			SetReference(_leftHandProxy.Target, ik.Solver.BoneReferences.leftHand, leftHandReference);
			SetReference(_rightHandProxy.Target, ik.Solver.BoneReferences.rightHand, rightHandReferece);
			if (leftFootReference != null)
			{
				SetReference(_leftFootProxy.Target, ik.Solver.BoneReferences.LeftToesOrFoot, leftFootReference);
			}
			if (rightFootReference != null)
			{
				SetReference(_rightFootProxy.Target, ik.Solver.BoneReferences.RightToesOrFoot, rightFootReference);
			}
			if (leftFootReference != null && rightFootReference != null)
			{
				FeetCalibrated.Value = true;
			}
			if (pelvisReference != null)
			{
				SetReference(_pelvisProxy.Target, ik.Solver.BoneReferences.pelvis.Target, pelvisReference);
				PelvisCalibrated.Value = true;
			}
			ComputeDefaultFullBodyCalibration(360f, float.MaxValue);
			UpdateHandOffsets();
			SetupHands(rig);
			SetControllerHandOffsets();
			for (int i = 0; i < ik.Solver.BoneReferences.ReferenceCount; i++)
			{
				ik.Solver.BoneReferences[i]?.GetComponent<IKDraggableOffset>()?.Destroy();
			}
			ik.Solver.BoneReferences.root.Target.GetComponentsInChildren<IKDraggableOffset>().ForEach(delegate(IKDraggableOffset c)
			{
				c.Destroy();
			});
			IKSolverVR.References boneReferences = ik.Solver.BoneReferences;
			Slot obj = boneReferences.leftToes.Target ?? boneReferences.leftFoot.Target;
			Slot slot = boneReferences.rightToes.Target ?? boneReferences.rightFoot.Target;
			Elements.Core.float3 a = hmdReference.GlobalPosition;
			_ = (obj.GlobalPosition + slot.GlobalPosition) * 0.5f;
			Elements.Core.float3 b = boneReferences.root.Target.GlobalPosition;
			AvatarHeight.Value = base.Slot.GlobalVectorToLocal(a - b).y;
			base.Slot.AttachComponent<AvatarGroup>();
			Slot slot2 = boneReferences.leftToes.Target ?? boneReferences.leftFoot.Target;
			Slot slot3 = boneReferences.rightToes.Target ?? boneReferences.rightFoot.Target;
			Elements.Core.floatQ globalRotation = boneReferences.root.Target.GlobalRotation;
			_leftFootRelativeToRoot.Value = globalRotation.Inverted * slot2.GlobalRotation;
			_rightFootRelativeToRoot.Value = globalRotation.Inverted * slot3.GlobalRotation;
			LeftFootRootHeight.Value = boneReferences.root.Target.GlobalPointToLocal(slot2.GlobalPosition).y;
			RightFootRootHeight.Value = boneReferences.root.Target.GlobalPointToLocal(slot3.GlobalPosition).y;
			base.Slot.AttachComponent<AvatarRoot>().Scale.Value = base.Slot.LocalScale;
			AvatarUserPositioner avatarUserPositioner = base.Slot.AttachComponent<AvatarUserPositioner>();
			avatarUserPositioner.PositionNode.Value = UserRoot.UserNode.Feet;
			avatarUserPositioner.RotationNode.Value = UserRoot.UserNode.Feet;
			avatarUserPositioner.RotationReference.Target = _headProxy.Target;
			ClearDestroyRoots(base.Slot);
			CleanupOldBones();
			GenerateOptimizedColliders();
			InitializeHaptics();
			InitializeFacetAnchors();
			InitializeLocomotionColliders();
			InitializeLocomotionMetrics();
		}

