		public override bool IsValid(ref string message)
		{
			if (!BoneReferences.isFilled)
			{
				message = "Trying to initiate IKSolverVR with invalid bone references.";
				return false;
			}
			if (leftArm.WristToPalmAxis.Value == Elements.Core.float3.Zero)
			{
				message = "Left arm 'Wrist To Palm Axis' needs to be set in VRIK. Please select the hand bone, set it to the axis that points from the wrist towards the palm. If the arrow points away from the palm, axis must be negative.";
				return false;
			}
			if (rightArm.WristToPalmAxis.Value == Elements.Core.float3.Zero)
			{
				message = "Right arm 'Wrist To Palm Axis' needs to be set in VRIK. Please select the hand bone, set it to the axis that points from the wrist towards the palm. If the arrow points away from the palm, axis must be negative.";
				return false;
			}
			if ((Elements.Core.float3)leftArm.PalmToThumbAxis == Elements.Core.float3.Zero)
			{
				message = "Left arm 'Palm To Thumb Axis' needs to be set in VRIK. Please select the hand bone, set it to the axis that points from the palm towards the thumb. If the arrow points away from the thumb, axis must be negative.";
				return false;
			}
			if ((Elements.Core.float3)rightArm.PalmToThumbAxis == Elements.Core.float3.Zero)
			{
				message = "Right arm 'Palm To Thumb Axis' needs to be set in VRIK. Please select the hand bone, set it to the axis that points from the palm towards the thumb. If the arrow points away from the thumb, axis must be negative.";
				return false;
			}
			return true;
		}

		private Elements.Core.float3 GuessWristToPalmAxis(Slot hand, Slot forearm)
		{
			Elements.Core.float3 direction = forearm.GlobalPosition - hand.GlobalPosition;
			Elements.Core.float3 v = AxisTools.Tofloat3(AxisTools.GetAxisToDirection(hand, in direction));
			if (MathX.Dot(in direction, hand.GlobalRotation * v) > 0f)
			{
				v = -v;
			}
			return v;
		}

		private Elements.Core.float3 GuessPalmToThumbAxis(Slot hand, Slot forearm)
		{
			if (hand.ChildrenCount == 0)
			{
				base.Debug.Warning("Hand " + hand.Name + " does not have any fingers, VRIK can not guess the hand bone's orientation. Please assign 'Wrist To Palm Axis' and 'Palm To Thumb Axis' manually for both arms in VRIK settings.\n" + hand);
				return Elements.Core.float3.Right;
			}
			Slot thumb = GetThumb(hand);
			if (thumb == null)
			{
				base.Debug.Warning("Couldn't find a thumb on the hand: " + hand);
				return Elements.Core.float3.Right;
			}
			Elements.Core.float3 direction = MathX.Cross(MathX.Cross(hand.GlobalPosition - forearm.GlobalPosition, thumb.GlobalPosition - hand.GlobalPosition), hand.GlobalPosition - forearm.GlobalPosition);
			Elements.Core.float3 v = AxisTools.Tofloat3(AxisTools.GetAxisToDirection(hand, in direction));
			if (MathX.Dot(in direction, hand.GlobalRotation * v) < 0f)
			{
				v = -v;
			}
			return v;
		}

		private Slot GetThumb(Slot hand)
		{
			Slot slot = hand.FindChild((Slot ch) => ch.Name.ToLower().Contains("thumb"));
			if (slot == null)
			{
				float num = float.PositiveInfinity;
				int num2 = -1;
				for (int num3 = 0; num3 < hand.ChildrenCount; num3++)
				{
					if (hand[num3].GetMaxChildDepth() >= 2)
					{
						float sqrMagnitude = (hand[num3].GlobalPosition - hand.GlobalPosition).SqrMagnitude;
						if (sqrMagnitude < num)
						{
							num = sqrMagnitude;
							num2 = num3;
						}
					}
				}
				if (num2 >= 0)
				{
					slot = hand[num2];
				}
			}
			return slot;
		}

		private static void GetSineKeyframes(float mag, SyncCurve<float> curve)
		{
			curve.Append(new CurveKey<float>(0f, 0f));
			curve.Append(new CurveKey<float>(0.5f, mag));
			curve.Append(new CurveKey<float>(1f, 0f));
		}

		private void UpdateSolverTransforms()
		{
			EnsureValidBoneReferences();
			readPositions = readPositions.EnsureExactSize(_boneReferences.Length);
			readRotations = readRotations.EnsureExactSize(_boneReferences.Length);
			Slot simulationSpace = GetSimulationSpace();
			for (int i = 0; i < _boneReferences.Length; i++)
			{
				Slot slot = _boneReferences[i];
				if (slot != null)
				{
					readPositions[i] = simulationSpace.SpacePointToLocal(slot.LocalPosition, slot.Parent);
					readRotations[i] = simulationSpace.SpaceRotationToLocal(slot.LocalRotation, slot.Parent);
				}
			}
			Elements.Core.float3 a = LocomotionPositionOffset.Value;
			if (a != Elements.Core.float3.Zero)
			{
				for (int j = 0; j < readPositions.Length; j++)
				{
					ref Elements.Core.float3 reference = ref readPositions[j];
					reference += a;
				}
			}
			if (simulationSpace != _lastSimulationSpace)
			{
				ResetBodyParts();
				_lastSimulationSpace = simulationSpace;
			}
		}

		protected override void OnInitiate()
		{
			UpdateSolverTransforms();
			Read(readPositions, readRotations, HasChest, HasNeck, HasShoulders, HasToes);
		}

		protected override void OnUpdate()
		{
			if ((float)IKPositionWeight > 0f)
			{
				UpdateSolverTransforms();
				Read(readPositions, readRotations, HasChest, HasNeck, HasShoulders, HasToes);
				Solve();
				Write();
				WriteTransforms();
			}
		}

		private void WriteTransforms()
		{
			EnsureValidBoneReferences();
			Slot simulationSpace = GetSimulationSpace();
			_ = _boneReferences[0];
			readPositions[0] = DefaultRootPosition;
			readRotations[0] = DefaultRootRotation;
			for (int i = 0; i < _boneReferences.Length; i++)
			{
				Slot slot = _boneReferences[i];
				if (slot != null)
				{
					bool num = i < 2;
					bool flag = i > 5 && i < 14;
					if (num || flag)
					{
						Elements.Core.float3 localPosition = simulationSpace.LocalPointToSpace(MathX.LerpUnclamped(in readPositions[i], GetPosition(i) - (Elements.Core.float3)LocomotionPositionOffset, IKPositionWeight), slot.Parent);
