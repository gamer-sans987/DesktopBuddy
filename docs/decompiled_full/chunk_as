				return;
			}
			componentInChildrenOrParents.DetectHandRigs();
			if (SetupHands(componentInChildrenOrParents))
			{
				button.LabelText = "Setup Complete";
			}
			else
			{
				button.LabelText = "Setup Failed!";
			}
			button.Enabled = false;
		}

		public void OnBodyNodeAdded(BodyNode node, AvatarObjectSlot slot)
		{
			if (!base.IsUnderLocalUser)
			{
				return;
			}
			switch (node)
			{
			case BodyNode.LeftFoot:
				if (_leftFootNode.Target.CanEquip)
				{
					slot.Equip(_leftFootNode.Target);
				}
				break;
			case BodyNode.RightFoot:
				if (_rightFootNode.Target.CanEquip)
				{
					slot.Equip(_rightFootNode.Target);
				}
				break;
			case BodyNode.LeftLowerArm:
				if (_leftElbowNode.Target.CanEquip)
				{
					slot.Equip(_leftElbowNode.Target);
				}
				break;
			case BodyNode.RightLowerArm:
				if (_rightElbowNode.Target.CanEquip)
				{
					slot.Equip(_rightElbowNode.Target);
				}
				break;
			case BodyNode.LeftLowerLeg:
				if (_leftKneeNode.Target.CanEquip)
				{
					slot.Equip(_leftKneeNode.Target);
				}
				break;
			case BodyNode.RightLowerLeg:
				if (_rightKneeNode.Target.CanEquip)
				{
					slot.Equip(_rightKneeNode.Target);
				}
				break;
			case BodyNode.Hips:
				if (_pelvisNode.Target.CanEquip)
				{
					slot.Equip(_pelvisNode.Target);
				}
				break;
			case BodyNode.Chest:
				if (_chestNode.Target.CanEquip)
				{
					slot.Equip(_chestNode.Target);
				}
				break;
			}
		}

