				spine.Initialize(this, num2);
				num2 += spine.MaxBones;
				leftArm.Initialize(this, num2);
				num2 += leftArm.MaxBones;
				rightArm.Initialize(this, num2);
				num2 += rightArm.MaxBones;
				leftLeg.Initialize(this, num2);
				num2 += leftLeg.MaxBones;
				rightLeg.Initialize(this, num2);
				num2 += rightLeg.MaxBones;
			}
			spine.Read(positions, rotations, hasChest, hasNeck, hasShoulders, hasToes, 0, 1, ForwardFlipped);
			leftArm.Read(positions, rotations, hasChest, hasNeck, hasShoulders, hasToes, hasChest ? 3 : 2, 6, ForwardFlipped);
			rightArm.Read(positions, rotations, hasChest, hasNeck, hasShoulders, hasToes, hasChest ? 3 : 2, 10, ForwardFlipped);
			leftLeg.Read(positions, rotations, hasChest, hasNeck, hasShoulders, hasToes, 1, 14, ForwardFlipped);
			rightLeg.Read(positions, rotations, hasChest, hasNeck, hasShoulders, hasToes, 1, 18, ForwardFlipped);
