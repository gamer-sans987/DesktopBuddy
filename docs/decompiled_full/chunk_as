			public static void SwingRotation(Span<VirtualBone> bones, int index, in Elements.Core.float3 swingTarget, float weight = 1f)
			{
				if (!(weight <= 0f))
				{
					Elements.Core.floatQ b = Elements.Core.floatQ.FromToRotation(bones[index].solverRotation * bones[index].axis, swingTarget - bones[index].solverPosition);
					if (weight < 1f)
					{
						b = MathX.LerpUnclamped(Elements.Core.floatQ.Identity, in b, weight);
					}
					for (int i = index; i < bones.Length; i++)
					{
						bones[i].solverRotation = b * bones[i].solverRotation;
					}
				}
			}

			public static float PreSolve(Span<VirtualBone> bones)
			{
				float num = 0f;
				for (int i = 0; i < bones.Length; i++)
				{
					ref VirtualBone reference = ref bones[i];
					if (i < bones.Length - 1)
					{
						ref VirtualBone reference2 = ref bones[i + 1];
						reference.sqrMag = (reference2.solverPosition - reference.solverPosition).SqrMagnitude;
						reference.length = MathX.Sqrt(reference.sqrMag);
						num += reference.length;
						reference.axis = reference.solverRotation.Inverted * (reference2.solverPosition - reference.solverPosition);
					}
					else
					{
						reference.sqrMag = 0f;
						reference.length = 0f;
					}
				}
				return num;
			}

			public static void RotateAroundPoint(Span<VirtualBone> bones, int index, in Elements.Core.float3 point, in Elements.Core.floatQ rotation)
			{
				for (int i = index; i < bones.Length; i++)
				{
					ref VirtualBone reference = ref bones[i];
					reference.solverPosition = point + rotation * ILSpyHelper_AsRefReadOnly(reference.solverPosition - point);
					reference.solverRotation = rotation * reference.solverRotation;
				}
				static ref readonly T ILSpyHelper_AsRefReadOnly<T>(in T temp)
				{
					//ILSpy generated this function to help ensure overload resolution can pick the overload using 'in'
					return ref temp;
				}
			}

			public static void RotateBy(Span<VirtualBone> bones, int index, in Elements.Core.floatQ rotation)
			{
				ref VirtualBone reference = ref bones[index];
				for (int i = index; i < bones.Length; i++)
				{
					ref VirtualBone reference2 = ref bones[i];
					Elements.Core.float3 v = reference2.solverPosition - reference.solverPosition;
					reference2.solverPosition = reference.solverPosition + rotation * v;
					reference2.solverRotation = rotation * reference2.solverRotation;
				}
			}

			public static void RotateBy(Span<VirtualBone> bones, in Elements.Core.floatQ rotation)
			{
				ref VirtualBone reference = ref bones[0];
				for (int i = 0; i < bones.Length; i++)
				{
					ref VirtualBone reference2 = ref bones[i];
					if (i > 0)
					{
						Elements.Core.float3 v = reference2.solverPosition - reference.solverPosition;
						reference2.solverPosition = reference.solverPosition + rotation * v;
					}
					reference2.solverRotation = rotation * reference2.solverRotation;
				}
			}

			public static void RotateTo(Span<VirtualBone> bones, int index, in Elements.Core.floatQ rotation)
			{
				ref VirtualBone reference = ref bones[index];
				Elements.Core.floatQ rotation2 = Elements.Core.floatQ.FromToRotation(reference.solverRotation, rotation);
				RotateAroundPoint(bones, index, in reference.solverPosition, in rotation2);
			}

			/// <summary>
			/// Solve the bone chain virtually using both solverPositions and SolverRotations. This will work the same as IKSolverTrigonometric.Solve.
			/// </summary>
			public static void SolveTrigonometric(Span<VirtualBone> bones, int first, int second, int third, Elements.Core.float3 targetPosition, in Elements.Core.float3 bendNormal, float weight)
			{
				if (weight <= 0f)
				{
					return;
				}
				ref VirtualBone reference = ref bones[first];
				ref VirtualBone reference2 = ref bones[second];
				ref VirtualBone reference3 = ref bones[third];
				targetPosition = MathX.LerpUnclamped(in reference3.solverPosition, in targetPosition, weight);
				Elements.Core.float3 a = targetPosition - reference.solverPosition;
				float sqrMagnitude = a.SqrMagnitude;
				if (sqrMagnitude != 0f)
				{
					float directionMag = MathX.Sqrt(sqrMagnitude);
					float sqrMagnitude2 = (reference2.solverPosition - reference.solverPosition).SqrMagnitude;
					float sqrMagnitude3 = (reference3.solverPosition - reference2.solverPosition).SqrMagnitude;
					Elements.Core.float3 to = GetDirectionToBendPoint(in a, directionMag, MathX.Cross(in a, in bendNormal), sqrMagnitude2, sqrMagnitude3);
					Elements.Core.floatQ b = Elements.Core.floatQ.FromToRotation(reference2.solverPosition - reference.solverPosition, in to);
					if (weight < 1f)
					{
						b = MathX.LerpUnclamped(Elements.Core.floatQ.Identity, in b, weight);
					}
					RotateAroundPoint(bones, first, in reference.solverPosition, in b);
					Elements.Core.floatQ b2 = Elements.Core.floatQ.FromToRotation(reference3.solverPosition - reference2.solverPosition, targetPosition - reference2.solverPosition);
					if (weight < 1f)
					{
						b2 = MathX.LerpUnclamped(Elements.Core.floatQ.Identity, in b2, weight);
					}
					RotateAroundPoint(bones, second, in reference2.solverPosition, in b2);
				}
			}

			private static Elements.Core.float3 GetDirectionToBendPoint(in Elements.Core.float3 direction, float directionMag, in Elements.Core.float3 bendDirection, float sqrMag1, float sqrMag2)
			{
				float num = (directionMag * directionMag + (sqrMag1 - sqrMag2)) / 2f / directionMag;
				float y = (float)Math.Sqrt(MathX.Clamp(sqrMag1 - num * num, 0f, float.PositiveInfinity));
				if (direction == Elements.Core.float3.Zero)
				{
					return Elements.Core.float3.Zero;
				}
				return Elements.Core.floatQ.LookRotation(in direction, in bendDirection) * new Elements.Core.float3(0f, y, num);
			}

			public static void SolveFABRIK(Span<VirtualBone> bones, in Elements.Core.float3 startPosition, Elements.Core.float3 targetPosition, float weight, float minNormalizedTargetDistance, int iterations, float length, in Elements.Core.float3 startOffset)
			{
				if (weight <= 0f)
				{
					return;
				}
				if (minNormalizedTargetDistance > 0f)
				{
					Elements.Core.float3 v = targetPosition - startPosition;
					float magnitude = v.Magnitude;
					targetPosition = startPosition + v / magnitude * MathX.Max(length * minNormalizedTargetDistance, magnitude);
				}
				for (int i = 0; i < bones.Length; i++)
				{
					ref Elements.Core.float3 reference = ref bones[i].solverPosition;
					reference += startOffset;
				}
				for (int j = 0; j < iterations; j++)
				{
					bones[bones.Length - 1].solverPosition = MathX.LerpUnclamped(in bones[bones.Length - 1].solverPosition, in targetPosition, weight);
					for (int num = bones.Length - 2; num > -1; num--)
					{
						bones[num].solverPosition = SolveFABRIKJoint(in bones[num].solverPosition, in bones[num + 1].solverPosition, bones[num].length);
					}
					bones[0].solverPosition = startPosition;
					for (int k = 1; k < bones.Length; k++)
					{
						bones[k].solverPosition = SolveFABRIKJoint(in bones[k].solverPosition, in bones[k - 1].solverPosition, bones[k - 1].length);
					}
				}
				for (int l = 0; l < bones.Length - 1; l++)
				{
					if (!((double)bones[l].length < 1E-05))
					{
						SwingRotation(bones, l, in bones[l + 1].solverPosition);
					}
				}
			}

			private static Elements.Core.float3 SolveFABRIKJoint(in Elements.Core.float3 pos1, in Elements.Core.float3 pos2, float length)
			{
				return pos2 + (pos1 - pos2).Normalized * length;
			}
		}

