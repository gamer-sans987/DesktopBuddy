		public bool Equip(Slot target, bool isManualEquip = false, bool forceDestroyOld = false, bool isFillingEmptySlot = false)
		{
			if (target.GetComponentInChildren((AvatarEquipBlock b) => b.Enabled) != null)
			{
				return false;
			}
			if (base.Slot.ActiveUserRoot == null)
			{
				UniLog.Warning("Trying to equip avatar on an AvatarManager that's not under user root.\n" + this.ParentHierarchyToString(), stackTrace: true);
				return false;
			}
			if (!target.ForeachComponentInChildren((SimpleAvatarProtection p) => p.CanUse(base.Slot.ActiveUser)))
			{
				return false;
			}
			if (!isFillingEmptySlot && _fillSlotCancellationSource != null)
			{
				_fillSlotCancellationSource.Cancel();
				_fillSlotCancellationSource.Dispose();
				_fillSlotCancellationSource = null;
			}
			IsEquippingManually = isManualEquip;
			HashSet<BodyNode> bodyNodes = new HashSet<BodyNode>();
			List<IAvatarObject> componentsInChildren = target.GetComponentsInChildren((IAvatarObject o) => CanEquip(o));
			List<AvatarObjectSlot> registeredComponents = base.Slot.ActiveUserRoot.GetRegisteredComponents((AvatarObjectSlot s) => bodyNodes.Add(s.Node.Value));
			Dictionary<AvatarGroup, List<IAvatarObject>> dictionary = new Dictionary<AvatarGroup, List<IAvatarObject>>();
			List<IAvatarObject> list = new List<IAvatarObject>();
			List<EquipPair> list2 = new List<EquipPair>();
			HashSet<IAvatarObject> hashSet = new HashSet<IAvatarObject>();
			componentsInChildren.Sort((IAvatarObject a, IAvatarObject b) => -a.EquipOrderPriority.CompareTo(b.EquipOrderPriority));
			foreach (IAvatarObject item in componentsInChildren)
			{
				foreach (AvatarObjectSlot item2 in registeredComponents)
				{
					IAvatarObject target2 = item2.Equipped.Target;
					AvatarGroup componentInParents = item.Slot.GetComponentInParents<AvatarGroup>();
					if (!item2.PreEquip(item, hashSet))
					{
						continue;
					}
					list2.Add(new EquipPair(item2, item));
					TryRemoveGroup(target2, hashSet);
					registeredComponents.Remove(item2);
					if (componentInParents != null)
					{
						if (!dictionary.TryGetValue(componentInParents, out var value))
						{
							value = new List<IAvatarObject>();
							dictionary.Add(componentInParents, value);
						}
						value.Add(item);
					}
					else
					{
						list.Add(item);
					}
					break;
				}
			}
			HashSet<BodyNode> hashSet2 = new HashSet<BodyNode>();
			foreach (EquipPair item3 in list2)
			{
				foreach (BodyNode mutuallyExclusiveNode in item3.avatarObject.MutuallyExclusiveNodes)
				{
					hashSet2.Add(mutuallyExclusiveNode);
				}
			}
			foreach (BodyNode node in hashSet2)
			{
				registeredComponents.FirstOrDefault((AvatarObjectSlot s) => s.Node.Value == node)?.Dequip(hashSet);
			}
			foreach (IAvatarObject item4 in hashSet)
			{
				if (item4.Slot.IsChildOf(base.Slot))
				{
					item4.Slot.Parent = null;
				}
			}
			if (forceDestroyOld)
			{
				foreach (IAvatarObject item5 in hashSet)
				{
					item5?.Slot?.Destroy();
				}
			}
			foreach (EquipPair item6 in list2)
			{
				item6.objectSlot.Equip(item6.avatarObject);
			}
			foreach (KeyValuePair<AvatarGroup, List<IAvatarObject>> item7 in dictionary)
			{
				EquippedGroup equippedGroup = _objectGroups.Add();
				equippedGroup.Group.Target = item7.Key;
				foreach (IAvatarObject item8 in componentsInChildren)
				{
					if (item8.Slot.GetComponentInParents<AvatarGroup>() == item7.Key)
					{
						equippedGroup.Objects.Add(item8);
					}
				}
				if (!item7.Key.Slot.IsChildOf(base.Slot))
				{
					item7.Key.OriginalParent.Target = item7.Key.Slot.Parent;
					item7.Key.Slot.Parent = base.Slot;
				}
			}
			foreach (IAvatarObject item9 in list)
			{
				if (!item9.Slot.IsChildOf(base.Slot))
				{
					item9.Slot.Parent = base.Slot;
				}
			}
			if (!isFillingEmptySlot)
			{
				FillEmptySlots(registeredComponents);
			}
			User activeUser = base.Slot.ActiveUserRoot.ActiveUser;
			if ((bool)AutoAddNameBadge)
			{
				bool num = base.Slot.GetComponentInChildren((AvatarNameTagAssigner a) => a.Slot != _autoNameBadge.Target && !IsUnderView(a.Slot)) != null;
				if (!num && _autoNameBadge.Target == null)
				{
					_autoNameBadge.Target = NameplateHelper.SetupDefaultNameBadge(base.Slot, activeUser);
					UpdateNameTags();
				}
				if (num)
				{
					_autoNameBadge.Target?.Destroy();
				}
			}
			if ((bool)AutoAddIconBadge)
			{
				bool num2 = base.Slot.GetComponentInChildren((AvatarBadgeManager b) => b.Slot != _autoIconBadge.Target && !IsUnderView(b.Slot)) != null;
				if (!num2 && _autoIconBadge.Target == null)
				{
					_autoIconBadge.Target = NameplateHelper.SetupDefaultIconBadge(base.Slot, activeUser);
					UpdateBadges();
				}
				if (num2)
				{
					_autoIconBadge.Target?.Destroy();
				}
			}
			if ((bool)AutoAddLiveIndicator)
			{
				bool num3 = base.Slot.GetComponentInChildren((AvatarLiveIndicator b) => b.Slot != _autoLiveIndicator.Target && !IsUnderView(b.Slot)) != null;
				if (!num3 && _autoLiveIndicator.Target == null)
				{
					_autoLiveIndicator.Target = NameplateHelper.SetupDefaultLiveIndicator(base.Slot, activeUser);
				}
				if (num3)
				{
					_autoLiveIndicator.Target?.Destroy();
				}
			}
			return true;
		}

		public void FillEmptySlots(List<AvatarObjectSlot> slots = null)
		{
			if (_isFillingEmptySlots)
			{
				return;
			}
			if (_fillSlotCancellationSource != null)
			{
				_fillSlotCancellationSource.Cancel();
				_fillSlotCancellationSource.Dispose();
				_fillSlotCancellationSource = null;
			}
			_fillSlotCancellationSource = new CancellationTokenSource();
			try
			{
				CancellationToken token = _fillSlotCancellationSource.Token;
				_isFillingEmptySlots = true;
				if (slots == null)
				{
					slots = base.Slot.ActiveUserRoot.GetRegisteredComponents<AvatarObjectSlot>();
				}
				if (EmptySlotHandler.Target == null)
				{
					return;
				}
				foreach (AvatarObjectSlot slot in slots)
				{
					if (slot.Equipped.Target == null)
					{
						StartTask(async delegate
						{
							await EmptySlotHandler.Target.FillEmptySlot(slot.Node.Value, this, token);
						});
					}
				}
			}
			finally
			{
				_isFillingEmptySlots = false;
			}
		}

		private void TryRemoveGroup(IAvatarObject obj, HashSet<IAvatarObject> dequippedObjects)
		{
			if (obj == null)
			{
				return;
			}
			foreach (EquippedGroup objectGroup in _objectGroups)
			{
				if (!objectGroup.Objects.Contains(obj))
				{
					continue;
				}
				foreach (IAvatarObject @object in objectGroup.Objects)
				{
					if (@object != obj)
					{
						@object.EquippingSlot?.Dequip(dequippedObjects);
					}
				}
				if (objectGroup.Group.Target.Slot.IsChildOf(base.Slot))
				{
					objectGroup.Group.Target.Slot.Parent = objectGroup.Group.Target.OriginalParent.Target;
				}
				_objectGroups.Remove(objectGroup);
				break;
			}
		}

