		public void SetupIntensityFadeInFadeOut(float fadeIn, float fadeOut)
		{
			fadeIn = MathX.Clamp01(fadeIn);
			fadeOut = MathX.Clamp01(fadeOut);
			float num = 1f - fadeOut;
			if (fadeIn + fadeOut > 1f)
			{
				throw new Exception("FadeIn and FadeOut cross each other");
			}
			ColorOverLifetime.Clear();
			if (fadeIn > 0f)
			{
