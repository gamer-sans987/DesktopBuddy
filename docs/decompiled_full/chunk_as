		public void ClearLastEmissionTime()
		{
			_lastEmissionTime = base.Time.WorldTime;
		}

		public int ConsumeEmissionCount()
		{
			if (!ShouldBeEmitting)
			{
				ClearLastEmissionTime();
				_emissionAccumulator = 0.0;
				return 0;
			}
			double num = base.Time.WorldTime - _lastEmissionTime;
			_lastEmissionTime = base.Time.WorldTime;
			_emissionAccumulator += MathX.Max(0.0, num * (double)Rate.Value);
			int num2 = (int)_emissionAccumulator;
			_emissionAccumulator -= num2;
			return num2;
		}

