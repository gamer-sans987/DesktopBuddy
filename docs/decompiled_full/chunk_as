			LocomotionAnimationHandMetrics componentInChildren2 = base.Slot.GetComponentInChildren<LocomotionAnimationHandMetrics>();
			Elements.Core.float3 a = base.Slot.GlobalPointToLocal(leftToesOrFoot.GlobalPosition);
			Elements.Core.float3 a2 = base.Slot.GlobalPointToLocal(rightToesOrFoot.GlobalPosition);
			Elements.Core.float3 a3 = a - LeftFootProxy.LocalPosition;
			Elements.Core.float3 a4 = a2 - RightFootProxy.LocalPosition;
			Elements.Core.float3 @float = MathX.Average(a3 + Elements.Core.float3.Down * 0.1049848f, a4 + Elements.Core.float3.Down * 0.1049848f);
			if (componentInChildren == null)
			{
				LocomotionAnimationFeetMetrics locomotionAnimationFeetMetrics = base.Slot.AttachComponent<LocomotionAnimationFeetMetrics>();
				locomotionAnimationFeetMetrics.Space.Value = LocomotionMetricsSpace.Local;
				locomotionAnimationFeetMetrics.FeetSeparation.Value = MathX.Distance(in a, in a2);
			}
			if (componentInChildren2 == null)
			{
				componentInChildren2 = base.Slot.AttachComponent<LocomotionAnimationHandMetrics>();
				componentInChildren2.Space.Value = LocomotionMetricsSpace.Local;
				Elements.Core.float3 a5 = base.Slot.GlobalPointToLocal(target4.GlobalPosition);
				Elements.Core.float3 b = base.Slot.GlobalPointToLocal(target5.GlobalPosition);
				Elements.Core.float3 a6 = ((target2 == null) ? a5 : base.Slot.GlobalPointToLocal(target2.GlobalPosition));
				Elements.Core.float3 b2 = ((target3 == null) ? b : base.Slot.GlobalPointToLocal(target3.GlobalPosition));
				Elements.Core.float3 b3 = base.Slot.GlobalPointToLocal(target4.GlobalPosition);
				Elements.Core.float3 b4 = base.Slot.GlobalPointToLocal(target5.GlobalPosition);
				Elements.Core.float3 b5 = base.Slot.GlobalPointToLocal(target6.GlobalPosition);
				Elements.Core.float3 b6 = base.Slot.GlobalPointToLocal(target7.GlobalPosition);
				float num = MathX.Distance(in a6, in b2);
				float num2 = MathX.Distance(in a5, in b);
				componentInChildren2.ShoulderSeparation.Value = num2;
				componentInChildren2.ShoulderHeight.Value = MathX.Average(in a6.y, in b2.y) - @float.y;
				MathX.Distance(in a6, in a5);
				float num3 = MathX.Distance(in a5, in b3);
				float num4 = MathX.Distance(in b3, in b5);
				float a7 = num3 + num4;
				MathX.Distance(in b2, in b);
				float num5 = MathX.Distance(in b, in b4);
				float num6 = MathX.Distance(in b4, in b6);
				componentInChildren2.ArmLength.Value = MathX.Average(in a7, num5 + num6);
				componentInChildren2.HandOffset.Value = MathX.Max(0.1f, (num2 - num) * 0.5f);
				Elements.Core.float3 v = (b2 - a6).Normalized;
				Elements.Core.float3 forward = Elements.Core.floatQ.AxisAngle(Elements.Core.float3.Up, -90f) * v;
				if (target != null)
				{
					Elements.Core.float3 v2 = base.Slot.GlobalPointToLocal(target.GlobalPosition);
					Elements.Core.floatQ q = Elements.Core.floatQ.LookRotation(in forward).Inverted;
					Elements.Core.float3 float2 = q * a5;
					Elements.Core.float3 float3 = q * b;
					Elements.Core.float3 float4 = q * v2;
					float num7 = MathX.Average(in float2.z, in float3.z);
					num7 -= float4.z;
					componentInChildren2.ShoulderOffset.Value = num7;
				}
			}
		}

