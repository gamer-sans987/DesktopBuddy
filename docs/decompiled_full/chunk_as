		protected override void UpdateVisuals(QuadMeshRenderData data)
		{
			RunSynchronously(delegate
			{
				ParticleSystemBindingManager manager = data.Manager;
				Span<Elements.Core.float3> positions = manager.Positions;
				Span<Elements.Core.floatQ> rotations = manager.Rotations;
				Span<Elements.Core.float3> scales = manager.Scales;
				Span<Elements.Core.color> colors = manager.Colors;
				for (int i = 0; i < manager.Count; i++)
				{
					if (data.mesh.Points.Count == i)
					{
						data.mesh.Points.Append(positions[i]);
						data.mesh.Sizes.Append(scales[i].xy);
						data.mesh.Rotations.Append(rotations[i]);
						data.mesh.Colors.Append(colors[i]);
						data.mesh.UVs.Append(new Elements.Core.float4(0.5f, 0.5f, 1f, 1f));
					}
					else
					{
						data.mesh.Points[i] = positions[i];
						data.mesh.Sizes[i] = scales[i].xy;
						data.mesh.Rotations[i] = rotations[i];
						data.mesh.Colors[i] = colors[i];
					}
				}
				int num = data.mesh.Points.Count - manager.Count;
				if (num > 0)
