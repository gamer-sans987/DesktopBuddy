		private void CleanupOldBones()
		{
			foreach (CapsuleCollider componentsInChild in base.Slot.GetComponentsInChildren<CapsuleCollider>())
			{
				Slot slot = componentsInChild.Slot;
				componentsInChild.Destroy();
				if (slot.ComponentCount == 0)
				{
					slot.Destroy();
				}
			}
		}

		private void GenerateOptimizedColliders()
		{
			IKSolverVR.References boneReferences = IK.Target.Solver.BoneReferences;
			Slot target = boneReferences.root.Target;
			Slot target2 = boneReferences.pelvis.Target;
			Slot slot = boneReferences.chest.Target ?? boneReferences.spine.Target;
			Slot target3 = boneReferences.head.Target;
			Slot target4 = boneReferences.leftUpperArm.Target;
			Slot target5 = boneReferences.leftForearm.Target;
			Slot target6 = boneReferences.leftHand.Target;
			Slot target7 = boneReferences.rightUpperArm.Target;
			Slot target8 = boneReferences.rightForearm.Target;
			Slot target9 = boneReferences.rightHand.Target;
			Slot target10 = boneReferences.leftThigh.Target;
			Slot target11 = boneReferences.leftCalf.Target;
			Slot target12 = boneReferences.leftFoot.Target;
			Slot target13 = boneReferences.leftToes.Target;
			Slot target14 = boneReferences.rightThigh.Target;
			Slot target15 = boneReferences.rightCalf.Target;
			Slot target16 = boneReferences.rightFoot.Target;
			Slot target17 = boneReferences.rightToes.Target;
			Rig rig = base.Slot.GetComponentInChildren<Rig>();
