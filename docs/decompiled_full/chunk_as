		private void InitiateSolver()
		{
			if (Solver.Initiated)
			{
				return;
			}
			if (Solver.BoneReferences.isEmpty)
			{
				BipedRig bipedRig = base.Slot.GetComponentInChildren<BipedRig>() ?? base.Slot.GetComponentInParents<BipedRig>();
				if (bipedRig != null)
				{
					Solver.BoneReferences.AssignFrom(bipedRig);
					bipedRig.GuessForwardFlipped();
				}
			}
			if (!Solver.BoneReferences.isFilled)
			{
				return;
			}
			Solver.DefaultAnimationCurves();
			Solver.CreateCenteredRoot();
			Solver.GuessMisalignedHands();
			Solver.GuessHandOrientations(onlyIfZero: true);
			Solver.GuessLegBendNormals(onlyIfZero: true);
			Solver.GuessFeetSeparation();
			Solver.GuessMinHeadHeight();
			_drives.Clear();
			for (int i = 0; i < Solver.BoneReferences.ReferenceCount; i++)
			{
				Slot slot = Solver.BoneReferences[i];
				if (slot != null)
				{
					BoneDrive boneDrive = _drives.Add();
					boneDrive.Position.Target = slot.Position_Field;
					boneDrive.Rotation.Target = slot.Rotation_Field;
				}
			}
			Solver.Initiate(base.Slot);
		}

