		public readonly SyncRef<Slot> PositionReference;

		public readonly Sync<UserRoot.UserNode> RotationNode;

		public readonly SyncRef<Slot> RotationReference;

		[OldName("PreserveUp")]
		public readonly Sync<bool> PreserveUpOnEnter;

		public readonly Sync<bool> PreserveUpOnExit;

		public readonly Sync<bool> UnparentEverythingOnDestroy;

		public readonly Sync<RestoreMode> TransformRestoreMode;

		public readonly Sync<UserRoot.UserNode> RestoreNode;

		public readonly SyncRef<Slot> RestoreReference;

		public readonly SyncList<BodyNodeFilters> Filters;

		public readonly SyncRefList<IAvatarAnchorUserFilter> UserFilters;

		private User _lastAnchoredUser;

		public readonly SyncDelegate<AvatarAnchorUserEvent> UserAnchored;

		public readonly SyncDelegate<AvatarAnchorUserEvent> UserStay;

		public readonly SyncDelegate<AvatarAnchorUserEvent> UserReleased;

		protected readonly SyncRef<Slot> _originalSpace;

		protected readonly Sync<Elements.Core.float3> _originalPosition;

		protected readonly Sync<Elements.Core.floatQ> _originalRotation;

		protected readonly Sync<float> _originalScale;

		protected readonly SyncRefList<AvatarObjectSlot> _dummyObjectSlots;

		bool IAvatarAnchor.Highlight
		{
			get
			{
				return Highlight;
			}
			set
			{
				Highlight.Value = value;
			}
		}

		public AvatarManager AnchoredAvatarManager => base.ActiveLink?.FindNearestParent<AvatarManager>();

		public User AnchoredUser => AnchoredAvatarManager?.Slot.ActiveUserRoot?.ActiveUser;

		public bool IsOccupied => AnchoredAvatarManager != null;

		public event AvatarAnchorUserEvent LocalUserAnchored;

		public event AvatarAnchorUserEvent LocalUserStay;

		public event AvatarAnchorUserEvent LocalUserReleased;

		private void RunUserAnchored(User user)
		{
			this.LocalUserAnchored?.Invoke(this, user);
			UserAnchored.Target?.Invoke(this, user);
			ForeachAnchorComponent(delegate(IAvatarAnchorEventReceiver r)
			{
				r.OnAnchored(this, base.LocalUser);
			}, breakOnReleased: true);
		}

		private void RunUserStay(User user)
		{
			this.LocalUserStay?.Invoke(this, user);
			UserStay.Target?.Invoke(this, user);
			ForeachAnchorComponent(delegate(IAvatarAnchorEventReceiver r)
			{
				r.OnAnchorStay(this, user);
			}, breakOnReleased: true);
		}

		private void RunUserReleased(User user)
		{
			this.LocalUserReleased?.Invoke(this, user);
			UserReleased.Target?.Invoke(this, user);
			ForeachAnchorComponent(delegate(IAvatarAnchorEventReceiver r)
			{
				r.OnReleased(this, base.LocalUser);
			}, breakOnReleased: false);
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			MinScale.Value = 1f;
			MaxScale.Value = 1f;
			TransformRestoreMode.Value = RestoreMode.RelativeTransform;
			RestoreNode.Value = UserRoot.UserNode.GroundProjectedHead;
			PreserveUpOnExit.Value = true;
		}

		public bool CanAnchor(User user)
		{
			return CanAnchor(user.Root.GetRegisteredComponent<AvatarManager>());
		}

		public bool CanAnchor(AvatarManager manager)
		{
			if (!base.Enabled)
			{
				return false;
			}
			if (base.Slot.IsChildOf(manager.Slot.ActiveUserRoot.Slot))
			{
				return false;
			}
			User activeUser = manager.Slot.ActiveUser;
			foreach (IAvatarAnchorUserFilter userFilter in UserFilters)
			{
				if (userFilter != null && !userFilter.CanAnchor(activeUser))
				{
					return false;
				}
			}
			return true;
		}

		public void Anchor(User user)
		{
			Anchor(user.Root.GetRegisteredComponent<AvatarManager>());
		}

		public void Anchor(AvatarManager manager)
		{
			if (!CanAnchor(manager))
			{
				return;
			}
			manager.CurrentAnchor?.Release();
			UserRoot activeUserRoot = manager.Slot.ActiveUserRoot;
			activeUserRoot.GetRegisteredComponent<LocomotionController>()?.SupressSources.Add(this);
			_originalSpace.Target = activeUserRoot.Slot.Parent;
			switch (TransformRestoreMode.Value)
			{
			case RestoreMode.RelativeTransform:
				_originalPosition.Value = base.Slot.GlobalPointToLocal(activeUserRoot.GetGlobalPosition(RestoreNode));
				_originalRotation.Value = base.Slot.GlobalRotationToLocal(activeUserRoot.GetGlobalRotation(RestoreNode));
				_originalScale.Value = base.Slot.GlobalScaleToLocal(activeUserRoot.GlobalScale);
				break;
			case RestoreMode.GlobalTransform:
				_originalPosition.Value = activeUserRoot.GetGlobalPosition(RestoreNode);
				_originalRotation.Value = activeUserRoot.GetGlobalRotation(RestoreNode);
				_originalScale.Value = activeUserRoot.GlobalScale;
				break;
			}
			activeUserRoot.Slot.Parent = ParentSpace.Space;
			float x = activeUserRoot.Slot.LocalScale.x;
			x = MathX.Clamp(x, MinScale, MaxScale);
			activeUserRoot.Slot.LocalScale = new Elements.Core.float3(x, x, x);
			if (RotationReference.Target != null)
			{
				activeUserRoot.SetGlobalRotation(RotationNode.Value, RotationReference.Target.GlobalRotation);
				if ((bool)PreserveUpOnEnter)
				{
					activeUserRoot.Slot.Up = ParentSpace.Space.LocalDirectionToGlobal(Elements.Core.float3.Up);
				}
			}
			if (PositionReference.Target != null)
			{
				activeUserRoot.SetGlobalPosition(PositionNode, PositionReference.Target.GlobalPosition);
			}
			_dummyObjectSlots.Clear();
			foreach (BodyNodeFilters bodyNodeFilterSet in Filters)
			{
				AvatarObjectSlot avatarObjectSlot = activeUserRoot.GetRegisteredComponent((AvatarObjectSlot s) => s.Node.Value == bodyNodeFilterSet.Node.Value);
				if (avatarObjectSlot == null)
				{
					if (!bodyNodeFilterSet.Required.Value)
					{
						continue;
					}
					Slot slot = activeUserRoot.Slot.AddSlot("Dummy Body Node: " + bodyNodeFilterSet.Node);
					slot.Tag = "Dummy";
					avatarObjectSlot = slot.AttachComponent<AvatarObjectSlot>();
					avatarObjectSlot.Node.Value = bodyNodeFilterSet.Node;
					avatarObjectSlot.IsTracking.Value = false;
					_dummyObjectSlots.Add(avatarObjectSlot);
				}
				foreach (PoseFilter filter in bodyNodeFilterSet.Filters)
				{
					avatarObjectSlot.Filters.Add(filter.Filter.Target, filter.Priority.Value);
				}
			}
			manager.SetAnchor(this);
		}

		public void Release()
		{
			AvatarManager anchoredAvatarManager = AnchoredAvatarManager;
			if (anchoredAvatarManager == null)
			{
				throw new InvalidOperationException("No user currently anchored!");
			}
			UserRoot activeUserRoot = anchoredAvatarManager.Slot.ActiveUserRoot;
			activeUserRoot.GetRegisteredComponent<LocomotionController>()?.SupressSources.Remove(this);
			activeUserRoot.Slot.Parent = _originalSpace.Target;
			_originalSpace.Target = null;
			switch (TransformRestoreMode.Value)
			{
			case RestoreMode.RelativeTransform:
				activeUserRoot.GlobalScale = base.Slot.LocalScaleToGlobal(_originalScale);
				activeUserRoot.SetGlobalRotation(RestoreNode, base.Slot.LocalRotationToGlobal((Elements.Core.floatQ)_originalRotation));
				activeUserRoot.SetGlobalPosition(RestoreNode, base.Slot.LocalPointToGlobal((Elements.Core.float3)_originalPosition));
				break;
			case RestoreMode.GlobalTransform:
				activeUserRoot.GlobalScale = _originalScale;
				activeUserRoot.SetGlobalRotation(RestoreNode, (Elements.Core.floatQ)_originalRotation);
				activeUserRoot.SetGlobalPosition(RestoreNode, (Elements.Core.float3)_originalPosition);
				break;
			case RestoreMode.Reference:
				if (RestoreReference.Target != null)
				{
					activeUserRoot.GlobalScale = RestoreReference.Target.GlobalScale.x;
					activeUserRoot.SetGlobalPosition(RestoreNode, RestoreReference.Target.GlobalPosition);
					activeUserRoot.SetGlobalRotation(RestoreNode, RestoreReference.Target.GlobalRotation);
				}
				break;
			}
			if (PreserveUpOnExit.Value)
			{
				activeUserRoot.Slot.Up = activeUserRoot.Slot.Parent.LocalDirectionToGlobal(Elements.Core.float3.Up);
			}
			foreach (BodyNodeFilters bodyNodeFilterSet in Filters)
			{
				AvatarObjectSlot registeredComponent = activeUserRoot.GetRegisteredComponent((AvatarObjectSlot s) => s.Node.Value == bodyNodeFilterSet.Node.Value);
				if (registeredComponent == null)
				{
					continue;
				}
				foreach (PoseFilter filter in bodyNodeFilterSet.Filters)
				{
					registeredComponent.Filters.Remove(filter.Filter.Target);
				}
			}
			foreach (AvatarObjectSlot dummyObjectSlot in _dummyObjectSlots)
			{
				if (dummyObjectSlot != null)
				{
					dummyObjectSlot.Dequip(null);
					dummyObjectSlot.Slot.Destroy();
				}
			}
			_dummyObjectSlots.Clear();
			anchoredAvatarManager.ClearAnchor(this);
		}

		protected override void OnLinked()
		{
			_lastAnchoredUser = AnchoredUser;
			if (!_lastAnchoredUser.IsLocalUser)
			{
				return;
			}
			RunUserAnchored(base.LocalUser);
			StartTask(async delegate
			{
				bool isFirst = true;
				while (AnchoredUser == base.LocalUser)
				{
					if (!isFirst)
					{
						RunUserStay(base.LocalUser);
					}
					else
					{
						isFirst = false;
					}
					await default(NextUpdate);
				}
			});
		}

		protected override void OnUnlinked()
		{
			if (_lastAnchoredUser != null && _lastAnchoredUser.IsLocalUser)
			{
				RunUserReleased(_lastAnchoredUser);
				_lastAnchoredUser = null;
			}
		}

		protected override void OnDestroying()
		{
			if (IsOccupied)
			{
				Release();
			}
			if (UnparentEverythingOnDestroy.Value)
			{
				Slot space = ParentSpace.Space;
				if (space.IsChildOf(base.Slot, includeSelf: true))
				{
					space.ReparentChildren(base.Slot.GetObjectRoot().Parent);
				}
			}
			base.OnDestroying();
		}

		private void ForeachAnchorComponent(Action<IAvatarAnchorEventReceiver> action, bool breakOnReleased)
		{
			List<IAvatarAnchorEventReceiver> list = Pool.BorrowList<IAvatarAnchorEventReceiver>();
			base.Slot.GetComponents(list);
			foreach (IAvatarAnchorEventReceiver item in list)
			{
				action(item);
				if (!IsOccupied && breakOnReleased)
				{
					break;
				}
			}
			Pool.Return(ref list);
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Highlight = new Sync<bool>();
			ParentSpace = new RootSpace();
			MinScale = new Sync<float>();
			MaxScale = new Sync<float>();
			PositionNode = new Sync<UserRoot.UserNode>();
			PositionReference = new SyncRef<Slot>();
			RotationNode = new Sync<UserRoot.UserNode>();
			RotationReference = new SyncRef<Slot>();
			PreserveUpOnEnter = new Sync<bool>();
			PreserveUpOnExit = new Sync<bool>();
			UnparentEverythingOnDestroy = new Sync<bool>();
			TransformRestoreMode = new Sync<RestoreMode>();
			RestoreNode = new Sync<UserRoot.UserNode>();
			RestoreReference = new SyncRef<Slot>();
			Filters = new SyncList<BodyNodeFilters>();
			UserFilters = new SyncRefList<IAvatarAnchorUserFilter>();
			UserAnchored = new SyncDelegate<AvatarAnchorUserEvent>();
			UserStay = new SyncDelegate<AvatarAnchorUserEvent>();
			UserReleased = new SyncDelegate<AvatarAnchorUserEvent>();
