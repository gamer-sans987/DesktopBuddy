			TipTouchSource componentInChildren = handPoser.Slot.GetComponentInChildren<TipTouchSource>();
			VibrationDeviceRelay componentInChildren2 = handPoser.Slot.GetComponentInChildren<VibrationDeviceRelay>();
			if (componentInChildren != null && componentInChildren2 != null)
			{
				TouchSource.Target = componentInChildren;
				VibrationRelay.Target = componentInChildren2;
				return;
			}
			componentInChildren?.Destroy();
			componentInChildren2?.Destroy();
			componentInChildren = null;
			componentInChildren2 = null;
			BipedRig bipedRig = handPoser.FindCompatibleRig();
			Slot slot = null;
			Slot slot2 = null;
			if (bipedRig != null)
			{
				for (BodyNode bodyNode = BodyNode.LeftIndexFinger_Tip; bodyNode >= BodyNode.LeftIndexFinger_Intermediate; bodyNode--)
				{
					slot = bipedRig.TryGetBone(bodyNode.GetSide(handPoser.Side));
					if (slot != null)
					{
						slot2 = bipedRig.TryGetBone((bodyNode - 1).GetSide(handPoser.Side));
						break;
					}
				}
			}
			else
			{
				slot = handPoser.Index.FarthestSegment?.Root.Target;
				slot2 = handPoser.Index.NearestSegment?.Root.Target;
			}
			if (slot != null && slot2 != null)
			{
				componentInChildren = slot.AttachComponent<TipTouchSource>();
				componentInChildren.Direction.Value = slot.GlobalDirectionToLocal((slot.GlobalPosition - slot2.GlobalPosition).Normalized);
				AvatarUserReferenceAssigner avatarUserReferenceAssigner = slot.AttachComponent<AvatarUserReferenceAssigner>();
				avatarUserReferenceAssigner.AssignMode.Value = AvatarUserReferenceAssigner.Mode.Whitelist;
				avatarUserReferenceAssigner.References.Add(componentInChildren.AutoUpdateUser);
				componentInChildren2 = slot.AttachComponent<VibrationDeviceRelay>();
				TouchSource.Target = componentInChildren;
				VibrationRelay.Target = componentInChildren2;
			}
		}

