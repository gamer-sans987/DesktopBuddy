		public IGrabbable Grab(Grabber grabber, Slot holdSlot, bool supressEvents = false)
		{
			if (CanGrab(grabber))
			{
				base.World.BeginUndoBatch("Undo.MoveIKBone".AsLocaleKey());
				PositionTarget.Target?.CreateUndoPoint();
				RotationTarget.Target?.CreateUndoPoint();
				base.World.EndUndoBatch();
				_grabber.Target = grabber;
				_grabbingUser.Target = base.World.LocalUser;
				_holdSlot.Target = holdSlot;
				Slot offsetSpace = Solver.Target.GetOffsetSpace();
				_posOffset.Value = holdSlot.GlobalPointToLocal(offsetSpace.LocalPointToGlobal(PositionTarget.Target.Value));
				_rotOffset.Value = holdSlot.GlobalRotationToLocal(offsetSpace.LocalRotationToGlobal(RotationTarget.Target.Value));
				this.OnLocalGrabbed?.Invoke(this);
				return this;
			}
			return null;
		}

