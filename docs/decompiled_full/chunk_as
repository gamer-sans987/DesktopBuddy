					}
					Elements.Core.floatQ localRotation = simulationSpace.LocalRotationToSpace(MathX.LerpUnclamped(in readRotations[i], GetRotation(i), IKPositionWeight), slot.Parent);
					slot.LocalRotation = localRotation;
				}
			}
		}

		private void Read(Elements.Core.float3[] positions, Elements.Core.floatQ[] rotations, bool hasChest, bool hasNeck, bool hasShoulders, bool hasToes)
