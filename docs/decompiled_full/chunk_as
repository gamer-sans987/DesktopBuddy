	public class AvatarBadgeManager : Component, IAvatarObjectComponent, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public readonly Sync<float> BadgeSize;

		public readonly Sync<float> BadgeSeparation;

		public readonly Sync<int> MaxRowSize;

		protected readonly SyncRef<Slot> _badgesRoot;

		protected readonly FieldDrive<Elements.Core.float3> _badgesOffset;

		protected override void OnAwake()
		{
			base.OnAwake();
			BadgeSize.Value = 0.05f;
			BadgeSeparation.Value = 0.005f;
			MaxRowSize.Value = 12;
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			_badgesRoot.Target = base.Slot.AddSlot("Badges");
			_badgesOffset.Target = _badgesRoot.Target.Position_Field;
		}

		protected override void OnCommonUpdate()
		{
			if (_badgesRoot.Target == null)
			{
				Destroy();
				return;
			}
			int num = MathX.Min(MathX.Max(MaxRowSize, 1), _badgesRoot.Target.ChildrenCount);
			float x = ((float)num * (float)BadgeSize + (float)(num - 1) * (float)BadgeSeparation) * -0.5f + (float)BadgeSize * 0.5f;
			_badgesOffset.Target.Value = MathX.Lerp(_badgesOffset.Target.Value, new Elements.Core.float3(x), base.Time.Delta * 2f);
		}

		public void UpdateBadges(AvatarManager manager)
		{
			SetBadges(manager.BadgeTemplates);
		}

		private void SetBadges(Slot root)
		{
			HashSet<string> hashSet = Pool.BorrowHashSet<string>();
			foreach (Slot child in _badgesRoot.Target.Children)
			{
				hashSet.Add(child.Name);
			}
			int num = MathX.Max(MaxRowSize, 1);
			foreach (Slot child2 in root.Children)
			{
				if (!hashSet.Contains(child2.Name))
				{
					Slot slot = child2.Duplicate(_badgesRoot.Target);
					slot.ActiveSelf = true;
					int num2 = _badgesRoot.Target.ChildrenCount - 1;
					int num3 = num2 % num;
					int num4 = num2 / num;
					slot.LocalScale = Elements.Core.float3.One * BadgeSize;
					slot.LocalRotation = Elements.Core.floatQ.Identity;
					slot.LocalPosition = new Elements.Core.float3(num3, num4) * (BadgeSize.Value + BadgeSeparation.Value);
					slot.Scale_Field.TweenFrom(Elements.Core.float3.Zero, 0.5f);
				}
				hashSet.Remove(child2.Name);
			}
			foreach (string item in hashSet)
			{
				Slot slot2 = _badgesRoot.Target.FindChild(item);
				slot2.Scale_Field.TweenTo(Elements.Core.float3.Zero, 0.5f, CurvePreset.Sine, slot2.Destroy);
			}
			Pool.Return(ref hashSet);
		}

		private void ClearBadges()
		{
			_badgesRoot.Target.DestroyChildren();
		}

		public void OnPreEquip(AvatarObjectSlot slot)
		{
		}

		public void OnEquip(AvatarObjectSlot slot)
		{
			UpdateBadges(slot.Slot.GetComponentInParents<AvatarManager>());
		}

		public void OnDequip(AvatarObjectSlot slot)
		{
			ClearBadges();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			BadgeSize = new Sync<float>();
			BadgeSeparation = new Sync<float>();
			MaxRowSize = new Sync<int>();
			_badgesRoot = new SyncRef<Slot>();
			_badgesOffset = new FieldDrive<Elements.Core.float3>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => BadgeSize, 
				4 => BadgeSeparation, 
				5 => MaxRowSize, 
				6 => _badgesRoot, 
				7 => _badgesOffset, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static AvatarBadgeManager __New()
		{
			return new AvatarBadgeManager();
		}
	}
