	public static class V3Tools
	{
		/// <summary>
		/// Optimized float3.Lerp
		/// </summary>
		public static Elements.Core.float3 Lerp(in Elements.Core.float3 fromVector, in Elements.Core.float3 toVector, float weight)
		{
