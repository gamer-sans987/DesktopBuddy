	public class ParticleCollisionRaycaster : IParticleCollisionRaycaster
	{
		public readonly PhysicsManager Physics;

		public readonly World World;

		public readonly PositionSimulatorModule Owner;

		private Elements.Core.float4x4 toGlobal;

		private Elements.Core.float4x4 toLocal;

		public ParticleCollisionRaycaster(PositionSimulatorModule owner)
		{
			Owner = owner;
			World = owner.World;
			Physics = World.Physics;
		}

		public void UpdateMatrices(Slot targetSpace)
		{
			toGlobal = targetSpace.LocalToGlobal;
			toLocal = targetSpace.GlobalToLocal;
		}

		public RayHit RaycastParticle(Elements.Core.float3 origin, Elements.Core.float3 direction, float distance)
		{
			origin = toGlobal.TransformPoint3x4(in origin);
			direction = toGlobal.TransformDirection(in direction);
			distance = toGlobal.TransformScale(distance);
			try
			{
				if (!PhysicsManager.IsValidRaycast(in origin, in direction, distance))
				{
					return RayHit.NoHit;
				}
				RaycastHit? raycastHit = Physics.RaycastOne(in origin, in direction, distance);
				if (!raycastHit.HasValue)
				{
					return RayHit.NoHit;
				}
				ref Elements.Core.float4x4 reference = ref toLocal;
				RaycastHit value = raycastHit.Value;
				Elements.Core.float3 point = reference.TransformPoint3x4(in value.Point);
				ref Elements.Core.float4x4 reference2 = ref toLocal;
				value = raycastHit.Value;
				Elements.Core.float3 normal = reference2.TransformDirection(in value.Normal);
				float distance2 = toLocal.TransformScale(raycastHit.Value.Distance);
				return new RayHit(in point, in normal, distance2);
			}
			catch (Exception value2)
			{
				UniLog.Error($"Exception when running particle raycast: {value2}", stackTrace: false);
				return RayHit.NoHit;
			}
		}
	}
