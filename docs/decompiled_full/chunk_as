		private void UpdateTarget(FieldDrive<float> target, float value, float minIn, float maxIn, float minOut, float maxOut)
		{
			if (target.IsLinkValid)
			{
				value = MathX.InverseLerp(minIn, maxIn, value);
				value = MathX.Clamp01(value);
				target.Target.Value = MathX.Lerp(minOut, maxOut, value);
			}
		}

		protected override void OnCommonUpdate()
		{
			if (EyeManager.Target == null)
			{
				return;
			}
			EyeManager target = EyeManager.Target;
			float num = 0f;
			float num2 = 0f;
			foreach (EyeCloseLimit leftCloseSubtractLimit in LeftCloseSubtractLimits)
			{
				if (leftCloseSubtractLimit.Source.Target != null)
				{
					num = MathX.Max(leftCloseSubtractLimit.Source.Target.Value * (float)leftCloseSubtractLimit.Multiplier, num);
				}
			}
			foreach (EyeCloseLimit rightCloseSubtractLimit in RightCloseSubtractLimits)
			{
				if (rightCloseSubtractLimit.Source.Target != null)
				{
					num2 = MathX.Max(rightCloseSubtractLimit.Source.Target.Value * (float)rightCloseSubtractLimit.Multiplier, num2);
				}
			}
			foreach (EyeCloseLimit combinedCloseSubtractLimit in CombinedCloseSubtractLimits)
			{
				if (combinedCloseSubtractLimit.Source.Target != null)
				{
					float val = combinedCloseSubtractLimit.Source.Target.Value * (float)combinedCloseSubtractLimit.Multiplier;
					num = MathX.Max(val, num);
					num2 = MathX.Max(val, num2);
				}
			}
			float num3 = MathX.Max(num, num2);
			float num4 = MathX.Clamp01(target.LeftEyeClose.Value - num);
			float num5 = MathX.Clamp01(target.RightEyeClose.Value - num2);
			float num6 = MathX.Clamp01(target.CombinedEyeClose.Value - num3);
			foreach (Eye eye in Eyes)
			{
				eye._processOffset = false;
				if (eye.PositionOffset.IsLinkValid || eye.LookLeft.IsLinkValid || eye.LookUp.IsLinkValid || eye.LookRight.IsLinkValid || eye.LookDown.IsLinkValid)
				{
					if (eye.ProjectionPlanePoint.Target == null)
					{
						if (eye.PositionOffset.IsLinkValid)
						{
							eye.PositionOffset.Target.Value = PositionOffsetCenter.Value;
						}
						if (eye.LookLeft.IsLinkValid)
						{
							eye.LookLeft.Target.Value = 0f;
						}
						if (eye.LookUp.IsLinkValid)
						{
							eye.LookUp.Target.Value = 0f;
						}
						if (eye.LookRight.IsLinkValid)
						{
							eye.LookRight.Target.Value = 0f;
						}
						if (eye.LookDown.IsLinkValid)
						{
							eye.LookDown.Target.Value = 0f;
						}
					}
					else
					{
						Elements.Core.float3 globalPoint = eye.Side.Value switch
						{
							EyeSide.Left => target.LeftEyeTargetPoint.Value, 
							EyeSide.Right => target.RightEyeTargetPoint.Value, 
							_ => target.TargetPoint.Value, 
						};
						globalPoint = eye.ProjectionPlanePoint.Target.GlobalPointToLocal(in globalPoint);
						globalPoint = new Elements.Core.float3(globalPoint.xy, MathX.Max(MinimumTargetPointDistance, globalPoint.z)).Normalized;
						Elements.Core.float2 vector = -MathX.RayPlaneIntersection(new Elements.Core.float3(0f, 0f, 0f - (float)ProjectionPointDistance), in globalPoint, Elements.Core.float3.Zero, Elements.Core.float3.Forward).xy / ProjectionPlaneSize.Value;
						vector = ((PositionClampMode.Value != ClampMode.Circle) ? MathX.Clamp(in vector, -Elements.Core.float2.One, Elements.Core.float2.One) : MathX.ClampMagnitude(in vector, 1f));
						eye._computedOffset = vector;
						eye._processOffset = true;
					}
				}
				if (eye.OpenCloseTarget.IsLinkValid)
				{
					EyeSide value = eye.Side.Value;
					UpdateTarget(eye.OpenCloseTarget, value switch
					{
						EyeSide.Left => num4, 
						EyeSide.Right => num5, 
						_ => num6, 
					}, eye.MinInputCloseness, eye.MaxInputCloseness, eye.OpenState, eye.ClosedState);
				}
				UpdateTarget(eye.WidenTarget, target.GetWiden(eye.Side), eye.MinInputWiden, eye.MaxInputWiden, eye.MinOutputWiden, eye.MaxOutputWiden);
				UpdateTarget(eye.SqueezeTarget, target.GetSqueeze(eye.Side), eye.MinInputSqueeze, eye.MaxInputSqueeze, eye.MinOutputSqueeze, eye.MaxOutputSqueeze);
				UpdateTarget(eye.FrownTarget, target.GetFrown(eye.Side), eye.MinInputFrown, eye.MaxInputFrown, eye.MinOutputFrown, eye.MaxOutputFrown);
				UpdateTarget(eye.InnerBrowRaiseTarget, 0f - target.GetInnerBrowVertical(eye.Side), eye.MinInputInnerBrowRaise, eye.MaxInputInnerBrowRaise, eye.MinOutputInnerBrowRaise, eye.MaxOutputInnerBrowRaise);
				UpdateTarget(eye.InnerBrowLowerTarget, 0f - target.GetInnerBrowVertical(eye.Side), eye.MinInputInnerBrowLower, eye.MaxInputInnerBrowLower, eye.MinOutputInnerBrowLower, eye.MaxOutputInnerBrowLower);
				UpdateTarget(eye.OuterBrowRaiseTarget, target.GetOuterBrowVertical(eye.Side), eye.MinInputOuterBrowRaise, eye.MaxInputOuterBrowRaise, eye.MinOutputOuterBrowRaise, eye.MaxOutputOuterBrowRaise);
				UpdateTarget(eye.OuterBrowLowerTarget, target.GetOuterBrowVertical(eye.Side), eye.MinInputOuterBrowLower, eye.MaxInputOuterBrowLower, eye.MinOutputOuterBrowLower, eye.MaxOutputOuterBrowLower);
				if (eye.PupilSizeTarget.IsLinkValid)
				{
					float num7 = MathX.Remap(eye.Side.Value switch
					{
						EyeSide.Left => target.LeftEyePupilSizeMillimeters.Value, 
						EyeSide.Right => target.RightEyePupilSizeMillimeters.Value, 
						_ => target.CombinedEyePupilSizeMillimeters.Value, 
					}, eye.MinInputPupilSize, eye.MaxInputPupilSize, eye.MinOutputPupilSize, eye.MaxOutputPupilSize);
					float num8 = (eye.PupilSizeTarget.Target.Value = num7);
					num7 = num8;
				}
			}
			foreach (Eye eye2 in Eyes)
			{
				if (eye2._processOffset)
				{
					Elements.Core.float2 b = eye2._computedOffset;
					b = PositionOffsetCenter.Value + PositionOffsetRange.Value * b;
					if (eye2.PositionOffset.IsLinkValid)
					{
						eye2.PositionOffset.Target.Value = b;
					}
					if (eye2.LookUp.IsLinkValid)
					{
						eye2.LookUp.Target.Value = eye2.ProcessLook(0f - eye2._computedOffset.y);
					}
					if (eye2.LookDown.IsLinkValid)
					{
						eye2.LookDown.Target.Value = eye2.ProcessLook(eye2._computedOffset.y);
					}
					if (eye2.LookLeft.IsLinkValid)
					{
						eye2.LookLeft.Target.Value = eye2.ProcessLook(eye2._computedOffset.x);
					}
					if (eye2.LookRight.IsLinkValid)
					{
						eye2.LookRight.Target.Value = eye2.ProcessLook(0f - eye2._computedOffset.x);
					}
				}
			}
		}

