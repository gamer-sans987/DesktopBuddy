			_rightFootTargetPos.Target = ik.Solver.rightLeg.IKPosition;
			_rightFootTargetRot.Target = ik.Solver.rightLeg.IKRotation;
			_leftKneeTargetPos.Target = ik.Solver.leftLeg.BendGoalPosition;
			_rightKneeTargetPos.Target = ik.Solver.rightLeg.BendGoalPosition;
			_leftFootOffset.Target = ik.Solver.locomotion.LeftFootOffset;
