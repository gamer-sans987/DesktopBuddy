		public void GuessMisalignedHands(float maxAngle = 20f)
		{
			Slot target = BoneReferences.leftHand.Target;
			Slot target2 = BoneReferences.rightHand.Target;
			BoneReferences.leftHand.Target = GuessMisalignedHand(target, maxAngle);
			BoneReferences.rightHand.Target = GuessMisalignedHand(target2, maxAngle);
		}

		public Slot GuessMisalignedHand(Slot hand, float maxAngle)
		{
			Elements.Core.float3 v = Elements.Core.float3.Zero;
			int num = 0;
			foreach (Slot child in hand.Children)
			{
				if (child.GetMaxChildDepth() >= 2)
				{
					v += child.GlobalPosition;
					num++;
				}
			}
			if (num > 0)
			{
				Elements.Core.float3 a = (v / num - hand.GlobalPosition).Normalized;
				Elements.Core.float3 from = Elements.Core.float3.Zero;
				float num2 = float.MaxValue;
				for (int i = 0; i < 6; i++)
				{
					Elements.Core.float3 b = hand.LocalDirectionToGlobal(Elements.Core.float3.Zero.SetComponent((i < 3) ? 1f : (-1f), i % 3));
					float num3 = MathX.Angle(in a, in b);
					if (num3 < num2)
					{
						num2 = num3;
						from = b;
					}
				}
				if (num2 > maxAngle)
				{
					Elements.Core.floatQ b2 = Elements.Core.floatQ.FromToRotation(in from, in a);
					Slot slot = hand.Parent.AddSlot("Aligned Hand");
					slot.CopyTransform(hand);
					slot.GlobalRotation *= b2;
					hand.Parent = slot;
					return slot;
				}
			}
			return hand;
		}

		/// <summary>
		/// Guesses the hand bones orientations ('Wrist To Palm Axis' and "Palm To Thumb Axis" of the arms) based on the provided references. if onlyIfZero is true, will only guess an orientation axis if it is float3.zero.
		/// </summary>
		public void GuessHandOrientations(bool onlyIfZero)
		{
			References boneReferences = BoneReferences;
			if (!boneReferences.isFilled)
			{
				base.Debug.Warning("VRIK References are not filled in, can not guess hand orientations. Right-click on VRIK header and slect 'Guess Hand Orientations' when you have filled in the References.");
				return;
			}
			if ((Elements.Core.float3)leftArm.WristToPalmAxis == Elements.Core.float3.Zero || !onlyIfZero)
			{
				leftArm.WristToPalmAxis.Value = GuessWristToPalmAxis(boneReferences.leftHand, boneReferences.leftForearm);
			}
			if ((Elements.Core.float3)leftArm.PalmToThumbAxis == Elements.Core.float3.Zero || !onlyIfZero)
			{
				leftArm.PalmToThumbAxis.Value = GuessPalmToThumbAxis(boneReferences.leftHand, boneReferences.leftForearm);
			}
			if ((Elements.Core.float3)rightArm.WristToPalmAxis == Elements.Core.float3.Zero || !onlyIfZero)
			{
				rightArm.WristToPalmAxis.Value = GuessWristToPalmAxis(boneReferences.rightHand, boneReferences.rightForearm);
			}
			if ((Elements.Core.float3)rightArm.PalmToThumbAxis == Elements.Core.float3.Zero || !onlyIfZero)
			{
				rightArm.PalmToThumbAxis.Value = GuessPalmToThumbAxis(boneReferences.rightHand, boneReferences.rightForearm);
			}
		}

		public void GuessLegBendNormals(bool onlyIfZero)
		{
			References boneReferences = BoneReferences;
			if (!boneReferences.isFilled)
			{
				base.Debug.Warning("VRIK References are not filled in, can not guess hand orientations. Right-click on VRIK header and slect 'Guess Hand Orientations' when you have filled in the References.");
				return;
			}
			Elements.Core.float3 leftToRight = boneReferences.rightCalf.Target.GlobalPosition - boneReferences.leftCalf.Target.GlobalPosition + (boneReferences.rightFoot.Target.GlobalPosition - boneReferences.leftFoot.Target.GlobalPosition);
			if ((Elements.Core.float3)leftLeg.CalfBendNormal == Elements.Core.float3.Zero || !onlyIfZero)
			{
				AssignBendNormal(leftLeg, boneReferences.leftCalf.Target, leftToRight);
			}
			if ((Elements.Core.float3)rightLeg.CalfBendNormal == Elements.Core.float3.Zero || !onlyIfZero)
			{
				AssignBendNormal(rightLeg, boneReferences.rightCalf.Target, leftToRight);
			}
		}

		private void AssignBendNormal(Leg leg, Slot calf, Elements.Core.float3 leftToRight)
		{
			leg.CalfBendNormal.Value = calf.GlobalDirectionToLocal(in leftToRight).Normalized;
			if (MathX.Dot(calf.GlobalRotation * leg.CalfBendNormal.Value, in leftToRight) < 0f)
			{
				Sync<Elements.Core.float3> calfBendNormal = leg.CalfBendNormal;
				calfBendNormal.Value *= -1f;
			}
		}

		public void GuessFeetSeparation()
		{
			References boneReferences = BoneReferences;
			if (!boneReferences.isFilled)
			{
				base.Debug.Warning("VRIK References are not filled in, can not guess hand orientations. Right-click on VRIK header and slect 'Guess Hand Orientations' when you have filled in the References.");
				return;
			}
			float globalScale = MathX.Distance(boneReferences.leftFoot.Target.GlobalPosition, boneReferences.rightFoot.Target.GlobalPosition) * 1.5f;
			locomotion.FootDistance.Value = boneReferences.root.Target.GlobalScaleToLocal(globalScale);
			locomotion.StepThreshold.Value = (float)locomotion.FootDistance * 1.333f;
		}

		public void GuessMinHeadHeight()
		{
			References boneReferences = BoneReferences;
			if (!boneReferences.isFilled)
			{
				base.Debug.Warning("VRIK References are not filled in, can not guess hand orientations. Right-click on VRIK header and slect 'Guess Hand Orientations' when you have filled in the References.");
				return;
			}
			Slot obj = boneReferences.leftToes.Target ?? boneReferences.leftFoot.Target;
			Slot slot = boneReferences.rightToes.Target ?? boneReferences.rightFoot.Target;
			Elements.Core.float3 to = (obj.GlobalPosition + slot.GlobalPosition) * 0.5f;
			float globalScale = MathX.LerpUnclamped(boneReferences.head.Target.GlobalPosition, in to, 0.7f).y - boneReferences.root.Target.GlobalPosition.y;
			spine.MinHeadHeight.Value = boneReferences.root.Target.GlobalScaleToLocal(globalScale);
		}

		public void CreateCenteredRoot()
		{
			References boneReferences = BoneReferences;
			if (!boneReferences.isFilled)
			{
				base.Debug.Warning("VRIK References are not filled in, can not guess hand orientations. Right-click on VRIK header and slect 'Guess Hand Orientations' when you have filled in the References.");
				return;
			}
			Slot slot = boneReferences.leftToes.Target ?? boneReferences.leftFoot.Target;
			Slot slot2 = boneReferences.rightToes.Target ?? boneReferences.rightFoot.Target;
			foreach (Slot allChild in slot.GetAllChildren())
			{
				if (allChild.GlobalPosition.y < slot.GlobalPosition.y)
				{
					slot = allChild;
				}
			}
			foreach (Slot allChild2 in slot2.GetAllChildren())
			{
				if (allChild2.GlobalPosition.y < slot2.GlobalPosition.y)
				{
					slot2 = allChild2;
				}
			}
			Elements.Core.float3 b = (slot.GlobalPosition + slot2.GlobalPosition) * 0.5f;
			Elements.Core.float3 b2 = (boneReferences.head.Target.GlobalPosition - b).Normalized;
			Slot target = boneReferences.root.Target;
			float a = MathX.Dot(target.Up, in b2);
			float num = MathX.Dot(target.Forward, in b2);
			float num2 = MathX.Dot(target.Backward, in b2);
			float num3 = MathX.Max(a, num, num2);
			Slot slot3 = target.AddSlot("CenteredRoot");
			if (num3 == num)
			{
				slot3.LocalRotation = Elements.Core.floatQ.FromToRotation(Elements.Core.float3.Forward, Elements.Core.float3.Up).Inverted;
			}
			if (num3 == num2)
			{
				slot3.LocalRotation = Elements.Core.floatQ.FromToRotation(Elements.Core.float3.Right, Elements.Core.float3.Up).Inverted;
			}
			Elements.Core.float3 localDirection = BoneReferences.spine.Target.GuessForwardAxis(slot.GlobalPosition, slot2.GlobalPosition, Elements.Core.float3.Zero, in b2);
			localDirection = slot3.LocalDirectionToGlobal(slot3.GlobalDirectionToLocal(BoneReferences.spine.Target.LocalDirectionToGlobal(in localDirection)).x_z.Normalized);
			if (MathX.Angle(in localDirection, slot3.Forward) > 15f)
			{
				slot3.GlobalRotation *= Elements.Core.floatQ.FromToRotation(slot3.Forward, in localDirection);
			}
			if (target.GlobalPosition.y < b.y)
			{
				b = new Elements.Core.float3(b.x, target.GlobalPosition.y, b.z);
			}
			slot3.LocalPosition = slot3.LocalPointToParent(slot3.GlobalPointToLocal(in b));
			for (int num4 = target.ChildrenCount - 1; num4 >= 0; num4--)
			{
				if (target[num4] != slot3)
				{
					target[num4].Parent = slot3;
				}
			}
			boneReferences.root.Target = slot3;
			ForceRootHeight.Value = GetSimulationSpace().GlobalPointToLocal(slot3.GlobalPosition).y;
		}

