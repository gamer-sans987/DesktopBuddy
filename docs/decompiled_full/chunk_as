		public void AutoAssign(SkinnedMeshRenderer skin)
		{
			List<ExpressionCandidate> list = new List<ExpressionCandidate>();
			for (int i = 0; i < skin.MeshBlendshapeCount; i++)
			{
				Sync<float> element = skin.BlendShapeWeights.GetElement(i);
				if (!element.IsDriven)
				{
					string text = skin.BlendShapeName(i);
					List<string> names = NameHeuristicsHelper.SplitName(text);
					Chirality? chirality = NameHeuristicsHelper.NameToBoneChirality(text, names);
					AvatarExpression? value = DetermineExpression(names, text, chirality);
					UniLog.Log($"Name: {text}, Expression: {value}");
					if (value.HasValue)
					{
						list.Add(new ExpressionCandidate(value.Value, DetermineTarget(names), element, names));
					}
				}
			}
			DictionaryList<AvatarExpression, ExpressionCandidate> dictionaryList = new DictionaryList<AvatarExpression, ExpressionCandidate>();
			foreach (ExpressionCandidate item in list)
			{
				dictionaryList.Add(item.expression, item);
			}
			list.Clear();
			foreach (KeyValuePair<AvatarExpression, List<ExpressionCandidate>> item2 in dictionaryList)
			{
				if (item2.Value.Count == 1)
				{
					continue;
				}
				if (item2.Value.Any((ExpressionCandidate c) => c.target == FaceTarget.Unknown) && item2.Value.Any((ExpressionCandidate c) => c.target != FaceTarget.Unknown))
				{
					item2.Value.RemoveAll((ExpressionCandidate c) => c.target == FaceTarget.Unknown);
				}
				foreach (ExpressionCandidate item3 in item2.Value)
				{
					if (item3.names.Contains("jaw"))
					{
						item3.score = 5;
					}
					else if (item3.names.Contains("lip"))
					{
						item3.score = 4;
					}
					else if (item3.names.Contains("mouth"))
					{
						item3.score = 3;
					}
				}
				item2.Value.Sort(delegate(ExpressionCandidate a, ExpressionCandidate b)
				{
					int num = -a.names.Count.CompareTo(b.names.Count);
					return (num != 0) ? num : (-a.score.CompareTo(b.score));
				});
				ExpressionCandidate firstMouthJaw = item2.Value.FirstOrDefault((ExpressionCandidate c) => c.target == FaceTarget.MouthJaw);
				if (firstMouthJaw != null)
				{
					item2.Value.RemoveAll((ExpressionCandidate c) => c.target == FaceTarget.MouthJaw && c != firstMouthJaw);
				}
			}
			foreach (KeyValuePair<AvatarExpression, List<ExpressionCandidate>> item4 in dictionaryList)
			{
				foreach (ExpressionCandidate item5 in item4.Value)
				{
					list.Add(item5);
				}
			}
			RemoveDualSided(list, AvatarExpression.SmileLeft, AvatarExpression.SmileRight, AvatarExpression.Smile);
			RemoveDualSided(list, AvatarExpression.FrownLeft, AvatarExpression.FrownRight, AvatarExpression.Frown);
			RemoveDualSided(list, AvatarExpression.GrinLeft, AvatarExpression.GrinRight, AvatarExpression.Grin);
			RemoveDualSided(list, AvatarExpression.CheekPuffLeft, AvatarExpression.CheekPuffRight, AvatarExpression.CheekPuff);
			RemoveDualSided(list, AvatarExpression.CheekSuckLeft, AvatarExpression.CheekSuckRight, AvatarExpression.CheekSuck);
			RemoveComposites(list, AvatarExpression.SmirkLeft, AvatarExpression.SmileLeft, AvatarExpression.SmileRight);
			RemoveComposites(list, AvatarExpression.SmirkRight, AvatarExpression.SmileLeft, AvatarExpression.SmileRight);
			RemoveComposites(list, AvatarExpression.GrinLeft, AvatarExpression.LipRaiseUpperLeft);
			RemoveComposites(list, AvatarExpression.GrinRight, AvatarExpression.LipRaiseUpperRight);
			RemoveComposites(list, AvatarExpression.Grin, AvatarExpression.LipRaiseUpperLeft, AvatarExpression.LipRaiseUpperRight);
			RemoveComposites(list, AvatarExpression.Angry, AvatarExpression.LipRaiseUpperLeft, AvatarExpression.LipRaiseUpperRight, AvatarExpression.LipRaiseLowerLeft, AvatarExpression.LipRaiseLowerRight);
			foreach (ExpressionCandidate item6 in list)
			{
				AddExpression(item6.expression, item6.field);
			}
		}

		private static void RemoveDualSided(List<ExpressionCandidate> candidates, AvatarExpression left, AvatarExpression right, AvatarExpression dual)
		{
			if (candidates.Any((ExpressionCandidate e) => e.expression == left) && candidates.Any((ExpressionCandidate e) => e.expression == right))
			{
				candidates.RemoveAll((ExpressionCandidate e) => e.expression == dual);
			}
		}

		private static void RemoveComposites(List<ExpressionCandidate> candidates, AvatarExpression composite, params AvatarExpression[] parts)
		{
			HashSet<FaceTarget> hashSet = new HashSet<FaceTarget>();
			foreach (AvatarExpression avatarExpression in parts)
			{
				foreach (ExpressionCandidate candidate in candidates)
				{
					if (candidate.expression == avatarExpression)
					{
						hashSet.Add(candidate.target);
					}
				}
				foreach (FaceTarget target in hashSet)
				{
					candidates.RemoveAll((ExpressionCandidate c) => c.expression == composite && (c.target == FaceTarget.Unknown || c.target == target));
				}
				hashSet.Clear();
			}
		}

		private static FaceTarget DetermineTarget(List<string> names)
		{
			if (names.Contains("笑い") || names.Contains("敵意"))
			{
				return FaceTarget.Eyes;
			}
			if (names.Contains("にっこり") || names.Contains("∧") || names.Contains("□") || names.Contains("ぺろっ"))
			{
				return FaceTarget.MouthJaw;
			}
			if (names.Contains("nose"))
			{
				return FaceTarget.Nose;
			}
			if (names.Contains("eye") || names.Contains("eyes"))
			{
				return FaceTarget.Eyes;
			}
			if (names.Contains("teeth"))
			{
				return FaceTarget.Teeth;
			}
			if (names.Contains("mouth") || names.Contains("jaw") || names.Contains("tongue"))
			{
				return FaceTarget.MouthJaw;
			}
			return FaceTarget.Unknown;
		}

		public static AvatarExpression? DetermineExpression(List<string> names, string name, Chirality? chirality)
		{
			foreach (AvatarExpression item in Enum.GetValues(typeof(AvatarExpression)).Cast<AvatarExpression>())
			{
				if (name.Equals(item.ToString(), StringComparison.InvariantCultureIgnoreCase))
				{
					return item;
				}
			}
			name = name.ToLower();
			switch (name)
			{
			case "笑い":
			case "にっこり":
				return AvatarExpression.Smile;
			case "敵意":
			case "□":
				return AvatarExpression.Angry;
			case "∧":
				return AvatarExpression.Frown;
			case "ぺろっ":
				return AvatarExpression.TongueOut;
			default:
			{
				bool flag = name.Contains("m0") && names.Contains("expressions");
				if (names.Contains("blep"))
				{
					return AvatarExpression.TongueOut;
				}
				if (names.Contains("angry") || names.Contains("growl"))
				{
					return AvatarExpression.Angry;
				}
				if (names.Contains("cheek"))
				{
					if (names.Contains("puff"))
					{
						if (chirality == Chirality.Left)
						{
							return AvatarExpression.CheekPuffLeft;
						}
						if (chirality == Chirality.Right)
						{
							return AvatarExpression.CheekPuffRight;
						}
						return AvatarExpression.CheekPuff;
					}
					if (names.Contains("suck"))
					{
						if (chirality == Chirality.Left)
						{
							return AvatarExpression.CheekSuckLeft;
						}
						if (chirality == Chirality.Right)
						{
							return AvatarExpression.CheekSuckRight;
						}
						return AvatarExpression.CheekSuck;
					}
					if (names.Contains("raise"))
					{
						if (chirality == Chirality.Left)
						{
							return AvatarExpression.CheekRaiseLeft;
						}
						if (chirality == Chirality.Right)
						{
							return AvatarExpression.CheekRaiseRight;
						}
						return AvatarExpression.CheekRaise;
					}
				}
				if (names.Contains("blow"))
				{
					if (chirality == Chirality.Left)
					{
						return AvatarExpression.CheekPuffLeft;
					}
					if (chirality == Chirality.Right)
					{
						return AvatarExpression.CheekPuffRight;
					}
					return AvatarExpression.CheekPuff;
				}
				if (names.Contains("jaw"))
				{
					if (names.Contains("left"))
					{
						return AvatarExpression.JawLeft;
					}
					if (names.Contains("right"))
					{
						return AvatarExpression.JawRight;
					}
					if (names.Contains("forward") || names.Contains("front"))
					{
						return AvatarExpression.JawForward;
					}
					if (names.Contains("open"))
					{
						return AvatarExpression.JawOpen;
					}
					if (chirality == Chirality.Left)
					{
						return AvatarExpression.JawLeft;
					}
					if (chirality == Chirality.Right)
					{
						return AvatarExpression.JawRight;
					}
				}
				if (names.Contains("tongue"))
				{
					if (name.Contains("longstep1"))
					{
						return AvatarExpression.TongueRaise;
					}
					if (name.Contains("longstep2"))
					{
						return AvatarExpression.TongueExtend;
					}
					if (names.Contains("up"))
					{
						if (names.Contains("left"))
						{
							return AvatarExpression.TongueUpLeft;
						}
						if (names.Contains("right"))
						{
							return AvatarExpression.TongueUpRight;
						}
						return AvatarExpression.TongueUp;
					}
					if (names.Contains("down"))
					{
						if (names.Contains("left"))
						{
							return AvatarExpression.TongueDownLeft;
						}
						if (names.Contains("right"))
						{
							return AvatarExpression.TongueDownRight;
						}
						return AvatarExpression.TongueDown;
					}
					if (names.Contains("left"))
					{
						return AvatarExpression.TongueLeft;
					}
					if (names.Contains("right"))
					{
						return AvatarExpression.TongueRight;
					}
					if (names.Contains("roll"))
					{
						return AvatarExpression.TongueRoll;
					}
					return AvatarExpression.TongueOut;
				}
				if (names.Contains("pout") || names.Contains("pucker") || names.Contains("kiss"))
				{
					if (chirality == Chirality.Left)
					{
						return AvatarExpression.PoutLeft;
					}
					if (chirality == Chirality.Right)
					{
						return AvatarExpression.PoutRight;
					}
					return AvatarExpression.Pout;
				}
				if (names.Contains("nose") && (names.Contains("snarl") || names.Contains("wrinkle") || names.Contains("sneer")))
				{
					if (chirality == Chirality.Left)
					{
						return AvatarExpression.NoseWrinkleLeft;
					}
					if (chirality == Chirality.Right)
					{
						return AvatarExpression.NoseWrinkleRight;
					}
					return AvatarExpression.NoseWrinkle;
				}
				if (names.Contains("grin"))
				{
					if (chirality == Chirality.Left)
					{
						return AvatarExpression.GrinLeft;
					}
					if (chirality == Chirality.Right)
					{
						return AvatarExpression.GrinRight;
					}
					return AvatarExpression.Grin;
				}
				if (names.Contains("smile") || names.Contains("happy"))
				{
					if ((names.Contains("close") || names.Contains("closed")) && !flag)
					{
						if (chirality == Chirality.Left)
						{
							return AvatarExpression.SmileClosedLeft;
						}
						if (chirality == Chirality.Right)
						{
							return AvatarExpression.SmileClosedRight;
						}
						return AvatarExpression.SmileClosed;
					}
					if (names.Contains("open"))
					{
						if (flag)
						{
							return null;
						}
						if (chirality == Chirality.Left)
						{
							return AvatarExpression.GrinLeft;
						}
						if (chirality == Chirality.Right)
						{
							return AvatarExpression.GrinRight;
						}
						return AvatarExpression.Grin;
					}
					if (chirality == Chirality.Left)
					{
						return AvatarExpression.SmileLeft;
					}
					if (chirality == Chirality.Right)
					{
						return AvatarExpression.SmileRight;
					}
					return AvatarExpression.Smile;
				}
				if (names.Contains("frown") || names.Contains("sad"))
				{
					if (chirality == Chirality.Left)
					{
						return AvatarExpression.FrownLeft;
					}
					if (chirality == Chirality.Right)
					{
						return AvatarExpression.FrownRight;
					}
					return AvatarExpression.Frown;
				}
				if (name.Contains("MPB"))
				{
					if (names.Contains("down"))
					{
						return AvatarExpression.LipUnderlayLower;
					}
					if (names.Contains("up"))
					{
						return AvatarExpression.LipUnderlayUpper;
					}
				}
				if (names.Contains("mouth") || names.Contains("lip") || names.Contains("lips"))
				{
					if (names.Contains("open"))
					{
						return AvatarExpression.JawOpen;
					}
					if (names.Contains("ape"))
					{
						return AvatarExpression.JawDown;
					}
					if (names.Contains("overturn"))
					{
						if (IsUpper(names, name))
						{
							if (chirality == Chirality.Left)
							{
								return AvatarExpression.LipTopLeftOverturn;
							}
							if (chirality == Chirality.Right)
							{
								return AvatarExpression.LipTopRightOverturn;
							}
							return AvatarExpression.LipTopOverturn;
						}
						if (IsLower(names, name))
						{
							if (chirality == Chirality.Left)
							{
								return AvatarExpression.LipTopLeftOverturn;
							}
							if (chirality == Chirality.Right)
							{
								return AvatarExpression.LipTopRightOverturn;
							}
							return AvatarExpression.LipTopOverturn;
						}
					}
					else if (names.Contains("overlay") || names.Contains("shrug"))
					{
						if (IsUpper(names, name))
						{
							return AvatarExpression.LipOverlayUpper;
						}
						if (IsLower(names, name))
						{
							return AvatarExpression.LipOverlayLower;
						}
					}
					else if (names.Contains("inside") || names.Contains("under") || names.Contains("roll"))
					{
						if (IsUpper(names, name))
						{
							return AvatarExpression.LipUnderlayUpper;
						}
						if (IsLower(names, name))
						{
							return AvatarExpression.LipUnderlayLower;
						}
					}
					else
					{
						if (names.Contains("narrow"))
						{
							return AvatarExpression.Pout;
						}
						if (IsUpper(names, name))
						{
							if (name.Contains("upleft"))
							{
								return AvatarExpression.LipRaiseUpperLeft;
							}
							if (name.Contains("upright"))
							{
								return AvatarExpression.LipRaiseUpperRight;
							}
							if (names.Contains("left"))
							{
								return AvatarExpression.LipMoveLeftUpper;
							}
							if (names.Contains("right"))
							{
								return AvatarExpression.LipMoveRightUpper;
							}
						}
						else if (IsLower(names, name))
						{
							if (name.Contains("downleft"))
							{
								return AvatarExpression.LipRaiseLowerLeft;
							}
							if (name.Contains("downright"))
							{
								return AvatarExpression.LipRaiseLowerRight;
							}
							if (names.Contains("left"))
							{
								return AvatarExpression.LipMoveLeftLower;
							}
							if (names.Contains("right"))
							{
								return AvatarExpression.LipMoveRightLower;
							}
						}
					}
				}
				if (names.Contains("lip") || names.Contains("lips"))
				{
					if (names.Contains("down"))
					{
						if (chirality == Chirality.Left)
						{
							return AvatarExpression.LipRaiseLowerLeft;
						}
						if (chirality == Chirality.Right)
						{
							return AvatarExpression.LipRaiseLowerRight;
						}
					}
					if (names.Contains("up"))
					{
						if (chirality == Chirality.Left)
						{
							return AvatarExpression.LipRaiseUpperLeft;
						}
						if (chirality == Chirality.Right)
						{
							return AvatarExpression.LipRaiseUpperRight;
						}
					}
				}
				if (names.Contains("mouth") || names.Contains("jaw"))
				{
					if (names.Contains("down"))
					{
						return AvatarExpression.JawDown;
					}
					if (names.Contains("left") && names.Count == 2)
					{
						return AvatarExpression.LipMoveLeftUpper;
					}
					if (names.Contains("right") && names.Count == 2)
					{
						return AvatarExpression.LipMoveRightUpper;
					}
				}
				return null;
			}
			}
		}

		private static bool IsUpper(List<string> names, string name)
		{
			if (!names.Contains("upper"))
			{
				return names.Contains("top");
			}
			return true;
		}

		private static bool IsLower(List<string> names, string name)
		{
			if (!names.Contains("lower"))
			{
				return names.Contains("bottom");
			}
			return true;
		}

		private void AddExpression(AvatarExpression expression, IField<float> field)
		{
			ExpressionDriver expressionDriver = ExpressionDrivers.Add();
			expressionDriver.Target.Target = field;
			expressionDriver.Expression.Value = expression;
			if ((uint)(expression - 19) <= 1u || (uint)(expression - 51) <= 1u || expression == AvatarExpression.JawHorizontal)
			{
				expressionDriver.Min.Value = -1f;
			}
		}

