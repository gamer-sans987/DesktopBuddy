		}

		internal void MarkEmitterMappingDirty()
		{
			EmitterMappingDirty = true;
		}

		public void Dispose()
		{
			if (rendererModules == null)
			{
				throw new InvalidOperationException("Manager has already been disposed");
			}
			foreach (KeyValuePair<IParticleRenderer, Slot> rendererModule in rendererModules)
			{
				rendererModule.Key.Unregister(this);
			}
			rendererModules = null;
			NativeSystem.ThreadSafeDispose();
		}
