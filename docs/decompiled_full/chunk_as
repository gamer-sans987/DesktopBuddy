	public class AvatarObjectSlot : UserRootComponent
	{
		public readonly Sync<int> Priority;

		public readonly LinkRef<IAvatarObject> Equipped;

		public readonly Sync<BodyNode> Node;

		public readonly Sync<bool> IsTracking;

		public readonly Sync<bool> IsActive;

		public readonly Sync<bool> IsSimulated;

		public readonly Sync<bool> DriveActive;

		public readonly Sync<bool> DriveScale;

		public readonly Sync<bool> DoNotSimulate;

		public readonly PrioritySyncRefList<IAvatarPoseFilter> Filters;

		protected readonly SyncRef<AvatarPoseSmoothLerp> _autoSmoothing;

		private bool _smoothingSettingRegistered;

		public bool HasEquipped => Equipped.Target != null;

		private static bool InstallSmoothing(BodyNode node)
		{
			switch (node)
			{
			case BodyNode.Hips:
			case BodyNode.LeftHand:
			case BodyNode.RightHand:
			case BodyNode.LeftFoot:
			case BodyNode.RightFoot:
				return true;
			default:
				return false;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			IsTracking.Value = true;
			IsActive.Value = true;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (!base.IsUnderLocalUser || !Node.GetWasChangedAndClear())
			{
				return;
			}
			base.Slot.ActiveUserRoot.GetRegisteredComponent<AvatarManager>()?.NotifyObjectSlotNodeChanged(Node.Value, this);
			if (InstallSmoothing(Node.Value))
			{
				if (_autoSmoothing.Target == null)
				{
					AvatarPoseSmoothLerp avatarPoseSmoothLerp = base.Slot.AddSlot("AutoSmoothing").AttachComponent<AvatarPoseSmoothLerp>();
					_autoSmoothing.Target = avatarPoseSmoothLerp;
					Filters.Add(avatarPoseSmoothLerp, int.MinValue);
					avatarPoseSmoothLerp.PositionSmoothSpeed.Value = -1f;
					avatarPoseSmoothLerp.RotationSmoothSpeed.Value = -1f;
					avatarPoseSmoothLerp.SmoothSimulatedPoses.Value = false;
					if (!_smoothingSettingRegistered)
					{
						Settings.RegisterValueChanges<TrackingSmoothingSettings>(OnSmoothingChanged);
						_smoothingSettingRegistered = true;
					}
				}
			}
			else if (_autoSmoothing.Target != null)
			{
				Filters.Remove(_autoSmoothing.Target);
				_autoSmoothing.Target.Slot.Destroy();
				UnregisterSettings();
			}
		}

		public bool PreEquip(IAvatarObject avatarObject, HashSet<IAvatarObject> dequippedObjects)
		{
			if (avatarObject.Node == Node.Value)
			{
				Dequip(dequippedObjects);
				ForeachObjectComponent(avatarObject.Slot, delegate(IAvatarObjectComponent c)
				{
					try
					{
						c.OnPreEquip(this);
					}
					catch (Exception exception)
					{
						base.Debug.Error($"Exception in OnPreEquip on {c}\n" + DebugManager.PreprocessException(exception));
					}
				});
				return true;
			}
			return false;
		}

		public void Equip(IAvatarObject avatarObject)
		{
			base.World.ClearUndoPoints((UpdateTransform u) => u.Target.Target == base.Slot, allUsers: true);
			Equipped.Target = avatarObject;
			Equipped.Target.Equip(this);
			ForeachObjectComponent(Equipped.Target.Slot, delegate(IAvatarObjectComponent c)
			{
				try
				{
					c.OnEquip(this);
				}
				catch (Exception exception)
				{
					base.Debug.Error($"Exception in OnEquip on {c}\n" + DebugManager.PreprocessException(exception));
				}
			});
		}

		public void Dequip(HashSet<IAvatarObject> dequippedObjects)
		{
			if (Equipped.Target == null)
			{
				return;
			}
			dequippedObjects?.Add(Equipped.Target);
			ForeachObjectComponent(Equipped.Target.Slot, delegate(IAvatarObjectComponent c)
			{
				try
				{
					c.OnDequip(this);
				}
				catch (Exception exception)
				{
					base.Debug.Error($"Exception in OnDequip on {c}\n" + DebugManager.PreprocessException(exception));
				}
			});
			Equipped.Target.Dequip();
			Equipped.Target = null;
		}

		public void ForeachObjectComponent(Action<IAvatarObjectComponent> action)
		{
			ForeachObjectComponent(Equipped.Target.Slot, action);
		}

		public AvatarObjectSlot FindSlotForNode(BodyNode node)
		{
			return base.Slot.GetComponentInParents<AvatarManager>()?.Slot.GetComponentInChildren((AvatarObjectSlot s) => s.Node.Value == node);
		}

		public static void ForeachObjectComponent(Slot slot, Action<IAvatarObjectComponent> action)
		{
			List<IAvatarObjectComponent> list = Pool.BorrowList<IAvatarObjectComponent>();
			CollectObjectComponents(slot, list);
			foreach (IAvatarObjectComponent item in list)
			{
				action(item);
			}
			Pool.Return(ref list);
		}

		private void OnSmoothingChanged(TrackingSmoothingSettings settings)
		{
			RunSynchronously(delegate
			{
				AvatarPoseSmoothLerp target = _autoSmoothing.Target;
				if (target != null)
				{
					float? positionSmoothing = settings.GetPositionSmoothing(Node.Value);
					float? rotationSmoothing = settings.GetRotationSmoothing(Node.Value);
					target.PositionSmoothSpeed.Value = positionSmoothing ?? (-1f);
					target.RotationSmoothSpeed.Value = rotationSmoothing ?? (-1f);
				}
			});
		}

		private void UnregisterSettings()
		{
			if (_smoothingSettingRegistered)
			{
				Settings.UnregisterValueChanges<TrackingSmoothingSettings>(OnSmoothingChanged);
			}
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			UnregisterSettings();
		}

		private static void CollectObjectComponents(Slot slot, List<IAvatarObjectComponent> objectComponents)
		{
			slot.GetComponents(objectComponents);
			foreach (Slot child in slot.Children)
			{
				if (child.GetComponent<AvatarObjectSlot>() == null)
				{
					CollectObjectComponents(child, objectComponents);
				}
			}
		}

		public Slot GetFilteredPoseData(out Elements.Core.float3 position, out Elements.Core.floatQ rotation, out bool isTracking)
		{
			Slot unfilteredPoseData = GetUnfilteredPoseData(out position, out rotation, out isTracking);
			foreach (IAvatarPoseFilter filter in Filters)
			{
				filter?.ProcessPose(this, unfilteredPoseData, ref position, ref rotation, ref isTracking);
			}
			return unfilteredPoseData;
		}

		public Slot GetUnfilteredPoseData(out Elements.Core.float3 position, out Elements.Core.floatQ rotation, out bool isTracking)
		{
			Slot slot = base.Slot.ActiveUserRoot?.Slot;
			if (slot == null)
			{
				position = Elements.Core.float3.Zero;
				rotation = Elements.Core.floatQ.Identity;
				isTracking = false;
				return base.Slot;
			}
			position = slot.SpacePointToLocal(base.Slot.LocalPosition, base.Slot.Parent);
			rotation = slot.SpaceRotationToLocal(base.Slot.LocalRotation, base.Slot.Parent);
			isTracking = IsTracking;
			return slot;
		}

