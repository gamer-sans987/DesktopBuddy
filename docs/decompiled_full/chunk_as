		private void SimulateEyeLook()
		{
			if (SimulatingUser.Target == base.LocalUser || (SimulateOnHost.Value && base.World.IsAuthority))
			{
				SimulateEyes();
			}
			if (LookTargetRoot.Target != null)
			{
				Elements.Core.float3 to = LookTargetRoot.Target.LocalPointToGlobal(LookTargetLocalPoint.Value + LookTargetOffset.Value);
				TargetPoint.Value = MathX.Lerp(TargetPoint.Value, in to, (float)SaccadeSpeed * base.Time.Delta);
				LeftEyeTargetPoint.Value = TargetPoint.Value;
				RightEyeTargetPoint.Value = TargetPoint.Value;
			}
		}

		protected override void OnCommonUpdate()
		{
			bool increase = false;
			User target = SimulatingUser.Target;
			if (target != null && target.VR_Active && !target.IsPresentInHeadset)
			{
				increase = true;
			}
			_awayCloseLerp = MathX.Progress01(_awayCloseLerp, base.Time.Delta * 4f, increase);
			IEyeDataSourceComponent target2 = EyeDataSource.Target;
			bool flag = true;
			bool simulatePupilSize = true;
			if (target2 != null && target2.IsEyeTrackingActive)
			{
				flag = false;
				UpdateFromEyeTracking(target2, ref simulatePupilSize);
			}
			if (flag)
			{
				SimulateBlinking();
				SimulateEyeExpressions();
				SimulateEyeLook();
			}
			if (simulatePupilSize)
			{
				SimulatePupilSize();
			}
		}

		private void SimulateEyes()
		{
			Elements.Core.float3 a = GlobalLookPoint;
			Elements.Core.float3 b = GlobalEyeCenter;
			Elements.Core.float3 b2 = GlobalEyeForward;
			Elements.Core.float3 a2 = (a - b).Normalized;
			if (MiniExpressions.Count > 0)
			{
				_miniExpressionRemainingAttempt -= base.Time.Delta;
				if (_miniExpressionRemainingAttempt < 0f)
				{
					if (RandomX.Chance(MiniExpressionProbability))
					{
						float num = 0f;
						for (int i = 0; i < MiniExpressions.Count; i++)
						{
							num += MiniExpressions[i].Weight.Value;
						}
						float num2 = RandomX.Value * num;
						num = 0f;
						MiniExpression miniExpression = MiniExpressions[0];
						for (int j = 0; j < MiniExpressions.Count; j++)
						{
							miniExpression = MiniExpressions[j];
							num += (float)miniExpression.Weight;
							if (num >= num2)
							{
								break;
							}
						}
						float num3 = RandomX.Range(miniExpression.MinDuration, miniExpression.MaxDuration);
						_nextTargetSaccade = base.Time.WorldTime + (double)num3;
						_miniExpressionRemainingAttempt = num3;
						LookTargetRoot.Target = base.Slot;
						LookTargetLocalPoint.Value = miniExpression.Direction.Value.Normalized * base.Slot.GlobalScaleToLocal(0.25f);
						_currentBreakAngle = 360f;
						return;
					}
					_miniExpressionRemainingAttempt += MiniExpressionInterval.Value;
				}
			}
			if (base.Time.WorldTime > _nextTargetSaccade || MathX.Angle(in a2, in b2) > _currentBreakAngle || LookTargetRoot.Target == null)
			{
				AquireNewLookTarget();
			}
			if (base.Time.WorldTime > _nextRandomSaccade && LookTargetRoot.Target != null)
			{
				LookTargetOffset.Value = LookTargetRoot.Target.GlobalVectorToLocal(RandomX.InsideUnitSphere * MaxRandomSaccadeOffset * (base.LocalUserRoot?.GlobalScale ?? 1f));
				_nextRandomSaccade = base.Time.WorldTime + (double)RandomX.Range(MinRandomSaccadeInterval, MaxRandomSaccadeInterval);
			}
		}

		private bool IsGripping(Slot hand)
		{
			return hand.GetComponentInChildren<InteractionHandler>()?.Grabber?.IsHoldingObjects == true;
		}

		private bool RaycastFilter(ICollider c)
		{
			return c.Slot.ActiveUserRoot != base.Slot.ActiveUserRoot;
		}

		public void AquireNewLookTarget()
		{
			List<LookCandidate> list = Pool.BorrowList<LookCandidate>();
			foreach (User allUser in base.World.AllUsers)
			{
				UserRoot root = allUser.Root;
				if (root == null)
				{
					continue;
				}
				if (UserHeadWeight.Value > 0f && root.HeadSlot != null && (allUser != base.LocalUser || !IgnoreLocalUserHead.Value))
				{
					list.Add(new LookCandidate(root.HeadSlot, UserHeadWeight, HeadAcceptAngle, HeadBreakAngle));
				}
				if (UserHandWeight.Value > 0f || GrippingHandWeight.Value > 0f)
				{
					if (root.LeftControllerSlot != null)
					{
						list.Add(new LookCandidate(root.LeftControllerSlot, IsGripping(root.LeftControllerSlot) ? GrippingHandWeight : UserHandWeight, HandAcceptAngle, HandBreakAngle));
					}
					if (root.RightControllerSlot != null)
					{
						list.Add(new LookCandidate(root.RightControllerSlot, IsGripping(root.RightControllerSlot) ? GrippingHandWeight : UserHandWeight, HandAcceptAngle, HandBreakAngle));
					}
				}
			}
			if (CameraWeight.Value > 0f || ForcedCameraWeight.Value > 0f)
			{
				List<InteractiveCamera> list2 = Pool.BorrowList<InteractiveCamera>();
				base.World.GetGloballyRegisteredComponents(list2);
				foreach (InteractiveCamera item in list2)
				{
					float num = CameraWeight;
					float timeMultiplier = 1f;
					if (item.ForceEyeAttentionUsers.Any((UserRef u) => u.Target == base.LocalUser))
					{
						num = ForcedCameraWeight;
						timeMultiplier = 4f;
					}
					if (!(num <= 0f))
					{
						list.Add(new LookCandidate(item.Slot, num, CameraAcceptAngle, CameraBreakAngle, timeMultiplier));
					}
				}
				Pool.Return(ref list2);
			}
			Elements.Core.float3 b = GlobalEyeCenter;
			Elements.Core.float3 b2 = GlobalEyeForward;
			for (int num2 = 0; num2 < list.Count; num2++)
			{
				Elements.Core.float3 a = list[num2].slot.GlobalPosition;
				float x = MathX.Distance(in a, in b);
				float num3 = MathX.Angle((a - b).Normalized, in b2);
				if (num3 >= list[num2].acceptAngle)
				{
					list[num2] = list[num2].SetWeight(0f);
					continue;
				}
				float num4 = num3 * MathX.Pow(x, DistanceCompensationExp);
				list[num2].SetWeight(list[num2].weight / num4);
			}
			for (int num5 = list.Count - 1; num5 >= 0; num5--)
			{
				if (list[num5].weight == 0f)
				{
					list.RemoveAt(num5);
				}
			}
			LookCandidate lookCandidate = default(LookCandidate);
			Slot slot = null;
			Elements.Core.float3 value = Elements.Core.float3.Zero;
			if (list.Count > 0)
			{
				float num6 = 0f;
				foreach (LookCandidate item2 in list)
				{
					num6 += item2.weight;
				}
				float num7 = RandomX.Value * num6;
				num6 = 0f;
				foreach (LookCandidate item3 in list)
				{
					lookCandidate = item3;
					slot = item3.slot;
					_currentBreakAngle = item3.breakAngle;
					num6 += item3.weight;
					if (num6 > num7)
					{
						break;
					}
				}
			}
			float num8 = base.Slot.ActiveUserRoot?.GlobalScale ?? base.Slot.GlobalScale.x;
			if (slot == null)
			{
				RaycastHit? raycastHit = base.Physics.RaycastOne(b + b2 * num8 * 0.2f, in b2, _raycastFilter);
				if (raycastHit.HasValue)
				{
					slot = raycastHit.Value.Collider.Slot;
					Slot slot2 = slot;
					RaycastHit value2 = raycastHit.Value;
					value = slot2.GlobalPointToLocal(in value2.Point);
					_currentBreakAngle = DefaultBreakAngle;
				}
			}
			if (slot == null)
			{
				slot = base.World.RootSlot;
				value = b + b2 * num8 * 5f;
				_currentBreakAngle = DefaultBreakAngle;
			}
			LookTargetRoot.Target = slot;
			LookTargetLocalPoint.Value = value;
			Pool.Return(ref list);
			float num9 = lookCandidate.timeMultiplier;
			if (num9 == 0f)
			{
				num9 = 1f;
			}
			_nextTargetSaccade = base.Time.WorldTime + (double)(RandomX.Range(MinTargetSaccadeInterval, MaxTargetSaccadeInterval) * num9);
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			int typeVersion = control.GetTypeVersion(GetType());
			if (typeVersion == 0)
			{
				RunSynchronously(SetupMiniExpressions);
			}
			if (typeVersion >= 2)
			{
				return;
			}
			RunSynchronously(delegate
			{
				if (base.Slot.GetComponent((AvatarUserReferenceAssigner a) => a.References.Any((SyncRef<User> r) => r == SimulatingUser)) != null)
				{
					base.Slot.AttachComponent<AvatarEyeDataSourceAssigner>().TargetReference.Target = EyeDataSource;
				}
			});
		}

