		public void BuildInspectorUI(UIBuilder ui)
		{
			WorkerInspector.BuildInspectorUI(this, ui);
			ui.HorizontalLayout(4f);
			ui.Button("Inspector.ParticleStyle.AlphaFadeInOut".AsLocaleKey(), SetupAlphaFadeInFadeOut);
			ui.Button("Inspector.ParticleStyle.AlphaFadeIn".AsLocaleKey(), SetupAlphaFadeIn);
			ui.Button("Inspector.ParticleStyle.AlphaFadeOut".AsLocaleKey(), SetupAlphaFadeOut);
			ui.NestOut();
			ui.Button("Inspector.ParticleStyle.ClearFades".AsLocaleKey(), ClearFadeEffects);
		}

		public override void UpdateParameters(ParticleModuleBindingManager<AlphaOverLifetimeGradient> manager)
		{
			CurveFloatAnimationTrack curveFloatAnimationTrack = new CurveFloatAnimationTrack();
			foreach (LinearKey<float> item in AlphaOverLifetime)
			{
				curveFloatAnimationTrack.InsertKeyFrame(item.value, item.time, KeyframeInterpolation.Linear, 0f, 0f);
			}
			manager.NativeModule.Gradient = curveFloatAnimationTrack;
		}

		[SyncMethod(typeof(Delegate), null)]
		private void SetupAlphaFadeInFadeOut(IButton button, ButtonEventData eventData)
		{
			SetupAlphaFadeInFadeOut(0.1f, 0.1f);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void SetupAlphaFadeOut(IButton button, ButtonEventData eventData)
		{
			SetupAlphaFadeInFadeOut(0f, 0.1f);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void SetupAlphaFadeIn(IButton button, ButtonEventData eventData)
		{
			SetupAlphaFadeInFadeOut(0.1f, 0f);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void ClearFadeEffects(IButton button, ButtonEventData eventData)
		{
			AlphaOverLifetime.Clear();
		}

		public void SetupAlphaFadeInFadeOut(float fadeIn, float fadeOut, float alpha = 1f)
		{
			fadeIn = MathX.Clamp01(fadeIn);
			fadeOut = MathX.Clamp01(fadeOut);
			float num = 1f - fadeOut;
			if (fadeIn + fadeOut > 1f)
			{
				throw new Exception("FadeIn and FadeOut cross each other");
			}
			AlphaOverLifetime.Clear();
			if (fadeIn > 0f)
			{
				AlphaOverLifetime.InsertKey(0f, 0f);
			}
			AlphaOverLifetime.InsertKey(fadeIn, alpha);
			if (num < 1f)
			{
				AlphaOverLifetime.InsertKey(num, alpha);
				AlphaOverLifetime.InsertKey(1f, 0f);
			}
		}

