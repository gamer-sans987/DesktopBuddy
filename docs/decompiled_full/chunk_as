	[Category(new string[] { "Rendering/Particle System/Renderers" })]
	public abstract class ParticleRenderer<D> : Component, IParticleRenderer, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable where D : ParticleRenderer<D>.RenderData, new()
	{
		public class RenderData
		{
			public Slot root;

			public Action<IParticleRenderer> onSubmitted;

			public IParticleRenderer Owner { get; private set; }

			public ParticleSystemBindingManager Manager { get; private set; }

			public void AssignOwner(IParticleRenderer owner, ParticleSystemBindingManager manager)
			{
				if (Owner != null)
				{
					throw new InvalidOperationException("Owner has already been assigned");
				}
				Owner = owner;
				Manager = manager;
			}

			public void OnSubmitted()
			{
				onSubmitted(Owner);
			}
		}

		private Dictionary<ParticleSystemBindingManager, D> _renderData;

		public Slot SetupVisuals(ParticleSystemBindingManager manager)
		{
			if (base.IsDestroyed)
			{
				throw new InvalidOperationException("Cannot Setup Visuals on a destroyed particle renderer");
			}
			D val = new D();
			val.AssignOwner(this, manager);
			if (_renderData == null)
			{
				_renderData = new Dictionary<ParticleSystemBindingManager, D>();
			}
			_renderData.Add(manager, val);
			val.root = GetTargetSpace(val.Manager).AddLocalSlot("Renderer");
			SetupVisuals(val);
			return val.root;
		}

		public void Unregister(ParticleSystemBindingManager manager)
		{
			if (!base.IsDestroyed)
			{
				_renderData[manager].root.Destroy();
				_renderData.Remove(manager);
			}
		}

		public void UpdateVisuals(ParticleSystemBindingManager manager, Action<IParticleRenderer> onSubmitted)
		{
			D val = _renderData[manager];
			val.onSubmitted = onSubmitted;
			UpdateVisuals(val);
		}

		protected virtual Slot GetTargetSpace(ParticleSystemBindingManager manager)
		{
			return manager.BindingSystem.TargetSpace;
		}

		protected abstract void SetupVisuals(D data);

		protected abstract void UpdateVisuals(D data);

		protected abstract void UpdateRenderer(D data);

		protected virtual void RendererSpaceChanged(D data, Slot oldSpace, Slot newSpace)
		{
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (_renderData == null)
			{
				return;
			}
			foreach (KeyValuePair<ParticleSystemBindingManager, D> renderDatum in _renderData)
			{
				Slot targetSpace = GetTargetSpace(renderDatum.Value.Manager);
				Slot parent = renderDatum.Value.root.Parent;
				if (targetSpace != parent)
				{
					renderDatum.Value.root.SetParent(targetSpace, keepGlobalTransform: false);
					RendererSpaceChanged(renderDatum.Value, parent, targetSpace);
				}
				UpdateRenderer(renderDatum.Value);
			}
		}

		protected override void OnDestroy()
		{
			base.OnDestroy();
			if (_renderData == null)
			{
				return;
			}
			foreach (KeyValuePair<ParticleSystemBindingManager, D> renderDatum in _renderData)
			{
				renderDatum.Value.root.Destroy();
			}
			_renderData = null;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
		}
	}
