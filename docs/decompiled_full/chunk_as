					data.mesh.Points.Remove(manager.Count, num);
					data.mesh.Sizes.Remove(manager.Count, num);
					data.mesh.Rotations.Remove(manager.Count, num);
					data.mesh.Colors.Remove(manager.Count, num);
					data.mesh.UVs.Remove(manager.Count, num);
				}
