		private float ProcessGaitAngle(float angle)
		{
			angle = MathX.Repeat(angle, MathF.PI * 2f);
			float num = _cycleGroundRatio * (MathF.PI * 2f);
			if (angle < num)
			{
				return MathX.InverseLerp(0f, num, angle) * MathF.PI;
			}
			return MathX.InverseLerp(num, MathF.PI * 2f, angle) * MathF.PI + MathF.PI;
		}

