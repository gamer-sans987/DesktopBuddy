	/// <summary>
	/// The Cartesian axes.
	/// </summary>
	[Serializable]
	public enum Axis
	{
		X,
		Y,
		Z
	}
	/// <summary>
	/// Contains tools for working with Axes that have no positive/negative directions.
	/// </summary>
	public class AxisTools
	{
		/// <summary>
		/// Converts an Axis to float3.
		/// </summary>
		public static Elements.Core.float3 Tofloat3(Axis axis)
		{
			return axis switch
			{
				Axis.X => Elements.Core.float3.Right, 
				Axis.Y => Elements.Core.float3.Up, 
				_ => Elements.Core.float3.Forward, 
			};
		}

		/// <summary>
		/// Converts a float3 to Axis.
		/// </summary>
		public static Axis ToAxis(in Elements.Core.float3 v)
		{
			float num = MathX.Abs(v.x);
			float num2 = MathX.Abs(v.y);
			float num3 = MathX.Abs(v.z);
			Axis result = Axis.X;
			if (num2 > num && num2 > num3)
			{
				result = Axis.Y;
			}
			if (num3 > num && num3 > num2)
			{
				result = Axis.Z;
			}
			return result;
		}

		/// <summary>
		/// Returns the Axis of the Transform towards a world space position.
		/// </summary>
		public static Axis GetAxisToPoint(Slot s, in Elements.Core.float3 worldPosition)
		{
			Elements.Core.float3 a = GetAxisVectorToPoint(s, in worldPosition);
			if (a == Elements.Core.float3.Right)
			{
				return Axis.X;
			}
			if (a == Elements.Core.float3.Up)
			{
				return Axis.Y;
			}
			return Axis.Z;
		}

		/// <summary>
		/// Returns the Axis of the Transform towards a world space direction.
		/// </summary>
		public static Axis GetAxisToDirection(Slot s, in Elements.Core.float3 direction)
		{
			Elements.Core.float3 a = GetAxisVectorToDirection(s, direction);
			if (a == Elements.Core.float3.Right)
			{
				return Axis.X;
			}
			if (a == Elements.Core.float3.Up)
			{
				return Axis.Y;
			}
			return Axis.Z;
		}

		/// <summary>
		/// Returns the local axis of the Transform towards a world space position.
		/// </summary>
		public static Elements.Core.float3 GetAxisVectorToPoint(Slot s, in Elements.Core.float3 worldPosition)
		{
			return GetAxisVectorToDirection(s, worldPosition - s.GlobalPosition);
		}

		/// <summary>
		/// Returns the local axis of the Transform that aligns the most with a direction.
		/// </summary>
		public static Elements.Core.float3 GetAxisVectorToDirection(Slot s, Elements.Core.float3 direction)
		{
			direction = direction.Normalized;
			Elements.Core.float3 result = Elements.Core.float3.Right;
			float num = MathX.Abs(MathX.Dot(s.Right, in direction));
			float num2 = MathX.Abs(MathX.Dot(s.Up, in direction));
			if (num2 > num)
			{
				result = Elements.Core.float3.Up;
			}
			float num3 = MathX.Abs(MathX.Dot(s.Forward, in direction));
			if (num3 > num && num3 > num2)
			{
				result = Elements.Core.float3.Forward;
			}
			return result;
		}
	}
