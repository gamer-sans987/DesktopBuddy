				rootBone.solverPosition = solverPosition;
				rootVelocity += (to - rootBone.solverPosition) * base.Time.Delta * 10f;
				Elements.Core.float3 b3 = V3Tools.ExtractVertical(in rootVelocity, in v, 1f);
				rootVelocity -= b3;
				float num = leftFootOffset + rightFootOffset;
				bodyOffset = MathX.Lerp(in bodyOffset, v * num, base.Time.Delta * 3f);
				bodyOffset = MathX.LerpUnclamped(Elements.Core.float3.Zero, in bodyOffset, locomotion.Weight);
			}
			leftLeg.ApplyOffsets();
			rightLeg.ApplyOffsets();
			if (!PlantFeet.Value)
			{
				spine.InverseTranslateToHead(leftLeg, rightLeg, limited: false, useCurrentLegMag: false, in bodyOffset, 1f);
				leftLeg.TranslateRoot(in spine.pelvis.solverPosition, in spine.pelvis.solverRotation);
				rightLeg.TranslateRoot(in spine.pelvis.solverPosition, in spine.pelvis.solverRotation);
				leftLeg.Solve();
				rightLeg.Solve();
			}
			else
			{
				for (int i = 0; i < 2; i++)
				{
					spine.InverseTranslateToHead(leftLeg, rightLeg, limited: true, i == 0, in bodyOffset, 1f);
					leftLeg.TranslateRoot(in spine.pelvis.solverPosition, in spine.pelvis.solverRotation);
					rightLeg.TranslateRoot(in spine.pelvis.solverPosition, in spine.pelvis.solverRotation);
					leftLeg.Solve();
					rightLeg.Solve();
				}
			}
			leftArm.TranslateRoot(in spine.chest.solverPosition, in spine.chest.solverRotation);
			rightArm.TranslateRoot(in spine.chest.solverPosition, in spine.chest.solverRotation);
			leftArm.Solve(isLeft: true);
			rightArm.Solve(isLeft: false);
			spine.ResetOffsets();
			leftLeg.ResetOffsets();
			rightLeg.ResetOffsets();
			leftArm.ResetOffsets();
			rightArm.ResetOffsets();
			Spine obj = spine;
			obj.pelvisPositionOffset += GetPelvisOffset();
			Spine obj2 = spine;
			obj2.chestPositionOffset += spine.pelvisPositionOffset;
			Write();
			supportLeg = null;
			float num2 = ComputeSupportLegMagnitude(leftLeg);
			float num3 = ComputeSupportLegMagnitude(rightLeg);
			if (num2 < num3)
