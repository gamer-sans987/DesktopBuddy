	{
		public readonly SyncRef<IPointSnappable> AnchorPointSnap;

		public readonly Sync<int> MaxUsers;

		public readonly Sync<float> MinDistance;

		public readonly SyncRef<IAvatarAnchor> Template;

		public readonly SyncRef<Slot> AnchorsRoot;

		public readonly Sync<bool> AcceptOutOfSightTouch;

		public readonly Sync<bool> AcceptPhysicalTouch;

		public readonly Sync<bool> AcceptRemoteTouch;

		private IAvatarAnchor _localPreviewAnchor;

		private int _previewAnchorUpdateIndex;

		private Component _lastTouch;

		public bool AcceptsExistingTouch => false;

		public bool CanTouchOutOfSight => AcceptOutOfSightTouch;

		protected override void OnAwake()
		{
			base.OnAwake();
			MaxUsers.Value = -1;
			MinDistance.Value = 0.25f;
			AcceptPhysicalTouch.Value = false;
			AcceptRemoteTouch.Value = true;
		}

		public bool CanTouchInteract(TouchSource source)
		{
			if (base.LocalUserRoot.Slot.IsChildOf(AnchorsRoot.Target))
			{
				return false;
			}
			return true;
		}

		public void OnTouch(in TouchEventInfo eventInfo)
		{
			switch (eventInfo.type)
			{
			case TouchType.Physical:
				if (!AcceptPhysicalTouch)
				{
					return;
				}
				break;
			case TouchType.Remote:
				if (!AcceptRemoteTouch)
				{
					return;
				}
				break;
			default:
				base.Debug.Warning("Unknown touch type: " + eventInfo.type);
				return;
			}
			if (_lastTouch != null && eventInfo.source != _lastTouch)
			{
				return;
			}
			_lastTouch = eventInfo.source;
			if (eventInfo.hover == EventState.End)
			{
				_lastTouch = null;
			}
			else
			{
				if (Template.Target == null || AnchorsRoot.Target == null || AnchorPointSnap.Target == null)
				{
					return;
				}
				AnchorPointSnap.Target.Snap(eventInfo.point, out var snappedPoint, out var snappedOrientation);
				if (!snappedPoint.HasValue)
				{
					return;
				}
				List<IAvatarAnchor> list = Pool.BorrowList<IAvatarAnchor>();
				GetActiveAnchors(list);
				if (MaxUsers.Value >= 0 && list.Count >= MaxUsers.Value)
				{
					Pool.Return(ref list);
					return;
				}
				float num = float.MaxValue;
				foreach (IAvatarAnchor item in list)
				{
					num = MathX.Min(num, MathX.Distance(item.Slot.GlobalPosition, snappedPoint.Value));
				}
				if (num < MinDistance.Value)
				{
					Pool.Return(ref list);
					return;
				}
				_previewAnchorUpdateIndex = base.Time.LocalUpdateIndex;
				if (_localPreviewAnchor == null)
				{
					Slot slot = Template.Target.Slot.Duplicate(AnchorsRoot.Target);
					slot.ActiveSelf = true;
					slot.PersistentSelf = false;
					slot.AttachComponent<DestroyOnUserLeave>().TargetUser.Target = base.LocalUser;
					_localPreviewAnchor = slot.GetComponent<IAvatarAnchor>();
					slot.GetComponentOrAttach<AvatarAnchorDestroyOnRelease>();
					_localPreviewAnchor.Highlight = true;
					StartTask(DeletePreviewAnchor);
				}
				_localPreviewAnchor.Slot.GlobalPosition = snappedPoint.Value;
				_localPreviewAnchor.Slot.GlobalRotation = snappedOrientation ?? AnchorsRoot.Target.GlobalRotation;
				if (eventInfo.touch == EventState.Begin)
				{
					_localPreviewAnchor.Highlight = false;
					_localPreviewAnchor.Anchor(base.LocalUser);
					_localPreviewAnchor = null;
				}
			}
		}

		private async Task DeletePreviewAnchor()
		{
			while (_localPreviewAnchor != null)
			{
				if (base.Time.LocalUpdateIndex - _previewAnchorUpdateIndex >= 2)
				{
					_localPreviewAnchor.Slot.Destroy();
					_localPreviewAnchor = null;
					break;
				}
				await default(NextUpdate);
			}
		}

		public void GetActiveAnchors(List<IAvatarAnchor> anchors)
		{
			if (AnchorsRoot.Target == null)
			{
				return;
			}
			for (int i = 0; i < AnchorsRoot.Target.ChildrenCount; i++)
			{
				IAvatarAnchor component = AnchorsRoot.Target[i].GetComponent<IAvatarAnchor>();
				if (component != null && component.IsOccupied)
				{
					anchors.Add(component);
				}
			}
		}

		void ITouchable.OnTouch(in TouchEventInfo eventInfo)
		{
			OnTouch(in eventInfo);
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			AnchorPointSnap = new SyncRef<IPointSnappable>();
			MaxUsers = new Sync<int>();
			MinDistance = new Sync<float>();
			Template = new SyncRef<IAvatarAnchor>();
			AnchorsRoot = new SyncRef<Slot>();
			AcceptOutOfSightTouch = new Sync<bool>();
			AcceptPhysicalTouch = new Sync<bool>();
			AcceptRemoteTouch = new Sync<bool>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => AnchorPointSnap, 
				4 => MaxUsers, 
				5 => MinDistance, 
				6 => Template, 
				7 => AnchorsRoot, 
				8 => AcceptOutOfSightTouch, 
				9 => AcceptPhysicalTouch, 
				10 => AcceptRemoteTouch, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

