		private void EnsureValidBoneReferences()
		{
			if (validTargetSlots)
			{
				return;
			}
			for (int i = 0; i < _boneReferences.Length; i++)
			{
				Slot slot = BoneReferences[i];
				if (slot != _boneReferences[i])
				{
					UnregisterDisposingEvent(_boneReferences[i]);
					_boneReferences[i] = slot;
					slot.Disposing += BoneDisposing;
				}
			}
			validTargetSlots = true;
		}

		private void UnregisterDisposingEvent(Slot slot)
		{
			if (slot != null && !slot.IsDisposed)
			{
				slot.Disposing -= BoneDisposing;
			}
		}

		private void BoneDisposing(Worker worker)
		{
