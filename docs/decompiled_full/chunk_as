		private bool SetupHands(BipedRig rig)
		{
			if (rig.HasLeftHandFingers)
			{
				SetupHand(rig, rig[BodyNode.LeftHand], Chirality.Left);
			}
			if (rig.HasRightHandFingers)
			{
				SetupHand(rig, rig[BodyNode.RightHand], Chirality.Right);
			}
			if (!rig.HasLeftHandFingers)
			{
				return rig.HasRightHandFingers;
			}
			return true;
		}

		private void SetupHand(BipedRig rig, Slot hand, Chirality chirality)
		{
			HandPoser handPoser = hand.AttachComponent<HandPoser>();
			handPoser.Side.Value = chirality;
			handPoser.AssignFingers(rig);
			AvatarHandDataAssigner avatarHandDataAssigner = hand.AttachComponent<AvatarHandDataAssigner>();
			avatarHandDataAssigner.TargetReference.Target = handPoser.PoseSource;
			avatarHandDataAssigner.SetupFingerTouch();
		}

