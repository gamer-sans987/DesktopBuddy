	public class ParticleSystemManager : IJobScheduler, IDisposable
	{
		private struct ParticleJob
		{
			public Action<int> job;

			public int jobIndex;

			public ParticleJob(Action<int> job, int jobIndex)
			{
				this.job = job;
				this.jobIndex = jobIndex;
			}
		}

		private HashSet<ParticleSystem> particleSystems = new HashSet<ParticleSystem>();

		private ActionBlock<ParticleJob> _processor;

		public Engine Engine => World.Engine;

		public World World { get; private set; }

		public ParticleSystemManager(World world)
		{
			World = world;
			_processor = new ActionBlock<ParticleJob>(delegate(ParticleJob job)
			{
				try
				{
					job.job(job.jobIndex);
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception in particle job: " + ex);
					throw;
				}
			}, new ExecutionDataflowBlockOptions
			{
				EnsureOrdered = false,
				MaxDegreeOfParallelism = -1
			});
		}

		internal void RegisterSystem(ParticleSystem system)
		{
			if (!particleSystems.Add(system))
			{
				throw new InvalidOperationException("ParticleSystem already registered");
			}
		}

		internal void UnregisterSystem(ParticleSystem system)
		{
			if (!particleSystems.Remove(system))
			{
				throw new InvalidOperationException("ParticleSystem is not registered");
			}
		}

		public void Update()
		{
			foreach (ParticleSystem particleSystem in particleSystems)
			{
				if (!particleSystem.IsComputingUpdate && !particleSystem.IsRemoved)
				{
					particleSystem.ScheduleUpdate();
				}
			}
		}

		public void Schedule(Action<int> job, int jobCount)
		{
			for (int i = 0; i < jobCount; i++)
			{
				_processor.Post(new ParticleJob(job, i));
			}
		}

		public void Dispose()
		{
			_processor.Complete();
		}
	}
