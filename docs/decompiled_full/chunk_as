				Slot filteredPoseData = EquippingSlot.GetFilteredPoseData(out position, out rotation, out isTracking);
				IsTracking.Value = isTracking;
				SourceIsTracking.Value = EquippingSlot.IsTracking.Value;
				SourceIsActive.Value = EquippingSlot.IsActive.Value;
				SourceIsSimulated.Value = EquippingSlot.IsSimulated.Value;
				if (base.IsUnderLocalUser && _position.Target != null != IsPresent)
				{
					if (IsPresent)
					{
						AquireDrives();
					}
					else
					{
						ReleaseDrives();
					}
				}
				if (_position.IsLinkValid)
				{
					base.Slot.LocalPosition = filteredPoseData.LocalPointToSpace(in position, base.Slot.Parent);
				}
				if (_rotation.IsLinkValid)
				{
					base.Slot.LocalRotation = filteredPoseData.LocalRotationToSpace(in rotation, base.Slot.Parent);
				}
				if (_scale.IsLinkValid)
				{
					base.Slot.LocalScale = base.Slot.Parent.SpaceScaleToLocal(EquippingSlot.Slot.LocalScale, EquippingSlot.Slot.Parent);
				}
				if (_active.IsLinkValid)
				{
					base.Slot.ActiveSelf = EquippingSlot.Slot.ActiveSelf;
				}
			}
			else
			{
				IsTracking.Value = false;
				SourceIsTracking.Value = false;
				if (base.IsUnderLocalUser)
				{
					ReleaseDrives();
				}
			}
