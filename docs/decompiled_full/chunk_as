		public static async Task FillEmptySlot(BodyNode node, AvatarManager manager, bool userspace, Action<Slot> allowAvatarObject, CancellationToken cancellationToken)
		{
			World world = manager.World;
			User user = manager.Slot.ActiveUserRoot.ActiveUser;
			switch (node)
			{
			case BodyNode.View:
			{
				if (userspace)
				{
					break;
				}
				Slot view = world.RootSlot.FindChildOrAdd("__TEMP", persistent: false).AddSlot("View", persistent: false);
				view.DestroyWhenUserLeaves(user);
				if (!(await view.LoadObjectAsync(ViewVisualURL(manager.Cloud.Platform))))
				{
					break;
				}
				if (cancellationToken.IsCancellationRequested || manager.IsRemoved)
				{
					view.Destroy();
					break;
				}
				foreach (Grabbable componentsInChild in view.GetComponentsInChildren<Grabbable>())
				{
					componentsInChild.Destroy();
				}
				view.GetComponentInChildren<AvatarPoseNode>().Slot.AttachComponent<AvatarDestroyOnDequip>();
				allowAvatarObject?.Invoke(view);
				manager.Equip(view, isManualEquip: false, forceDestroyOld: false, isFillingEmptySlot: true);
				break;
			}
			case BodyNode.Head:
			{
				if (userspace)
				{
					break;
				}
				Slot camera;
				if (user.HeadDevice == HeadOutputDevice.StaticCamera && user.Devices.Any((SyncVar i) => i.AsField<string>(setIfDifferent: false)?.Value == Engine.Current.Cloud.Platform.Name + " Camera"))
				{
					camera = world.RootSlot.FindChildOrAdd("__TEMP", persistent: false).AddSlot("Interactive Camera", persistent: false);
