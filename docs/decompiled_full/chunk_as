	{
		private struct PoseData
		{
			public Elements.Core.float3 pos;

			public Elements.Core.floatQ rot;

			public Elements.Core.float3 intermediatePos;

			public Elements.Core.floatQ intermediateRot;

			public int lastUpdate;
		}

		private Dictionary<AvatarObjectSlot, PoseData> _data = new Dictionary<AvatarObjectSlot, PoseData>();

		public readonly Sync<float> PositionSmoothSpeed;

		public readonly Sync<float> RotationSmoothSpeed;

		public readonly Sync<bool> SmoothSimulatedPoses;

		protected override void OnAwake()
		{
			base.OnAwake();
			PositionSmoothSpeed.Value = 10f;
			RotationSmoothSpeed.Value = 8f;
			SmoothSimulatedPoses.Value = true;
		}

		private bool IsOld(ref PoseData data)
		{
			return base.Time.LocalUpdateIndex - data.lastUpdate > 1;
		}

		public void ProcessPose(AvatarObjectSlot avatarSlot, Slot space, ref Elements.Core.float3 position, ref Elements.Core.floatQ rotation, ref bool isTracking)
		{
			if (!avatarSlot.IsSimulated.Value || SmoothSimulatedPoses.Value)
			{
				if (!_data.TryGetValue(avatarSlot, out var value))
				{
					value = new PoseData
					{
						lastUpdate = -2
					};
					_data.Add(avatarSlot, value);
				}
				if (IsOld(ref value))
				{
					value.pos = (value.intermediatePos = position);
					value.rot = (value.intermediateRot = rotation);
				}
				value.lastUpdate = base.Time.LocalUpdateIndex;
				if (PositionSmoothSpeed.Value > 0f)
				{
					value.pos = MathX.SmoothLerp(value.pos, position, ref value.intermediatePos, base.Time.Delta * (float)PositionSmoothSpeed);
					position = value.pos;
				}
				if (RotationSmoothSpeed.Value > 0f)
				{
					value.rot = MathX.SmoothSlerp(in value.rot, in rotation, ref value.intermediateRot, base.Time.Delta * (float)RotationSmoothSpeed);
					rotation = value.rot;
				}
				_data[avatarSlot] = value;
			}
		}

