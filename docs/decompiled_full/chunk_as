		}

		/// <summary>
		/// Optimized float3.Slerp
		/// </summary>
		public static Elements.Core.float3 Slerp(in Elements.Core.float3 fromVector, in Elements.Core.float3 toVector, float weight)
		{
			if (weight <= 0f)
			{
				return fromVector;
			}
			if (weight >= 1f)
			{
				return toVector;
			}
			return MathX.Slerp(fromVector, in toVector, weight);
		}

		/// <summary>
		/// Returns vector projection on axis multiplied by weight.
		/// </summary>
		public static Elements.Core.float3 ExtractVertical(in Elements.Core.float3 v, in Elements.Core.float3 verticalAxis, float weight)
		{
			if (weight == 0f)
			{
				return Elements.Core.float3.Zero;
			}
			return MathX.Project(in v, in verticalAxis) * weight;
		}

		/// <summary>
		/// Returns vector projected to a plane and multiplied by weight.
		/// </summary>
		public static Elements.Core.float3 ExtractHorizontal(in Elements.Core.float3 v, Elements.Core.float3 normal, float weight)
		{
			if (weight == 0f)
			{
				return Elements.Core.float3.Zero;
			}
			Elements.Core.float3 tangent = v;
			MathX.Orthonormalize(ref normal, ref tangent);
			return MathX.Project(in v, in tangent) * weight;
		}

		/// <summary>
		/// Clamps the direction to clampWeight from normalDirection, clampSmoothing is the number of sine smoothing iterations applied on the result.
		/// </summary>
		public static Elements.Core.float3 ClampDirection(in Elements.Core.float3 direction, in Elements.Core.float3 normalDirection, float clampWeight, int clampSmoothing, out bool changed)
		{
			changed = false;
			if (clampWeight <= 0f)
			{
				return direction;
			}
			if (clampWeight >= 1f)
			{
				changed = true;
				return normalDirection;
			}
			float num = MathX.Angle(in normalDirection, in direction);
			float num2 = 1f - num / 180f;
			if (num2 > clampWeight)
			{
				return direction;
			}
			changed = true;
			float num3 = ((clampWeight > 0f) ? MathX.Clamp(1f - (clampWeight - num2) / (1f - num2), 0f, 1f) : 1f);
			float num4 = ((clampWeight > 0f) ? MathX.Clamp(num2 / clampWeight, 0f, 1f) : 1f);
			for (int i = 0; i < clampSmoothing; i++)
			{
				num4 = MathX.Sin(num4 * MathF.PI * 0.5f);
			}
			return MathX.Slerp(normalDirection, in direction, num4 * num3);
		}

		/// <summary>
		/// Clamps the direction to clampWeight from normalDirection, clampSmoothing is the number of sine smoothing iterations applied on the result.
		/// </summary>
		public static Elements.Core.float3 ClampDirection(in Elements.Core.float3 direction, in Elements.Core.float3 normalDirection, float clampWeight, int clampSmoothing, out float clampValue)
		{
			clampValue = 1f;
			if (clampWeight <= 0f)
			{
				return direction;
			}
			if (clampWeight >= 1f)
			{
				return normalDirection;
			}
			float num = MathX.Angle(in normalDirection, in direction);
			float num2 = 1f - num / 180f;
			if (num2 > clampWeight)
			{
				clampValue = 0f;
				return direction;
			}
			float num3 = ((clampWeight > 0f) ? MathX.Clamp(1f - (clampWeight - num2) / (1f - num2), 0f, 1f) : 1f);
			float num4 = ((clampWeight > 0f) ? MathX.Clamp(num2 / clampWeight, 0f, 1f) : 1f);
			for (int i = 0; i < clampSmoothing; i++)
			{
				num4 = MathX.Sin(num4 * MathF.PI * 0.5f);
			}
			float num5 = num4 * num3;
			clampValue = 1f - num5;
			return MathX.Slerp(normalDirection, in direction, num5);
		}

		/// <summary>
		/// Get the intersection point of line and plane
		/// </summary>
		public static Elements.Core.float3 LineToPlane(in Elements.Core.float3 origin, in Elements.Core.float3 direction, in Elements.Core.float3 planeNormal, in Elements.Core.float3 planePoint)
		{
			float num = MathX.Dot(planePoint - origin, in planeNormal);
			float num2 = MathX.Dot(in direction, in planeNormal);
			if (num2 == 0f)
			{
				return Elements.Core.float3.Zero;
			}
			float num3 = num / num2;
			return origin + direction.Normalized * num3;
		}

		/// <summary>
		/// Projects a point to a plane.
		/// </summary>
		public static Elements.Core.float3 PointToPlane(in Elements.Core.float3 point, in Elements.Core.float3 planePosition, in Elements.Core.float3 planeNormal)
		{
			if (planeNormal == Elements.Core.float3.Up)
			{
				return new Elements.Core.float3(point.x, planePosition.y, point.z);
			}
			Elements.Core.float3 tangent = point - planePosition;
			Elements.Core.float3 normal = planeNormal;
			MathX.Orthonormalize(ref normal, ref tangent);
			return planePosition + MathX.Project(point - planePosition, in tangent);
		}
	}
