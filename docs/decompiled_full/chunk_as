				return;
			}
			await default(ToBackground);
			string text = await base.Engine.AssetManager.GatherAssetFile(_savedObject.Value, 100f);
			if (string.IsNullOrEmpty(text))
			{
				return;
			}
			DataTreeDictionary dataTreeDictionary = DataTreeConverter.Load(text);
			LoadControl loadControl = new LoadControl(base.World, new ReferenceTranslator(), FrooxEngine.Engine.Version, null);
			loadControl.SetCustomLoadData(this);
			loadControl.LoadFeatureFlags((DataTreeDictionary)dataTreeDictionary["FeatureFlags"]);
			loadControl.LoadTypeData(dataTreeDictionary.TryGetList("Types"), (DataTreeDictionary)dataTreeDictionary["TypeVersions"]);
			loadControl.InitializeLoaders();
			DataTreeNode root = dataTreeDictionary["Root"];
			DataTreeList assets = dataTreeDictionary.TryGetList("Assets");
			await default(ToWorld);
			_referenceTable.Target.Fill(loadControl);
			if (_isComponent.Value)
