	public class AvatarUserRootOverrideAssigner : Component, IAvatarObjectComponent, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public enum OverrideNode
		{
			Root,
			View,
			Ears
		}

		public readonly SyncRef<Slot> Override;

		public readonly Sync<OverrideNode> Node;

		protected readonly SyncRef<AvatarObjectSlot> _equippingSlot;

		private Slot _lastOverride;

		private UserRoot _lastUserRoot;

		private OverrideNode _lastNode = (OverrideNode)(-1);

		private AudioListener _lastOverrideListener;

		private User TargetUser => _equippingSlot.Target?.Slot?.ActiveUser;

		public void OnDequip(AvatarObjectSlot slot)
		{
			_equippingSlot.Target = null;
			Clear();
		}

		public void OnEquip(AvatarObjectSlot slot)
		{
			_equippingSlot.Target = slot;
		}

		public void OnPreEquip(AvatarObjectSlot slot)
		{
		}

		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			if (TargetUser == base.LocalUser && base.LocalUserRoot != null)
			{
				_lastUserRoot = base.LocalUserRoot;
				Slot target = Override.Target;
				OverrideNode value = Node.Value;
				if (target != _lastOverride || value != _lastNode)
				{
					switch (_lastNode)
					{
					case OverrideNode.Root:
						_lastUserRoot.OverrideRoot.Target = null;
						break;
					case OverrideNode.Ears:
						ClearEars();
						break;
					case OverrideNode.View:
						_lastUserRoot.OverrideView.Target = null;
						break;
					}
					switch (value)
					{
					case OverrideNode.Root:
						_lastUserRoot.OverrideRoot.Target = target;
						break;
					case OverrideNode.Ears:
					{
						Slot slot = _lastUserRoot.PrimaryListener.Target.Slot.Duplicate(target, keepGlobalTransform: false);
						_lastOverrideListener = slot.GetComponent<AudioListener>();
						_lastUserRoot.PrimaryListener.Target.Enabled = false;
						break;
					}
					case OverrideNode.View:
						_lastUserRoot.OverrideView.Target = target;
						break;
					}
					_lastNode = value;
					_lastOverride = target;
				}
			}
			else
			{
				Clear();
			}
		}

		private void Clear()
		{
			if (_lastOverride != null && _lastUserRoot != null && !_lastOverride.IsDisposed)
			{
				switch (_lastNode)
				{
				case OverrideNode.Root:
					_lastUserRoot.OverrideRoot.Target = null;
					break;
				case OverrideNode.Ears:
					ClearEars();
					break;
				case OverrideNode.View:
					_lastUserRoot.OverrideView.Target = null;
					break;
				}
			}
			_lastOverride = null;
			_lastUserRoot = null;
			_lastNode = (OverrideNode)(-1);
		}

		private void ClearEars()
		{
			_lastUserRoot.PrimaryListener.Target.Enabled = true;
			_lastOverrideListener?.Slot.Destroy();
			_lastOverrideListener = null;
		}

		protected override void OnDispose()
		{
			Clear();
			base.OnDispose();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Override = new SyncRef<Slot>();
			Node = new Sync<OverrideNode>();
			_equippingSlot = new SyncRef<AvatarObjectSlot>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Override, 
				4 => Node, 
				5 => _equippingSlot, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

