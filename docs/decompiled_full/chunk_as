				//ILSpy generated this function to help ensure overload resolution can pick the overload using 'in'
				return ref temp;
			}
		}

		private float ComputeSupportLegMagnitude(Leg leg)
		{
			return (leg.lastBone.solverPosition - leg.thigh.solverPosition).SqrMagnitude;
		}

