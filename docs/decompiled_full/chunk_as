		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			if (DataSource.Target == null)
			{
				foreach (ExpressionDriver expressionDriver in ExpressionDrivers)
				{
					if (expressionDriver.Target.IsLinkValid)
					{
						expressionDriver.Target.Target.Value = 0f;
					}
				}
				return;
			}
			IMouthTrackingSourceComponent target = DataSource.Target;
			float volumeSupressionWeight = VolumeSupressionWeight;
			float num = StrengthMultiplier.Value;
			if (FrooxEngine.Engine.IsAprilFools)
			{
				num *= Settings.GetActiveSetting<MysterySettings>()?.Expressiveness.Value ?? 1f;
			}
			foreach (ExpressionDriver expressionDriver2 in ExpressionDrivers)
			{
				if (expressionDriver2.Target.IsLinkValid)
				{
					float num2 = Eval(target, expressionDriver2.Expression.Value, expressionDriver2.EstimateIfNotTracked.Value);
					num2 *= 1f - volumeSupressionWeight * expressionDriver2.VolumeSupressionStrength.Value;
					num2 = MathX.Lerp(expressionDriver2.Min, expressionDriver2.Max, num2);
					expressionDriver2.Target.Target.Value = num2 * num;
				}
			}
		}

