		{
			WorkerInspector.BuildInspectorUI(this, ui);
			ui.Button("Inspector.SimpleAvatarProtection.RemoveAll".AsLocaleKey(), OnRemoveAllInstances);
			ui.Button("Inspector.SimpleAvatarProtection.RemoveSingle".AsLocaleKey(), OnRemoveSingleInstance);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnRemoveSingleInstance(IButton button, ButtonEventData eventData)
		{
			Remove(eventData, allInstances: false);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnRemoveAllInstances(IButton button, ButtonEventData eventData)
		{
			Remove(eventData, allInstances: true);
		}

		private void Remove(ButtonEventData eventData, bool allInstances)
		{
			if (!CanUse(base.LocalUser))
			{
				return;
			}
			Userspace.OpenContextMenu(eventData.source.Slot, new ContextMenuOptions
			{
				disableFlick = true
			}, async delegate(ContextMenu menu)
			{
				menu.AddItem("Inspector.SimpleAvatarProtection.ConfirmRemoveAll".AsLocaleKey(), (Uri)null, new Elements.Core.colorX?(Elements.Core.colorX.Red)).Button.LocalPressed += [SyncMethod(typeof(Delegate), null)] (IButton button, ButtonEventData buttonEventData) =>
				{
					StartTask(async delegate
					{
						await default(ToWorld);
						if (allInstances)
						{
							base.Slot.GetObjectRoot().GetComponentsInChildren<SimpleAvatarProtection>().ForEach(delegate(SimpleAvatarProtection p)
							{
								if (p.CanUse(base.LocalUser))
								{
									p._allowRemoval = true;
									p.Destroy();
								}
							});
						}
						else if (CanUse(base.LocalUser))
						{
							_allowRemoval = true;
							Destroy();
						}
					});
					menu.Close();
				};
				for (int num = 0; num < 4; num++)
				{
					menu.AddItem("General.Cancel".AsLocaleKey(), (Uri?)null, new Elements.Core.colorX?(Elements.Core.colorX.Gray), (ButtonEventHandler)menu.CloseMenu);
				}
			});
