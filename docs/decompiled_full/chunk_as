			DoNotSimulate = new Sync<bool>();
			Filters = new PrioritySyncRefList<IAvatarPoseFilter>();
			_autoSmoothing = new SyncRef<AvatarPoseSmoothLerp>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Priority, 
				4 => Equipped, 
				5 => Node, 
				6 => IsTracking, 
				7 => IsActive, 
				8 => IsSimulated, 
				9 => DriveActive, 
				10 => DriveScale, 
				11 => DoNotSimulate, 
				12 => Filters, 
				13 => _autoSmoothing, 
				_ => throw new ArgumentOutOfRangeException(), 
