		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			int typeVersion = control.GetTypeVersion(GetType());
			if (typeVersion < 3)
			{
				RunSynchronously(delegate
				{
					IK.Target.Solver.PlantFeet.Value = false;
					FootFloatOffsetMagnitude.Value *= 0.5f;
					FeetHoverHeight.Value *= 0.5f;
					MaxFeetVelocityOffset.Value *= 0.5f;
					SetupDefaultGaits();
				});
			}
			if (typeVersion < 4)
			{
				RunSynchronously(delegate
				{
					CleanupOldBones();
					GenerateOptimizedColliders();
				});
			}
			if (typeVersion < 5)
			{
				RunSynchronously(delegate
				{
					LeftHandRotationOffset.Value = Elements.Core.floatQ.Euler(90f, 90f, 90f) * LeftHandRotationOffset.Value;
					RightHandRotationOffset.Value = Elements.Core.floatQ.Euler(90f, 90f, 90f) * RightHandRotationOffset.Value;
				});
			}
			if (typeVersion < 6)
			{
				RunSynchronously(delegate
				{
					BipedRig componentInChildrenOrParents = base.Slot.GetComponentInChildrenOrParents<BipedRig>();
					if (componentInChildrenOrParents == null)
					{
						UniLog.Warning("Cannot upgrade BipedRig with hands - couldn't find it in the hierarchy");
					}
					else
					{
						componentInChildrenOrParents.DetectHandRigs();
						SetupHands(componentInChildrenOrParents);
					}
				});
			}
			if (typeVersion < 8)
			{
				RunSynchronously(delegate
				{
					ClearDestroyRoots(base.Slot);
				});
			}
			if (typeVersion < 9)
			{
				RunSynchronously(delegate
				{
					AssignDrives(IK.Target);
					IK.Target.Solver.spine.BodyPosStiffness.Value = 1f;
				});
			}
			if (typeVersion < 10)
			{
				RunSynchronously(delegate
				{
					EnsureDefaultKneeProxies();
					IK.Target.Solver.spine.BodyPosStiffness.Value = 1f;
				});
			}
			if (typeVersion < 12)
			{
				RunSynchronously(delegate
				{
					AssignDrives(IK.Target);
					EnsurePoseNodes();
				});
			}
			if (typeVersion < 11)
			{
				RunSynchronously(delegate
				{
					ComputeDefaultFullBodyCalibration(30f, 0.15f);
				});
			}
			if (typeVersion < 12)
			{
				RunSynchronously(delegate
				{
					if (HeightCompensation.Value == 1.05f)
					{
						HeightCompensation.Value = 0.95f;
					}
				});
			}
			if (typeVersion < 17)
			{
				RunSynchronously(delegate
				{
					if (IK.Target != null)
					{
						IK.Target.AutoUpdate.Value = false;
					}
				});
			}
			RunSynchronously(delegate
			{
				List<Slot> toDelete = Pool.BorrowList<Slot>();
				base.Slot.ForeachChild(delegate(Slot s)
				{
					if (s.Name != null && s.Name.IndexOf("vigen", StringComparison.InvariantCultureIgnoreCase) >= 0 && s.GetComponentInChildren<ProtoFluxNode>() != null)
					{
						toDelete.Add(s);
					}
				});
				foreach (Slot item in toDelete)
				{
					item.Destroy(sendDestroyingEvent: false);
				}
				Pool.Return(ref toDelete);
			});
			if (typeVersion < 18)
			{
				RunSynchronously(InitializeHaptics);
			}
			if (typeVersion < 20)
			{
				RunSynchronously(delegate
				{
					foreach (LegHapticPointMapper componentsInChild in IK.Target.Solver.BoneReferences[BodyNode.RightUpperLeg].GetComponentsInChildren((LegHapticPointMapper m) => m.Side.Value == Chirality.Left))
					{
						componentsInChild.Slot.Destroy();
					}
					InitializeHaptics();
				});
			}
			if (typeVersion < 21)
			{
				RunSynchronously(delegate
				{
					foreach (FieldDrive<bool> rigCollidersEnabledState in _rigCollidersEnabledStates)
					{
						Collider collider = rigCollidersEnabledState.Target.FindNearestParent<Collider>();
						if (collider != null)
						{
							collider.Type.Value = ColliderType.Static;
						}
					}
				});
			}
			if (typeVersion < 22)
			{
				RunSynchronously(InitializeHaptics);
			}
			if (typeVersion < 23)
			{
				RunSynchronously(InitializeFacetAnchors);
			}
			if (typeVersion < 24)
			{
				RunSynchronously(InitializeLocomotionColliders);
			}
			if (typeVersion < 25)
			{
				RunSynchronously(InitializeLocomotionMetrics);
			}
		}

