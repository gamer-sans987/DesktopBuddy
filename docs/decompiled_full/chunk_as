		public void AddModelBadge(Uri uri, string name = null)
		{
			StartTask(async delegate
			{
				Slot badge = base.Slot.AddSlot(name ?? "3D Badge");
				Slot model = badge.AddSlot("Model");
				await model.LoadObjectAsync(uri, null, null, preserveRootTransform: false, skipHolder: false, delegate(Type type)
				{
					if (type == typeof(StaticTexture2D))
					{
						return true;
					}
					if (type == typeof(StaticMesh))
					{
						return true;
					}
					if (type == typeof(StaticShader))
					{
						return true;
					}
					if (type == typeof(MeshRenderer))
					{
						return true;
					}
					if (type == typeof(Spinner))
					{
						return true;
					}
					if (type == typeof(Wiggler))
					{
						return true;
					}
					if (type == typeof(Panner1D))
					{
						return true;
					}
					if (type == typeof(Panner2D))
					{
						return true;
					}
					if (type == typeof(Panner3D))
					{
						return true;
					}
					if (type == typeof(Panner4D))
					{
						return true;
					}
					return typeof(MaterialProvider).IsAssignableFrom(type) ? true : false;
				});
				List<MeshRenderer> componentsInChildren = model.GetComponentsInChildren<MeshRenderer>();
				if (componentsInChildren.Count == 0)
				{
					UniLog.Warning($"No mesh renderers found on custom 3D badge {uri}, deleting.");
					badge.Destroy();
				}
				else
				{
					for (int num = 1; num < componentsInChildren.Count; num++)
					{
						componentsInChildren[num].Destroy();
					}
					HashSet<IDestroyable> toDestroy = new HashSet<IDestroyable>();
					foreach (Component material in componentsInChildren[0].Materials)
					{
						material.ForeachSyncMember(delegate(ISyncRef r)
						{
							if (r.Target is StaticTexture2D staticTexture2D)
							{
								staticTexture2D.MaxSize.Value = 128;
							}
							else if (r.Target is ProceduralTexture item)
							{
								toDestroy.Add(item);
							}
						});
					}
					foreach (IDestroyable item2 in toDestroy)
					{
						item2.Destroy();
					}
					while (!model.ForeachComponentInChildren((IBounded b) => b.HasBoundingBox && b.IsBoundingBoxAvailable))
					{
						await default(NextUpdate);
					}
					Elements.Core.BoundingBox boundingBox = model.ComputeBoundingBox(includeInactive: true, badge);
					if (!boundingBox.IsValid || boundingBox.IsEmpty)
					{
						UniLog.Warning($"Custom 3D badge {uri} does not have valid bounds, deleting.");
						badge.Destroy();
					}
					else
					{
						float num2 = MathX.MaxComponent(boundingBox.Size);
						model.LocalPosition = Elements.Core.float3.Zero;
						model.LocalRotation = Elements.Core.floatQ.AxisAngle(Elements.Core.float3.Up, 180f);
						model.LocalScale = 1f / num2 * Elements.Core.float3.One;
						AddBadgeTemplate(badge);
					}
				}
			});
		}

		public void AddBadgeTemplate(Slot template)
		{
			string name = template.Name;
			int num = 2;
			while (_badgeTemplates.Target.FindChild(template.Name) != null)
