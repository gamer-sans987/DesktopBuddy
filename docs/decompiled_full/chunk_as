		private Elements.Core.float3 ComputeTargetPoint(in Elements.Core.float3 direction, in Elements.Core.float3 offset, float distance)
		{
			Elements.Core.float3 localPoint = offset + direction * distance;
			return base.Slot.LocalPointToGlobal(in localPoint);
		}

		private void UpdateFromEyeTracking(IEyeDataSourceComponent eyeData, ref bool simulatePupilSize)
		{
			Slot slot = base.Slot.ActiveUserRoot?.Slot ?? base.Slot.GetObjectRoot();
			bool isTracking = eyeData.GetIsTracking(EyeSide.Left);
			Elements.Core.float3 a = eyeData.GetPosition(EyeSide.Left);
			Elements.Core.float3 a2 = eyeData.GetDirection(EyeSide.Left);
			bool isTracking2 = eyeData.GetIsTracking(EyeSide.Right);
			Elements.Core.float3 b = eyeData.GetPosition(EyeSide.Right);
			Elements.Core.float3 b2 = eyeData.GetDirection(EyeSide.Right);
			Elements.Core.float3 localDirection = ((isTracking && isTracking2) ? ((a2 + b2) * 0.5f) : (isTracking ? a2 : ((!isTracking2) ? Elements.Core.float3.Forward : b2)));
			float spaceScale = MathX.Distance(in a, in b) * 0.5f;
			spaceScale = base.Slot.SpaceScaleToLocal(spaceScale, slot);
			float num = eyeData.ConvergenceDistance;
			if (num <= 0f)
			{
				RaycastHit? raycastHit = base.Physics.RaycastOne(GlobalEyeCenter, base.Slot.LocalDirectionToGlobal(in localDirection), _raycastFilter);
				num = ((!raycastHit.HasValue) ? 10000f : slot.GlobalScaleToLocal(raycastHit.Value.Distance));
			}
			num = base.Slot.SpaceScaleToLocal(num, slot);
			LeftEyeTargetPoint.Value = ComputeTargetPoint(in a2, new Elements.Core.float3(0f - spaceScale), num);
			RightEyeTargetPoint.Value = ComputeTargetPoint(in b2, new Elements.Core.float3(spaceScale), num);
			TargetPoint.Value = ComputeTargetPoint(in localDirection, Elements.Core.float3.Zero, num);
			LeftEyeClose.Value = MathX.Lerp(MathX.Max(1f - eyeData.GetOpenness(EyeSide.Left), LeftEyeCloseOverride), 1f, _awayCloseLerp);
			RightEyeClose.Value = MathX.Lerp(MathX.Max(1f - eyeData.GetOpenness(EyeSide.Right), RightEyeCloseOverride), 1f, _awayCloseLerp);
			CombinedEyeClose.Value = MathX.Max(LeftEyeClose.Value, RightEyeClose.Value);
			float? num2 = eyeData.GetPupilDiameter(EyeSide.Left) * 1000f;
			float? num3 = eyeData.GetPupilDiameter(EyeSide.Right) * 1000f;
			if (num2.HasValue && num3.HasValue)
			{
				simulatePupilSize = false;
				num2 = MathX.SmoothLerp(LeftEyePupilSizeMillimeters.Value, num2.Value, ref _leftIntermediatePupilSize, base.Time.Delta * (float)EyeTrackingPupilSizeSmoothSpeed);
				num3 = MathX.SmoothLerp(RightEyePupilSizeMillimeters.Value, num3.Value, ref _rightIntermediatePupilSize, base.Time.Delta * (float)EyeTrackingPupilSizeSmoothSpeed);
				LeftEyePupilSizeMillimeters.Value = num2.Value;
				RightEyePupilSizeMillimeters.Value = num3.Value;
				CombinedEyePupilSizeMillimeters.Value = (LeftEyePupilSizeMillimeters.Value + RightEyePupilSizeMillimeters.Value) * 0.5f;
			}
			LeftEyeWiden.Value = eyeData.GetWiden(EyeSide.Left);
			RightEyeWiden.Value = eyeData.GetWiden(EyeSide.Right);
			CombinedEyeWiden.Value = (LeftEyeWiden.Value + RightEyeWiden.Value) * 0.5f;
			LeftEyeSqueeze.Value = eyeData.GetSqueeze(EyeSide.Left);
			RightEyeSqueeze.Value = eyeData.GetSqueeze(EyeSide.Right);
			CombinedEyeSqueeze.Value = (LeftEyeSqueeze.Value + RightEyeSqueeze.Value) * 0.5f;
			LeftEyeFrown.Value = eyeData.GetFrown(EyeSide.Left);
			RightEyeFrown.Value = eyeData.GetFrown(EyeSide.Right);
			CombinedEyeFrown.Value = (LeftEyeFrown.Value + RightEyeFrown.Value) * 0.5f;
			LeftEyeInnerBrowVertical.Value = eyeData.GetInnerBrowVertical(EyeSide.Left);
			RightEyeInnerBrowVertical.Value = eyeData.GetInnerBrowVertical(EyeSide.Right);
			CombinedEyeInnerBrowVertical.Value = (LeftEyeInnerBrowVertical.Value + RightEyeInnerBrowVertical.Value) * 0.5f;
			LeftEyeOuterBrowVertical.Value = eyeData.GetOuterBrowVertical(EyeSide.Left);
			RightEyeOuterBrowVertical.Value = eyeData.GetOuterBrowVertical(EyeSide.Right);
			CombinedEyeOuterBrowVertical.Value = (LeftEyeOuterBrowVertical.Value + RightEyeOuterBrowVertical.Value) * 0.5f;
		}

		private void SimulatePupilSize()
		{
			float num = (float)base.Time.WorldTime * PupilSizeNoiseSpeed.Value;
			float lerp = MathX.SimplexNoise(num) * 0.15f + 0.3f;
			float lerp2 = MathX.SimplexNoise(num + PupilSizeNoiseOffset.Value) * 0.15f + 0.3f;
			LeftEyePupilSizeMillimeters.Value = MathX.Lerp(MinPupilSize, MaxPupilSize, lerp);
			RightEyePupilSizeMillimeters.Value = MathX.Lerp(MinPupilSize, MaxPupilSize, lerp2);
			CombinedEyePupilSizeMillimeters.Value = (LeftEyePupilSizeMillimeters.Value + RightEyePupilSizeMillimeters.Value) * 0.5f;
		}

		private void SimulateBlinking()
		{
			double num = _lastBlinkTime + (double)MathX.Lerp(MinBlinkInterval, MaxBlinkInterval, _nextBlinkIntervalLerp);
			if (_blinkState == BlinkState.Off && base.Time.WorldTime > num)
			{
				_blinkState = BlinkState.BlinkClose;
				float num2 = RandomX.Range(BlinkMinSpeed, BlinkMaxSpeed);
				_leftBlinkSpeed = num2 + RandomX.Range(0f - (float)BlinkSpeedSpread, BlinkSpeedSpread);
				_rightBlinkSpeed = num2 + RandomX.Range(0f - (float)BlinkSpeedSpread, BlinkSpeedSpread);
				_leftBlinkSpeed = MathX.Max(_leftBlinkSpeed, MIN_BLINK_SPEED);
				_rightBlinkSpeed = MathX.Max(_rightBlinkSpeed, MIN_BLINK_SPEED);
			}
			if (_blinkState == BlinkState.BlinkClose)
			{
				_leftBlinkLerp += base.Time.Delta * _leftBlinkSpeed;
				_rightBlinkLerp += base.Time.Delta * _rightBlinkSpeed;
				bool num3 = _leftBlinkLerp >= 1f;
				bool flag = _rightBlinkLerp >= 1f;
				if (num3)
				{
					_leftBlinkLerp = 1f;
				}
				if (flag)
				{
					_rightBlinkLerp = 1f;
				}
				if (num3 && flag)
				{
					_blinkState = BlinkState.BlinkOpen;
				}
			}
			else if (_blinkState == BlinkState.BlinkOpen)
			{
				_leftBlinkLerp -= base.Time.Delta * _leftBlinkSpeed;
				_rightBlinkLerp -= base.Time.Delta * _rightBlinkSpeed;
				bool num4 = _leftBlinkLerp <= 0f;
				bool flag2 = _rightBlinkLerp <= 0f;
				if (num4)
				{
					_leftBlinkLerp = 0f;
				}
				if (flag2)
				{
					_rightBlinkLerp = 0f;
				}
				if (num4 && flag2)
				{
					_blinkState = BlinkState.Off;
					_lastBlinkTime = base.Time.WorldTime;
					_nextBlinkIntervalLerp = RandomX.Value;
				}
			}
			LeftEyeClose.Value = MathX.Lerp(MathX.Lerp(LeftEyeCloseOverride.Value, 1f, _leftBlinkLerp), 1f, _awayCloseLerp);
			RightEyeClose.Value = MathX.Lerp(MathX.Lerp(RightEyeCloseOverride.Value, 1f, _rightBlinkLerp), 1f, _awayCloseLerp);
			CombinedEyeClose.Value = (LeftEyeClose.Value + RightEyeClose.Value) * 0.5f;
		}

