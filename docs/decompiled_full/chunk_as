		{
			if (locomotion.StepHeight.Count == 0)
			{
				GetSineKeyframes(0.03f, locomotion.StepHeight);
			}
			if (locomotion.HeelHeight.Count == 0)
			{
				GetSineKeyframes(0.03f, locomotion.HeelHeight);
			}
			DefaultArmStretchCurve(leftArm);
			DefaultArmStretchCurve(rightArm);
		}

		private void DefaultArmStretchCurve(Arm arm)
		{
			if (arm.StretchCurve.Count == 0)
			{
				arm.StretchCurve.Append(new CurveKey<float>(0f, 0f));
				arm.StretchCurve.Append(new CurveKey<float>(0.9f, 0f, 0f, 0.5f));
				arm.StretchCurve.Append(new CurveKey<float>(1.1f, 0.1f, -0.5f, 0f));
			}
		}

		/// <summary>
		/// Adds position offset to a body part. Position offsets add to the targets in VRIK.
		/// </summary>
		public void AddPositionOffset(PositionOffset positionOffset, in Elements.Core.float3 value)
		{
			switch (positionOffset)
			{
			case PositionOffset.Pelvis:
			{
				Spine obj3 = spine;
				obj3.pelvisPositionOffset += value;
				break;
			}
			case PositionOffset.Chest:
			{
				Spine obj2 = spine;
				obj2.chestPositionOffset += value;
				break;
			}
			case PositionOffset.Head:
			{
				Spine obj = spine;
				obj.headPositionOffset += value;
				break;
			}
			case PositionOffset.LeftHand:
			{
				Arm arm2 = leftArm;
				arm2.handPositionOffset += value;
				break;
			}
			case PositionOffset.RightHand:
			{
				Arm arm = rightArm;
				arm.handPositionOffset += value;
				break;
			}
			case PositionOffset.LeftFoot:
			{
				Leg leg4 = leftLeg;
				leg4.footPositionOffset += value;
				break;
			}
			case PositionOffset.RightFoot:
			{
				Leg leg3 = rightLeg;
				leg3.footPositionOffset += value;
				break;
			}
			case PositionOffset.LeftHeel:
			{
				Leg leg2 = leftLeg;
				leg2.heelPositionOffset += value;
				break;
			}
			case PositionOffset.RightHeel:
			{
				Leg leg = rightLeg;
				leg.heelPositionOffset += value;
				break;
			}
			}
		}

