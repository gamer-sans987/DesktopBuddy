				Slot slot = base.Slot.Parent.AddSlot("INJECTED Legacy Toolshelf Offset");
				slot.CopyTransform(base.Slot);
				Chirality? chirality = base.Slot.TryDetermineChirality();
				base.Slot.Parent = slot;
