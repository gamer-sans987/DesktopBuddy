		private Elements.Core.float3 GetPelvisOffset()
		{
			if ((float)locomotion.Weight <= 0f)
			{
				return Elements.Core.float3.Zero;
			}
			Elements.Core.float3 @float = raycastOriginPelvis;
			@float = new Elements.Core.float3(@float.x, spine.pelvis.solverPosition.y, @float.z);
			Elements.Core.float3 readPosition = spine.pelvis.readPosition;
			readPosition = new Elements.Core.float3(readPosition.x, spine.pelvis.solverPosition.y, readPosition.z);
			_ = readPosition - @float;
			Elements.Core.float3 a = spine.pelvis.solverPosition;
			_ = a - readPosition;
			lastOffset = MathX.Lerp(in lastOffset, Elements.Core.float3.Zero, base.Time.Delta * 3f);
			a += MathX.ClampMagnitude(in lastOffset, 0.75f);
			a = new Elements.Core.float3(a.x, spine.pelvis.solverPosition.y, a.z);
			lastOffset = MathX.Lerp(in lastOffset, a - spine.pelvis.solverPosition, base.Time.Delta * 15f);
			if (lastOffset.IsNaN)
			{
				lastOffset = Elements.Core.float3.Zero;
			}
			return lastOffset;
		}

