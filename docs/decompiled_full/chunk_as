	public class DiscordConnector : IPlatformConnector, IDisposable
	{
		public readonly string LARGE_IMAGE_ID = "resonite-logo";

		public readonly string SMALL_IMAGE_ID = "resonite-logo";

		private Discord discord;

		public PlatformInterface Interface { get; private set; }

		public int Priority => -10;

		public string PlatformName => "Discord";

		public string Username { get; private set; }

		public string PlatformUserId { get; private set; }

		public bool IsPlatformNameUnique => false;

		public static bool Initialized { get; private set; }

		public static bool ShouldUpdate { get; private set; }

		public RichPresenceLevel RichPresencePreference { get; private set; } = RichPresenceLevel.Full;

		public bool IsRichPresenceEnabled => RichPresencePreference > RichPresenceLevel.None;

		public void LogHook(LogLevel level, string message)
		{
			UniLog.Log($"Discord:{level} - {message}");
		}

		public async Task<bool> Initialize(PlatformInterface platformInterface)
		{
			Interface = platformInterface;
			discord = new Discord(Interface.Engine.PlatformProfile.DiscordAppId, 1uL);
			discord.SetLogHook(LogLevel.Warn, LogHook);
			discord.GetUserManager().OnCurrentUserUpdate += UserCallback;
			discord.GetActivityManager().RegisterSteam(Convert.ToUInt32(Interface.Engine.PlatformProfile.SteamAppId, CultureInfo.InvariantCulture));
			Initialized = true;
			ShouldUpdate = true;
			UniLog.Log("Discord connector initialized.");
			Settings.RegisterValueChanges<DiscordIntegrationSettings>(OnRichPresenceSettingsChanged);
			return true;
		}

		private void OnRichPresenceSettingsChanged(DiscordIntegrationSettings setting)
		{
			if (setting.RichPresence.Value < RichPresenceLevel.Basic)
			{
				ClearCurrentStatus();
			}
			RichPresencePreference = setting.RichPresence.Value;
		}

		public void Update()
		{
			if (!Initialized || !ShouldUpdate)
			{
				return;
			}
			try
			{
				discord.RunCallbacks();
			}
			catch (ResultException ex)
			{
				HandleDiscordResult(ex.Result, "Callbacks", ex.Message);
			}
			catch (Exception ex2)
			{
				UniLog.Log("Error running discord callbacks: " + ex2.Message);
			}
		}

		private void HandleDiscordResult(DiscordGameSDKWrapper.Result result, string action, string message = "None")
		{
			switch (result)
			{
			case DiscordGameSDKWrapper.Result.NotInstalled:
				ShouldUpdate = false;
				return;
			case DiscordGameSDKWrapper.Result.Ok:
			case DiscordGameSDKWrapper.Result.NotRunning:
				return;
			}
			UniLog.Log($"Error running discord action {action}, with result {result} and message: {message}");
		}

		public void Dispose()
		{
			discord.Dispose();
		}

		public void SetCurrentStatus(World world, bool isPrivate, int totalWorldCount)
		{
			if (Initialized && IsRichPresenceEnabled)
			{
				ActivityManager activityManager = discord.GetActivityManager();
				Activity activity = new Activity
				{
					Assets = 
					{
						LargeImage = LARGE_IMAGE_ID
					},
					Timestamps = 
					{
						Start = new DateTimeOffset(world.Time.LocalSessionBeginTime).ToUnixTimeSeconds()
					}
				};
				string rawString = StringTokenizer.Tokenize(world.Name).GetRawString();
				activity.Type = ActivityType.Playing;
				if (isPrivate || RichPresencePreference < RichPresenceLevel.Full)
				{
					activity.State = world.GetLocalized("Discord.RichPresence.InPrivateWorld");
					activity.Details = "";
					activity.Assets.LargeText = world.GetLocalized("Discord.RichPresence.InPrivateLargeText", null, ("version", Engine.CurrentVersion));
					activity.Party = new ActivityParty
					{
						Id = "Private",
						Privacy = ActivityPartyPrivacy.Private,
						Size = 
						{
							CurrentSize = 0,
							MaxSize = 0
						}
					};
				}
				else
				{
					activity.State = world.GetLocalized("Discord.RichPresence.InPublicWorld");
					activity.Details = world.GetLocalized("Discord.RichPresence.PublicWorldDetails", null, ("worldName", rawString), ("totalWorlds", totalWorldCount));
					activity.Assets.LargeText = world.GetLocalized("Discord.RichPresence.InPublicLargeText", null, ("version", Engine.CurrentVersion));
					activity.Party = new ActivityParty
					{
						Id = world.SessionId,
						Privacy = ActivityPartyPrivacy.Public,
						Size = 
						{
							CurrentSize = world.UserCount,
							MaxSize = world.MaxUsers
						}
					};
				}
				activityManager.UpdateActivity(activity, OnDiscordActivityUpdate);
			}
		}

		private void SetBlankActivity()
		{
			if (Initialized)
			{
				ActivityManager activityManager = discord.GetActivityManager();
				Activity activity = default(Activity);
				activity.Assets.LargeImage = LARGE_IMAGE_ID;
				activity.Timestamps.Start = DateTimeOffset.Now.ToUnixTimeSeconds();
				activity.State = "";
				activity.Type = ActivityType.Playing;
				activity.Details = "";
				activity.Assets.LargeText = "";
				activity.Party = new ActivityParty
				{
					Id = "Blank",
					Privacy = ActivityPartyPrivacy.Private,
					Size = 
					{
						CurrentSize = 0,
						MaxSize = 0
					}
				};
				activityManager.UpdateActivity(activity, OnDiscordActivityUpdate);
			}
		}

		public void ClearCurrentStatus()
		{
			SetBlankActivity();
		}

		private void OnDiscordActivityUpdate(DiscordGameSDKWrapper.Result result)
		{
			HandleDiscordResult(result, "Update Activity");
		}

		public void UserCallback()
		{
			DiscordGameSDKWrapper.User currentUser = discord.GetUserManager().GetCurrentUser();
			Username = currentUser.Username;
			PlatformUserId = currentUser.Id.ToString(CultureInfo.InvariantCulture);
		}

