	/// Helper methods for dealing with floatQs.
	/// </summary>
	public static class QuaTools
	{
		/// <summary>
		/// Clamps the rotation similar to V3Tools.ClampDirection.
		/// </summary>
		public static Elements.Core.floatQ ClampRotation(in Elements.Core.floatQ rotation, float clampWeight, int clampSmoothing)
		{
			if (clampWeight >= 1f)
			{
				return Elements.Core.floatQ.Identity;
			}
			if (clampWeight <= 0f)
			{
				return rotation;
			}
			float num = MathX.AngleRad(Elements.Core.floatQ.Identity, in rotation);
			float num2 = 1f - num / MathF.PI;
			float num3 = MathX.Clamp(1f - (clampWeight - num2) / (1f - num2), 0f, 1f);
			float num4 = MathX.Clamp(num2 / clampWeight, 0f, 1f);
			for (int i = 0; i < clampSmoothing; i++)
			{
				num4 = MathX.Sin(num4 * MathF.PI * 0.5f);
			}
			return MathX.LerpUnclamped(Elements.Core.floatQ.Identity, in rotation, num4 * num3);
		}
	}
	/// <summary>
