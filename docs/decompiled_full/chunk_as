			}
		}

		private void GetTerminalPoints(Slot root, BoneNode node, bool isUnderRoot, List<Elements.Core.float3> points)
		{
			if (!isUnderRoot && node.bone.IsChildOf(root, includeSelf: true))
			{
				isUnderRoot = true;
			}
			if (node.children.Count == 0)
			{
				if (isUnderRoot)
				{
					points.Add(node.bone.GlobalPosition);
				}
				return;
			}
			foreach (BoneNode child in node.children)
			{
				GetTerminalPoints(root, child, isUnderRoot, points);
			}
		}

		private void SetupTerminalBoxColliderBone(Slot root, List<BoneNode> hierarchies)
		{
			List<Elements.Core.float3> points;
			Elements.Core.float3 a = ComputeAverageTerminalPoint(root, hierarchies, out points);
			Slot slot = root.AddSlot("Collider");
			slot.Forward = a - root.GlobalPosition;
			Elements.Core.BoundingBox boundingBox = new Elements.Core.BoundingBox(Elements.Core.float3.Zero);
			foreach (Elements.Core.float3 item in points)
			{
				boundingBox.Encapsulate(slot.GlobalPointToLocal(item));
			}
			BoxCollider boxCollider = slot.AttachComponent<BoxCollider>();
			boxCollider.Size.Value = boundingBox.Size * new Elements.Core.float3(1f, 1.5f, 1f);
			boxCollider.Offset.Value = boundingBox.Center;
			boxCollider.Type.Value = ColliderType.Static;
			_rigCollidersEnabledStates.Add().Target = boxCollider.EnabledField;
		}

		private Elements.Core.float3 ComputeAverageTerminalPoint(Slot root, List<BoneNode> hierarchies, out List<Elements.Core.float3> points)
		{
			points = new List<Elements.Core.float3>();
			GetTerminalPoints(root, hierarchies, points);
			Elements.Core.float3 v = Elements.Core.float3.Zero;
			int num = 0;
			foreach (Elements.Core.float3 point in points)
			{
				v += point;
				num++;
			}
			return v / num;
		}

		private void SetupTerminalFootBone(Slot calf, Slot foot, Slot toes, float radiusRatio, List<BoneNode> hierachies)
		{
			Elements.Core.float3 a = Elements.Core.float3.Zero;
			if (toes != null && foot != toes)
			{
				a = foot.GlobalPointToLocal(ComputeAverageTerminalPoint(foot, hierachies, out List<Elements.Core.float3> _));
			}
			if (a == Elements.Core.float3.Zero || a.IsNaN || a.IsInfinity)
			{
				float num = MathX.Distance(calf.GlobalPosition, foot.GlobalPosition);
				a = foot.GlobalPointToLocal(foot.GlobalPosition + foot.Forward * num * 0.25f);
			}
			SetupCapsuleBone(foot, a, radiusRatio);
		}

		private void SetupCapsuleBone(Slot root, Slot end, float radiusRatio)
		{
			Elements.Core.float3 endPoint = root.GlobalPointToLocal(end.GlobalPosition);
			SetupCapsuleBone(root, endPoint, radiusRatio);
		}

		private void SetupCapsuleBone(Slot root, Elements.Core.float3 endPoint, float radiusRatio)
		{
			float magnitude;
			Elements.Core.float3 a = endPoint.GetNormalized(out magnitude);
			float value = radiusRatio * magnitude;
			Elements.Core.float3 @float = endPoint * 0.5f;
			Slot slot;
			if (MathX.Dot(in a, Elements.Core.float3.Up) < 0.98f)
			{
				slot = root.AddSlot(root.Name + " - Bone");
				slot.Up = root.LocalDirectionToGlobal(in a);
				slot.LocalPosition = @float;
				@float = Elements.Core.float3.Zero;
			}
			else
			{
				slot = root;
			}
			CapsuleCollider capsuleCollider = slot.AttachComponent<CapsuleCollider>();
			capsuleCollider.Height.Value = magnitude;
			capsuleCollider.Radius.Value = value;
			capsuleCollider.Offset.Value = @float;
			capsuleCollider.Type.Value = ColliderType.Static;
			_rigCollidersEnabledStates.Add().Target = capsuleCollider.EnabledField;
		}

