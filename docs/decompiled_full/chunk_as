		private void Solve()
		{
			spine.PreSolve();
			leftArm.PreSolve();
			rightArm.PreSolve();
			leftLeg.PreSolve();
			rightLeg.PreSolve();
			leftArm.ApplyOffsets();
			rightArm.ApplyOffsets();
			spine.ApplyOffsets();
			spine.Solve(ref rootBone, leftLeg, rightLeg, leftArm, rightArm);
			if ((float)locomotion.Weight > 0f)
			{
				Elements.Core.float3 leftFootPosition = Elements.Core.float3.Zero;
				Elements.Core.float3 rightFootPosition = Elements.Core.float3.Zero;
				Elements.Core.floatQ leftFootRotation = Elements.Core.floatQ.Identity;
				Elements.Core.floatQ rightFootRotation = Elements.Core.floatQ.Identity;
				float leftFootOffset = 0f;
				float rightFootOffset = 0f;
				float leftHeelOffset = 0f;
				float rightHeelOffset = 0f;
				locomotion.Solve(ref rootBone, spine, leftLeg, rightLeg, leftArm, rightArm, supportLeg, out leftFootPosition, out rightFootPosition, out leftFootRotation, out rightFootRotation, out leftFootOffset, out rightFootOffset, out leftHeelOffset, out rightHeelOffset);
				Elements.Core.float3 v = rootBone.solverRotation * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Up);
				leftFootPosition += v * leftFootOffset;
				rightFootPosition += v * rightFootOffset;
				Leg leg = leftLeg;
				leg.footPositionOffset += (leftFootPosition - leftLeg.lastBone.solverPosition) * IKPositionWeight * (1f - (float)leftLeg.PositionWeight) * locomotion.Weight;
				Leg leg2 = rightLeg;
				leg2.footPositionOffset += (rightFootPosition - rightLeg.lastBone.solverPosition) * IKPositionWeight * (1f - (float)rightLeg.PositionWeight) * locomotion.Weight;
				Leg leg3 = leftLeg;
				leg3.heelPositionOffset += v * leftHeelOffset * locomotion.Weight;
				Leg leg4 = rightLeg;
				leg4.heelPositionOffset += v * rightHeelOffset * locomotion.Weight;
				Elements.Core.floatQ b = Elements.Core.floatQ.FromToRotation(leftLeg.lastBone.solverRotation, leftFootRotation);
				Elements.Core.floatQ b2 = Elements.Core.floatQ.FromToRotation(rightLeg.lastBone.solverRotation, rightFootRotation);
				b = MathX.Slerp(Elements.Core.floatQ.Identity, b, (float)IKPositionWeight * (1f - (float)leftLeg.RotationWeight) * (float)locomotion.Weight);
				b2 = MathX.Slerp(Elements.Core.floatQ.Identity, b2, (float)IKPositionWeight * (1f - (float)rightLeg.RotationWeight) * (float)locomotion.Weight);
				leftLeg.footRotationOffset = b * leftLeg.footRotationOffset;
				rightLeg.footRotationOffset = b2 * rightLeg.footRotationOffset;
				Elements.Core.float3 to = V3Tools.PointToPlane(MathX.LerpUnclamped(leftLeg.position + leftLeg.footPositionOffset, rightLeg.position + rightLeg.footPositionOffset, 0.5f), in rootBone.solverPosition, in v);
