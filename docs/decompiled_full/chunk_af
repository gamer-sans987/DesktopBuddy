	public class ContextMenuSubmenu : Component, IButtonPressReceiver, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public readonly SyncRef<Slot> ItemsRoot;

		public readonly Sync<bool> SearchWholeHierarchy;

		public readonly Sync<bool> DisableFlick;

		public readonly Sync<float?> SpeedOverride;

		public readonly Sync<bool> CounterClockwise;

		public readonly Sync<bool> KeepPosition;

		public readonly Sync<bool> Hidden;

		private static bool IsValidSource(Slot slot)
		{
			if (slot.ActiveUserRoot != null)
			{
				return slot.IsUnderLocalUser;
			}
			return true;
		}

		public void Pressed(IButton button, ButtonEventData eventData)
		{
			if (ItemsRoot.Target == null || !IsValidSource(ItemsRoot.Target))
			{
				return;
			}
			List<ContextMenuItemSource> items = Pool.BorrowList<ContextMenuItemSource>();
			if (SearchWholeHierarchy.Value)
			{
				ItemsRoot.Target?.GetComponentsInChildren(items, (ContextMenuItemSource s) => IsValidSource(s.Slot), excludeDisabled: true);
			}
			else
			{
				foreach (Slot child in ItemsRoot.Target.Children)
				{
					if (IsValidSource(child))
					{
						ContextMenuItemSource component = child.GetComponent<ContextMenuItemSource>(null, excludeDisabled: true);
						if (component != null)
						{
							items.Add(component);
						}
					}
				}
			}
			if (items.Count > 0)
			{
				StartTask(async delegate
				{
					IWorldElement summoner = this;
					Slot pointer = eventData.source.Slot;
					ContextMenu userContextMenu = base.LocalUser.GetUserContextMenu();
					if (userContextMenu != null && userContextMenu.IsOpened && userContextMenu.CurrentSummoner is InteractionHandler interactionHandler)
					{
						summoner = interactionHandler;
						pointer = interactionHandler.PointReference;
					}
					else
					{
						InteractionHandler interactionHandler2 = eventData.source.Slot.FindInteractionHandler();
						if (interactionHandler2 != null)
						{
							summoner = interactionHandler2;
							pointer = interactionHandler2.PointReference;
						}
					}
					ContextMenu contextMenu = await base.LocalUser.OpenContextMenu(summoner, pointer, new ContextMenuOptions
					{
						disableFlick = DisableFlick.Value,
						speedOverride = SpeedOverride.Value,
						counterClockwise = CounterClockwise.Value,
						keepPosition = KeepPosition.Value,
						hidden = Hidden.Value
					});
					if (contextMenu != null)
					{
						foreach (ContextMenuItemSource item in items)
						{
							item.SetupItem(contextMenu);
						}
					}
					Pool.Return(ref items);
				});
			}
			else
			{
				Pool.Return(ref items);
			}
		}

