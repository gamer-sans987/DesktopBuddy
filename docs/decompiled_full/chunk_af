				if (!activeSearch || text.IndexOf(searchPhrase, StringComparison.InvariantCultureIgnoreCase) >= 0)
				{
					DataFeedEnum<E> dataFeedEnum = new DataFeedEnum<E>();
					E _value = value;
					dataFeedEnum.InitBase(text, null, null, value.GetName() ?? text);
					dataFeedEnum.InitSetupValue(delegate(IField<E> f)
