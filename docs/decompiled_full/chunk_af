	public class Tween<T> : Component
	{
		public readonly SyncRef<User> User;

		public readonly SyncRef<IField<T>> Target;

		public readonly SyncRef<Slot> OnlyUnderParent;

		public readonly Sync<T> From;

		public readonly Sync<T> To;

		public readonly Sync<double> StartTime;

		public readonly Sync<float> Duration;

		public readonly Sync<CurvePreset> Curve;

		public readonly Sync<bool> LocalCallback;

		public readonly SyncDelegate<Action> OnDone;

		public Action OnDoneLocal;

		private bool _forceFinalValue;

		public static bool IsValidGenericType => Coder<T>.IsEnginePrimitive;

		public float Lerp => MathX.Clamp01((float)((base.Time.WorldTime - (double)StartTime) / (double)(float)Duration));

		public bool IsTweenAuthority
		{
			get
			{
				if (User.Target != null)
				{
					return User.Target.IsLocalUser;
				}
				return base.World.IsAuthority;
			}
		}

		protected override void OnAwake()
		{
		}

		protected override void OnStart()
		{
			if (IsTweenAuthority && !base.Slot.IsActive)
			{
				_forceFinalValue = true;
				Destroy();
			}
		}

		protected override void OnDeactivated()
		{
			if (IsTweenAuthority && !base.Slot.IsActive)
			{
				_forceFinalValue = true;
				base.World.RunSynchronously(Destroy);
			}
			base.OnDeactivated();
		}

		protected override void OnDisabled()
		{
			if (IsTweenAuthority && !base.Slot.IsActive)
			{
				_forceFinalValue = true;
				base.World.RunSynchronously(Destroy);
			}
			base.OnDisabled();
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			User.Target = base.World.LocalUser;
			persistent.Value = false;
		}

		private void UpdateValue()
		{
			if (Target.Target == null)
			{
				return;
			}
			bool isTweenAuthority = IsTweenAuthority;
			if (!isTweenAuthority)
			{
				return;
			}
			if (OnlyUnderParent.Target != null && OnlyUnderParent.Target != Target.Target.FindNearestParent<Slot>()?.Parent)
			{
				FinishTween();
				return;
			}
			float num = (_forceFinalValue ? 1f : Lerp);
			Target.Target.Value = Coder<T>.LerpUnclamped(From.Value, To.Value, Curve.Value.Remap(num));
			if (num >= 1f && ((!LocalCallback.Value && isTweenAuthority) || (LocalCallback.Value && OnDoneLocal != null)))
			{
				FinishTween();
			}
		}

		private void FinishTween()
		{
			OnDone.Target?.Invoke();
			OnDoneLocal?.Invoke();
			Destroy();
			OnDoneLocal = null;
			OnDone.Target = null;
		}

		protected override void OnCommonUpdate()
		{
			UpdateValue();
		}

		protected override void OnDestroy()
		{
			UpdateValue();
			OnDoneLocal?.Invoke();
			OnDoneLocal = null;
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			OnDoneLocal?.Invoke();
			OnDoneLocal = null;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			User = new SyncRef<User>();
			Target = new SyncRef<IField<T>>();
			OnlyUnderParent = new SyncRef<Slot>();
			From = new Sync<T>();
			To = new Sync<T>();
