			int oldVersion = control.GetTypeVersion(GetType());
			if (oldVersion < Version || ForceUpgrade)
			{
				control.OnLoaded(this, delegate
				{
					UniLog.Log($"Upgrading facet {GetType().Name} {base.ReferenceID} from {oldVersion} to {Version}. ForceUpgrade: {ForceUpgrade}");
					Facet component = base.Slot.GetComponent<Facet>();
					Elements.Core.float2 currentSize = component.CurrentSize;
					component.Canvas.Target.Slot.DestroyChildren();
					SetupFacetData(currentSize);
					Build(component, SetupBackground(component), oldVersion);
				}, 100);
			}
