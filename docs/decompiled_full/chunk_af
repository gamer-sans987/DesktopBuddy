				Slot slot = WorldItemTemplate.Target.Slot.Duplicate(base.Slot);
				slot.ActiveSelf = true;
				slot.PersistentSelf = false;
				SetupHoverRelay(slot);
				legacyWorldItem = slot.GetComponent<LegacyWorldItem>();
			}
			else if (WorldItemType.Value != null)
			{
				Slot slot2 = base.Slot.AddSlot("Item");
				slot2.PersistentSelf = false;
				SetupHoverRelay(slot2);
				legacyWorldItem = (LegacyWorldItem)slot2.AttachComponent(WorldItemType.Value);
