	public class SetDataFeedCategory : Component, IButtonPressReceiver, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public readonly SyncRef<IDataFeedView> View;

		public readonly SyncFieldList<string> CategoryPath;

		public readonly RawOutput<bool> IsInsideCategoryPath;

		private IDataFeedView _registeredEvents;

		private void Unregister()
		{
			if (_registeredEvents != null)
			{
				_registeredEvents.PathCategoryChanged -= OnPathCategoryChanged;
			}
		}

		private void OnPathCategoryChanged(IReadOnlyList<string> path)
		{
			RunInUpdateScope(delegate
			{
				IsInsideCategoryPath.Value = MatchesPath(path);
			});
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (_registeredEvents != View.Target)
			{
				Unregister();
				_registeredEvents = View.Target;
				if (_registeredEvents != null)
				{
					_registeredEvents.PathCategoryChanged += OnPathCategoryChanged;
					IsInsideCategoryPath.Value = MatchesPath(_registeredEvents.Path);
				}
			}
		}

		private bool MatchesPath(IReadOnlyList<string> path)
		{
			if (path.Count < CategoryPath.Count)
			{
				return false;
			}
			for (int i = 0; i < CategoryPath.Count; i++)
			{
				if (path[i] != CategoryPath[i])
				{
					return false;
				}
			}
			return true;
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			Unregister();
		}

