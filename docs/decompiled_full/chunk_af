		}

		public void UpdatePlacedSize(FacetContainer targetContainer, NestedCanvas nestedCanvas)
		{
			RectTransform rectTransform = nestedCanvas.RectTransform;
			Slot slot = rectTransform.Canvas.Slot;
			Elements.Core.Rect rect = Elements.Core.Rect.FromMinMax((Elements.Core.float2)rectTransform.OffsetMin, (Elements.Core.float2)rectTransform.OffsetMax);
			Canvas.Target.Size.Value = rect.size;
			Canvas.Target.Slot.LocalScale = slot.LocalScale;
			LastPlacedSize.Value = rect.size;
			Elements.Core.Rect currentGlobalRect = targetContainer.CurrentGlobalRect;
			Elements.Core.float2 v = currentGlobalRect.position + rect.position + rect.size * 0.5f;
			base.Slot.GlobalPosition = slot.LocalPointToGlobal((Elements.Core.float3)v);
			base.Slot.GlobalRotation = slot.GlobalRotation;
