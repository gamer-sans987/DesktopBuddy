	[Category(new string[] { "Radiant UI/Data Feeds/Views" })]
	public class RootCategoryView : DataFeedViewBase, ICustomInspector, IWorker, IWorldElement
	{
		public readonly DataFeedItemMappingManager CategoryManager;

		public readonly DataFeedItemMappingManager ItemsManager;

		private object _rootFeedData;

		private IDataFeedComponent _registeredFeed;

		private string _registeredSearchPhrase;

		private DataFeedCategory _firstCategory;

		public override bool ShouldUpdate
		{
			get
			{
				if (CategoryManager.IsValid)
				{
					return ItemsManager.IsValid;
				}
				return false;
			}
		}

		public static bool IsRootItem(DataFeedItem item)
		{
			if (item is DataFeedCategory)
			{
				return item.IsRootItem;
			}
			return false;
		}

		private void OnRootCategoryUpdated(DataFeedItem item, DataFeedItemChange change)
		{
			RunSynchronously(delegate
			{
				switch (change)
				{
				case DataFeedItemChange.Added:
					FeedItemAdded(item);
					break;
				case DataFeedItemChange.Updated:
					FeedItemUpdated(item);
					break;
				case DataFeedItemChange.Removed:
					FeedItemRemoved(item);
					break;
				case DataFeedItemChange.PathSortingInvalidated:
					CategoryManager.SortItems();
					break;
				case DataFeedItemChange.PathItemsInvalidated:
					Path.Clear();
					ForceRegenerate();
					break;
				}
			});
		}

		protected override void OnFeedChanged(IDataFeedComponent previous, IDataFeedComponent next, string search)
		{
			previous?.UnregisterListener(null, null, _registeredSearchPhrase, OnRootCategoryUpdated);
			previous?.UnregisterViewData(_rootFeedData);
			_rootFeedData = next?.RegisterViewData();
			_registeredSearchPhrase = search;
			_registeredFeed = next;
			next?.ListenToUpdates(null, null, search, OnRootCategoryUpdated, _rootFeedData);
		}

		protected override void OnSearchPhraseChanged(string previous, string next)
		{
			if (!(next == _registeredSearchPhrase))
			{
				_registeredFeed?.UnregisterListener(null, null, _registeredSearchPhrase, OnRootCategoryUpdated);
				_registeredFeed?.ListenToUpdates(null, null, next, OnRootCategoryUpdated, _rootFeedData);
				_registeredSearchPhrase = next;
			}
		}

		protected override void OnFeedGenerationStarted(IDataFeedComponent feed, IReadOnlyList<string> path, IReadOnlyList<string> groupingKeys, string search, bool feedWasReset, ref object feedData, ref bool registerEvents)
		{
			bool num = feedWasReset || path.Count == 0 || !string.IsNullOrWhiteSpace(search);
			if (path.Count == 0)
			{
				feedData = _rootFeedData;
				registerEvents = false;
			}
			if (num)
			{
				CategoryManager.BeginNewGeneration();
			}
			ItemsManager.BeginNewGeneration();
		}

		protected override void FeedItemAdded(DataFeedItem item)
		{
			if (IsRootItem(item))
			{
				if (item is DataFeedCategory dataFeedCategory && (_firstCategory == null || _firstCategory.SortingOrder > dataFeedCategory.SortingOrder))
				{
					_firstCategory = item as DataFeedCategory;
				}
				CategoryManager.AddItem(item);
			}
			else
			{
				ItemsManager.AddItem(item);
			}
		}

		protected override void FeedItemRemoved(DataFeedItem item)
		{
			if (IsRootItem(item))
			{
				CategoryManager.RemoveItem(item);
			}
			else
			{
				ItemsManager.RemoveItem(item);
			}
		}

		protected override void FeedItemUpdated(DataFeedItem item)
		{
			if (IsRootItem(item))
			{
				CategoryManager.UpdateItem(item);
			}
			else
			{
				ItemsManager.UpdateItem(item);
			}
		}

		protected override void OnFeedGenerationFinished()
		{
			if (Path.Count == 0 && _firstCategory != null)
			{
				Path.Add(_firstCategory.ItemKey);
			}
			else
			{
				SortItems();
			}
			_firstCategory = null;
		}

