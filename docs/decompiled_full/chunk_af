			foreach (KeyValuePair<string, SessionItem> sessionItem in _sessionItems)
			{
				hashSet.Add(sessionItem.Key);
			}
			int num = 0;
			foreach (SessionSelectionItem sessionSelection in _sessionSelectionList)
			{
				hashSet.Remove(sessionSelection.NormalizedSessionId);
				string normalizedSessionId = sessionSelection.NormalizedSessionId;
				if (!_sessionItems.TryGetValue(normalizedSessionId, out SessionItem value))
				{
					value = GenerateSessionItem(normalizedSessionId);
