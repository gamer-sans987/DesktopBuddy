		protected abstract void OnFeedChanged(IDataFeedComponent previous, IDataFeedComponent next, string search);

		protected abstract void OnFeedGenerationStarted(IDataFeedComponent feed, IReadOnlyList<string> path, IReadOnlyList<string> groupingKeys, string search, bool feedWasReset, ref object feedData, ref bool registerEvents);

		protected abstract void FeedItemAdded(DataFeedItem item);

