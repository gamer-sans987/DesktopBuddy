	{
		public readonly SyncRef<TTemplate> Template;

		public readonly SyncRef<Slot> Root;

		public readonly Sync<int> MaxItems;

		public readonly Sync<int> Offset;

		private bool _isDirty;

		private IList<TItem> _lastItems;

		private IDataFeedView _lastView;

		private List<TTemplate> _currentItems;

		protected override void OnAwake()
		{
			base.OnAwake();
			MaxItems.Value = int.MaxValue;
			Root.OnTargetChange += Root_OnTargetChange;
			MaxItems.OnValueChange += MaxItems_OnValueChange;
			Offset.OnValueChange += Offset_OnValueChange;
		}

		public void Set(IList<TItem> items, IDataFeedView view)
		{
			_lastItems = items;
			_lastView = view;
			if (Template.Target == null || Root.Target == null)
			{
				return;
			}
			int num = items?.Count ?? 0;
			int val = MathX.Max(num - Offset.Value, 0);
			val = MathX.Min(val, MaxItems);
			if (_currentItems == null)
			{
				_currentItems = new List<TTemplate>();
			}
			_currentItems.RemoveAll((TTemplate t) => t.IsDestroyed);
			while (_currentItems.Count > val)
			{
				_currentItems[_currentItems.Count - 1].Slot.Destroy();
				_currentItems.RemoveAt(_currentItems.Count - 1);
			}
			for (int num2 = 0; num2 < val; num2++)
			{
				TItem item = null;
				int num3 = num2 + (int)Offset;
				if (num3 >= 0 && num3 < num)
				{
					item = items[num3];
				}
				if (_currentItems.Count == num2)
				{
					FeedItemInterface.InstanceResult instanceResult = Template.Target.Instantiate(Root, _lastView, item, null);
					_currentItems.Add((TTemplate)instanceResult.primaryItem);
				}
				else
				{
					_currentItems[num2].Update(_lastView, item);
				}
			}
			_isDirty = false;
		}

		private void MarkItemsDirty()
		{
			if (_isDirty)
			{
				return;
			}
			this.FindNearestParent<Component>().RunSynchronously(delegate
			{
				if (_isDirty)
				{
					Set(_lastItems, _lastView);
				}
			});
			_isDirty = true;
		}

		private void Root_OnTargetChange(SyncRef<Slot> reference)
		{
			MarkItemsDirty();
		}

		private void Offset_OnValueChange(SyncField<int> syncField)
		{
			MarkItemsDirty();
		}

		private void MaxItems_OnValueChange(SyncField<int> syncField)
		{
			MarkItemsDirty();
		}

