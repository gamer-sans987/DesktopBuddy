	public abstract class TemplateFacetPreset : FacetPreset
	{
		protected readonly Sync<bool> _fullyLoaded;

		protected abstract string TemplateName { get; }

		protected override Elements.Core.float2 DefaultSize => Elements.Core.float2.One * 32;

		protected override Elements.Core.float2 MinSize => Elements.Core.float2.Zero;

		protected override Elements.Core.float2 MaxSize => Elements.Core.float2.MaxValue;

		protected virtual int? TemplateSwitchVersion => null;

		protected virtual float TemplateSwitchCanvasMultiplier => 1f;

		protected override bool ForceUpgrade => !_fullyLoaded.Value;

		protected override void Build(Facet facet, Slot root, int? oldVersion)
		{
			_fullyLoaded.Value = false;
			StartTask(async delegate
			{
				Slot facetRoot = facet.Slot;
				List<Component> existingComponents = facetRoot.Components.Where((Component c) => c != this).ToList();
				List<Slot> existingChildren = facetRoot.Children.ToList();
				string[] obj = new string[6] { "Loading facet template: ", TemplateName, ", OldVersion: ", null, null, null };
				int? num = oldVersion;
				obj[3] = num.ToString();
				obj[4] = ", CurrentUserId: ";
				obj[5] = base.Cloud.CurrentUserID;
				UniLog.Log(string.Concat(obj));
				await facetRoot.LoadObjectAsync(base.Cloud.Platform.GetInventoryItemUri("Facets/Templates/" + TemplateName), null, null, preserveRootTransform: true, skipHolder: true, (Type t) => t != GetType());
				Facet component = facetRoot.GetComponent((Facet f) => f != facet);
				if (component == null)
				{
					await BuildFallback(facet, root, oldVersion);
				}
				else
				{
					facet.ReplacementFacet = component;
					component.LastPlacedSize.Value = facet.LastPlacedSize.Value;
					component.IsStandalone.Value = facet.IsStandalone.Value;
					Canvas target = component.Canvas.Target;
					Canvas target2 = facet.Canvas.Target;
					target.Slot.CopyTransform(target2.Slot);
					target.Size.Value = target2.Size.Value;
					target.BlockAllInteractions.Value = target2.BlockAllInteractions.Value;
					target.Collider.Target.Enabled = target2.Collider.Target.Enabled;
					if (oldVersion < TemplateSwitchVersion && TemplateSwitchCanvasMultiplier != 1f)
					{
						GrabValueSet<float> grabValueSet = target.Slot.AttachComponent<GrabValueSet<float>>();
						grabValueSet.Target.Target = target.UnitScale;
						grabValueSet.GrabbedValue.Value = target.UnitScale.Value;
						target.UnitScale.Value *= TemplateSwitchCanvasMultiplier;
					}
					base.World.ReplaceReferenceTargets(facet, component, nullIfIncompatible: false);
					base.World.ReplaceReferenceTargets(target2, target, nullIfIncompatible: false);
					foreach (Slot item in existingChildren)
					{
						item.Destroy();
					}
					foreach (Component item2 in existingComponents)
					{
						item2.Destroy();
					}
					await OnLoaded(target.Slot);
					_fullyLoaded.Value = true;
					UniLog.Log("Facet template fully loaded: " + TemplateName);
					this.NotifyModified();
				}
			});
		}

		protected virtual Task OnLoaded(Slot root)
		{
			return Task.CompletedTask;
		}

		protected virtual Task BuildFallback(Facet facet, Slot root, int? oldVersion)
		{
			UniLog.Warning("Failed to load facet from template, Facet component not found. TemplateName: " + TemplateName);
			return Task.CompletedTask;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			_fullyLoaded = new Sync<bool>();
		}
	}
