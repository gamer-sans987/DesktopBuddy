	/// <summary>
	/// Used to create Cursors that are appropriate for the engine based on a user's settings.
	/// </summary>
	/// <remarks>
	/// Does not determine how/where/why icons for cursors are sourced, you can find a default implementation here: <see cref="T:FrooxEngine.DefaultInteractionCursorFactory" />.
	/// </remarks>
	public abstract class BaseInteractionCursorFactory : IDisposable, IInteractionCursorFactory
	{
		public const float DEFAULT_CURSOR_MULTIPLIER = 1f;

		/// <summary>
		/// Used in <see cref="M:FrooxEngine.BaseInteractionCursorFactory.Pointer(Elements.Core.colorX)" />, as this type of Cursor is used on the dash which has a different UI Scale
		/// </summary>
		public const float POINTER_MULTIPLIER = 0.9f;

		protected CursorSettings? CursorSettings;

		public bool IsDirectCursorEnabled
		{
			get
			{
				Sync<bool> sync = CursorSettings?.DirectCursorEnabled;
				if (sync == null)
				{
					return true;
				}
				return sync;
			}
		}

		public event SettingUpdateHandler<CursorSettings>? SettingsChanged;

		public BaseInteractionCursorFactory()
		{
		}

		public InteractionCursor Default(float multiplier = 1f, Elements.Core.colorX? color = null)
		{
			color = color ?? Elements.Core.colorX.White;
			return new InteractionCursor(GetCursorUri(InteractionCursorType.Default), GetSize(multiplier), color);
		}

		public InteractionCursor Pointer(Elements.Core.colorX color)
		{
			return new InteractionCursor(GetCursorUri(InteractionCursorType.Default), GetSize(0.9f), color);
		}

		public InteractionCursor Text()
		{
			InteractionCursorType type = InteractionCursorType.Text;
			return new InteractionCursor(GetCursorUri(type), GetSize(GetMultiplier(type)));
		}

		public InteractionCursor Custom(Uri uri, float multiplier = 1f)
		{
			return new InteractionCursor(uri, GetSize(multiplier));
		}

		public InteractionCursor Grab(bool isGrabbing)
		{
			InteractionCursorType type = InteractionCursorType.Grab;
			return new InteractionCursor(GetGrabIconUri(isGrabbing), GetSize(GetMultiplier(type, isGrabbing)));
		}

		public InteractionCursor Slide(InteractionDirection orientation)
		{
			return new InteractionCursor(GetSliderCursorUri(orientation), GetSize(GetMultiplier(InteractionCursorType.Slide)));
		}

		public InteractionCursor Interact()
		{
			InteractionCursorType type = InteractionCursorType.Interact;
			return new InteractionCursor(GetCursorUri(type), GetSize(GetMultiplier(type)));
		}

		private float GetSize(float multiplier = 1f)
		{
			float num = MathX.Clamp(CursorSettings?.BaseCursorSize.Value ?? 0.022f, 0.01f, 0.2f);
			if (multiplier != 0f)
			{
				num *= multiplier;
			}
			return num;
		}

		private float GetMultiplier(InteractionCursorType type, bool active = false)
		{
			return GetMultiplier(type, active, CursorSettings);
		}

		/// <summary>
		/// Returns an appropriate multiplier for an interaction type.
		/// </summary>
		/// <param name="active">Is this interaction active? Examples of active are: Button Held, Grabbing etc. Inactive would be "hover"</param>
		private static float GetMultiplier(InteractionCursorType type, bool active, CursorSettings? settings)
		{
			if (settings == null)
			{
				return 1f;
			}
			return type switch
			{
				InteractionCursorType.Grab => active ? 1f : settings.GrabMultiplier.Value, 
				InteractionCursorType.Text => settings.TextMultiplier.Value, 
				InteractionCursorType.Interact => settings.InteractionMultiplier.Value, 
				InteractionCursorType.Slide => settings.SliderMultiplier.Value, 
				_ => 1f, 
			};
		}

		protected abstract Uri GetGrabIconUri(bool isGrabbing);

		protected abstract Uri GetSliderCursorUri(InteractionDirection? interactionDirection = null);

		protected abstract Uri GetCursorUri(InteractionCursorType type);

		public void Dispose()
		{
			UnregisterSettingsListener();
			GC.SuppressFinalize(this);
		}

		private void OnCursorSettingsChanged(CursorSettings setting)
		{
			CursorSettings = setting;
			this.SettingsChanged?.Invoke(setting);
		}

		public void RegisterSettingsListener()
		{
			CursorSettings = Settings.GetActiveSetting<CursorSettings>();
			Settings.RegisterValueChanges<CursorSettings>(OnCursorSettingsChanged);
		}

		public void UnregisterSettingsListener()
		{
			Settings.UnregisterValueChanges<CursorSettings>(OnCursorSettingsChanged);
		}
	}
