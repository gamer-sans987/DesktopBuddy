		public bool MatchesSearchParameters(List<string> optionalTerms, List<string> requiredTerms, List<string> excludedTerms)
		{
			foreach (string excludedTerm in excludedTerms)
			{
				if (MatchesTerm(excludedTerm))
				{
					return false;
				}
			}
			foreach (string requiredTerm in requiredTerms)
			{
				if (!MatchesTerm(requiredTerm))
				{
					return false;
				}
			}
			if (requiredTerms.Count > 0)
			{
				return true;
			}
			if (optionalTerms.Count == 0)
			{
				return true;
			}
			foreach (string optionalTerm in optionalTerms)
			{
				if (MatchesTerm(optionalTerm))
				{
					return true;
				}
			}
			return false;
		}

		public bool MatchesTerm(string term)
		{
			if (record != null)
			{
				if (ContainsTerm(record.Name, term))
				{
					return true;
				}
				if (ContainsTerm(record.Description, term))
				{
					return true;
				}
				if (record.Tags != null && record.Tags.Any((string t) => ContainsTerm(t, term)))
				{
					return true;
				}
			}
			foreach (SessionInfo session in sessions)
			{
				if (ContainsTerm(session.Name, term))
				{
					return true;
				}
				if (ContainsTerm(session.Description, term))
				{
					return true;
				}
				if (session.Tags != null && session.Tags.Any((string t) => ContainsTerm(t, term)))
				{
					return true;
				}
			}
			foreach (World world in worlds)
			{
				if (ContainsTerm(world.Name, term))
				{
					return true;
				}
				if (ContainsTerm(world.Description, term))
				{
					return true;
				}
				if (world.Tags.Any((string t) => ContainsTerm(t, term)))
				{
					return true;
				}
			}
			return false;
		}

		private static bool ContainsTerm(string str, string term)
		{
			if (string.IsNullOrEmpty(str))
			{
				return false;
			}
			return str.IndexOf(term, StringComparison.OrdinalIgnoreCase) >= 0;
		}

		public override string ToString()
		{
			return $"Name: {MainName}, UniqueId: {UniqueId}, Record: {HasRecord}, Sessions: {sessions.Count}, Worlds: {worlds.Count}";
		}
