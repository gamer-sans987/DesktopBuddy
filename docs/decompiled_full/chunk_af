		private Facet GetHeldFacet(TouchSource source)
		{
			InteractionHandler interactionHandler = source.Slot.FindInteractionHandler();
			if (interactionHandler == null)
			{
				return null;
			}
			foreach (Slot child in interactionHandler.Grabber.HolderSlot.Children)
			{
				Facet component = child.GetComponent<Facet>();
				if (component != null)
				{
					return component;
				}
			}
			return null;
		}

		public bool ProcessEvent(Canvas.InteractionData eventData)
		{
			if (FacetsRoot.Target == null)
			{
				ClearVisualization();
				return false;
			}
			if (!EditMode.Value)
			{
				ClearVisualization();
				return false;
			}
			Facet facet = GetHeldFacet(eventData.source);
			Facet lastFacet = _lastFacet;
			if (lastFacet != null && lastFacet.IsDestroyed)
			{
				_lastFacet = null;
			}
			if (_lastFacet != null && facet != null && _lastFacet != facet)
			{
				return false;
			}
			bool flag = false;
			if (facet == null && _lastSource == eventData.source && _lastFacet != null)
			{
				flag = true;
				facet = _lastFacet;
			}
			Elements.Core.float2 a = GetLocalPoint(eventData);
			if (facet == null)
			{
				UpdateVisualization(GetCursorRect(a), Elements.Core.colorX.Yellow, isCursor: true);
				PlacedFacet facetAtPoint = GetFacetAtPoint(a);
				if (facetAtPoint.facet != null && eventData.hover != EventState.End)
				{
					Elements.Core.Rect rect = Elements.Core.Rect.FromMinMax((Elements.Core.float2)facetAtPoint.nestedCanvas.RectTransform.OffsetMin, (Elements.Core.float2)facetAtPoint.nestedCanvas.RectTransform.OffsetMax);
					UpdateVisualization(rect, Elements.Core.colorX.Cyan, isCursor: false);
				}
				else
				{
					ClearVisualization(eventData.hover != EventState.End);
				}
				return true;
			}
			_lastFacet = facet;
			_lastSource = eventData.source;
			bool flag2 = false;
			if (eventData.touch != EventState.None)
			{
				bool flag3 = false;
				flag3 = ((!AllowCustomSizing) ? (eventData.touch == EventState.Begin) : (eventData.touch == EventState.End && eventData.hover != EventState.End));
				Elements.Core.float2? forceSize = null;
				if (AllowCustomSizing)
				{
					if (eventData.touch == EventState.Begin || !_dragOriginalPoint.HasValue)
					{
						_dragOriginalPoint = a;
					}
					else
					{
						Elements.Core.float2 b = _dragOriginalPoint.Value;
						Elements.Core.float2 value = a - b;
						if (value.Magnitude >= CustomSizingThreshold)
						{
							UpdateVisualization(GetCursorRect(a), Elements.Core.colorX.Yellow, isCursor: true);
							a = b;
							forceSize = value;
							PreviewFacetPlacement(facet, a, eventData, forceSize);
						}
					}
				}
				if (flag3)
				{
					flag2 = true;
					_dragOriginalPoint = null;
					EndFacetPlacementPreview(facet);
					PlaceFacet(facet, a, eventData, forceSize);
					this.NotifyModified();
				}
				else if (eventData.touch == EventState.End)
				{
					EndFacetPlacementPreview(facet);
				}
			}
			else if (eventData.hover == EventState.End || flag)
			{
				flag2 = true;
				EndFacetPlacementPreview(facet);
			}
			else
			{
				UpdateVisualization(GetCursorRect(a), Elements.Core.colorX.Yellow, isCursor: true);
				PreviewFacetPlacement(facet, a, eventData);
			}
			if (flag2)
			{
				_lastFacet = null;
				_lastSource = null;
			}
			return true;
		}

