						if (num4 > num)
						{
							num = num4;
							@float = float2;
						}
					}
				}
				offeredSize = @float;
			}
			return offeredSize;
		}

		public void Place(FacetContainer targetContainer, NestedCanvas nestedCanvas)
		{
			if (ReplacementFacet != null)
			{
				ReplacementFacet.Place(targetContainer, nestedCanvas);
				return;
			}
			IGrabbable component = base.Slot.GetComponent<IGrabbable>();
			if (component != null)
			{
				if (component.IsGrabbed)
				{
					component.Release(component.Grabber);
				}
				component.Enabled = false;
			}
			base.Slot.SetParent(targetContainer.FacetsRoot, keepGlobalTransform: false);
			base.Slot.LocalScale = Elements.Core.float3.One;
			UpdatePlacedSize(targetContainer, nestedCanvas);
			nestedCanvas.TargetCanvas.Target = Canvas;
			SetPlaced(placed: true);
			base.Slot.ForeachComponentInChildren(delegate(IFacetEventReceiver e)
			{
				e.OnFacetPlaced(this);
