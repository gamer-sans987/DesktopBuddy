		protected override void OnChanges()
		{
			base.OnChanges();
			if (!FilterPropertiesChanged)
			{
				return;
			}
			foreach (SyncElement filterProperty in FilterProperties)
			{
				filterProperty.WasChanged = false;
			}
			if ((bool)ListOpenedWorlds != _openWorldEventsRegistered)
			{
				if ((bool)ListOpenedWorlds)
				{
					base.World.WorldManager.WorldAdded += WorldManager_WorldAdded;
					base.World.WorldManager.WorldRemoved += WorldManager_WorldRemoved;
					base.World.WorldManager.WorldsChanged += WorldManager_WorldsChanged;
					_openWorldEventsRegistered = true;
				}
				else
				{
					UnregisterOpenedWorldEvents();
				}
			}
			if (((bool)ListSessions || ((bool)ListOpenedWorlds && (bool)MergeBySessionId)) != _sessionEventsRegistered)
			{
				if ((bool)ListSessions)
				{
					base.Cloud.Sessions.SessionAdded += Sessions_SessionAdded;
					base.Cloud.Sessions.SessionRemoved += Sessions_SessionRemoved;
					base.Cloud.Sessions.SessionUpdated += Sessions_SessionUpdated;
					_sessionEventsRegistered = true;
				}
				else
				{
					UnregisterSessionEvents();
				}
			}
			foreach (KeyValuePair<SearchPhraseFeedUpdateHandler, WorldsDataFeedData> updateHandler in _updateHandlers)
			{
				updateHandler.Key.handler(null, DataFeedItemChange.PathItemsInvalidated);
			}
		}

		private void ProcessUpdate(SearchPhraseFeedUpdateHandler handler, MergedWorldDataResult result)
		{
			if (result.change == DataFeedItemChange.Unchanged)
			{
				return;
			}
			result.data.ComputeAggregateData(base.Engine);
			bool flag = Filter(result.data);
			if (flag && !string.IsNullOrEmpty(handler.searchPhrase))
			{
				List<string> list = Pool.BorrowList<string>();
				List<string> list2 = Pool.BorrowList<string>();
				List<string> list3 = Pool.BorrowList<string>();
				SearchQueryParser.Parse(handler.searchPhrase, list, list2, list3);
				if (!result.data.MatchesSearchParameters(list, list2, list3))
				{
					flag = false;
				}
				Pool.Return(ref list);
				Pool.Return(ref list2);
				Pool.Return(ref list3);
			}
			if (!flag)
			{
				if (result.data.Submitted)
				{
					result.data.ClearSubmitted();
					handler.handler(ToItem(result.data), DataFeedItemChange.Removed);
				}
				return;
			}
			DataFeedItemChange dataFeedItemChange = result.change;
			if (dataFeedItemChange == DataFeedItemChange.Added)
			{
				result.data.MarkSubmitted();
			}
			if (dataFeedItemChange == DataFeedItemChange.Updated && !result.data.Submitted)
			{
				dataFeedItemChange = DataFeedItemChange.Added;
				result.data.MarkSubmitted();
			}
			DataFeedItem item = ToItem(result.data);
			handler.handler(item, dataFeedItemChange);
		}

		private void Sessions_SessionUpdated(SessionInfo info)
