			{
				Elements.Core.float2 currentSize = facet.CurrentSize;
				facet.Canvas.Target.Slot.DestroyChildren();
				SetupFacetData(currentSize);
			}
			else
			{
				facet = base.Slot.AttachComponent<Facet>();
