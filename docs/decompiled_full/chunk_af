		/// <summary>
		/// Creates an Item within the filter preset, which includes a HiddenSearchTerm.
		/// </summary>
		/// <param name="ui">Builder for the current set of filters in the facet.</param>
		/// <param name="presetName">Name of the preset, also used as a Locale Key.</param>
		/// <param name="presetIcon">Icon for the preset, displayed to the left of the name in game.</param>
		/// <param name="hiddenSearch">Hidden search term for this button</param>
		/// <param name="presetRoots">List of preset roots to apply when this option is pressed.</param>
		/// <returns>A created preset button</returns>
		private DataPreset AddHiddenSearchButton(UIBuilder ui, string presetName, Uri presetIcon, string hiddenSearch, params Slot[] presetRoots)
		{
			DataPreset dataPreset = AddPresetButton(ui, presetName, presetIcon, presetRoots);
			dataPreset.Entries.Add(CreatePresetValue(dataPreset.Slot, "Worlds.HiddenSearchTerm", hiddenSearch));
			return dataPreset;
		}

		/// <summary>
		/// Creates a preset button in the World Filter Facet.
		/// </summary>
		/// <param name="ui">Builder for the current set of filters in the facet.</param>
		/// <param name="presetName">Name of the preset, also used as a Locale Key.</param>
		/// <param name="presetIcon">Icon for the preset, displayed to the left of the name in game.</param>
		/// <param name="presetRoots">List of preset roots to apply when this option is pressed.</param>
		/// <returns></returns>
		private DataPreset AddPresetButton(UIBuilder ui, string presetName, Uri presetIcon, params Slot[] presetRoots)
		{
			Button button = ui.Button(presetIcon, presetName.AsLocaleKey());
			button.Label.AutoSizeMax.Value *= 0.8f;
			button.Label.HorizontalAlign.Value = TextHorizontalAlignment.Left;
			button.Slot.Name = "Button - " + presetName;
			button.ConvertTintToAdditive();
			DataPreset dataPreset = ui.Current.AttachComponent<DataPreset>();
			for (int i = 0; i < presetRoots.Length; i++)
			{
				foreach (IDataPresetEntry component in presetRoots[i].GetComponents<IDataPresetEntry>())
				{
					dataPreset.Entries.Add(component);
				}
			}
			ValueOptionDescriptionDriver<bool> valueOptionDescriptionDriver = button.EnsureOptionDescriptionDriver(dataPreset.IsActive, setupLabel: false);
			ValueOptionDescriptionDriver<bool>.Option defaultOption = valueOptionDescriptionDriver.DefaultOption;
			Elements.Core.colorX? buttonColor = RadiantUI_Constants.TAB_INACTIVE_BACKGROUND_COLOR;
			defaultOption.SetupFrom(new OptionDescription<bool>(reference: false, default(LocaleString), buttonColor));
			ValueOptionDescriptionDriver<bool>.Option option = valueOptionDescriptionDriver.Options.Add();
			buttonColor = RadiantUI_Constants.TAB_ACTIVE_BACKGROUND_COLOR;
			option.SetupFrom(new OptionDescription<bool>(reference: true, default(LocaleString), buttonColor));
			return dataPreset;
		}

		private DataPresetValue<T> CreatePresetValue<T>(Slot slot, string variable, T value)
		{
			DataPresetValue<T> dataPresetValue = slot.AttachComponent<DataPresetValue<T>>();
			DynamicValueVariable<T> dynamicValueVariable = slot.AttachComponent<DynamicValueVariable<T>>();
			dynamicValueVariable.VariableName.Value = variable;
			dataPresetValue.TargetField.Target = dynamicValueVariable.Value;
			dataPresetValue.PresetValue.Value = value;
			return dataPresetValue;
		}

