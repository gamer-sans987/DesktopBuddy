	internal delegate MergedWorldData MergedWorldDataSplitter(MergedWorldData existingEntry, out bool createdNewEntry);
	internal class WorldsDataFeedData
	{
		private List<MergedWorldData> _data = new List<MergedWorldData>();

		private Dictionary<string, MergedWorldData> _dataByUniqueId = new Dictionary<string, MergedWorldData>();

		private Dictionary<string, MergedWorldData> _dataBySessionId = new Dictionary<string, MergedWorldData>();

		private Dictionary<World, MergedWorldData> _dataByWorld = new Dictionary<World, MergedWorldData>();

		public bool MergeByWorldId { get; private set; }

		public bool MergedBySessionId { get; private set; }

		public IEnumerable<MergedWorldData> WorldData => _data;

		public void Clear(bool mergeByWorldId, bool mergeBySessionId)
		{
			_data.Clear();
			_dataByUniqueId.Clear();
			_dataBySessionId.Clear();
			_dataByWorld.Clear();
			MergeByWorldId = mergeByWorldId;
			MergedBySessionId = mergeBySessionId;
		}

		private MergedWorldData RegisterPublished(SkyFrost.Base.Record record)
		{
			bool created;
			MergedWorldData mergedWorldData = EnsureEntry(record.CombinedRecordId.ToString(), out created);
			if (mergedWorldData.record != null)
			{
				throw new InvalidOperationException("Record with this RecordId has already been added!");
			}
			mergedWorldData.record = record;
			return mergedWorldData;
		}

		private MergedWorldData RegisterSession(SessionInfo info, out bool createdEntry)
		{
			MergedWorldData mergedWorldData = EnsureEntry(GetUniqueId(info), out createdEntry);
			mergedWorldData.AddSession(info);
			_dataBySessionId[info.SessionId] = mergedWorldData;
			return mergedWorldData;
		}

		public MergedWorldDataResult AddSession(SessionInfo info)
		{
			bool createdEntry;
			return new MergedWorldDataResult(RegisterSession(info, out createdEntry), (!createdEntry) ? DataFeedItemChange.Updated : DataFeedItemChange.Added);
		}

		public MergedWorldDataResult AddOpenWorld(World world)
		{
			bool createdNewEntry;
			return new MergedWorldDataResult(RegisterOpenWorld(world, out createdNewEntry), (!createdNewEntry) ? DataFeedItemChange.Updated : DataFeedItemChange.Added);
		}

		public IEnumerable<MergedWorldDataResult> UpdateSession(SessionInfo info)
		{
			if (!_dataBySessionId.TryGetValue(info.SessionId, out MergedWorldData value))
			{
				return new SingleItemEnumerable<MergedWorldDataResult>(AddSession(info));
			}
			string uniqueId = GetUniqueId(info);
			return UpdateEntry(value, uniqueId, delegate(MergedWorldData d)
			{
				d.UpdateSession(info);
			}, delegate(MergedWorldData oldEntry, out bool createdNew)
			{
				MergedWorldData result = RegisterSession(info, out createdNew);
				oldEntry.RemoveSession(info);
				return result;
			});
		}

		public IEnumerable<MergedWorldDataResult> UpdateWorld(World world)
		{
			if (!_dataByWorld.TryGetValue(world, out MergedWorldData value))
			{
				return new SingleItemEnumerable<MergedWorldDataResult>(AddOpenWorld(world));
			}
			string uniqueId = GetUniqueId(world);
			return UpdateEntry(value, uniqueId, delegate
			{
			}, delegate(MergedWorldData oldEntry, out bool createdNew)
			{
				MergedWorldData result = RegisterOpenWorld(world, out createdNew);
				oldEntry.RemoveWorld(world);
				return result;
			});
		}

		public MergedWorldDataResult RemoveSession(SessionInfo session)
		{
			if (!_dataBySessionId.TryGetValue(session.SessionId, out MergedWorldData value))
			{
				return new MergedWorldDataResult(null, DataFeedItemChange.Unchanged);
			}
			_dataBySessionId.Remove(session.SessionId);
			value.RemoveSession(session);
			if (value.IsEmpty)
			{
				RemoveEntry(value);
			}
			return new MergedWorldDataResult(value, (!value.IsEmpty) ? DataFeedItemChange.Updated : DataFeedItemChange.Removed);
		}

		public MergedWorldDataResult RemoveOpenWorld(World world, bool removeSessions)
		{
			if (!_dataByWorld.TryGetValue(world, out MergedWorldData value))
			{
				return new MergedWorldDataResult(null, DataFeedItemChange.Unchanged);
			}
			_dataByWorld.Remove(world);
			value.RemoveWorld(world);
			if (removeSessions)
			{
				value.sessions.Clear();
			}
			if (value.IsEmpty)
			{
				RemoveEntry(value);
			}
			return new MergedWorldDataResult(value, (!value.IsEmpty) ? DataFeedItemChange.Updated : DataFeedItemChange.Removed);
		}

		private IEnumerable<MergedWorldDataResult> UpdateEntry(MergedWorldData data, string newUniqueId, Action<MergedWorldData> updateExisting, MergedWorldDataSplitter split)
		{
			if (newUniqueId == data.UniqueId)
			{
				updateExisting(data);
				yield return new MergedWorldDataResult(data, DataFeedItemChange.Updated);
				yield break;
			}
			bool createdNewEntry;
			MergedWorldData data2 = split(data, out createdNewEntry);
			yield return new MergedWorldDataResult(data2, (!createdNewEntry) ? DataFeedItemChange.Updated : DataFeedItemChange.Added);
			if (data.IsEmpty)
			{
				RemoveEntry(data);
				yield return new MergedWorldDataResult(data, DataFeedItemChange.Removed);
			}
			else
			{
				yield return new MergedWorldDataResult(data, DataFeedItemChange.Updated);
			}
		}

		private void RemoveEntry(MergedWorldData data)
		{
			_data.Remove(data);
			_dataByUniqueId.Remove(data.UniqueId);
		}

		private MergedWorldData RegisterOpenWorld(World world, out bool createdNewEntry)
		{
			MergedWorldData mergedWorldData = EnsureEntry(GetUniqueId(world), out createdNewEntry);
			mergedWorldData.AddWorld(world);
			_dataByWorld[world] = mergedWorldData;
			return mergedWorldData;
		}

		private string GetUniqueId(SessionInfo session)
		{
			if (MergeByWorldId)
			{
				string text = session.ActualCorrespondingWorldId?.ToString();
				if (!string.IsNullOrEmpty(text))
				{
					return text;
				}
			}
			return session.SessionId;
		}

		private string GetUniqueId(World world)
		{
			if (MergeByWorldId)
			{
				string correspondingWorldId = world.CorrespondingWorldId;
				if (!string.IsNullOrEmpty(correspondingWorldId))
				{
					return correspondingWorldId;
				}
			}
			if (MergedBySessionId)
			{
				string sessionId = world.SessionId;
				if (!string.IsNullOrEmpty(sessionId))
				{
					return sessionId;
				}
			}
			return $"World-{world.LocalWorldHandle:X}";
		}

		private MergedWorldData EnsureEntry(string uniqueId, out bool created)
		{
			if (_dataByUniqueId.TryGetValue(uniqueId, out MergedWorldData value))
			{
				created = false;
				return value;
			}
			value = new MergedWorldData(uniqueId);
			_data.Add(value);
			_dataByUniqueId.Add(uniqueId, value);
			created = true;
			return value;
		}
	}
