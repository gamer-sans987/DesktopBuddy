		protected override void OnChanges()
		{
			base.OnChanges();
			if (!DisplayOrder.WasChanged && !Distinct.WasChanged && !IncludeObsolete.WasChanged)
			{
				return;
			}
			DisplayOrder.WasChanged = false;
			Distinct.WasChanged = false;
			IncludeObsolete.WasChanged = false;
			foreach (DataFeedUpdateHandler updateHandler in _updateHandlers)
