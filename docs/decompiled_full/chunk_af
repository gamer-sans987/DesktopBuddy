		private void BuildMiniSetting<T, S>(UIBuilder ui, LocaleString name, string settingName, T defaultValue, params (LocaleString, LocaleString, T)[] options) where S : SettingComponent<S>, new()
		{
			BeginMiniSettingPanel(ui);
			Sync<T> value = ui.Root.AttachComponent<ValueField<T>>().Value;
			value.Value = defaultValue;
			value.SyncWithSetting<T, S>(settingName);
			List<RectTransform> list = CreateMiniSettingSplit(ui, 1f, 1.5f, 2f);
			ui.ForceNext = list[0];
			ui.Text(in name);
			ui.NestInto(list[1]);
			ui.HorizontalLayout(8f);
			(LocaleString, LocaleString, T)[] array = options;
			for (int i = 0; i < array.Length; i++)
			{
				(LocaleString, LocaleString, T) tuple = array[i];
				Button button = ui.Button(in tuple.Item1);
				button.ConvertTintToAdditive();
				button.SetupValueSet(value, tuple.Item3, new OptionDescription<T>
				{
					color = RadiantUI_Constants.TAB_ACTIVE_BACKGROUND_COLOR
				}, new OptionDescription<T>
				{
					color = RadiantUI_Constants.TAB_INACTIVE_BACKGROUND_COLOR
				});
			}
			ui.NestOut();
			ui.NestOut();
			ui.ForceNext = list[2];
			Text text = ui.Text((LocaleString)"");
			ValueOptionDescriptionDriver<T> valueOptionDescriptionDriver = text.Slot.AttachComponent<ValueOptionDescriptionDriver<T>>();
			valueOptionDescriptionDriver.Value.Target = value;
			valueOptionDescriptionDriver.Label.Target = text.Content;
			array = options;
			for (int i = 0; i < array.Length; i++)
			{
				(LocaleString, LocaleString, T) tuple2 = array[i];
				ValueOptionDescriptionDriver<T>.Option option;
				if (EqualityComparer<T>.Default.Equals(tuple2.Item3, valueOptionDescriptionDriver.DefaultOption.ReferenceValue.Value))
				{
					option = valueOptionDescriptionDriver.DefaultOption;
				}
				else
				{
					option = valueOptionDescriptionDriver.Options.Add();
					option.ReferenceValue.Value = tuple2.Item3;
				}
				option.Label.AssignLocaleString(tuple2.Item2);
			}
			ui.NestOut();
		}

