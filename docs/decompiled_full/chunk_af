	[Category(new string[] { "Radiant UI/World Browsing/Legacy" })]
	public abstract class LegacyWorldItem : Component
	{
		public readonly UserRef UpdatingUser;

		public readonly Sync<string> WorldOrSessionId;

		protected readonly Sync<bool> _visited;

		protected readonly Sync<int> _totalActiveUsers;

		[OldName("_totalFriends")]
		protected readonly Sync<int> _totalContacts;

		protected FrooxEngine.Store.Record _worldRecord;

		private string _lastId;

		private RecordId _lastRecordId;

		protected SlimList<World> _openedWorlds;

		private Dictionary<World, SessionThumbnailData> _registeredThumbnailData;

		private int prevSessionCount;

		public const float ICON_ADVANCE = 1.25f;

		public bool IsLocalUserUpdating
		{
			get
			{
				if (base.World != Userspace.UserspaceWorld && (UpdatingUser.Target != null || !base.LocalUser.IsHost))
				{
					return UpdatingUser.Target == base.LocalUser;
				}
				return true;
			}
		}

		public FrooxEngine.Store.Record CachedRecord => _worldRecord;

		protected abstract void UpdateInfo(FrooxEngine.Store.Record record, IReadOnlyList<SessionInfo> sessions, IReadOnlyList<World> openedWorlds);

		protected override void OnChanges()
		{
			base.OnChanges();
			UpdateTarget();
		}

		public void SetTarget(string id, FrooxEngine.Store.Record prefetchedRecord = null, IReadOnlyList<SessionInfo> prefetchedInfo = null, bool notifyManager = false)
		{
			WorldOrSessionId.Value = id;
			UpdateTarget(prefetchedRecord, prefetchedInfo, notifyManager);
		}

		private void UpdateTarget(FrooxEngine.Store.Record prefetchedRecord = null, IReadOnlyList<SessionInfo> prefetchedInfo = null, bool notifyManager = true)
		{
			if (!(_lastId != WorldOrSessionId.Value))
			{
				return;
			}
			Unregister();
			_lastId = WorldOrSessionId.Value;
			if (_lastId == null)
			{
				return;
			}
			RecordId recordId;
			if (_lastId.StartsWith("S-", StringComparison.InvariantCultureIgnoreCase))
			{
				base.Engine.Cloud.Sessions.RegisterSessionIdChanges(_lastId, OnSessionChanged, prefetchedInfo == null);
				base.Engine.WorldManager.RegisterSessionIdEvents(_lastId, OnOpenWorldChanged);
				_visited.Value = false;
			}
			else if (RecordId.TryParse(_lastId, out recordId))
			{
				_visited.Value = true;
				StartTask(async delegate
				{
					try
					{
						bool flag = await base.Engine.LocalDB.GetVisitAsync(recordId.ToURL(base.Cloud.Platform)) != null;
						if (base.IsDestroyed)
						{
							UniLog.Warning("Running async continuation on a destroyed updatable. This shouldn't occur.");
						}
						else if (flag != _visited.Value)
						{
							_visited.Value = flag;
							ForceUpdate(notifyManager: false);
						}
					}
					catch (Exception ex)
					{
						UniLog.Error("Exception getting visit status:\n" + ex?.ToString() + "\nOn Item:\n" + this.ParentHierarchyToString());
					}
				});
				_lastRecordId = recordId;
				if (prefetchedRecord != null)
				{
					_worldRecord = prefetchedRecord;
				}
				else
				{
					StartTask(async delegate
					{
						RecordId fetchingId = _lastRecordId;
						FrooxEngine.Store.Record worldRecord = await base.Cloud.Records.RecordCache<FrooxEngine.Store.Record>().Get(fetchingId);
						if (!(_lastRecordId != fetchingId))
						{
							_worldRecord = worldRecord;
							if (_worldRecord != null)
							{
								ForceUpdate();
							}
						}
					});
				}
				base.Engine.Cloud.Sessions.RegisterWorldIdChanges(recordId, OnWorldIdSessionsChanged, prefetchedInfo == null);
				base.Engine.WorldManager.RegisterWorldIdEvents(_lastId, OnOpenWorldChanged);
			}
			if (prefetchedInfo != null)
			{
				UpdateData(prefetchedInfo, notifyManager);
			}
		}

		private void OnSessionChanged(SessionInfo session)
		{
			RunSynchronously(delegate
			{
				List<SessionInfo> list = Pool.BorrowList<SessionInfo>();
				if (session != null)
				{
					list.Add(session);
				}
				UpdateData(list);
				Pool.Return(ref list);
			});
		}

		private void OnWorldIdSessionsChanged(IReadOnlyList<SessionInfo> sessions)
		{
			RunSynchronously(delegate
			{
				UpdateData(sessions);
			});
		}

		private void OnOpenWorldChanged(string worldId, World world, WorldIdLinkStatus status)
		{
			if (status == WorldIdLinkStatus.Unliked)
			{
				_openedWorlds.Remove(world);
				UnregisterThumbnailEvent(world);
			}
			else
			{
				_openedWorlds.Add(world);
			}
			RunSynchronously(delegate
			{
				ForceUpdate();
			});
		}

		protected void ForceUpdate(bool notifyManager = true)
		{
			List<SessionInfo> list = Pool.BorrowList<SessionInfo>();
			if (_lastRecordId != null)
			{
				if (RecordId.TryParse(_lastId, out var recordId))
				{
					base.Engine.Cloud.Sessions.GetSessionsForWorldId(recordId, list);
				}
			}
			else
			{
				SessionInfo sessionInfo = base.Engine.Cloud.Sessions.TryGetInfo(_lastId);
				if (sessionInfo != null)
				{
					list.Add(sessionInfo);
				}
			}
			UpdateData(list, notifyManager);
			Pool.Return(ref list);
		}

		private void UpdateData(IReadOnlyList<SessionInfo> sessions, bool notifyManager = true)
		{
			if (!IsLocalUserUpdating)
			{
				return;
			}
			prevSessionCount = sessions.Count;
			int value = sessions.Sum((SessionInfo i) => i.TotalActiveUsers);
			int num = 0;
			foreach (SessionInfo session in sessions)
			{
				num += base.Cloud.Contacts.CountPresentContacts(session);
			}
			_totalActiveUsers.Value = value;
			_totalContacts.Value = num;
			foreach (World openedWorld in _openedWorlds)
			{
				if (_registeredThumbnailData == null)
				{
					_registeredThumbnailData = new Dictionary<World, SessionThumbnailData>();
				}
				if (!_registeredThumbnailData.ContainsKey(openedWorld))
				{
					SessionThumbnailData thumbnailData = Userspace.GetThumbnailData(openedWorld);
					if (thumbnailData != null)
					{
						thumbnailData.ThumbnailUpdated += OnLocalThumbnailUpdated;
						_registeredThumbnailData.Add(openedWorld, thumbnailData);
					}
				}
			}
			UpdateInfo(_worldRecord, sessions, _openedWorlds);
			if (notifyManager)
			{
				base.Slot.GetComponentInParents<LegacyWorldListManager>()?.MarkSortDirty();
			}
		}

		private void UnregisterThumbnailEvent(World world)
		{
			if (_registeredThumbnailData != null && _registeredThumbnailData.TryGetValue(world, out SessionThumbnailData value))
			{
				value.ThumbnailUpdated -= OnLocalThumbnailUpdated;
				_registeredThumbnailData.Remove(world);
			}
		}

		private void OnLocalThumbnailUpdated(SessionThumbnailData obj)
		{
			RunSynchronously(delegate
			{
				ForceUpdate();
			});
		}

		protected World GetBestOpenedWorld(IReadOnlyList<World> worlds)
		{
			World world = null;
			foreach (World world2 in worlds)
			{
				if (world2.State == FrooxEngine.World.WorldState.Running && !world2.IsDestroyed)
				{
					if (world == null)
					{
						world = world2;
					}
					else if (world2.IsAuthority && !world.IsAuthority)
					{
						world = world2;
					}
				}
			}
			return world;
		}

		protected SessionInfo GetBestSession(IReadOnlyList<SessionInfo> sessions)
		{
			SessionInfo sessionInfo = null;
			int num = 0;
			foreach (SessionInfo session in sessions)
			{
				if (session.HasEnded)
				{
					continue;
				}
				if (sessionInfo == null)
				{
					sessionInfo = session;
					num = ScoreSession(session);
					continue;
				}
				int num2 = ScoreSession(session);
				if (num2 > num)
				{
					num = num2;
					sessionInfo = session;
				}
			}
			return sessionInfo;
		}

		private int ScoreSession(SessionInfo info)
		{
			return info.ActiveUsers;
		}

		private void Unregister()
		{
			if (_lastId != null)
			{
				if (_lastId.StartsWith("S-", StringComparison.InvariantCultureIgnoreCase))
				{
					base.Engine.Cloud.Sessions.UnregisterSessionIdChanges(_lastId, OnSessionChanged);
					base.Engine.WorldManager.UnregisterSesionIdEvents(_lastId, OnOpenWorldChanged);
				}
				else if (_lastRecordId != null)
				{
					if (RecordId.TryParse(_lastId, out var recordId))
					{
						base.Engine.Cloud.Sessions.UnregisterWorldIdChanges(recordId, OnWorldIdSessionsChanged);
					}
					base.Engine.WorldManager.UnregisterWorldIdEvents(_lastId, OnOpenWorldChanged);
				}
			}
			_lastId = null;
			_worldRecord = null;
			_lastRecordId = null;
			_openedWorlds.Clear();
		}

		protected override void OnDispose()
		{
			Unregister();
			if (_registeredThumbnailData != null)
			{
				foreach (World item in _registeredThumbnailData.Keys.ToList())
				{
					UnregisterThumbnailEvent(item);
				}
			}
			base.OnDispose();
		}

