				_worldItemPool.Add(item.worldItem);
				item.worldItem = null;
			}
		}

		private async Task UpdateList()
		{
			Engine _engine = base.Engine;
			while (!base.Slot.IsActive || (!_parametersChanged && (DateTime.UtcNow - _lastUpdate).TotalSeconds < (double)CurrentSortDelay))
			{
				if (!base.Slot.IsActive)
				{
					_lastUpdate = DateTime.MinValue;
				}
				await default(NextUpdate);
			}
			_lastUpdate = DateTime.UtcNow;
			_parametersChanged = false;
			IsSearching.Value = true;
			bool _hasMoreResults = false;
			if (string.IsNullOrWhiteSpace(SearchTerm.Value))
			{
				_searchTerm = null;
			}
			else
			{
				_searchTerm = SearchTerm.Value.Trim();
			}
			_optionalTerms.Clear();
			_requiredTerms.Clear();
			_excludedTerms.Clear();
			SearchQueryParser.Parse(_searchTerm, _optionalTerms, _requiredTerms, _excludedTerms);
			if (string.IsNullOrWhiteSpace(ByOwner.Value))
			{
				_byOwner = null;
			}
			else
			{
				_byOwner = ByOwner.Value.Trim();
			}
			_ownerType = OwnerType.Value;
			_sortProperties.Clear();
			foreach (SortProperty sortProperty in SortProperties)
			{
				_sortProperties.Add(new SortInfo(sortProperty.Parameter, sortProperty.Direction));
			}
			bool updateSort = _sortDirty;
			bool updateLocal = _localDirty;
			bool updateSessions = _sessionsDirty;
			bool updateWorlds = _worldsDirty;
			if (SkipItems.Value > 0)
			{
				_delayedLocalDirty |= updateLocal;
				_delayedSessionsDirty |= updateSessions;
				updateLocal = false;
				updateSessions = false;
			}
			else
			{
				updateLocal |= _delayedLocalDirty;
				updateSessions |= _delayedSessionsDirty;
				_delayedLocalDirty = false;
				_delayedSessionsDirty = false;
			}
			_localDirty = false;
			_sessionsDirty = false;
			_sortDirty = false;
			_worldsDirty = false;
			Task resubmitTask = StartTask(SubmitList);
			await default(ToBackground);
			if (updateSessions)
			{
				_foundSessions.Clear();
				if ((bool)ShowSessions)
				{
					_engine.Cloud.Sessions.GetSessions(_foundSessions);
					if (base.World != Userspace.UserspaceWorld)
					{
						_foundSessions.RemoveAll((SessionInfo s) => s.AccessLevel <= SessionAccessLevel.Contacts);
					}
					if (!IncompatibleSessions)
					{
						_foundSessions.RemoveAll((SessionInfo s) => !s.IsCompatible());
					}
				}
			}
			if (updateLocal)
			{
				_openWorlds.Clear();
				if ((bool)ShowOpenedWorlds)
				{
					_engine.WorldManager.GetWorlds(_openWorlds);
					_openWorlds.RemoveAll((World w) => w.State != FrooxEngine.World.WorldState.Running || w.Focus == FrooxEngine.World.WorldFocus.Overlay || w.Focus == FrooxEngine.World.WorldFocus.PrivateOverlay || w.IsDisposed);
					if (base.World != Userspace.UserspaceWorld)
					{
						_openWorlds.RemoveAll((World w) => w.HideFromListing || w.AccessLevel <= SessionAccessLevel.Contacts);
					}
				}
			}
			if (updateWorlds)
			{
				if ((bool)ShowPublishedWorlds)
				{
					SearchParameters searchParameters = GenerateSearchParameters();
					if (_recordSearch == null || !_recordSearch.EqualsParameters(searchParameters))
					{
						_recordSearch = new RecordSearch<FrooxEngine.Store.Record>(searchParameters, _engine.Cloud);
					}
				}
				else
				{
					_recordSearch = null;
				}
			}
			bool updateLocalWorlds = false;
			if (ShowLocallySavedWorlds.Value && base.World == Userspace.UserspaceWorld)
			{
				if (_localWorlds == null)
				{
					string machineId = "M-" + base.Engine.LocalDB.MachineID;
					_localWorlds = await base.Engine.LocalDB.FetchRecordsAsync((FrooxEngine.Store.Record r) => r.OwnerId == machineId).ConfigureAwait(continueOnCapturedContext: false);
					_localWorlds.RemoveAll((FrooxEngine.Store.Record r) => r.RecordType != "world");
					updateLocalWorlds = true;
				}
			}
			else if (_localWorlds != null)
			{
				updateLocalWorlds = true;
				_localWorlds = null;
			}
			if (_recordSearch != null)
			{
				_recordSearch.BatchSize = MaxItems;
				if (await _recordSearch.EnsureResults((int)SkipItems + (int)MaxItems).ConfigureAwait(continueOnCapturedContext: false))
				{
					updateSessions = true;
				}
				_hasMoreResults |= _recordSearch.HasMoreResults;
			}
			await resubmitTask.ConfigureAwait(continueOnCapturedContext: false);
			bool num = updateSessions || updateLocal || updateWorlds || updateLocalWorlds;
			bool addedOrRemoved = false;
			if (num)
			{
				await default(ToBackground);
				toRemove.Clear();
				foreach (KeyValuePair<string, Item> item2 in _items)
				{
					toRemove.Add(item2.Key);
					item2.Value.sessions.Clear();
					item2.Value.worlds.Clear();
				}
				if (_recordSearch != null)
				{
					addedOrRemoved |= AddRecords(_recordSearch.Records, toRemove, assignRecordIndex: true);
				}
				else
				{
					foreach (KeyValuePair<string, Item> item3 in _items)
					{
						if (!item3.Key.StartsWith("M-"))
						{
							item3.Value.record = null;
						}
						item3.Value.recordIndex = 0;
					}
				}
				if (_localWorlds != null)
				{
					addedOrRemoved |= AddRecords(_localWorlds, toRemove, assignRecordIndex: false);
				}
				else
				{
					foreach (KeyValuePair<string, Item> item4 in _items)
					{
						if (item4.Key.StartsWith("M-"))
						{
							item4.Value.record = null;
						}
					}
				}
				foreach (SessionInfo foundSession in _foundSessions)
				{
					bool num2 = MergeSessionsByWorldId.Value && foundSession.ActualCorrespondingWorldId != null;
					string text = (num2 ? foundSession.ActualCorrespondingWorldId.ToString() : foundSession.NormalizedSessionId);
					toRemove.Remove(text);
					if (!_items.TryGetValue(text, out Item value))
					{
						value = new Item(this, text);
						_items.Add(text, value);
						addedOrRemoved = true;
					}
					if (num2)
					{
						value.sessions.Add(foundSession);
						continue;
					}
					value.sessions.Clear();
					value.sessions.Add(foundSession);
				}
				foreach (World world in _openWorlds)
				{
					string text2 = (MergeSessionsByWorldId.Value ? world.CorrespondingWorldId : null);
					if (text2 == null)
					{
						text2 = world.SessionId?.ToLowerInvariant();
					}
					if (text2 != null)
					{
						toRemove.Remove(text2);
						if (!_items.TryGetValue(text2, out Item value2))
						{
							value2 = new Item(this, text2);
							_items.Add(text2, value2);
							addedOrRemoved = true;
						}
						value2.sessions.RemoveAll((SessionInfo s) => s.SessionId.Equals(world.SessionId, StringComparison.InvariantCultureIgnoreCase));
						SessionInfo sessionInfo = base.Engine.SessionAnnouncer.GetSessionInfo(world);
						if (sessionInfo != null)
						{
							value2.sessions.Add(sessionInfo);
						}
						value2.worlds.Add(world);
					}
				}
				if (toRemove.Count > 0)
				{
					addedOrRemoved = true;
					foreach (string item5 in toRemove)
					{
						Item item = _items[item5];
						RemoveWorldItem(item);
						_items.Remove(item5);
					}
				}
				toRemove.Clear();
			}
			if (addedOrRemoved || updateSort)
			{
				await SubmitList();
			}
			await default(ToWorld);
			IsSearching.Value = false;
			HasMoreResults.Value = _hasMoreResults;
