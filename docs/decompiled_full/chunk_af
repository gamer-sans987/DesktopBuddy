		public static bool operator !=(InteractionCursor a, InteractionCursor b)
		{
			return !a.Equals(b);
		}

		public override bool Equals(object obj)
		{
			if (obj == null)
			{
				return false;
			}
			if (obj is InteractionCursor other)
			{
				return Equals(other);
			}
			return false;
		}

