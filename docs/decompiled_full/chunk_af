		private void CancelIteration()
		{
			_currentIteration?.Cancel();
			_currentIteration = null;
		}

		protected override void OnChanges()
		{
			if (!IsUpdatingUser || !ShouldUpdate)
			{
				return;
			}
			IDataFeedComponent target = Feed.Target;
			string text = SearchPhrase.Value?.Trim();
			if (string.IsNullOrWhiteSpace(text))
			{
				text = "";
			}
			bool flag = _forceFeedRegeneration;
			bool flag2 = false;
			_forceFeedRegeneration = false;
			if (target != _currentFeed)
			{
				flag2 = true;
				flag = true;
				_currentFeed?.UnregisterViewData(_currentFeedData);
				_currentFeedData = target?.RegisterViewData();
				OnFeedChanged(_currentFeed, target, text);
			}
			bool isCurrentPathInvalid = IsCurrentPathInvalid;
			bool isCurrentGroupingKeysInvalid = IsCurrentGroupingKeysInvalid;
			bool flag3 = _currentSearch != text;
			if (!flag2 && flag3)
			{
				OnSearchPhraseChanged(_currentSearch, text);
			}
			if (!flag && flag3)
			{
				flag = true;
			}
			if (!flag && isCurrentPathInvalid)
			{
				flag = true;
			}
			if (!flag && isCurrentGroupingKeysInvalid)
			{
				flag = true;
			}
			if (flag)
			{
				_forceFeedSort = false;
				CancelIteration();
				bool mustRegisterEvents = flag2 || isCurrentPathInvalid || isCurrentGroupingKeysInvalid || flag3;
				if (mustRegisterEvents && _eventsRegistered)
				{
					UnregisterEvents();
				}
				_currentIteration = new CancellationTokenSource();
				_currentFeed = target;
				_currentPath = Path.ToList();
				_currentGroupingKeys = GroupingKeys.ToList();
				_currentSearch = text;
				object feedData = _currentFeedData;
				OnFeedGenerationStarted(_currentFeed, _currentPath, _currentGroupingKeys, _currentSearch, flag2, ref feedData, ref mustRegisterEvents);
				if (_currentFeed != null)
				{
					StartTask(async delegate
					{
						try
						{
							if (mustRegisterEvents)
							{
								_eventsRegistered = true;
								_currentFeed.ListenToUpdates(_currentPath, _currentGroupingKeys, _currentSearch, OnFeedChanged, feedData);
							}
							await GenerateFeed(_currentFeed, _currentPath, _currentGroupingKeys, _currentSearch, feedData, _currentIteration.Token);
						}
						catch (Exception value)
						{
							UniLog.Error($"Exception when generating feed.\nPath: {string.Join(" -> ", _currentPath)}\nGrouping: {string.Join(" -> ", _currentGroupingKeys)}\nSearch: {_currentSearch}\nFeed: {_currentFeed}\n{value}");
						}
					});
				}
				else
				{
					OnFeedGenerationFinished();
				}
			}
			else if (_forceFeedSort)
			{
				_forceFeedSort = false;
				SortItems();
			}
			if (isCurrentPathInvalid)
			{
				this.PathCategoryChanged?.Invoke(Path);
			}
		}

		private void UnregisterEvents()
		{
			if (_currentFeed != null)
			{
				_currentFeed.UnregisterListener(_currentPath, _currentGroupingKeys, _currentSearch, OnFeedChanged);
				_eventsRegistered = false;
			}
		}

		protected void ForceRegenerate()
		{
			_forceFeedRegeneration = true;
			MarkChangeDirty();
		}

		private void OnFeedChanged(DataFeedItem item, DataFeedItemChange change)
		{
			switch (change)
			{
			case DataFeedItemChange.PathItemsInvalidated:
				ForceRegenerate();
				break;
			case DataFeedItemChange.PathSortingInvalidated:
				_forceFeedSort = true;
				MarkChangeDirty();
				break;
			case DataFeedItemChange.Added:
				RunSynchronously(delegate
				{
					FeedItemAdded(item);
				});
				break;
			case DataFeedItemChange.Removed:
				RunSynchronously(delegate
				{
					FeedItemRemoved(item);
				});
				break;
			case DataFeedItemChange.Updated:
				RunSynchronously(delegate
				{
					FeedItemUpdated(item);
				});
				break;
			}
		}

		private async Task GenerateFeed(IDataFeedComponent feed, List<string> path, List<string> groupingKeys, string searchPhrase, object feedData, CancellationToken cancellationToken)
		{
			if (feed.SupportsBackgroundQuerying)
			{
				await default(ToBackground);
			}
			if (cancellationToken.IsCancellationRequested)
			{
				return;
			}
			Stopwatch submissionTimer = Stopwatch.StartNew();
			List<DataFeedItem> submissionFeed = new List<DataFeedItem>();
			try
			{
				await foreach (DataFeedItem item in feed.Enumerate(path, groupingKeys, searchPhrase, feedData))
				{
					if (!cancellationToken.IsCancellationRequested)
					{
						submissionFeed.Add(item);
						if (submissionTimer.Elapsed >= SUBMISSION_INTERVAL)
						{
							await SubmitItems();
						}
						continue;
					}
					return;
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception when enumerating data feed\n: {feed}\n{value}");
			}
			if (!cancellationToken.IsCancellationRequested)
			{
				if (submissionFeed.Count > 0)
				{
					await SubmitItems();
				}
				if (feed.SupportsBackgroundQuerying)
				{
					await default(ToWorld);
				}
				if (!cancellationToken.IsCancellationRequested)
				{
					OnFeedGenerationFinished();
				}
			}
			async Task SubmitItems()
			{
				if (feed.SupportsBackgroundQuerying)
				{
					await default(ToWorld);
				}
				if (!cancellationToken.IsCancellationRequested)
				{
					foreach (DataFeedItem item2 in submissionFeed)
					{
						FeedItemAdded(item2);
					}
					if (feed.SupportsBackgroundQuerying)
					{
						await default(ToBackground);
					}
					if (!cancellationToken.IsCancellationRequested)
					{
						submissionFeed.Clear();
						submissionTimer.Restart();
					}
				}
			}
		}

