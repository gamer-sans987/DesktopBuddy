		private int CompareItems(Item a, Item b)
		{
			int result;
			foreach (SortInfo sortProperty in _sortProperties)
			{
				int num = 0;
				switch (sortProperty.parameter)
				{
				case SortParameter.SearchScore:
					num = a.searchScore.CompareTo(b.searchScore);
					break;
				case SortParameter.Name:
					num = string.Compare(a.mainName, b.mainName, ignoreCase: true);
					break;
				case SortParameter.Random:
					num = ((a.record == null || b.record == null) ? RandomX.Range(-1, 2) : a.record.Rating.CompareTo(b.record.RandomOrder));
					break;
				case SortParameter.OpenedWorldCount:
					result = a.worlds.Count;
					num = result.CompareTo(b.worlds.Count);
					break;
				case SortParameter.TotalSessionCount:
					result = a.sessions.Count;
					num = result.CompareTo(b.sessions.Count);
					break;
				case SortParameter.TotalUserCount:
					num = a.totalUsers.CompareTo(b.totalUsers);
					break;
				case SortParameter.CreationDate:
				case SortParameter.LastUpdateDate:
				case SortParameter.FirstPublishTime:
				case SortParameter.TotalVisits:
					if (a.record == null || b.record == null)
					{
						break;
					}
					num = a.recordIndex.CompareTo(b.recordIndex);
					if (num == 0)
					{
						break;
					}
					result = num;
					goto IL_0191;
				case SortParameter.LastVisit:
					num = a.lastVisit.CompareTo(b.lastVisit);
					break;
				}
				if (num == 0)
				{
					continue;
				}
				if (sortProperty.direction == SortDirection.Descending)
				{
					num = -num;
				}
				result = num;
				goto IL_0191;
			}
			return 0;
			IL_0191:
			return result;
		}

