					EnsureItemAt(ref index, separator: true, out var _);
				}
				EnsureItemAt(ref index, separator: false, out var breadcrumb2);
				breadcrumb2.Assign(target.GetElement(i), i + 1);
			}
			for (int num = root.ChildrenCount - 1; num >= index; num--)
			{
				Slot slot = root[num];
				if (slot.ActiveSelf)
				{
					slot.Destroy();
				}
			}
			void EnsureItemAt(ref int reference2, bool separator, out BreadcrumbInterface reference)
			{
				Slot slot2 = null;
				reference = null;
				while (reference2 < root.ChildrenCount && slot2 == null)
				{
					Slot slot3 = root[reference2];
					if (!slot3.ActiveSelf)
					{
						reference2++;
					}
					else
					{
						reference = slot3.GetComponent<BreadcrumbInterface>();
						if (reference == null != separator)
						{
							slot3.Destroy();
						}
						else
						{
							slot2 = slot3;
						}
					}
				}
				if (slot2 == null)
				{
					if (separator)
					{
						slot2 = SeparatorTemplate.Target.Duplicate(root, keepGlobalTransform: false);
						slot2.ActiveSelf = true;
					}
					else
					{
						slot2 = BreadcrumbTemplate.Target.Slot.Duplicate(root, keepGlobalTransform: false);
						slot2.ActiveSelf = true;
						slot2.PersistentSelf = false;
						reference = slot2.GetComponent<BreadcrumbInterface>();
					}
				}
				slot2.OrderOffset = reference2;
				reference2++;
			}
		}

