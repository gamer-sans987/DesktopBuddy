		private async Task SubmitList()
		{
			await default(ToBackground);
			List<Item> submissionList = Pool.BorrowList<Item>();
			foreach (KeyValuePair<string, Item> item in _items)
			{
				await item.Value.UpdateMetadata().ConfigureAwait(continueOnCapturedContext: false);
				if (Filter(item.Value) == null)
				{
					submissionList.Add(item.Value);
				}
				else
				{
					RemoveWorldItem(item.Value);
				}
			}
			int filteredResults = submissionList.Count;
			submissionList.Sort(CompareItems);
			int num2;
			if (SkipItems.Value >= submissionList.Count)
			{
				submissionList.Clear();
			}
			else
			{
				int num = SkipItems.Value + MaxItems.Value;
				for (int i = 0; i < SkipItems.Value; i++)
				{
					RemoveWorldItem(submissionList[i]);
				}
				for (int j = num; j < submissionList.Count; j++)
				{
					RemoveWorldItem(submissionList[j]);
				}
				num2 = submissionList.Count - num;
				if (num2 > 0)
				{
					submissionList.RemoveRange(num, num2);
				}
				if (SkipItems.Value > 0)
				{
					submissionList.RemoveRange(0, SkipItems);
				}
			}
			await default(ToWorld);
			if (!IsLocalUserUpdating)
			{
				return;
			}
			FilteredResults.Value = filteredResults;
			int num3 = 0;
			foreach (Item item2 in submissionList)
			{
				if (item2.worldItem == null)
				{
					item2.worldItem = GetFreeWorldItem();
					if (item2.worldItem == null)
					{
						continue;
					}
					item2.worldItem.Slot.ActiveSelf = true;
					item2.worldItem.SetTarget(item2.id, item2.record, item2.sessions);
				}
				item2.worldItem.Slot.OrderOffset = num3++;
			}
			num2 = _worldItemPool.Count - (40 - submissionList.Count);
			while (_worldItemPool.Count > 0 && num2-- > 0)
			{
				_worldItemPool.TakeLast().Slot.Destroy();
			}
			foreach (LegacyWorldItem item3 in _worldItemPool)
			{
				item3.Slot.ActiveSelf = false;
			}
			Pool.Return(ref submissionList);
		}

