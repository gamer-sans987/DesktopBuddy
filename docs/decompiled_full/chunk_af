		protected override void OnChanges()
		{
			base.OnChanges();
			_expandButton.Target.SetColors(Expanded.Value ? RadiantUI_Constants.Sub.ORANGE : RadiantUI_Constants.Sub.CYAN);
			_expandIcon.Target.Sprite.Target = (Expanded.Value ? _compactSprite.Target : _expandSprite.Target);
			float expandLerp = _expandLerp;
			_expandLerp = MathX.Progress01(_expandLerp, base.Time.Delta * 2f, Expanded);
			if (expandLerp != _expandLerp)
			{
				MarkChangeDirty();
			}
			float compactDetailLerp = _compactDetailLerp;
			_compactDetailLerp = MathX.Progress01(_compactDetailLerp, base.Time.Delta * 2f, CompactDetailExpanded);
			_compactDetailLerp *= MathX.Clamp01(MathX.InverseLerp(0.25f, 0f, _expandLerp));
			if (compactDetailLerp != _compactDetailLerp)
			{
				MarkChangeDirty();
			}
			float num = MathX.SmootherStep(_expandLerp);
			float num2 = MathX.SmootherStep(_compactDetailLerp);
			_sidebarActive.Target.Value = num > 0f;
			_rectTransformLerp.Target.Value = num;
			_sidebarAnchorMin.Target.Value = Elements.Core.float2.Zero;
			_sidebarAnchorMax.Target.Value = new Elements.Core.float2(num * 0.25f, 1f);
			_contentAnchorMin.Target.Value = new Elements.Core.float2(num * 0.25f);
			_contentAnchorMax.Target.Value = new Elements.Core.float2(1f, 1f);
			bool flag = !Expanded.Value;
			_compactMaskRootEnabled.Target.Value = flag;
			_compactMaskEnabled.Target.Value = MathX.Approximately(num, 0f);
			_compactParent.Target.Target = (flag ? _compactRoot.Target : _detailImageRoot.Target);
			_compactHeaderParent.Target.Target = (flag ? _compactRoot.Target : _detailHeaderRoot.Target);
			float val = MathX.Clamp01(MathX.InverseLerp(0f, 0.2f, _expandLerp));
			val = MathX.SmootherStep(val);
			_compactButtonsAnchorMin.Target.Value = new Elements.Core.float2(0f, val * -3f);
			_compactButtonsAnchorMax.Target.Value = new Elements.Core.float2(1f, 1f - val * 3f);
			_compactButtonsActive.Target.Value = val < 1f;
			if (_modalAnchorMin.Target != null && _modalAnchorMax.Target != null)
			{
				Elements.Core.float2 v = MathX.LerpUnclamped((Elements.Core.float2)ModalCompactSize, (Elements.Core.float2)ModalExpandedSize, num) * 0.5f;
				_modalAnchorMin.Target.Value = 0.5f - v;
				_modalAnchorMax.Target.Value = 0.5f + v;
			}
			_compactDetailRect.Target.Value = new Elements.Core.Rect(0f, 1f - num2, 1f, num2);
			_compactDetailButtonRect.Target.Value = new Elements.Core.Rect(0f, 0f, num2, 1f);
			_compactDetailExpandButton.Target.Slot.ActiveSelf = _expandLerp < 0.25f;
			if (CompactDetailCategory.GetWasChangedAndClear())
			{
				UpdateSelected();
			}
		}

		protected override void UpdateInfo(FrooxEngine.Store.Record record, IReadOnlyList<SessionInfo> sessions, IReadOnlyList<World> openedWorlds)
		{
			GetBestSession(sessions);
			_ = GetBestOpenedWorld(openedWorlds)?.IsAuthority;
			_sessionSelectionList.Clear();
			if (openedWorlds != null)
			{
				foreach (World w in openedWorlds)
				{
					SessionInfo session = sessions?.FirstOrDefault((SessionInfo sessionInfo) => sessionInfo.SessionId.Equals(w.SessionId, StringComparison.InvariantCultureIgnoreCase));
					_sessionSelectionList.Add(new SessionSelectionItem(session, w));
				}
			}
			if (sessions != null)
			{
				foreach (SessionInfo s in sessions)
				{
					UniLog.Log(s);
					if (!_sessionSelectionList.Any((SessionSelectionItem item) => item.session == s))
					{
						_sessionSelectionList.Add(new SessionSelectionItem(s, null));
					}
				}
			}
			_sessionSelectionList.Sort(CompareSessions);
			object selectedItem = _selectedItem;
			if (!(selectedItem is FrooxEngine.Store.Record))
			{
				SessionSelectionItem sessionSelectionItem = selectedItem as SessionSelectionItem;
				if ((object)sessionSelectionItem != null)
				{
					if (sessionSelectionItem.session != null)
					{
						_selectedItem = _sessionSelectionList.FirstOrDefault((SessionSelectionItem i) => i.session.SessionId.Equals(sessionSelectionItem.session.SessionId, StringComparison.InvariantCultureIgnoreCase));
					}
					else
					{
						_selectedItem = _sessionSelectionList.FirstOrDefault((SessionSelectionItem i) => i.world == sessionSelectionItem.world);
					}
				}
			}
			else if ((bool)Expanded)
			{
				_selectedItem = record;
			}
			else
			{
				_selectedItem = null;
			}
			UpdateSelected();
			UpdateSessionItems();
		}

