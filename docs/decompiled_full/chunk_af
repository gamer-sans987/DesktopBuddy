	public static class TweenExtensions
	{
		public static Tween<T> GetActiveTween<T>(this IField<T> field)
		{
			return field.FindNearestParent<Slot>().GetComponent((Tween<T> t) => t.Target.Target == field);
		}

		public static int ClearTweens<T>(this IField<T> field)
		{
			int num = 0;
			Slot slot = field.FindNearestParent<Slot>();
			List<Tween<T>> list = Pool.BorrowList<Tween<T>>();
			slot.GetComponents(list);
			foreach (Tween<T> item in list)
			{
				if (item.Target.Target == field)
				{
					item.Target.Target = null;
					item.Destroy();
					num++;
				}
			}
			Pool.Return(ref list);
			return num;
		}

		public static Tween<T> TweenFromTo<T>(this IField<T> field, T from, T to, float duration, CurvePreset curve = CurvePreset.Sine, Action onDone = null, Action onDoneLocal = null)
		{
			field.ClearTweens();
			field.Value = from;
			return field.TweenTo(to, duration, curve, onDone, onDoneLocal);
		}

		public static Tween<T> TweenFrom<T>(this IField<T> field, T from, float duration, CurvePreset curve = CurvePreset.Sine, Action onDone = null, Action onDoneLocal = null, Slot onlyUnderParent = null)
		{
			T value = field.Value;
			field.ClearTweens();
			field.Value = from;
			return field.TweenTo(value, duration, curve, onDone, onDoneLocal, onlyUnderParent);
		}

		public static Tween<T> TweenTo<T>(this IField<T> field, T to, float duration, CurvePreset curve = CurvePreset.Sine, Action onDone = null, Action onDoneLocal = null, Slot onlyUnderParent = null)
		{
			Slot slot = field.FindNearestParent<Slot>();
			field.ClearTweens();
			Tween<T> tween = slot.AttachComponent<Tween<T>>();
			tween.Target.Target = field;
			tween.From.Value = field.Value;
			tween.To.Value = to;
			tween.Curve.Value = curve;
			tween.OnDone.Target = onDone;
			if (onDoneLocal != null)
			{
				tween.LocalCallback.Value = true;
				tween.OnDoneLocal = onDoneLocal;
			}
			tween.StartTime.Value = slot.Time.WorldTime;
			tween.Duration.Value = duration;
			tween.OnlyUnderParent.Target = onlyUnderParent;
			return tween;
		}

		public static Tween<T> TweenToCallbackValue<T, A>(this IField<T> field, T to, float duration, CurvePreset curve = CurvePreset.Sine, Action<A> onDone = null, A argument = default(A))
		{
			CallbackValueArgument<A> callbackValueArgument = field.FindNearestParent<Slot>().AttachComponent<CallbackValueArgument<A>>();
			callbackValueArgument.Value.Value = argument;
			return field.TweenTo(to, duration, curve, callbackValueArgument.CallAndDestroy);
		}

		public static Tween<T> TweenToCallbackRef<T, A>(this IField<T> field, T to, float duration, CurvePreset curve = CurvePreset.Sine, Action<A> onDone = null, A argument = null) where A : class, IWorldElement
		{
			CallbackRefArgument<A> callbackRefArgument = field.FindNearestParent<Slot>().AttachComponent<CallbackRefArgument<A>>();
			callbackRefArgument.Reference.Target = argument;
			return field.TweenTo(to, duration, curve, callbackRefArgument.CallAndDestroy);
		}
	}
