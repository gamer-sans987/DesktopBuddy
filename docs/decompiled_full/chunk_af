		private string Filter(Item item)
		{
			if (_byOwner != null && !HasOwner(item, _byOwner))
			{
				return "NotByOwner";
			}
			foreach (string requiredTerm in _requiredTerms)
			{
				if (!ContainsTerm(item, requiredTerm))
				{
					return "MissingRequiredTerm";
				}
			}
			foreach (string excludedTerm in _excludedTerms)
			{
				if (ContainsTerm(item, excludedTerm))
				{
					return "ContainingExcludedTerm";
				}
			}
			if (_optionalTerms.Count > 0)
			{
				bool flag = false;
				foreach (string optionalTerm in _optionalTerms)
				{
					if (ContainsTerm(item, optionalTerm))
					{
						flag = true;
						break;
					}
				}
				if (!flag)
				{
					return "MissingAllOptionalTerms";
				}
			}
			if (item.totalUsers < MinimumTotalUsers.Value)
			{
				return "UnderMinimumTotalUsers";
			}
			if (item.totalContacts < MinimumTotalContacts.Value)
			{
				return "UnderMinimumTotalContacts";
			}
			if (base.World != Userspace.UserspaceWorld && item.record != null && !item.record.IsPublic)
			{
				return "PrivateRecordInPublic";
			}
			if (!MatchesSessionAccessLevel(item))
			{
				return "SessionAccessLevelMismatch";
			}
			if (!MatchesUptime(item))
			{
				return "SessionUptimeMismatch";
			}
			if (Visited.Value.HasValue && Visited.Value.Value != item.IsVisited)
			{
				return "VisitedStateMismatch";
			}
			if (item.record == null && item.worlds.Count == 0)
			{
				bool flag2 = item.sessions.Any((SessionInfo s) => s.HeadlessHost);
				if (OnlyHeadlessHosts.Value && !flag2)
				{
					return "NotHeadless";
				}
				if (item.totalUsers == 0)
				{
					switch (EmptySessions.Value)
					{
					case EmptySessionFilter.HideAll:
						return "HidingAllEmptySessions";
					case EmptySessionFilter.OnlyHeadless:
						if (!flag2)
						{
							return "HidingNonHeadlessEmptySessions";
						}
						break;
					}
				}
			}
			if (item.sessions.Count > 0 && item.worlds.Count == 0)
			{
				bool flag3 = true;
				foreach (SessionInfo session in item.sessions)
				{
					if (session.ParentSessionIds == null || session.ParentSessionIds.Count == 0)
					{
						flag3 = true;
						break;
					}
					if (session.ParentSessionIds.Any((string s) => s.Equals(ParentSessionId.Value, StringComparison.InvariantCultureIgnoreCase)))
					{
						flag3 = true;
						break;
					}
					flag3 = false;
				}
				if (!flag3)
				{
					return "IsNestedSession";
				}
			}
			return null;
		}

		private bool MatchesUptime(Item item)
		{
			if (item.record != null)
			{
				return true;
			}
			foreach (World world in item.worlds)
			{
				if (world.Time.WorldTime >= MinUptime.Value && world.Time.WorldTime <= MaxUptime.Value)
				{
					return true;
				}
			}
			foreach (SessionInfo session in item.sessions)
			{
				double totalSeconds = (DateTime.UtcNow - session.SessionBeginTime).TotalSeconds;
				if (totalSeconds >= MinUptime.Value && totalSeconds <= MaxUptime.Value)
				{
					return true;
				}
			}
			return false;
		}

		private bool MatchesSessionAccessLevel(Item item)
		{
			if (item.record != null)
			{
				return true;
			}
			foreach (World world in item.worlds)
			{
				if (world.AccessLevel >= MinSessionAccessLevel.Value && world.AccessLevel <= (SessionAccessLevel)MaxSessionAccessLevel)
				{
					return true;
				}
			}
			foreach (SessionInfo session in item.sessions)
			{
				if (session.AccessLevel >= MinSessionAccessLevel.Value && session.AccessLevel <= (SessionAccessLevel)MaxSessionAccessLevel)
				{
					return true;
				}
			}
			return false;
		}

		private static bool HasOwner(Item item, string owner)
		{
			if (item.record != null)
			{
				if (item.record.OwnerId == owner)
				{
					return true;
				}
				if (ContainsTerm(item.record.OwnerName, owner))
				{
					return true;
				}
			}
			if (item.sessions.Any((SessionInfo s) => s.HostUserId == owner || ContainsTerm(s.HostUsername, owner)))
			{
				return true;
			}
			return false;
		}

		private static bool ContainsTerm(Item item, string term)
		{
			if (ContainsTerm(item.mainName, term))
			{
				return true;
			}
			if (item.record != null)
			{
				if (ContainsTerm(item.record.Name, term) || ContainsTerm(item.record.Description, term) || ContainsTerm(item.record.OwnerName, term))
				{
					return true;
				}
				if (HasTag(item.record.Tags, term))
				{
					return true;
				}
			}
			foreach (SessionInfo session in item.sessions)
			{
				if (ContainsTerm(session.Name, term))
				{
					return true;
				}
				if (ContainsTerm(session.Description, term))
				{
					return true;
				}
				if (ContainsTerm(session.HostUsername, term))
				{
					return true;
				}
				if (HasTag(session.Tags, term))
				{
					return true;
				}
			}
			return false;
		}

		private static bool HasTag(IEnumerable<string> tags, string term)
		{
			if (tags == null)
			{
				return false;
			}
			foreach (string tag in tags)
			{
				if (string.Equals(tag, term, StringComparison.InvariantCultureIgnoreCase))
				{
					return true;
				}
			}
			return false;
		}

		private static bool ContainsTerm(string str, string term)
		{
			if (str == null)
			{
				return false;
			}
			return str.IndexOf(term, StringComparison.InvariantCultureIgnoreCase) >= 0;
		}

