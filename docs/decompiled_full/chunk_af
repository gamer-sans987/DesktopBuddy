				IField field = mapper(arg);
				if (field == null)
				{
					continue;
				}
				if (field.IsDriven)
				{
					ignoreSlots.Add(field.FindNearestParent<Slot>());
					field = mapper(arg);
					if (field == null)
					{
						continue;
					}
				}
