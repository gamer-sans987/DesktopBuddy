	public class DataFeedItemMappingManager : SyncObject
	{
		public readonly struct ItemData
		{
			public readonly DataFeedItem item;

			public readonly Slot root;

			public readonly FeedItemInterface @interface;

			public ItemData(DataFeedItem item, Slot root, FeedItemInterface @interface)
			{
				this.item = item;
				this.root = root;
				this.@interface = @interface;
			}
		}

		public readonly SyncRef<Slot> ContainerRoot;

		public readonly SyncRef<DataFeedItemMapper> TemplateMapper;

		public readonly SyncDelegateList<Action> OnGenerationStarted;

		private PathDictionary<string, Slot> _itemGroups;

		private Dictionary<string, ItemData> _items;

		private HashSet<FeedItemInterface> _walkedItems = new HashSet<FeedItemInterface>();

		private IDataFeedView _view;

		public bool IsValid
		{
			get
			{
				if (_view != null && ContainerRoot.Target != null)
				{
					return TemplateMapper.Target != null;
				}
				return false;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			_view = this.FindNearestParent<IDataFeedView>();
		}

		public void BeginNewGeneration()
		{
			if (_itemGroups == null)
			{
				_itemGroups = new PathDictionary<string, Slot>();
			}
			else
			{
				_itemGroups.Clear();
			}
			if (_items == null)
			{
				_items = new Dictionary<string, ItemData>();
			}
			else
			{
				_items.Clear();
			}
			ContainerRoot.Target?.DestroyChildren();
			foreach (Action item in OnGenerationStarted)
			{
				item?.Invoke();
			}
		}

		public void AddItem(DataFeedItem item)
		{
			AddItem(item, ContainerRoot.Target);
		}

		private void AddItem(DataFeedItem item, Slot root)
		{
			DataFeedItemMap? dataFeedItemMap = TemplateMapper.Target.FindMapping(item);
			if (!dataFeedItemMap.HasValue)
			{
				return;
			}
			if (item.IsInGroup && _itemGroups.TryGetValue(item.GroupingParameters, out Slot item2))
			{
				root = item2;
			}
			FeedItemInterface.InstanceResult instanceResult = dataFeedItemMap.Value.Instantiate(root, _view, item, _walkedItems);
			instanceResult.topRoot.PersistentSelf = false;
			_items.Add(item.ItemKey, new ItemData(item, instanceResult.topRoot, instanceResult.primaryItem));
			if (item is DataFeedGroup)
			{
				FeedGroupInterface componentInChildren = instanceResult.topRoot.GetComponentInChildren((FeedGroupInterface i) => i.ChildContainer.Target != null);
				if (componentInChildren != null)
				{
					string[] array = new string[(item.GroupingParameters?.Count ?? 0) + 1];
					for (int num = 0; num < (item.GroupingParameters?.Count ?? 0); num++)
					{
						array[num] = item.GroupingParameters[num];
					}
					array[^1] = item.ItemKey;
					root = componentInChildren.ChildContainer.Target;
					_itemGroups.TryAdd(array, root);
				}
			}
			if (!item.HasSubItems)
			{
				return;
			}
			foreach (DataFeedItem subItem in item.SubItems)
			{
				AddItem(subItem, root);
			}
		}

		public void RemoveItem(DataFeedItem item)
		{
			if (_items.TryGetValue(item.ItemKey, out var value))
			{
				value.root.Destroy();
				_items.Remove(item.ItemKey);
			}
		}

		public void UpdateItem(DataFeedItem item)
		{
			if (_items.TryGetValue(item.ItemKey, out var value))
			{
				value.@interface.Update(_view, item);
			}
		}

		public void SortItems()
		{
			foreach (KeyValuePair<string, ItemData> item in _items)
			{
				item.Value.root.OrderOffset = item.Value.item.SortingOrder;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			ContainerRoot = new SyncRef<Slot>();
			TemplateMapper = new SyncRef<DataFeedItemMapper>();
			OnGenerationStarted = new SyncDelegateList<Action>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => ContainerRoot, 
				1 => TemplateMapper, 
				2 => OnGenerationStarted, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

