		protected override void OnChanges()
		{
			base.OnChanges();
			int num = 0;
			while (true)
			{
				InvalidationInfo invalidationInfo2;
				InvalidationInfo invalidationInfo = (invalidationInfo2 = GetInvalidationInfo(num++));
				if (invalidationInfo.IsNull)
				{
					break;
				}
				if (invalidationInfo2.element.GetWasChangedAndClear())
				{
					_parametersChanged = true;
					switch (invalidationInfo2.group)
					{
					case InvalidationGroup.OpenedWorlds:
						_localDirty = true;
						break;
					case InvalidationGroup.PublishedWorlds:
						_worldsDirty = true;
						break;
					case InvalidationGroup.Sessions:
						_sessionsDirty = true;
						break;
					case InvalidationGroup.Sort:
						_sortDirty = true;
						break;
					case InvalidationGroup.All:
						_localDirty = true;
						_worldsDirty = true;
						_sessionsDirty = true;
						_sortDirty = true;
						break;
					}
				}
			}
			if (!IsLocalUserUpdating)
			{
				if (!_lastWasUpdating)
				{
					return;
				}
				_lastWasUpdating = false;
				foreach (KeyValuePair<string, Item> item in _items)
				{
					item.Value.worldItem?.Slot?.Destroy();
					item.Value.worldItem = null;
				}
				foreach (LegacyWorldItem item2 in _worldItemPool)
				{
					item2?.Slot.Destroy();
				}
				_worldItemPool.Clear();
				return;
			}
			_lastWasUpdating = true;
			if (_sortDirty || _localDirty || _sessionsDirty || _worldsDirty)
			{
				if (_updateRunning)
				{
					_runUpdateAgain = true;
					return;
				}
				_updateRunning = true;
				StartTask(UpdateList);
			}
		}

