		private new bool IsValid(World world)
		{
			if (world.IsDisposed)
			{
				return false;
			}
			if (world.State != FrooxEngine.World.WorldState.Running)
			{
				return false;
			}
			if (world.Focus == FrooxEngine.World.WorldFocus.Overlay || world.Focus == FrooxEngine.World.WorldFocus.PrivateOverlay)
			{
				return false;
			}
			return true;
		}

		private new bool IsValid(SessionInfo info)
		{
			if (base.World.IsPriviledged())
			{
				return true;
			}
			if (info.AccessLevel <= SessionAccessLevel.ContactsPlus)
			{
				return false;
			}
			if (info.HideFromListing)
			{
				return false;
			}
			return true;
		}

		private bool Filter(MergedWorldData data)
		{
			if (MinimumTotalUsers.Value > 0 && data.TotalAggregateActiveUsers < MinimumTotalUsers.Value)
			{
				return false;
			}
			if (MinimumTotalContacts.Value > 0 && data.TotalAggregateContacts < MinimumTotalContacts.Value)
			{
				return false;
			}
			if (data.record != null && !IsMatch(data.record))
			{
				return false;
			}
			if (data.HasAnySessions && !data.MatchesSessionFilter(IsMatch))
			{
				return false;
			}
			if (data.HasAnyWorlds && !data.MatchesWorldFilter(IsMatch))
			{
				return false;
			}
			return true;
		}

		private DataFeedItem ToItem(MergedWorldData data)
		{
			return new MergedWorldDataFeedItem(data);
		}

		private bool IsMatch(SkyFrost.Base.Record record)
		{
			return true;
		}

		private bool IsMatch(World world)
		{
			if (!IsValid(world))
			{
				return false;
			}
			return true;
		}

		private bool IsMatch(SessionInfo info)
		{
			if (!IsValid(info))
			{
				return false;
			}
			if (!IncompatibleSessions.Value && !info.IsCompatible())
			{
				return false;
			}
			if (!ListSessions.Value && base.Engine.WorldManager.GetWorld((World w) => w.SessionId == info.SessionId) == null)
			{
				return false;
			}
			if (info.HeadlessHost && !HeadlessHosts.Value)
			{
				return false;
			}
			if (!info.HeadlessHost && !UserHosts.Value)
			{
				return false;
			}
			if (info.AccessLevel < MinSessionAccessLevel.Value || info.AccessLevel > MaxSessionAccessLevel.Value)
			{
				return false;
			}
			if (!(DateTime.UtcNow - info.SessionBeginTime).TotalSeconds.IsBetween(MinUptime, MaxUptime))
			{
				return false;
			}
			return true;
		}

