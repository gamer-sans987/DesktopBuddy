		public Elements.Core.float2? FitSize(Elements.Core.float2 offeredSize)
		{
			if (offeredSize.x < (float)MinWidth || offeredSize.y < (float)MinHeight)
			{
				return null;
			}
			offeredSize = MathX.Min(in offeredSize, new Elements.Core.float2(MaxWidth, MaxHeight));
			if (AllowedAspectRatios.Count > 0)
			{
				float num = 0f;
				Elements.Core.float2 @float = Elements.Core.float2.Zero;
				float num2 = offeredSize.x / offeredSize.y;
				foreach (Elements.Core.float2 allowedAspectRatio in AllowedAspectRatios)
				{
					if (!(allowedAspectRatio <= 0f).Any())
					{
						float num3 = allowedAspectRatio.x / allowedAspectRatio.y;
						Elements.Core.float2 float2 = ((!(num2 < num3)) ? new Elements.Core.float2(offeredSize.y * num3, offeredSize.y) : new Elements.Core.float2(offeredSize.x, offeredSize.x / num3));
