	public class BoneNode
	{
		public readonly Slot bone;

		public readonly List<BoneNode> children = new List<BoneNode>();

		public BoneNode parent;

		public BodyNode boneType;

		public BoneNode(Slot bone)
		{
			this.bone = bone;
		}

		public BoneNode(Slot bone, BodyNode boneType)
		{
			this.bone = bone;
			this.boneType = boneType;
		}

		public override string ToString()
		{
			return ToString((BoneNode b) => b.bone.Name + $" ({b.boneType})");
		}

		public string ToString(Func<BoneNode, string> namePrinter)
		{
			StringBuilder stringBuilder = new StringBuilder();
			GenerateString(0, stringBuilder, namePrinter);
			return stringBuilder.ToString();
		}

		private void GenerateString(int level, StringBuilder str, Func<BoneNode, string> namePrint)
		{
			for (int i = 0; i < level; i++)
			{
				str.Append("-");
			}
			str.AppendLine(namePrint(this));
			foreach (BoneNode child in children)
			{
				child.GenerateString(level + 1, str, namePrint);
			}
		}

		public bool HasParent(BodyNode node)
		{
			if (parent == null)
			{
				return false;
			}
			if (parent.boneType == node)
			{
				return true;
			}
			return parent.HasParent(node);
		}

		public bool HasChild(BodyNode node)
		{
			foreach (BoneNode child in children)
			{
				if (child.boneType == node)
				{
					return true;
				}
				if (child.HasChild(node))
				{
					return true;
				}
			}
			return false;
		}

		public bool HasBone(Slot bone)
		{
			if (bone == this.bone)
			{
				return true;
			}
			foreach (BoneNode child in children)
			{
				if (child.HasBone(bone))
				{
					return true;
				}
			}
			return false;
		}

		public void CollapseBonesAtSamePosition(float minDistance = 1E-05f)
		{
			for (int num = children.Count - 1; num >= 0; num--)
			{
				children[num].CollapseBonesAtSamePosition(minDistance);
			}
			if (parent == null || !(MathX.Distance(parent.bone.GlobalPosition, bone.GlobalPosition) < minDistance))
			{
				return;
			}
			parent.children.Remove(this);
			foreach (BoneNode child in children)
			{
				child.parent = parent;
				parent.children.Add(child);
			}
		}

		public static void SetupNodeRelationships(Dictionary<Slot, BoneNode> nodes)
		{
			foreach (KeyValuePair<Slot, BoneNode> node in nodes)
			{
				Slot slot = node.Key.Parent;
				while (!slot.IsRootSlot)
				{
					if (nodes.TryGetValue(slot, out BoneNode value))
					{
						value.children.Add(node.Value);
						node.Value.parent = value;
						break;
					}
					slot = slot.Parent;
				}
			}
		}

		public static List<BoneNode> ConstructBoneNodeHiearchies(IEnumerable<Slot> bones)
		{
			Dictionary<Slot, BoneNode> dictionary = new Dictionary<Slot, BoneNode>();
			foreach (Slot bone in bones)
			{
				if (bone != null)
				{
					dictionary.Add(bone, new BoneNode(bone));
				}
			}
			return ConstructBoneNodeHiearchies(dictionary);
		}

		public static List<BoneNode> ConstructBoneNodeHiearchies(Dictionary<Slot, BoneNode> nodes)
		{
			SetupNodeRelationships(nodes);
			return (from n in nodes
				where n.Value.parent == null
				select n.Value).ToList();
		}
	}
