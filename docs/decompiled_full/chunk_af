				bool num = base.Cloud.Contacts.IsContact(user.UserID);
				if (!user.IsPresent)
				{
					str.Append("<alpha=#66>");
				}
				if (num)
				{
					str.Append("<color=#59eb5c>");
				}
				str.Append(user.SanitizedUsername);
				if (num)
				{
					str.Append("</color>");
				}
				if (!user.IsPresent)
