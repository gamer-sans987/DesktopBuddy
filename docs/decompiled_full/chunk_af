		private void UpdateDevices()
		{
			UIBuilder uIBuilder = new UIBuilder(_deviceButtonRoot.Target);
			RadiantUI_Constants.SetupDefaultStyle(uIBuilder);
			uIBuilder.Style.ButtonTextPadding = 8f;
			for (int i = 0; i < base.AudioSystem.AudioInputCount; i++)
			{
				AudioInput audioInput = base.AudioSystem.AudioInputs[i];
				if (!_deviceButtons.TryGetValue(audioInput, out Slot value))
				{
					uIBuilder.Style.PreferredHeight = 48f;
					Button button = uIBuilder.Button((LocaleString)audioInput.Name);
					button.PassThroughVerticalMovement.Value = true;
					button.Label.HorizontalAlign.Value = TextHorizontalAlignment.Left;
					Slot slot = button.Slot;
					value = slot;
					slot.OrderOffset = (long)audioInput.InputType;
					AudioInputDeviceInfo audioInputDeviceInfo = slot.AttachComponent<AudioInputDeviceInfo>();
					button.Label.Content.DriveFrom(audioInputDeviceInfo.DeviceName);
					button.ConvertTintToAdditive();
					button.SetupValueSet(SelectedDeviceIndex, i, new OptionDescription<int>
					{
						color = RadiantUI_Constants.TAB_ACTIVE_BACKGROUND_COLOR
					}, new OptionDescription<int>
					{
						color = RadiantUI_Constants.TAB_INACTIVE_BACKGROUND_COLOR
					});
					audioInputDeviceInfo.DeviceIndex.Value = i;
					_deviceButtons.Add(audioInput, slot);
				}
				value.ActiveSelf = audioInput.IsConnected;
			}
		}

		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			if (base.World == Userspace.UserspaceWorld && (DateTime.UtcNow - _lastRefresh).TotalSeconds > 5.0)
			{
				base.AudioSystem.RefreshAudioDevices();
				UpdateDevices();
				_lastRefresh = DateTime.UtcNow;
			}
		}

		private void BuildUI()
		{
			base.Slot.DestroyChildren();
			base.Slot.SetContainerTitle("Settings.AudioInputDeviceSettings".AsLocaleKey());
			UIBuilder uIBuilder = new UIBuilder(base.Slot);
			RadiantUI_Constants.SetupDefaultStyle(uIBuilder);
			uIBuilder.SplitHorizontally(0.6f, out RectTransform left, out RectTransform right);
			left.AddFixedPadding(8f);
			right.AddFixedPadding(8f);
			uIBuilder.NestInto(left);
			uIBuilder.ScrollArea(Alignment.TopCenter);
			uIBuilder.VerticalLayout(8f);
			uIBuilder.FitContent(SizeFit.Disabled, SizeFit.PreferredSize);
			uIBuilder.PushStyle();
			uIBuilder.Style.PreferredHeight = 48f;
			uIBuilder.Text("Settings.AudioInputDeviceSettings.DevicePriorities.Breadcrumb".AsLocaleKey("<b>{0}</b>"));
			uIBuilder.PopStyle();
			_deviceButtonRoot.Target = uIBuilder.Root;
			uIBuilder.NestOut();
			uIBuilder.NestOut();
			uIBuilder.NestInto(right);
			uIBuilder.SplitVertically(0.4f, out RectTransform top, out RectTransform bottom);
