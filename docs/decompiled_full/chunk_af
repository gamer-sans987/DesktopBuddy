		protected override void OnCommonUpdate()
		{
			if (!base.LocalUser.IsHost)
			{
				return;
			}
			if (_previousScreen != null && _previousScreen.IsDestroyed)
			{
				_previousScreen = null;
			}
			if (_currentScreen != null && _currentScreen.IsDestroyed)
			{
				_currentScreen = null;
			}
			if (CurrentScreen.Target == null)
			{
				CurrentScreen.Target = Screens.FirstOrDefault();
			}
			if (_previousScreen == null && CurrentScreen.Target != _currentScreen)
			{
				_previousScreen = _currentScreen;
				_currentScreen = CurrentScreen.Target;
				_currentScreen?.Show();
				if (_previousScreen != null && _currentScreen != null)
				{
					_offsetDirection = MathX.Sign(_currentScreen.Slot.ChildIndex - _previousScreen.Slot.ChildIndex);
					_screenLerp = 1f;
				}
				else
				{
					_screenLerp = 0f;
				}
			}
			if (_previousScreen != null)
			{
				_screenLerp -= base.Time.Delta * 2f;
				if (_screenLerp <= 0f)
				{
					_screenLerp = 0f;
					_previousScreen.Hide();
					_previousScreen = null;
				}
			}
			float num = MathX.SmootherStep(_screenLerp);
			if (_currentScreen != null)
			{
				PositionScreen(_currentScreen, num, _offsetDirection);
			}
			if (_previousScreen != null)
			{
				PositionScreen(_previousScreen, 1f - num, 0f - _offsetDirection);
			}
			if (AutoAdaptWidth)
			{
				_renderTexture.Target.Size.Value = MathX.RoundToInt((Elements.Core.float2)base.InputInterface.WindowResolution);
			}
			else
			{
				_renderTexture.Target.Size.Value = MathX.RoundToInt(TextureResolution * RenderTextureScale);
			}
			float screenAspectRatio = ScreenAspectRatio;
			Canvas target = _topCanvas.Target;
			if (target == null)
			{
				target = TopContainer.GetComponentInChildren<GridContainer>()?.Slot?.GetComponentInParents<Canvas>();
				if (target != null)
				{
					target.Size.Value = TopContainerResolution;
					_topCanvas.Target = target;
				}
			}
			if (screenAspectRatio == _previousAspectRatio)
			{
				return;
			}
			foreach (RadiantDashScreen screen in Screens)
			{
				screen.SetAspectRatio(screenAspectRatio);
			}
			_buttonsCanvas.Target.Size.Value = ButtonsStripeResolution;
			if (_topCanvas.Target != null)
			{
				_topCanvas.Target.Size.Value = TopContainerResolution;
			}
			MarkChangeDirty();
			_previousAspectRatio = screenAspectRatio;
		}

