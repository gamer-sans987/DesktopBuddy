	[Category(new string[] { "Utility" })]
	public class Workspace : Component, ICustomInspector, IWorker, IWorldElement, IModifiedEventReceiver, IComponent, IComponentBase, IDestroyable, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public readonly UserRef User;

		public readonly Sync<string> OverrideOwnerId;

		[NoContinuousParsing]
		public readonly Sync<string> WorkspacePath;

		public readonly SyncDelegate<Action<Slot>> InitializeWorkspace;

		public readonly Sync<bool> ReadOnly;

		public readonly Sync<float> AutosaveDelay;

		public readonly Sync<bool> SuspendUpdates;

		public bool LocalForceReinitialize;

		[NonPersistent]
		protected readonly Sync<bool> _unsavedChanges;

		[NonPersistent]
		protected readonly SyncTime _lastModification;

		private string _currentOwnerId;

		private FrooxEngine.Store.Record _currentRecord;

		private string _currentPath;

		private Action<Slot> _currentDefault;

		private bool _loadingWorkspace;

		public bool IsLoadingWorkspace => _loadingWorkspace;

		public string CurrentWorkspaceOwnerId => _currentOwnerId;

		public string CurrentWorkspacePath => _currentPath;

		private bool CanUpdate
		{
			get
			{
				if (base.World != Userspace.UserspaceWorld)
				{
					return false;
				}
				if (User.Target != base.LocalUser)
				{
					return false;
				}
				if (_loadingWorkspace)
				{
					return false;
				}
				if (SuspendUpdates.Value)
				{
					return false;
				}
				return true;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			AutosaveDelay.Value = float.MaxValue;
			base.Cloud.Session.UserUpdated += Cloud_UserUpdated;
			Userspace.RegisterExitTask(SaveOnExit);
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			base.Cloud.Session.UserUpdated -= Cloud_UserUpdated;
			Userspace.UnregisterExitTask(SaveOnExit);
		}

		private void Cloud_UserUpdated(SkyFrost.Base.User obj)
		{
			MarkChangeDirty();
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			User.Target = base.LocalUser;
		}

		protected override void OnChanges()
		{
			if (!CanUpdate)
			{
				return;
			}
			string value = OverrideOwnerId.Value;
			string targetOwnerId = base.Cloud.Session.CurrentUserID;
			if (CanUseOverridenUser(value))
			{
				targetOwnerId = value;
			}
			else if (!string.IsNullOrEmpty(value))
			{
				UniLog.Log("Invalid Override owner for workspace " + WorkspacePath.Value + ". Override Owner: " + value);
				targetOwnerId = null;
			}
			if (!(WorkspacePath.Value != _currentPath) && !(targetOwnerId != _currentOwnerId))
			{
				return;
			}
			if (ShouldWaitForLogin(targetOwnerId))
			{
				RunInSeconds(0.15f, base.MarkChangeDirty);
				return;
			}
			StartTask(async delegate
			{
				await LoadTargetWorkspace(WorkspacePath.Value, targetOwnerId);
			});
		}

		private bool CanUseOverridenUser(string overrideOwnerId)
		{
			if (string.IsNullOrWhiteSpace(overrideOwnerId))
			{
				return false;
			}
			if (!base.Cloud.Platform.IsPlatformOwnerId(overrideOwnerId))
			{
				return base.Engine.Universe?.IsPrimaryGroup(overrideOwnerId) ?? false;
			}
			return true;
		}

		private bool ShouldWaitForLogin(string ownerId)
		{
			if (Userspace.AutoLoginInProgress == true)
			{
				if (string.IsNullOrEmpty(ownerId))
				{
					return true;
				}
				if (IdUtil.GetOwnerType(ownerId) == OwnerType.Group)
				{
					return true;
				}
			}
			return false;
		}

		protected override void OnCommonUpdate()
		{
			if (CanUpdate && _unsavedChanges.Value && _lastModification.CurrentTime >= (double)AutosaveDelay.Value)
			{
				SaveChanges();
			}
		}

		private Uri GetWorkspaceRecordUri(string workspace, string userId)
		{
			if (userId == null)
			{
				return null;
			}
			if (string.IsNullOrWhiteSpace(workspace))
			{
				return null;
			}
			if (Uri.TryCreate($"{base.Cloud.Platform.RecordScheme}:///{userId}/Workspaces/{workspace}", UriKind.Absolute, out Uri result))
			{
				return result;
			}
			return null;
		}

		public async Task<CloudResult<FrooxEngine.Store.Record>> LoadWorkspaceFromPath(string workspacePath, string userId)
		{
			Uri workspaceRecordUri = GetWorkspaceRecordUri(workspacePath, userId);
			return await base.Engine.RecordManager.FetchRecord(workspaceRecordUri);
		}

		private bool InitializeToDefault(bool force = false)
		{
			if (!force && _currentDefault != null && _currentDefault == InitializeWorkspace.Target && base.Slot.ChildrenCount > 0)
			{
				return false;
			}
			Clear();
			InitializeWorkspace.Target?.Invoke(base.Slot);
			_currentDefault = InitializeWorkspace.Target;
			_unsavedChanges.Value = false;
			return true;
		}

		private void LogInitialization(string workspacePath, string reason)
		{
			UniLog.Log("Workspace " + workspacePath + " initialized to default state. Reason: " + reason);
		}

		private async Task LoadTargetWorkspace(string workspacePath, string userId)
		{
			if (string.IsNullOrEmpty(workspacePath))
			{
				return;
			}
			UniLog.Log("Loading " + workspacePath + " for " + userId);
			_loadingWorkspace = true;
			if (_unsavedChanges.Value)
			{
				SaveChanges();
			}
			FrooxEngine.Store.Record record = null;
			if (!string.IsNullOrEmpty(userId) && !LocalForceReinitialize)
			{
				CloudResult<FrooxEngine.Store.Record> cloudResult = await LoadWorkspaceFromPath(workspacePath, userId);
				if (cloudResult.IsOK)
				{
					Clear();
					record = cloudResult.Entity;
					if (await base.Slot.LoadObjectAsync(record))
					{
						UniLog.Log("Successfully loaded workspace " + workspacePath + " for " + userId);
						_currentDefault = null;
					}
					else if (InitializeToDefault(force: true))
					{
						LogInitialization(workspacePath, "Spawning in the world failed");
					}
				}
				else
				{
					UniLog.Log($"Workspace {workspacePath} for {userId} failed to load due to HTTP Code: {cloudResult.State}, Message: {cloudResult.Content}");
					if (InitializeToDefault())
					{
						LogInitialization(workspacePath, "HTTP Record Retrieval.");
					}
				}
			}
			else if (InitializeToDefault())
			{
				LogInitialization(workspacePath, "Reset Dash/Anonymous user");
			}
			_currentPath = workspacePath;
			_currentRecord = record;
			_currentOwnerId = userId;
			_loadingWorkspace = false;
			if (LocalForceReinitialize && _currentRecord != null)
			{
				LocalForceReinitialize = false;
				MarkModified();
			}
			MarkChangeDirty();
		}

		private void Clear()
		{
			base.Slot.Components.Where((Component c) => c != this).ToList().ForEach(delegate(Component c)
			{
				c.Destroy();
			});
			base.Slot.DestroyChildren();
		}

		private Task SaveOnExit()
		{
			return StartTask(async delegate
			{
				await default(ToWorld);
				await SaveChanges();
			});
		}

		public Task SaveChanges()
		{
			if (!_unsavedChanges.Value)
			{
				return Task.CompletedTask;
			}
			_unsavedChanges.Value = false;
			if (ReadOnly.Value)
			{
				return Task.CompletedTask;
			}
			if (OverrideOwnerId.Value != null && !base.Engine.RecordManager.CanModify(OverrideOwnerId.Value))
			{
				return Task.CompletedTask;
			}
			if (GetWorkspaceRecordUri(_currentPath, _currentOwnerId) == null)
			{
				return Task.CompletedTask;
			}
			bool flag = base.Persistent;
			base.Persistent = false;
			SavedGraph graph = base.Slot.SaveObject(DependencyHandling.CollectAssets);
			base.Persistent = flag;
			bool makePublic = false;
			string savePath = _currentPath;
			FrooxEngine.Store.Record saveRecord = _currentRecord;
			string saveOwnerId = _currentOwnerId;
			if (savePath.StartsWith("public/", StringComparison.OrdinalIgnoreCase))
			{
				makePublic = true;
			}
			return StartTask(async delegate
			{
				await default(ToBackground);
				Uri uri = await base.Engine.LocalDB.SaveAssetAsync(graph, base.Engine).ConfigureAwait(continueOnCapturedContext: false);
				if (uri == null)
				{
					UniLog.Warning("Error saving Workspace " + savePath + ". SaveAsset resulted in null URL");
				}
				else
				{
					GetPathAndName(savePath, out string name, out string path);
					if (saveRecord == null)
					{
						saveRecord = RecordHelper.CreateForObject<FrooxEngine.Store.Record>(name, saveOwnerId, uri.ToString());
					}
					saveRecord.Name = name;
					saveRecord.AssetURI = uri.ToString();
					saveRecord.Path = path;
					saveRecord.IsPublic = makePublic;
					RecordManager.RecordSaveResult recordSaveResult = await base.Engine.RecordManager.SaveRecord(saveRecord, graph);
					if (recordSaveResult.saved)
					{
						UniLog.Log("Workspace " + path + " saved!");
					}
					else
					{
						UniLog.Log("Workspace " + path + ", failed to save reason: " + recordSaveResult.task.FailReason);
					}
				}
			});
		}

		public static void GetPathAndName(string workspace, out string name, out string path)
		{
			name = PathUtility.GetFileName(workspace);
			path = PathUtility.GetDirectoryName(workspace).Replace('/', '\\');
			if (string.IsNullOrEmpty(path))
			{
				path = "Workspaces";
			}
			else
			{
				path = "Workspaces\\" + path;
			}
		}

		public void MarkModified()
		{
			_unsavedChanges.Value = true;
			_lastModification.SetNow();
		}

