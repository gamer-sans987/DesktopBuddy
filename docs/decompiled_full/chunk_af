		private void Cycle(int delta)
		{
			int num = ((!(_selectedItem is SessionSelectionItem item)) ? (-1) : _sessionSelectionList.IndexOf(item));
			if (_sessionSelectionList.Count == 0)
			{
				_selectedItem = null;
			}
			else
			{
				if (num < 0)
				{
					num = ((delta <= 0) ? (_sessionSelectionList.Count - 1) : 0);
				}
				else
				{
					num += delta;
					num = MathX.Repeat(num, _sessionSelectionList.Count - 1);
				}
				_selectedItem = _sessionSelectionList[num];
			}
			UpdateSelected();
			UpdateSessionItems();
		}

