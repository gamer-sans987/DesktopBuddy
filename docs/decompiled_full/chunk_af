		protected override void OnAwake()
		{
			base.OnAwake();
			LaughThreshold.Value = 0.75f;
			LaughBeginSpeed.Value = 4f;
			LaughEndSpeed.Value = 1f;
			VoiceMouthSupressWeight.Value = 0.9f;
			StrengthMultiplier.Value = 1f;
		}

		protected override void OnCommonUpdate()
		{
			VisemeAnalyzer target = Source.Target;
			IMouthTrackingSourceComponent target2 = MouthTrackingSource.Target;
			float num = 1f;
			if (target != null)
			{
				num = target.Silence.Value;
			}
			float num2 = 1f - (1f - num) * (float)VoiceMouthSupressWeight;
			float num3 = StrengthMultiplier.Value;
			if (FrooxEngine.Engine.IsAprilFools)
			{
				num3 *= Settings.GetActiveSetting<MysterySettings>()?.Expressiveness.Value ?? 1f;
			}
			for (int i = 0; i < 16; i++)
			{
				Viseme viseme = (Viseme)i;
				if (viseme == Viseme.Laughter)
				{
					continue;
				}
				FieldDrive<float> fieldDrive = this[viseme];
				if (fieldDrive.IsLinkValid)
				{
					float num4 = 0f;
					if (target != null)
					{
						num4 += target[viseme].Value;
					}
					else if (viseme == Viseme.Silence)
					{
						num4 = 1f;
					}
					if (target2 != null)
					{
						num4 += target2.GetViseme(viseme) * num2;
					}
					if (num4 > 1f)
					{
						num4 = 1f;
					}
					fieldDrive.Target.Value = num4 * num3;
				}
			}
			FieldDrive<float> fieldDrive2 = this[Viseme.Laughter];
			if (fieldDrive2.IsLinkValid)
			{
				float num5 = 0f;
				if (target != null)
				{
					num5 = target[Viseme.Laughter].Value;
				}
				bool flag = num5 > LaughThreshold.Value;
				fieldDrive2.Target.Value = MathX.Progress01(fieldDrive2.Target.Value, base.Time.Delta * (flag ? LaughBeginSpeed.Value : (0f - LaughEndSpeed.Value)));
			}
		}

		public bool AutoAssignTargets()
		{
			SkinnedMeshRenderer component = base.Slot.GetComponent((SkinnedMeshRenderer r) => r.MeshBlendshapeCount > 0);
			if (component == null)
			{
				return false;
			}
			return AutoAssignTargets(component);
		}

		public bool AutoAssignTargets(SkinnedMeshRenderer skin)
		{
			bool result = false;
			for (int i = 0; i < 16; i++)
			{
				Viseme viseme = (Viseme)i;
				List<string> list = new List<string>();
				list.Add(viseme.ToString().ToLower());
				switch (viseme)
				{
				case Viseme.Silence:
					list.Add("sil");
					break;
				case Viseme.ih:
					list.Add("い");
					break;
				case Viseme.PP:
					list.Add("p");
					break;
				case Viseme.kk:
					list.Add("k");
					break;
				case Viseme.DD:
					list.Add("d");
					list.Add("td");
					break;
				case Viseme.RR:
					list.Add("r");
					break;
				case Viseme.nn:
					list.Add("n");
					list.Add("ん");
					break;
				case Viseme.FF:
					list.Add("f");
					list.Add("fv");
					break;
				case Viseme.aa:
					list.Add("ah");
					list.Add("a");
					list.Add("あ");
					break;
				case Viseme.ou:
					list.Add("u");
					list.Add("う");
					break;
				case Viseme.E:
					list.Add("ee");
					list.Add("え");
					break;
				case Viseme.CH:
					list.Add("sh");
					break;
				case Viseme.oh:
					list.Add("o");
					list.Add("oo");
					list.Add("uh");
					list.Add("お");
					break;
				case Viseme.TH:
					list.Add("h");
					break;
				case Viseme.SS:
					list.Add("s");
					break;
				}
				SyncField<float> syncField = null;
				string bestName = null;
				for (int j = 0; j < skin.MeshBlendshapeCount; j++)
				{
					string text = skin.BlendShapeName(j).ToLower();
					List<string> names = NameHeuristicsHelper.SplitName(text);
					if (list.Any((string vName) => names.Contains(vName)) && PreferViseme(text, bestName))
					{
						syncField = skin.BlendShapeWeights.GetElement(j);
						bestName = text;
					}
				}
				if (syncField != null)
				{
					this[viseme].ForceLink(syncField);
					result = true;
				}
			}
			return result;
		}

		private static bool PreferViseme(string newName, string bestName)
		{
			if (bestName == null)
			{
				return true;
			}
			if (newName.Contains("vrc."))
			{
				return true;
			}
			if (bestName.Contains("vrc."))
			{
				return false;
			}
			return bestName.Length > newName.Length;
		}

