		public async Task<MeshCollider> GeneratePointCloudCollider()
		{
			if (GaussianSplat.Target == null)
			{
				return null;
			}
			while (!GaussianSplat.IsAssetAvailable)
			{
				await default(NextUpdate);
			}
			GaussianCloud cloud = await GaussianSplat.Asset.GetOriginalData();
			if (cloud == null)
			{
				return null;
			}
			await default(ToBackground);
			try
			{
				MeshX meshX = new MeshX();
				meshX.SetVertexCount(cloud.SplatCount);
				for (int i = 0; i < meshX.VertexCount; i++)
				{
					meshX.RawPositions[i] = cloud.Positions[i];
				}
				meshX = meshX.GetMergedDoubles(0.009999999776482582);
				meshX.SetupAsPointCloud();
				Uri uri = await base.Engine.LocalDB.SaveAssetAsync(meshX);
				await default(ToWorld);
				MeshCollider meshCollider = base.Slot.AttachComponent<MeshCollider>();
				StaticMesh staticMesh = base.Slot.AttachComponent<StaticMesh>();
				staticMesh.URL.Value = uri;
				meshCollider.Mesh.Target = staticMesh;
				return meshCollider;
			}
			catch (Exception ex)
			{
				UniLog.Log("Exception generating point cloud collider for gaussian splat:\n" + ex);
				return null;
			}
		}

