		private async Task PopulateExitMessages()
		{
			_exitMessage.Target.Enabled = true;
			_exitMessage.Target.Content.Value = this.GetLocalized("Dash.Exit.ThankYou");
			if (RandomX.Chance(0.2f))
			{
				await DelaySeconds(30f);
				ExitMessage message = await base.Cloud.GetRandomExitMessage();
				if (message != null)
				{
					CloudResult<SkyFrost.Base.User> cloudResult = await base.Cloud.Users.GetUser(message.AddedByUserId);
					string localized = this.GetLocalized("Dash.Exit.SubmittedBy", null, new Dictionary<string, object> { 
					{
						"name",
						cloudResult.Entity?.Username ?? "<i>unknown</i>"
					} });
					_exitMessage.Target.Content.Value = message.Message.Replace("$LocalUser", base.Engine.LocalUserName) + "\n<line-height=125%><size=50%><alpha=#88>" + localized + "</alpha></size></line-height>";
				}
			}
		}

		private async Task PopulateShoutouts()
		{
			Task<List<CreditUser>> userCreditsCached = base.Cloud.Stats.GetUserCreditsCached(CreditType.Sponsor);
			Task<List<CreditUser>> spokenTask = base.Cloud.Stats.GetUserCreditsCached(CreditType.Spoken);
			Task<List<CreditUser>> prominentTask = base.Cloud.Stats.GetUserCreditsCached(CreditType.Prominent);
			Task<List<CreditUser>> basicTask = base.Cloud.Stats.GetUserCreditsCached(CreditType.Basic);
			List<CreditUser> sponsors = await userCreditsCached;
			List<CreditUser> spoken = await spokenTask;
			List<CreditUser> prominent = await prominentTask;
			List<CreditUser> basic = await basicTask;
			if (!base.Cloud.Session.IsUserSignedIn)
			{
				await Task.Delay(TimeSpan.FromSeconds(10.0));
			}
			if (sponsors != null)
			{
				CreditUser random = sponsors.GetRandom();
				if (base.Cloud.CurrentUserID != null && random.UserId == base.Cloud.CurrentUserID)
				{
					Sync<string> sponsorName = _sponsorName;
					string value = (_sponsorName.Value = "<color=hero.yellow>" + this.GetLocalized("Dash.Exit.Sponsor.You", "<b>{0}</b>") + "</color>");
					sponsorName.Value = value;
				}
				else
				{
					_sponsorName.Value = "<color=hero.yellow>" + StringParsingHelper.SanitizeFormatTags(random.Username) + "</color>";
				}
				Uri.TryCreate(random.IconURL, UriKind.Absolute, out Uri result);
				_sponsorIcon.Target.URL.Value = result;
			}
			if (spoken != null && prominent != null && basic != null)
			{
				List<CreditUser> list = spoken.TakeRandomSet(24);
				int num = 0 | ((spoken.Count > 0) ? 1 : 0);
				int num2 = 16 + (24 - list.Count);
				List<CreditUser> list2 = prominent.TakeRandomSet(num2);
				int num3 = num | ((prominent.Count > 0) ? 1 : 0);
				int count = 8 + (num2 - list2.Count);
				List<CreditUser> list3 = basic.TakeRandomSet(count);
				int num4 = num3 | ((basic.Count > 0) ? 1 : 0);
				spoken = list;
				prominent = list2;
				basic = list3;
				string text2 = "<size=85%><color=hero.cyan>" + string.Join(", ", spoken.Select(FormatShoutout)) + "</color>";
				if (prominent.Count > 0)
				{
					text2 = text2 + ", <size=85%><color=hero.orange>" + string.Join(", ", prominent.Select(FormatShoutout)) + "</color>";
				}
				if (basic.Count > 0)
				{
					text2 = text2 + ", <size=85%><color=hero.purple>" + string.Join(", ", basic.Select(FormatShoutout)) + "</color>";
				}
				if (num4 != 0)
				{
					text2 += this.GetLocalized("Dash.Exit.Shoutouts.AndMore");
				}
				text2 += "</size>";
				_shoutouts.Target.Content.Value = text2;
			}
		}

		private string FormatShoutout(CreditUser s)
		{
			if (s.UserId == base.Cloud.CurrentUserID)
			{
				string localized = this.GetLocalized("Dash.Exit.Shoutouts.You", null, "name", "<color=hero.yellow>" + s.Username + "</color>");
				return "<color=hero.purple>" + localized + "</color>";
			}
