		private GridContainer SetupAsGridContainer(Elements.Core.int2 cellCount, float padding = 8f)
		{
			base.ScreenCanvas.Slot.DestroyChildren();
			for (int num = base.ScreenRoot.ChildrenCount - 1; num >= 0; num--)
			{
				Slot slot = base.ScreenRoot[num];
				if (slot != base.ScreenCanvas.Slot)
				{
					slot.Destroy();
				}
			}
			Slot slot2 = base.ScreenCanvas.Slot.AddSlot("Container");
			Slot target = base.ScreenRoot.AddSlot("Facets");
			slot2.AttachComponent<RectTransform>();
			GridContainer gridContainer = slot2.AttachComponent<GridContainer>();
			gridContainer.CellSize.Value = null;
			gridContainer.CellCount.Value = cellCount;
			gridContainer.Padding.Value = Elements.Core.float2.One * padding;
			gridContainer.FacetsRoot.Target = target;
			ValueCopyExtensions.DriveFrom(source: slot2.AttachComponent<UserInterfaceEditModeSync>().EditModeActive, field: gridContainer.EditMode);
			gridContainer.ComputeGridSizeForRect(BaseResolution.Value);
			return gridContainer;
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			int typeVersion = control.GetTypeVersion(GetType());
			if (typeVersion == 0)
			{
				control.OnLoaded(this, delegate
				{
					base.Slot.AttachComponent<DynamicVariableSpace>();
				});
			}
			if (typeVersion < 2)
			{
				control.OnLoaded(this, delegate
				{
					Elements.Core.int2 value = _gridContainer.Target.ComputeGridSizeForRect(BaseResolution.Value);
					_gridContainer.Target.CellCount.Value = value;
					_gridContainer.Target.CellSize.Value = null;
					_gridContainer.Target.ComputeLastDataForRect(BaseResolution.Value);
				});
			}
			if (typeVersion >= 3)
			{
				return;
			}
			control.OnLoaded(this, delegate
			{
				FrooxEngine.UIX.Image component = _gridContainer.Target.BackgroundRoot.Slot.GetComponent<FrooxEngine.UIX.Image>();
				if (component != null)
				{
					component.Tint.Value = UserspaceRadiantDash.DEFAULT_BACKGROUND;
				}
			});
		}

