		private IEnumerable<SyncElement> FilterProperties
		{
			get
			{
				Type type = GetType();
				for (int i = 0; i < base.SyncMemberCount; i++)
				{
					if (!(GetSyncMemberFieldInfo(i).DeclaringType != type) && GetSyncMember(i) is SyncElement syncElement)
					{
						yield return syncElement;
					}
				}
			}
		}

		private bool FilterPropertiesChanged
		{
			get
			{
				foreach (SyncElement filterProperty in FilterProperties)
				{
					if (filterProperty.WasChanged)
					{
						return true;
					}
				}
				return false;
			}
		}

		public async IAsyncEnumerable<DataFeedItem> Enumerate(IReadOnlyList<string> path, IReadOnlyList<string> groupKeys, string searchPhrase, object viewData)
		{
			if (path != null && path.Count > 0)
			{
				yield break;
			}
			WorldsDataFeedData worldsDataFeedData = (WorldsDataFeedData)viewData;
			worldsDataFeedData.Clear(MergeByWorldId, MergeBySessionId);
			if (ListOpenedWorlds.Value && base.World.IsPriviledged())
			{
				List<World> list = Pool.BorrowList<World>();
				base.Engine.WorldManager.GetWorlds(list);
				foreach (World item in list)
				{
					if (IsValid(item))
					{
						worldsDataFeedData.AddOpenWorld(item);
					}
				}
				Pool.Return(ref list);
			}
			if (ListSessions.Value)
			{
				List<SessionInfo> list2 = Pool.BorrowList<SessionInfo>();
				base.Engine.Cloud.Sessions.GetSessions(list2);
				foreach (SessionInfo item2 in list2)
				{
					if (IsValid(item2))
					{
						worldsDataFeedData.AddSession(item2);
					}
				}
				Pool.Return(ref list2);
			}
			foreach (MergedWorldData worldDatum in worldsDataFeedData.WorldData)
			{
				worldDatum.ComputeAggregateData(base.Engine);
			}
			List<string> optionalTerms = Pool.BorrowList<string>();
			List<string> requiredTerms = Pool.BorrowList<string>();
			List<string> excludedTerms = Pool.BorrowList<string>();
			SearchQueryParser.Parse(searchPhrase, optionalTerms, requiredTerms, excludedTerms);
			foreach (MergedWorldData worldDatum2 in worldsDataFeedData.WorldData)
			{
				if (worldDatum2.MatchesSearchParameters(optionalTerms, requiredTerms, excludedTerms) && Filter(worldDatum2))
				{
					worldDatum2.MarkSubmitted();
					yield return ToItem(worldDatum2);
				}
			}
			Pool.Return(ref optionalTerms);
			Pool.Return(ref requiredTerms);
			Pool.Return(ref excludedTerms);
		}

