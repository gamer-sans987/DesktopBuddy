		private void SetupFacetData(Elements.Core.float2? size)
		{
			Facet component = base.Slot.GetComponent<Facet>();
			component.PreferredSizes.Clear();
			component.AllowedAspectRatios.Clear();
			component.PreferredSizes.Add(DefaultSize);
			component.MinSize = MinSize;
			component.MaxSize = MaxSize;
			if (AspectRatio.HasValue)
			{
				component.AllowedAspectRatios.Add(AspectRatio.Value);
			}
			component.Canvas.Target.Size.Value = size ?? DefaultSize;
		}

