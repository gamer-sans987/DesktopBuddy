			slot.AttachComponent<RectTransform>();
			FrooxEngine.UIX.Image image = slot.AttachComponent<FrooxEngine.UIX.Image>();
			image.NineSliceSizing.Value = NineSliceSizing.FixedSize;
			image.Sprite.Target = RadiantUI_Constants.GetOutlinedSprite(base.World);
			image.Tint.Value = RadiantUI_Constants.BUTTON_COLOR.MulRGB(0.8f);
			return slot;
		}

