		public bool TryReceive(IEnumerable<IGrabbable> items, Component grabber, Canvas.InteractionData eventData, in Elements.Core.float3 globalPoint)
		{
			foreach (IGrabbable item in items)
			{
				Facet component = item.Slot.GetComponent<Facet>();
				if (component != null && component.IsStandalone.Value)
				{
					Elements.Core.float2 localPoint = GetLocalPoint(eventData);
					if (PlaceFacet(component, localPoint, eventData))
					{
						this.NotifyModified();
						return true;
					}
				}
			}
			return false;
		}

