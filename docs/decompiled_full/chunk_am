	public class ResoniteLinkReferenceManager
	{
		public const string ID_PREFIX = "Reso_";

		private BiDictionary<string, IWorldElement> _references = new BiDictionary<string, IWorldElement>();

		private int _idPool;

		public bool HasID(string id)
		{
			return _references.ContainsFirst(id);
		}

		public T? ResolveReference<T>(string id) where T : class, IWorldElement
		{
			return ResolveReference(id) as T;
		}

		public IWorldElement ResolveReference(string id)
		{
			if (_references.TryGetSecond(id, out IWorldElement second))
			{
				if (second.IsRemoved)
				{
					_references.RemoveByFirst(id);
					return null;
				}
				return second;
			}
			return null;
		}

		public string TryGetID(IWorldElement target)
		{
			if (_references.TryGetFirst(target, out string first))
			{
				return first;
			}
			return null;
		}

		public string GetID(IWorldElement target)
		{
			if (_references.TryGetFirst(target, out string first))
			{
				return first;
			}
			return AllocateID(target);
		}

		public string AllocateID(IWorldElement target)
		{
			string text = $"{"Reso_"}{_idPool:X}";
			_idPool++;
			RegisterReference(text, target);
			return text;
		}

		public void RegisterReference(string reference, IWorldElement target)
		{
			_references.Add(reference, target);
		}

		public void EnsureReference(string reference, IWorldElement target)
		{
			if (_references.TryGetSecond(reference, out IWorldElement second))
			{
				if (second != target)
				{
					throw new Exception($"Reference mistmach! Possible duplicate ID for two different objects?\nReference: {reference}\nExistingTarget: {second.ParentHierarchyToString()}\nNewTarget: {target.ParentHierarchyToString()}");
				}
			}
			else
			{
				RegisterReference(reference, target);
			}
		}
	}
	public class ResoniteLinkService
	{
		private class DummyMessage : ResoniteLink.Message
		{
		}

		public readonly string UniqueSessionId;

		private readonly ClientMetadata _client;

		private BinaryPayloadMessage _stagedBinaryPayloadMessage;

		public ResoniteLinkHost Host { get; private set; }

		public World World => Host.World;

		public Engine Engine => World.Engine;

		public ResoniteLinkReferenceManager References => Host.References;

		public ResoniteLinkTranslator Translator => Host.Translator;

		public ResoniteLinkAssetImporter AssetImporter => Host.AssetImporter;

		public ResoniteLinkReflection Reflection => Host.Reflection;

		public ResoniteLinkService(ResoniteLinkHost host, string uniqueSessionId, ClientMetadata client)
		{
			Host = host;
			UniqueSessionId = uniqueSessionId;
			_client = client;
		}

		public void OnMessage(MessageReceivedEventArgs e)
		{
			if (e.MessageType == WebSocketMessageType.Close)
			{
				return;
			}
			bool flag = e.MessageType == WebSocketMessageType.Binary;
			try
			{
				if (_stagedBinaryPayloadMessage != null)
				{
					if (!flag)
					{
						throw new InvalidOperationException("Previous message was binary payload, but it was not followed by a binary message");
					}
					_stagedBinaryPayloadMessage.RawBinaryPayload = e.Data.ToArray();
					HandleMessage(_stagedBinaryPayloadMessage);
					_stagedBinaryPayloadMessage = null;
					return;
				}
				if (flag)
				{
					throw new InvalidOperationException("Unexpected binary message");
				}
				ResoniteLink.Message message = System.Text.Json.JsonSerializer.Deserialize<ResoniteLink.Message>(e.Data, LinkInterface.SerializationOptions);
				if (message is BinaryPayloadMessage stagedBinaryPayloadMessage)
				{
					_stagedBinaryPayloadMessage = stagedBinaryPayloadMessage;
				}
				else
				{
					HandleMessage(message);
				}
			}
			catch (Exception ex)
			{
				_stagedBinaryPayloadMessage = null;
				UniLog.Error($"Exception processing ResoniteLink message:\n{ex}");
				Response response = new Response();
				response.SourceMessageID = TryExtractMessageId(e);
				response.ErrorInfo = "Failed to process message: " + ex.Message;
				SendResponse(response);
			}
		}

		private string TryExtractMessageId(MessageReceivedEventArgs e)
		{
			if (e.MessageType != WebSocketMessageType.Text)
			{
				return null;
			}
			try
			{
				return System.Text.Json.JsonSerializer.Deserialize<DummyMessage>(e.Data).MessageID;
			}
			catch
			{
				return null;
			}
		}

		public void OnClose(DisconnectionEventArgs e)
		{
			UniLog.Error($"WebSocket closed in ResoniteLink: {e.Client}");
		}

		internal void HandleMessage(ResoniteLink.Message message)
		{
			if (!(message is ImportTexture2DFile file))
			{
