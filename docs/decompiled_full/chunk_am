	public class GamepadManager
	{
		private Dictionary<string, StandardGamepad> _gamepads;

		public InputInterface Input { get; private set; }

		public GamepadManager(InputInterface input)
		{
			Input = input;
		}

		public void UpdateGamepads(List<GamepadState> states, float deltaTime)
		{
			if (states == null)
			{
				return;
			}
			if (_gamepads == null)
			{
				_gamepads = new Dictionary<string, StandardGamepad>();
			}
			foreach (GamepadState state in states)
			{
				if (!_gamepads.TryGetValue(state.displayName, out StandardGamepad value))
				{
					UniLog.Log("Registering gamepad: " + state.displayName);
					value = Input.CreateDevice<StandardGamepad>(state.displayName);
					_gamepads.Add(state.displayName, value);
				}
				value.UpdateState(state, deltaTime);
			}
		}
