		/// <summary>
		/// Generates a unique file path if file already exists.
		/// </summary>
		/// <param name="fileName">The file name</param>
		/// <param name="targetPath">The path where to save the file</param>
		/// <returns></returns>
		private string GetUniqueFilePath(string fileName, string targetPath)
		{
			int num = 1;
			string text2;
			do
			{
				string extension = Path.GetExtension(fileName);
				string text = Path.GetFileNameWithoutExtension(fileName);
				if (num > 1)
				{
					text = text + "-" + num;
				}
				text2 = Path.Combine(targetPath, text + extension);
				num++;
			}
			while (File.Exists(text2));
			return text2;
		}

		public void NotifyOfFile(string file, string name)
		{
			engine.GlobalCoroutineManager.StartTask(async delegate
			{
				await default(ToBackground);
				string folderPath = Environment.GetFolderPath(Environment.SpecialFolder.Personal);
				folderPath = Path.Combine(folderPath, engine.Cloud.Platform.Name);
				Directory.CreateDirectory(folderPath);
				string uniqueFilePath = GetUniqueFilePath(name, folderPath);
				File.Copy(file, uniqueFilePath);
				File.SetAttributes(uniqueFilePath, FileAttributes.Normal);
			});
		}

		public void NotifyOfScreenshot(World world, string file, ScreenshotType type, DateTime time)
		{
			engine.GlobalCoroutineManager.StartTask(async delegate
			{
				await default(ToBackground);
				if (time.Kind == System.DateTimeKind.Utc)
				{
					time = time.ToLocalTime();
				}
				string folderPath = Environment.GetFolderPath(Environment.SpecialFolder.MyPictures);
				folderPath = Path.Combine(folderPath, engine.Cloud.Platform.Name);
				Directory.CreateDirectory(folderPath);
				string text = time.ToString("yyyy-MM-dd HH.mm.ss");
				string text2 = (_settings.KeepOriginalScreenshotFormat.Value ? Path.GetExtension(file) : ".jpg");
				if (string.IsNullOrEmpty(text2))
				{
					FileType fileType = new FileInfo(file).GetFileType();
					if (fileType != null)
					{
						text2 = "." + fileType.Extension;
					}
				}
				try
				{
					string fileName = text + text2;
					string uniqueFilePath = GetUniqueFilePath(fileName, folderPath);
					if (_settings.KeepOriginalScreenshotFormat.Value)
					{
						File.Copy(file, uniqueFilePath);
						File.SetAttributes(uniqueFilePath, FileAttributes.Normal);
					}
					else
					{
						TextureEncoder.ConvertToJPG(file, uniqueFilePath);
					}
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception saving screenshot to Linux:\n {value}");
				}
			});
		}

