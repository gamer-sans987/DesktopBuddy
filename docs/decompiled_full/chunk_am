		private static bool Equals(List<List<FontAtlases>> a, List<List<FontAtlases>> b)
		{
			if (a == null && b == null)
			{
				return true;
			}
			if (a == null || b == null)
			{
				return false;
			}
			if (a.Count != b.Count)
			{
				return false;
			}
			for (int i = 0; i < a.Count; i++)
			{
				List<FontAtlases> list = a[i];
				List<FontAtlases> list2 = b[i];
				if (list.Count != list2.Count)
				{
					return false;
				}
				for (int j = 0; j < list.Count; j++)
				{
					FontAtlases fontAtlases = list[j];
					FontAtlases fontAtlases2 = list2[j];
					if (fontAtlases.atlases.Count != fontAtlases2.atlases.Count)
					{
						return false;
					}
					for (int k = 0; k < fontAtlases.atlases.Count; k++)
					{
						if (fontAtlases.atlases[k] != fontAtlases2.atlases[k])
						{
							return false;
						}
					}
				}
			}
			return true;
		}

		private static void ReturnToPool(ref List<List<FontAtlases>> atlases)
		{
			foreach (List<FontAtlases> atlase in atlases)
			{
				foreach (FontAtlases item in atlase)
				{
					List<GlyphAtlasManager> list = item.atlases;
					Pool.Return(ref list);
				}
				List<FontAtlases> list2 = atlase;
				Pool.Return(ref list2);
			}
			Pool.Return(ref atlases);
		}

