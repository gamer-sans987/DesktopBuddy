		private void DebugRaycast(float duration, in Elements.Core.float3 origin, in Elements.Core.float3 direction, in float maxDistance, IEnumerable<RaycastHit> results)
		{
			DebugManager debug = World.Debug;
			debug.Vector(origin, direction * MathX.Min(maxDistance, 100000f), Elements.Core.colorX.Yellow, 1f, duration);
			foreach (RaycastHit result in results)
			{
				RaycastHit current = result;
				debug.Sphere(in current.Point, 0.005f, Elements.Core.colorX.Red, 2, duration);
				debug.Vector(current.Point, current.Normal * 0.1f, Elements.Core.colorX.Blue, 1f, duration);
				if (current.TriangleIndex >= 0)
				{
					Elements.Assets.Triangle triangle = current.GetTriangle();
					if (!triangle.IsNull)
					{
						Slot slot = current.Collider.Slot;
						Elements.Core.float3 point = slot.LocalPointToGlobal(in triangle.Vertex0.PositionUnsafe);
						Elements.Core.float3 point2 = slot.LocalPointToGlobal(in triangle.Vertex1.PositionUnsafe);
						Elements.Core.float3 point3 = slot.LocalPointToGlobal(in triangle.Vertex2.PositionUnsafe);
						debug.Triangle(point, point2, point3, Elements.Core.colorX.Green, duration);
					}
				}
			}
		}

