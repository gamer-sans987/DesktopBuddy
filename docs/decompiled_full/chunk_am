		{
			if (linkComponent.Members != null)
			{
				WriteMembers(linkComponent.Members, component, context);
			}
		}

		private void WriteMembers(Dictionary<string, ResoniteLink.Member> members, Worker target, ResoniteLinkUpdateContext context)
		{
			foreach (KeyValuePair<string, ResoniteLink.Member> member in members)
			{
				ISyncMember syncMember = target.GetSyncMember(member.Key);
				if (syncMember == null)
				{
					throw new InvalidOperationException("Member " + member.Key + " does not exist on target");
				}
				WriteMemberData(member.Value, syncMember, context);
			}
		}

		private void WriteDictionary(SyncDictionary linkDictionary, ISyncDictionary dictionary, ResoniteLinkUpdateContext context)
		{
			Type keyType = dictionary.KeyType;
			if (keyType.IsEnum)
			{
				WriteEnumDictionary((SyncDictionary_Enum)linkDictionary, dictionary, context);
				return;
			}
			if (keyType == typeof(byte))
			{
				WriteDictionary((SyncDictionary_byte)linkDictionary, dictionary, (byte key) => key.ToEngine(), context);
				return;
			}
			if (keyType == typeof(ushort))
			{
				WriteDictionary((SyncDictionary_ushort)linkDictionary, dictionary, (ushort key) => key.ToEngine(), context);
				return;
			}
			if (keyType == typeof(uint))
			{
				WriteDictionary((SyncDictionary_uint)linkDictionary, dictionary, (uint key) => key.ToEngine(), context);
				return;
			}
			if (keyType == typeof(ulong))
			{
				WriteDictionary((SyncDictionary_ulong)linkDictionary, dictionary, (ulong key) => key.ToEngine(), context);
				return;
			}
			if (keyType == typeof(sbyte))
			{
				WriteDictionary((SyncDictionary_sbyte)linkDictionary, dictionary, (sbyte key) => key.ToEngine(), context);
				return;
			}
			if (keyType == typeof(short))
			{
				WriteDictionary((SyncDictionary_short)linkDictionary, dictionary, (short key) => key.ToEngine(), context);
				return;
			}
