		internal SteamListener(CSteamID hostUser, int channel, World world, SteamNetworkManager manager)
		{
			this.hostUser = hostUser;
			this.world = world;
			sessionId = world.SessionId;
			this.manager = manager;
			UniLog.Log($"Creating Listener for host SteamID {hostUser}, channel: {channel}, sessionId: {sessionId}");
			listeners = new HSteamListenSocket[2];
			int num = channel * 2;
			for (int i = 0; i < listeners.Length; i++)
			{
				SteamNetworkingConfigValue_t[] config = manager.GetConfig(i);
				listeners[i] = SteamNetworkingSockets.CreateListenSocketP2P(num + i, config.Length, config);
				manager.RegisterListener(listeners[i], this);
			}
			pollGroup = SteamNetworkingSockets.CreatePollGroup();
			_messageHandler = MessageReceived;
			_reassemblyStateFetcher = GetReassemblyState;
			_connectionFailureHandler = ConnectionReceiveError;
			_globalUri = manager.GenerateUri(hostUser, channel, world.SessionId);
			IsActive = true;
			_dummyState.buffer = new byte[0];
			_dummyState.expectingBytes = -1;
			_dummyState.receivedBytes = -1;
		}

		internal void Update(nint[] buffer)
		{
			try
			{
				if (IsActive)
				{
					SteamNetworkManager.ExtractMessages(SteamNetworkingSockets.ReceiveMessagesOnPollGroup(pollGroup, buffer, buffer.Length), buffer, _messageHandler, _connectionFailureHandler, _reassemblyStateFetcher);
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception updating SteamListener:\n{value}");
				Close();
			}
		}

		internal void UpdateStats()
		{
			if (!IsActive)
			{
				return;
			}
			foreach (KeyValuePair<CSteamID, SteamConnection> connection in connections)
			{
				connection.Value.UpdateStats();
			}
		}

		private ref ReassemblyState GetReassemblyState(HSteamNetConnection connection)
		{
			if (connectionMap.TryGetValue(connection, out SteamConnection value))
			{
				return ref value.GetReassemblyState(connection);
			}
			return ref _dummyState;
		}

		private void ConnectionReceiveError(HSteamNetConnection connection)
		{
			if (connectionMap.TryGetValue(connection, out SteamConnection value))
			{
				value.Close(SteamCloseReason.ReceiveError);
			}
		}

		private void MessageReceived(CSteamID steamId, HSteamNetConnection connection, byte[] data, ulong length)
		{
			if (IsActive && connections.TryGetValue(steamId, out SteamConnection value))
			{
				value.MessageReceived(steamId, connection, data, length);
			}
		}

		public void Close()
		{
			lock (manager.Lock)
			{
				if (!IsActive)
				{
					return;
				}
				IsActive = false;
				List<SteamConnection> list = new List<SteamConnection>();
				list.AddRange(connections.Values);
				foreach (SteamConnection item in list)
				{
					item.Close(SteamCloseReason.ClosedLocally);
				}
				connections.Clear();
				connectionMap.Clear();
				manager.UnregisterListener(this);
			}
		}

