		public static void UpgradeResoniteLink(World world)
		{
			PermissionSet permissionSet = world.Permissions.Roles.FirstOrDefault((PermissionSet r) => r.RoleName.Value == "Builder");
			PermissionSet permissionSet2 = world.Permissions.Roles.FirstOrDefault((PermissionSet r) => r.RoleName.Value == "Admin");
			if (permissionSet == null && permissionSet2 == null)
			{
				UniLog.Warning("Failed to identify both Admin & Builder roles, cannot upgrade permissions");
				return;
			}
			Slot slot = null;
			if ((permissionSet ?? permissionSet2).GetGlobalValidators(out List<LocomotionPermissions> validators))
			{
				slot = validators.FirstOrDefault()?.Slot;
			}
			if (slot == null)
			{
				slot = world.RootSlot.FindChildOrAdd("Roles").FindChildOrAdd("Builder");
			}
			ResoniteLinkPermissions resoniteLinkPermissions = slot.AttachComponent<ResoniteLinkPermissions>();
			resoniteLinkPermissions.AllowReadAccess.Value = true;
			resoniteLinkPermissions.AllowWriteAccess.Value = true;
			permissionSet2?.AddGlobal(resoniteLinkPermissions);
			permissionSet?.AddGlobal(resoniteLinkPermissions);
		}
