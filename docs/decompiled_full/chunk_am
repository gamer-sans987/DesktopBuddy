		public void GetComponentList(ResoniteLinkService service, GetComponentTypeList request)
		{
			RunTask(service, request, () => BuildComponentList(request.CategoryPath));
		}

		private void RunTask<TResponse>(ResoniteLinkService service, ResoniteLink.Message sourceMessage, Func<TResponse> task) where TResponse : Response, new()
		{
			World.Coroutines.StartBackgroundTask(async delegate
			{
				try
				{
					TResponse response = task();
					response.Success = true;
					await default(ToWorld);
					service.SendResponse(sourceMessage, response);
				}
				catch (Exception ex)
				{
					service.SendErrorResponse<TResponse>(sourceMessage, ex.Message);
				}
			});
		}

		public ComponentTypeList BuildComponentList(string path)
		{
			CategoryNode<Type> categoryNode = ((!string.IsNullOrEmpty(path) && !(path == "/")) ? WorkerInitializer.ComponentLibrary.GetSubcategory(path) : WorkerInitializer.ComponentLibrary);
			ComponentTypeList componentTypeList = new ComponentTypeList();
			componentTypeList.ComponentTypes = new List<string>();
			componentTypeList.SubCategories = new List<string>();
			componentTypeList.TotalComponentCount = categoryNode.TotalElementCount;
			foreach (Type element in categoryNode.Elements)
			{
				if (World.Types.IsSupported(element))
				{
					componentTypeList.ComponentTypes.Add(World.Types.EncodeType(element));
				}
			}
			foreach (CategoryNode<Type> subcategory in categoryNode.Subcategories)
			{
				componentTypeList.SubCategories.Add(subcategory.Name);
			}
			return componentTypeList;
		}

		public SyncObjectDefinition BuildSyncObjectDefinition(Type syncObjectType, bool flattened)
		{
			if (!IsSyncObjectType(syncObjectType))
			{
				throw new ArgumentException("Provided type is not a sync object type");
			}
			SyncObjectDefinition syncObjectDefinition = new SyncObjectDefinition();
			BuildWorkerDefinition(syncObjectType, syncObjectDefinition, flattened);
			syncObjectDefinition.BaseTypeIsSyncObject = IsSyncObjectType(syncObjectType.BaseType);
			return syncObjectDefinition;
		}

		public ComponentDefinition BuildComponentDefinition(Type componentType, bool flattened)
		{
			if (!IsComponentType(componentType))
			{
				throw new ArgumentException("Provided type is not a component type");
			}
			ComponentDefinition componentDefinition = new ComponentDefinition();
			BuildWorkerDefinition(componentType, componentDefinition, flattened);
			WorkerInitInfo initInfo = WorkerInitializer.GetInitInfo(componentType);
			componentDefinition.CategoryPath = initInfo.CategoryPath;
			componentDefinition.BaseTypeIsComponent = IsComponentType(componentType.BaseType);
			return componentDefinition;
		}

		private void BuildWorkerDefinition(Type workerType, WorkerDefinition definition, bool flattened)
		{
			definition.Type = GetTypeDefinition(workerType, !flattened);
			definition.Members = CollectMemberDefinitions(workerType, flattened);
			definition.Methods = CollectMethodDefinitions(workerType, flattened);
		}

		private static bool IsComponentType(Type type)
		{
			if (!typeof(ComponentBase<Component>).IsAssignableFrom(type))
			{
				return type == typeof(ComponentBase<>);
			}
			return true;
		}

		private static bool IsSyncObjectType(Type type)
		{
			return typeof(SyncObject).IsAssignableFrom(type);
		}

		public TypeDefinition GetTypeDefinition(Type type, bool includeBaseType, Predicate<Type> baseTypeFilter = null)
		{
			TypeDefinition typeDefinition = new TypeDefinition();
			typeDefinition.FullTypeName = World.Types.EncodeType(type);
			typeDefinition.Name = type.Name;
			if (type.IsGenericType)
			{
				string[] array = typeDefinition.Name.Split('`');
				typeDefinition.Name = array[0];
				if (array.Length == 1)
				{
					typeDefinition.DirectGenericParameterCount = 0;
				}
				else
				{
					typeDefinition.DirectGenericParameterCount = int.Parse(array[1]);
				}
			}
			typeDefinition.Namespace = type.Namespace;
			typeDefinition.AssemblyName = type.Assembly.GetName().Name;
			typeDefinition.IsAbstract = type.IsAbstract;
			typeDefinition.IsInterface = type.IsInterface;
			typeDefinition.IsValueType = type.IsValueType;
			typeDefinition.IsEnginePrimitive = type.IsEnginePrimitive() || typeof(ISphericalHarmonics).IsAssignableFrom(type) || type == typeof(Type);
			typeDefinition.IsEnum = type.IsEnum;
			typeDefinition.IsComponent = IsComponentType(type);
			typeDefinition.IsSyncObject = IsSyncObjectType(type);
			typeDefinition.IsWorldElement = typeof(IWorldElement).IsAssignableFrom(type);
			typeDefinition.IsGenericType = type.IsGenericType;
			typeDefinition.IsGenericTypeDefinition = type.IsGenericTypeDefinition;
			if (type.IsNested)
			{
				typeDefinition.IsNested = true;
				typeDefinition.DeclaringType = World.Types.EncodeType(type.DeclaringType);
			}
			if (type.IsGenericType && !type.IsGenericTypeDefinition)
			{
				typeDefinition.GenericArguments = new List<TypeReference>();
				Type[] genericArguments = type.GetGenericArguments();
				foreach (Type type2 in genericArguments)
				{
					typeDefinition.GenericArguments.Add(GetTypeReference(type2));
				}
			}
			if (type.IsGenericTypeDefinition)
			{
				typeDefinition.GenericParameters = new List<GenericParameter>();
				Type[] genericArguments = type.GetGenericArguments();
				foreach (Type parameter in genericArguments)
				{
					typeDefinition.GenericParameters.Add(GetGenericParameter(parameter));
				}
			}
			if (includeBaseType && !typeDefinition.IsEnginePrimitive && !typeDefinition.IsValueType && !typeDefinition.IsInterface && type.BaseType != null && type.BaseType != typeof(object) && BaseTypeSupported(type.BaseType))
			{
				typeDefinition.BaseType = GetTypeReference(type.BaseType);
			}
			typeDefinition.Interfaces = new List<TypeReference>();
			foreach (Type item in type.EnumerateDirectInterfaces())
			{
				TypeReference typeReference = GetTypeReference(item, nullOnUnsupported: true);
				if (typeReference != null)
				{
					typeDefinition.Interfaces.Add(typeReference);
				}
			}
			return typeDefinition;
			bool BaseTypeSupported(Type genericTypeDefinition)
			{
				if (baseTypeFilter != null)
				{
					return baseTypeFilter(genericTypeDefinition);
				}
				if (genericTypeDefinition.IsGenericType)
				{
					genericTypeDefinition = genericTypeDefinition.GetGenericTypeDefinition();
				}
				return World.Types.IsSupported(genericTypeDefinition);
			}
		}

		private TypeReference? GetTypeReference(Type type, bool nullOnUnsupported = false)
		{
			TypeReference typeReference = new TypeReference();
			if (type.IsGenericParameter)
			{
				typeReference.Type = type.Name;
				typeReference.IsGenericParameter = true;
			}
			else if (type.IsGenericType)
			{
				Type[] genericArguments = type.GetGenericArguments();
				type = type.GetGenericTypeDefinition();
				if (World.Types.IsSupported(type))
				{
					typeReference.GenericArguments = new List<TypeReference>();
					Type[] array = genericArguments;
					foreach (Type type2 in array)
					{
						typeReference.GenericArguments.Add(GetTypeReference(type2, nullOnUnsupported));
					}
					typeReference.Type = World.Types.EncodeType(type);
				}
				else
				{
					if (nullOnUnsupported)
					{
						return null;
					}
					typeReference.Type = World.Types.EncodeType(typeof(object));
				}
			}
			else if (World.Types.IsSupported(type))
			{
				typeReference.Type = World.Types.EncodeType(type);
			}
			else
			{
				if (nullOnUnsupported)
				{
					return null;
				}
				typeReference.Type = World.Types.EncodeType(typeof(object));
			}
			return typeReference;
		}

		private Type GetGenericInstance(Type type)
		{
			Type element = ((!type.IsValueType || !type.IsNested) ? type : type.DeclaringType);
			DefaultGenericTypeAttribute customAttribute = element.GetCustomAttribute<DefaultGenericTypeAttribute>();
			if (customAttribute != null)
			{
				return type.MakeGenericType(customAttribute.Types);
			}
			Type type2 = element.GetCustomAttribute<GenericTypesAttribute>()?.Types?.FirstOrDefault();
			if (type2 != null)
			{
				return type.MakeGenericType(type2);
			}
			throw new InvalidOperationException($"Cannot determine generic instance for type {type}");
		}

		public EnumDefinition GetEnumDefinition(Type type)
		{
			if (!type.IsEnum)
			{
				throw new ArgumentException("This type is not an enum");
			}
			EnumDefinition enumDefinition = new EnumDefinition();
			enumDefinition.Type = GetTypeDefinition(type, includeBaseType: false);
			enumDefinition.BackingType = World.Types.EncodeType(Enum.GetUnderlyingType(type));
			enumDefinition.Values = new Dictionary<string, long>();
			if (type.ContainsGenericParameters)
			{
				type = GetGenericInstance(type);
			}
			foreach (EnumMember member in EnumsNET.Enums.GetMembers(type))
			{
				enumDefinition.Values.Add(member.Name, ((IConvertible)member.Value).ToInt64(null));
			}
			enumDefinition.IsFlags = type.GetCustomAttribute<FlagsAttribute>() != null;
			return enumDefinition;
		}

		private GenericParameter GetGenericParameter(Type parameter)
		{
			if (!parameter.IsGenericParameter)
			{
				throw new InvalidOperationException();
			}
			GenericParameter genericParameter = new GenericParameter();
			genericParameter.Name = parameter.Name;
			Type[] genericParameterConstraints = parameter.GetGenericParameterConstraints();
			foreach (Type type in genericParameterConstraints)
			{
				if (type == typeof(ValueType))
				{
					object[] customAttributes = type.GetCustomAttributes(inherit: true);
					if (customAttributes != null && customAttributes.Any((object a) => a.GetType().Name == "IsUnmanagedAtrribute"))
					{
						genericParameter.Unmanaged = true;
					}
					else
					{
						genericParameter.Struct = true;
					}
					continue;
				}
				if (type == typeof(Enum))
				{
					genericParameter.Enum = true;
					continue;
				}
				TypeReference typeReference = GetTypeReference(type, nullOnUnsupported: true);
				if (typeReference != null)
				{
					if (genericParameter.Types == null)
					{
						genericParameter.Types = new List<TypeReference>();
					}
					genericParameter.Types.Add(typeReference);
				}
			}
			if (parameter.GenericParameterAttributes.HasFlag(GenericParameterAttributes.ReferenceTypeConstraint))
			{
				genericParameter.Class = true;
			}
			return genericParameter;
		}

		private Dictionary<string, MemberDefinition> CollectMemberDefinitions(Type containerType, bool flattened)
		{
			WorkerInitInfo initInfo = WorkerInitializer.GetInitInfo(containerType);
			Dictionary<string, MemberDefinition> dictionary = new Dictionary<string, MemberDefinition>();
			for (int i = 0; i < initInfo.syncMemberFields.Length; i++)
			{
				FieldInfo fieldInfo = initInfo.syncMemberFields[i];
				if (flattened || !(fieldInfo.DeclaringType != containerType))
				{
					MemberDefinition memberDefinition = BuildMemberDefinition(fieldInfo.FieldType, flattened);
					if (memberDefinition != null)
					{
						string key = initInfo.syncMemberNames[i];
						dictionary.Add(key, memberDefinition);
					}
				}
			}
			return dictionary;
		}

		private List<SyncMethodDefinition> CollectMethodDefinitions(Type containerType, bool flattened)
		{
			WorkerInitInfo initInfo = WorkerInitializer.GetInitInfo(containerType);
			List<SyncMethodDefinition> list = new List<SyncMethodDefinition>();
			if (initInfo.syncMethods != null)
			{
				SyncMethodInfo[] syncMethods = initInfo.syncMethods;
				for (int i = 0; i < syncMethods.Length; i++)
				{
					SyncMethodInfo info = syncMethods[i];
					if (flattened || !(info.method.DeclaringType != containerType))
					{
						SyncMethodDefinition syncMethodDefinition = BuildMethodDefinition(info);
						if (syncMethodDefinition != null)
						{
							list.Add(syncMethodDefinition);
						}
					}
				}
			}
			if (initInfo.staticSyncMethods != null)
			{
				SyncMethodInfo[] syncMethods = initInfo.staticSyncMethods;
				for (int i = 0; i < syncMethods.Length; i++)
				{
					SyncMethodInfo info2 = syncMethods[i];
					if (flattened || !(info2.method.DeclaringType != containerType))
					{
						SyncMethodDefinition syncMethodDefinition2 = BuildMethodDefinition(info2);
						syncMethodDefinition2.IsStatic = true;
						if (syncMethodDefinition2 != null)
						{
							list.Add(syncMethodDefinition2);
						}
					}
				}
			}
			return list;
		}

		public MemberDefinition BuildMemberDefinition(Type memberType, bool flattened)
		{
			if (typeof(ISyncDelegate).IsAssignableFrom(memberType))
			{
				return null;
			}
			if (typeof(SyncPlayback).IsAssignableFrom(memberType))
			{
				return BuildSyncPlaybackDefinition(memberType);
			}
			if (typeof(SyncObject).IsAssignableFrom(memberType))
			{
				return BuildSyncObjectMemberDefinition(memberType, flattened);
			}
			if (typeof(ISyncDictionary).IsAssignableFrom(memberType))
			{
				return BuildDictionaryDefinition(memberType, flattened);
			}
			if (typeof(ISyncArray).IsAssignableFrom(memberType))
			{
				return BuildArrayDefinition(memberType);
			}
			if (typeof(ISyncList).IsAssignableFrom(memberType))
			{
				return BuildListDefinition(memberType, flattened);
			}
			if (typeof(ISyncRef).IsAssignableFrom(memberType))
			{
				return BuildReferenceDefinition(memberType);
			}
			if (typeof(IField).IsAssignableFrom(memberType))
			{
				return BuildFieldDefinition(memberType);
			}
			if (typeof(EmptySyncElement).IsAssignableFrom(memberType))
			{
				return BuildEmptyElementDefinition(memberType);
			}
			return null;
		}

		public FieldDefinition BuildFieldDefinition(Type memberType)
		{
			FieldDefinition obj = new FieldDefinition
			{
				Type = GetTypeReference(memberType)
			};
			Type type = memberType.EnumerateInterfacesRecursively().First((Type t) => t.IsGenericType && t.GetGenericTypeDefinition() == typeof(IField<>)).GetGenericArguments()[0];
			obj.ValueType = GetTypeReference(type);
			return obj;
		}

		public SyncObjectMemberDefinition BuildSyncObjectMemberDefinition(Type memberType, bool flattened)
		{
			return new SyncObjectMemberDefinition
			{
				Type = GetTypeReference(memberType)
			};
		}

		public SyncPlaybackDefinition BuildSyncPlaybackDefinition(Type memberType)
		{
			return new SyncPlaybackDefinition
			{
				Type = GetTypeReference(memberType)
			};
		}

		public ReferenceDefinition BuildReferenceDefinition(Type memberType)
		{
			ReferenceDefinition obj = new ReferenceDefinition
			{
				Type = GetTypeReference(memberType)
			};
			Type type = memberType.EnumerateInterfacesRecursively().First((Type t) => t.IsGenericType && t.GetGenericTypeDefinition() == typeof(ISyncRef<>)).GetGenericArguments()[0];
			obj.TargetType = GetTypeReference(type);
			return obj;
		}

		public ListDefinition BuildListDefinition(Type memberType, bool flattened)
		{
			ListDefinition listDefinition = new ListDefinition();
			listDefinition.Type = GetTypeReference(memberType);
			Type memberType2 = memberType.FindGenericBaseClass(typeof(SyncElementList<>)).GetGenericArguments()[0];
			listDefinition.ElementDefinition = BuildMemberDefinition(memberType2, flattened);
			if (listDefinition.ElementDefinition == null)
			{
				return null;
			}
			return listDefinition;
		}

		public DictionaryDefinition BuildDictionaryDefinition(Type memberType, bool flattened)
		{
			DictionaryDefinition dictionaryDefinition = new DictionaryDefinition();
			dictionaryDefinition.Type = GetTypeReference(memberType);
			Type[] genericArguments = memberType.FindGenericBaseClass(typeof(SyncDictionary<, >)).GetGenericArguments();
			Type type = genericArguments[0];
			Type memberType2 = genericArguments[1];
			dictionaryDefinition.KeyType = GetTypeReference(type);
			dictionaryDefinition.ElementDefinition = BuildMemberDefinition(memberType2, flattened);
			if (dictionaryDefinition.ElementDefinition == null)
			{
				return null;
			}
			return dictionaryDefinition;
		}

		public ArrayDefinition BuildArrayDefinition(Type memberType)
		{
			ArrayDefinition obj = new ArrayDefinition
			{
				Type = GetTypeReference(memberType)
			};
			Type type = memberType.FindGenericBaseClass(typeof(SyncArray<>)).GetGenericArguments()[0];
			obj.ValueType = GetTypeReference(type);
			return obj;
		}

		public EmptyMemberDefinition BuildEmptyElementDefinition(Type memberType)
		{
			return new EmptyMemberDefinition
			{
				Type = GetTypeReference(memberType)
			};
		}

		public SyncMethodDefinition BuildMethodDefinition(SyncMethodInfo info)
		{
			SyncMethodDefinition syncMethodDefinition = new SyncMethodDefinition();
			MethodInfo method = info.method;
			syncMethodDefinition.Name = method.Name;
			Type type = method.ReturnType;
			if (type.IsGenericType && type.GetGenericTypeDefinition() == typeof(Task<>))
			{
				syncMethodDefinition.IsAsync = true;
				type = type.GetGenericArguments()[0];
			}
			syncMethodDefinition.ReturnType = GetTypeReference(type, nullOnUnsupported: true);
			if (syncMethodDefinition.ReturnType == null)
			{
				return null;
			}
			ParameterInfo[] parameters = method.GetParameters();
			foreach (ParameterInfo parameterInfo in parameters)
			{
				TypeReference typeReference = GetTypeReference(parameterInfo.ParameterType, nullOnUnsupported: true);
				if (typeReference == null)
				{
					return null;
				}
				syncMethodDefinition.Parameters.Add(parameterInfo.Name, typeReference);
			}
			return syncMethodDefinition;
		}
	}
	public class ResoniteLinkHost : IDisposable
	{
		private readonly struct OutgoingMessage
		{
			public readonly ClientMetadata client;

			public readonly string json;

			public OutgoingMessage(ClientMetadata client, string json)
			{
				this.client = client;
				this.json = json;
			}
		}

		public const string FEATURE_FLAG = "RESONITE_LINK";

		private WatsonWsServer _server;

		private ActionBlock<OutgoingMessage> _messageSender;

		private Dictionary<ClientMetadata, ResoniteLinkService> _handlers = new Dictionary<ClientMetadata, ResoniteLinkService>();

		private int _sessionPool;

		private DateTime _lastAnnoucement;

		public World World { get; private set; }

		public int Port { get; private set; } = -1;

		public ResoniteLinkReferenceManager References { get; private set; }

		public ResoniteLinkTranslator Translator { get; private set; }

		public ResoniteLinkAssetImporter AssetImporter { get; private set; }

		public ResoniteLinkReflection Reflection { get; private set; }

		public bool CanRead => World.CanResoniteLinkRead();

		public bool CanWrite => World.CanResoniteLinkWrite();

		public ResoniteLinkHost(World world)
		{
			World = world;
			References = new ResoniteLinkReferenceManager();
			Translator = new ResoniteLinkTranslator(this, References);
			AssetImporter = new ResoniteLinkAssetImporter(this);
			Reflection = new ResoniteLinkReflection(this);
			References.RegisterReference("Root", world.RootSlot);
		}

		public void Update()
		{
			if (Port > 0 && DateTime.UtcNow - _lastAnnoucement > LinkSessionListener.ANNOUNCE_INTERVAL)
			{
				_lastAnnoucement = DateTime.UtcNow;
				World.Engine.SessionAnnouncer.LAN_Announcer.AnnounceResoniteLink(World.SessionId, World.RawName, Port);
			}
		}

		internal bool Start(int? port)
		{
			if (!CanRead && !CanWrite)
			{
				throw new InvalidOperationException("ResoniteLink is not allowed in this world, cannot start");
			}
			bool flag = false;
			do
			{
				try
				{
					Port = port ?? RandomX.Range(2000, 65535);
					_server = new WatsonWsServer("localhost", Port);
					_server.ClientConnected += ClientConnected;
					_server.ClientDisconnected += ClientDisconnected;
					_server.MessageReceived += MessageReceived;
					_server.Start();
					flag = true;
				}
				catch (Exception value)
				{
					UniLog.Log($"Failed to start on port {Port}. Trying next one. Error:\n{value}");
				}
			}
			while (!flag && !port.HasValue);
			if (flag)
			{
				UniLog.Log($"ResoniteLink Started on port: {Port} for world: {World.RawName}");
			}
			else
			{
				UniLog.Log($"Failed to start ResoniteLink on port: {port}");
			}
			_messageSender = new ActionBlock<OutgoingMessage>(async delegate(OutgoingMessage message)
			{
				if (!(await _server.SendAsync(message.client.Guid, message.json)))
				{
					UniLog.Log($"Failed to send message to client: {message.client}");
				}
			});
			return flag;
		}

		private void MessageReceived(object? sender, MessageReceivedEventArgs e)
		{
			_handlers[e.Client].OnMessage(e);
		}

		private void ClientDisconnected(object? sender, DisconnectionEventArgs e)
		{
			_handlers[e.Client].OnClose(e);
			_handlers.Remove(e.Client);
		}

		private void ClientConnected(object? sender, WatsonWebsocket.ConnectionEventArgs e)
		{
			ResoniteLinkService value = new ResoniteLinkService(this, _sessionPool++.ToString(), e.Client);
			_handlers.Add(e.Client, value);
		}

		internal void Send(ClientMetadata client, string json)
		{
			_messageSender.Post(new OutgoingMessage(client, json));
		}

		public void Dispose()
		{
			_server.Stop();
			_messageSender.Complete();
			if (Port > 0)
			{
				World.Engine.SessionAnnouncer.LAN_Announcer.AnnounceResoniteLinkEnded(World.SessionId);
			}
		}
	}
