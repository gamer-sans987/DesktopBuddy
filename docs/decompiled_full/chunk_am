	public static class WorldOptimizer
	{
		public enum CleanupMode
		{
			MarkNonpersistent,
			Destroy
		}

		public static int CleanupAssets(World world, bool ignoreNonpersistentUsers = true, CleanupMode mode = CleanupMode.MarkNonpersistent)
		{
			Slot assetsSlot = world.AssetsSlot;
			if (assetsSlot == null)
			{
				return 0;
			}
			int result = CleanupUnreferencedAssets(assetsSlot, ignoreNonpersistentUsers, mode);
			if (mode == CleanupMode.MarkNonpersistent)
			{
				CleanupSlotsWithNonpersistentComponents(assetsSlot, includingSelf: false);
				return result;
			}
			CleanupEmptySlots(assetsSlot, includingSelf: false);
			return result;
		}

		public static int CleanupUnreferencedAssets(Slot root, bool ignoreNonpersistentUsers = true, CleanupMode mode = CleanupMode.MarkNonpersistent)
		{
			int num = 0;
			HashSet<IAssetProvider> hashSet = Pool.BorrowHashSet<IAssetProvider>();
			List<IAssetProvider> list = Pool.BorrowList<IAssetProvider>();
			root.GetComponentsInChildren(list, (IAssetProvider a) => a.Slot.AllowOptimization());
			foreach (IAssetProvider item in list)
			{
				hashSet.Clear();
				if (!IsReferencedOutsideHierarchy(item, root, ignoreNonpersistentUsers, hashSet))
				{
					num++;
					switch (mode)
					{
					case CleanupMode.MarkNonpersistent:
						((Component)item).Persistent = false;
						break;
					case CleanupMode.Destroy:
						item.Destroy();
						break;
					default:
						throw new Exception("Invalid mode: " + mode);
					}
				}
			}
			Pool.Return(ref hashSet);
			Pool.Return(ref list);
			return num;
		}

		public static bool IsReferencedOutsideHierarchy(IAssetProvider assetProvider, Slot hierarchyRoot, bool ignoreNonpersistentUsers = true, HashSet<IAssetProvider> walked = null)
		{
			if (walked == null)
			{
				walked = new HashSet<IAssetProvider>();
			}
			if (walked.Contains(assetProvider))
			{
				return false;
			}
			walked.Add(assetProvider);
			foreach (IAssetRef reference in assetProvider.References)
			{
				if (!ignoreNonpersistentUsers || reference.IsPersistent)
				{
					if (!reference.FindNearestParent<Slot>().IsChildOf(hierarchyRoot, includeSelf: true))
					{
						return true;
					}
					if (reference.FindNearestParent<Component>() is IAssetProvider assetProvider2 && IsReferencedOutsideHierarchy(assetProvider2, hierarchyRoot, ignoreNonpersistentUsers, walked))
					{
						return true;
					}
				}
			}
			return false;
		}

		public static void CleanupSlotsWithNonpersistentComponents(Slot root, bool includingSelf = true)
		{
			for (int num = root.ChildrenCount - 1; num >= 0; num--)
			{
				CleanupSlotsWithNonpersistentComponents(root[num]);
			}
			if (includingSelf && root.Components.Count((Component c) => c.Persistent) == 0 && root.Children.Count((Slot ch) => ch.PersistentSelf) == 0)
			{
				root.PersistentSelf = false;
			}
		}

		public static int CleanupEmptySlots(Slot root, bool includingSelf = true)
		{
			int num = 0;
			for (int num2 = root.ChildrenCount - 1; num2 >= 0; num2--)
			{
				num += CleanupEmptySlots(root[num2]);
			}
			if (includingSelf && root.ComponentCount == 0 && root.ChildrenCount == 0)
			{
				root.Destroy();
				num++;
			}
			return num;
		}

		public static void CleanupBrokenLocalAssets(World world)
		{
			world.Coroutines.StartTask(async delegate
			{
				foreach (IStaticAssetProvider provider in world.RootSlot.GetComponentsInChildren<IStaticAssetProvider>())
				{
					if (provider.URL != null && provider.URL.Scheme == "local")
					{
						AssetRecord assetRecord = await world.Engine.LocalDB.TryFetchAssetRecordAsync(provider.URL).ConfigureAwait(continueOnCapturedContext: false);
						if (assetRecord == null || !File.Exists(assetRecord.path))
						{
							provider.Destroy();
						}
					}
				}
			});
		}

		public static int DeduplicateStaticProviders(World world)
		{
			return DeduplicateStaticProviders(world.AssetsSlot, world.RootSlot);
		}

		public static int DeduplicateStaticProviders(Slot root, Slot replaceRoot = null)
		{
			int num = 0;
			List<IStaticAssetProvider> list = Pool.BorrowList<IStaticAssetProvider>();
			Dictionary<IWorldElement, IWorldElement> dictionary = Pool.BorrowDictionary<IWorldElement, IWorldElement>();
			root.GetComponentsInChildren(list);
			DictionaryList<Type, IStaticAssetProvider> dictionary2 = Pool.BorrowDictionaryList<Type, IStaticAssetProvider>();
			foreach (IStaticAssetProvider item in list)
			{
				dictionary2.Add(item.GetType(), item);
			}
			Pool.Return(ref list);
			foreach (KeyValuePair<Type, List<IStaticAssetProvider>> item2 in dictionary2)
			{
				for (int i = 0; i < item2.Value.Count; i++)
				{
					Component component = (Component)item2.Value[i];
					for (int num2 = item2.Value.Count - 1; num2 > i; num2--)
					{
						Component component2 = (Component)item2.Value[num2];
						if (component.PublicMembersEqual(component2))
						{
							dictionary.Add(component2, component);
							item2.Value.RemoveAt(num2);
							num++;
						}
					}
				}
			}
			Pool.Return(ref dictionary2);
			root.World.ReplaceReferenceTargets(dictionary, nullIfIncompatible: false, replaceRoot ?? root?.World.RootSlot);
			foreach (KeyValuePair<IWorldElement, IWorldElement> item3 in dictionary)
			{
				if (((IStaticAssetProvider)item3.Key).AssetReferenceCount <= 0)
				{
					((Component)item3.Key).Destroy();
				}
			}
			Pool.Return(ref dictionary);
			return num;
		}
	}
