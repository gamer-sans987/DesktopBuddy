	public static class Settings
	{
		private interface ISettingListenerCollection
		{
			Type SettingType { get; }

			SettingComponent CurrentComponent { get; }

			void ComponentUpdated(SettingComponent component);

			void ValueUpdated(SettingComponent component);
		}

		private class SettingListenerCollection<T> : ISettingListenerCollection where T : SettingComponent
		{
			public readonly HashSet<SettingUpdateHandler<T>> componentUpdateListeners = new HashSet<SettingUpdateHandler<T>>();

			public readonly HashSet<SettingUpdateHandler<T>> valueUpdateListeners = new HashSet<SettingUpdateHandler<T>>();

			public readonly DictionaryHashSet<string, SettingSubcategoryUpdateHandler<T>> subcategoryUpdateListeners = new DictionaryHashSet<string, SettingSubcategoryUpdateHandler<T>>();

			public Type SettingType => typeof(T);

			public T CurrentComponent { get; private set; }

			SettingComponent ISettingListenerCollection.CurrentComponent => CurrentComponent;

			public bool RegisterComponentUpdateListener(SettingUpdateHandler<T> handler)
			{
				return componentUpdateListeners.Add(handler);
			}

			public bool RegisterValueUpdateListener(SettingUpdateHandler<T> handler)
			{
				return valueUpdateListeners.Add(handler);
			}

			public bool RegisterSubcategoryUpdateListener(SettingSubcategoryUpdateHandler<T> handler, string subcategory)
			{
				return subcategoryUpdateListeners.Add(subcategory, handler);
			}

			public bool UnregisterComponentUpdateListener(SettingUpdateHandler<T> handler)
			{
				return componentUpdateListeners.Remove(handler);
			}

			public bool UnregisterValueUpdateListener(SettingUpdateHandler<T> handler)
			{
				return valueUpdateListeners.Remove(handler);
			}

			public bool UnregisterSubcategoryUpdateListener(SettingSubcategoryUpdateHandler<T> handler, string subcategory)
			{
				return subcategoryUpdateListeners.Remove(subcategory, handler);
			}

			public void ComponentUpdated(SettingComponent component)
			{
				T val = (T)component;
				if (CurrentComponent == val)
				{
					return;
				}
				CurrentComponent?.RunDeactivated();
				CurrentComponent = val;
				CurrentComponent?.RunActivated();
				foreach (SettingUpdateHandler<T> componentUpdateListener in componentUpdateListeners)
				{
					componentUpdateListener(CurrentComponent);
				}
				foreach (SettingUpdateHandler<T> valueUpdateListener in valueUpdateListeners)
				{
					valueUpdateListener(CurrentComponent);
				}
				foreach (KeyValuePair<string, HashSet<SettingSubcategoryUpdateHandler<T>>> subcategoryUpdateListener in subcategoryUpdateListeners)
				{
					foreach (SettingSubcategoryUpdateHandler<T> item in subcategoryUpdateListener.Value)
					{
						item(CurrentComponent, subcategoryUpdateListener.Key, null, DataFeedItemChange.PathItemsInvalidated);
					}
				}
			}

			public void ValueUpdated(SettingComponent component)
			{
				if (CurrentComponent != (T)component)
				{
					return;
				}
				foreach (SettingUpdateHandler<T> valueUpdateListener in valueUpdateListeners)
				{
					try
					{
						valueUpdateListener(CurrentComponent);
					}
					catch (Exception ex)
					{
						UniLog.Error("Exception notifying listener of updated setting value.\n" + ex);
					}
				}
			}

			public void SubcategoryElementUpdate(SettingComponent component, string subcategory, DataFeedItem item, DataFeedItemChange change)
			{
				if (CurrentComponent != (T)component)
				{
					return;
				}
				HashSet<SettingSubcategoryUpdateHandler<T>> hashSet = subcategoryUpdateListeners.TryGetSet(subcategory);
				if (hashSet == null)
				{
					return;
				}
				foreach (SettingSubcategoryUpdateHandler<T> item2 in hashSet)
				{
					item2(CurrentComponent, subcategory, item, change);
				}
			}
		}

