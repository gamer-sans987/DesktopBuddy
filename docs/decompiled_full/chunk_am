				}
			}
			update.boneAssignments = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<BoneAssignment>);
			update.boneTransformIndexes = sharedMemoryBlockLease2?.Descriptor ?? default(SharedMemoryBufferDescriptor<int>);
