					MeshX meshX = data.mesh.Data;
					if (data.renderer is SkinnedMeshRenderer && !skinnedMeshMode)
					{
						meshX = new MeshX(meshX);
						meshX.BakeBlendShapes(data.blendshapeWeights);
						if (data.boneTransforms.Length != 0)
						{
							meshX.BakeSkinnedMesh(data.boneTransforms);
						}
					}
					data.appendResult = combinedMesh.Append(meshX, appendSubmeshes: true, in data.transform, delegate(Elements.Assets.Submesh submesh)
					{
						IAssetProvider<Material> material = data.materials.ElementAtOrDefault(submesh.Index) ?? data.materials.LastOrDefault();
						MappingKey key = new MappingKey(material, submesh.Topology);
						if (!submeshMapping.TryGetValue(key, out var value))
						{
							value = submeshMapping.Count;
							submeshMapping.Add(key, value);
						}
						return value;
					});
					if (data.appendResult.boneMapping != null && data.bones != null)
					{
						for (int num = 0; num < data.appendResult.boneMapping.Count; num++)
						{
							if (data.appendResult.boneMapping[num] >= boneMapping.Count && num < data.bones.Count)
							{
								boneMapping.Add(data.bones[num]);
							}
						}
					}
					if (data.appendResult.blendshapeMapping == null || data.blendshapes == null)
					{
						continue;
					}
					for (int num2 = 0; num2 < data.appendResult.blendshapeMapping.Count; num2++)
					{
						int num3 = data.appendResult.blendshapeMapping[num2];
						while (blendshapeMapping.Count <= num3)
						{
							blendshapeMapping.Add(new List<Sync<float>>());
						}
						if (num2 < data.blendshapes.Count)
						{
							blendshapeMapping[num3].Add(data.blendshapes[num2]);
						}
					}
				}
				finally
				{
					data.mesh.ReleaseReadLock(assetLock);
				}
			}
			Uri meshUrl = await root.Engine.LocalDB.SaveAssetAsync(combinedMesh).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToWorld);
			Slot slot = root.Parent.AddSlot(root.Name + " (Baked)");
			slot.CopyTransform(root);
			slot.PersistentSelf = root.PersistentSelf;
			slot.ActiveSelf = root.ActiveSelf;
			slot.Tag = root.Tag;
			if (addProtection)
			{
				slot.AttachComponent<SimpleAvatarProtection>();
			}
			Slot slot2 = ((assetsSlot != null) ? assetsSlot : root.World.AssetsSlot.AddSlot(root.Name + " - Baked Mesh"));
			StaticMesh staticMesh = slot2.AttachComponent<StaticMesh>();
			staticMesh.URL.Value = meshUrl;
			MeshRenderer meshRenderer;
			if (skinnedMeshMode)
			{
				SkinnedMeshRenderer skinnedMeshRenderer2 = slot.AttachComponent<SkinnedMeshRenderer>();
				skinnedMeshRenderer2.Mesh.Target = staticMesh;
				skinnedMeshRenderer2.Bones.AddRange(boneMapping);
				for (int num4 = 0; num4 < blendshapeMapping.Count; num4++)
				{
					Sync<float> newShape = skinnedMeshRenderer2.BlendShapeWeights.Add();
					foreach (Sync<float> oldShape in blendshapeMapping[num4])
					{
						if (oldShape == null)
						{
							continue;
						}
						world.ForeachWorldElement(delegate(ISyncRef syncRef)
						{
							if (syncRef.Target == oldShape)
							{
								syncRef.Target = newShape;
							}
						});
					}
				}
				meshRenderer = skinnedMeshRenderer2;
			}
			else
			{
				meshRenderer = slot.AttachComponent<MeshRenderer>();
				meshRenderer.Mesh.Target = staticMesh;
				Grabbable componentInChildren = root.GetComponentInChildren<Grabbable>();
				bool flag = false;
				if (componentInChildren != null && grabbableHandling == ComponentHandling.IfExists)
				{
					slot.DuplicateComponent(componentInChildren);
					flag = true;
				}
				else if (grabbableHandling == ComponentHandling.AlwaysAdd)
				{
					componentInChildren = slot.AttachComponent<Grabbable>();
					componentInChildren.Scalable.Value = true;
					flag = true;
				}
				if ((flag && colliderHandling != ComponentHandling.NeverAdd) || colliderHandling == ComponentHandling.AlwaysAdd)
				{
					slot.AttachComponent<MeshCollider>().Mesh.Target = staticMesh;
				}
				if (root.GetComponent<ObjectRoot>() != null)
				{
					slot.AttachComponent<ObjectRoot>();
				}
			}
			foreach (KeyValuePair<MappingKey, int> item in submeshMapping)
			{
				meshRenderer.Materials.Add(item.Key.material);
			}
			root.GetComponentsInChildren<IMeshBakeEventReceiver>().ForEach(delegate(IMeshBakeEventReceiver r)
			{
				r.OnMeshBaked(meshRenderer, destroyOriginal);
			});
			if (undoable)
			{
				world.BeginUndoBatch(root.GetLocalized("Undo.BakeMeshes", null, "name", root.Name));
				slot.CreateSpawnUndoPoint();
			}
			if (destroyOriginal)
			{
				if (skinnedMeshMode)
				{
					foreach (MeshData item2 in bakeData)
					{
						Slot slot3 = item2.renderer.Slot;
						if (undoable)
						{
							item2.renderer.UndoableDestroy();
						}
						else
						{
							item2.renderer.Destroy();
						}
						if (slot3.ComponentCount > 0)
						{
							slot3.Parent = slot;
						}
					}
				}
				if (undoable)
				{
					root.UndoableDestroyPreservingAssets();
				}
				else
				{
					root.DestroyPreservingAssets(slot);
				}
			}
			if (undoable)
			{
				world.EndUndoBatch();
			}
			return slot;
		}
	}
