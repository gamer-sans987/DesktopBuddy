		internal bool AssignConnection(HSteamNetConnection connection, int channel)
		{
			if (state != State.Connecting)
			{
				return false;
			}
			if (connectionsConnected[channel])
			{
				return false;
			}
			UniLog.Log($"Assigning Connection: {connection}, channel: {channel}");
			connections[channel] = connection;
			connectionsConnected[channel] = true;
			SteamNetworkingSockets.SetConnectionPollGroup(connection, pollGroup);
			if (AllConnected())
			{
				UniLog.Log($"All connections assigned, connection open for remoteID: {remoteId}, connections: {string.Join(", ", connections)}");
				state = State.Open;
			}
			return true;
		}

		internal void Update(nint[] buffer)
		{
			try
			{
				if (IsOpen)
				{
					SteamNetworkManager.ExtractMessages(SteamNetworkingSockets.ReceiveMessagesOnPollGroup(pollGroup, buffer, buffer.Length), buffer, _messageHandler, _connectionFailureHandler, _reassemblyStateFetcher);
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception updating SteamConnection:\n{value}");
