		private void RunImportTask(ResoniteLinkService service, ResoniteLink.Message sourceMessage, Func<Task<Uri>> importTask)
		{
			World.Coroutines.StartBackgroundTask(async delegate
			{
				_ = 1;
				try
				{
					Uri assetURL = await importTask();
					ResoniteLink.AssetData response = new ResoniteLink.AssetData
					{
						AssetURL = assetURL,
						Success = true
					};
					await default(ToWorld);
					service.SendResponse(sourceMessage, response);
				}
				catch (Exception ex)
				{
					service.SendErrorResponse<ResoniteLink.AssetData>(sourceMessage, ex.Message);
				}
			});
		}

