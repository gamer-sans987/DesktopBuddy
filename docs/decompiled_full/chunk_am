		{
			World = null;
		}

		public async Task RenderToFile(RenderTask renderSettings, string file, int quality = 200)
		{
			Bitmap2D bitmap = await RenderToBitmap(renderSettings).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToBackground);
			bitmap.Save(file, quality);
		}

		public async Task<Bitmap2D> RenderToBitmap(RenderTask task, bool willHandleBuffer = false)
		{
			RenderVector2i size = task.parameters.resolution;
			Bitmap2D bitmap;
			if (IsRenderingSupported)
			{
				bitmap = new Bitmap2D(size.x, size.y, task.parameters.textureFormat, mipmaps: false, ColorProfile.sRGB, flipY: true, null, Render);
				task.task = new TaskCompletionSource<bool>();
				task.bitmap = bitmap;
				lock (_scheduledRenderTasks)
				{
					_scheduledRenderTasks.Add(task);
				}
				await task.task.Task.ConfigureAwait(continueOnCapturedContext: false);
				await default(ToBackground);
				if (task.customPostProcess != null)
				{
					Bitmap2D bitmap2D = task.customPostProcess(bitmap);
					if (bitmap != bitmap2D)
					{
						bitmap.Buffer.Dispose();
						willHandleBuffer = false;
					}
					bitmap = bitmap2D;
				}
				if (!willHandleBuffer)
				{
					bitmap.EnsureManagedMemoryBuffer();
				}
			}
			else
			{
				await default(ToBackground);
				bitmap = TextureDecoder.GenerateErrorTexture(size.x, size.y, task.parameters.textureFormat);
			}
			return bitmap;
		}

		public async Task<Uri> RenderToAsset(RenderTask renderSettings, string format = "webp", int quality = 200)
		{
			string file = World.Engine.LocalDB.GetTempFilePath(format);
			await RenderToFile(renderSettings, file, quality).ConfigureAwait(continueOnCapturedContext: false);
			return await DB.ImportLocalAssetAsync(file, LocalDB.ImportLocation.Move).ConfigureAwait(continueOnCapturedContext: false);
		}

		public async Task<StaticTexture2D> RenderToStaticTexture(RenderTask renderSettings, Slot slot, string format = "webp", int quality = 200, Job<StaticTexture2D> task = null)
		{
			string file = World.Engine.LocalDB.GetTempFilePath(format);
			await RenderToFile(renderSettings, file, quality).ConfigureAwait(continueOnCapturedContext: false);
			if (!File.Exists(file))
			{
				return null;
			}
			Uri uri = await DB.ImportLocalAssetAsync(file, LocalDB.ImportLocation.Move).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToWorld);
			StaticTexture2D staticTexture2D = slot.AttachComponent<StaticTexture2D>();
			staticTexture2D.URL.Value = uri;
			return staticTexture2D;
		}
