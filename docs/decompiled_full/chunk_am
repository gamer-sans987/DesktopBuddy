		private void HandleMessageSynchronously(ResoniteLink.Message message, BatchResponse batch, ResoniteLinkUpdateContext context = null)
		{
			try
			{
				bool flag = false;
				if (context == null)
				{
					context = new ResoniteLinkUpdateContext(Translator);
					flag = true;
				}
				if (!(message is RequestSessionData))
				{
					if (!(message is GetSlot getSlot))
					{
						if (!(message is AddSlot addSlot))
						{
							if (!(message is UpdateSlot updateSlot))
							{
								if (!(message is RemoveSlot removeSlot))
								{
									if (!(message is GetComponent getComponent))
									{
										if (!(message is AddComponent addComponent))
										{
											if (!(message is UpdateComponent updateComponent))
											{
												if (!(message is RemoveComponent removeComponent))
												{
													if (!(message is CallSyncMethod callMethod))
													{
														if (!(message is CallStaticSyncMethod callMethod2))
														{
															if (!(message is DataModelOperationBatch dataModelOperationBatch))
															{
																throw new NotImplementedException("Handling for ResoniteLink message type not implemented: " + message.GetType().GetNiceFullName());
															}
															BatchResponse batchResponse = new BatchResponse();
															batchResponse.Responses = new List<Response>();
															foreach (ResoniteLink.Message operation in dataModelOperationBatch.Operations)
															{
																HandleMessageSynchronously(operation, batchResponse, context);
															}
															batchResponse.Success = true;
															SendResponse(dataModelOperationBatch, batchResponse);
														}
														else
														{
															CallStaticMethod(callMethod2, batch);
														}
													}
													else
													{
														CallMethod(callMethod, batch);
													}
												}
												else
												{
													RemoveComponent(removeComponent, batch);
												}
											}
											else
											{
												UpdateComponent(updateComponent, context, batch);
											}
										}
										else
										{
											AddComponent(addComponent, context, batch);
										}
									}
									else
									{
										GetComponent(getComponent, batch);
									}
								}
								else
								{
									RemoveSlot(removeSlot, context, batch);
								}
							}
							else
							{
								UpdateSlot(updateSlot, context, batch);
							}
						}
						else
						{
							AddSlot(addSlot, context, batch);
						}
					}
					else
					{
						GetSlot(getSlot, batch);
					}
				}
				else
				{
					SendResponse(message, new ResoniteLink.SessionData
					{
						Success = true,
						ResoniteVersion = FrooxEngine.Engine.VersionNumber,
						ResoniteLinkVersion = typeof(LinkInterface).Assembly.GetName().Version.ToString(),
						UniqueSessionId = UniqueSessionId
					}, batch);
				}
				if (flag)
				{
					context.ProcessDeferredOperations();
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception processing ResoniteLink message\n{value}");
				SendErrorResponse<Response>(message, $"Exception processing message:\n{value}", batch);
			}
		}

		private bool CheckReadPermission<R>(ResoniteLink.Message message, BatchResponse batch) where R : Response, new()
		{
			if (!Host.CanRead)
			{
				SendErrorResponse<R>(message, "Reading is not allowed in this session", batch);
				return false;
			}
			return true;
		}

		private bool CheckWritePermission<R>(ResoniteLink.Message message, BatchResponse batch) where R : Response
		{
