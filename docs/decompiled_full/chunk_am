	public class MaterialUpdateManager
	{
		private ConcurrentQueue<MaterialProvider> _materialsToUpdate = new ConcurrentQueue<MaterialProvider>();

		private ConcurrentQueue<MaterialPropertyBlockProvider> _propertyBlocksToUpdate = new ConcurrentQueue<MaterialPropertyBlockProvider>();

		public RenderSystem RenderSystem => Engine.RenderSystem;

		public Engine Engine => World.Engine;

		public World World => RenderManager.World;

		public RenderManager RenderManager { get; private set; }

		public MaterialUpdateManager(RenderManager renderManager)
		{
			RenderManager = renderManager;
		}

		internal void RegisterMaterialToUpdate(MaterialProvider provider)
		{
			_materialsToUpdate.Enqueue(provider);
		}

		internal void RegisterPropertyBlockToUpdate(MaterialPropertyBlockProvider provider)
		{
			_propertyBlocksToUpdate.Enqueue(provider);
		}

		public void ProcessUpdate()
		{
			MaterialsUpdateBatch materialsUpdateBatch = new MaterialsUpdateBatch();
			List<SharedMemoryBlockLease> memoryBlocks = Pool.BorrowList<SharedMemoryBlockLease>();
			MaterialUpdateWriter writer = new MaterialUpdateWriter(this, materialsUpdateBatch, memoryBlocks);
			List<MaterialProvider> list = Pool.BorrowList<MaterialProvider>();
			List<MaterialPropertyBlockProvider> list2 = Pool.BorrowList<MaterialPropertyBlockProvider>();
			MaterialProvider result;
			while (_materialsToUpdate.TryDequeue(out result))
			{
				if (!result.IsRemoved)
				{
					if (result.Asset == null)
					{
						result.ClearUpdateStatus();
					}
					else if (result.GenerateMaterialUpdate(ref writer))
					{
						list.Add(result);
					}
				}
			}
			MaterialPropertyBlockProvider result2;
			while (_propertyBlocksToUpdate.TryDequeue(out result2))
			{
				if (!result2.IsRemoved)
				{
					if (result2.Asset == null)
					{
						result2.ClearUpdateStatus();
					}
					else if (result2.GeneratePropertyBlockUpdate(ref writer))
					{
						list2.Add(result2);
					}
				}
			}
			if (list.Count == 0 && list2.Count == 0)
			{
				Pool.Return(ref list);
				Pool.Return(ref list2);
				return;
			}
			materialsUpdateBatch.materialUpdateCount = list.Count;
			writer.FinalizeUpdate();
			int count = BitSpan.ComputeMinimumBufferLength(list.Count + list2.Count);
			SharedMemoryBlockLease<uint> sharedMemoryBlockLease = RenderSystem.AllocateBlock<uint>(count, frameBound: false, this);
			materialsUpdateBatch.instanceChangedBuffer = sharedMemoryBlockLease.Descriptor;
			MaterialUpdateData data = new MaterialUpdateData(World, list, list2, sharedMemoryBlockLease, memoryBlocks);
			RenderSystem.Materials.SendMaterialUpdateBatch(materialsUpdateBatch, data);
		}
	}
