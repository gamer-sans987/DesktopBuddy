		private void RecomputeSettings()
		{
			Dictionary<Type, SettingComponent> dictionary = Pool.BorrowDictionary<Type, SettingComponent>();
			List<SettingSwitchValue> list = Pool.BorrowList<SettingSwitchValue>();
			CollectSettingsRecursive(base.Slot, dictionary, list);
			Pool.Return(ref list);
			foreach (KeyValuePair<Type, SettingComponent> item in dictionary)
			{
				item.Value.RegisterAsActive();
			}
			List<Type> list2 = Pool.BorrowList<Type>();
			Settings.GetSettingTypes(list2);
			foreach (Type item2 in list2)
			{
				if (!dictionary.ContainsKey(item2))
				{
					List<SettingSwitchValue> switches = null;
					MethodInfo method = item2.GetMethod("GetDefaultSettingSwitches", BindingFlags.Static | BindingFlags.Public);
					if (method != null)
					{
						switches = (List<SettingSwitchValue>)method.Invoke(null, new object[1] { base.World });
					}
					UniLog.Log("Instantiating new setting component: " + item2);
					AddSettingComponent(item2, switches).RegisterAsActive();
				}
			}
			Pool.Return(ref dictionary);
		}

		private Slot GetRoot(List<SettingSwitchValue> switches)
		{
			Slot slot = base.Slot;
			if (switches != null)
			{
				switches.Sort((SettingSwitchValue a, SettingSwitchValue b) => string.Compare(a.source.SwitchKey, b.source.SwitchKey, StringComparison.Ordinal));
				foreach (SettingSwitchValue @switch in switches)
				{
					slot = GetSettingSwitch(slot, @switch);
				}
			}
			return slot;
		}

		internal S AddSettingComponent<S>(List<SettingSwitchValue> switches) where S : SettingComponent, new()
		{
			return GetRoot(switches).AddSlot(typeof(S).Name).AttachComponent<S>();
		}

		internal SettingComponent AddSettingComponent(Type settingType, List<SettingSwitchValue> switches)
		{
			return (SettingComponent)GetRoot(switches).AddSlot(settingType.Name).AttachComponent(settingType);
		}

		private Slot GetSettingSwitch(Slot root, SettingSwitchValue value)
		{
			foreach (Slot child in root.Children)
			{
				SettingSwitch component = child.GetComponent<SettingSwitch>();
				if (component != null && component.Matches(value))
				{
					return child;
				}
			}
			Slot slot = root.AddSlot(value.source.SwitchKey);
			value.source.AttachSwitch(slot, value.value);
			return slot;
		}

		public S GetSetting<S>(List<SettingSwitchValue> matchSwitchValues = null) where S : SettingComponent, new()
		{
			Dictionary<Type, SettingComponent> dictionary = Pool.BorrowDictionary<Type, SettingComponent>();
			try
			{
				List<SettingSwitchValue> list = Pool.BorrowList<SettingSwitchValue>();
				CollectSettingsRecursive(base.Slot, dictionary, list, matchSwitchValues);
				Pool.Return(ref list);
				foreach (KeyValuePair<Type, SettingComponent> item in dictionary)
				{
					if (item.Value is S result)
					{
						return result;
					}
				}
			}
			finally
			{
				Pool.Return(ref dictionary);
			}
			return AddSettingComponent<S>(matchSwitchValues);
		}

		private void CollectSettingsRecursive(Slot root, Dictionary<Type, SettingComponent> settings, List<SettingSwitchValue> switches, List<SettingSwitchValue> overrideActiveValues = null)
		{
			foreach (Slot child in root.Children)
			{
				SettingComponent component = child.GetComponent<SettingComponent>();
				if (component == null)
				{
					continue;
				}
				if (!component.IsValidSetOfSwitches(switches))
				{
					UniLog.Log($"Setting {component.WorkerTypeName} has invalid set of switches:\n{string.Join("\n", switches)}\nCleaning up!");
					RunSynchronously(component.Slot.Destroy);
					continue;
				}
				Type type = component.GetType();
				if (settings.TryGetValue(type, out SettingComponent value) && value.Slot.Parent == component.Slot.Parent)
				{
					UniLog.Warning($"Found a duplicate setting of type {type}, cleaning up.\nExisting:\n{value}\nDuplicate:\n{component}");
					RunSynchronously(component.Slot.Destroy);
				}
				else
				{
					settings[component.GetType()] = component;
				}
			}
			foreach (Slot child2 in root.Children)
			{
				SettingSwitch settingSwitch = child2.GetComponent<SettingSwitch>();
				if (settingSwitch == null)
				{
					continue;
				}
				if (overrideActiveValues == null)
				{
					if (!settingSwitch.IsActive(_switchSources))
					{
						continue;
					}
				}
				else if (!overrideActiveValues.Any((SettingSwitchValue v) => settingSwitch.Matches(v)))
				{
					continue;
				}
				switches.Add(settingSwitch.SwitchValue);
				CollectSettingsRecursive(child2, settings, switches);
				switches.RemoveAt(switches.Count - 1);
			}
		}

