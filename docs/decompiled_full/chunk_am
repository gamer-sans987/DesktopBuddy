	public class PlatformInterface : IDisposable
	{
		private static Type[] __connectorTypes;

		private IPlatformConnector[] connectors;

		public Engine Engine { get; private set; }

		public string PlatformName => PrimaryConnector?.PlatformName;

		public string Username => PrimaryConnector?.Username;

		public IPlatformConnector PrimaryConnector
		{
			get
			{
				if (connectors == null || connectors.Length == 0)
				{
					return null;
				}
				return connectors[0];
			}
		}

		internal async Task Initialize(Engine engine)
		{
			Engine = engine;
			if (FrooxEngine.Engine.Config.DisablePlatformInterfaces)
			{
				connectors = Array.Empty<IPlatformConnector>();
				return;
			}
			List<IPlatformConnector> initializedConnectors = new List<IPlatformConnector>();
			for (int i = 0; i < __connectorTypes.Length; i++)
			{
				IPlatformConnector connector = (IPlatformConnector)Activator.CreateInstance(__connectorTypes[i]);
				string platformName = connector.PlatformName;
				if (!ShouldInitializePlatformInterface(platformName, FrooxEngine.Engine.Config))
				{
					UniLog.Log("Skipping initialization of disallowed platform interface: " + platformName);
					continue;
				}
				engine.InitProgress?.SetSubphase("Initializing " + platformName + " Platform Interface");
				try
				{
					if (await connector.Initialize(this))
					{
						initializedConnectors.Add(connector);
					}
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception initializing connector: {connector}\n{value}", stackTrace: false);
				}
			}
			connectors = initializedConnectors.ToArray();
			Array.Sort(connectors, (IPlatformConnector a, IPlatformConnector b) => -a.Priority.CompareTo(b.Priority));
		}

		/// <summary>
		/// Tests to see if a Platform interface should be initialized based on its name and a supplied app config.
		/// </summary>
		/// <param name="platformName"></param>
		/// <param name="config"></param>
		/// <returns>true if the provided platform should be initialized</returns>
		internal static bool ShouldInitializePlatformInterface(string platformName, AppConfig config)
		{
			if (config.DisallowedPlatformInterfaces != null && config.DisallowedPlatformInterfaces.Contains<string>(platformName, StringComparer.InvariantCultureIgnoreCase))
