		public void WriteMemberData(ResoniteLink.Member linkMember, ISyncMember member, ResoniteLinkUpdateContext context)
		{
			if (!string.IsNullOrEmpty(linkMember.ID))
			{
				References.EnsureReference(linkMember.ID, member);
			}
			if (!(member is SyncPlayback playback))
			{
				if (member is EmptySyncElement)
				{
					return;
				}
				if (!(member is SyncObject syncObject))
				{
					if (!(member is ISyncArray array))
					{
						if (!(member is ISyncList syncList))
						{
							if (!(member is ISyncDictionary dictionary))
							{
								if (!(member is ISyncRef reference))
								{
									if (!(member is IField field))
									{
										throw new NotSupportedException("Unsupported member type: " + member.GetType());
									}
									WriteField((Field)linkMember, field);
								}
								else
								{
									context.WriteReference((Reference)linkMember, reference);
								}
							}
							else
							{
								WriteDictionary((SyncDictionary)linkMember, dictionary, context);
							}
						}
						else
						{
							WriteSyncList((SyncList)linkMember, syncList, context);
						}
					}
					else
					{
						WriteArray((SyncArray)linkMember, array);
					}
				}
				else
				{
					WriteSyncObject((ResoniteLink.SyncObject)linkMember, syncObject, context);
				}
			}
			else
			{
				WritePlayback((ResoniteLink.SyncPlayback)linkMember, playback);
			}
		}

		private void WriteSyncObject(ResoniteLink.SyncObject linkObject, SyncObject syncObject, ResoniteLinkUpdateContext context)
		{
			if (linkObject.Members != null)
			{
				WriteMembers(linkObject.Members, syncObject, context);
			}
		}

		private void WritePlayback(ResoniteLink.SyncPlayback linkPlayback, SyncPlayback playback)
		{
			if (linkPlayback.Loop.HasValue)
			{
				playback.Loop = linkPlayback.Loop.Value;
			}
			if (linkPlayback.Speed.HasValue)
			{
				playback.Speed = linkPlayback.Speed.Value;
			}
			if (linkPlayback.Position.HasValue)
			{
				playback.Position = (float)linkPlayback.Position.Value;
			}
			if (linkPlayback.Play.HasValue && playback.IsPlaying != linkPlayback.Play.Value)
			{
				if (linkPlayback.Play.Value)
				{
					playback.Play();
				}
				else
				{
					playback.Pause();
				}
			}
		}

		private void WriteSyncList(SyncList linkList, ISyncList syncList, ResoniteLinkUpdateContext context)
		{
			HashSet<string> hashSet = Pool.BorrowHashSet<string>();
			foreach (ResoniteLink.Member element in linkList.Elements)
			{
				if (!string.IsNullOrEmpty(element.ID) && References.HasID(element.ID))
				{
					hashSet.Add(element.ID);
				}
			}
			for (int i = 0; i < linkList.Elements.Count; i++)
			{
				ResoniteLink.Member member = linkList.Elements[i];
				ISyncMember syncMember;
				if (i >= syncList.Count)
				{
					if (!string.IsNullOrWhiteSpace(member.ID) && hashSet.Contains(member.ID))
					{
						throw new InvalidOperationException("Pre-existing ID in unexpected location in the list. Moving already allocated elements is not supported.");
					}
					syncMember = syncList.AddElement();
				}
				else if (string.IsNullOrWhiteSpace(member.ID))
				{
					syncMember = syncList.GetElement(i);
					string iD = References.GetID(syncMember);
					if (hashSet.Contains(iD))
					{
						syncMember = syncList.InsertElement(i);
					}
				}
				else if (hashSet.Contains(member.ID))
				{
					while (syncList.Count > i && References.GetID(syncList.GetElement(i)) != member.ID)
					{
						syncList.RemoveElement(i);
					}
					if (syncList.Count == i)
					{
						throw new InvalidOperationException("Pre-existing ID not found in the list. Moving already allocated elements is not supported!");
					}
					syncMember = syncList.GetElement(i);
				}
				else
				{
					syncMember = syncList.InsertElement(i);
				}
				WriteMemberData(member, syncMember, context);
			}
			Pool.Return(ref hashSet);
		}

		private void WriteDictionary<TKey, TLinkKey>(SyncDictionary<TLinkKey> linkDict, ISyncDictionary syncDict, Func<TLinkKey, TKey> keyConverter, ResoniteLinkUpdateContext context)
		{
			HashSet<TKey> usedKeys = Pool.BorrowHashSet<TKey>();
			foreach (KeyValuePair<TLinkKey, ResoniteLink.Member> element in linkDict.Elements)
			{
				TKey val = keyConverter(element.Key);
				ISyncMember syncMember = syncDict.TryGetMember(val);
				if (syncMember != null && !string.IsNullOrWhiteSpace(element.Value.ID))
				{
					string text = References.TryGetID(syncMember);
					if (text != null && text != element.Value.ID)
					{
						if (References.HasID(element.Value.ID))
						{
							throw new InvalidOperationException("ID " + element.Value.ID + " has already been assigned to a different element");
						}
						syncDict.RemoveByKey(val);
						syncMember = null;
					}
				}
				if (syncMember == null)
				{
					syncMember = syncDict.Add(val);
				}
				usedKeys.Add(val);
				WriteMemberData(element.Value, syncMember, context);
			}
			syncDict.RemoveAll((KeyValuePair<object, ISyncMember> pair) => !usedKeys.Contains((TKey)pair.Key));
			Pool.Return(ref usedKeys);
		}

		private void WriteEnumDictionary(SyncDictionary_Enum linkDict, ISyncDictionary syncDict, ResoniteLinkUpdateContext context)
		{
			Type enumType = syncDict.KeyType;
			if (!enumType.IsEnum)
			{
				throw new ArgumentException($"Dictionary key type is not an enum: {syncDict}");
			}
			if (!string.IsNullOrEmpty(linkDict.EnumType) && enumType != World.Types.DecodeType(linkDict.EnumType))
			{
				throw new ArgumentException("Enum type mismatch");
			}
			WriteDictionary(linkDict, syncDict, (string str) => EnumsNET.Enums.Parse(enumType, str), context);
		}

		public void WriteSlotData(ResoniteLink.Slot linkSlot, Slot slot, ResoniteLinkUpdateContext context)
		{
			if (linkSlot.Parent != null)
			{
				Slot slot2 = References.ResolveReference<Slot>(linkSlot.Parent.TargetID);
				if (slot2 == null)
				{
					throw new InvalidOperationException("Parent slot can't be null");
				}
				if (!CanProcessSlot(slot2))
				{
					throw new InvalidOperationException("Parent slot is not accessible");
				}
				if (!string.IsNullOrEmpty(linkSlot.Parent.ID))
				{
					References.EnsureReference(linkSlot.Parent.ID, slot.ParentReference);
				}
				slot.Parent = slot2;
			}
			if (linkSlot.Position != null)
			{
				WriteMemberData(linkSlot.Position, slot.Position_Field, context);
			}
			if (linkSlot.Rotation != null)
			{
				WriteMemberData(linkSlot.Rotation, slot.Rotation_Field, context);
			}
			if (linkSlot.Scale != null)
			{
				WriteMemberData(linkSlot.Scale, slot.Scale_Field, context);
			}
			if (linkSlot.IsActive != null)
			{
				WriteMemberData(linkSlot.IsActive, slot.ActiveSelf_Field, context);
			}
			if (linkSlot.IsPersistent != null)
			{
				WriteMemberData(linkSlot.IsPersistent, slot.Persistent_Field, context);
			}
			if (linkSlot.Name != null)
			{
				WriteMemberData(linkSlot.Name, slot.Name_Field, context);
			}
			if (linkSlot.Tag != null)
			{
				WriteMemberData(linkSlot.Tag, slot.Tag_Field, context);
			}
			if (linkSlot.OrderOffset != null)
			{
				WriteMemberData(linkSlot.OrderOffset, slot.OrderOffset_Field, context);
			}
			if (linkSlot.Components != null)
			{
				throw new InvalidOperationException("Components cannot be specified when updating slot. Please use Add/Update Component instead");
			}
			if (linkSlot.Children != null)
			{
				throw new InvalidOperationException("Children slots cannot be specified when updating slot. Please use Add/Update Slot instead");
			}
		}

		private bool TryWriteSphericalHarmonicsField(Field linkField, IField field)
		{
			if (!field.ValueType.IsSphericalHarmonicsType())
			{
				return false;
			}
			field.BoxedValue = linkField.BoxedValue.LinkToEngine();
			return true;
		}

		private void WriteTypeField(Field_Type linkField, SyncType field)
		{
			if (string.IsNullOrEmpty(linkField.Type))
			{
				field.Value = null;
			}
			else
			{
				field.Value = World.Types.DecodeType(linkField.Type);
			}
		}
	}
	public static class BanManager
	{
		private static HashSet<string> _tempBannedUsers;

		private static HashSet<string> _tempBannedConnections;

		public static UserRestrictionsSettings CurrentRestrictions { get; private set; }

		public static event Action OnAllBlockingChanged;

		public static event Action<UserRestrictionsSettings.Entry> OnBlockingChanged;

		static BanManager()
		{
			_tempBannedUsers = new HashSet<string>();
			_tempBannedConnections = new HashSet<string>();
			Settings.RegisterComponentChanges<UserRestrictionsSettings>(OnSettingChanged);
		}

		private static void OnSettingChanged(UserRestrictionsSettings settings)
		{
			CurrentRestrictions = settings;
		}

		private static void UpdateRestriction(Action<UserRestrictionsSettings> update)
		{
			Settings.UpdateActiveSetting(update);
		}

		public static void TempBanConnection(IConnection connection)
		{
			if (string.IsNullOrEmpty(connection.Identifier))
			{
				return;
			}
			lock (_tempBannedConnections)
			{
				_tempBannedConnections.Add(connection.Identifier);
			}
		}

		public static void TempBanUser(string userId)
		{
			lock (_tempBannedUsers)
			{
				_tempBannedUsers.Add(userId);
			}
		}

		public static bool IsTempBanned(string userId)
		{
			lock (_tempBannedUsers)
			{
				return _tempBannedUsers.Contains(userId);
			}
		}

		public static bool IsTempBanned(IConnection connection)
		{
			lock (_tempBannedConnections)
			{
				return _tempBannedConnections.Contains(connection.Identifier);
			}
		}

		public static void Ban(UserFingerprint fingerprint, RecordId world = null)
		{
			UpdateRestriction(delegate(UserRestrictionsSettings r)
			{
				if (world != null)
				{
					r.BanFromWorld(fingerprint, world.ToString());
				}
				else
				{
					r.ActivateBan(fingerprint);
				}
			});
		}

		public static void RemoveBan(UserFingerprint fingerprint, RecordId world = null)
		{
			UpdateRestriction(delegate(UserRestrictionsSettings r)
			{
				if (world == null)
				{
					r.RemoveBan(fingerprint);
				}
				else
				{
					r.RemoveBanFromWorld(fingerprint, world.ToString());
				}
			});
		}

		public static void RemoveBlock(UserFingerprint fingerprint)
		{
			UpdateRestriction(delegate(UserRestrictionsSettings r)
			{
				r.SetBlock(fingerprint, BlockType.None);
			});
		}

		public static void BlockAvatar(UserFingerprint fingerprint)
		{
			UpdateRestriction(delegate(UserRestrictionsSettings r)
			{
				r.SetBlock(fingerprint, BlockType.Avatar);
			});
		}

		public static void MutuallyBlock(UserFingerprint fingerprint)
		{
			UpdateRestriction(delegate(UserRestrictionsSettings r)
			{
				r.SetBlock(fingerprint, BlockType.Mutual);
			});
		}

		public static bool IsBanned(UserFingerprint fingerprint, RecordId world = null)
		{
			return CurrentRestrictions?.HasMatch(fingerprint, (UserRestrictionsSettings.Entry entry) => (world == null) ? entry.IsFullyBanned.Value : entry.BannedWorldList.Contains(world.ToString())) ?? false;
		}

		public static bool IsMutuallyBlocked(UserFingerprint fingerprint)
		{
			return CurrentRestrictions?.HasMatch(fingerprint, (UserRestrictionsSettings.Entry e) => e.BlockType.Value == BlockType.Mutual) ?? false;
		}

		public static bool IsAvatarBlocked(UserFingerprint fingerprint)
		{
			return CurrentRestrictions?.HasMatch(fingerprint, (UserRestrictionsSettings.Entry e) => e.BlockType.Value == BlockType.Avatar) ?? false;
		}

		internal static void RunAllBlockingChanged()
		{
			BanManager.OnAllBlockingChanged?.Invoke();
		}

		internal static void RunBlockingChanged(UserRestrictionsSettings.Entry entry)
		{
			BanManager.OnBlockingChanged?.Invoke(entry);
		}
	}
