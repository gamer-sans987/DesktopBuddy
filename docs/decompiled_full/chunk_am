		public ICollider Collider;

		public int TriangleIndex;

		public bool IsMeshCollider => MeshCollider != null;

		public MeshCollider MeshCollider => Collider as MeshCollider;

		public RaycastHit(in Elements.Core.float3 point, in Elements.Core.float3 normal, float distance, ICollider collider, int triangleIndex)
		{
			Point = point;
			Normal = normal;
			Distance = distance;
			Collider = collider;
			TriangleIndex = triangleIndex;
		}

		public bool Equals(RaycastHit other)
		{
			if (Point == other.Point && Normal == other.Normal && Distance == other.Distance && Collider == other.Collider)
			{
				return TriangleIndex == other.TriangleIndex;
			}
			return false;
		}

		public override bool Equals(object obj)
		{
			if (obj is RaycastHit other)
			{
				return Equals(other);
			}
			return false;
		}

		public override int GetHashCode()
		{
			return Point.GetHashCode() ^ Normal.GetHashCode() ^ Distance.GetHashCode() ^ Collider.GetHashCode() ^ TriangleIndex.GetHashCode();
		}

		public Elements.Assets.Triangle GetTriangle()
		{
			MeshX meshX = MeshCollider?.Mesh.Target?.Asset?.Data;
			if (meshX == null)
			{
				return default(Elements.Assets.Triangle);
			}
			bool flag = MeshCollider.Sidedness.Value == MeshColliderSidedness.DualSided;
			int num = TriangleIndex;
			foreach (Elements.Assets.Submesh submesh in meshX.Submeshes)
			{
				if (!(submesh is Elements.Assets.TriangleSubmesh { Count: var num2 } triangleSubmesh))
				{
					if (submesh is Elements.Assets.PointSubmesh pointSubmesh)
					{
						int num3 = pointSubmesh.Count * 3;
						if (num < num3)
						{
							return default(Elements.Assets.Triangle);
						}
						num -= num3;
						continue;
					}
					throw new NotImplementedException("Submesh type not supported: " + submesh.GetType());
				}
				if (flag)
				{
					num2 *= 2;
				}
				if (num < num2)
				{
					if (flag)
					{
						return triangleSubmesh.GetTriangle(num >> 1);
					}
					return triangleSubmesh.GetTriangle(num);
				}
				num -= num2;
			}
			return default(Elements.Assets.Triangle);
		}

		public override string ToString()
		{
			return $"Hit Point: {Point}, Normal: {Normal}, Distance: {Distance}, Collider: {Collider}, TriangleIndex: {TriangleIndex}";
		}

		public int CompareTo(RaycastHit other)
		{
			return Distance.CompareTo(other.Distance);
		}
	}
	public class PhysicsManager : IDisposable
	{
		private readonly struct ScheduledAction
		{
			public readonly IUpdatable updatable;

			public readonly Action action;

			public ScheduledAction(IUpdatable updatable, Action action)
			{
				this.updatable = updatable;
				this.action = action;
			}
		}

		private struct MovedStatic
		{
			public double lastChange;

			public int changes;

			public override string ToString()
			{
				return $"Changes: {changes}, LastChange: {lastChange}";
			}
		}

		public const int MAX_STATIC_MOVES = 8;

		public const float STATIC_MOVE_EXPIRE_SECONDS = 2f;

		internal MainPhysicsSimulation MainSimulation;

		internal HapticsPhysicsSimulation HapticSimulation;

		private IThreadDispatcher _threadDispatcher;

		private bool _refineDispatched;

		private List<ScheduledAction> _postActions = new List<ScheduledAction>();

		private List<Slot> _physicsMoved = new List<Slot>();

		private Stopwatch timing = new Stopwatch();

		private Dictionary<Collider, MovedStatic> _movedStatics = new Dictionary<Collider, MovedStatic>();

		private double _nextMovedStaticUpdate;

		public Engine Engine => World.Engine;

		public World World { get; private set; }

		public double PreUpdateTime { get; set; }

		public double MainUpdateTime { get; set; }

		public double HapticWaitTime { get; set; }

		public double PostUpdateTime { get; set; }

		public double MovedEventTime { get; set; }

		public double RemainderWaitTime { get; set; }

		public event Action PreUpdate;

		public event Action PostUpdate;

		public void RegisterPhysicsMoved(Slot slot)
		{
			_physicsMoved.Add(slot);
		}

		public void SchedulePostUpdateAction(IUpdatable updatable, Action action)
		{
			_postActions.Add(new ScheduledAction(updatable, action));
		}

		public void RegisterMovedStaticAuto(Collider collider)
		{
			if (_movedStatics.TryGetValue(collider, out var value))
			{
				if (++value.changes == 8)
				{
					collider.SwitchToKinematicTriggers();
					_movedStatics.Remove(collider);
				}
				else
				{
					value.lastChange = World.Time.WorldTime;
					_movedStatics[collider] = value;
				}
			}
			else
			{
				value = new MovedStatic
				{
					changes = 1,
					lastChange = World.Time.WorldTime
				};
				_movedStatics.Add(collider, value);
			}
		}

		internal PhysicsManager(World world)
		{
			World = world;
			MainSimulation = new MainPhysicsSimulation(world);
			HapticSimulation = new HapticsPhysicsSimulation(world);
			MainSimulation.Initialize(_threadDispatcher);
			HapticSimulation.Initialize(null);
			HapticSimulation.OnTimestepDone = new AutoResetEvent(initialState: false);
		}

		internal void Sync()
		{
			if (_refineDispatched)
			{
				MainSimulation.Sync();
				HapticSimulation.Sync();
				_refineDispatched = false;
			}
		}

		internal void Update()
		{
			timing.Restart();
			this.PreUpdate?.Invoke();
			timing.Stop();
			PreUpdateTime = timing.GetElapsedMilliseconds();
			timing.Restart();
			Engine.WorkProcessor.Enqueue(HapticSimulation.RunTimestep, WorkType.HighPriority);
			MainSimulation.RunTimestep();
			MainSimulation.FinishUpdate();
			timing.Stop();
			MainUpdateTime = timing.GetElapsedMilliseconds();
			timing.Restart();
			World.LastPhysicsActiveBodies = MainSimulation.Simulation.Bodies.ActiveSet.Count;
			World.LastPhysicsStatics = MainSimulation.Simulation.Statics.Count;
			this.PostUpdate?.Invoke();
			foreach (ScheduledAction postAction in _postActions)
			{
				if (postAction.updatable.IsRemoved)
				{
					continue;
				}
				try
				{
					World.UpdateManager.NestCurrentlyUpdating(postAction.updatable);
					postAction.action();
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception in post physics update action, Method: {postAction.action.Method}\nTarget: {postAction.action.Target}\nUpdatable:{postAction.updatable}\n{value}");
				}
				finally
				{
					World.UpdateManager.PopCurrentlyUpdating(postAction.updatable);
				}
			}
			_postActions.Clear();
			timing.Stop();
			PostUpdateTime = timing.GetElapsedMilliseconds();
			timing.Restart();
			HapticSimulation.OnTimestepDone.WaitOne();
			HapticSimulation.FinishUpdate();
			timing.Stop();
			HapticWaitTime = timing.GetElapsedMilliseconds();
			timing.Restart();
			foreach (Slot item in _physicsMoved)
			{
				if (!item.IsRemoved)
				{
					World.PhysicsMovedHierarchyEvents.GetHandler(item, createIfDoesNotExist: false)?.SendMovedEvent(0);
				}
			}
			_physicsMoved.Clear();
			timing.Stop();
			MovedEventTime = timing.GetElapsedMilliseconds();
			timing.Restart();
			if (World.Time.WorldTime >= _nextMovedStaticUpdate && _movedStatics.Count > 0)
			{
				double num = World.Time.WorldTime - 2.0;
				double num2 = double.PositiveInfinity;
				HashSet<Collider> hashSet = Pool.BorrowHashSet<Collider>();
				foreach (KeyValuePair<Collider, MovedStatic> movedStatic in _movedStatics)
				{
					if (movedStatic.Value.lastChange <= num)
					{
						hashSet.Add(movedStatic.Key);
					}
					else
					{
						num2 = MathX.Min(num2, movedStatic.Value.lastChange);
					}
				}
				if (num2 < double.PositiveInfinity)
				{
					_nextMovedStaticUpdate = num2 + 2.0;
				}
				foreach (Collider item2 in hashSet)
				{
					_movedStatics.Remove(item2);
				}
				Pool.Return(ref hashSet);
			}
			timing.Stop();
			RemainderWaitTime = timing.GetElapsedMilliseconds();
		}

