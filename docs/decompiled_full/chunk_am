		public static int DeduplicateMaterials(Slot root)
		{
			List<MeshRenderer> componentsInChildren = root.GetComponentsInChildren<MeshRenderer>();
			HashSet<IAssetProvider<Material>> hashSet = new HashSet<IAssetProvider<Material>>();
			foreach (MeshRenderer item in componentsInChildren)
			{
				foreach (IAssetProvider<Material> material in item.Materials)
				{
					if (material != null && !IsMaterialDriven(material) && material.Slot.AllowOptimization())
					{
						hashSet.Add(material);
					}
				}
			}
			return DeduplicateMaterials(hashSet, root);
		}

		public static int DeduplicateMaterials(IEnumerable<IAssetProvider<Material>> materials, Slot replaceRoot)
		{
			int num = 0;
			DictionaryList<Type, IAssetProvider<Material>> dictionary = Pool.BorrowDictionaryList<Type, IAssetProvider<Material>>();
			Dictionary<IWorldElement, IWorldElement> dictionary2 = Pool.BorrowDictionary<IWorldElement, IWorldElement>();
			foreach (IAssetProvider<Material> material in materials)
			{
				dictionary.Add(material.GetType(), material);
			}
			foreach (KeyValuePair<Type, List<IAssetProvider<Material>>> item in dictionary)
			{
				if (item.Value.Count == 1)
				{
					continue;
				}
				for (int i = 0; i < item.Value.Count; i++)
				{
					IAssetProvider<Material> assetProvider = item.Value[i];
					for (int num2 = item.Value.Count - 1; num2 > i; num2--)
					{
						IAssetProvider<Material> assetProvider2 = item.Value[num2];
						if (AreMaterialsSame(assetProvider, assetProvider2))
						{
							dictionary2.Add(assetProvider2, assetProvider);
							item.Value.RemoveAt(num2);
							num++;
						}
					}
				}
			}
			Pool.Return(ref dictionary);
			if (dictionary2.Count > 0)
			{
				replaceRoot.World.ReplaceReferenceTargets(dictionary2, nullIfIncompatible: false, replaceRoot);
				foreach (KeyValuePair<IWorldElement, IWorldElement> item2 in dictionary2)
				{
					((Component)item2.Key).Destroy();
				}
			}
			Pool.Return(ref dictionary2);
			return num;
		}

		public static bool AreMaterialsSame(IAssetProvider<Material> a, IAssetProvider<Material> b)
		{
			if (a.GetType() != b.GetType())
			{
				return false;
			}
			Component obj = (Component)a;
			Component other = (Component)b;
			return obj.PublicMembersEqual(other);
		}

		public static bool IsMaterialDriven(IAssetProvider<Material> material)
		{
			Component obj = (Component)material;
			bool isDriven = false;
			obj.ForeachSyncMember(delegate(ISyncMember e)
			{
				if (e.IsDriven)
				{
					isDriven = true;
				}
			});
			return isDriven;
		}
	}
