				return false;
			}
			if (!DllCheck.Test())
			{
				UniLog.Error("[Steamworks.NET] DllCheck Test returned false, One or more of the Steamworks binaries seems to be the wrong version.", stackTrace: false);
				return false;
			}
			string OutSteamErrMsg;
			switch (SteamAPI.InitEx(out OutSteamErrMsg))
			{
			case ESteamAPIInitResult.k_ESteamAPIInitResult_OK:
				UniLog.Log("Steam API Initialized successfully.");
				return true;
			case ESteamAPIInitResult.k_ESteamAPIInitResult_NoSteamClient:
				UniLog.Log("Skipping Steam API setup because Steam is not installed or running.");
				return false;
			case ESteamAPIInitResult.k_ESteamAPIInitResult_VersionMismatch:
				UniLog.Log("Skipping Steam API setup because Steam is not up to date.");
				return false;
			default:
