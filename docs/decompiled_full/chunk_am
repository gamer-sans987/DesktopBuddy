		public bool CanProcessSlot(Slot slot)
		{
			SimpleAvatarProtection component = slot.GetComponent<SimpleAvatarProtection>();
			if (component != null && !component.CanSave)
			{
				return false;
			}
			return true;
		}

		public ResoniteLink.Slot GatherSlotData(Slot slot, int depth, bool includeComponentData)
		{
			ResoniteLink.Slot slot2 = new ResoniteLink.Slot();
			slot2.ID = References.GetID(slot);
			GatherSlotFields(slot, slot2);
			slot2.Components = new List<ResoniteLink.Component>();
			foreach (Component component in slot.Components)
			{
				slot2.Components.Add(includeComponentData ? GatherComponentData(component) : GatherComponentReference(component));
			}
			if (slot.ChildrenCount > 0)
			{
				slot2.Children = new List<ResoniteLink.Slot>();
				int num = depth;
				if (num > 0)
				{
					num--;
				}
				foreach (Slot child in slot.Children)
				{
					if (CanProcessSlot(child))
					{
						if (depth == 0)
						{
							slot2.Children.Add(GatherSlotReference(child));
						}
						else
						{
							slot2.Children.Add(GatherSlotData(child, num, includeComponentData));
						}
					}
				}
				if (slot2.Children.Count == 0)
				{
					slot2.Children = null;
				}
			}
			return slot2;
		}

		public ResoniteLink.Slot GatherSlotReference(Slot slot)
		{
			ResoniteLink.Slot slot2 = new ResoniteLink.Slot();
			slot2.ID = References.GetID(slot);
			slot2.IsReferenceOnly = true;
			GatherSlotFields(slot, slot2);
			return slot2;
		}

		private void GatherSlotFields(Slot slot, ResoniteLink.Slot linkSlot)
		{
			linkSlot.Parent = (Reference)GatherMemberData(slot.ParentReference);
			linkSlot.Position = (Field_float3)GatherMemberData(slot.Position_Field);
			linkSlot.Rotation = (Field_floatQ)GatherMemberData(slot.Rotation_Field);
			linkSlot.Scale = (Field_float3)GatherMemberData(slot.Scale_Field);
			linkSlot.IsActive = (Field_bool)GatherMemberData(slot.ActiveSelf_Field);
			linkSlot.IsPersistent = (Field_bool)GatherMemberData(slot.Persistent_Field);
			linkSlot.Name = (Field_string)GatherMemberData(slot.Name_Field);
			linkSlot.Tag = (Field_string)GatherMemberData(slot.Tag_Field);
			linkSlot.OrderOffset = (Field_long)GatherMemberData(slot.OrderOffset_Field);
		}

		private Field TryConvertSphericalHarmonicsField(IField field)
		{
			if (!field.ValueType.IsSphericalHarmonicsType())
			{
				return null;
			}
			int sphericalHarmonicsOrder = field.ValueType.GetSphericalHarmonicsOrder();
			return sphericalHarmonicsOrder switch
			{
				1 => new Field_SH_L1
				{
					BoxedValue = field.BoxedValue.EngineToLink()
				}, 
				2 => new Field_SH_L2
				{
					BoxedValue = field.BoxedValue.EngineToLink()
				}, 
				3 => new Field_SH_L3
				{
					BoxedValue = field.BoxedValue.EngineToLink()
				}, 
				4 => new Field_SH_L4
				{
					BoxedValue = field.BoxedValue.EngineToLink()
				}, 
				_ => throw new NotImplementedException("Order not implemented: " + sphericalHarmonicsOrder), 
			};
		}

		private Field_Type ConvertTypeField(SyncType field)
		{
			Field_Type field_Type = new Field_Type();
			if (field.Value == null)
			{
				field_Type.Type = null;
			}
			else
			{
				field_Type.Type = World.Types.EncodeType(field.Value);
			}
			return field_Type;
		}

