				return false;
			}
			return true;
		}

		private void GetSlot(GetSlot getSlot, BatchResponse batch)
		{
			try
			{
				if (!CheckReadPermission<SlotData>(getSlot, batch))
				{
					return;
				}
				if (string.IsNullOrWhiteSpace(getSlot.SlotID))
				{
					SendErrorResponse<SlotData>(getSlot, "Slot ID must be provided.", batch);
					return;
				}
				Slot slot = References.ResolveReference<Slot>(getSlot.SlotID);
				if (slot == null)
				{
					SendErrorResponse<SlotData>(getSlot, "Slot with ID '" + getSlot.SlotID + "' not found.", batch);
					return;
				}
				if (!Translator.CanProcessSlot(slot))
				{
					SendErrorResponse<SlotData>(getSlot, "Slot with ID '" + getSlot.SlotID + "' is not accessible.", batch);
					return;
				}
				ResoniteLink.Slot data = Translator.GatherSlotData(slot, getSlot.Depth, getSlot.IncludeComponentData);
				SlotData slotData = new SlotData();
				slotData.Success = true;
				slotData.Data = data;
				SendResponse(getSlot, slotData, batch);
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception processing ResoniteLink message\n{value}");
				SendErrorResponse<SlotData>(getSlot, $"Exception processing message: {value}", batch);
			}
		}

		private void AddSlot(AddSlot addSlot, ResoniteLinkUpdateContext context, BatchResponse batch)
		{
			if (!CheckWritePermission<NewEntityId>(addSlot, batch))
			{
				return;
			}
			if (addSlot.Data == null)
			{
				SendErrorResponse<NewEntityId>(addSlot, "No update data was provided", batch);
				return;
			}
			Slot slot = World.RootSlot;
			if (addSlot.Data.Parent != null)
			{
				slot = References.ResolveReference<Slot>(addSlot.Data.Parent.TargetID);
				if (slot == null)
				{
					SendErrorResponse<NewEntityId>(addSlot, "Slot with ID '" + addSlot.Data.Parent.TargetID + "' not found.", batch);
					return;
				}
				if (!Translator.CanProcessSlot(slot))
				{
					SendErrorResponse<NewEntityId>(addSlot, "Parent Slot is not accessible.", batch);
					return;
				}
			}
			if (addSlot.Data.ID != null && References.HasID(addSlot.Data.ID))
			{
				SendErrorResponse<NewEntityId>(addSlot, "ID '" + addSlot.Data.ID + "' is already in use", batch);
				return;
			}
			Slot slot2 = slot.AddSlot();
			try
			{
				if (string.IsNullOrEmpty(addSlot.Data.ID))
				{
					addSlot.Data.ID = References.AllocateID(slot2);
				}
				else
				{
					References.RegisterReference(addSlot.Data.ID, slot2);
				}
				Translator.WriteSlotData(addSlot.Data, slot2, context);
				NewEntityId newEntityId = new NewEntityId();
				newEntityId.Success = true;
				newEntityId.EntityId = addSlot.Data.ID;
				SendResponse(addSlot, newEntityId, batch);
			}
			catch (Exception)
			{
				slot2.Destroy();
				throw;
			}
		}

