		protected void GenerateBonesUpdate(SkinnedMeshRenderablesUpdate update)
		{
			SharedMemoryBlockLease<BoneAssignment> sharedMemoryBlockLease = base.RenderSystem.AllocateBlock<BoneAssignment>(updatedBones.Count, frameBound: true, this);
			Span<BoneAssignment> span = sharedMemoryBlockLease.AccessData();
