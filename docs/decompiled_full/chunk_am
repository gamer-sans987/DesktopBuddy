			return instanceChangeValidator;
		}

		internal void WorkerChanged(Worker worker, User user, List<ValidationTask> _validations)
		{
			bool flag = true;
			bool flag2 = false;
			if (_instanceChangeValidators.TryGetValue(worker, out List<InstanceChangeValidator> value))
			{
				foreach (InstanceChangeValidator item in value)
				{
					if (item.Validator.Target == null)
					{
						UniLog.Warning($"Validator Is Null. RawTarget: {item.Validator.RawTarget?.ParentHierarchyToString()}. Role: {RoleName}");
					}
					else
					{
						if ((bool)item.OverrideGlobal)
						{
							flag = false;
						}
						_validations.Add(new ValidationTask(item.Validator.Target, item.ViolationActionOverride.Value ?? item.Validator.Target.DefaultViolationAction, worker, user));
						flag2 = true;
					}
				}
			}
			if (flag && GetValidators(worker.GetType(), out List<GlobalChangeValidator> validators))
			{
				foreach (GlobalChangeValidator item2 in validators)
				{
					if (item2.Validator.Target == null)
					{
						UniLog.Warning($"Validator Is Null. RawTarget: {item2.Validator.RawTarget?.ParentHierarchyToString()}. Role: {RoleName}");
					}
					else
					{
						_validations.Add(new ValidationTask(item2.Validator.Target, item2.ViolationActionOverride.Value ?? item2.Validator.Target.DefaultViolationAction, worker, user));
						flag2 = true;
					}
				}
			}
			if (!flag2)
