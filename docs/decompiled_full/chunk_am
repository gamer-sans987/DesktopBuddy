		public static IEnumerable<DataFeedItem> EnumerateSettingProperties(Type containerType, IReadOnlyList<string> path, Type settingType = null, string subcategory = null, string settingGetter = null, string settingKey = null, SettingMemberIdentity parent = null)
		{
			string[] grouping = new string[1] { containerType.Name };
			FieldInfo[] fields = containerType.GetFields();
			foreach (FieldInfo fieldInfo in fields)
			{
				SettingPropertyAttribute customAttribute = fieldInfo.GetCustomAttribute<SettingPropertyAttribute>();
				if (customAttribute == null || customAttribute.Hidden)
				{
					continue;
				}
				FieldIdentity fieldIdentity = new FieldIdentity();
				InitIdentity(fieldIdentity);
				fieldIdentity.field = fieldInfo;
				if (typeof(SyncObject).IsAssignableFrom(fieldInfo.FieldType))
				{
					foreach (DataFeedItem item in EnumerateSettingProperties(fieldInfo.FieldType, path, settingType, subcategory, settingGetter, settingKey, fieldIdentity))
					{
						yield return item;
					}
					continue;
				}
				DataFeedItem dataFeedItem;
				try
				{
					dataFeedItem = GenerateItem(fieldIdentity, customAttribute, path, grouping);
				}
				catch (Exception)
				{
					UniLog.Error($"Exception generating item from field {fieldIdentity.FullName} on {containerType}");
					throw;
				}
				yield return dataFeedItem;
			}
			MethodInfo[] methods = containerType.GetMethods();
			foreach (MethodInfo methodInfo in methods)
			{
				SettingPropertyAttribute customAttribute2 = methodInfo.GetCustomAttribute<SettingPropertyAttribute>();
				if (customAttribute2 != null && !customAttribute2.Hidden)
				{
					ActionIdentity actionIdentity = new ActionIdentity();
					InitIdentity(actionIdentity);
					actionIdentity.method = methodInfo;
					DataFeedItem dataFeedItem2;
					try
					{
						dataFeedItem2 = GenerateItem(actionIdentity, customAttribute2, path, grouping);
					}
					catch (Exception)
					{
						UniLog.Error($"Exception generating item from method {actionIdentity.FullName} on {containerType}");
						throw;
					}
					if (dataFeedItem2 != null)
					{
						yield return dataFeedItem2;
					}
				}
			}
			void InitIdentity(SettingMemberIdentity identity)
			{
				identity.parent = parent;
				identity.settingType = settingType ?? containerType;
				identity.subcategory = subcategory;
				identity.settingGetter = settingGetter;
				identity.settingKey = settingKey;
			}
		}

		public async IAsyncEnumerable<DataFeedItem> Enumerate(IReadOnlyList<string> path, IReadOnlyList<string> groupingKeys, string searchPhrase, object viewData)
		{
			if (path.Count == 0)
			{
				List<SettingCategoryInfo> uniqueCategories = Pool.BorrowList<SettingCategoryInfo>();
				Settings.GetCategories(uniqueCategories);
				foreach (SettingCategoryInfo item in uniqueCategories)
				{
					yield return GenerateCategory(item, path);
				}
				Pool.Return(ref uniqueCategories);
			}
			else if (path.Count == 1)
			{
				List<Type> types = Pool.BorrowList<Type>();
				Settings.GetSettingTypesInCategory(path[0] ?? "", types);
				foreach (Type type in types)
				{
					DataFeedGroup dataFeedGroup = ((Settings.TryGetActiveSetting(type)?.CanResetToDefault ?? false) ? new DataFeedResettableGroup() : new DataFeedGroup());
					dataFeedGroup.InitBase(type.Name, path, null, ("Settings." + type.Name).AsLocaleKey());
					if (dataFeedGroup is DataFeedResettableGroup dataFeedResettableGroup)
					{
						dataFeedResettableGroup.InitResetAction(delegate(SyncDelegate<Action> field)
						{
							field.ProxySettingAction(type, "ResetToDefault");
						});
					}
					yield return dataFeedGroup;
					foreach (DataFeedItem item2 in EnumerateSettingProperties(type, path))
					{
						yield return item2;
					}
				}
				Pool.Return(ref types);
			}
			else
			{
				if (path.Count != 2 || !GetSubsetting(path, out Type type2, out string subsetting))
				{
					yield break;
				}
				SettingComponent settingComponent = Settings.TryGetActiveSetting(type2);
				if (settingComponent == null || (HideSubsettings && !settingComponent.IsSubcategoryPublic(subsetting)))
				{
					yield break;
				}
				await foreach (DataFeedItem subcategoryItem in settingComponent.GetSubcategoryItems(subsetting))
				{
					yield return subcategoryItem;
				}
			}
		}

		private static bool GetSubsetting(IReadOnlyList<string> path, out Type type, out string subsetting)
		{
			type = null;
			subsetting = null;
			if (path.Count < 2)
			{
				return false;
			}
			string[] split = path[1].Split('.');
			if (split.Length != 2)
			{
				return false;
			}
			List<Type> list = Pool.BorrowList<Type>();
			Settings.GetSettingTypesInCategory(path[0] ?? "", list);
			type = list.FirstOrDefault((Type t) => t.Name == split[0]);
			Pool.Return(ref list);
			if (type == null)
			{
				return false;
			}
			subsetting = split[1];
			return true;
		}

		public void ListenToUpdates(IReadOnlyList<string> path, IReadOnlyList<string> groupingKeys, string searchPhrase, DataFeedUpdateHandler handler, object viewData)
		{
			if (!string.IsNullOrEmpty(searchPhrase))
			{
				return;
			}
			switch (path?.Count ?? 0)
			{
			case 0:
				if (_categoryListeners == null)
				{
					break;
				}
				lock (_categoryListeners)
				{
					if (_categoryListeners != null)
					{
						Action<SettingCategoryInfo> value = delegate(SettingCategoryInfo category)
						{
							DataFeedCategory item = GenerateCategory(category, null);
							handler(item, DataFeedItemChange.Added);
						};
						_categoryListeners[handler] = value;
						Settings.SettingCategoryAdded += value;
					}
					break;
				}
			case 2:
			{
				if (!HideSubsettings && _subcategoryListeners != null && GetSubsetting(path, out Type type, out string subsetting))
				{
					GetType().GetMethod("RegisterSubcategoryListener", BindingFlags.Instance | BindingFlags.NonPublic).MakeGenericMethod(type).Invoke(this, new object[2] { subsetting, handler });
				}
				break;
			}
			}
		}

		private void RegisterSubcategoryListener<T>(string subcategory, DataFeedUpdateHandler handler) where T : SettingComponent
		{
			SettingSubcategoryUpdateHandler<T> settingSubcategoryUpdateHandler = delegate(T setting, string text, DataFeedItem item, DataFeedItemChange change)
			{
				handler(item, change);
			};
			lock (_subcategoryListeners)
			{
				_subcategoryListeners[handler] = new SubcategoryWrapper(settingSubcategoryUpdateHandler, typeof(T), subcategory);
				Settings.RegisterSubcategoryChanges(settingSubcategoryUpdateHandler, subcategory);
			}
		}

		private void UnregisterSubcategoryListener<T>(string subcategory, DataFeedUpdateHandler handler) where T : SettingComponent
		{
			lock (_subcategoryListeners)
			{
				if (_subcategoryListeners.TryGetValue(handler, out var value))
				{
					Settings.UnregisterSubcategoryChanges((SettingSubcategoryUpdateHandler<T>)value.wrapper, subcategory);
					_subcategoryListeners.Remove(handler);
				}
			}
		}

		public void UnregisterListener(IReadOnlyList<string> path, IReadOnlyList<string> groupingKeys, string searchPhrase, DataFeedUpdateHandler handler)
		{
			if (!string.IsNullOrEmpty(searchPhrase))
			{
				return;
			}
			switch (path?.Count ?? 0)
			{
			case 0:
				lock (_categoryListeners)
				{
					if (_categoryListeners != null && _categoryListeners.TryGetValue(handler, out Action<SettingCategoryInfo> value))
					{
						Settings.SettingCategoryAdded -= value;
						_categoryListeners.Remove(handler);
					}
					break;
				}
			case 2:
			{
				if (!HideSubsettings && _subcategoryListeners != null && GetSubsetting(path, out Type type, out string subsetting))
				{
					GetType().GetMethod("UnregisterSubcategoryListener", BindingFlags.Instance | BindingFlags.NonPublic).MakeGenericMethod(type).Invoke(this, new object[2] { subsetting, handler });
				}
				break;
			}
			}
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			lock (_categoryListeners)
			{
				foreach (KeyValuePair<DataFeedUpdateHandler, Action<SettingCategoryInfo>> categoryListener in _categoryListeners)
				{
					Settings.SettingCategoryAdded -= categoryListener.Value;
				}
				_categoryListeners.Clear();
				_categoryListeners = null;
			}
			lock (_subcategoryListeners)
			{
				foreach (KeyValuePair<DataFeedUpdateHandler, SubcategoryWrapper> subcategoryListener in _subcategoryListeners)
				{
					GetType().GetMethod("UnregisterSubcategoryListener", BindingFlags.Instance | BindingFlags.NonPublic).MakeGenericMethod(subcategoryListener.Value.type).Invoke(this, new object[2]
					{
						subcategoryListener.Value.subcategory,
						subcategoryListener.Value.wrapper
					});
				}
				_subcategoryListeners.Clear();
				_subcategoryListeners = null;
			}
		}

