		public void RunLayout(out bool autoSized)
		{
			autoSized = false;
			if (_layoutChanged && !IsEmpty)
			{
				_renderTree.HorizontalAlignment = _horizontalAlign;
				_renderTree.VerticalAlignment = _verticalAlign;
				_renderTree.BoundsSize = _boundsSize;
				_renderTree.Bounded = _bounded;
				_renderTree.BoundsAlignment = _boundsAlignment;
				float size = _renderTree.Size;
				Elements.Core.float2 boundsSize = _renderTree.BoundsSize;
				if (!_textShaped)
				{
					_renderTree.ShapeText();
				}
				if (_horizontalAutoSize && _bounded && _boundsSize.x > 0f)
				{
					_renderTree.HorizontalAutoSize();
				}
				if (_verticalAutoSize && _bounded && _boundsSize.y > 0f)
				{
					autoSized = _renderTree.AutoSizeLayout(_autoSizeMin, _autoSizeMax);
				}
				else
				{
					_renderTree.Layout();
				}
				_renderTree.Size = size;
				_renderTree.BoundsSize = boundsSize;
				_renderTree.AutoSizeRatio = 1f;
				_textShaped = false;
			}
		}

		public void FillMeshData(MeshX meshx, Elements.Core.float2 offset, AtlasSubmeshMapper submeshMapper)
		{
			if (IsEmpty)
			{
				return;
			}
			Dictionary<Elements.Assets.FontSet, List<AtlasData>> dictionary = Pool.BorrowDictionary<Elements.Assets.FontSet, List<AtlasData>>();
			for (int i = 0; i < _currentFontAssetSet.Count; i++)
			{
				Elements.Assets.FontSet key = _currentFontSet[i];
				List<FontAtlases> list = _currentAtlases[i];
				List<AtlasData> list2 = Pool.BorrowList<AtlasData>();
				for (int j = 0; j < list.Count; j++)
				{
					foreach (GlyphAtlasManager atlase in list[j].atlases)
					{
						list2.Add(new AtlasData(atlase.Atlas, atlase));
					}
				}
				dictionary.Add(key, list2);
			}
			TextEditingVisuals textEditVisuals = new TextEditingVisuals
			{
				selectionStart = _selectionStart,
				selectionColor = _selectionColor,
				caretPosition = _caretPosition,
				caretColor = _caretColor
			};
			bool currentUsingAuxiliarySubmesh = _currentUsingAuxiliarySubmesh;
			GlyphAtlasMeshGenerator.Generate(_renderTree, offset, meshx, submeshMapper, dictionary, textEditVisuals, out _currentUsingAuxiliarySubmesh);
			_materialsChanged |= _fontChanged;
			_materialsChanged |= currentUsingAuxiliarySubmesh != _currentUsingAuxiliarySubmesh;
			_materialsChanged |= _lastSubmeshCount != meshx.SubmeshCount;
			_lastSubmeshCount = meshx.SubmeshCount;
			foreach (KeyValuePair<Elements.Assets.FontSet, List<AtlasData>> item in dictionary)
			{
				List<AtlasData> list3 = item.Value;
				Pool.Return(ref list3);
			}
			Pool.Return(ref dictionary);
		}

