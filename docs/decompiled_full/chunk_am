		internal void GetAllValidators<P>(List<P> validators, bool includeInstance = false) where P : class, IWorkerPermissions
		{
			foreach (GlobalChangeValidator globalChangeValidator in GlobalChangeValidators)
			{
				if (globalChangeValidator.Validator.Target is P item)
				{
					validators.Add(item);
				}
			}
			if (!includeInstance)
			{
				return;
			}
			foreach (InstanceChangeValidator instanceChangeValidator in InstanceChangeValidators)
			{
				if (instanceChangeValidator.Validator.Target is P item2)
				{
					validators.Add(item2);
				}
			}
		}

		internal bool CheckAll<P>(Predicate<P> predicate, bool includeInstance = false, bool noValidatorState = true) where P : class, IWorkerPermissions
		{
			bool flag = false;
			if (GetGlobalValidators(out List<P> validators))
			{
				foreach (P item in validators)
				{
					flag = true;
					if (!predicate(item))
					{
						return false;
					}
				}
			}
			if (includeInstance)
			{
				foreach (InstanceChangeValidator instanceChangeValidator in InstanceChangeValidators)
				{
					if (instanceChangeValidator.Validator.Target is P obj)
					{
						flag = true;
						if (!predicate(obj))
						{
							return false;
						}
					}
				}
			}
			if (!flag)
			{
				return noValidatorState;
			}
			return true;
		}

		internal void GetValidators<P>(IWorker instance, Type workerType, List<P> validators) where P : class, IWorkerPermissions
		{
			bool flag = true;
			if (instance != null && _instanceChangeValidators.TryGetValue(instance, out List<InstanceChangeValidator> value))
			{
				foreach (InstanceChangeValidator item3 in value)
				{
					if ((bool)item3.OverrideGlobal)
					{
						flag = false;
					}
					if (item3.Validator.Target is P item)
					{
						validators.Add(item);
					}
				}
			}
			if (!flag || !GetValidators(instance?.GetType() ?? workerType, out List<GlobalChangeValidator> validators2))
			{
				return;
			}
			foreach (GlobalChangeValidator item4 in validators2)
			{
				if (item4.Validator.Target is P item2)
				{
					validators.Add(item2);
				}
			}
		}

		internal bool GetValidators(Type type, out List<GlobalChangeValidator> validators)
		{
			lock (_globalChangeValidators)
			{
				if (!_globalChangeValidators.TryGetValue(type, out validators))
				{
					foreach (GlobalChangeValidator globalChangeValidator in GlobalChangeValidators)
					{
						if (globalChangeValidator.Validator.Target != null && globalChangeValidator.Validator.Target.ValidatesType(type))
						{
							validators = validators ?? new List<GlobalChangeValidator>();
							validators.Add(globalChangeValidator);
						}
					}
					_globalChangeValidators.TryAdd(type, validators);
				}
				return validators != null;
			}
		}

		internal bool GetGlobalValidators<P>(out List<P> validators) where P : class, IWorkerPermissions
		{
			lock (_globalChangeValidatorsByType)
			{
				if (!_globalChangeValidatorsByType.TryGetValue(typeof(P), out IList value))
				{
					validators = null;
					foreach (GlobalChangeValidator globalChangeValidator in GlobalChangeValidators)
					{
						if (globalChangeValidator.Validator.Target is P item)
						{
							validators = validators ?? new List<P>();
							validators.Add(item);
						}
					}
					_globalChangeValidatorsByType.TryAdd(typeof(P), validators);
					return validators != null;
				}
				if (value == null)
				{
					validators = null;
					return false;
				}
				validators = (List<P>)value;
				return true;
			}
		}

		internal bool Check<P>(IWorker instance, Type workerType, Predicate<P> check) where P : class, IWorkerPermissions
		{
			bool flag = true;
			if (instance != null && _instanceChangeValidators.TryGetValue(instance, out List<InstanceChangeValidator> value))
			{
				foreach (InstanceChangeValidator item in value)
				{
					if ((bool)item.OverrideGlobal)
					{
						flag = false;
					}
					if (item.Validator.Target is P obj && !check(obj))
					{
						return false;
					}
				}
			}
			if (flag && GetValidators(instance?.GetType() ?? workerType, out List<GlobalChangeValidator> validators))
			{
				foreach (GlobalChangeValidator item2 in validators)
				{
					if (item2.Validator.Target is P obj2 && !check(obj2))
					{
						return false;
					}
				}
			}
			return true;
		}

