		private static UserFingerprint GetFingerprint(SyncDictionary<string, SyncVar> dict)
		{
			string value = null;
			string value2 = null;
			string value3 = null;
			if (dict.TryGetElement("UserName", out SyncVar element))
			{
				element.TryGetValue<string>(out value);
			}
			if (dict.TryGetElement("UserId", out SyncVar element2))
			{
				element2.TryGetValue<string>(out value2);
			}
			if (dict.TryGetElement("MachineId", out SyncVar element3))
			{
				element3.TryGetValue<string>(out value3);
			}
			Dictionary<string, string> dictionary = new Dictionary<string, string>();
			if (dict.TryGetElement("ExtraIds", out SyncVar element4))
			{
				SyncDictionary<string, SyncVar> syncDictionary = element4.AsDictionary<string, SyncVar>(setIfDifferent: false);
				if (syncDictionary != null)
				{
					foreach (KeyValuePair<string, SyncVar> item in syncDictionary)
					{
						if (item.Value.TryGetValue<string>(out var value4))
						{
