		public unsafe static void ExtractMessages(int count, nint[] messages, MessageHandler callback, ConnectionFailureHandler connectionFailureCallback, ReassemblyStateFetcher reassemblyStateFetcher)
		{
			HashSet<HSteamNetConnection> hashSet = null;
			for (int i = 0; i < count; i++)
			{
				SteamNetworkingMessage_t steamNetworkingMessage_t = Marshal.PtrToStructure<SteamNetworkingMessage_t>(messages[i]);
				if (hashSet != null && hashSet.Contains(steamNetworkingMessage_t.m_conn))
				{
					continue;
				}
				ref ReassemblyState reference = ref reassemblyStateFetcher(steamNetworkingMessage_t.m_conn);
				if ((steamNetworkingMessage_t.m_nFlags & 8) != 0 && (reference.buffer != null || steamNetworkingMessage_t.m_cbSize == 4))
				{
					if (reference.buffer == null)
					{
						int* ptr = (int*)((IntPtr)steamNetworkingMessage_t.m_pData).ToPointer();
						reference.expectingBytes = *ptr;
						reference.buffer = NetworkManager.GetArray(reference.expectingBytes);
						reference.receivedBytes = 0;
					}
					else
					{
						if (reference.receivedBytes < 0 || reference.expectingBytes < 0 || reference.receivedBytes + steamNetworkingMessage_t.m_cbSize > reference.expectingBytes)
						{
							connectionFailureCallback(steamNetworkingMessage_t.m_conn);
							hashSet = hashSet ?? new HashSet<HSteamNetConnection>();
							hashSet.Add(steamNetworkingMessage_t.m_conn);
							continue;
						}
						Marshal.Copy(steamNetworkingMessage_t.m_pData, reference.buffer, reference.receivedBytes, steamNetworkingMessage_t.m_cbSize);
						reference.receivedBytes += steamNetworkingMessage_t.m_cbSize;
						if (reference.receivedBytes == reference.expectingBytes)
						{
							callback(steamNetworkingMessage_t.m_identityPeer.GetSteamID(), steamNetworkingMessage_t.m_conn, reference.buffer, (ulong)steamNetworkingMessage_t.m_cbSize);
							reference.buffer = null;
							reference.expectingBytes = -1;
							reference.receivedBytes = -1;
						}
					}
				}
				else
				{
					byte[] array = NetworkManager.GetArray(steamNetworkingMessage_t.m_cbSize);
					Marshal.Copy(steamNetworkingMessage_t.m_pData, array, 0, steamNetworkingMessage_t.m_cbSize);
					callback(steamNetworkingMessage_t.m_identityPeer.GetSteamID(), steamNetworkingMessage_t.m_conn, array, (ulong)steamNetworkingMessage_t.m_cbSize);
				}
				nint pointer = messages[i];
				messages[i] = IntPtr.Zero;
				SteamNetworkingMessage_t.Release(pointer);
			}
		}

