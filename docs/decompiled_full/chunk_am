				{
					return IdPacker<MeshRendererType>.Pack(renderer.RenderableIndex, MeshRendererType.MeshRenderer);
				}
				return -1;
			}
			return IdPacker<MeshRendererType>.Pack(skinnedMeshRenderer.RenderableIndex, MeshRendererType.SkinnedMeshRenderer);
		}
