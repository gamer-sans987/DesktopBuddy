			int num2 = 0;
			int num3 = 0;
			for (int j = 0; j < _changedStates.Count; j++)
			{
				TMeshRenderable val2 = _changedStates[j];
				if (!val2.IsRenderableAllocated)
				{
					continue;
				}
				ref MeshRendererState reference = ref span[num2++];
				reference.renderableIndex = val2.RenderableIndex;
				reference.meshAssetId = val2.Mesh.Asset?.AssetId ?? (-1);
				reference.shadowCastMode = val2.ShadowCastMode;
				reference.motionVectorMode = val2.MotionVectorMode;
				reference.sortingOrder = val2.SortingOrder;
				if (reference.renderableIndex < 0)
				{
					throw new Exception($"[{base.RenderSystem.FrameIndex}] Renderable index is not allocated for mesh renderer. IsRenderable: {val2.IsRenderable}, RenderableAllocated: {val2.IsRenderableAllocated}, ShouldBeEnabled: {val2.ShouldBeEnabled}\n{val2}");
				}
				if (val2.MaterialsOrPropertyBlocksChanged)
				{
					reference.materialCount = val2.Materials.Count;
					reference.materialPropertyBlockCount = MathX.Min(val2.MaterialPropertyBlocks.Count, reference.materialCount);
					for (int k = 0; k < reference.materialCount; k++)
					{
						span2[num3++] = val2.Materials[k]?.Asset?.AssetId ?? (-1);
					}
					for (int l = 0; l < reference.materialPropertyBlockCount; l++)
					{
						if (val2.Materials[l] == null)
						{
							span2[num3++] = -1;
						}
						else
						{
							span2[num3++] = val2.MaterialPropertyBlocks[l]?.Asset?.AssetId ?? (-1);
						}
					}
					val2.MaterialsOrPropertyBlocksChanged = false;
				}
				else
				{
					reference.materialCount = -1;
					reference.materialPropertyBlockCount = -1;
				}
			}
			if (num2 < span.Length)
			{
				span[num2].renderableIndex = -1;
			}
			FillChangeUpdates(update, _changedStates);
			update.meshStates = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<MeshRendererState>);
			update.meshMaterialsAndPropertyBlocks = sharedMemoryBlockLease2?.Descriptor ?? default(SharedMemoryBufferDescriptor<int>);
			_changedStates.Clear();
			_computingUpdate = false;
		}

