				}
			});
		}

		internal ref ReassemblyState GetReassemblyState(HSteamNetConnection connection)
		{
			for (int i = 0; i < connections.Length; i++)
			{
				if (connection == connections[i])
				{
					return ref reassemblyStates[i];
				}
			}
			throw new Exception("Connection doesn't belong to this SteamConnection instance");
		}

		private void ConnectionReceiveError(HSteamNetConnection connection)
		{
			for (int i = 0; i < connections.Length; i++)
			{
				if (connections[i] == connection)
				{
					Close(SteamCloseReason.ReceiveError);
					break;
				}
			}
		}

		internal void MessageReceived(CSteamID steamId, HSteamNetConnection connection, byte[] data, ulong length)
		{
			if (IsOpen)
			{
				if (GetChannel(connection) < 0)
				{
					UniLog.Warning($"Invalid channel for SteamID {steamId}, Connection: {connection}, data size: {data.Length}");
				}
				else
				{
					receivedBytes += length;
					this.NewData?.Invoke(new RawInMessage(this, data, 0, (int)length, NetworkManager.ReturnArray, data));
				}
			}
		}

		internal void Close(SteamCloseReason closeReason)
		{
			UniLog.Log($"Close Connection. State: {state}, Reason: {closeReason}");
			if (state == State.Closed)
			{
				return;
			}
			lock (manager.Lock)
			{
				if (state != State.Closed)
				{
					bool num = state == State.Open;
					state = State.Closed;
					CloseReason = closeReason;
					manager.UnregisterConnection(this);
					if (!num)
					{
						FailReason = closeReason.ToString();
						this.ConnectionFailed?.Invoke(this);
					}
					this.Closed?.Invoke(this);
				}
			}
		}

		public void Dispose()
		{
			for (int i = 0; i < connections.Length; i++)
			{
				HSteamNetConnection hSteamNetConnection = connections[i];
				if (!(hSteamNetConnection == HSteamNetConnection.Invalid))
				{
					SteamNetworkingSockets.CloseConnection(hSteamNetConnection, (int)CloseReason, null, bEnableLinger: true);
					connections[i] = default(HSteamNetConnection);
				}
			}
			SteamNetworkingSockets.DestroyPollGroup(pollGroup);
			pollGroup = default(HSteamNetPollGroup);
		}

		internal int GetChannel(HSteamNetConnection connection)
		{
			if (connections == null)
			{
				return -1;
			}
			for (int i = 0; i < connections.Length; i++)
			{
				if (connections[i] == connection)
				{
					return i;
				}
			}
			return -1;
		}

		private bool AllConnected()
		{
			for (int i = 0; i < connectionsConnected.Length; i++)
			{
				if (!connectionsConnected[i])
				{
					return false;
				}
			}
			return true;
		}

		public void Close()
		{
			Close(SteamCloseReason.ClosedLocally);
		}

		public void Connect(Action<LocaleString> statusCallback)
		{
			statusCallback("World.Connection.SteamNetworkingSockets".AsLocaleKey());
			SteamNetworkingIdentity identityRemote = default(SteamNetworkingIdentity);
			identityRemote.SetSteamID64(remoteId.m_SteamID);
			lock (manager.Lock)
			{
				int num = remoteChannel * 2;
				for (int i = 0; i < 2; i++)
				{
					SteamNetworkingConfigValue_t[] config = manager.GetConfig(i);
					connections[i] = SteamNetworkingSockets.ConnectP2P(ref identityRemote, num + i, config.Length, config);
					SteamNetworkingSockets.SetConnectionPollGroup(connections[i], pollGroup);
					manager.RegisterConnection(connections[i], this);
				}
			}
		}

		internal unsafe void Transmit(nint data, uint count, bool reliable, bool background)
		{
			if (!IsOpen)
			{
				return;
			}
			if (SteamNetworkManager.NeedReassembly(count) && reliable)
			{
				nint data2 = new IntPtr(&count);
				if (!TransmitRaw(data2, 4u, reliable: true, background))
				{
					return;
				}
				uint num = count;
				while (num != 0)
				{
					uint num2 = MathX.Min(num, 524288u);
					if (!TransmitRaw(data, num2, reliable, background))
					{
						break;
					}
					data += (int)num2;
					num -= num2;
				}
			}
			else
			{
				TransmitRaw(data, count, reliable, background);
			}
		}

		private bool TransmitRaw(nint data, uint count, bool reliable, bool background)
		{
			if (count > 524288)
			{
				throw new InvalidOperationException($"Message is too big! Reassembly is supported only for reliable. Size: {count}, reliable: {reliable}, background: {background}");
			}
			HSteamNetConnection hSteamNetConnection = connections[background ? 1u : 0u];
			long pOutMessageNumber;
			EResult eResult = SteamNetworkingSockets.SendMessageToConnection(hSteamNetConnection, data, count, reliable ? 8 : 5, out pOutMessageNumber);
			if (eResult != EResult.k_EResultOK && eResult != EResult.k_EResultIgnored)
			{
				SteamNetworkingSockets.GetConnectionInfo(hSteamNetConnection, out var pInfo);
				UniLog.Warning($"Error sending {count} bytes to connection {hSteamNetConnection} to SteamID {remoteId}: {eResult}. Reliable: {reliable}, background: {background}, state: {state}, messagseNumber: {pOutMessageNumber}.\nConnection state: {pInfo.m_eState}, EndReason: {pInfo.m_eEndReason}, Listen Socket: {pInfo.m_hListenSocket}");
				Close(SteamCloseReason.TransmissionError);
				return false;
			}
			return true;
		}

		internal void ConnectionStatusChanged(ref SteamNetConnectionStatusChangedCallback_t info)
		{
			UniLog.Log($"Connection Status: {info.m_info.m_eState}, State: {state}, Connection: {info.m_hConn}, Remote Identity: {info.m_info.m_identityRemote.GetSteamID()}");
			if (state == State.Closed)
			{
				return;
			}
			switch (info.m_info.m_eState)
			{
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_Connected:
			{
				if (state == State.Open)
				{
					Close(SteamCloseReason.ChannelMismatch);
					break;
				}
				int channel = GetChannel(info.m_hConn);
				if (channel < 0)
				{
					Close(SteamCloseReason.ChannelMismatch);
					break;
				}
				connectionsConnected[channel] = true;
				if (AllConnected())
				{
					state = State.Open;
					this.Connected?.Invoke(this);
				}
				break;
			}
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_ClosedByPeer:
				Close(SteamCloseReason.ClosedRemotely);
				break;
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_ProblemDetectedLocally:
				UniLog.Log($"LocalProblem. EndReason: {info.m_info.m_eEndReason}, EndDebug: {info.m_info.m_szEndDebug}");
				Close(SteamCloseReason.LocalProblem);
				break;
			}
		}

		public override string ToString()
		{
			return $"Steam Connection. RemoteId: {remoteId}, State: {state}, Connections: {string.Join(", ", connections)}";
		}
	}
	public class SteamListener : IListener, IDisposable
	{
		private Uri _globalUri;

