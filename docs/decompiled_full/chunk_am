		internal void ConnectionStatusChanged(ref SteamNetConnectionStatusChangedCallback_t info)
		{
			if (!IsActive)
			{
				return;
			}
			CSteamID steamID = info.m_info.m_identityRemote.GetSteamID();
			int channel = GetChannel(info.m_info.m_hListenSocket);
			UniLog.Log($"Listener Status: {info.m_info.m_eState}, Connection: {info.m_hConn}, Remote Identity: {info.m_info.m_identityRemote.GetSteamID()}");
			switch (info.m_info.m_eState)
			{
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_Connecting:
			{
				bool flag = false;
				if (channel >= 0)
				{
					if (!connections.TryGetValue(steamID, out SteamConnection value))
					{
						value = new SteamConnection(steamID, channel, sessionId, manager);
						value.NewData += Connection_NewData;
						value.Closed += Connection_Closed;
						value.ConnectionFailed += Connection_ConnectionFailed;
						value.StatsUpdated += Connection_StatsUpdated;
						connections.Add(steamID, value);
					}
					flag = value.AssignConnection(info.m_hConn, channel);
					if (flag)
					{
						connectionMap.Add(info.m_hConn, value);
					}
				}
				if (flag)
				{
					SteamNetworkingSockets.AcceptConnection(info.m_hConn);
					SteamNetworkingSockets.SetConnectionPollGroup(info.m_hConn, pollGroup);
				}
				else
				{
					CloseConnection(steamID, SteamCloseReason.ChannelMismatch);
					SteamNetworkingSockets.CloseConnection(info.m_hConn, 4, null, bEnableLinger: false);
				}
				break;
			}
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_ClosedByPeer:
				CloseConnection(steamID, SteamCloseReason.ClosedRemotely);
				break;
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_ProblemDetectedLocally:
				CloseConnection(steamID, SteamCloseReason.LocalProblem);
				break;
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_FindingRoute:
			case ESteamNetworkingConnectionState.k_ESteamNetworkingConnectionState_Connected:
				break;
			}
		}

