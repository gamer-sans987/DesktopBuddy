	internal class LNL_Logger : INetLogger
	{
		public void WriteNet(NetLogLevel level, string str, params object[] args)
		{
			if (str.Contains("AddressAlreadyInUse"))
			{
				level = NetLogLevel.Info;
			}
			switch (level)
			{
			case NetLogLevel.Error:
				UniLog.Error(string.Format(CultureInfo.InvariantCulture, str, args));
				break;
			case NetLogLevel.Warning:
				UniLog.Warning(string.Format(CultureInfo.InvariantCulture, str, args));
				break;
			case NetLogLevel.Info:
				UniLog.Log(string.Format(CultureInfo.InvariantCulture, str, args));
				break;
			case NetLogLevel.Trace:
				break;
			}
		}
	}
