		protected void GenerateBlendshapesUpdate(SkinnedMeshRenderablesUpdate update)
		{
			updateRunning = true;
			SharedMemoryBlockLease<BlendshapeUpdateBatch> sharedMemoryBlockLease = base.RenderSystem.AllocateBlock<BlendshapeUpdateBatch>(updatedBlendshapes.Count, frameBound: true, this);
			Span<BlendshapeUpdateBatch> span = sharedMemoryBlockLease.AccessData();
			int num = 0;
			int num2 = 0;
			int num3 = updatedBlendshapes.Count;
			if (num3 > 4096)
			{
				num3 = 0;
			}
			Span<int> span2 = stackalloc int[num3];
			RawValueList<int> list = null;
			if (num3 == 0 && updatedBlendshapes.Count > 0)
			{
				list = Pool.BorrowRawValueList<int>();
				if (list.Capacity < updatedBlendshapes.Count)
				{
					list.Capacity = updatedBlendshapes.Count;
				}
				span2 = list.Elements;
			}
			for (int i = 0; i < updatedBlendshapes.Count; i++)
			{
				SkinnedMeshRenderer skinnedMeshRenderer = updatedBlendshapes[i];
				skinnedMeshRenderer.BlendShapeWeightsChanged = false;
				if (!skinnedMeshRenderer.IsRenderableAllocated)
				{
					continue;
				}
				int num4 = skinnedMeshRenderer.Mesh.Asset?.AssetId ?? (-1);
				AssetLoadState assetLoadState = skinnedMeshRenderer.Mesh?.Asset?.LoadState ?? ((AssetLoadState)(-1));
				ref BlendshapeUpdateBatch reference = ref span[num++];
				reference.renderableIndex = skinnedMeshRenderer.RenderableIndex;
				if (skinnedMeshRenderer.LastMeshAssetId != num4 || skinnedMeshRenderer.LastMeshLoadState != assetLoadState)
				{
					skinnedMeshRenderer.UpdateAllBlendshapes = true;
					skinnedMeshRenderer.LastMeshAssetId = num4;
					skinnedMeshRenderer.LastMeshLoadState = assetLoadState;
				}
				int renderableBlendshapeCount = skinnedMeshRenderer.RenderableBlendshapeCount;
				span2[i] = renderableBlendshapeCount;
				int num5 = 0;
				for (int j = 0; j < renderableBlendshapeCount; j++)
				{
					if (skinnedMeshRenderer.UpdateAllBlendshapes || skinnedMeshRenderer.BlendShapeWeights.GetElement(j).WasChanged)
					{
						num5++;
					}
				}
				reference.blendshapeUpdateCount = num5;
				num2 += num5;
			}
			if (num < span.Length)
			{
				span[num].renderableIndex = -1;
			}
			SharedMemoryBlockLease<BlendshapeUpdate> sharedMemoryBlockLease2 = base.RenderSystem.AllocateBlock<BlendshapeUpdate>(num2, frameBound: true, this);
			Span<BlendshapeUpdate> span3 = sharedMemoryBlockLease2.AccessData();
			int num6 = 0;
			num = 0;
			for (int k = 0; k < updatedBlendshapes.Count; k++)
			{
				SkinnedMeshRenderer skinnedMeshRenderer2 = updatedBlendshapes[k];
				if (!skinnedMeshRenderer2.IsRenderableAllocated)
				{
					continue;
				}
				ref BlendshapeUpdateBatch reference2 = ref span[num++];
				int num7 = reference2.blendshapeUpdateCount;
				int num8 = span2[k];
				for (int l = 0; l < num8; l++)
				{
					Sync<float> element = skinnedMeshRenderer2.BlendShapeWeights.GetElement(l);
					if (element.GetWasChangedAndClear() || skinnedMeshRenderer2.UpdateAllBlendshapes)
					{
						ref BlendshapeUpdate reference3 = ref span3[num6++];
						reference3.blendshapeIndex = l;
						reference3.weight = element.Value;
						if (--num7 == 0)
						{
							break;
						}
					}
				}
				if (num7 > 0)
				{
					throw new InvalidOperationException($"Failed to fill all expected blendshapes for skin {skinnedMeshRenderer2.RenderableIndex}.\nExpected: {reference2.blendshapeUpdateCount}, Remaining to fill: {num7}, UpdateAllBlendshapes: {skinnedMeshRenderer2.UpdateAllBlendshapes}, Renderable count: {skinnedMeshRenderer2.RenderableBlendshapeCount}\nLastAssetId: {skinnedMeshRenderer2.LastMeshAssetId}, LastLoadState: {skinnedMeshRenderer2.LastMeshLoadState}\n{skinnedMeshRenderer2}\nAll updated blendshapes: {string.Join(", ", updatedBlendshapes.Select((SkinnedMeshRenderer s) => s.RenderableIndex))}");
				}
				skinnedMeshRenderer2.UpdateAllBlendshapes = false;
			}
			if (num6 != num2)
			{
				throw new InvalidOperationException($"Didn't fill all the blendshapes! Total: {num2}, Filled: {num6}");
			}
			update.blendshapeUpdateBatches = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<BlendshapeUpdateBatch>);
			update.blendshapeUpdates = sharedMemoryBlockLease2?.Descriptor ?? default(SharedMemoryBufferDescriptor<BlendshapeUpdate>);
			updatedBlendshapes.Clear();
			updateRunning = false;
			if (list != null)
			{
				Pool.Return(ref list);
			}
		}

