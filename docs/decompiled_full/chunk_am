	public class RawOutMessage : IDisposable
	{
		public MemoryStream Data;

		public bool Background;

		public bool UseReliable;

		private volatile int transmissionCount = -1;

		public List<IConnection> Targets { get; private set; }

		public void SetTransmissionCount(int count)
		{
			if (transmissionCount >= 0)
			{
				throw new InvalidOperationException("Transmission count was already set!");
			}
			transmissionCount = count;
		}

		public void TransmissionFinished()
		{
			if (transmissionCount <= 0)
			{
				throw new InvalidOperationException("Transmission count wasn't initialized or already reached zero!");
			}
			if (Interlocked.Decrement(ref transmissionCount) == 0)
			{
				Dispose();
			}
		}

		public RawOutMessage()
		{
			Targets = new List<IConnection>();
		}

		public void Dispose()
		{
			if (transmissionCount != 0)
			{
				throw new Exception("Transmission count doesn't equal zero, cannot dispose!");
			}
			Data.Dispose();
			Data = null;
			Targets = null;
		}

		public override string ToString()
		{
			return $"RawOut. Length: {Data?.Length ?? (-1)}, Background: {Background}, Reliable: {UseReliable}";
		}
	}
