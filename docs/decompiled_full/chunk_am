	public class TCP_Listener : IListener, IDisposable
	{
		private TcpListener _listener;

		private CancellationTokenSource _cancellation;

		private HashSet<TCP_Connection> _connections = new HashSet<TCP_Connection>();

		private PortRange? _portRange;

		public bool IsActive => _listener.Server.Connected;

		public int Port => ((IPEndPoint)_listener.LocalEndpoint).Port;

		public IEnumerable<Uri> LocalUris
		{
			get
			{
				foreach (IPAddress filteredLocalIP in NetUtils.FilteredLocalIPs)
				{
					IPEndPoint value = new IPEndPoint(filteredLocalIP, Port);
					yield return new Uri($"tcp://{value}");
				}
			}
		}

		public IEnumerable<Uri> GlobalUris
		{
			get
			{
				yield break;
			}
		}

		public bool GlobalUrisReady => true;

		public event DataEvent NewData;

		public event StatsEvent StatsUpdated;

		public TCP_Listener(ushort port, World world, LNLConfig? config)
		{
			_cancellation = new CancellationTokenSource();
			if (port != 0)
			{
				_listener = new TcpListener(IPAddress.Any, port);
				_listener.Start();
			}
			else if (config?.Ports != null)
			{
				_portRange = config.Ports;
				if (!_portRange.Try(delegate(int num)
				{
					try
					{
						UniLog.Log($"Attempting TCP Server start at {num}");
						_listener = new TcpListener(IPAddress.Any, num);
						_listener.Start();
						return true;
					}
					catch (SocketException ex)
					{
						UniLog.Log($"Failed to start TCP Server at {num}: {ex.Message}");
						return false;
					}
				}))
				{
					throw new Exception("Failed to start TCP Listener at the port range");
				}
			}
			else
			{
				_listener = new TcpListener(IPAddress.Any, 0);
				_listener.Start();
			}
			Task.Run(async delegate
			{
				await ListenToConnections(_cancellation.Token);
			});
		}

		public void Close()
		{
			_portRange?.Free(Port);
			_portRange = null;
			lock (_connections)
			{
				_cancellation.Cancel();
				_listener.Stop();
				foreach (TCP_Connection connection in _connections)
				{
					connection.Close();
					connection.Dispose();
				}
			}
		}

		public void Dispose()
		{
			_listener = null;
		}

		public void GlobalAnnounceRefresh()
		{
		}

		private async Task ListenToConnections(CancellationToken cancellationToken)
		{
			while (!cancellationToken.IsCancellationRequested)
			{
				TcpClient tcpClient = await _listener.AcceptTcpClientAsync().ConfigureAwait(continueOnCapturedContext: false);
				UniLog.Log($"TcpClient connected: {tcpClient.Client.RemoteEndPoint}");
				TCP_Connection tCP_Connection = new TCP_Connection(tcpClient);
				lock (_connections)
				{
					if (cancellationToken.IsCancellationRequested)
					{
						break;
					}
					_connections.Add(tCP_Connection);
				}
				tCP_Connection.NewData += OnNewClientData;
				tCP_Connection.StatsUpdated += OnClientStatsUpdates;
				tCP_Connection.Closed += OnConnectionClosed;
				tCP_Connection.StartProcessing();
			}
		}

		private void OnClientStatsUpdates(IConnection connection, Action<User> setStats)
		{
			this.StatsUpdated?.Invoke(connection, setStats);
		}

		private void OnConnectionClosed(IConnection connection)
		{
			UniLog.Log("TCP Connection closed: " + connection);
			lock (_connections)
			{
				_connections.Remove((TCP_Connection)connection);
				connection.Dispose();
			}
		}

		private void OnNewClientData(RawInMessage rawMessage)
		{
			this.NewData?.Invoke(rawMessage);
		}
	}
