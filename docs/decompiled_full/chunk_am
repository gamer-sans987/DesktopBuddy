		private static MeshX GenerateMesh(ImportMeshJSON meshData)
		{
			MeshX meshX = new MeshX();
			foreach (ResoniteLink.Vertex vertex2 in meshData.Vertices)
			{
				Elements.Assets.Vertex vertex = meshX.AddVertex();
				vertex.Position = vertex2.Position.ToEngine();
				if (vertex2.Normal.HasValue)
				{
					vertex.Normal = vertex2.Normal.Value.ToEngine();
				}
				if (vertex2.Tangent.HasValue)
				{
					vertex.Tangent4 = vertex2.Tangent.Value.ToEngine();
				}
				if (vertex2.Color.HasValue)
				{
					vertex.Color = vertex2.Color.Value.ToEngine();
				}
				for (int i = 0; i < (vertex2.UVs?.Count ?? 0); i++)
				{
					UV_Coordinate uV_Coordinate = vertex2.UVs[i];
					if (!(uV_Coordinate is UV2D_Coordinate uV2D_Coordinate))
					{
						if (!(uV_Coordinate is UV3D_Coordinate uV3D_Coordinate))
						{
							if (!(uV_Coordinate is UV4D_Coordinate uV4D_Coordinate))
							{
								throw new NotImplementedException($"Unsupported UV coordinate type: {vertex2.UVs[i].GetType()}");
							}
							vertex.SetUV_4D(i, uV4D_Coordinate.uv.ToEngine(), throwIfDimensionMismatch: true);
						}
						else
						{
							vertex.SetUV_3D(i, uV3D_Coordinate.uv.ToEngine(), throwIfDimensionMismatch: true);
						}
					}
					else
					{
						vertex.SetUV(i, uV2D_Coordinate.uv.ToEngine(), throwIfDimensionMismatch: true);
					}
				}
				List<ResoniteLink.BoneWeight> boneWeights = vertex2.BoneWeights;
				if (boneWeights != null && boneWeights.Count > 0)
				{
					vertex.BoneBinding = ConvertBoneBinding(vertex2.BoneWeights);
				}
			}
			if (meshData.Submeshes != null)
			{
				foreach (ResoniteLink.Submesh submesh in meshData.Submeshes)
				{
					ConvertSubmesh(meshX, submesh);
				}
			}
			if (meshData.BlendShapes != null)
			{
				foreach (ResoniteLink.BlendShape blendShape in meshData.BlendShapes)
				{
					ConvertBlendShape(meshX, blendShape);
				}
			}
			if (meshData.Bones != null)
			{
				ConvertBones(meshX, meshData.Bones);
			}
			return meshX;
		}

		private static void ConvertBones(MeshX mesh, List<ResoniteLink.Bone> bones)
		{
			foreach (ResoniteLink.Bone bone in bones)
			{
				mesh.AddBone(bone.Name).BindPose = bone.BindPose.ToEngine();
			}
		}

		private static void ConvertSubmesh(MeshX mesh, ResoniteLink.Submesh submeshData)
		{
			if (!(submeshData is ResoniteLink.PointSubmesh pointSubmesh))
			{
				if (!(submeshData is ResoniteLink.TriangleSubmesh triangleSubmesh))
				{
					if (submeshData is TriangleSubmeshFlat triangleSubmeshFlat)
					{
						if (triangleSubmeshFlat.VertexIndices.Count % 3 != 0)
						{
							throw new Exception("Number of vertex indicies for triangle submesh must be divisible by 3");
						}
						Elements.Assets.TriangleSubmesh triangleSubmesh2 = mesh.AddSubmesh<Elements.Assets.TriangleSubmesh>();
						triangleSubmesh2.SetCount(triangleSubmeshFlat.VertexIndices.Count / 3);
						triangleSubmeshFlat.VertexIndices.CopyTo(triangleSubmesh2.RawIndicies);
					}
				}
				else
				{
					Elements.Assets.TriangleSubmesh triangleSubmesh3 = mesh.AddSubmesh<Elements.Assets.TriangleSubmesh>();
					triangleSubmesh3.SetCount(triangleSubmesh.Triangles.Count);
					for (int i = 0; i < triangleSubmesh.Triangles.Count; i++)
					{
						ResoniteLink.Triangle triangle = triangleSubmesh.Triangles[i];
						triangleSubmesh3.SetTriangle(i, triangle.Vertex0Index, triangle.Vertex1Index, triangle.Vertex2Index);
					}
				}
			}
			else
			{
				Elements.Assets.PointSubmesh pointSubmesh2 = mesh.AddSubmesh<Elements.Assets.PointSubmesh>();
				pointSubmesh2.SetCount(pointSubmesh.VertexIndices.Count);
				pointSubmesh.VertexIndices.CopyTo(pointSubmesh2.RawIndicies);
			}
		}

		private static void ConvertBlendShape(MeshX mesh, ResoniteLink.BlendShape blendshapeData)
		{
			Elements.Assets.BlendShape blendShape = mesh.AddBlendShape(blendshapeData.Name);
			foreach (BlendshapeFrame frame in blendshapeData.Frames)
			{
				BlendShapeFrame blendShapeFrame = blendShape.AddFrame(frame.Position);
				if (frame.PositionDeltas.Count != mesh.VertexCount)
				{
					throw new Exception("Number of position deltas on a blendshape frame must match vertex count");
				}
				for (int i = 0; i < frame.PositionDeltas.Count; i++)
				{
					blendShapeFrame.RawPositions[i] = frame.PositionDeltas[i].ToEngine();
				}
				if (frame.NormalDeltas != null)
				{
					if (frame.NormalDeltas.Count != mesh.VertexCount)
					{
						throw new Exception("Number of normal deltas on a blendshape frame must match vertex count");
					}
					blendShape.HasNormals = true;
					for (int j = 0; j < frame.NormalDeltas.Count; j++)
					{
						blendShapeFrame.RawNormals[j] = frame.NormalDeltas[j].ToEngine();
					}
				}
				if (frame.TangentDeltas != null)
				{
					if (frame.TangentDeltas.Count != mesh.VertexCount)
					{
						throw new Exception("Number of tangent deltas on a blendshape frame must match vertex count");
					}
					blendShape.HasTangents = true;
					for (int k = 0; k < frame.TangentDeltas.Count; k++)
					{
						blendShapeFrame.RawTangents[k] = frame.TangentDeltas[k].ToEngine();
					}
				}
			}
			blendShape.NormalizeFrameWeights();
		}

		private static BoneBinding ConvertBoneBinding(List<ResoniteLink.BoneWeight> weights)
		{
			if (weights.Count > 4)
			{
				throw new NotSupportedException("Maximum of 4 bone weights is currently supported");
			}
			BoneBinding result = default(BoneBinding);
			for (int i = 0; i < weights.Count; i++)
			{
				result.SetBinding(i, weights[i].BoneIndex, weights[i].Weight);
			}
			result.Sort();
			result.Normalize();
			return result;
		}

		private static MeshX GenerateMesh(ImportMeshRawData meshData)
		{
			if (meshData.BoneWeightCount < 0 || meshData.BoneWeightCount > 4)
			{
				throw new ArgumentException("BoneWeightCount must be between 0 and 4 (inclusive)");
			}
			meshData.MapBuffer();
			MeshX meshX = new MeshX();
			meshX.SetVertexCount(meshData.VertexCount);
			MemoryMarshal.Cast<ResoniteLink.float3, Elements.Core.float3>(meshData.Positions).CopyTo(meshX.RawPositions);
			if (meshData.HasNormals)
			{
				meshX.HasNormals = true;
				MemoryMarshal.Cast<ResoniteLink.float3, Elements.Core.float3>(meshData.Normals).CopyTo(meshX.RawNormals);
			}
			if (meshData.HasTangents)
			{
				meshX.HasTangents = true;
				MemoryMarshal.Cast<ResoniteLink.float4, Elements.Core.float4>(meshData.Tangents).CopyTo(meshX.RawTangents);
			}
			if (meshData.HasColors)
			{
				meshX.HasColors = true;
				MemoryMarshal.Cast<ResoniteLink.color, Elements.Core.color>(meshData.Colors).CopyTo(meshX.RawColors);
			}
			for (int i = 0; i < (meshData.UV_Channel_Dimensions?.Count ?? 0); i++)
			{
				int num = meshData.UV_Channel_Dimensions[i];
				meshX.SetUV_Dimension(i, num);
				switch (num)
				{
				case 2:
					MemoryMarshal.Cast<ResoniteLink.float2, Elements.Core.float2>(meshData.AccessUV_2D(i)).CopyTo(meshX.GetRawUVs(i));
					break;
				case 3:
					MemoryMarshal.Cast<ResoniteLink.float3, Elements.Core.float3>(meshData.AccessUV_3D(i)).CopyTo(meshX.GetRawUVs_3D(i));
					break;
				case 4:
					MemoryMarshal.Cast<ResoniteLink.float4, Elements.Core.float4>(meshData.AccessUV_4D(i)).CopyTo(meshX.GetRawUVs_4D(i));
					break;
				default:
					throw new NotSupportedException($"Unsupported UV channel dimensions: {num}");
				case 0:
					break;
				}
			}
			if (meshData.BoneWeightCount > 0)
			{
				meshX.HasBoneBindings = meshData.BoneWeightCount > 0;
				Span<ResoniteLink.BoneWeight> boneWeights = meshData.BoneWeights;
				int num2 = 0;
				for (int j = 0; j < meshX.VertexCount; j++)
				{
					ref BoneBinding reference = ref meshX.RawBoneBindings[j];
					for (int k = 0; k < meshData.BoneWeightCount; k++)
					{
						ResoniteLink.BoneWeight boneWeight = boneWeights[num2++];
						reference.SetBinding(k, boneWeight.BoneIndex, boneWeight.Weight);
					}
					reference.Sort();
					reference.Normalize();
				}
			}
			if (meshData.Submeshes != null)
			{
				foreach (SubmeshRawData submesh in meshData.Submeshes)
				{
					ConvertSubmesh(meshX, submesh);
				}
			}
			if (meshData.BlendShapes != null)
			{
				foreach (BlendShapeRawData blendShape in meshData.BlendShapes)
				{
					ConvertBlendShape(meshX, blendShape);
				}
			}
			if (meshData.Bones != null)
			{
				ConvertBones(meshX, meshData.Bones);
			}
			return meshX;
		}

		private static void ConvertSubmesh(MeshX mesh, SubmeshRawData submeshData)
		{
			if (!(submeshData is PointSubmeshRawData pointSubmeshRawData))
			{
				if (!(submeshData is TriangleSubmeshRawData triangleSubmeshRawData))
				{
					throw new NotSupportedException($"Unsupported submesh type: {submeshData?.GetType()}");
				}
				if (triangleSubmeshRawData.TriangleCount < 0)
				{
					throw new ArgumentOutOfRangeException("trianglesData", "Number of triangles cannot be negative");
				}
				if (triangleSubmeshRawData.Indices == null)
				{
					throw new ArgumentException("Missing indice data");
				}
				if (triangleSubmeshRawData.Indices.Length != triangleSubmeshRawData.TriangleCount * 3)
				{
					throw new ArgumentException($"Number of indices does not match provided triangle count. Indicie count: {triangleSubmeshRawData.Indices.Length}, TriangleCount: {triangleSubmeshRawData.TriangleCount}");
				}
				Elements.Assets.TriangleSubmesh triangleSubmesh = mesh.AddSubmesh<Elements.Assets.TriangleSubmesh>();
				triangleSubmesh.SetCount(triangleSubmeshRawData.TriangleCount);
				triangleSubmeshRawData.Indices.CopyTo(triangleSubmesh.RawIndicies);
			}
			else
			{
				Elements.Assets.PointSubmesh pointSubmesh = mesh.AddSubmesh<Elements.Assets.PointSubmesh>();
				pointSubmesh.SetCount(pointSubmeshRawData.PointCount);
				pointSubmeshRawData.Indices.CopyTo(pointSubmesh.RawIndicies);
			}
		}

		private static void ConvertBlendShape(MeshX mesh, BlendShapeRawData blendshapeData)
		{
			Elements.Assets.BlendShape blendShape = mesh.AddBlendShape(blendshapeData.Name);
			blendShape.HasNormals = blendshapeData.HasNormalDeltas;
			blendShape.HasTangents = blendshapeData.HasTangentDeltas;
			foreach (BlendShapeFrameRawData frame in blendshapeData.Frames)
			{
				BlendShapeFrame blendShapeFrame = blendShape.AddFrame(frame.Position);
				MemoryMarshal.Cast<ResoniteLink.float3, Elements.Core.float3>(frame.PositionDeltas).CopyTo(blendShapeFrame.RawPositions);
				if (blendShape.HasNormals)
				{
					MemoryMarshal.Cast<ResoniteLink.float3, Elements.Core.float3>(frame.NormalDeltas).CopyTo(blendShapeFrame.RawNormals);
				}
				if (blendShape.HasTangents)
				{
					MemoryMarshal.Cast<ResoniteLink.float3, Elements.Core.float3>(frame.TangentDeltas).CopyTo(blendShapeFrame.RawTangents);
				}
			}
			blendShape.NormalizeFrameWeights();
		}

