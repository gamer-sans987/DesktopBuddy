		private Dictionary<CSteamID, SteamConnection> connections = new Dictionary<CSteamID, SteamConnection>();

		private SteamNetworkManager.MessageHandler _messageHandler;

		private ReassemblyStateFetcher _reassemblyStateFetcher;

		private ConnectionFailureHandler _connectionFailureHandler;

		private ReassemblyState _dummyState;

