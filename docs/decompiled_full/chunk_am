		{
			if (!IsValidRaycast(in origin, in direction, maxDistance))
			{
				throw new ArgumentException($"Invalid Raycast. Origin: {origin}, Direction: {direction}, MaxDistance: {maxDistance}");
			}
			int count = results.Count;
			int result = MainSimulation.RaycastAll(in origin, in direction, maxDistance, results, filter, hitTriggers);
