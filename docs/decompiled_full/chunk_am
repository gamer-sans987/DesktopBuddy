	public class BootstrapperManager : IDisposable
	{
		private IPublisher _bootstrapperIn;

		private ISubscriber _bootstrapperOut;

		private bool _rendererStarting;

		public Engine Engine { get; private set; }

		public BootstrapperManager(Engine engine)
		{
			Engine = engine;
			if (!Engine.IsRunningWithBootstrapper)
			{
				throw new InvalidOperationException("Engine wasn't started with bootstrapper");
			}
			QueueFactory queueFactory = new QueueFactory();
			QueueOptions options = new QueueOptions(engine.SharedMemoryPrefix + ".bootstrapper_in", 8192L, deleteOnDispose: false);
			_bootstrapperIn = queueFactory.CreatePublisher(options);
			options = new QueueOptions(engine.SharedMemoryPrefix + ".bootstrapper_out", 8192L, deleteOnDispose: false);
			_bootstrapperOut = queueFactory.CreateSubscriber(options);
		}

		public async Task<string> GetClipboardText()
		{
			if (!_bootstrapperIn.TryEnqueue(Encoding.UTF8.GetBytes("GETTEXT")))
			{
				return null;
			}
			UniLog.Log("Getting text from bootstrapper");
			TaskCompletionSource<string> taskCompletionSource = new TaskCompletionSource<string>();
			Task.Run(delegate
			{
				try
				{
					string result = Encoding.UTF8.GetString(_bootstrapperOut.Dequeue(CancellationToken.None).Span);
					taskCompletionSource.SetResult(result);
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception getting text:\n" + ex);
					taskCompletionSource.SetResult(null);
				}
			});
			return await taskCompletionSource.Task;
		}

		public bool SetClipboardText(string text)
		{
			UniLog.Log("Setting text through bootstrapper");
			return _bootstrapperIn.TryEnqueue(Encoding.UTF8.GetBytes("SETTEXT" + text));
		}

		public async Task<Process> StartRenderer(string startArgs)
		{
			if (_rendererStarting)
			{
				throw new InvalidOperationException("Renderer is already being started!");
			}
			_rendererStarting = true;
			try
			{
				UniLog.Log("Sending start args to bootstrapper: " + startArgs);
				_bootstrapperIn.TryEnqueue(Encoding.UTF8.GetBytes(startArgs));
				TaskCompletionSource<Process> taskCompletionSource = new TaskCompletionSource<Process>();
				Task.Run(delegate
				{
					try
					{
						UniLog.Log("Awaiting bootstrapper confirmation...");
						string text = Encoding.UTF8.GetString(_bootstrapperOut.Dequeue(CancellationToken.None).Span);
						string[] array = text.Split(':');
						if (array[0] != "RENDERITE_STARTED")
						{
							throw new InvalidOperationException("Response from bootstrapper was not correct. Expected 'RENDERITE_STARTED', Got: " + text);
						}
						if (Engine.Platform == Platform.Linux)
						{
							Process[] processes = Process.GetProcesses();
							foreach (Process process in processes)
							{
								if (process.ProcessName.StartsWith("Renderite", StringComparison.Ordinal))
								{
									taskCompletionSource.SetResult(process);
									break;
								}
							}
						}
						else
						{
							int processId = int.Parse(array[1], NumberFormatInfo.InvariantInfo);
							taskCompletionSource.SetResult(Process.GetProcessById(processId));
						}
					}
					catch (Exception exception)
					{
						taskCompletionSource.TrySetException(exception);
					}
				});
				return await taskCompletionSource.Task;
			}
			finally
			{
				_rendererStarting = false;
			}
		}

		public void SendHeartbeat()
		{
			_bootstrapperIn.TryEnqueue(Encoding.UTF8.GetBytes("HEARTBEAT"));
		}

		public void Dispose()
		{
			_bootstrapperIn.TryEnqueue(Encoding.UTF8.GetBytes("SHUTDOWN"));
			_bootstrapperIn.Dispose();
			_bootstrapperOut.Dispose();
		}
	}
	public class FrameFinalizeHandler
	{
		private List<Action> _frameCompleteTasks = new List<Action>();

		private List<SharedMemoryBlockLease> _memoryBlocks = new List<SharedMemoryBlockLease>();

