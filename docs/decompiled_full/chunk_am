		{
			if (!(scheme == "lnl"))
			{
				return scheme == "lnl-nat";
			}
			return true;
		}

		public List<ConnectionConstructor> GetPrioritizedConnectionConstructors(IEnumerable<Uri> uris, World world, out string expectedSessionId)
		{
			List<Uri> list = new List<Uri>();
			expectedSessionId = null;
			foreach (Uri uri in uris)
			{
				if (uri.Scheme == "lnl-nat")
				{
					GetConnectionTokens(uri, out string _, out expectedSessionId);
				}
				if (SupportsScheme(uri.Scheme))
				{
					list.Add(uri);
				}
			}
			list.Sort(delegate(Uri a, Uri b)
			{
				if (a.Scheme == "lnl" && b.Scheme == "lnl-nat")
				{
					return -1;
				}
				return (a.Scheme == "lnl-nat" && b.Scheme == "lnl") ? 1 : 0;
			});
			List<ConnectionConstructor> constructors = new List<ConnectionConstructor>();
			foreach (Uri item in list)
			{
				if (!(item.Scheme != "lnl"))
				{
					AddBothConstructors(item, IPAddress.Any);
				}
			}
			foreach (Uri item2 in list)
			{
				if (item2.Scheme == "lnl")
				{
					foreach (IPAddress filteredLocalIP in NetUtils.FilteredLocalIPs)
					{
						AddBothConstructors(item2, filteredLocalIP);
					}
				}
				else
				{
					AddConstructor(item2, dontRoute: false, IPAddress.Any);
				}
			}
			return constructors;
			void AddBothConstructors(Uri uri, IPAddress bindIP)
			{
				AddConstructor(uri, dontRoute: false, bindIP);
				AddConstructor(uri, dontRoute: true, bindIP);
			}
			void AddConstructor(Uri uri, bool dontRoute, IPAddress bindIP)
			{
				constructors.Add(new ConnectionConstructor(this, uri, () => CreateConnection(uri, world, dontRoute, bindIP)));
			}
		}

		public void TransmitData(RawOutMessage data)
		{
			byte[] buffer = data.Data.GetBuffer();
			long length = data.Data.Length;
			foreach (IConnection target in data.Targets)
			{
				NetPeer netPeer = (target as LNL_Peer)?.Peer ?? (target as LNL_Connection)?.Peer;
				if (netPeer != null)
				{
					DeliveryMethod deliveryMethod = ((!data.UseReliable) ? DeliveryMethod.Sequenced : DeliveryMethod.ReliableOrdered);
					byte channelNumber = (data.Background ? ((byte)1) : ((byte)0));
					if (deliveryMethod == DeliveryMethod.Sequenced && netPeer.GetMaxSinglePacketSize(deliveryMethod) < length)
					{
						deliveryMethod = DeliveryMethod.ReliableUnordered;
					}
					netPeer.Send(buffer, 0, (int)length, channelNumber, deliveryMethod);
				}
			}
			data.TransmissionFinished();
		}
	}
