		{
			_frameCompleteTasks.Add(task);
		}

		public void RegisterFrameMemoryBlock(SharedMemoryBlockLease block)
		{
			_memoryBlocks.Add(block);
		}

		public void FrameFinalized()
		{
			foreach (Action frameCompleteTask in _frameCompleteTasks)
			{
				frameCompleteTask();
