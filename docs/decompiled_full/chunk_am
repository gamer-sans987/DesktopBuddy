	public class ReflectionProbeSH2Manager : RenderableComponentManager<ReflectionProbeSH2, ReflectionProbeSH2Tasks>
	{
		private List<ReflectionProbeSH2> _toRender = new List<ReflectionProbeSH2>();

		private SharedMemoryBlockLease<ReflectionProbeSH2Task> _scheduledTasks;

		private int _scheduledFrameIndex;

		protected override bool HasAnyUpdates => _toRender.Count > 0;

		public ReflectionProbeSH2Manager(RenderManager manager)
			: base(manager)
		{
		}

		private void HandleResults()
		{
			Span<ReflectionProbeSH2Task> data = _scheduledTasks.Data;
			for (int i = 0; i < data.Length; i++)
			{
				ref ReflectionProbeSH2Task reference = ref data[i];
				if (reference.renderableIndex < 0)
				{
					break;
				}
				ReflectionProbeSH2 reflectionProbeSH = base[reference.renderableIndex];
				switch (reference.result)
				{
				case ComputeResult.Computed:
					reflectionProbeSH.UpdateValue(reference.resultData);
					continue;
				case ComputeResult.Failed:
					reflectionProbeSH.UpdateValue(default(RenderSH2));
					continue;
				case ComputeResult.Postpone:
					ScheduleRender(reflectionProbeSH);
					continue;
				}
				throw new Exception("Invalid compute result: " + reference.result.ToString() + $", Task: {i} of {data.Length}, scheduled frame index: {_scheduledFrameIndex}");
			}
			_scheduledTasks = null;
			_scheduledFrameIndex = -1;
		}

		protected override void FillUpdates(ReflectionProbeSH2Tasks update)
		{
			if (_scheduledTasks != null)
			{
				throw new InvalidOperationException("Cannot schedule new tasks until previous ones were completed");
			}
			if (_toRender.Count == 0)
			{
				return;
			}
			SharedMemoryBlockLease<ReflectionProbeSH2Task> sharedMemoryBlockLease = base.RenderSystem.AllocateBlock<ReflectionProbeSH2Task>(_toRender.Count, frameBound: true, this);
			Span<ReflectionProbeSH2Task> span = sharedMemoryBlockLease.AccessData();
			int num = 0;
			for (int i = 0; i < _toRender.Count; i++)
			{
				ReflectionProbeSH2 reflectionProbeSH = _toRender[i];
				reflectionProbeSH.RenderRegistered = false;
				if (reflectionProbeSH.IsRenderable)
				{
					ReflectionProbe target = reflectionProbeSH.Probe.Target;
					if (target != null && target.IsRenderable)
					{
						ref ReflectionProbeSH2Task reference = ref span[num++];
						reference.renderableIndex = reflectionProbeSH.RenderableIndex;
						reference.reflectionProbeRenderableIndex = target.RenderableIndex;
						reference.result = ComputeResult.Scheduled;
					}
				}
			}
			if (num < span.Length)
			{
				span[num].renderableIndex = -1;
			}
			update.tasks = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<ReflectionProbeSH2Task>);
			_scheduledTasks = sharedMemoryBlockLease;
			_scheduledFrameIndex = base.RenderSystem.FrameIndex;
			_toRender.Clear();
			base.RenderSystem.Finalizer.RegisterFrameCompleteTask(HandleResults);
		}

		protected override void RenderableAssigned(ReflectionProbeSH2 renderable)
		{
			_toRender.Add(renderable);
		}

		internal void ScheduleRender(ReflectionProbeSH2 sh2)
		{
			if (!sh2.RenderRegistered)
			{
				sh2.RenderRegistered = true;
				_toRender.Add(sh2);
			}
		}
	}
