
		public void Update(MouseState state, float deltaTime)
		{
			base.IsDeviceActive = state.isActive;
			if (base.IsDeviceActive)
			{
				LeftButton.UpdateState(state.leftButtonState);
				RightButton.UpdateState(state.rightButtonState);
				MiddleButton.UpdateState(state.middleButtonState);
				MouseButton4.UpdateState(state.button4State);
				MouseButton5.UpdateState(state.button5State);
				if (base.Input.CursorLockPosition.HasValue)
				{
					Elements.Core.float2 b = (Elements.Core.float2)state.desktopPosition - (Elements.Core.float2)state.windowPosition;
					WindowPosition.UpdateValue(base.Input.CursorLockPosition.Value, deltaTime);
					DesktopPosition.UpdateValue((Elements.Core.float2)base.Input.CursorLockPosition.Value + b, deltaTime);
				}
				else
				{
					WindowPosition.UpdateValue(state.windowPosition, deltaTime);
					DesktopPosition.UpdateValue(state.desktopPosition, deltaTime);
				}
				DirectDelta.UpdateValue(state.directDelta, deltaTime);
				ScrollWheelDelta.UpdateValue(state.scrollWheelDelta, deltaTime);
				NormalizedScrollWheelDelta.UpdateValue((Elements.Core.float2)state.scrollWheelDelta / base.Input.PrimaryResolution.y, deltaTime);
				UpdatePointer(deltaTime);
			}
		}

		private void UpdatePointer(float deltaTime)
		{
			Pointer.Update(WindowPosition.Value, LeftButton.Held, deltaTime, 1f, RightButton.Held, MiddleButton.Held);
		}
	}
