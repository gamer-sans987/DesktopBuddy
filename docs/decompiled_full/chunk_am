	public class ReferenceTranslator
	{
		private Dictionary<Guid, RefID> global2local;

		private Dictionary<RefID, Guid> local2global;

		private Dictionary<Guid, List<ISyncRef>> requests;

		private byte[] _currentGUID = new byte[16];

		public IReadOnlyDictionary<Guid, RefID> Global2Local => global2local;

		public IReadOnlyDictionary<RefID, Guid> Local2Global => local2global;

		public Dictionary<Guid, List<ISyncRef>> GetUnresolvedRequests()
		{
			Dictionary<Guid, List<ISyncRef>> result = requests;
			requests = new Dictionary<Guid, List<ISyncRef>>();
			return result;
		}

		public ReferenceTranslator()
		{
			global2local = new Dictionary<Guid, RefID>();
			local2global = new Dictionary<RefID, Guid>();
			requests = new Dictionary<Guid, List<ISyncRef>>();
		}

		public bool HasReference(RefID local)
		{
			return local2global.ContainsKey(local);
		}

		public bool HasReference(Guid global)
		{
			return global2local.ContainsKey(global);
		}

		public void Associate(RefID local, Guid global, bool isAdditionalReference = false)
		{
			if (local == RefID.Null)
			{
				throw new Exception("Cannot Associate null reference!");
			}
			global2local.Add(global, local);
			if (!isAdditionalReference)
			{
				local2global.Add(local, global);
			}
			if (!requests.TryGetValue(global, out List<ISyncRef> value))
			{
				return;
			}
			foreach (ISyncRef item in value)
			{
				SyncElement syncElement = (SyncElement)item;
				syncElement.IsLoading = true;
				item.Value = local;
				syncElement.IsLoading = false;
			}
			requests.Remove(global);
		}

		private void IncrementGUID()
		{
			for (int i = 0; i < _currentGUID.Length; i++)
			{
				ref byte reference = ref _currentGUID[i];
				if (reference == byte.MaxValue)
				{
					reference = 0;
					continue;
				}
				reference++;
				break;
			}
		}

		public Guid Fetch(RefID local)
		{
			if (local == RefID.Null)
			{
				throw new Exception("Cannot Fetch null reference!");
			}
			if (local2global.TryGetValue(local, out var value))
			{
				return value;
			}
			while (global2local.ContainsKey(new Guid(_currentGUID)))
			{
				IncrementGUID();
			}
			value = new Guid(_currentGUID);
			IncrementGUID();
			Associate(local, value);
			return value;
		}

		public bool Contains(Guid global)
		{
			return global2local.ContainsKey(global);
		}

		public void Request(Guid global, ISyncRef requestee)
		{
			if (global2local.TryGetValue(global, out var value))
			{
				requestee.Value = value;
				return;
			}
			if (!requests.TryGetValue(global, out List<ISyncRef> value2))
			{
				value2 = new List<ISyncRef>();
				requests.Add(global, value2);
			}
			value2.Add(requestee);
		}
	}
