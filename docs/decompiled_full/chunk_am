	public class PermissionController : SyncObject
	{
		public readonly SyncList<PermissionSet> Roles;

		public readonly ReadOnlyRef<PermissionSet> DefaultAnonymousRole;

		public readonly ReadOnlyRef<PermissionSet> DefaultVisitorRole;

		[OldName("DefaultFriendRole")]
		public readonly ReadOnlyRef<PermissionSet> DefaultContactRole;

		public readonly ReadOnlyRef<PermissionSet> DefaultHostRole;

		public readonly ReadOnlyRef<PermissionSet> DefaultOwnerRole;

		public readonly SyncRefDictionary<string, PermissionSet> DefaultUserPermissions;

		private List<ValidationTask> _validations = new List<ValidationTask>();

		private SpinQueue<Action> _postValidationActions = new SpinQueue<Action>();

		private HashSet<string> silencedUsers = new HashSet<string>();

		private bool _runningValidations;

		private bool _runningCleanups;

		public override int Version => 2;

		public PermissionSet HighestRole => Roles[0];

		public PermissionSet LowestRole => Roles[Roles.Count - 1];

		public string DefaultRoleCloudVariable { get; set; }

		public int RolesVersion { get; private set; }

		public bool PermissionHandlingInitialized { get; private set; }

		protected override void OnAwake()
		{
			base.OnAwake();
			Roles.Changed += delegate
			{
				RolesVersion++;
			};
			Roles.MarkNonDrivable();
			Roles.MarkHostOnly();
			ForeachSyncMember(delegate(SyncElement e)
			{
				e.MarkNonDrivable();
			});
			ForeachSyncMember(delegate(ConflictingSyncElement e)
			{
				e.MarkDirectAccessOnly();
			});
		}

		internal void InitializePermissionHandling()
		{
			if (PermissionHandlingInitialized)
			{
				throw new InvalidOperationException("Permission Handling is already initialized");
			}
			base.World.UpdateManager.UpdatableChanged += UpdateManager_UpdatableChanged;
			PermissionHandlingInitialized = true;
		}

		private void UpdateManager_UpdatableChanged(IUpdatable obj)
		{
			if (_runningCleanups)
			{
				return;
			}
			Worker worker = (Worker)obj;
			if (_runningValidations)
			{
				if (base.World.IsDisposed)
				{
					return;
				}
				UniLog.Log("Updatable Changed while running validations: " + worker?.ToString() + ", ScheduledForValidation: " + worker.IsScheduledForValidation + ", CurrentlyUpdatingUser: " + base.World.UpdateManager.CurrentlyUpdatingUser, stackTrace: true);
			}
			if (!worker.IsScheduledForValidation)
			{
				User currentlyUpdatingUser = base.World.UpdateManager.CurrentlyUpdatingUser;
				PermissionSet role = currentlyUpdatingUser.Role;
				if (base.World.IsAuthority || currentlyUpdatingUser == base.LocalUser)
				{
					role?.WorkerChanged(worker, currentlyUpdatingUser, _validations);
				}
			}
		}

		internal async ValueTask ProcessJoinRequest(SessionConnection connection)
		{
			if (CloudVariableHelper.IsValidPath(DefaultRoleCloudVariable))
			{
				CloudResult<string> cloudResult = await base.Engine.Cloud.Variables.Read<string>(connection.UserID, DefaultRoleCloudVariable).ConfigureAwait(continueOnCapturedContext: false);
				if (cloudResult != null && cloudResult.Entity != null)
				{
					connection.RoleOverride = cloudResult.Entity;
					UniLog.Log($"Cloud Variable Role {DefaultRoleCloudVariable} for {connection.UserID} is {cloudResult.Entity}");
				}
			}
		}

		public bool IsSilenced(User user)
		{
			if (silencedUsers.Count == 0)
			{
				return false;
			}
			foreach (string uniqueId in user.UniqueIds)
			{
				if (silencedUsers.Contains(uniqueId))
				{
					return true;
				}
			}
			return false;
		}

		public void AddSilenced(User user)
		{
			foreach (string uniqueId in user.UniqueIds)
			{
				silencedUsers.Add(uniqueId);
			}
		}

		public void RemoveSilenced(User user)
		{
			foreach (string uniqueId in user.UniqueIds)
			{
				silencedUsers.Remove(uniqueId);
			}
		}

		public void RunAfterValidations(Action action)
		{
			_postValidationActions.Enqueue(action);
		}

		public PermissionSet FindRoleByName(string name)
		{
			return Roles.FirstOrDefault((PermissionSet p) => p.RoleName.Value.Equals(name, StringComparison.InvariantCultureIgnoreCase));
		}

		public PermissionSet GetDefaultRole(User user)
		{
			if (user.IsHost)
			{
				if (base.World.CorrespondingRecord == null || Userspace.CanSave(base.World))
				{
					return (SyncRef<PermissionSet>)DefaultOwnerRole;
				}
				PermissionSet permissionSet = (SyncRef<PermissionSet>)DefaultHostRole;
				if (user.UserID != null && DefaultUserPermissions.TryGetTarget(user.UserID, out PermissionSet target) && permissionSet < target)
				{
					permissionSet = target;
				}
				if (base.World.CorrespondingRecord?.OwnerId != null && base.Engine.Cloud.Contacts.IsContact(base.World.CorrespondingRecord.OwnerId) && permissionSet < DefaultContactRole.Target)
				{
					permissionSet = (SyncRef<PermissionSet>)DefaultContactRole;
				}
				UniLog.Log("Default Host Role: " + permissionSet?.RoleName.Value);
				return permissionSet;
			}
			if (!string.IsNullOrWhiteSpace(user.UserID) && user.UserID == base.World.HostUser.UserID)
			{
				return base.World.HostUser.Role;
			}
			if (user.UserID != null)
			{
				if (DefaultUserPermissions.TryGetTarget(user.UserID, out PermissionSet target2))
				{
					return FilterRole(target2);
				}
				if (base.Engine.Cloud.Contacts.IsContact(user.UserID))
				{
					return FilterRole((SyncRef<PermissionSet>)DefaultContactRole);
				}
				if (user.DefaultSpectator)
				{
					return Roles[Roles.Count - 1];
				}
				return FilterRole((SyncRef<PermissionSet>)DefaultVisitorRole);
			}
			return (SyncRef<PermissionSet>)DefaultAnonymousRole;
		}

		public PermissionSet FilterRole(PermissionSet targetRole)
		{
			if (base.World.HostUser.Role < targetRole)
			{
				return base.World.HostUser.Role;
			}
			return targetRole;
		}

		public void AssignDefaultRole(User user, PermissionSet role)
		{
			DefaultUserPermissions.Remove(user.UserID);
			DefaultUserPermissions.Add(user.UserID, role);
		}

		public PermissionSet AddRole(string name, string description = null)
		{
			PermissionSet permissionSet = Roles.Add();
			permissionSet.RoleName.Value = name;
			permissionSet.RoleDescription.Value = description;
			return permissionSet;
		}

		public bool CheckAll<P>(Predicate<P> check, bool includeInstance = false, User user = null, bool noValidatorState = true) where P : class, IWorkerPermissions
		{
			if (base.IsDisposed)
			{
				return false;
			}
			user = user ?? base.LocalUser;
			if (user == null)
			{
