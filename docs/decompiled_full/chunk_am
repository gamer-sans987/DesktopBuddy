	public class RenderTransformManager
	{
		private List<Slot> _renderableSlots = new List<Slot>();

		private List<Slot> _renderableSlotsToAddOrRemove = new List<Slot>();

		private List<Slot> _renderableSlotPoseUpdates = new List<Slot>();

		private List<Slot> _renderableParentUpdates = new List<Slot>();

		public RenderSystem RenderSystem => Engine.RenderSystem;

		public Engine Engine => World.Engine;

		public World World => RenderManager.World;

		public RenderManager RenderManager { get; private set; }

		public int RenderableTransformCount => _renderableSlots.Count;

		public int EstimatedAdditionCount { get; private set; }

		public int EstimatedRemovalCount { get; private set; }

		public int EstimatedParentUpdateCount => _renderableParentUpdates.Count + EstimatedAdditionCount;

		public int EstimatedPoseUpdateCount => _renderableSlotPoseUpdates.Count + EstimatedAdditionCount;

		public RenderTransformManager(RenderManager renderManager)
		{
			RenderManager = renderManager;
		}

		internal void RegisterAddedOrRemovedRenderableSlot(Slot slot)
		{
			_renderableSlotsToAddOrRemove.Add(slot);
			if (slot.IsRenderable)
			{
				EstimatedAdditionCount++;
			}
			else
			{
				EstimatedRemovalCount++;
			}
		}

		internal void RegisterPoseUpdate(Slot slot)
		{
			_renderableSlotPoseUpdates.Add(slot);
		}

		internal void RegisterParentUpdate(Slot slot)
		{
			_renderableParentUpdates.Add(slot);
		}

		internal TransformsUpdate? GenerateUpdate()
		{
			if (EstimatedRemovalCount == 0 && EstimatedParentUpdateCount == 0 && EstimatedPoseUpdateCount == 0)
			{
				return null;
			}
			TransformsUpdate transformsUpdate = new TransformsUpdate();
			SharedMemoryBlockLease<int> sharedMemoryBlockLease = RenderSystem.AllocateBlock<int>(EstimatedRemovalCount, frameBound: true, this);
			SharedMemoryBlockLease<TransformParentUpdate> sharedMemoryBlockLease2 = RenderSystem.AllocateBlock<TransformParentUpdate>(EstimatedParentUpdateCount, frameBound: true, this);
			SharedMemoryBlockLease<TransformPoseUpdate> sharedMemoryBlockLease3 = RenderSystem.AllocateBlock<TransformPoseUpdate>(EstimatedPoseUpdateCount, frameBound: true, this);
			FillUpdate(sharedMemoryBlockLease.AccessData(), sharedMemoryBlockLease2.AccessData(), sharedMemoryBlockLease3.AccessData());
			transformsUpdate.targetTransformCount = RenderableTransformCount;
			transformsUpdate.removals = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<int>);
			transformsUpdate.parentUpdates = sharedMemoryBlockLease2?.Descriptor ?? default(SharedMemoryBufferDescriptor<TransformParentUpdate>);
			transformsUpdate.poseUpdates = sharedMemoryBlockLease3?.Descriptor ?? default(SharedMemoryBufferDescriptor<TransformPoseUpdate>);
			EstimatedAdditionCount = 0;
			EstimatedRemovalCount = 0;
			return transformsUpdate;
		}

		private void FillUpdate(Span<int> removals, Span<TransformParentUpdate> parentUpdates, Span<TransformPoseUpdate> poseUpdates)
		{
			if (removals.Length < EstimatedRemovalCount)
			{
				throw new ArgumentException($"{"removals"} size is too small. Expected: {EstimatedRemovalCount}. Got: {removals.Length}");
			}
			if (parentUpdates.Length < EstimatedParentUpdateCount)
			{
				throw new ArgumentException($"{"parentUpdates"} size is too small. Expected: {EstimatedParentUpdateCount}. Got: {parentUpdates.Length}");
			}
			if (poseUpdates.Length < EstimatedPoseUpdateCount)
			{
				throw new ArgumentException($"{"poseUpdates"} size is too small. Expected: {EstimatedPoseUpdateCount}. Got: {poseUpdates.Length}");
			}
			int num = 0;
			for (int i = 0; i < _renderableSlotsToAddOrRemove.Count; i++)
			{
				Slot slot = _renderableSlotsToAddOrRemove[i];
				if (!slot.IsRenderable && slot.IsRenderTransformAllocated)
				{
					removals[num++] = slot.RenderTransformIndex;
					RemoveRenderTransform(slot);
				}
			}
			if (num < removals.Length)
			{
				removals[num] = -1;
			}
			for (int j = 0; j < _renderableSlotsToAddOrRemove.Count; j++)
			{
				Slot slot2 = _renderableSlotsToAddOrRemove[j];
				if (slot2.IsRenderable && !slot2.IsRenderTransformAllocated)
				{
					AssignRenderTransform(slot2);
				}
			}
			_renderableSlotsToAddOrRemove.Clear();
			int num2 = 0;
			for (int k = 0; k < _renderableParentUpdates.Count; k++)
			{
				Slot slot3 = _renderableParentUpdates[k];
				if (slot3.IsRenderTransformAllocated && !slot3.IsRootSlot)
				{
					ref TransformParentUpdate reference = ref parentUpdates[num2++];
					reference.transformId = slot3.RenderTransformIndex;
					reference.newParentId = slot3.Parent.RenderTransformIndex;
				}
			}
			_renderableParentUpdates.Clear();
			if (num2 < parentUpdates.Length)
			{
				parentUpdates[num2].transformId = -1;
			}
			int num3 = 0;
			for (int l = 0; l < _renderableSlotPoseUpdates.Count; l++)
			{
				Slot slot4 = _renderableSlotPoseUpdates[l];
				slot4.IsRenderTransformDirty = false;
				if (slot4.IsRenderTransformAllocated)
				{
					ref TransformPoseUpdate reference2 = ref poseUpdates[num3++];
					reference2.transformId = slot4.RenderTransformIndex;
					reference2.pose.position = slot4.LocalPosition;
					reference2.pose.rotation = slot4.LocalRotation;
					reference2.pose.scale = slot4.LocalScale;
				}
			}
			_renderableSlotPoseUpdates.Clear();
			if (num3 < poseUpdates.Length)
			{
				poseUpdates[num3].transformId = -1;
			}
		}

		private void AssignRenderTransform(Slot slot)
		{
			slot.RenderTransformIndex = _renderableSlots.Count;
			slot.IsRenderTransformDirty = true;
			_renderableSlots.Add(slot);
			_renderableSlotPoseUpdates.Add(slot);
			_renderableParentUpdates.Add(slot);
		}

		private void RemoveRenderTransform(Slot slot)
		{
			int renderTransformIndex = slot.RenderTransformIndex;
			int index = _renderableSlots.Count - 1;
			Slot slot2 = _renderableSlots[index];
			_renderableSlots[renderTransformIndex] = slot2;
			slot2.RenderTransformIndex = renderTransformIndex;
			_renderableSlots.RemoveAt(index);
			slot.RenderTransformIndex = -1;
		}
	}
	public static class SlotRenderer
	{
		public static void GetRenderPoint(this Slot slot, out Elements.Core.float3 globalPosition, out Elements.Core.floatQ globalRotation, Elements.Core.int2 size, Elements.Core.float3 sourcePosition, float fov = 60f)
		{
			slot.GetRenderPoint(out globalPosition, out globalRotation, out var _, out var _, size, sourcePosition, fov);
		}

		public static void GetRenderPoint(this Slot slot, out Elements.Core.float3 globalPosition, out Elements.Core.floatQ globalRotation, out float minDistance, out float radius, Elements.Core.int2 size, Elements.Core.float3 sourcePosition, float fov = 60f)
		{
			World world = slot.World;
			Elements.Core.BoundingSphere boundingSphere = Elements.Core.BoundingSphere.FromBoundingBox(slot.ComputeBoundingBox());
			float aspectRatio = (float)size.x / (float)size.y;
			float fieldOfView = MathX.HorizontalFOVFromVerical(fov, aspectRatio);
			minDistance = MathX.Max(MathX.MinSpherePointDistance(boundingSphere.radius, fov), MathX.MinSpherePointDistance(boundingSphere.radius, fieldOfView));
			radius = boundingSphere.radius;
			Elements.Core.float3 forward = boundingSphere.center - sourcePosition;
			globalPosition = boundingSphere.center - forward.Normalized * minDistance;
			globalRotation = Elements.Core.floatQ.LookRotation(in forward);
			if (world.Focus == World.WorldFocus.Overlay || world.Focus == World.WorldFocus.PrivateOverlay)
			{
				World focusedWorld = world.Engine.WorldManager.FocusedWorld;
				globalPosition = WorldManager.TransferPoint(globalPosition, world, focusedWorld);
				globalRotation = WorldManager.TransferRotation(globalRotation, world, focusedWorld);
			}
		}

		public static async Task<Uri> RenderToAsset(this Slot slot, Elements.Core.int2 size, Elements.Core.float3 sourcePosition, float fov = 60f, string format = "png", int quality = 80, List<Slot> excludeObjects = null)
		{
			slot.GetRenderPoint(out var globalPosition, out var globalRotation, out var minDistance, out var radius, size, sourcePosition, fov);
			RenderTask renderTask = new RenderTask(globalPosition, globalRotation);
			renderTask.parameters.fov = fov;
			renderTask.parameters.resolution = size;
			renderTask.parameters.nearClip = minDistance * 0.5f;
			renderTask.parameters.farClip = minDistance + radius * 3f;
			renderTask.excludeObjects = excludeObjects;
			return await slot.RenderToAsset(renderTask, format, quality);
		}

		public static async Task<Uri> RenderToAsset(this Slot slot, RenderTask renderSettings, string format = "png", int quality = 80)
		{
			World world = slot.World;
			renderSettings.parameters.textureFormat = TextureFormat.ARGB32;
			renderSettings.customPostProcess = PostProcess;
			renderSettings.renderObjects = new List<Slot>();
			renderSettings.renderObjects.Add(slot);
			renderSettings.parameters.postProcessing = false;
			renderSettings.parameters.clearMode = CameraClearMode.Color;
			renderSettings.ClearColor = Elements.Core.colorX.Clear;
			Bitmap2D bitmap2D = await world.Coroutines.StartTask(async () => await world.Render.RenderToBitmap(renderSettings).ConfigureAwait(continueOnCapturedContext: false)).ConfigureAwait(continueOnCapturedContext: false);
			if (bitmap2D.Size.x == 0 || bitmap2D.Size.y == 0)
			{
				renderSettings.customPostProcess = null;
				renderSettings.parameters.clearMode = CameraClearMode.Skybox;
				renderSettings.renderObjects = null;
				Bitmap2D texture = await world.Coroutines.StartTask(async () => await world.Render.RenderToBitmap(renderSettings).ConfigureAwait(continueOnCapturedContext: false)).ConfigureAwait(continueOnCapturedContext: false);
				return await slot.Engine.LocalDB.SaveAssetAsync(texture, format, quality).ConfigureAwait(continueOnCapturedContext: false);
			}
			return await slot.Engine.LocalDB.SaveAssetAsync(bitmap2D, format, quality).ConfigureAwait(continueOnCapturedContext: false);
		}

		public static Bitmap2D PostProcess(Bitmap2D bitmap)
		{
			Bitmap2D bitmap2D = bitmap.TrimTransparent();
			if (bitmap2D.Size.x == 0 || bitmap2D.Size.y == 0)
			{
				bitmap2D = bitmap.TrimByCornerColor();
			}
			return bitmap2D;
		}

		public static async Task<StaticTexture2D> RenderToStaticTexture(this Slot slot, Slot texSlot, Elements.Core.int2 size, Elements.Core.float3 sourcePosition, float fov = 60f, string format = "png", int quality = 80)
		{
			if (texSlot == null)
			{
				texSlot = slot.World.AssetsSlot.AddSlot("Object Render");
			}
			Uri uri = await slot.RenderToAsset(size, sourcePosition, fov, format, quality);
			return await texSlot.StartTask(async delegate
			{
				await default(ToWorld);
				StaticTexture2D staticTexture2D = texSlot.AttachComponent<StaticTexture2D>();
				staticTexture2D.URL.Value = uri;
				return staticTexture2D;
			});
		}
	}
