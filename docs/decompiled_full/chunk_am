		private SyncVar GetSetting(string path, SyncDictionary<string, SyncVar> root)
		{
			int pathSeparatorIndex = GetPathSeparatorIndex(path);
			string key;
			if (pathSeparatorIndex >= 0)
			{
				key = path.Substring(0, pathSeparatorIndex);
				path = path.Substring(pathSeparatorIndex + 1);
			}
			else
			{
				key = path;
				path = null;
			}
			if (!root.TryGetElement(key, out SyncVar element))
			{
				return null;
			}
			if (element == null)
			{
				return null;
			}
			if (path == null)
			{
				return element;
			}
			SyncDictionary<string, SyncVar> syncDictionary = element.AsDictionary<string, SyncVar>(setIfDifferent: false);
			if (syncDictionary == null)
			{
				return null;
			}
			return GetSetting(path, syncDictionary);
		}

