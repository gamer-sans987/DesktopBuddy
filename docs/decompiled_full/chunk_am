	public class RenderAssetManager<A> where A : class, IRendererAsset
	{
		private int _idPool;

		private Dictionary<int, A> _assetsById = new Dictionary<int, A>();

		private object _lock = new object();

		public A this[AssetCommand command] => this[command.assetId];

		public A this[int assetId]
		{
			get
			{
				lock (_lock)
				{
					if (_assetsById.TryGetValue(assetId, out var value))
					{
						return value;
					}
				}
				throw new ArgumentException($"There is no asset of type {typeof(A)} with AssetID {assetId}");
			}
		}

		public A TryGet(AssetCommand command)
		{
			return TryGet(command.assetId);
		}

		public A TryGet(int assetId)
		{
			lock (_lock)
			{
				if (_assetsById.TryGetValue(assetId, out var value))
				{
					return value;
				}
				return null;
			}
		}

		internal int RegisterAsset(A asset)
		{
			if (asset.AssetId >= 0)
			{
				throw new InvalidOperationException("This renderer asset has already been registered");
			}
			lock (_lock)
			{
				int num = _idPool++;
				_assetsById.Add(num, asset);
				return num;
			}
		}

		internal void UnregisterAsset(A asset)
		{
			if (asset.AssetId < 0)
			{
				throw new InvalidOperationException("This asset is not registered");
			}
			lock (_lock)
			{
				_assetsById.Remove(asset.AssetId);
			}
		}
	}
