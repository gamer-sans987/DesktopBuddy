			ITrackedDevice device5 = base.Input.GetDevice((ITrackedDevice d) => d.TrackingSpace == this && d.CorrespondingBodyNode == BodyNode.LeftLowerArm);
			ITrackedDevice device6 = base.Input.GetDevice((ITrackedDevice d) => d.TrackingSpace == this && d.CorrespondingBodyNode == BodyNode.RightLowerArm);
			ITrackedDevice device7 = base.Input.GetDevice((ITrackedDevice d) => d.TrackingSpace == this && d.CorrespondingBodyNode == BodyNode.LeftFoot);
			ITrackedDevice device8 = base.Input.GetDevice((ITrackedDevice d) => d.TrackingSpace == this && d.CorrespondingBodyNode == BodyNode.RightFoot);
			ITrackedDevice device9 = base.Input.GetDevice((ITrackedDevice d) => d.TrackingSpace == this && d.CorrespondingBodyNode == BodyNode.Chest);
			if (device == null || device2 == null || device3 == null || device4 == null || device5 == null || device6 == null || device7 == null || device8 == null || device9 == null)
			{
				return false;
			}
			Elements.Core.float3 a = device.RawPosition;
			Elements.Core.float3 b = device2.RawPosition;
			Elements.Core.float3 a2 = device3.RawPosition;
			Elements.Core.float3 v = device4.RawPosition;
			Elements.Core.float3 a3 = device5.RawPosition;
			Elements.Core.float3 a4 = device6.RawPosition;
			Elements.Core.float3 b2 = (device7.RawPosition + device8.RawPosition) * 0.5f;
			Elements.Core.float3 a5 = device9.RawPosition;
			Elements.Core.float3 b3 = (a5 - b2).Normalized;
			Elements.Core.float3 b4 = MathX.Reject(in a3, in b3);
			Elements.Core.float3 a6 = MathX.Reject(in a4, in b3);
			Elements.Core.float3 forward = (a2 - b).x_z.Normalized;
			Elements.Core.float3 forward2 = (a6 - b4).Normalized;
			Elements.Core.floatQ to = Elements.Core.floatQ.LookRotation(in forward, Elements.Core.float3.Up);
			Elements.Core.floatQ q = Elements.Core.floatQ.FromToRotation(Elements.Core.floatQ.LookRotation(in forward2, in b3), to);
			Elements.Core.float3 b5 = q * v;
			_ = q * a3;
			_ = q * a4;
			Elements.Core.float3 b6 = a - b5;
			b2 = q * b2;
			a5 = q * a5;
			b2 += b6;
			a5 += b6;
			SetOffset(b6, q);
			return true;
		}
	}
	public class VR_Manager
	{
		private GeneralHeadset _headset;

		private Dictionary<string, ControllerBase> _controllers = new Dictionary<string, ControllerBase>();

		private Dictionary<string, MappableTrackedObject> _controllerBoundHands = new Dictionary<string, MappableTrackedObject>();

		private Dictionary<string, ViveTracker> _trackers = new Dictionary<string, ViveTracker>();

		private Dictionary<string, TrackedObject> _trackingReferences = new Dictionary<string, TrackedObject>();

		private Dictionary<string, Hand> _hands = new Dictionary<string, Hand>();

		private DateTime _lastActivityChange;

		private bool _lastIsPresent;

		private Elements.Core.float3 _lastPresentPos;

		private Elements.Core.floatQ _lastPresentRot = Elements.Core.floatQ.Identity;

		private HapticPoint _leftControllerHapticPoint;

		private HapticPoint _rightControllerHapticPoint;

		private double _leftVibration;

		private double _rightVibration;

		private ViveHandTrackingDriver _viveHandTracking;

		public InputInterface Input { get; private set; }

		public VR_Manager(InputInterface input)
		{
			Input = input;
		}

		public void Update(VR_InputsState state, float deltaTime)
		{
			if (state == null)
			{
				return;
			}
			Input.UpdatePlatformDashboard(state.dashboardOpen);
			if (state.headsetState != null)
			{
				HandleHeadsetState(state.headsetState, deltaTime);
			}
			UpdateActivityState(state.userPresentInHeadset);
			if (state.controllers != null)
			{
				foreach (VR_ControllerState controller in state.controllers)
				{
					HandleController(controller, deltaTime);
				}
			}
			if (state.trackers != null)
			{
				foreach (TrackerState tracker in state.trackers)
				{
					HandleTracker(tracker, deltaTime);
				}
			}
			if (state.trackingReferences != null)
			{
				foreach (TrackingReferenceState trackingReference in state.trackingReferences)
				{
					HandleTrackingReference(trackingReference, deltaTime);
				}
			}
			if (state.hands != null)
			{
				foreach (HandState hand in state.hands)
				{
					HandleHand(hand, deltaTime);
				}
			}
			if (_viveHandTracking != null)
			{
				_viveHandTracking.UpdateInputs(state.viveHandTracking, deltaTime);
			}
		}

		public void CollectOutputState(Renderite.Shared.OutputState output)
		{
			if (output.vr == null)
			{
				output.vr = new VR_OutputState();
			}
			UpdateHaptics(_leftControllerHapticPoint, Chirality.Left, ref _leftVibration, ref output.vr.leftController);
			UpdateHaptics(_rightControllerHapticPoint, Chirality.Right, ref _rightVibration, ref output.vr.rightController);
			output.vr.useViveHandTracking = _viveHandTracking?.TrackingEnabled ?? false;
		}

		private void UpdateHaptics(HapticPoint point, Chirality side, ref double vibrationTime, ref VR_ControllerOutputState state)
		{
			if (state == null)
			{
				if (point == null && vibrationTime <= 0.0)
				{
					return;
				}
				state = new VR_ControllerOutputState();
			}
			state.side = side;
			state.vibrateTime = vibrationTime;
			vibrationTime = 0.0;
			if (point != null)
			{
				point.SampleSources();
				state.hapticState.force = point.Force;
				state.hapticState.vibration = point.Vibration;
				state.hapticState.pain = point.Pain;
				state.hapticState.temperature = point.Temperature;
			}
			else
			{
				state.hapticState = default(HapticPointState);
			}
		}

		private void HandleHeadsetState(HeadsetState state, float deltaTime)
		{
			if (_headset == null)
			{
				_headset = Input.CreateDevice<GeneralHeadset>(state.headsetModel);
				_headset.CorrespondingBodyNode = BodyNode.Head;
				_headset.ConnectionType = state.connectionType;
				if (state.connectionType == HeadsetConnection.WirelessSteamLink || state.headsetModel.Contains("oculus", StringComparison.InvariantCultureIgnoreCase))
				{
					Input.RegisterInputDriver(new SteamLinkOSC_Driver());
				}
				if (Input.HeadOutputDevice == HeadOutputDevice.SteamVR)
				{
					UniLog.Log("Registering Vive Hand Tracking Driver");
					_viveHandTracking = new ViveHandTrackingDriver(Input);
				}
			}
			_headset.IsDeviceActive = true;
			_headset.IsTracking = state.isTracking;
			if (state.isTracking)
			{
				_headset.RawPosition = state.position;
				_headset.RawRotation = state.rotation;
				_headset.BatteryLevel.UpdateValue(state.batteryLevel, deltaTime);
				_headset.BatteryCharging.UpdateState(state.batteryCharging);
			}
		}

		private void UpdateActivityState(bool isPresent)
		{
			if (isPresent && !_lastIsPresent && MathX.Distance(in _lastPresentPos, _headset.RawPosition) <= 0.025f && MathX.Angle(in _lastPresentRot, _headset.RawRotation) <= 1f && (DateTime.UtcNow - _lastActivityChange).TotalSeconds <= 5.0)
			{
				isPresent = false;
			}
			if (_lastIsPresent != isPresent)
			{
				if (!isPresent)
				{
					_lastPresentPos = _headset.Position;
					_lastPresentRot = _headset.Rotation;
				}
				Input.UpdateUserPresent(isPresent);
				_lastIsPresent = isPresent;
			}
			_lastActivityChange = DateTime.UtcNow;
		}

		private void HandleTracker(TrackerState state, float deltaTime)
		{
			if (!_trackers.TryGetValue(state.uniqueId, out ViveTracker value))
			{
				UniLog.Log("Allocating tracker: " + state.uniqueId);
				value = Input.CreateDevice<ViveTracker>("Vive Tracker");
				value.UniqueID = state.uniqueId;
				_trackers.Add(state.uniqueId, value);
			}
			if (!value.FreezeTracking)
			{
				if (state.isTracking)
				{
					value.IsTracking = true;
					value.RawPosition = state.position;
					value.RawRotation = state.rotation;
				}
				else
				{
					value.IsTracking = false;
				}
				value.IsDeviceActive = value.ShouldMappingBeActive;
			}
		}

		private void HandleTrackingReference(TrackingReferenceState state, float deltaTime)
		{
			if (!_trackingReferences.TryGetValue(state.uniqueId, out TrackedObject value))
			{
				value = Input.CreateDevice<TrackedObject>("Tracking Reference " + state.uniqueId);
				_trackingReferences.Add(state.uniqueId, value);
			}
			value.IsTracking = state.isTracking;
			if (value.IsTracking)
			{
				value.RawPosition = state.position;
				value.RawRotation = state.rotation;
			}
		}

		private void HandleController(VR_ControllerState state, float deltaTime)
		{
			if (!(state is CosmosControllerState state2))
			{
				if (!(state is GenericControllerState state3))
				{
					if (!(state is HP_ReverbControllerState state4))
					{
						if (!(state is IndexControllerState state5))
						{
							if (!(state is PicoNeo2ControllerState state6))
							{
								if (!(state is TouchControllerState state7))
								{
									if (!(state is ViveControllerState state8))
									{
										if (!(state is WindowsMR_ControllerState state9))
										{
											throw new NotImplementedException($"Controller type is not implemented: {state}");
										}
										HandleController<WindowsMRController, WindowsMR_ControllerState>(state9, deltaTime);
									}
									else
									{
										HandleController<ViveController, ViveControllerState>(state8, deltaTime);
									}
								}
								else
								{
									HandleController<TouchController, TouchControllerState>(state7, deltaTime);
								}
							}
							else
							{
								HandleController<PicoNeo2Controller, PicoNeo2ControllerState>(state6, deltaTime);
							}
						}
						else
						{
							HandleController<IndexController, IndexControllerState>(state5, deltaTime);
						}
					}
					else
					{
						HandleController<HPReverbController, HP_ReverbControllerState>(state4, deltaTime);
					}
				}
				else
				{
					HandleController<GenericController, GenericControllerState>(state3, deltaTime);
				}
			}
			else
			{
				HandleController<CosmosController, CosmosControllerState>(state2, deltaTime);
			}
		}

		private void RegisterVibration(ControllerBase controller, double time)
		{
			switch (controller.Side)
			{
			case Chirality.Left:
				_leftVibration = time;
				return;
			case Chirality.Right:
				_rightVibration = time;
				return;
			}
			UniLog.Log($"Received vibration on controller without a valid side. Ignoring. Controller: {controller}");
		}

		private void HandleController<T, S>(S state, float deltaTime) where T : ControllerBase<S>, new() where S : VR_ControllerState
		{
			MappableTrackedObject value = null;
			T controller;
			if (!_controllers.TryGetValue(state.deviceID, out ControllerBase value2))
			{
				controller = Input.CreateDevice<T>(typeof(T).Name + " " + state.deviceModel);
				controller.Side = state.side;
				controller.CorrespondingBodyNode = state.bodyNode;
				UniLog.Log($"Registered controller: {controller.Name} ({controller.Side}, {controller.CorrespondingBodyNode})");
				_controllers.Add(state.deviceID, controller);
				Input.RegisterController(controller);
				if (state.hasBoundHand)
				{
					value = Input.CreateDevice<MappableTrackedObject>(controller.Name + " - Hand");
					value.Initialize(value.Name, BodyNode.LeftHand.GetSide(state.side), MappingTarget.VR, state.handPosition, state.handRotation);
					value.Priority = -10;
					_controllerBoundHands.Add(state.deviceID, value);
				}
				switch (controller.Side)
				{
				case Chirality.Left:
					EnsureHapticPoint(ref _leftControllerHapticPoint, Chirality.Left);
					break;
				case Chirality.Right:
					EnsureHapticPoint(ref _rightControllerHapticPoint, Chirality.Right);
					break;
				}
				controller.VibrationCallback = delegate(double time)
				{
					RegisterVibration(controller, time);
				};
			}
			else
			{
				controller = (T)value2;
				_controllerBoundHands.TryGetValue(state.deviceID, out value);
			}
			controller.IsDeviceActive = Input.VR_Active;
			if (value != null)
			{
				value.IsDeviceActive = value.ShouldMappingBeActive && controller.IsDeviceActive;
			}
			if (state.side != controller.Side)
			{
				UniLog.Log($"Controller {controller} - {state.deviceID} changed side from {controller.Side} -> {state.side}");
				controller.Side = state.side;
				Input.RegisterController(controller);
			}
			if (state.isTracking)
			{
				controller.IsTracking = true;
				controller.RawPosition = state.position;
				controller.RawRotation = state.rotation;
				controller.BatteryLevel.UpdateValue(state.batteryLevel, deltaTime);
				controller.BatteryCharging.UpdateState(state.batteryCharging);
				if (value != null)
				{
					value.IsTracking = true;
					value.RawPosition = state.position;
					value.RawRotation = state.rotation;
				}
			}
			else
			{
				controller.IsTracking = false;
				if (value != null)
				{
					value.IsTracking = false;
				}
			}
			controller.ApplyState(state, deltaTime);
			void EnsureHapticPoint(ref HapticPoint point, Chirality side)
			{
				if (point == null)
				{
					point = new HapticPoint(Input, 0.05f, new ControllerHapticPosition(side));
					Input.RegisterHapticPoint(point);
				}
			}
		}

		private void HandleHand(HandState handState, float deltaTime)
		{
			if (!_hands.TryGetValue(handState.uniqueId, out Hand value))
			{
				value = new Hand(Input, handState.chirality, handState.priority);
				value.TracksMetacarpals = handState.tracksMetacarpals;
				SetHandTracking(value, tracking: false, forceSet: true);
				_hands.Add(handState.uniqueId, value);
				UniLog.Log($"Registered hand: {handState.uniqueId} - {value.Chirality}");
			}
			SetHandDeviceActive(value, handState.isDeviceActive && Input.VR_Active);
			SetHandTracking(value, handState.isTracking);
			if (value.IsTracking)
			{
				value.Wrist.RawPosition = handState.wristPosition;
				value.Wrist.RawRotation = handState.wristRotation;
				for (BodyNode bodyNode = BodyNode.LeftThumb_Metacarpal; bodyNode <= BodyNode.LeftPinky_Tip; bodyNode++)
				{
					int index = (int)(bodyNode - 19);
					FingerSegment fingerSegment = value[bodyNode.GetSide(value.Chirality)];
					fingerSegment.RawPosition = handState.segmentPositions[index];
					fingerSegment.RawRotation = handState.segmentRotations[index];
				}
			}
		}

		private static void SetHandTracking(Hand hand, bool tracking, bool forceSet = false)
		{
			if (hand.IsTracking == tracking && !forceSet)
			{
				return;
			}
			hand.IsTracking = tracking;
			hand.Wrist.IsTracking = tracking;
			foreach (Finger item in hand)
			{
				foreach (FingerSegment item2 in item)
				{
					item2.IsTracking = tracking;
				}
			}
		}

		public static void SetHandDeviceActive(Hand hand, bool isActive)
		{
			if (hand.IsDeviceActive == isActive)
			{
				return;
			}
			hand.IsDeviceActive = isActive;
			hand.Wrist.IsDeviceActive = isActive;
			foreach (Finger item in hand)
			{
				foreach (FingerSegment item2 in item)
				{
					item2.IsDeviceActive = isActive;
				}
			}
		}
	}
