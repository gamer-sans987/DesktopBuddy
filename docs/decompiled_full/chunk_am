		private async Task ProcessScreenshot(ScreenshotData data)
		{
			await default(ToBackground);
			Bitmap2D bitmap2D = Bitmap2D.Load(data.file, false);
			if (bitmap2D.Size.x > 3840 || bitmap2D.Size.y > 2160)
			{
				bitmap2D = bitmap2D.GetRescaled(3840);
			}
			data.file = Path.GetTempFileName() + ".jpg";
			bitmap2D.Save(data.file);
			string normalFile = data.file;
			EVRScreenshotType evrType;
			switch (data.type)
			{
			case ScreenshotType.Mono:
				evrType = EVRScreenshotType.k_EVRScreenshotType_Mono;
				break;
			case ScreenshotType.Mono360:
				evrType = EVRScreenshotType.k_EVRScreenshotType_MonoPanorama;
				break;
			case ScreenshotType.Stereo:
				evrType = EVRScreenshotType.k_EVRScreenshotType_Stereo;
				bitmap2D = bitmap2D.Crop(0, 0, bitmap2D.Size.x / 2, bitmap2D.Size.y);
				normalFile = Path.GetTempFileName() + ".jpg";
				bitmap2D.Save(normalFile);
				break;
			default:
				evrType = EVRScreenshotType.k_EVRScreenshotType_None;
				break;
			}
			await default(ToWorld);
			ScreenshotHandle hScreenshot = SteamScreenshots.AddVRScreenshotToLibrary(evrType, normalFile, data.file);
			SteamScreenshots.SetLocation(hScreenshot, data.worldName);
			foreach (ulong steamId in data.steamIds)
			{
				SteamScreenshots.TagUser(hScreenshot, new CSteamID(steamId));
			}
			await DeleteFile(data.file).ConfigureAwait(continueOnCapturedContext: false);
			if (data.file != normalFile)
			{
				await DeleteFile(normalFile).ConfigureAwait(continueOnCapturedContext: false);
			}
		}

		private async Task DeleteFile(string file)
		{
			do
			{
				try
				{
					File.Delete(file);
				}
				catch (Exception)
				{
				}
				await Task.Delay(1000).ConfigureAwait(continueOnCapturedContext: false);
			}
			while (File.Exists(file));
		}

		private void GameRichPresenceJoinRequested(GameRichPresenceJoinRequested_t request)
		{
			if (RichPresencePreference < RichPresenceLevel.Basic || !request.m_rgchConnect.Contains("-Join"))
			{
				return;
			}
			string url = request.m_rgchConnect.Replace("-Join", "").Trim();
			if (Uri.IsWellFormedUriString(url, UriKind.Absolute))
			{
				Interface.Engine.GlobalCoroutineManager.RunInSeconds(0f, delegate
				{
					Userspace.JoinSession(new Uri(url));
				});
			}
		}
