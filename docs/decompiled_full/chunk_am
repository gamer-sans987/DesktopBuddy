			}
			_memoryBlocks.Clear();
		}
	}
	public class GlobalRenderableManager<R> where R : RenderableComponent, IGloballyMappedRenderableComponent
	{
		private int _idPool;

		private Dictionary<int, R> _renderablesById = new Dictionary<int, R>();

		private object _lock = new object();

		public R this[int renderableId]
		{
			get
			{
				lock (_lock)
				{
					if (_renderablesById.TryGetValue(renderableId, out var value))
					{
						return value;
					}
					throw new ArgumentException($"There is no renderable of type {typeof(R)} with UniqueID {renderableId}");
				}
			}
		}

		public R TryGet(int renderableId)
		{
			lock (_lock)
			{
				if (_renderablesById.TryGetValue(renderableId, out var value))
				{
					return value;
				}
				return null;
			}
		}

		internal int RegisterRenderable(R renderable)
		{
			if (renderable.GlobalUniqueId >= 0)
			{
				throw new InvalidOperationException("This renderable has already been registered");
			}
			lock (_lock)
			{
				int num = _idPool++;
				_renderablesById.Add(num, renderable);
				return num;
			}
		}

		internal void UnregisterRenderable(R renderable)
		{
			if (renderable.GlobalUniqueId < 0)
			{
				throw new InvalidOperationException("This renderable is not registered");
			}
			lock (_lock)
			{
				_renderablesById.Remove(renderable.GlobalUniqueId);
			}
		}
	}
