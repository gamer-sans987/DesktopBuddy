		private DataFeedItem TrackerToItem(ISyncMember item)
		{
			Tracker tracker = (Tracker)item;
			DataFeedGroup dataFeedGroup = new DataFeedGroup();
			List<DataFeedItem> list = new List<DataFeedItem>();
			foreach (DataFeedItem item2 in SettingsDataFeed.EnumerateSettingProperties(typeof(Tracker), null, typeof(TrackerSettings), "Trackers", "GetTrackerForSubsetting", tracker.TrackerID.Value))
			{
				list.Add(item2);
			}
