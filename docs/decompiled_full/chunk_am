		internal RenderSpaceUpdate CollectRenderUpdate(List<CameraRenderTask> renderTasks)
		{
			CheckRenderingSupported();
			if (_stagedRenderSpaceUpdate == null)
			{
				throw new InvalidOperationException("There's no staged render space update!");
			}
			lock (_scheduledRenderTasks)
			{
				foreach (RenderTask task in _scheduledRenderTasks)
				{
					CameraRenderTask cameraRenderTask = new CameraRenderTask();
					cameraRenderTask.renderSpaceId = World.LocalWorldHandle;
					Elements.Core.float3 v = task.root?.LocalPointToGlobal(in task.position) ?? task.position;
					Elements.Core.floatQ v2 = task.root?.LocalRotationToGlobal(in task.rotation) ?? task.rotation;
					cameraRenderTask.position = v;
					cameraRenderTask.rotation = v2;
					cameraRenderTask.parameters = task.parameters;
					cameraRenderTask.resultData = ((SharedMemoryBlockLease<byte>)task.bitmap.Buffer).Descriptor;
					if (task.renderObjects != null)
					{
						cameraRenderTask.onlyRenderList = new List<int>();
						foreach (Slot renderObject in task.renderObjects)
						{
							if (renderObject.IsRenderTransformAllocated)
							{
								cameraRenderTask.onlyRenderList.Add(renderObject.RenderTransformIndex);
							}
						}
					}
					if (task.excludeObjects != null)
					{
						cameraRenderTask.excludeRenderList = new List<int>();
						foreach (Slot excludeObject in task.excludeObjects)
						{
							if (excludeObject.IsRenderTransformAllocated)
							{
								cameraRenderTask.excludeRenderList.Add(excludeObject.RenderTransformIndex);
							}
						}
					}
					Render.Finalizer.RegisterFrameCompleteTask(delegate
					{
						task.task.SetResult(result: true);
					});
					renderTasks.Add(cameraRenderTask);
				}
				_scheduledRenderTasks.Clear();
			}
			RenderSpaceUpdate stagedRenderSpaceUpdate = _stagedRenderSpaceUpdate;
			_stagedRenderSpaceUpdate = null;
			return stagedRenderSpaceUpdate;
		}

