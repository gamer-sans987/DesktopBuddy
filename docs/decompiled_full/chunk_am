			}
			buffer[0] = (byte)value;
			buffer[1] = (byte)(value >> 8);
			buffer[2] = (byte)(value >> 16);
			buffer[3] = (byte)(value >> 24);
		}

		private async Task ProcessIncomingData(CancellationToken cancellationToken)
		{
			_ = 1;
			try
			{
				byte[] sizeBuffer = new byte[4];
				while (!cancellationToken.IsCancellationRequested)
				{
					if (!(await ReadData(_stream, sizeBuffer, 4).ConfigureAwait(continueOnCapturedContext: false)))
					{
						throw new Exception("Failed to read size of the next message from TCP stream");
					}
					int messageSize = ToInt32(sizeBuffer);
					byte[] rawData = NetworkManager.GetArray(messageSize);
					if (!(await ReadData(_stream, rawData, messageSize).ConfigureAwait(continueOnCapturedContext: false)))
					{
						throw new Exception($"Failed to read data of size {messageSize} from TCP stream");
					}
					_receivedMessages++;
					_receivedBytes += (uint)messageSize;
					RawInMessage rawMessage = new RawInMessage(this, rawData, 0, messageSize, NetworkManager.ReturnArray, rawData);
					this.NewData(rawMessage);
				}
			}
			catch (Exception value)
			{
				UniLog.Warning($"Exception receiving data from TCP stream:\n{value}");
				Close();
			}
		}

		private async Task UpdateStats(CancellationToken cancellationToken)
		{
			try
			{
				while (!cancellationToken.IsCancellationRequested)
				{
					this.StatsUpdated?.Invoke(this, delegate(User user)
					{
						UpdateUserStats(user);
					});
					await Task.Delay(TimeSpan.FromSeconds(1L), cancellationToken);
				}
			}
			catch (TaskCanceledException)
			{
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception when updating stats:\n{value}");
			}
		}

		private async Task<bool> ReadData(NetworkStream stream, byte[] buffer, int count)
		{
			int offset = 0;
			do
			{
				int num = await stream.ReadAsync(buffer, offset, count).ConfigureAwait(continueOnCapturedContext: false);
				if (num == 0)
				{
					return false;
				}
				offset += num;
				count -= num;
			}
			while (count > 0);
			return true;
		}

		public void Transmit(TCP_TransmissionData data)
		{
			_transmitProcessor.Post(data);
		}

		private async Task TransmitData(TCP_TransmissionData data)
		{
			_ = 1;
			try
			{
				if (!_cancellation.IsCancellationRequested)
				{
					_transmittedMessages++;
					_transmittedBytes += (uint)data.length;
					FromInt32(data.length, _sizeWriteBuffer);
					await _stream.WriteAsync(_sizeWriteBuffer, 0, 4).ConfigureAwait(continueOnCapturedContext: false);
					if (!_cancellation.IsCancellationRequested)
					{
						await _stream.WriteAsync(data.data, 0, data.length).ConfigureAwait(continueOnCapturedContext: false);
					}
				}
			}
			catch (Exception)
			{
				UniLog.Error($"Exception when transmitting data: {data} on {Address}");
				Close();
			}
			finally
			{
				data.TransmissionFinished();
			}
		}

		public void UpdateUserStats(User user)
		{
			if (user == null)
			{
				throw new ArgumentNullException("user");
			}
			if (user.World.IsAuthority)
			{
				user.UploadedBytes = _receivedBytes;
				user.SetNetworkStatistic("Protocol", "TCP");
				user.SetNetworkStatistic("TransmittedMessages", _transmittedMessages);
				user.SetNetworkStatistic("ReceivedMessages", _receivedMessages);
				user.SetNetworkStatistic("NoDelay", _client.NoDelay);
				user.SetNetworkStatistic("ReceiveBufferSize", _client.ReceiveBufferSize);
				user.SetNetworkStatistic("SendBufferSize", _client.SendBufferSize);
			}
			else
			{
				user.DownloadedBytes = _receivedBytes;
			}
		}

