	public class SharedMemoryBlockManager : IDisposable
	{
		private int _unusedTickCount;

		private MemoryView view;

		private UnmanagedMemoryManager<byte> memory;

		private SortedList<int, SharedMemoryBlockLease> blocks = new SortedList<int, SharedMemoryBlockLease>();

		private int index;

		public SharedMemoryManager Manager { get; private set; }

		public string Prefix => Manager.InstancePrefix;

		public int Id { get; private set; }

		public string Name { get; private set; }

		public int Capacity { get; private set; }

		public int BlockCount => blocks.Count;

		public int UsedBytes { get; private set; }

		public int FreeBytes => Capacity - UsedBytes;

		public int UnusedTickCount => _unusedTickCount;

		public Span<byte> RawData => view.Data;

		public Memory<byte> Memory => memory.Memory;

		public unsafe SharedMemoryBlockManager(SharedMemoryManager manager, int id, int capacity)
		{
			Manager = manager;
			Id = id;
			Capacity = capacity;
			Name = Helper.ComposeMemoryViewName(Prefix, id);
			view = new MemoryView(new MemoryViewOptions(Name, Capacity, destroyOnDispose: true), NullLoggerFactory.Instance);
			memory = new UnmanagedMemoryManager<byte>(view.Pointer, Capacity);
		}

		public void IncrementUnused()
		{
			if (UsedBytes <= 0)
			{
				Interlocked.Increment(ref _unusedTickCount);
			}
		}

		public unsafe SharedMemoryBlockLease<T> TryClaimBlock<T>(int count, object owner = null) where T : unmanaged
		{
			int num = sizeof(T) * count;
			if (num > FreeBytes)
			{
				return null;
			}
			index %= blocks.Count + 1;
			for (int i = 0; i < blocks.Count + 1; i++)
			{
				int num2 = ((index != 0) ? blocks.GetValueAtIndex(index - 1).BlockBytesEnd : 0);
				int num3 = ((index != blocks.Count) ? blocks.GetValueAtIndex(index).BlockBytesStart : Capacity);
				if (num3 - num2 >= num)
				{
					index++;
					return CreateBlock<T>(num2, num, owner);
				}
				index++;
				index %= blocks.Count + 1;
			}
			return null;
		}

		private SharedMemoryBlockLease<T> CreateBlock<T>(int start, int size, object owner = null) where T : unmanaged
		{
			SharedMemoryBlockLease<T> sharedMemoryBlockLease = new SharedMemoryBlockLease<T>(this, start, size, owner);
			blocks.Add(sharedMemoryBlockLease.BlockBytesStart, sharedMemoryBlockLease);
			if (UsedBytes == 0)
			{
				Manager.AddMemoryManagerInUse();
			}
			UsedBytes += size;
			_unusedTickCount = 0;
			Manager.AddUsedBytes(size);
			return sharedMemoryBlockLease;
		}

		internal void FreeBlock(SharedMemoryBlockLease block)
		{
			lock (Manager.Lock)
			{
				blocks.Remove(block.BlockBytesStart);
				UsedBytes -= block.BlockBytesSize;
				Manager.RemoveUsedBytes(block.BlockBytesSize);
				if (UsedBytes == 0)
				{
					Manager.RemoveMemoryManagerInUse();
				}
			}
		}

		internal void GenerateDebugDiagnostic(StringBuilder builder)
		{
			foreach (KeyValuePair<int, SharedMemoryBlockLease> block in blocks)
			{
				StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(37, 5, builder);
				handler.AppendLiteral("\tBlock Start: ");
				handler.AppendFormatted(block.Value.BlockBytesStart);
				handler.AppendLiteral(", ");
				handler.AppendLiteral("Size: ");
				handler.AppendFormatted(UnitFormatting.FormatBytes(block.Value.SizeBytes));
				handler.AppendLiteral(", Owner: ");
				handler.AppendFormatted(block.Value.Owner?.GetType());
				handler.AppendLiteral(" (");
				handler.AppendFormatted(block.Value.Owner?.GetHashCode());
				handler.AppendLiteral(") = ");
				handler.AppendFormatted(block.Value.Owner?.ToString());
				builder.AppendLine(ref handler);
			}
		}

		public void Dispose()
		{
			view.Dispose();
			view = null;
		}
	}
	public class SharedMemoryManager
	{
		public static readonly TimeSpan PruneUpdateInterval = TimeSpan.FromMilliseconds(250L);

		public const int MINIMUM_MANAGER_CAPACITY = 33554432;

		public const int MANAGER_CAPACITY_ALIGNMENT = 16777216;

		public const int PRUNE_MINIMUM_TICKS = 16;

		private int _idIndex;

		private long _totalUsedBytes;

		private long _totalCapacity;

		private int _usedMemoryManagers;

		private DateTime _lastPruneTime;

		private List<SharedMemoryBlockManager> _managers = new List<SharedMemoryBlockManager>();

		private Action<int> bufferIdFreed;

		public string InstancePrefix { get; private set; }

		internal object Lock { get; private set; } = new object();

		public int ManagerCount => _managers.Count;

		public int UsedManagerCount => _usedMemoryManagers;

		public long TotalUsedBytes => _totalUsedBytes;

		public long TotalFreeBytes => _totalCapacity - _totalUsedBytes;

		public long TotalCapacity => _totalCapacity;

		public bool ShouldPrune
		{
			get
			{
				if (_usedMemoryManagers < ManagerCount)
				{
					return _totalCapacity > _totalUsedBytes * 2 + 33554432;
				}
				return false;
			}
		}

		public SharedMemoryManager(string instancePrefix, Action<int> bufferIdFreed)
		{
			InstancePrefix = instancePrefix;
			this.bufferIdFreed = bufferIdFreed;
		}

		public unsafe SharedMemoryBlockLease<T> ClaimBlock<T>(int count, object owner) where T : unmanaged
		{
			if (count == 0)
			{
				return null;
			}
			if (count < 0)
			{
				throw new ArgumentOutOfRangeException("Count cannot be negative");
			}
			lock (Lock)
			{
				SharedMemoryBlockLease<T> sharedMemoryBlockLease;
				for (int i = 0; i < _managers.Count; i++)
				{
					sharedMemoryBlockLease = _managers[i].TryClaimBlock<T>(count, owner);
					if (sharedMemoryBlockLease != null)
					{
						return sharedMemoryBlockLease;
					}
				}
				int num = sizeof(T) * count;
				if (num < 0)
				{
