	public class ResoniteLinkUpdateContext
	{
		private readonly struct DeferredReferenceWrite
		{
			public readonly Reference linkReference;

			public readonly ISyncRef reference;

			public DeferredReferenceWrite(Reference linkReference, ISyncRef reference)
			{
				this.linkReference = linkReference;
				this.reference = reference;
			}
		}

		private Queue<DeferredReferenceWrite> _deferredWrites;

		private Queue<Slot> _deferredRemovals;

		public ResoniteLinkTranslator Translator { get; private set; }

		public ResoniteLinkReferenceManager References => Translator.References;

		public ResoniteLinkUpdateContext(ResoniteLinkTranslator translator)
		{
			Translator = translator;
		}

		public void DestroySlot(Slot slot)
		{
			if (_deferredRemovals == null)
			{
				_deferredRemovals = new Queue<Slot>();
			}
			_deferredRemovals.Enqueue(slot);
		}

		public void WriteReference(Reference linkReference, ISyncRef reference)
		{
			if (string.IsNullOrEmpty(linkReference.TargetID))
			{
				reference.Target = null;
				return;
			}
			IWorldElement worldElement = References.ResolveReference(linkReference.TargetID);
			if (worldElement == null)
			{
				if (_deferredWrites == null)
				{
					_deferredWrites = new Queue<DeferredReferenceWrite>();
				}
				_deferredWrites.Enqueue(new DeferredReferenceWrite(linkReference, reference));
			}
			else
			{
				WriteReference(linkReference, reference, worldElement);
			}
		}

		public void ProcessDeferredOperations()
		{
			ProcessDeferredRemovals();
			ProcessDeferredWrites();
		}

		private void ProcessDeferredRemovals()
		{
			if (_deferredRemovals != null)
			{
				Slot result;
				while (_deferredRemovals.TryDequeue(out result))
				{
					result.Destroy();
				}
			}
		}

		private void ProcessDeferredWrites()
		{
			if (_deferredWrites != null)
			{
				DeferredReferenceWrite result;
				while (_deferredWrites.TryDequeue(out result))
				{
					IWorldElement target = References.ResolveReference(result.linkReference.TargetID);
					WriteReference(result.linkReference, result.reference, target);
				}
			}
		}

		private void WriteReference(Reference linkReference, ISyncRef reference, IWorldElement target)
		{
			if (target == null)
			{
				throw new InvalidOperationException("Reference target " + linkReference.TargetID + " cannot be resolved");
			}
			if (!Translator.CanProcessSlot(target.FindNearestParent<Slot>()))
			{
				throw new InvalidOperationException("Target is not accessible");
			}
			if (!reference.TrySet(target))
			{
				throw new InvalidOperationException("Reference target " + linkReference.TargetID + " is not compatible type");
			}
		}
	}
