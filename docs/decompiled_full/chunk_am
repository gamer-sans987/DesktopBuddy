	{
		private static readonly GamepadState EmptyGamepadState = new GamepadState();

		public readonly Analog2D LeftThumbstick;

		public readonly Digital LeftThumbstickClick;

		public readonly Analog2D RightThumbstick;

		public readonly Digital RightThumbstickClick;

		public readonly Digital DPadUp;

		public readonly Digital DPadRight;

		public readonly Digital DPadDown;

		public readonly Digital DPadLeft;

		public readonly Analog2D DPad;

		public readonly Analog LeftTrigger;

		public readonly Analog RightTrigger;

		public readonly Digital LeftBumper;

		public readonly Digital RightBumper;

		public readonly Digital Start;

		public readonly Digital Menu;

		public readonly Digital A;

		public readonly Digital B;

		public readonly Digital X;

		public readonly Digital Y;

		public readonly Digital Paddle0;

		public readonly Digital Paddle1;

		public readonly Digital Paddle2;

		public readonly Digital Paddle3;

		private GamepadSettings _settings;

		public override void Initialize(InputInterface input, int deviceIndex, string name)
		{
			base.Initialize(input, deviceIndex, name);
			Settings.RegisterComponentChanges<GamepadSettings>(OnGamepadSettingsChanged);
		}

		private void OnGamepadSettingsChanged(GamepadSettings setting)
		{
			_settings = setting;
		}

		public void UpdateState(GamepadState state, float deltaTime)
		{
			GamepadSettings settings = _settings;
			bool flag = (settings != null && settings.UseGamepadWhenUnfocused.Value) || base.Input.IsWindowFocused;
			UpdateStateInternal(flag ? state : EmptyGamepadState, deltaTime);
		}

		private void UpdateStateInternal(GamepadState state, float deltaTime)
		{
			LeftThumbstick.UpdateValue(state.leftThumbstick, deltaTime);
			LeftThumbstickClick.UpdateState(state.leftThumbstickClick);
			RightThumbstick.UpdateValue(state.rightThumbstick, deltaTime);
			RightThumbstickClick.UpdateState(state.rightThumbstickClick);
			UpdateDPad(state.dPadUp, state.dPadRight, state.dPadDown, state.dPadLeft, deltaTime);
			LeftTrigger.UpdateValue(state.leftTrigger, deltaTime);
			RightTrigger.UpdateValue(state.rightTrigger, deltaTime);
			LeftBumper.UpdateState(state.leftBumper);
			RightBumper.UpdateState(state.rightBumper);
			Start.UpdateState(state.start);
			Menu.UpdateState(state.menu);
			A.UpdateState(state.a);
			B.UpdateState(state.b);
			X.UpdateState(state.x);
			Y.UpdateState(state.y);
			Paddle0.UpdateState(state.paddle0);
			Paddle1.UpdateState(state.paddle1);
			Paddle2.UpdateState(state.paddle2);
			Paddle3.UpdateState(state.paddle3);
		}

		public void UpdateDPad(bool up, bool right, bool down, bool left, float deltaTime)
		{
			DPadUp.UpdateState(up);
			DPadRight.UpdateState(right);
			DPadDown.UpdateState(down);
			DPadLeft.UpdateState(left);
			Elements.Core.float2 a = Elements.Core.float2.Zero;
			if (up)
			{
				a += new Elements.Core.float2(0f, 1f);
			}
			if (right)
			{
				a += new Elements.Core.float2(1f);
			}
			if (down)
			{
				a += new Elements.Core.float2(0f, -1f);
			}
			if (left)
			{
				a += new Elements.Core.float2(-1f);
			}
			DPad.UpdateValue(a, deltaTime);
		}

		public void Bind(InputGroup group)
		{
			if (!(group is GlobalActions globalActions))
			{
				if (!(group is InteractionHandlerInputs interactionHandlerInputs))
				{
					if (!(group is ContextMenuInputs contextMenuInputs))
					{
						if (!(group is LaserHoldInputs laserHoldInputs))
						{
							if (!(group is ScreenCameraInputs screenCameraInputs))
							{
								if (!(group is HeadInputs headInputs))
								{
									if (!(group is TeleportInputs teleportInputs))
									{
										if (!(group is SmoothLocomotionInputs smoothLocomotionInputs))
										{
											if (!(group is SmoothThreeAxisLocomotionInputs smoothThreeAxisLocomotionInputs))
											{
												if (!(group is AnchorLocomotionInputs anchorLocomotionInputs))
												{
													if (group is AnchorReleaseInputs anchorReleaseInputs)
													{
														anchorReleaseInputs.Release.AddBinding(A);
														anchorReleaseInputs.ReleaseStrength.AddBinding(InputNode.Analog2D(LeftThumbstick).Magnitude(), this);
														return;
													}
													UniLog.Warning($"Cannot bind {group} to Standard Gamepad ({base.Name})");
												}
												else
												{
													anchorLocomotionInputs.PrimaryAxis.AddBinding(LeftThumbstick);
													anchorLocomotionInputs.SecondaryAxis.AddBinding(RightThumbstick);
													anchorLocomotionInputs.PrimaryAction.AddBinding(LeftThumbstickClick);
													anchorLocomotionInputs.SecondaryAction.AddBinding(RightThumbstickClick);
												}
											}
											else
											{
												smoothThreeAxisLocomotionInputs.Move.AddBinding(GenerateScreenDirection(), this);
												smoothThreeAxisLocomotionInputs.Jump.AddBinding(A);
												smoothThreeAxisLocomotionInputs.Align.AddBinding(B);
											}
										}
										else
										{
											smoothLocomotionInputs.Move.AddBinding(GenerateScreenDirection(), this);
											smoothLocomotionInputs.Jump.AddBinding(A);
											smoothLocomotionInputs.TurnDelta.AddBinding(GenerateTurn(), this);
										}
									}
									else
									{
										teleportInputs.Teleport.AddBinding(LeftThumbstickClick);
										teleportInputs.Backstep.AddBinding(InputNode.Analog2D(LeftThumbstick).Y().Negate()
											.ToDigital(0.8f), this);
										teleportInputs.TurnDelta.AddBinding(GenerateTurn(), this);
									}
								}
								else
								{
									headInputs.Crouch.AddBinding(InputNode.Digital(LeftBumper).ToAnalog(), this);
									headInputs.Crouch.AddBinding(InputNode.Digital(LeftBumper).MultiTapToggle().ToAnalog(), this);
								}
							}
							else
							{
								screenCameraInputs.Look.AddBinding(InputNode.Analog2D(RightThumbstick).Pow(InputNode.Setting((GamepadSettings s) => s.ThumbstickLookExponent, 0f)).Multiply(InputNode.Setting((GamepadSettings s) => s.ThumbstickLookSpeed, 0f)), this);
							}
						}
						else
						{
							laserHoldInputs.Align.AddBinding(InputNode.PrimarySecondary(InputNode.Digital(RightThumbstickClick), null), this);
							laserHoldInputs.Slide.AddBinding(InputNode.PrimarySecondary(InputNode.Analog2D(RightThumbstick).Y(), null), this);
							laserHoldInputs.Rotate.AddBinding(InputNode.PrimarySecondary(InputNode.Analog2D(RightThumbstick).X(), null), this);
						}
					}
					else
					{
						contextMenuInputs.SelectDirection.AddBinding(RightThumbstick);
						contextMenuInputs.Select.AddBinding(InputNode.Analog(RightTrigger).ToDigital(), this);
					}
				}
				else
				{
					interactionHandlerInputs.Interact.AddBinding(InputNode.PrimarySecondary(InputNode.Analog(RightTrigger).ToDigital(), null), this);
					interactionHandlerInputs.Strength.AddBinding(InputNode.PrimarySecondary(InputNode.Analog(RightTrigger), null), this);
					interactionHandlerInputs.Grab.AddBinding(InputNode.PrimarySecondary(InputNode.Digital(RightBumper), null), this);
					interactionHandlerInputs.Menu.AddBinding(InputNode.PrimarySecondary(InputNode.Digital(Y), null), this);
					interactionHandlerInputs.Secondary.AddBinding(InputNode.PrimarySecondary(InputNode.Digital(X), null), this);
				}
			}
			else
			{
				globalActions.ToggleDash.AddBinding(Start);
			}
		}

		private VR_SingleLocomotionTurn GenerateTurn()
		{
			return new VR_SingleLocomotionTurn(InputNode.Analog2D(RightThumbstick).X());
		}

		private ScreenLocomotionDirection GenerateScreenDirection()
		{
			ScreenLocomotionDirection screenLocomotionDirection = new ScreenLocomotionDirection();
			screenLocomotionDirection.Axis = InputNode.Analog2D(LeftThumbstick);
			screenLocomotionDirection.Fast = InputNode.Digital(LeftThumbstickClick);
			screenLocomotionDirection.Left = InputNode.Digital(DPadLeft);
			screenLocomotionDirection.Right = InputNode.Digital(DPadRight);
			screenLocomotionDirection.Up = InputNode.Digital(DPadUp);
			screenLocomotionDirection.Down = InputNode.Digital(DPadDown);
			screenLocomotionDirection.Up = InputNode.Digital(A);
			screenLocomotionDirection.Down = InputNode.Digital(LeftBumper);
			return screenLocomotionDirection;
		}
	}
