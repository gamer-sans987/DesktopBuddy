		public static S EnsureSettingSwitchSource<S>(World world) where S : SettingSwitchSource, new()
		{
			S globallyRegisteredComponent = world.GetGloballyRegisteredComponent<S>();
			if (globallyRegisteredComponent != null)
			{
				return globallyRegisteredComponent;
			}
			Slot slot = world.RootSlot.FindChild("SettingSwitches");
			if (slot == null)
			{
				slot = world.RootSlot.AddSlot("SettingSwitches");
				slot.PersistentSelf = false;
			}
			UniLog.Log("Created setting switch source: " + typeof(S).Name);
			return slot.AttachComponent<S>();
		}

