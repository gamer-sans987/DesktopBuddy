		public void Preprocess()
		{
			_fontChanged = _fontVersion != _lastFontVersion;
			_stringChanged = _renderTree?.String != _string || _rtf != _lastRtf;
			_lastRtf = _rtf;
			_layoutChanged |= _stringChanged;
			_layoutChanged |= _fontChanged;
			_layoutChanged |= _maskPatternChanged;
			if (_stringChanged || _fontChanged)
			{
				ClearPins();
			}
			if (_fontAssetSet == null || _fontAssetSet.Count == 0 || (string.IsNullOrEmpty(_string) && _caretPosition < 0))
			{
				_renderTree = null;
				return;
			}
			if (_fontChanged)
			{
				_currentFontAssetSet = _fontAssetSet;
				if (_currentFontSet == null)
				{
					_currentFontSet = new List<Elements.Assets.FontSet>();
				}
				else
				{
					_currentFontSet.Clear();
				}
				foreach (FontAssetSet item in _currentFontAssetSet)
				{
					Elements.Assets.FontSet fontSet = item.ToFontSet();
					if (fontSet == null)
					{
						_renderTree = null;
						return;
					}
					_currentFontSet.Add(fontSet);
				}
				_lastFontVersion = _fontVersion;
			}
			if (_currentFontSet == null || _currentFontSet.Count == 0)
			{
				_renderTree = null;
				return;
			}
			if (_stringChanged || _fontChanged || _maskPatternChanged)
			{
				_renderTree = new StringRenderTree(_string, _currentFontSet, delegate(StringContainerNode root)
				{
					if (!string.IsNullOrWhiteSpace(_maskPattern))
					{
						CharSubstitutionNode charSubstitutionNode = new CharSubstitutionNode(_maskPattern[0], 0, root);
						root.Nodes.Add(charSubstitutionNode);
						root = charSubstitutionNode;
					}
					return root;
				}, _rtf);
			}
			_renderTree.Color = _color;
			if (_layoutChanged)
			{
				_renderTree.Size = MaximumSize;
				_renderTree.HorizontalAlignment = _horizontalAlign;
				_renderTree.VerticalAlignment = _verticalAlign;
				_renderTree.AlignmentMode = _alignmentMode;
				_renderTree.LineHeight = _lineHeight;
				_renderTree.BoundsSize = _boundsSize;
				_renderTree.Bounded = _bounded;
				_renderTree.BoundsAlignment = _boundsAlignment;
				_renderTree.ShapeText();
				_textShaped = true;
			}
		}

		public async ValueTask PinGlyphs(Action invalidateCallback)
		{
			if (IsEmpty)
			{
				return;
			}
			List<ValueTask<bool>> pinTasks = Pool.BorrowList<ValueTask<bool>>();
			if (_stringChanged || _fontChanged || _maskPatternChanged)
			{
				List<List<FontAtlases>> atlases = _currentAtlases;
				_currentAtlases = Pool.BorrowList<List<FontAtlases>>();
				for (int i = 0; i < _currentFontAssetSet.Count; i++)
				{
					List<FontAtlases> list = Pool.BorrowList<FontAtlases>();
					_currentAtlases.Add(list);
					foreach (FontAssetData font in _currentFontAssetSet[i].Fonts)
					{
						FontAssetData fontAsset = font;
						List<GlyphAtlasManager> list2 = Pool.BorrowList<GlyphAtlasManager>();
						list.Add(new FontAtlases(in fontAsset, list2));
						ValueTask<bool> item = fontAsset.font.PinGlyphs(_renderTree, invalidateCallback, list2);
						pinTasks.Add(item);
					}
				}
				_materialsChanged |= !Equals(_currentAtlases, atlases);
				if (atlases != null)
				{
					ReturnToPool(ref atlases);
				}
			}
			foreach (ValueTask<bool> item2 in pinTasks)
			{
				bool materialsChanged = _materialsChanged;
				_materialsChanged = materialsChanged | await item2.ConfigureAwait(continueOnCapturedContext: false);
			}
			Pool.Return(ref pinTasks);
		}

