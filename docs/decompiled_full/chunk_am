	public class MultiTouchManager
	{
		private Dictionary<int, Pointer> _pointers = new Dictionary<int, Pointer>();

		public InputInterface Input { get; private set; }

		public MultiTouchManager(InputInterface input)
		{
			Input = input;
		}

		public void UpdateTouches(List<TouchState> touches, float deltaTime)
		{
			HashSet<int> hashSet = Pool.BorrowHashSet<int>();
			foreach (KeyValuePair<int, Pointer> pointer in _pointers)
			{
				hashSet.Add(pointer.Key);
			}
			if (touches != null)
			{
				foreach (TouchState touch in touches)
				{
					if (!_pointers.TryGetValue(touch.touchId, out Pointer value))
					{
						value = new Pointer(touch.touchId, PointerType.Touch);
						_pointers.Add(touch.touchId, value);
						Input.RegisterPointer(value);
					}
					value.Update((Elements.Core.float2)touch.position, touch.isPressing, deltaTime, touch.pressure);
					hashSet.Remove(touch.touchId);
				}
			}
			foreach (int item in hashSet)
			{
				Input.UnregisterPointer(_pointers[item]);
				_pointers.Remove(item);
			}
			Pool.Return(ref hashSet);
		}
	}
