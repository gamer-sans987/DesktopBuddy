		private void AddComponent(AddComponent addComponent, ResoniteLinkUpdateContext context, BatchResponse batch)
		{
			if (!CheckWritePermission<NewEntityId>(addComponent, batch))
			{
				return;
			}
			if (addComponent.Data == null)
			{
				SendErrorResponse<NewEntityId>(addComponent, "No update data was provided", batch);
				return;
			}
			if (string.IsNullOrWhiteSpace(addComponent.ContainerSlotId))
			{
				SendErrorResponse<NewEntityId>(addComponent, "ContainerSlotId must be provided", batch);
				return;
			}
			Slot slot = References.ResolveReference<Slot>(addComponent.ContainerSlotId);
			if (slot == null)
			{
				SendErrorResponse<NewEntityId>(addComponent, "Slot with ID '" + addComponent.ContainerSlotId + "' not found.", batch);
				return;
			}
			if (!Translator.CanProcessSlot(slot))
			{
				SendErrorResponse<NewEntityId>(addComponent, "Container Slot is not accessible.", batch);
				return;
			}
			Type type;
			try
			{
				type = World.Types.DecodeType(addComponent.Data.ComponentType);
				if (type == null)
				{
					throw new Exception("Failed to resolve type");
				}
			}
			catch (Exception ex)
			{
				SendErrorResponse<NewEntityId>(addComponent, "Invalid component type. Error: " + ex.Message, batch);
				return;
			}
			if (addComponent.Data.ID != null && References.HasID(addComponent.Data.ID))
			{
				SendErrorResponse<NewEntityId>(addComponent, "ID '" + addComponent.Data.ID + "' is already in use", batch);
				return;
			}
			Component component = slot.AttachComponent(type);
			try
			{
				if (string.IsNullOrEmpty(addComponent.Data.ID))
				{
					addComponent.Data.ID = References.AllocateID(component);
				}
				else
				{
					References.RegisterReference(addComponent.Data.ID, component);
				}
				Translator.WriteComponentData(addComponent.Data, component, context);
				NewEntityId newEntityId = new NewEntityId();
				newEntityId.Success = true;
				newEntityId.EntityId = addComponent.Data.ID;
				SendResponse(addComponent, newEntityId, batch);
			}
			catch (Exception)
			{
				component.Destroy();
				throw;
			}
		}

