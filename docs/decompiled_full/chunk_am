	[AutoRegisterSetting]
	[SettingCategory("Audio")]
	public class VoiceSettings : SettingComponent<VoiceSettings>
	{
		private static string _lastActivatedUserId;

		[SettingProperty(null, null, null, false, 0L, null, null, false)]
		public readonly Sync<MutePersistence> MutePersistence;

		protected override void OnAwake()
		{
			base.OnAwake();
			ResetToDefault();
			base.Cloud.Session.OnFinalizeSession += OnSessionLoggingOut;
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			base.Cloud.Session.OnFinalizeSession -= OnSessionLoggingOut;
		}

		protected override void OnActivated()
		{
			base.OnActivated();
			string settingOwnerId = base.SettingOwnerId;
			UniLog.Log($"VoiceSettings OnActivated. LastActivatedUserId: {_lastActivatedUserId}, Current: {settingOwnerId}, MutePersistence: {MutePersistence.Value}");
			if (_lastActivatedUserId == settingOwnerId)
			{
				return;
			}
			_lastActivatedUserId = settingOwnerId;
			if (FrooxEngine.Engine.Config.ForceStartMicrophoneMuted)
			{
				base.AudioSystem.IsMuted = true;
				return;
			}
			switch (MutePersistence.Value)
			{
			case FrooxEngine.MutePersistence.StartMuted:
				base.AudioSystem.IsMuted = true;
				break;
			case FrooxEngine.MutePersistence.StartUnmuted:
				base.AudioSystem.IsMuted = false;
				break;
			case FrooxEngine.MutePersistence.RememberLast:
				base.AudioSystem.IsMuted = true;
				Task.Run(async delegate
				{
					UniLog.Log("Reading last muted status for user " + base.Cloud.CurrentUserID);
					try
					{
						CloudResult<bool> cloudResult = await base.Cloud.Variables.ReadOwners<bool>(base.Cloud.Platform.VariablePath(SettingsCloudVariables.LAST_MUTE_STATUS.subpath), SettingsCloudVariables.LAST_MUTE_STATUS.type);
						if (cloudResult.IsOK)
						{
							base.AudioSystem.IsMuted = cloudResult.Entity;
							UniLog.Log("Read last muted status: " + base.AudioSystem.IsMuted);
						}
						else
						{
							UniLog.Warning($"Failed to read last muted status for user {base.Cloud.CurrentUserID}: {cloudResult}");
						}
					}
					catch (Exception ex)
					{
						UniLog.Error("Exception reading last muted status:\n" + ex);
					}
				});
				break;
			}
		}

		private void OnSessionLoggingOut(List<Task> tasks)
		{
			UniLog.Log($"OnSessionLoggingOut: {base.SettingOwnerId} - {MutePersistence}");
			if (Settings.GetActiveSetting<VoiceSettings>() != this)
			{
				UniLog.Log("Not an active voice setting!");
			}
			else
			{
				if (MutePersistence.Value != FrooxEngine.MutePersistence.RememberLast)
				{
					return;
				}
				tasks.Add(Task.Run(async delegate
				{
					try
					{
						UniLog.Log($"Storing last mute status for user {base.Cloud.CurrentUserID}: {base.AudioSystem.IsMuted}");
						await base.Cloud.Variables.WriteOwners(base.Cloud.Platform.VariablePath(SettingsCloudVariables.LAST_MUTE_STATUS.subpath), base.AudioSystem.IsMuted, SettingsCloudVariables.LAST_MUTE_STATUS.type).ConfigureAwait(continueOnCapturedContext: false);
						UniLog.Log("Stored last mute status");
					}
					catch (Exception ex)
					{
						UniLog.Error("Exception storing last mute status:\n" + ex);
					}
				}));
			}
		}

		public override void ResetToDefault()
		{
			base.ResetToDefault();
			MutePersistence.Value = FrooxEngine.MutePersistence.StartUnmuted;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			MutePersistence = new Sync<MutePersistence>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => MutePersistence, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static VoiceSettings __New()
		{
			return new VoiceSettings();
		}
	}
