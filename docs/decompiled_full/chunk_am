		public static async Task ConvertHostAccessSettings(LegacySettingsData data)
		{
			UniLog.Log("Converting host access settings");
			await Settings.UpdateActiveSettingAsync(delegate(HostAccessSettings s)
			{
				SyncDictionary<string, SyncVar> syncDictionary = data.GetSetting("Security.HostAccessPermission")?.AsDictionary<string, SyncVar>(setIfDifferent: false);
				if (syncDictionary == null)
				{
					UniLog.Warning("Couldn't find host access permission setting root, cannot convert");
					return;
				}
				foreach (KeyValuePair<string, SyncVar> item in syncDictionary)
				{
					if (!item.Value.TryGetValue<HostAccessPermission>(out var value))
					{
						UniLog.Warning("Failed to read host access permission for " + item.Key);
					}
					else
					{
						string text = item.Key?.Trim();
						text = text.Replace("http://", "").Replace("https://", "").Replace("ftp://", "");
						if (text.StartsWith("\"") && text.EndsWith("\""))
						{
							text = text.Substring(1, text.Length - 2);
						}
						if (text.EndsWith("/"))
						{
							text = text.Substring(0, text.Length - 1);
						}
						int result = 0;
						string host;
						if (text.Contains(":"))
						{
							text.LastIndexOf(':');
							string[] array = text.Split(':');
							host = array[0];
							if (!int.TryParse(array[1], out result))
							{
								UniLog.Warning("Failed to parse port for host: " + text + " (port: " + array[1]);
								continue;
							}
						}
						else
						{
							host = text;
						}
						switch (value)
						{
						case HostAccessPermission.Allowed:
							if (result > 0)
							{
								s.AllowWebsocket(host, result, "Legacy Setting");
								s.AllowHTTP_Requests(host, result, "Legacy Setting");
							}
							else
							{
								s.AllowHTTP_Requests(host, 80, "Legacy Setting");
								s.AllowHTTP_Requests(host, 443, "Legacy Setting");
							}
							break;
						case HostAccessPermission.Denied:
							if (result > 0)
							{
								s.BlockHTTP_Requests(host, result, "Legacy Setting");
								s.BlockWebsocket(host, result, "Legacy Setting");
							}
							else
							{
								s.BlockHTTP_Requests(host, null, "Legacy Setting");
								s.BlockWebsocket(host, null, "Legacy Setting");
							}
							break;
						}
					}
				}
			});
		}

