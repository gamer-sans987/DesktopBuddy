	public class SteamVoiceAudioInputDriver
	{
		private AudioInput audioInput;

		private bool activeState;

		private object lockObj = new object();

		private double lastPosition;

		private MonoSample lastMonoSample;

		private CancellationTokenSource workerCancellation;

		public void Initialize(SteamConnector steamConnector)
		{
			Engine engine = steamConnector.Interface.Engine;
			audioInput = new AudioInput("Steam Voice", "SteamVoice", engine.InputInterface, AudioInputType.CaptureDevice, isDefault: false);
			audioInput.ActiveChanged += AudioInput_ActiveChanged;
			engine.AudioSystem.RegisterAudioInput(audioInput);
			audioInput.SetSampleRate(engine.AudioSystem.SampleRate);
			UniLog.Log("Steam Voice Initialized");
		}

		private void AudioInput_ActiveChanged(AudioInput input, bool active)
		{
			activeState = active;
			Task.Run((Action)UpdateActiveState);
		}

		private void UpdateActiveState()
		{
			lock (lockObj)
			{
				if (activeState && workerCancellation == null)
				{
					try
					{
						workerCancellation = new CancellationTokenSource();
						CancellationToken token = workerCancellation.Token;
						UniLog.Log("Starting Steam Voice Recording");
						SteamUser.StartVoiceRecording();
						Thread thread = new Thread((ThreadStart)delegate
						{
							WorkerThread(token);
						});
						thread.Priority = ThreadPriority.Highest;
						thread.IsBackground = true;
						thread.Start();
						return;
					}
					catch (Exception ex)
					{
						UniLog.Error("Exception starting Steam Voice:\n" + ex);
						return;
					}
				}
				if (!activeState && workerCancellation != null)
				{
					try
					{
						UniLog.Log("Stopping Steam Voice Recording");
						SteamUser.StopVoiceRecording();
						workerCancellation.Cancel();
						workerCancellation = null;
						return;
					}
					catch (Exception ex2)
					{
						UniLog.Error("Exception stopping Steam Voice:\n" + ex2);
						return;
					}
				}
			}
		}

		private void WorkerThread(CancellationToken cancellationToken)
		{
			byte[] array = new byte[16384];
			byte[] array2 = new byte[32768];
			float[] array3 = new float[32768];
			while (!cancellationToken.IsCancellationRequested)
			{
				lock (lockObj)
				{
					if (cancellationToken.IsCancellationRequested)
					{
						break;
					}
					if (SteamUser.GetVoice(bWantCompressed: true, array, (uint)array.Length, out var nBytesWritten) == EVoiceResult.k_EVoiceResultOK && nBytesWritten != 0 && SteamUser.DecompressVoice(array, nBytesWritten, array2, (uint)array2.Length, out var nBytesWritten2, (uint)audioInput.SampleRate) == EVoiceResult.k_EVoiceResultOK)
					{
						Span<short> input = MemoryMarshal.Cast<byte, short>(array2.AsSpan().Slice(0, (int)nBytesWritten2));
						Span<float> span = array3.AsSpan().Slice(0, input.Length);
						SignalX.Convert(input, span);
						audioInput.WriteSamples(span.AsMonoBuffer(), ref lastPosition, ref lastMonoSample);
					}
				}
				Thread.Sleep(25);
			}
		}
	}
