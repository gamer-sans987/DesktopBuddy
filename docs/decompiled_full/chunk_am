		public static async Task<T> GetActiveSettingAsync<T>() where T : SettingComponent<T>, new()
		{
			T val = GetActiveSetting<T>();
			if (val != null)
			{
				return val;
			}
			TaskCompletionSource<T> source = new TaskCompletionSource<T>();
			SettingUpdateHandler<T> handler = delegate(T s)
			{
				if (s != null)
				{
					source.TrySetResult(s);
				}
			};
			RegisterComponentChanges(handler);
			try
			{
				val = await source.Task;
			}
			finally
			{
				UnregisterComponentChanges(handler);
			}
			return val;
		}

		public static bool UpdateActiveSetting<T>(Action<T> update) where T : SettingComponent<T>, new()
		{
			T setting = GetActiveSetting<T>();
			if (setting == null)
			{
