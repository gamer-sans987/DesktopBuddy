				renderSpaceUpdate.viewPositionIsExternal = World.ViewPositionIsExternal;
				renderSpaceUpdate.overrideViewPosition = World.OverrideViewPosition;
				renderSpaceUpdate.overridenViewTransform = World.LocalUserViewTransform;
