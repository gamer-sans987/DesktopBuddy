		public ResoniteLink.Member GatherMemberData(ISyncMember member)
		{
			ResoniteLink.Member member2;
			if (!(member is SyncPlayback playback))
			{
				if (!(member is EmptySyncElement))
				{
					if (!(member is SyncObject syncObject))
					{
						if (!(member is ISyncArray array))
						{
							if (!(member is ISyncList syncList))
							{
								if (!(member is ISyncDictionary dictionary))
								{
									if (!(member is ISyncRef syncRef))
									{
										if (member is IField field)
										{
											member2 = ConvertField(field);
										}
										else
										{
											UniLog.Warning("ResoniteLink unsupported member type: " + member.GetType().GetNiceFullName());
											member2 = null;
										}
									}
									else
									{
										member2 = ConvertReference(syncRef);
									}
								}
								else
								{
									member2 = ConvertDictionary(dictionary);
								}
							}
							else
							{
								member2 = ConvertSyncList(syncList);
							}
						}
						else
						{
							member2 = ConvertArray(array);
						}
					}
					else
					{
						member2 = ConvertSyncObject(syncObject);
					}
				}
				else
				{
					member2 = new EmptyElement();
				}
			}
			else
			{
				member2 = ConvertPlayback(playback);
			}
			if (member2 != null)
			{
				member2.ID = References.GetID(member);
			}
			return member2;
		}

		private ResoniteLink.SyncPlayback ConvertPlayback(SyncPlayback playback)
		{
			return new ResoniteLink.SyncPlayback
			{
				Play = playback.IsPlaying,
				Loop = playback.Loop,
				Position = playback.Position,
				Speed = playback.Speed
			};
		}

		private Reference ConvertReference(ISyncRef syncRef)
		{
			Reference reference = new Reference();
			reference.TargetType = World.Types.EncodeType(syncRef.TargetType);
			if (syncRef.Target != null)
			{
				reference.TargetID = References.GetID(syncRef.Target);
			}
			return reference;
		}

		private ResoniteLink.SyncObject ConvertSyncObject(SyncObject syncObject)
		{
			ResoniteLink.SyncObject syncObject2 = new ResoniteLink.SyncObject();
			syncObject2.Members = new Dictionary<string, ResoniteLink.Member>();
			GatherMembers(syncObject, syncObject2.Members);
			return syncObject2;
		}

		private SyncList ConvertSyncList(ISyncList syncList)
		{
			SyncList syncList2 = new SyncList();
			syncList2.Elements = new List<ResoniteLink.Member>();
			for (int i = 0; i < syncList.Count; i++)
			{
				ISyncMember element = syncList.GetElement(i);
				ResoniteLink.Member member = GatherMemberData(element);
				if (member == null)
				{
					return null;
				}
				syncList2.Elements.Add(member);
			}
			return syncList2;
		}

		private TLink ConvertSyncDictionary<TKey, TLinkKey, TLink>(ISyncDictionary dictionary, Func<TKey, TLinkKey> keyConverter) where TLink : SyncDictionary<TLinkKey>, new()
		{
			TLink val = new TLink
			{
				Elements = new Dictionary<TLinkKey, ResoniteLink.Member>()
			};
			foreach (KeyValuePair<object, ISyncMember> boxedEntry in dictionary.BoxedEntries)
			{
				ResoniteLink.Member member = GatherMemberData(boxedEntry.Value);
				if (member == null)
				{
					return null;
				}
				val.Elements.Add(keyConverter((TKey)boxedEntry.Key), member);
			}
			return val;
		}

		private SyncDictionary_Enum ConvertEnumSyncDictionary(ISyncDictionary dictionary)
		{
			Type keyType = dictionary.KeyType;
			if (!keyType.IsEnum)
			{
				throw new ArgumentException($"Dictionary key type is not an enum: {dictionary}");
			}
			SyncDictionary_Enum syncDictionary_Enum = new SyncDictionary_Enum();
			syncDictionary_Enum.EnumType = World.Types.EncodeType(keyType);
			syncDictionary_Enum.Elements = new Dictionary<string, ResoniteLink.Member>();
			foreach (KeyValuePair<object, ISyncMember> boxedEntry in dictionary.BoxedEntries)
			{
				ResoniteLink.Member member = GatherMemberData(boxedEntry.Value);
				if (member == null)
				{
					return null;
				}
				syncDictionary_Enum.Elements.Add(EnumsNET.Enums.GetName(keyType, boxedEntry.Key), member);
			}
			return syncDictionary_Enum;
		}

