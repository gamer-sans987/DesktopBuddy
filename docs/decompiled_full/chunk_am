		public LNL_Listener(string appId, ushort port, IPAddress bindIP, World world, LNLConfig? config)
		{
			LNL_Listener lNL_Listener = this;
			AppId = appId;
			_world = world;
			_bindIP = bindIP;
			IPAddress bindIPv6 = (BoundToSpecificIP ? IPAddress.IPv6None : IPAddress.IPv6Any);
			_server = new NetManager(this);
			_server.UseNativeSockets = false;
			_server.UpdateTime = LNL_Implementer.GetUpdateTime(world.Engine.Platform);
			_server.UnsyncedEvents = true;
			_server.DisconnectTimeout = 15000;
			_server.ChannelsCount = 2;
			_server.AutoRecycle = false;
			_server.EnableStatistics = true;
			_server.Statistics.TrackAveragePacketSize = true;
			_server.Statistics.TrackAveragePacketMergeCount = true;
			_server.UnconnectedMessagesEnabled = true;
			_server.NatPunchEnabled = true;
			_server.NatPunchModule.Init(this);
			_server.NatPunchModule.UnsyncedEvents = true;
			_server.AllowPeerAddressChange = true;
			bool flag = false;
			if (port != 0)
			{
				flag = _server.Start(bindIP, bindIPv6, port);
			}
			else if (config?.Ports != null)
			{
				_portRange = config.Ports;
				flag = _portRange.Try(delegate(int num)
				{
					bool flag2 = lNL_Listener._server.Start(bindIP, bindIPv6, num);
					UniLog.Log($"Attempting LNL Server start at {bindIP}:{num}. Success: {flag2}");
					return flag2;
				});
			}
			else
			{
				flag = _server.Start(bindIP, bindIPv6, 0);
			}
			if (flag)
			{
				UniLog.Log($"LNL Listener for {world}, running on {bindIP}, port {_server.LocalPort}");
				initialized = true;
			}
			else
			{
				string value = ((port == 0) ? "Any Port" : port.ToString());
				if (_portRange != null)
				{
					value = _portRange.ToString();
				}
				UniLog.Error($"Failed to start LNL Listener for on {bindIP}, on port: {value}, {world}");
			}
			_nodeManager = world.Engine.Cloud.NetworkNodes as NetworkNodeManager;
			if (BoundToSpecificIP && world.Engine.InUniverse && _nodeManager != null && LocalUris.Any())
			{
				_pokeConnectionUrl = LocalUris.First().ToString();
				Task.Run(async delegate
				{
					UniLog.Log("Listening for LNL session pokes for " + lNL_Listener._pokeConnectionUrl);
					await lNL_Listener._nodeManager.ListenForLNLPokeRequests(lNL_Listener._pokeConnectionUrl).ConfigureAwait(continueOnCapturedContext: false);
					lNL_Listener._nodeManager.OnLNLPokeRequested += lNL_Listener.OnLNLPokeRequested;
				});
			}
		}

		private void OnLNLPokeRequested(string connectionUrl, string targetAddress, int targetPort)
		{
			if (!IsActive || _pokeConnectionUrl != connectionUrl)
			{
				return;
			}
			UniLog.Log($"LNL Poke requested for {connectionUrl} to {targetAddress}:{targetPort}");
			Task.Run(async delegate
			{
				try
				{
					NetDataWriter writer = new NetDataWriter();
					writer.Put("LNL poke from: " + connectionUrl);
					for (int i = 0; i < 10; i++)
					{
						UniLog.Log($"LNL Poking {targetAddress}:{targetPort} for session {connectionUrl}");
						_server.SendUnconnectedMessage(writer, targetAddress, targetPort);
						await Task.Delay(TimeSpan.FromMilliseconds(250L));
					}
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception running LNL poke:\n{value}", stackTrace: false);
				}
			});
		}

		public void Close()
		{
			if (_server.IsRunning)
			{
				if (_portRange != null)
				{
					UniLog.Log($"LNL Listener using port:{_server.LocalPort} has closed. Marking port as Free.");
					_portRange?.Free(_server.LocalPort);
				}
				_server.Stop();
				_world = null;
			}
		}

