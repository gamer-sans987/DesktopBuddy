		private List<ReflectionProbeRenderHandler> _renderTasksToSubmit = new List<ReflectionProbeRenderHandler>();

		private Dictionary<int, ReflectionProbe> _probesByUniqueId = new Dictionary<int, ReflectionProbe>();

		private int _uniqueIdPool;

		protected override bool HasAnyUpdates
		{
			get
			{
				if (!base.HasAnyUpdates && _changesToRender.Count <= 0)
				{
					return _renderTasksToSubmit.Count > 0;
				}
				return true;
			}
		}

		public ReflectionProbesManager(RenderManager manager)
			: base(manager)
		{
		}

		public List<ReflectionProbeRenderTask> CollectRenderTasks()
		{
			if (_renderTasksToSubmit == null)
			{
				return null;
			}
			List<ReflectionProbeRenderTask> list = new List<ReflectionProbeRenderTask>();
			foreach (ReflectionProbeRenderHandler item in _renderTasksToSubmit)
			{
				if (!item.probe.IsRenderable)
				{
					item.Finished(success: false);
					continue;
				}
				item.task.renderableIndex = item.probe.RenderableIndex;
				if (item.excludeList != null)
				{
					item.task.excludeTransformIds = new List<int>();
					foreach (Slot exclude in item.excludeList)
					{
						if (exclude.IsRenderTransformAllocated)
						{
							item.task.excludeTransformIds.Add(exclude.RenderTransformIndex);
						}
					}
				}
				list.Add(item.task);
			}
			_renderTasksToSubmit.Clear();
			return list;
		}

		protected override void AssignIndex(ref ReflectionProbeState state, int index)
		{
			state.renderableIndex = index;
		}

		protected override void FillState(ref ReflectionProbeState state, ReflectionProbe probe, ref dummy updateData)
		{
			state.renderableIndex = probe.RenderableIndex;
			state.type = probe.ProbeType;
			state.importance = MathX.Max(0, probe.Importance);
			state.intensity = probe.Intensity;
			state.blendDistance = probe.BlendDistance;
			state.boxSize = probe.BoxSize.Value;
			state.useBoxProjection = probe.BoxProjection;
			state.cubemapAssetId = probe.BakedCubemap.Asset?.AssetId ?? (-1);
			state.timeSlicingMode = probe.TimeSlicing;
			state.resolution = MathX.Clamp(MathX.NearestPowerOfTwo(probe.Resolution), 16, 2049);
			state.HDR = probe.HDR;
			state.shadowDistance = probe.ShadowDistance;
			state.clearFlags = probe.ClearFlags;
			state.backgroundColor = (Elements.Core.float4)probe.BackgroundColor.Value.ToProfile(ColorProfile.sRGB);
			state.nearClip = MathX.Max(0.001f, probe.NearClip);
			state.farClip = MathX.Max(state.nearClip + 0.001f, probe.FarClip);
			state.skyboxOnly = probe.SkyboxOnly;
		}

		protected override void FinalizeUpdate(ReflectionProbeRenderablesUpdate update, Span<ReflectionProbeState> statesData, ref dummy updateData)
		{
			SharedMemoryBlockLease<ReflectionProbeChangeRenderTask> sharedMemoryBlockLease = base.RenderSystem.AllocateBlock<ReflectionProbeChangeRenderTask>(_changesToRender.Count, frameBound: true, this);
			Span<ReflectionProbeChangeRenderTask> span = sharedMemoryBlockLease.AccessData();
			int num = 0;
			for (int i = 0; i < _changesToRender.Count; i++)
			{
				ReflectionProbe reflectionProbe = _changesToRender[i];
				reflectionProbe.ClearRenderScheduled();
				if (reflectionProbe.IsRenderable)
				{
					if (reflectionProbe.UniqueId < 0)
					{
						throw new InvalidOperationException($"Probe doesn't have UniqueID assigned for OnChanges render: {reflectionProbe}");
					}
					ref ReflectionProbeChangeRenderTask reference = ref span[num++];
					reference.renderableIndex = reflectionProbe.RenderableIndex;
					reference.uniqueId = reflectionProbe.UniqueId;
				}
			}
			if (num < span.Length)
			{
				span[num].renderableIndex = -1;
			}
			update.changedProbesToRender = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<ReflectionProbeChangeRenderTask>);
			_changesToRender.Clear();
		}

		protected override dummy InitUpdateData(ReflectionProbeRenderablesUpdate update)
		{
			return default(dummy);
		}

		internal void ProbeRenderFinished(int renderProbeUniqueId, bool resetProbe)
		{
			if (_probesByUniqueId.TryGetValue(renderProbeUniqueId, out ReflectionProbe value))
			{
				value.NotifyOnChangesRenderFinished(resetProbe);
			}
		}

		protected override void RenderableAssigned(ReflectionProbe renderable)
		{
			base.RenderableAssigned(renderable);
			renderable.UniqueId = _uniqueIdPool++;
			_probesByUniqueId.Add(renderable.UniqueId, renderable);
		}

		protected override void RenderableCleared(ReflectionProbe renderable)
		{
			base.RenderableCleared(renderable);
			_probesByUniqueId.Remove(renderable.UniqueId);
			renderable.UniqueId = -1;
		}

		internal void ScheduleChangesRender(ReflectionProbe renderable)
		{
			_changesToRender.Add(renderable);
		}

		internal Task<BitmapCube> ScheduleRender(ReflectionProbe probe, List<Slot> excludeList, bool handleLifetime = false)
		{
			ReflectionProbeRenderHandler reflectionProbeRenderHandler = base.RenderSystem.ReflectionProbeRenderManager.AllocateTask();
			reflectionProbeRenderHandler.probe = probe;
			reflectionProbeRenderHandler.excludeList = excludeList;
			reflectionProbeRenderHandler.handleLifetime = handleLifetime;
			ReflectionProbeRenderTask reflectionProbeRenderTask = new ReflectionProbeRenderTask();
			reflectionProbeRenderTask.renderTaskId = reflectionProbeRenderHandler.TaskId;
			reflectionProbeRenderTask.size = probe.Resolution;
			reflectionProbeRenderTask.hdr = probe.HDR;
			reflectionProbeRenderHandler.task = reflectionProbeRenderTask;
			reflectionProbeRenderHandler.cubemap = new BitmapCube(reflectionProbeRenderTask.size, reflectionProbeRenderTask.size, reflectionProbeRenderTask.hdr ? TextureFormat.RGBAHalf : TextureFormat.RGBA32, mipmaps: true, ColorProfile.Linear, null, base.RenderSystem);
			reflectionProbeRenderHandler.task.resultData = ((SharedMemoryBlockLease<byte>)reflectionProbeRenderHandler.cubemap.Buffer).Descriptor;
			reflectionProbeRenderTask.mipOrigins = new List<List<int>>();
			for (int i = 0; i < 6; i++)
			{
				List<int> list = new List<int>();
				reflectionProbeRenderTask.mipOrigins.Add(list);
				for (int j = 0; j < reflectionProbeRenderHandler.cubemap.MipMapLevels; j++)
				{
					int item = reflectionProbeRenderHandler.cubemap.MipmapByteOrigin(j, (BitmapCube.Face)i);
					list.Add(item);
				}
			}
			reflectionProbeRenderHandler.completionSource = new TaskCompletionSource<BitmapCube>();
			_renderTasksToSubmit.Add(reflectionProbeRenderHandler);
			return reflectionProbeRenderHandler.completionSource.Task;
		}
	}
	public abstract class RenderableComponentManager<TRenderable, TUpdate> where TRenderable : RenderableComponent where TUpdate : RenderablesUpdate, new()
	{
		private List<TRenderable> renderables = new List<TRenderable>();

		private List<TRenderable> _renderablesToAddOrRemove = new List<TRenderable>();

		public Engine Engine => World.Engine;

		public World World => Manager.World;

		public RenderSystem RenderSystem => Engine.RenderSystem;

		public RenderManager Manager { get; private set; }

		protected abstract bool HasAnyUpdates { get; }

		public int EstimatedAdditionCount { get; private set; }

		public int EstimatedRemovalCount { get; private set; }

		protected TRenderable this[int renderableIndex] => renderables[renderableIndex];

		public RenderableComponentManager(RenderManager manager)
		{
			Manager = manager;
		}

		public TUpdate? GenerateUpdate()
		{
			if (EstimatedAdditionCount <= 0 && EstimatedRemovalCount <= 0 && !HasAnyUpdates)
			{
				return null;
			}
			try
			{
				TUpdate val = new TUpdate();
				SharedMemoryBlockLease<int> sharedMemoryBlockLease = RenderSystem.AllocateBlock<int>(EstimatedRemovalCount, frameBound: true, this);
				SharedMemoryBlockLease<int> sharedMemoryBlockLease2 = RenderSystem.AllocateBlock<int>(EstimatedAdditionCount, frameBound: true, this);
				FillAdditionsAndRemovals(sharedMemoryBlockLease.AccessData(), sharedMemoryBlockLease2.AccessData());
				val.removals = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<int>);
				val.additions = sharedMemoryBlockLease2?.Descriptor ?? default(SharedMemoryBufferDescriptor<int>);
				FillUpdates(val);
				return val;
			}
			catch (Exception)
			{
				UniLog.Error($"[{RenderSystem.FrameIndex}] Exception generating render update on {GetType().FullName}. EstimatedRemovalCount: {EstimatedRemovalCount}, EstimatedAdditionCount: {EstimatedAdditionCount}");
				throw;
			}
		}

		private void FillAdditionsAndRemovals(Span<int> removals, Span<int> additions)
		{
			int num = 0;
			for (int i = 0; i < _renderablesToAddOrRemove.Count; i++)
			{
				TRenderable val = _renderablesToAddOrRemove[i];
				if (!val.IsRenderable && val.IsRenderableAllocated)
				{
					if (num == removals.Length)
					{
						throw new ArgumentOutOfRangeException($"Removals buffer is not big enough! Size: {removals.Length}. Index: {num}, ToAdd/Remove: {_renderablesToAddOrRemove.Count}");
					}
					removals[num++] = val.RenderableIndex;
					RemoveRenderable(val);
				}
			}
			if (num < removals.Length)
			{
				removals[num] = -1;
			}
			int num2 = 0;
			for (int j = 0; j < _renderablesToAddOrRemove.Count; j++)
			{
				TRenderable val2 = _renderablesToAddOrRemove[j];
				if (val2.IsRenderable && !val2.IsRenderableAllocated)
				{
					if (num2 == additions.Length)
					{
						throw new ArgumentOutOfRangeException($"Additions buffer is not big enough! Size: {additions.Length}. Index: {num2}, ToAdd/Remove: {_renderablesToAddOrRemove.Count}");
					}
					AssignRenderable(val2);
					additions[num2++] = val2.Slot.RenderTransformIndex;
				}
			}
			if (num2 < additions.Length)
			{
				additions[num2] = -1;
			}
			_renderablesToAddOrRemove.Clear();
		}

		private void AssignRenderable(TRenderable renderable)
		{
			if (renderable.Slot.RenderTransformIndex < 0)
			{
				throw new InvalidOperationException("Renderable slot does not have a valid transform index. Renderable:\n" + renderable);
			}
			renderable.RenderableIndex = renderables.Count;
			renderables.Add(renderable);
			renderable.InitRenderableState();
			RenderableAssigned(renderable);
		}

		private void RemoveRenderable(TRenderable renderable)
		{
			int renderableIndex = renderable.RenderableIndex;
			int index = renderables.Count - 1;
			TRenderable val = renderables[index];
			renderables[renderableIndex] = val;
			val.RenderableIndex = renderableIndex;
			renderables.RemoveAt(index);
			RenderableCleared(renderable);
			renderable.RenderableIndex = -1;
		}

		public void RenderableAddedOrRemoved(TRenderable renderable)
		{
			_renderablesToAddOrRemove.Add(renderable);
			if (!renderable.IsRenderableAllocated)
			{
				EstimatedAdditionCount++;
			}
			else
			{
				EstimatedRemovalCount++;
			}
		}

		protected abstract void RenderableAssigned(TRenderable renderable);

		protected virtual void RenderableCleared(TRenderable renderable)
		{
		}

		protected abstract void FillUpdates(TUpdate update);
	}
