		private static void InitBase(DataFeedItem item, SettingMemberIdentity identity, SettingPropertyAttribute setting, IReadOnlyList<string> path, IReadOnlyList<string> grouping)
		{
			string text = identity.settingType.Name + "." + identity.FullName;
			if (identity.subcategory != null)
			{
				text = text + "." + identity.subcategory + "." + identity.settingKey;
			}
			LocaleString label = ((setting.NameOverride == null) ? identity.LocaleKeyBase.AsLocaleKey() : ((LocaleString)setting.NameOverride));
			LocaleString description = ((setting.DescriptionOverride == null) ? (identity.LocaleKeyBase + ".Description").AsLocaleKey() : ((LocaleString)setting.DescriptionOverride));
			item.InitBase(text, path, grouping, label, description, setting.Icon);
			if (setting.OrderOffset != 0L)
			{
				item.InitSorting(setting.OrderOffset);
			}
			if (!string.IsNullOrEmpty(setting.EnabledFieldName))
			{
				FieldIdentity fieldIdentity = new FieldIdentity();
				fieldIdentity.InitBaseFrom(identity);
				fieldIdentity.field = identity.Container.GetField(setting.EnabledFieldName);
				item.InitEnabled(GenerateFieldSync<bool>(fieldIdentity));
			}
			if (!string.IsNullOrEmpty(setting.VisibilityFieldName))
			{
				FieldIdentity fieldIdentity2 = new FieldIdentity();
				fieldIdentity2.InitBaseFrom(identity);
				fieldIdentity2.field = identity.Container.GetField(setting.VisibilityFieldName);
				item.InitVisible(GenerateBoolFieldSync(fieldIdentity2, setting.InvertVisibility));
			}
		}

		private static Action<IField<bool>> GenerateBoolFieldSync(FieldIdentity identity, bool invert)
		{
			return delegate(IField<bool> f)
			{
				if (invert)
				{
					ValueField<bool> valueField = f.FindNearestParent<Slot>().AttachComponent<ValueField<bool>>();
					f.DriveInverted(valueField.Value);
					f = valueField.Value;
				}
				f.SyncWithSetting(identity.settingType, identity.FullName, identity.settingGetter, identity.settingKey);
			};
		}

		private static Action<IField<T>> GenerateFieldSync<T>(FieldIdentity identity)
		{
			return delegate(IField<T> f)
			{
				f.SyncWithSetting(identity.settingType, identity.FullName, identity.settingGetter, identity.settingKey);
			};
		}

