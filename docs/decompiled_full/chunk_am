		private BitmapCube GenerateCubemap(ImportCubemapFileWithRegions rawData)
		{
			Bitmap2D bitmap2D = Bitmap2D.Load(rawData.FilePath, false);
			Bitmap2D posX = bitmap2D.Crop(rawData.PositiveXRegion.ToEngine());
			Bitmap2D posY = bitmap2D.Crop(rawData.PositiveYRegion.ToEngine());
			Bitmap2D posZ = bitmap2D.Crop(rawData.PositiveZRegion.ToEngine());
			Bitmap2D negX = bitmap2D.Crop(rawData.NegativeXRegion.ToEngine());
			Bitmap2D negY = bitmap2D.Crop(rawData.NegativeYRegion.ToEngine());
			Bitmap2D negZ = bitmap2D.Crop(rawData.NegativeZRegion.ToEngine());
			return GenerateCubemap(posX, posY, posZ, negX, negY, negZ);
		}

		private BitmapCube GenerateCubemap(ImportCubemapFiles rawData)
		{
			Bitmap2D posX = Bitmap2D.Load(rawData.FilePathPositiveX, true);
			Bitmap2D posY = Bitmap2D.Load(rawData.FilePathPositiveY, true);
			Bitmap2D posZ = Bitmap2D.Load(rawData.FilePathPositiveZ, true);
			Bitmap2D negX = Bitmap2D.Load(rawData.FilePathNegativeX, true);
			Bitmap2D negY = Bitmap2D.Load(rawData.FilePathNegativeY, true);
			Bitmap2D negZ = Bitmap2D.Load(rawData.FilePathNegativeZ, true);
			return GenerateCubemap(posX, posY, posZ, negX, negY, negZ);
		}

		private BitmapCube GenerateCubemap(Bitmap2D posX, Bitmap2D posY, Bitmap2D posZ, Bitmap2D negX, Bitmap2D negY, Bitmap2D negZ)
		{
			Elements.Core.int2 b = MathX.Max(posX.Size, posY.Size, posZ.Size, negX.Size, negY.Size, negZ.Size);
			if (posX.Size != b)
			{
				posX = posX.GetRescaled(posX.Size);
			}
			if (posY.Size != b)
			{
				posY = posY.GetRescaled(posY.Size);
			}
			if (posZ.Size != b)
			{
				posZ = posZ.GetRescaled(posZ.Size);
			}
			if (negX.Size != b)
			{
				negX = negX.GetRescaled(negX.Size);
			}
			if (negY.Size != b)
			{
				negY = negY.GetRescaled(negY.Size);
			}
			if (negZ.Size != b)
			{
				negZ = negZ.GetRescaled(negZ.Size);
			}
			TextureFormat format = posX.Format;
			if (posX.Format != format)
			{
				posX = posX.ConvertTo(format);
			}
			if (posY.Format != format)
			{
				posY = posY.ConvertTo(format);
			}
			if (posZ.Format != format)
			{
				posZ = posZ.ConvertTo(format);
			}
			if (negX.Format != format)
			{
				negX = negX.ConvertTo(format);
			}
			if (negY.Format != format)
			{
				negY = negY.ConvertTo(format);
			}
			if (negZ.Format != format)
			{
				negZ = negZ.ConvertTo(format);
			}
			return new BitmapCube(posX, negX, posY, negY, posZ, negZ);
		}

