		}

		protected override void OnAwake()
		{
			base.OnAwake();
			UseTrackers.Value = true;
			base.InputInterface.InputDeviceAdded += OnDeviceAdded;
		}

		private void OnDeviceAdded(IInputDevice device)
		{
			ViveTracker viveTracker = device as ViveTracker;
			if (viveTracker != null)
			{
				RunSynchronously(delegate
				{
					RegisterTracker(viveTracker);
				});
			}
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			base.InputInterface.InputDeviceAdded -= OnDeviceAdded;
		}

		protected override void OnStart()
		{
			base.OnStart();
			foreach (ViveTracker device in base.InputInterface.GetDevices<ViveTracker>())
			{
				RegisterTracker(device);
			}
		}

		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			if (!base.IsSettingActive)
			{
				return;
			}
			foreach (Tracker tracker in Trackers)
			{
				tracker.Update();
			}
		}

		private void RegisterTracker(ViveTracker viveTracker)
		{
			if (string.IsNullOrEmpty(viveTracker.UniqueID))
			{
				return;
			}
			Tracker tracker = Trackers.FirstOrDefault((Tracker t) => t.TrackerID.Value == viveTracker.UniqueID);
			if (tracker == null)
			{
				tracker = Trackers.Add();
				tracker.TrackerID.Value = viveTracker.UniqueID;
				StartTask(async delegate
				{
					Elements.Core.float3 pos = await base.Engine.LocalDB.ReadVariableAsync(viveTracker.LegacyPosOffsetVar, Elements.Core.float3.Zero);
					Elements.Core.floatQ rot = await base.Engine.LocalDB.ReadVariableAsync(viveTracker.LegacyRotOffsetVar, default(Elements.Core.floatQ));
					BodyNode bodyNode = await base.Engine.LocalDB.ReadVariableAsync(viveTracker.LegacyBodyNodeVar, BodyNode.NONE);
					if (bodyNode != BodyNode.NONE)
					{
						tracker.MappedPosition.Value = pos;
						tracker.MappedRotation.Value = rot;
						tracker.MappedBodyNode.Value = bodyNode;
						tracker.UseInVR.Value = true;
					}
				});
			}
			tracker.MatchingTracker = viveTracker;
			tracker.IsConnected.Value = true;
		}

