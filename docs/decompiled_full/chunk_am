		internal void RunValidations()
		{
			_runningValidations = true;
			List<ValidationTask> list = Pool.BorrowList<ValidationTask>();
			HashSet<IUpdatable> hashSet = Pool.BorrowHashSet<IUpdatable>();
			foreach (ValidationTask validation in _validations)
			{
				if (validation.validator != null && !validation.worker.IsRemoved)
				{
					if (!validation.validator.Validate(validation.user, validation.worker))
					{
						UniLog.Warning($"Failed Validation {validation.validator} for {validation.worker} for User: {validation.user}");
						list.Add(validation);
					}
					IUpdatable updatable = (IUpdatable)validation.worker;
					if (updatable.IsChangeDirty)
					{
						hashSet.Add(updatable);
					}
				}
			}
			Dictionary<User, PermissionViolationAction> dictionary = Pool.BorrowDictionary<User, PermissionViolationAction>();
			_runningCleanups = true;
			foreach (ValidationTask item in list)
			{
				item.validator.Cleanup(item.user, item.worker);
				if (item.action > PermissionViolationAction.CleanupOnly)
				{
					if (!dictionary.TryGetValue(item.user, out var value))
					{
						value = PermissionViolationAction.CleanupOnly;
					}
					else
					{
						dictionary.Remove(item.user);
					}
					if (item.action > value)
					{
						dictionary.Add(item.user, item.action);
					}
				}
			}
			Pool.Return(ref list);
			_runningCleanups = false;
			foreach (ValidationTask validation2 in _validations)
			{
				validation2.worker.IsScheduledForValidation = false;
				validation2.validator?.ValidationFinished();
			}
			_validations.Clear();
			_runningValidations = false;
			foreach (KeyValuePair<User, PermissionViolationAction> item2 in dictionary)
			{
				switch (item2.Value)
				{
				case PermissionViolationAction.KickUser:
					if (base.World.IsAuthority)
					{
						item2.Key.Kick();
					}
					break;
				case PermissionViolationAction.TempBanUser:
					if (base.World.IsAuthority)
					{
						User key = item2.Key;
						BanManager.TempBanUser(key.UserID ?? key.MachineID);
						BanManager.TempBanUser(key.MachineID);
						item2.Key.Kick();
					}
					break;
				case PermissionViolationAction.BanUser:
					if (base.World.IsAuthority)
					{
						item2.Key.Ban();
					}
					break;
				}
			}
			Pool.Return(ref dictionary);
			foreach (IUpdatable item3 in hashSet)
			{
				UpdateManager_UpdatableChanged(item3);
			}
			Pool.Return(ref hashSet);
			Action val;
			while (_postValidationActions.TryDequeue(out val))
			{
				val();
			}
		}

