		private static void UpdateCollection<T>(Action<SettingListenerCollection<T>> update) where T : SettingComponent
		{
			lock (_lock)
			{
				Type typeFromHandle = typeof(T);
				string text = typeFromHandle.GetCustomAttribute<SettingCategoryAttribute>(inherit: true, fromInterfaces: false)?.Name;
				if (text != null)
				{
					HashSet<Type> value;
					bool flag = _typesByCategory.TryGetValue(text, out value);
					if (!flag)
					{
						value = new HashSet<Type>();
						_typesByCategory.Add(text, value);
						SettingCategoryInfo settingCategoryInfo = null;
						foreach (AssemblyTypeRegistry dataModelAssembly in GlobalTypeRegistry.DataModelAssemblies)
						{
							Type type = dataModelAssembly.TryGetType("SettingCategoryDefinitions");
							if (!(type == null))
							{
								PropertyInfo property = type.GetProperty(text, BindingFlags.Static | BindingFlags.Public);
								if (!(property == null))
								{
									settingCategoryInfo = (SettingCategoryInfo)property.GetValue(null);
									settingCategoryInfo.InitKey(text);
									break;
								}
							}
						}
						if (settingCategoryInfo == null)
						{
							UniLog.Log("No info found for category " + text + ", initializing default");
							settingCategoryInfo = new SettingCategoryInfo(null, 0L);
							settingCategoryInfo.InitKey(text);
						}
						_categoryInfos.Add(text, settingCategoryInfo);
					}
					value.Add(typeFromHandle);
					if (!flag)
					{
						Settings.SettingCategoryAdded?.Invoke(_categoryInfos[text]);
					}
				}
				ISettingListenerCollection value2;
				SettingListenerCollection<T> obj = (_listeners.TryGetValue(typeFromHandle, out value2) ? ((SettingListenerCollection<T>)value2) : CreateSettingListenerCollection<T>());
				update(obj);
			}
		}

		private static SettingListenerCollection<T> CreateSettingListenerCollection<T>() where T : SettingComponent
		{
			Type typeFromHandle = typeof(T);
			SettingListenerCollection<T> settingListenerCollection = new SettingListenerCollection<T>();
			_listeners.Add(typeFromHandle, settingListenerCollection);
			UniLog.Log($"New setting type registered: {typeFromHandle}");
			Settings.SettingTypeAdded?.Invoke(typeFromHandle);
			return settingListenerCollection;
		}
	}
