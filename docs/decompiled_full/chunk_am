	[Category(new string[] { "Permissions" })]
	public class CameraPermissions : PermissionsComponent
	{
		public readonly Sync<ListFilterMode> CameraModeFilterMode;

		public readonly SyncFieldList<CameraPositioningMode> CameraModes;

		public readonly Sync<bool> AllowFramingOtherUsers;

		public override int Version => 1;

		public override PermissionViolationAction DefaultViolationAction => PermissionViolationAction.KickUser;

		protected override void OnAwake()
		{
			base.OnAwake();
			CameraModeFilterMode.Value = ListFilterMode.Blacklist;
			AllowFramingOtherUsers.Value = true;
		}

		public bool CanUseMode(CameraPositioningMode mode)
		{
			switch (CameraModeFilterMode.Value)
			{
			case ListFilterMode.Blacklist:
				if (CameraModes.Contains(mode))
				{
					return false;
				}
				break;
			case ListFilterMode.Whitelist:
				if (!CameraModes.Contains(mode))
				{
					return false;
				}
				break;
			}
			return true;
		}

		public CameraPositioningMode? GetFirstValidMode()
		{
			switch (CameraModeFilterMode.Value)
			{
			case ListFilterMode.Whitelist:
				if (CameraModes.Count == 0)
				{
					return null;
				}
				return CameraModes.Min();
			case ListFilterMode.Blacklist:
				foreach (CameraPositioningMode value in Enum.GetValues(typeof(CameraPositioningMode)))
				{
					if (!CameraModes.Contains(value))
					{
						return value;
					}
				}
				break;
			}
			return null;
		}

		public override void Cleanup(User user, Worker worker)
		{
			InteractiveCamera interactiveCamera = (InteractiveCamera)worker;
			if (!AllowFramingOtherUsers.Value && interactiveCamera.FrameTargetUser.Target != user && interactiveCamera.FrameTargetUser.Target != null)
			{
				interactiveCamera.FrameTargetUser.Target = user;
			}
			CameraPositioningMode? firstValidMode = GetFirstValidMode();
			if (!firstValidMode.HasValue)
			{
				interactiveCamera.Slot.Destroy();
			}
			else
			{
				interactiveCamera.PositioningMode.Value = firstValidMode.Value;
			}
		}

		public override bool Validate(User user, Worker worker)
		{
			InteractiveCamera interactiveCamera = (InteractiveCamera)worker;
			if (interactiveCamera.SimulatingUser.Target != user)
			{
				return true;
			}
			if (!CanUseMode(interactiveCamera.PositioningMode.Value))
			{
				return false;
			}
			if (!AllowFramingOtherUsers.Value && interactiveCamera.FrameTargetUser.Target != user && interactiveCamera.FrameTargetUser.Target != null)
			{
				return false;
			}
			return true;
		}

		public override bool ValidatesType(Type type)
		{
			return type == typeof(InteractiveCamera);
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			if (control.GetTypeVersion(GetType()) == 0)
			{
				control.OnLoaded(this, delegate
				{
					ScreenViewPermissions screenViewPermissions = base.Slot.AttachComponent<ScreenViewPermissions>();
					screenViewPermissions.InitializeFrom(this);
					screenViewPermissions.CopyRoleAssignments(this);
				});
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			CameraModeFilterMode = new Sync<ListFilterMode>();
			CameraModes = new SyncFieldList<CameraPositioningMode>();
			AllowFramingOtherUsers = new Sync<bool>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => CameraModeFilterMode, 
				4 => CameraModes, 
				5 => AllowFramingOtherUsers, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static CameraPermissions __New()
		{
			return new CameraPermissions();
		}
	}
