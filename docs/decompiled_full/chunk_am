	public class ResoniteLinkReflection
	{
		public World World => Host.World;

		public Engine Engine => World.Engine;

		public LocalDB LocalDB => Engine.LocalDB;

		public ResoniteLinkHost Host { get; private set; }

		public ResoniteLinkReflection(ResoniteLinkHost host)
		{
			Host = host;
		}

		public void GetTypeDefinition(ResoniteLinkService service, GetTypeDefinition request)
		{
			RunTask(service, request, delegate
			{
				Type type = World.Types.DecodeType(request.Type);
				if (type == null)
				{
					throw new ArgumentException(request.Type + " is not a valid type");
				}
				return new TypeDefinitionData
				{
					Definition = GetTypeDefinition(type, includeBaseType: true)
				};
			});
		}

		public void GetGenericTypeDefinition(ResoniteLinkService service, GetGenericTypeDefinition request)
		{
			RunTask(service, request, delegate
			{
				Type type = World.Types.DecodeType(request.GenericInstanceType);
				if (type == null)
				{
					throw new ArgumentException(request.GenericInstanceType + " is not a valid type");
				}
				if (!type.IsGenericType)
				{
					throw new ArgumentException("Provided type is not a generic type");
				}
				if (type.IsGenericTypeDefinition)
				{
					throw new ArgumentException("Provided type is already generic type definition");
				}
				type = type.GetGenericTypeDefinition();
				return new TypeDefinitionData
				{
					Definition = GetTypeDefinition(type, includeBaseType: true)
				};
			});
		}

		public void GetEnumDefinition(ResoniteLinkService service, GetEnumDefinition request)
		{
			RunTask(service, request, () => new EnumDefinitionData
			{
				Definition = GetEnumDefinition(World.Types.DecodeType(request.Type))
			});
		}

		public void GetComponentDefinition(ResoniteLinkService service, GetComponentDefinition request)
		{
			RunTask(service, request, () => new ComponentDefinitionData
			{
