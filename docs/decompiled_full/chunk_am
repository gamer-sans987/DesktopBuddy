			SteamNetConnectionRealTimeLaneStatus_t pLanes = default(SteamNetConnectionRealTimeLaneStatus_t);
			SteamNetworkingSockets.GetConnectionRealTimeStatus(connections[0], ref _lastMainStatus, 0, ref pLanes);
			SteamNetworkingSockets.GetConnectionRealTimeStatus(connections[1], ref _lastBackgroundStatus, 0, ref pLanes);
			this.StatsUpdated?.Invoke(this, delegate(User user)
			{
				if (user.World.IsAuthority)
				{
					user.Ping = _lastMainStatus.m_nPing;
					user.UploadedBytes = receivedBytes;
					user.QueuedMessages = _lastMainStatus.m_cbPendingReliable;
					user.SetNetworkStatistic("Protocol", "Steam");
					user.SetNetworkStatistic("MainQualityLocal", _lastMainStatus.m_flConnectionQualityLocal);
					user.SetNetworkStatistic("MainQualityRemote", _lastMainStatus.m_flConnectionQualityRemote);
					user.SetNetworkStatistic("MainPendingReliable", _lastMainStatus.m_cbPendingReliable);
					user.SetNetworkStatistic("MainPendingUnreliable", _lastMainStatus.m_cbPendingUnreliable);
					user.SetNetworkStatistic("MainOutRate", _lastMainStatus.m_flOutPacketsPerSec);
					user.SetNetworkStatistic("MainInRate", _lastMainStatus.m_flInPacketsPerSec);
					user.SetNetworkStatistic("BG_QualityLocal", _lastBackgroundStatus.m_flConnectionQualityLocal);
					user.SetNetworkStatistic("BG_QualityRemote", _lastBackgroundStatus.m_flConnectionQualityRemote);
					user.SetNetworkStatistic("BG_PendingReliable", _lastBackgroundStatus.m_cbPendingReliable);
					user.SetNetworkStatistic("BG_PendingUnreliable", _lastBackgroundStatus.m_cbPendingUnreliable);
					user.SetNetworkStatistic("BG_OutRate", _lastBackgroundStatus.m_flOutPacketsPerSec);
					user.SetNetworkStatistic("BG_InRate", _lastBackgroundStatus.m_flInPacketsPerSec);
					user.SetNetworkStatistic("Bandwidth", _lastMainStatus.m_nSendRateBytesPerSecond);
				}
