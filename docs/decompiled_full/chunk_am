		public void Connect(Action<LocaleString> statusCallback)
		{
			if (Address.Scheme == "lnl")
			{
				if (Address.Port < 0)
				{
					Failed("World.Error.NoPort");
				}
				else if (world.Engine.InUniverse)
				{
					statusCallback("World.Connection.LNL.LNLPoke".AsLocaleKey());
					Task.Run(async delegate
					{
						UniLog.Log($"Requesting LNL poke for {Address}");
						NetworkNodeManager networkManager = (NetworkNodeManager)world.Engine.Cloud.NetworkNodes;
						if (_bindIP != IPAddress.Any)
						{
							await networkManager.RequestLNLPoke(Address.ToString(), _bindIP.ToString(), _client.LocalPort).ConfigureAwait(continueOnCapturedContext: false);
						}
						else
						{
							foreach (IPAddress filteredLocalIP in NetUtils.FilteredLocalIPs)
							{
								await networkManager.RequestLNLPoke(Address.ToString(), filteredLocalIP.ToString(), _client.LocalPort).ConfigureAwait(continueOnCapturedContext: false);
							}
						}
						DirectConnect();
					});
				}
				else
				{
					DirectConnect();
				}
			}
			else
			{
				if (!(Address.Scheme == "lnl-nat"))
				{
					throw new Exception("Invalid Scheme! URI: " + Address);
				}
				_client.NatPunchEnabled = true;
				_client.NatPunchModule.Init(this);
				_client.NatPunchModule.UnsyncedEvents = true;
				LNL_Manager.GetConnectionTokens(Address, out _nodeId, out _connectionToken);
				world.Engine.GlobalCoroutineManager.StartTask(async delegate
				{
					await PunchthroughConnect(statusCallback);
				});
			}
			void DirectConnect()
			{
				UniLog.Log($"Establishing direct IP connection to {Address}. Don't route: {_client.DontRoute}");
				statusCallback("World.Connection.LNL.DirectIP".AsLocaleKey(null, "address", $"{_bindIP}:{_client.LocalPort} -> {Address.Host}:{Address.Port}"));
				NetPeer netPeer = _client.Connect(Address.Host, Address.Port, AppId);
				UniLog.Log($"Direct IP connection peer. ID: {netPeer?.Id}, State: {netPeer?.ConnectionState}, Address: {netPeer?.Address}");
			}
		}

		private async Task PunchthroughConnect(Action<LocaleString> statusCallback)
		{
			RelaySettings settings = await Settings.GetActiveSettingAsync<RelaySettings>();
			await default(ToBackground);
			List<NetworkNodeInfo> nodes = new List<NetworkNodeInfo>();
			if (_nodeId != null)
			{
				NetworkNodeInfo networkNodeInfo = await Cloud.NetworkNodes.TryGetNodeWithRefetch(_nodeId).ConfigureAwait(continueOnCapturedContext: false);
				if (networkNodeInfo == null)
				{
					UniLog.Log($"Cannot find NAT Punchthrough node for connecting to {Address}: " + _nodeId);
				}
				else
				{
					nodes.Add(networkNodeInfo);
				}
			}
			else
			{
				foreach (NetworkNodeInfo node in Cloud.NetworkNodes.GetNodes(NetworkNodeType.LNL_NAT, 2, world.Engine.NodePreference, world.Engine.UniverseId))
				{
					nodes.Add(node);
				}
			}
			if (nodes.Count == 0 && !settings.AlwaysUseRelay.Value)
			{
				UniLog.Warning($"No LNL Bridge nodes available, NAT Punchthrough for {Address} will fail.");
			}
			if (!settings.AlwaysUseRelay.Value && nodes.Count > 0)
			{
				for (int i = 0; i < 5; i++)
				{
					statusCallback("World.Connection.LNL.NATPunchthrough".AsLocaleKey(null, "n", i));
					UniLog.Log($"Punchthrough attempt for {Address}: " + i);
					foreach (NetworkNodeInfo item in nodes)
					{
						_client.NatPunchModule.SendNatIntroduceRequest(item.Address, item.Port, "C;" + _connectionToken);
					}
					await Task.Delay(TimeSpan.FromSeconds(1.0));
					if (Peer != null || !_client.IsRunning)
					{
						return;
					}
				}
			}
			statusCallback("World.Connection.LNL.Relay".AsLocaleKey());
			UniLog.Log($"NAT Punchthrough for {Address} failed, Connecting to Relay");
			await ConnectToRelay(settings);
		}

		private async Task<NetworkNodeInfo> FindClosestRelay(List<NetworkNodeInfo> relays)
		{
			_relayData = new Dictionary<IPEndPoint, RelayInfo>();
			foreach (NetworkNodeInfo relay in relays)
			{
				IPEndPoint iPEndPoint = relay.TryGetEndpoint();
				if (iPEndPoint != null)
				{
					NetDataWriter netDataWriter = new NetDataWriter();
					netDataWriter.Put("PING");
					RelayInfo relayInfo = new RelayInfo(relay);
					relayInfo.pingSend = DateTime.UtcNow;
					lock (_relayData)
					{
						_relayData.Add(iPEndPoint, relayInfo);
					}
					_client.SendUnconnectedMessage(netDataWriter, iPEndPoint);
				}
			}
			int num = 0;
			DateTime started = DateTime.UtcNow;
			do
			{
				await Task.Delay(TimeSpan.FromMilliseconds(100L)).ConfigureAwait(continueOnCapturedContext: false);
				lock (_relayData)
				{
					num = _relayData.Count<KeyValuePair<IPEndPoint, RelayInfo>>((KeyValuePair<IPEndPoint, RelayInfo> r) => r.Value.ReceivedPong);
				}
			}
			while (num < relays.Count && (DateTime.UtcNow - started).TotalSeconds < 5.0);
			float num2 = float.MaxValue;
			NetworkNodeInfo result = null;
			foreach (KeyValuePair<IPEndPoint, RelayInfo> relayDatum in _relayData)
			{
				float ping = relayDatum.Value.Ping;
				UniLog.Log($"Relay {relayDatum.Key} ({relayDatum.Value.info.Address}): {ping * 1000f:F2} ms");
				if (ping < num2)
				{
					num2 = ping;
					result = relayDatum.Value.info;
				}
			}
			return result;
		}

		private async Task ConnectToRelay(RelaySettings settings)
		{
			try
			{
				ConnectionState = State.FindingRelay;
				List<NetworkNodeInfo> relays = Cloud.NetworkNodes.GetNodes(NetworkNodeType.LNL_Relay, 2, world.Engine.NodePreference, world.Engine.UniverseId).ToList();
				if (world.Engine.NodePreference == NetworkNodePreference.UniversePreferred)
				{
					relays = relays.OrderByDescending((NetworkNodeInfo i) => i.UniverseId == world.Engine.UniverseId).ToList();
				}
				UniLog.Log($"Using relay. Available relay count: {relays.Count}, with preference {world.Engine.NodePreference}");
				NetworkNodeInfo networkNodeInfo = null;
				if (relays.Count == 0)
				{
					UniLog.Warning("No LNL Relay Nodes found, Relay connection is impossible");
				}
				else if (relays.Count == 1)
				{
					networkNodeInfo = relays[0];
				}
				else if (relays.Count > 1)
				{
					if (settings.UseClosestAvailableRelay.Value)
					{
						networkNodeInfo = await FindClosestRelay(relays);
					}
					else
					{
						networkNodeInfo = await settings.RunSynchronouslyAsync(delegate
						{
							List<RelayPriorityEntry> list = settings.RelayPriorities.ToList();
							list.Sort((RelayPriorityEntry a, RelayPriorityEntry b) => -a.Priority.Value.CompareTo(b.Priority.Value));
							NetworkNodeInfo networkNodeInfo2 = null;
							foreach (RelayPriorityEntry p in list)
							{
								networkNodeInfo2 = relays.FirstOrDefault((NetworkNodeInfo r) => r.NodeName == p.EntryID.Value);
								if (networkNodeInfo2 != null)
								{
									break;
								}
							}
							return networkNodeInfo2;
						});
						if (networkNodeInfo == null)
						{
							UniLog.Warning("None of relays in the priority list match, finding closest relay instead");
							networkNodeInfo = await FindClosestRelay(relays);
						}
					}
				}
				if (networkNodeInfo != null)
				{
					_relay = networkNodeInfo;
					_relayEndpoint = networkNodeInfo.TryGetEndpoint();
					UniLog.Log($"Found best relay: {networkNodeInfo.NodeName} {networkNodeInfo.Address}:{networkNodeInfo.Port} - Endpoint: {_relayEndpoint}");
					ConnectionState = State.ConnectingToRelay;
					_client.Connect(_relayEndpoint, AppId);
					return;
				}
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception connecting to a relay:\n" + ex);
			}
			Failed("World.Error.FailedConnectToRelay");
		}

		public void StopClient()
		{
			if (_client.IsRunning)
			{
				if (PortRange != null)
				{
					UniLog.Log($"LNL Connection using port:{_client.LocalPort} has closed. Marking port as Free.");
					PortRange?.Free(_client.LocalPort);
				}
				Task.Run((Action)_client.Stop);
			}
		}

		public void Failed(string reason)
		{
			FailReason = reason;
			this.ConnectionFailed?.Invoke(this);
			StopClient();
		}

		public void Close()
		{
			Close(null);
		}

		public void Close(string reason = null)
		{
			if (_hasClosed)
			{
				return;
			}
			lock (lockobj)
			{
				if (!_hasClosed)
				{
					if (reason != null)
					{
						FailReason = reason;
					}
					_hasClosed = true;
					IsOpen = false;
					if (this._closed == null)
					{
						this.ConnectionFailed?.Invoke(this);
					}
					else
					{
						this._closed(this);
					}
					StopClient();
				}
			}
		}

		public void OnNetworkError(IPEndPoint endPoint, SocketError socketError)
		{
			UniLog.Log($"OnNetworkError, endpoint: {endPoint}, socketError: {socketError}, connection state: {ConnectionState}, client running: {_client.IsRunning}");
			if (!_client.IsRunning)
			{
				this.ConnectionFailed(this);
			}
			else
			{
				Close("World.Error.NetworkError");
			}
		}

		public void OnNetworkLatencyUpdate(NetPeer peer, int latency)
		{
			this.StatsUpdated?.Invoke(this, delegate(User user)
			{
				LNL_Implementer.UpdateUserStats(peer, this, latency, receivedBytes, user);
			});
		}

		public void OnNetworkReceive(NetPeer peer, NetPacketReader reader, byte channelNumber, DeliveryMethod deliveryMethod)
		{
			if (ConnectionState == State.Direct || ConnectionState == State.UsingRelay)
			{
				receivedBytes += (ulong)reader.AvailableBytes;
				RawInMessage rawMessage = new RawInMessage(this, reader.RawData, reader.UserDataOffset, reader.UserDataSize, LNL_Implementer.DisposeMethod, reader);
				this.NewData(rawMessage);
			}
			else if (ConnectionState == State.ConfiguringRelay)
			{
				ConnectionState = State.UsingRelay;
				this.Connected(this);
			}
			else
			{
				UniLog.Error("Invalid Connection State in OnNetworkReceive: " + ConnectionState);
				Close("Invalid Connection State in OnNetworkReceive");
			}
		}

		public void OnNetworkReceiveUnconnected(IPEndPoint remoteEndPoint, NetPacketReader reader, UnconnectedMessageType messageType)
		{
			string text = reader.GetString(100);
			UniLog.Log("NETWORK RECEIVE UNCONNECTED: " + remoteEndPoint?.ToString() + ", token: " + text + ", connection token: " + _connectionToken);
			if (text.StartsWith("SERVER_GONE:") && text.EndsWith(_connectionToken, StringComparison.InvariantCultureIgnoreCase))
			{
				Failed("World.Error.SessionEnded");
			}
			else if (text == _connectionToken && _client.ConnectedPeersCount == 0)
			{
				_client.Connect(remoteEndPoint, AppId);
			}
			else
			{
				if (!(text == "PONG") || _relayData == null)
				{
					return;
				}
				lock (_relayData)
				{
					if (_relayData.TryGetValue(remoteEndPoint, out RelayInfo value))
					{
						value.pongReceive = DateTime.UtcNow;
					}
				}
			}
		}

		public void OnPeerConnected(NetPeer peer)
		{
			UniLog.Log("LNL_Connection OnPeerConnected: " + peer?.ToString() + ", IsOpen: " + IsOpen);
			if (IsOpen)
			{
				return;
			}
			lock (lockobj)
			{
				_client.UnconnectedMessagesEnabled = false;
				if (ConnectionState == State.ConnectingToRelay && !peer.Equals(_relayEndpoint))
				{
					UniLog.Log($"Connecting to relay {_relayEndpoint} but connected to host {peer} directly. Switching connection state back to direct");
					ConnectionState = State.Direct;
				}
				if (ConnectionState == State.Direct)
				{
					IsOpen = true;
					Peer = peer;
					this.Connected(this);
				}
				else if (ConnectionState == State.ConnectingToRelay)
				{
					IsOpen = true;
					Peer = peer;
					ConnectionState = State.ConfiguringRelay;
					NetDataWriter netDataWriter = new NetDataWriter();
					string text = Address.ToString();
					netDataWriter.Put(text);
					peer.Send(netDataWriter, DeliveryMethod.ReliableOrdered);
					UniLog.Log("Configuring Relay to connect to " + text);
				}
				else
				{
					Failed("Invalid ConnectionState in OnPeerConnected: " + ConnectionState);
				}
			}
		}

		public void OnPeerDisconnected(NetPeer peer, DisconnectInfo disconnectInfo)
		{
			UniLog.Log("LNL Connection Disconnected: " + peer?.ToString() + ", reason: " + disconnectInfo.Reason.ToString() + ", socketErrorCode: " + disconnectInfo.SocketErrorCode);
			Close("Peer Disconnected");
		}

		public void OnNatIntroductionRequest(IPEndPoint localEndPoint, IPEndPoint remoteEndPoint, string token)
		{
			UniLog.Log("NAT INTRODUCTION REQUEST. LocalEndpoint: " + localEndPoint?.ToString() + ", Remote Endpoint: " + remoteEndPoint?.ToString() + ", token: " + token);
		}

		public void OnNatIntroductionSuccess(IPEndPoint targetEndPoint, NatAddressType type, string token)
		{
			UniLog.Log("NAT INTRODUCTION SUCCESS: " + targetEndPoint?.ToString() + ", token: " + token);
			bool flag = string.Equals(token, _connectionToken, StringComparison.InvariantCultureIgnoreCase);
			if (flag && _client.ConnectedPeersCount == 0)
			{
				_client.Connect(targetEndPoint, AppId);
			}
			else if (!flag)
			{
				UniLog.Log("WARNING!!! NatIntroductionSuccess passed different token than was requested. Received: " + token + ", Requested: " + _connectionToken);
			}
		}

		public override string ToString()
		{
			return $"LNL Connection: {IP} - {Address}";
		}

		public void OnConnectionRequest(ConnectionRequest request)
		{
			UniLog.Log("LNL Connection - connection request: " + request.RemoteEndPoint);
		}

		public void Dispose()
		{
			Close("Disposed");
		}
	}
	public class LNL_Implementer
	{
		public const bool USE_NATIVE_SOCKETS = false;

		internal static readonly Action<RawInMessage> DisposeMethod;

		public static readonly Lazy<string> SecretAnnounceKey;

		private static void DisposeMethodInternal(RawInMessage packet)
		{
			((NetPacketReader)packet.ExtraData).Recycle();
		}

		public static void UpdateUserStats(NetPeer peer, LNL_Connection connection, int latency, ulong receivedBytes, User user)
		{
			if (user.World.IsAuthority)
			{
				int packetsCountInReliableQueue = peer.GetPacketsCountInReliableQueue(0, ordered: true);
				int packetsCountInReliableQueue2 = peer.GetPacketsCountInReliableQueue(1, ordered: true);
				user.Ping = latency;
				user.UploadedBytes = receivedBytes;
				user.QueuedMessages = packetsCountInReliableQueue;
				if (peer.Statistics.PacketsSent > 0)
				{
					user.PacketLoss = (float)peer.Statistics.PacketLoss / (float)peer.Statistics.PacketsSent;
				}
				user.CommitMessageStats();
				user.SetNetworkStatistic("Protocol", "LNL");
				user.SetNetworkStatistic("PrimaryChannelQueue", packetsCountInReliableQueue);
				user.SetNetworkStatistic("BackgroundChannelQueue", packetsCountInReliableQueue2);
				user.SetNetworkStatistic("PacketsLost", peer.Statistics.PacketLoss);
				user.SetNetworkStatistic("PacketsSent", peer.Statistics.PacketsSent);
				user.SetNetworkStatistic("PacketsReceived", peer.Statistics.PacketsReceived);
				user.SetNetworkStatistic("BytesSent", peer.Statistics.BytesSent);
				user.SetNetworkStatistic("BytesReceived", peer.Statistics.BytesReceived);
				user.SetNetworkStatistic("WindowWaitCount", peer.Statistics.WindowWaitCount);
				user.SetNetworkStatistic("AveragePacketSize", peer.Statistics.ComputeAveragePacketSize());
				user.SetNetworkStatistic("AverageMergedPackets", peer.Statistics.ComputeAveragePacketMerge());
				user.SetNetworkStatistic("MTU", peer.Mtu);
				user.SetNetworkStatistic("TimeSinceLastPacket", peer.TimeSinceLastPacket);
				user.SetNetworkStatistic("TotalReliablePacketsInFlight", peer.TotalReliablePacketsInFlight);
			}
			else
			{
				user.DownloadedBytes = receivedBytes;
				if (connection != null && !user.HasNetworkStatistic("RelayName"))
				{
					user.SetNetworkStatistic("RelayName", connection.RelayName);
				}
			}
		}

		public static void UpdateBestMatchmakerNode(SkyFrostInterface cloud, ref NetworkNodeInfo current)
		{
			IEnumerable<NetworkNodeInfo> nodes = cloud.NetworkNodes.GetNodes(NetworkNodeType.LNL_NAT, 2, cloud.NodePreference, cloud.UniverseID);
			if (current != null)
			{
				foreach (NetworkNodeInfo item in nodes)
				{
					if (item.NodeId == current.NodeId)
					{
						if (item.IsShuttingDown)
						{
							break;
						}
						return;
					}
				}
			}
			DateTimeOffset? dateTimeOffset = null;
			if (nodes.Count() == 0)
			{
				UniLog.Warning("No LNL Bridge nodes found, NAT Punchthrough will not function.");
			}
			foreach (NetworkNodeInfo item2 in nodes)
			{
				if (item2.HasCapacity && (!dateTimeOffset.HasValue || item2.Timestamp > dateTimeOffset.Value))
				{
					dateTimeOffset = item2.Timestamp;
					current = item2;
				}
			}
		}

		static LNL_Implementer()
		{
			DisposeMethod = DisposeMethodInternal;
			SecretAnnounceKey = new Lazy<string>(() => CryptoHelper.GenerateCryptoToken(32), isThreadSafe: true);
		}

		public static int GetUpdateTime(Platform platform)
		{
			if (platform == Platform.Android)
			{
				return 16;
			}
			return 4;
		}
	}
