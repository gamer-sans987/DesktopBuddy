		public static int PackRenderableId(this ITexture texture)
		{
			if (!(texture is Texture2D texture2D))
			{
				if (!(texture is Texture3D texture3D))
				{
					if (!(texture is Cubemap cubemap))
					{
						if (!(texture is RenderTexture renderTexture))
						{
							if (!(texture is VideoTexture videoTexture))
							{
								if (!(texture is DesktopTexture desktopTexture))
								{
									if (texture == null)
									{
										return -1;
									}
									throw new NotSupportedException($"Unsupported texture type: {texture}");
								}
								return IdPacker<TextureAssetType>.Pack(desktopTexture.AssetId, TextureAssetType.Desktop);
							}
							return IdPacker<TextureAssetType>.Pack(videoTexture.AssetId, TextureAssetType.VideoTexture);
						}
						return IdPacker<TextureAssetType>.Pack(renderTexture.AssetId, TextureAssetType.RenderTexture);
					}
					return IdPacker<TextureAssetType>.Pack(cubemap.AssetId, TextureAssetType.Cubemap);
				}
				return IdPacker<TextureAssetType>.Pack(texture3D.AssetId, TextureAssetType.Texture3D);
			}
			return IdPacker<TextureAssetType>.Pack(texture2D.AssetId, TextureAssetType.Texture2D);
		}

		public static int PackRenderableId(this MeshRenderer renderer)
		{
			if (!(renderer is SkinnedMeshRenderer skinnedMeshRenderer))
