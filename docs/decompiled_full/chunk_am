	{
		public readonly string Username;

		public readonly string UserId;

		public readonly string MachineId;

		public readonly Dictionary<string, string> ExtraIds;

		public bool HasAnyId
		{
			get
			{
				if (!HasUsername && !HasMachineId && !HasUserId)
				{
					return HasExtraIds;
				}
				return true;
			}
		}

		public bool HasUsername => !string.IsNullOrEmpty(Username);

		public bool HasMachineId => !string.IsNullOrEmpty(MachineId);

		public bool HasUserId => !string.IsNullOrEmpty(UserId);

		public bool HasExtraIds
		{
			get
			{
				if (ExtraIds != null)
				{
					return ExtraIds.Count > 0;
				}
				return false;
			}
		}

		public UserFingerprint(User user)
		{
			Username = user.UserName;
			UserId = user.UserID;
			MachineId = user.MachineID;
			ExtraIds = new Dictionary<string, string>();
			foreach (KeyValuePair<string, Sync<string>> extraUserId in user.ExtraUserIds)
			{
				ExtraIds.Add(user.World.DeobfuscateString(extraUserId.Key), user.World.DeobfuscateString(extraUserId.Value.Value));
			}
		}

		public UserFingerprint(Contact contact)
		{
			Username = contact.ContactUsername;
			UserId = contact.ContactUserId;
		}

		public UserFingerprint(SessionConnection connection)
		{
			Username = connection.Username;
			UserId = connection.UserID;
			MachineId = connection.MachineID;
			ExtraIds = connection.ExtraIDs;
		}

		public UserFingerprint(SkyFrost.Base.User user)
		{
			Username = user.Username;
			UserId = user.Id;
		}

		public UserFingerprint(string username, string userId, string machineId, Dictionary<string, string> extraIds)
		{
			Username = username;
			UserId = userId;
			MachineId = machineId;
			ExtraIds = extraIds;
		}

		public bool Matches(User user)
		{
			if (MachineId != null && user.MachineID == MachineId)
			{
				return true;
			}
			if ((UserId != null) & (user.UserID == UserId))
			{
				return true;
			}
			if (HasExtraIds)
			{
				foreach (KeyValuePair<string, string> extraId in ExtraIds)
				{
					if (user.ExtraUserIds.TryGetValue(extraId.Key, out string value) && !string.IsNullOrWhiteSpace(value) && extraId.Value == value)
					{
						return true;
					}
				}
			}
			return false;
		}

		public override string ToString()
		{
			return $"Username: {Username}, UserId: {UserId}, MachineId: {MachineId}";
		}
