	{
		private World _world;

		private List<MaterialProvider> _updatingMaterials;

		private List<MaterialPropertyBlockProvider> _updatingPropertyBlocks;

		private SharedMemoryBlockLease<uint> _instanceChangedBuffer;

		private List<SharedMemoryBlockLease> _memoryBlocks;

		public MaterialUpdateData(World world, List<MaterialProvider> updatingMaterials, List<MaterialPropertyBlockProvider> updatingBlocks, SharedMemoryBlockLease<uint> instanceChangedBuffer, List<SharedMemoryBlockLease> memoryBlocks)
		{
			_world = world;
			_updatingMaterials = updatingMaterials;
			_updatingPropertyBlocks = updatingBlocks;
			_instanceChangedBuffer = instanceChangedBuffer;
			_memoryBlocks = memoryBlocks;
		}

		public void Completed()
		{
			_world.RunSynchronously(RunCompleted);
		}

		private void RunCompleted()
		{
			Span<uint> data = _instanceChangedBuffer.AccessData();
			BitSpan bitSpan = new BitSpan(data);
			for (int i = 0; i < _updatingMaterials.Count; i++)
			{
				_updatingMaterials[i].MaterialAssetUpdated(bitSpan[i]);
			}
			for (int j = 0; j < _updatingPropertyBlocks.Count; j++)
			{
				_updatingPropertyBlocks[j].MaterialAssetUpdated(bitSpan[_updatingMaterials.Count + j]);
			}
			Pool.Return(ref _updatingMaterials);
			_instanceChangedBuffer.Dispose();
			_instanceChangedBuffer = null;
			for (int num = _memoryBlocks.Count - 1; num >= 0; num--)
			{
				_memoryBlocks[num].Dispose();
			}
			Pool.Return(ref _memoryBlocks);
