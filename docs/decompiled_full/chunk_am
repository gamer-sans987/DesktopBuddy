		public readonly Sync<GaussianSplatQualityPreset> QualityPreset;

		[SettingProperty(null, null, null, false, 0L, null, "AdvancedQuality", true)]
		public readonly Sync<GaussianSplatQualityPreset> MinLocalQuality;

		[SettingProperty(null, null, null, false, 0L, null, null, false)]
		public readonly Sync<bool> AdvancedQuality;

		[SettingProperty(null, null, null, false, 0L, null, "AdvancedQuality", false)]
		public readonly Sync<GaussianVectorFormat> PositionFormat;

		[SettingProperty(null, null, null, false, 0L, null, "AdvancedQuality", false)]
		public readonly Sync<GaussianVectorFormat> ScaleFormat;

		[SettingProperty(null, null, null, false, 0L, null, "AdvancedQuality", false)]
		public readonly Sync<GaussianColorFormat> ColorFormat;

		[SettingProperty(null, null, null, false, 0L, null, "AdvancedQuality", false)]
		public readonly Sync<GaussianSHFormat> SphericalHarmonicsFormat;

		[SettingProperty(null, null, null, false, 0L, null, null, false)]
		[Range(1f, 2048f, "0.00")]
		public readonly Sync<float> SortMegaOperationsPerCamera;

		/// <remarks>Used via Reflection, See: <see cref="M:FrooxEngine.SettingManager.RecomputeSettings" /></remarks>
		public static List<SettingSwitchValue> GetDefaultSettingSwitches(World world)
		{
			DeviceIDSettingSwitchSource deviceIDSettingSwitchSource = SettingSwitchSource.EnsureSettingSwitchSource<DeviceIDSettingSwitchSource>(world);
			return new List<SettingSwitchValue> { deviceIDSettingSwitchSource.CurrentValue };
		}

		internal override bool IsValidSetOfSwitches(List<SettingSwitchValue> switches)
		{
			return switches.Any((SettingSwitchValue s) => s.source is DeviceIDSettingSwitchSource);
		}

		public GaussianSplatVariantDescriptor GetQualityDescriptor(bool isLocal, GaussianSplatMetadata metadata)
		{
			if (AdvancedQuality.Value)
			{
				return new GaussianSplatVariantDescriptor(PositionFormat.Value, GaussianRotationFormat.PackedNorm10, ScaleFormat.Value, ColorFormat.Value, SphericalHarmonicsFormat.Value);
			}
			GaussianSplatQualityPreset value = QualityPreset.Value;
			if (isLocal && value < MinLocalQuality.Value)
			{
				value = MinLocalQuality.Value;
			}
			return GetQualityDescriptor(value);
		}

		public static GaussianSplatVariantDescriptor GetQualityDescriptor(GaussianSplatQualityPreset preset)
		{
			return preset switch
			{
				GaussianSplatQualityPreset.High => new GaussianSplatVariantDescriptor(GaussianVectorFormat.Norm16, GaussianRotationFormat.PackedNorm10, GaussianVectorFormat.Norm16, GaussianColorFormat.Float16x4, GaussianSHFormat.Norm11), 
				GaussianSplatQualityPreset.Medium => new GaussianSplatVariantDescriptor(GaussianVectorFormat.Norm11, GaussianRotationFormat.PackedNorm10, GaussianVectorFormat.Norm11, GaussianColorFormat.Norm8x4, GaussianSHFormat.Norm6), 
				GaussianSplatQualityPreset.Low => new GaussianSplatVariantDescriptor(GaussianVectorFormat.Norm11, GaussianRotationFormat.PackedNorm10, GaussianVectorFormat.Norm6, GaussianColorFormat.Norm8x4, GaussianSHFormat.Cluster16k), 
				GaussianSplatQualityPreset.VeryLow => new GaussianSplatVariantDescriptor(GaussianVectorFormat.Norm11, GaussianRotationFormat.PackedNorm10, GaussianVectorFormat.Norm6, GaussianColorFormat.BC7, GaussianSHFormat.Cluster4k), 
				_ => new GaussianSplatVariantDescriptor(), 
			};
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			ResetToDefault();
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			double num = (double)base.Engine.SystemInfo.VRAMBytes / 1073741824.0;
			if (num <= 2.0)
			{
				QualityPreset.Value = GaussianSplatQualityPreset.VeryLow;
				SortMegaOperationsPerCamera.Value = 64f;
			}
			else if (num <= 6.0)
			{
				QualityPreset.Value = GaussianSplatQualityPreset.Low;
				SortMegaOperationsPerCamera.Value = 128f;
			}
			else if (num <= 16.0)
			{
				QualityPreset.Value = GaussianSplatQualityPreset.Medium;
				SortMegaOperationsPerCamera.Value = 256f;
			}
			else
			{
				QualityPreset.Value = GaussianSplatQualityPreset.High;
				SortMegaOperationsPerCamera.Value = 256f;
			}
		}

		public override void ResetToDefault()
		{
			base.ResetToDefault();
			SortMegaOperationsPerCamera.Value = 256f;
			QualityPreset.Value = GaussianSplatQualityPreset.Medium;
			MinLocalQuality.Value = GaussianSplatQualityPreset.Medium;
			AdvancedQuality.Value = false;
			PositionFormat.Value = GaussianVectorFormat.Norm11;
			ScaleFormat.Value = GaussianVectorFormat.Norm11;
			ColorFormat.Value = GaussianColorFormat.Norm8x4;
			SphericalHarmonicsFormat.Value = GaussianSHFormat.Norm6;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			QualityPreset = new Sync<GaussianSplatQualityPreset>();
			MinLocalQuality = new Sync<GaussianSplatQualityPreset>();
			AdvancedQuality = new Sync<bool>();
			PositionFormat = new Sync<GaussianVectorFormat>();
			ScaleFormat = new Sync<GaussianVectorFormat>();
			ColorFormat = new Sync<GaussianColorFormat>();
			SphericalHarmonicsFormat = new Sync<GaussianSHFormat>();
			SortMegaOperationsPerCamera = new Sync<float>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => QualityPreset, 
				4 => MinLocalQuality, 
				5 => AdvancedQuality, 
				6 => PositionFormat, 
				7 => ScaleFormat, 
				8 => ColorFormat, 
				9 => SphericalHarmonicsFormat, 
				10 => SortMegaOperationsPerCamera, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

