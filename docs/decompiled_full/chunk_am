				skinnedMeshRenderer.BonesChanged = false;
				if (skinnedMeshRenderer.IsRenderableAllocated)
				{
					ref BoneAssignment reference = ref span[num2++];
					int? meshBoneCount = skinnedMeshRenderer.MeshBoneCount;
					int meshBlendshapeCount = skinnedMeshRenderer.MeshBlendshapeCount;
					reference.renderableIndex = skinnedMeshRenderer.RenderableIndex;
					reference.rootBoneTransformId = skinnedMeshRenderer.ComputedRendererRoot?.RenderTransformIndex ?? (-1);
					if (meshBoneCount == 0 && meshBlendshapeCount > 0)
					{
						reference.boneCount = -1;
						num++;
					}
					else
					{
						reference.boneCount = meshBoneCount.GetValueOrDefault();
						num += reference.boneCount;
					}
				}
			}
			if (num2 < span.Length)
			{
				span[num2].renderableIndex = -1;
			}
			num2 = 0;
			SharedMemoryBlockLease<int> sharedMemoryBlockLease2 = base.RenderSystem.AllocateBlock<int>(num, frameBound: true, this);
			Span<int> span2 = sharedMemoryBlockLease2.AccessData();
			int num3 = 0;
			for (int j = 0; j < updatedBones.Count; j++)
			{
				SkinnedMeshRenderer skinnedMeshRenderer2 = updatedBones[j];
				if (!skinnedMeshRenderer2.IsRenderableAllocated)
				{
					continue;
				}
				ref BoneAssignment reference2 = ref span[num2++];
				if (reference2.boneCount == -1)
				{
