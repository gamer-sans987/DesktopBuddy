		private void CallStaticMethod(CallStaticSyncMethod callMethod, BatchResponse batch)
		{
			Type type = World.Types.DecodeType(callMethod.TargetType);
			if (type == null)
			{
				SendErrorResponse<MethodResult>(callMethod, "Target type does not exist or is not valid");
				return;
			}
			WorkerInitInfo workerInfo = WorkerInitializer.GetInitInfo(type);
			if (workerInfo == null)
			{
				SendErrorResponse<MethodResult>(callMethod, "Target is not a valid worker type");
				return;
			}
			CallMethod(callMethod, batch, delegate(Predicate<SyncMethodInfo> filter)
			{
				int num = workerInfo.staticSyncMethods.FindIndex(filter);
				if (num < 0)
				{
					return ((SyncMethodInfo, Delegate))(default(SyncMethodInfo), null);
				}
				SyncMethodInfo item = workerInfo.staticSyncMethods[num];
				Delegate item2 = item.method.CreateDelegate(item.methodType);
				return (item, item2);
			});
		}

		private void CallMethod(CallSyncMethod callMethod, BatchResponse batch)
		{
			IWorldElement worldElement = References.ResolveReference(callMethod.TargetID);
			if (worldElement == null)
			{
				SendErrorResponse<MethodResult>(callMethod, "Target does not exist");
				return;
			}
			Worker worker = worldElement as Worker;
			if (worker == null)
			{
				SendErrorResponse<MethodResult>(callMethod, "Target is not valid for calling methods");
				return;
			}
			CallMethod(callMethod, batch, delegate(Predicate<SyncMethodInfo> filter)
			{
				int num = worker.IndexOfSyncMethod(filter);
				if (num < 0)
				{
					return ((SyncMethodInfo, Delegate))(default(SyncMethodInfo), null);
				}
				worker.GetSyncMethodData(num, out SyncMethodInfo info, out Delegate method);
				return (info, method);
			});
		}

		private void CallMethod(CallSyncMethodBase callMethod, BatchResponse batch, Func<Predicate<SyncMethodInfo>, (SyncMethodInfo, Delegate)> methodFinder)
		{
			if (!CheckWritePermission<MethodResult>(callMethod, batch))
			{
				return;
			}
			Dictionary<Data_Reference, IWorldElement> resolvedTargets = new Dictionary<Data_Reference, IWorldElement>();
			foreach (KeyValuePair<string, Data> argument in callMethod.Arguments)
			{
				if (!(argument.Value is Data_Reference data_Reference))
				{
					continue;
				}
				if (string.IsNullOrEmpty(data_Reference.TargetID))
				{
					resolvedTargets.Add(data_Reference, null);
					continue;
				}
				IWorldElement worldElement = References.ResolveReference(data_Reference.TargetID);
				if (worldElement == null)
				{
					SendErrorResponse<MethodResult>(callMethod, "Target for argument " + argument.Key + " does not exist");
					return;
				}
				resolvedTargets.Add(data_Reference, worldElement);
			}
			var (syncMethodInfo, method) = methodFinder(delegate(SyncMethodInfo info)
			{
				if (info.method.Name != callMethod.MethodName)
				{
					return false;
				}
				ParameterInfo[] parameters2 = info.method.GetParameters();
				if (parameters2.Length != callMethod.Arguments.Count)
				{
					return false;
				}
				foreach (ParameterInfo parameterInfo2 in parameters2)
				{
					if (!callMethod.Arguments.TryGetValue(parameterInfo2.Name, out var value2))
					{
						return false;
					}
					if (!(value2 is DataValue dataValue2))
					{
						if (!(value2 is Data_Reference data_Reference2))
						{
							throw new NotImplementedException($"Argument type not implemented: {value2}");
						}
						if (!string.IsNullOrEmpty(data_Reference2.TargetID))
						{
							IWorldElement worldElement2 = resolvedTargets[data_Reference2];
							if (!parameterInfo2.ParameterType.IsAssignableFrom(worldElement2.GetType()))
							{
								return false;
							}
						}
					}
					else if (ResoniteLinkTypeMapper.LinkToEngine(dataValue2.ValueType) != parameterInfo2.ParameterType)
					{
						return false;
					}
				}
				return true;
			});
			if ((object)method == null)
			{
				SendErrorResponse<MethodResult>(callMethod, "Method with matching signature does not exist on this object");
				return;
			}
			ParameterInfo[] parameters = syncMethodInfo.method.GetParameters();
			object[] args = new object[callMethod.Arguments.Count];
			for (int num = 0; num < parameters.Length; num++)
			{
				ParameterInfo parameterInfo = parameters[num];
				Data data = callMethod.Arguments[parameterInfo.Name];
				if (!(data is DataValue dataValue))
				{
					if (!(data is Data_Reference key))
					{
						throw new NotImplementedException($"Argument type not implemented: {data}");
					}
					args[num] = resolvedTargets[key];
				}
				else
				{
					args[num] = dataValue.BoxedValue.LinkToEngine();
				}
			}
			Type returnType = syncMethodInfo.method.ReturnType;
			if (returnType.IsAssignableFrom(typeof(Task)))
			{
				World.Coroutines.StartTask(async delegate
				{
					try
					{
						Task resultTask = (Task)method.DynamicInvoke(args);
						await resultTask;
						object result2;
						if (returnType.IsGenericType)
						{
							result2 = resultTask.GetType().GetProperty("Result", BindingFlags.Instance | BindingFlags.Public).GetValue(resultTask);
							returnType = returnType.GetGenericArguments()[0];
						}
						else
						{
							result2 = null;
							returnType = typeof(void);
						}
						MethodResult response2 = GenerateMethodResponse(result2, returnType);
						SendResponse(callMethod, response2, batch);
					}
					catch (Exception value2)
					{
						SendErrorResponse<MethodResult>(callMethod, $"Method threw an exception:\n{value2}", batch);
					}
				});
				return;
			}
			try
			{
				object result = method.DynamicInvoke(args);
				MethodResult response = GenerateMethodResponse(result, returnType);
				SendResponse(callMethod, response, batch);
			}
			catch (Exception value)
			{
				SendErrorResponse<MethodResult>(callMethod, $"Method threw an exception:\n{value}", batch);
			}
		}

		private MethodResult GenerateMethodResponse(object result, Type returnType)
		{
			MethodResult methodResult = new MethodResult();
			methodResult.Success = true;
			if (returnType != typeof(void))
			{
				if (typeof(IWorldElement).IsAssignableFrom(returnType))
				{
					Data_Reference data_Reference = new Data_Reference();
					if (result is IWorldElement target)
					{
						data_Reference.TargetID = References.GetID(target);
					}
					methodResult.Result = data_Reference;
				}
				else
				{
					DataValue dataValue = ResoniteLinkTypeMapper.InstantiateData(returnType);
					dataValue.BoxedValue = result?.EngineToLink();
					methodResult.Result = dataValue;
				}
			}
			return methodResult;
		}

		internal void SendSuccessResponse<TResponse>(ResoniteLink.Message sourceMessage, BatchResponse batch = null) where TResponse : Response, new()
		{
			SendResponse(sourceMessage, new TResponse
			{
				Success = true
			}, batch);
		}

		internal void SendErrorResponse<TResponse>(ResoniteLink.Message sourceMessage, string errorMessage, BatchResponse batch = null) where TResponse : Response, new()
		{
			SendResponse(sourceMessage, new TResponse
			{
				Success = false,
				ErrorInfo = errorMessage
			}, batch);
