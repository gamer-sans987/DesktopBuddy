				if (!propertyInitializations.TryGetValue(type, out MaterialPropertyInitHandler value))
				{
					int num = Interlocked.Increment(ref initRequestId);
					List<MaterialProperty> materialProperties = provider.GetMaterialProperties();
					value = new MaterialPropertyInitHandler(type, materialProperties);
					MaterialPropertyIdRequest materialPropertyIdRequest = new MaterialPropertyIdRequest();
					materialPropertyIdRequest.requestId = num;
					materialPropertyIdRequest.propertyNames = materialProperties.Select((MaterialProperty p) => p.Name).ToList();
					propertyInitializations.Add(type, value);
					lock (propertyInitByRequestId)
					{
						propertyInitByRequestId.Add(num, value);
					}
					RenderSystem.SendMaterialPropertyIdRequest(materialPropertyIdRequest);
				}
				value.RegisterRequester(provider);
			}
		}

		public void HandlePropertyInitResult(MaterialPropertyIdResult result)
		{
			lock (propertyInitializations)
			{
				MaterialPropertyInitHandler materialPropertyInitHandler = propertyInitByRequestId[result.requestId];
				materialPropertyInitHandler.Initialize(result.propertyIDs);
				propertyInitByRequestId.Remove(result.requestId);
				propertyInitializations.Remove(materialPropertyInitHandler.MaterialType);
			}
		}

		public void SendMaterialUpdateBatch(MaterialsUpdateBatch batch, MaterialUpdateData data)
		{
			batch.updateBatchId = Interlocked.Increment(ref updateBatchId);
			lock (runningUpdates)
			{
				runningUpdates.Add(batch.updateBatchId, data);
			}
			RenderSystem.SendMaterialUpdate(batch);
		}

		public void HandleMaterialUpdateBatchResult(MaterialsUpdateBatchResult result)
		{
			MaterialUpdateData materialUpdateData;
			lock (runningUpdates)
			{
				materialUpdateData = runningUpdates[result.updateBatchId];
				runningUpdates.Remove(result.updateBatchId);
			}
			materialUpdateData.Completed();
		}
	}
