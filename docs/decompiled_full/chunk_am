	public abstract class ChangesHandlingRenderableComponentManager<TRenderable, TUpdate, TState, TUpdateData> : RenderableComponentManager<TRenderable, TUpdate> where TRenderable : ChangeHandlingRenderableComponent where TUpdate : RenderablesStateUpdate<TState>, new() where TState : unmanaged where TUpdateData : unmanaged
	{
		private List<TRenderable> _changedStates = new List<TRenderable>();

		protected override bool HasAnyUpdates => _changedStates.Count > 0;

		protected IReadOnlyList<TRenderable> ChangedStates => _changedStates;

		protected ChangesHandlingRenderableComponentManager(RenderManager manager)
			: base(manager)
		{
		}

		protected override void FillUpdates(TUpdate update)
		{
			SharedMemoryBlockLease<TState> sharedMemoryBlockLease = base.RenderSystem.AllocateBlock<TState>(_changedStates.Count, frameBound: true, this);
			Span<TState> statesData = sharedMemoryBlockLease.AccessData();
			int num = 0;
			TUpdateData updateData = InitUpdateData(update);
			for (int i = 0; i < _changedStates.Count; i++)
			{
				TRenderable val = _changedStates[i];
				if (val.IsRenderable)
				{
					ref TState state = ref statesData[num++];
					AssignIndex(ref state, val.RenderableIndex);
					FillState(ref state, val, ref updateData);
				}
			}
			if (num < statesData.Length)
			{
				AssignIndex(ref statesData[num], -1);
			}
			update.states = sharedMemoryBlockLease?.Descriptor ?? default(SharedMemoryBufferDescriptor<TState>);
			FinalizeUpdate(update, statesData, ref updateData);
			_changedStates.Clear();
		}

		protected abstract TUpdateData InitUpdateData(TUpdate update);

		protected abstract void FinalizeUpdate(TUpdate update, Span<TState> statesData, ref TUpdateData updateData);

		protected abstract void AssignIndex(ref TState state, int index);

		protected abstract void FillState(ref TState state, TRenderable renderable, ref TUpdateData updateData);

		public void RegisterChangedState(TRenderable renderable)
		{
			_changedStates.Add(renderable);
		}

		protected override void RenderableAssigned(TRenderable renderable)
		{
			RegisterChangedState(renderable);
		}
	}
