		}

		private static void Register<K, T>(ConcurrentDictionary<K, List<T>> dictionary, K key, T value) where K : class where T : class
		{
			if (!dictionary.TryGetValue(key, out List<T> value2))
			{
				value2 = new List<T>();
				dictionary.TryAdd(key, value2);
			}
			value2.Add(value);
		}

		private static void Unregister<K, T>(ConcurrentDictionary<K, List<T>> dictionary, K key, T value)
		{
			if (!dictionary.TryGetValue(key, out List<T> value2))
			{
				K val = key;
				throw new Exception("There are no items registered under a key " + val);
			}
			if (!value2.Remove(value))
			{
				K val = key;
				throw new Exception("Given value isn't registered under key " + val);
			}
			if (value2.Count == 0)
			{
				dictionary.TryRemove(key, out List<T> _);
			}
		}

