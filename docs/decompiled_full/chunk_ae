				1 => updateOrder, 
				2 => EnabledField, 
				3 => Parameter, 
				4 => ModificationMode, 
				5 => MinValue, 
				6 => MaxValue, 
				7 => Channel, 
				8 => Texture, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

