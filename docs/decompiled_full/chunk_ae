	[StructLayout(LayoutKind.Sequential, Size = 1)]
	public struct StaticCharacterMotionFunctions : IOneBodyConstraintFunctions<StaticCharacterMotionPrestep, StaticCharacterMotionProjection, CharacterMotionAccumulatedImpulse>
	{
		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		private static void ComputeJacobians(in Vector3Wide offsetA, in QuaternionWide basisQuaternion, out Matrix3x3Wide basis, out Matrix2x3Wide horizontalAngularJacobianA, out Vector3Wide verticalAngularJacobianA)
		{
			Matrix3x3Wide.CreateFromQuaternion(in basisQuaternion, out basis);
			Vector3Wide.CrossWithoutOverlap(in offsetA, in basis.X, out horizontalAngularJacobianA.X);
			Vector3Wide.CrossWithoutOverlap(in offsetA, in basis.Y, out verticalAngularJacobianA);
			Vector3Wide.CrossWithoutOverlap(in offsetA, in basis.Z, out horizontalAngularJacobianA.Y);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void Prestep(Bodies bodies, ref Vector<int> bodyReferences, int count, float dt, float inverseDt, ref BodyInertias inertiaA, ref StaticCharacterMotionPrestep prestepData, out StaticCharacterMotionProjection projection)
		{
			ComputeJacobians(in prestepData.OffsetFromCharacter, in prestepData.SurfaceBasis, out var _, out var horizontalAngularJacobianA, out var verticalAngularJacobianA);
			Symmetric3x3Wide.MatrixSandwich(in horizontalAngularJacobianA, in inertiaA.InverseInertiaTensor, out var result);
			result.XX += inertiaA.InverseMass;
			result.YY += inertiaA.InverseMass;
			Symmetric2x2Wide.InvertWithoutOverlap(in result, out projection.HorizontalEffectiveMass);
			Symmetric3x3Wide.VectorSandwich(in verticalAngularJacobianA, in inertiaA.InverseInertiaTensor, out var sandwich);
			Vector<float> vector = sandwich + inertiaA.InverseMass;
			projection.VerticalEffectiveMass = Vector<float>.One / vector;
			projection.SurfaceBasis = prestepData.SurfaceBasis;
			projection.OffsetFromCharacter = prestepData.OffsetFromCharacter;
			projection.TargetVelocity.X = prestepData.TargetVelocity.X;
			projection.TargetVelocity.Y = -prestepData.TargetVelocity.Y;
			projection.InertiaA = inertiaA;
			projection.MaximumHorizontalImpulse = prestepData.MaximumHorizontalForce * dt;
			projection.MaximumVerticalForce = prestepData.MaximumVerticalForce * dt;
			projection.VerticalBiasVelocity = System.Numerics.Vector.Max(Vector<float>.Zero, prestepData.Depth * inverseDt);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		private static void ApplyHorizontalImpulse(in Matrix3x3Wide basis, in Matrix2x3Wide angularJacobianA, in Vector2Wide constraintSpaceImpulse, in BodyInertias inertiaA, ref BodyVelocities velocityA)
		{
			Vector3Wide.Scale(in basis.X, in constraintSpaceImpulse.X, out var result);
			Vector3Wide.Scale(in basis.Z, in constraintSpaceImpulse.Y, out var result2);
			Vector3Wide.Add(in result, in result2, out var result3);
			Vector3Wide.Scale(in result3, in inertiaA.InverseMass, out var result4);
			Vector3Wide.Add(in velocityA.Linear, in result4, out velocityA.Linear);
			Matrix2x3Wide.Transform(in constraintSpaceImpulse, in angularJacobianA, out var result5);
			Symmetric3x3Wide.TransformWithoutOverlap(in result5, in inertiaA.InverseInertiaTensor, out var result6);
			Vector3Wide.Add(in velocityA.Angular, in result6, out velocityA.Angular);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		private static void ApplyVerticalImpulse(in Matrix3x3Wide basis, in Vector3Wide angularJacobianA, in Vector<float> constraintSpaceImpulse, in BodyInertias inertiaA, ref BodyVelocities velocityA)
		{
			Vector3Wide.Scale(in basis.Y, in constraintSpaceImpulse, out var result);
			Vector3Wide.Scale(in result, in inertiaA.InverseMass, out var result2);
			Vector3Wide.Add(in velocityA.Linear, in result2, out velocityA.Linear);
			Vector3Wide.Scale(in angularJacobianA, in constraintSpaceImpulse, out var result3);
			Symmetric3x3Wide.TransformWithoutOverlap(in result3, in inertiaA.InverseInertiaTensor, out var result4);
			Vector3Wide.Add(in velocityA.Angular, in result4, out velocityA.Angular);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void WarmStart(ref BodyVelocities velocityA, ref StaticCharacterMotionProjection projection, ref CharacterMotionAccumulatedImpulse accumulatedImpulse)
		{
			ComputeJacobians(in projection.OffsetFromCharacter, in projection.SurfaceBasis, out var basis, out var horizontalAngularJacobianA, out var verticalAngularJacobianA);
			ApplyHorizontalImpulse(in basis, in horizontalAngularJacobianA, in accumulatedImpulse.Horizontal, in projection.InertiaA, ref velocityA);
			ApplyVerticalImpulse(in basis, in verticalAngularJacobianA, in accumulatedImpulse.Vertical, in projection.InertiaA, ref velocityA);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void Solve(ref BodyVelocities velocityA, ref StaticCharacterMotionProjection projection, ref CharacterMotionAccumulatedImpulse accumulatedImpulse)
		{
			ComputeJacobians(in projection.OffsetFromCharacter, in projection.SurfaceBasis, out var basis, out var horizontalAngularJacobianA, out var verticalAngularJacobianA);
			Vector2Wide a = default(Vector2Wide);
			Vector3Wide.Dot(in basis.X, in velocityA.Linear, out a.X);
			Vector3Wide.Dot(in basis.Z, in velocityA.Linear, out a.Y);
			Matrix2x3Wide.TransformByTransposeWithoutOverlap(in velocityA.Angular, in horizontalAngularJacobianA, out var result);
			Vector2Wide.Add(in a, in result, out var result2);
			Vector2Wide.Subtract(in projection.TargetVelocity, in result2, out var result3);
			Symmetric2x2Wide.TransformWithoutOverlap(in result3, in projection.HorizontalEffectiveMass, out var result4);
			Vector2Wide b = accumulatedImpulse.Horizontal;
			Vector2Wide.Add(in accumulatedImpulse.Horizontal, in result4, out accumulatedImpulse.Horizontal);
			Vector2Wide.Length(in accumulatedImpulse.Horizontal, out var length);
			Vector<float> scalar = System.Numerics.Vector.Min(Vector<float>.One, projection.MaximumHorizontalImpulse / System.Numerics.Vector.Max(new Vector<float>(1E-16f), length));
			Vector2Wide.Scale(in accumulatedImpulse.Horizontal, in scalar, out accumulatedImpulse.Horizontal);
			Vector2Wide.Subtract(in accumulatedImpulse.Horizontal, in b, out result4);
			ApplyHorizontalImpulse(in basis, in horizontalAngularJacobianA, in result4, in projection.InertiaA, ref velocityA);
			Vector3Wide.Dot(in basis.Y, in velocityA.Linear, out var result5);
			Vector3Wide.Dot(in velocityA.Angular, in verticalAngularJacobianA, out var result6);
			Vector<float> vector = (projection.VerticalBiasVelocity - result5 - result6) * projection.VerticalEffectiveMass;
			Vector<float> vertical = accumulatedImpulse.Vertical;
			accumulatedImpulse.Vertical = System.Numerics.Vector.Min(Vector<float>.Zero, System.Numerics.Vector.Max(accumulatedImpulse.Vertical + vector, -projection.MaximumVerticalForce));
			ApplyVerticalImpulse(in basis, in verticalAngularJacobianA, accumulatedImpulse.Vertical - vertical, in projection.InertiaA, ref velocityA);
		}
	}
