		public LocaleString LocaleString
		{
			get
			{
				Dictionary<string, object> dictionary = null;
				if (ArgumentSources.Count > 0)
				{
					dictionary = new Dictionary<string, object>();
					foreach (KeyValuePair<string, RelayRef<IField>> argumentSource in ArgumentSources)
					{
						dictionary.Add(argumentSource.Key, argumentSource.Value.Target);
					}
					foreach (KeyValuePair<string, SyncVar> argumentValue in ArgumentValues)
					{
						if (!dictionary.ContainsKey(argumentValue.Key))
						{
							dictionary.Add(argumentValue.Key, argumentValue.Value.AsGenericField()?.BoxedValue);
						}
					}
				}
				return new LocaleString(Key.Value, Format.Value, isLocaleKey: true, isContinuous: true, dictionary);
			}
			set
			{
				if (!value.isLocaleKey)
				{
					Key.Value = null;
					Format.Value = value.content;
					ArgumentSources.Clear();
					return;
				}
				Key.Value = value.content;
				Format.Value = value.format;
				ArgumentSources.Clear();
				ArgumentValues.Clear();
				if (value.arguments == null)
				{
					return;
				}
				foreach (KeyValuePair<string, object> argument in value.arguments)
				{
					if (argument.Value is IField field)
					{
						SetArgumentSource(argument.Key, field);
					}
					else
					{
						SetArgumentValue(argument.Key, argument.Value);
					}
				}
			}
		}

		[SyncMethod(typeof(Action<string, IField>), new string[] { })]
		public void SetArgumentSource(string key, IField field)
		{
			if (!ArgumentSources.TryGetElement(key, out RelayRef<IField> element))
			{
				element = ArgumentSources.Add(key);
			}
			element.Target = field;
		}

		[SyncMethod(typeof(Func<string, object, bool>), new string[] { })]
		public bool SetArgumentValue(string key, object value)
		{
			if (!ArgumentValues.TryGetElement(key, out SyncVar element))
			{
				element = ArgumentValues.Add(key);
			}
			try
			{
				element.SetValueBoxed(value);
				return true;
			}
			catch (ArgumentException)
			{
				return false;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			Locale.ListenToAssetUpdates = true;
			Target.SetupValueSetHook(delegate(IField<string> field, string value)
			{
				Format.Value = value;
			});
		}

		protected override void OnChanges()
		{
			if (!Target.IsLinkValid)
			{
				return;
			}
			Dictionary<string, object> dictionary = Pool.BorrowDictionary<string, object>();
			foreach (KeyValuePair<string, RelayRef<IField>> argumentSource in ArgumentSources)
			{
				dictionary.Add(argumentSource.Key, argumentSource.Value.Target?.BoxedValue);
			}
			foreach (KeyValuePair<string, SyncVar> argumentValue in ArgumentValues)
			{
				if (!dictionary.ContainsKey(argumentValue.Key))
				{
					dictionary.Add(argumentValue.Key, argumentValue.Value.AsGenericField()?.BoxedValue);
				}
			}
			string text = Locale.Asset?.Format(Key.Value, dictionary);
			if (!string.IsNullOrWhiteSpace(Format.Value))
			{
				text = string.Format(Format.Value, text);
			}
			if (FrooxEngine.Engine.IsAprilFools && text != null)
			{
				MysterySettings? activeSetting = Settings.GetActiveSetting<MysterySettings>();
				if (activeSetting != null && activeSetting.Difficulty.Value == MysterySettings.ResoniteDifficulty.Hard)
				{
					StringBuilder stringBuilder = Pool.BorrowStringBuilder();
					for (int i = 0; i < text.Length; i++)
					{
						char c = text[i];
						switch (c)
						{
						case 'A':
						case 'a':
							stringBuilder.Append('4');
							continue;
						case 'O':
						case 'o':
							stringBuilder.Append('0');
							continue;
						case 'E':
						case 'e':
							stringBuilder.Append('3');
							continue;
						case 'I':
						case 'i':
							stringBuilder.Append('1');
							continue;
						case 'T':
						case 't':
							stringBuilder.Append('7');
							continue;
						case 'B':
						case 'b':
							stringBuilder.Append('8');
							continue;
						case 'S':
						case 's':
							stringBuilder.Append('5');
							continue;
						}
						if ((i & 1) == 0)
						{
							stringBuilder.Append(char.ToUpper(c));
						}
						else
						{
							stringBuilder.Append(char.ToLower(c));
						}
					}
					text = stringBuilder.ToString();
					Pool.Return(ref stringBuilder);
				}
			}
			Target.Target.Value = text;
			Pool.Return(ref dictionary);
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Target = new FieldDrive<string>();
			Key = new Sync<string>();
			Format = new Sync<string>();
			Locale = new AssetRef<LocaleResource>();
			ArgumentSources = new SyncDictionary<string, RelayRef<IField>>();
			ArgumentValues = new SyncDictionary<string, SyncVar>();
		}

