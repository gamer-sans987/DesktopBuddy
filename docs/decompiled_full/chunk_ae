		public void ClearLastCalculatedData()
		{
			_lastCalculatedCenteringOffset.Value = null;
			_lastCalculatedCellSize.Value = null;
			_lastCalculatedPadding.Value = null;
		}

		public void ComputeLastDataForRect(in Elements.Core.float2 rectSize)
		{
			_lastCalculatedCenteringOffset.Value = ComputeCenteringOffsetForRect(in rectSize);
			_lastCalculatedCellSize.Value = ComputeActualSizeForRect(in rectSize);
			_lastCalculatedPadding.Value = Padding.Value;
		}

		public Elements.Core.int2 ComputeGridSizeForRect(in Elements.Core.float2 rectSize)
		{
			if (CellCount.Value.HasValue)
			{
				return CellCount.Value.Value;
			}
			if (CellSize.Value.HasValue)
			{
				return MathX.FloorToInt(rectSize / CellSize.Value.Value);
			}
			return Elements.Core.int2.Zero;
