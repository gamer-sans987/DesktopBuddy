		public Task NotifyOfScreenshot(bool autoSave = true)
		{
			_exportedUsers.Add().Target = base.LocalUser;
			Engine _engine = base.Engine;
			World _world = base.World;
			bool is360 = Is360.Value;
			StereoLayout stereoLayout = StereoLayout.Value;
			return StartGlobalTask(async delegate
			{
				StaticTexture2D tex = base.Slot.GetComponent<StaticTexture2D>();
				Uri url = tex?.URL.Value;
				if (!(url == null))
				{
					await default(ToBackground);
					string text = await _engine.AssetManager.GatherAssetFile(url, 100f);
					if (text != null)
					{
						ScreenshotType type = ScreenshotType.Mono;
						if (is360)
						{
							type = ScreenshotType.Mono360;
						}
						else if (stereoLayout != Elements.Core.StereoLayout.None)
						{
							type = ScreenshotType.Stereo;
						}
						_engine.PlatformInterface.NotifyOfScreenshot(_world, text, type, TimeTaken.Value);
						if (autoSave)
						{
							string path = Settings.GetActiveSetting<PhotoCaptureSettings>()?.PhotoAutosavePath.Value;
							if (!string.IsNullOrEmpty(path))
							{
								path = PhotoCaptureSettings.GeneratePhotoPath(path, base.World, TimeTaken.Value.ToLocalTime(), LocationName.Value, AppVersion.Value);
								UniLog.Log("Autosaving photo to path: " + path);
								while (true)
								{
									Texture2D asset = tex.Asset;
									if (asset != null && asset.LoadState == AssetLoadState.FullyLoaded)
									{
										break;
									}
									await default(NextUpdate);
								}
								await ItemHelper.SaveItemAndSync(base.Slot, saveRoot: true, delegate(FrooxEngine.Store.Record r)
								{
									r.Path = path;
								});
							}
						}
					}
					else
					{
						_exportedUsers.RemoveAll((UserRef u) => u.Target == base.LocalUser);
					}
				}
			});
		}

