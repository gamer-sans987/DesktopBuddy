			}
			foreach (Pointer item in hashSet)
			{
				ReturnTouchSource(_activeTouchSources[item]);
				_activeTouchSources.Remove(item);
			}
			Pool.Return(ref hashSet);
			for (int i = 0; i < _usedPointers.Count; i++)
