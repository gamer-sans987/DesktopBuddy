		public void OnTouch(in TouchEventInfo eventInfo)
		{
			if (eventInfo.touch != EventState.Begin && eventInfo.touch != EventState.Stay)
			{
				return;
			}
			Elements.Core.float2 v = base.Slot.GlobalPointToLocal(in eventInfo.point).xy;
			float magnitude = v.Magnitude;
			float num = MathX.Atan2(in v);
			num = MathF.PI * 2f - num;
			num -= MathF.PI;
			if (magnitude < 0.0325f)
			{
				if (eventInfo.touch == EventState.Begin)
				{
					if (_clipPlayer.Target.IsPlaying)
					{
						_clipPlayer.Target.Pause();
					}
					else if (_clipPlayer.Target.NormalizedPosition < 1f)
					{
						_clipPlayer.Target.Resume();
					}
					else
					{
						_clipPlayer.Target.Play();
					}
				}
			}
			else if (magnitude < 0.05f)
			{
				num -= 0.1570797f;
				num = MathX.Clamp(num, 0f, 5.969026f);
				float normalizedPosition = num / 5.969026f;
				_clipPlayer.Target.NormalizedPosition = normalizedPosition;
			}
			else if (magnitude < 0.07f)
			{
				num += MathF.PI / 2f;
				num %= MathF.PI * 2f;
				num -= MathF.PI / 4f;
				float num2 = num / (MathF.PI / 2f);
				if (!(num2 < -0.1f) && !(num2 > 1.1f))
				{
					num2 = MathX.Pow(num2, VOLUME_POWER);
					_audioOutput.Target.Volume.Value = MathX.Clamp01(num2);
				}
			}
		}

