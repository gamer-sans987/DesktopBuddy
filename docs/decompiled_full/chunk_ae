	public class AlwaysOnFacetModule : Component, IFacetEventReceiver
	{
		protected readonly SyncRefList<Slot> _targets;

		public void OnFacetPicked(Facet facet)
		{
			Restore();
		}

		public void OnFacetPlaced(Facet facet)
		{
			Place();
		}

		private void Restore()
		{
			foreach (Slot target in _targets)
			{
				target?.SetParent(base.Slot, keepGlobalTransform: false);
				target?.SetIdentityTransform();
			}
			_targets.Clear();
		}

		private void Place()
		{
			Slot slot = base.Slot.GetComponentInParents<IAlwaysOnFacetContainer>()?.AlwaysOnFacetRoot;
			if (slot == null)
			{
				return;
			}
			_targets.Clear();
			List<Slot> list = Pool.BorrowList<Slot>();
			foreach (Slot child in base.Slot.Children)
			{
				list.Add(child);
			}
			foreach (Slot item in list)
			{
				item.SetParent(slot, keepGlobalTransform: false);
				item.SetIdentityTransform();
				_targets.Add(item);
			}
			Pool.Return(ref list);
		}

		protected override void OnStart()
		{
			base.OnStart();
			Place();
		}

		protected override void OnDisabled()
		{
			base.OnDisabled();
			Restore();
		}

		protected override void OnEnabled()
		{
			base.OnEnabled();
			Place();
		}

		protected override void OnSaving(SaveControl control)
		{
			List<Slot> origParents = Pool.BorrowList<Slot>();
			control.OnBeforeSaveStart(delegate
			{
				foreach (Slot target in _targets)
				{
					if (target != null)
					{
						origParents.Add(target.Parent);
						target.SetParent(base.Slot, keepGlobalTransform: false);
					}
				}
			});
			control.OnSaved(delegate
			{
				int num = 0;
				foreach (Slot target2 in _targets)
				{
					target2?.SetParent(origParents[num++], keepGlobalTransform: false);
				}
				Pool.Return(ref origParents);
			});
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			_targets = new SyncRefList<Slot>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => _targets, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static AlwaysOnFacetModule __New()
		{
			return new AlwaysOnFacetModule();
		}
	}
