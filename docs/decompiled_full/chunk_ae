	public class FocusManager : UserComponent, IInputUpdateReceiver, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		private static HashSet<FocusManager> _activeFocuses = new HashSet<FocusManager>();

		protected readonly SyncRef<IFocusable> _currentFocus;

		private IFocusable _lastFocus;

		private bool isLocal;

		private bool focusInvalidated;

		public IFocusable Focus
		{
			get
			{
				return _currentFocus.RawTarget;
			}
			set
			{
				_currentFocus.Target = value;
			}
		}

		protected override void OnAwake()
		{
			if (base.User.IsLocalUser)
			{
				base.World.Input.RegisterInputEventReceiver(this);
				_currentFocus.OnTargetChange += FocusChanged;
				isLocal = true;
			}
		}

		private void FocusChanged(SyncRef<IFocusable> reference)
		{
			if (focusInvalidated)
			{
				return;
			}
			focusInvalidated = true;
			RunSynchronously(delegate
			{
				focusInvalidated = false;
				if (_currentFocus.Target != _lastFocus)
				{
					IFocusable target = _currentFocus.Target;
					DefocusCurrent();
					_lastFocus = target;
					if (_lastFocus != null)
					{
						try
						{
							_lastFocus.Focus(base.User);
						}
						catch (Exception exception)
						{
							base.Debug.Error($"Exception running Focus() on {_lastFocus}:\n{DebugManager.PreprocessException(exception)}");
						}
					}
					if (base.World == Userspace.UserspaceWorld)
					{
						List<World> list = Pool.BorrowList<World>();
						base.Engine.WorldManager.GetWorlds(list);
						foreach (World item in list)
						{
							World _w = item;
							if (_w != base.World)
							{
								_w.RunSynchronously(delegate
								{
									FocusManager component = _w.LocalUser.GetComponent<FocusManager>();
									if (component != null)
									{
										component.Focus = null;
									}
								});
							}
						}
						Pool.Return(ref list);
					}
					if (_lastFocus != null && base.World != Userspace.UserspaceWorld)
					{
						Userspace.Defocus();
					}
				}
				if (base.World != Userspace.UserspaceWorld)
				{
					lock (_activeFocuses)
					{
						if (Focus == null)
						{
							RunInUpdates(2, delegate
							{
								_activeFocuses.Remove(this);
							});
						}
						else
						{
							_activeFocuses.Add(this);
						}
					}
				}
			});
		}

		protected override void OnCommonUpdate()
		{
			if (!base.User.IsLocalUser || Focus == null || (!Focus.IsDestroyed && Focus.Slot.IsActive))
			{
				return;
			}
			Focus = null;
			if (base.World != Userspace.UserspaceWorld)
			{
				RunInUpdates(2, delegate
				{
					_activeFocuses.Remove(this);
				});
			}
		}

		public override void OnFocusChanged(World.WorldFocus focus)
		{
			if (!base.IsDisposed && base.User.IsLocalUser && focus != FrooxEngine.World.WorldFocus.Focused)
			{
				Focus = null;
			}
		}

		protected override void OnDispose()
		{
			if (!base.World.IsDisposed)
			{
				DefocusCurrent();
			}
			if (isLocal)
			{
				base.World.Input.UnregisterInputEventReceiver(this);
			}
			base.OnDispose();
		}

		private void DefocusCurrent()
		{
			if (_lastFocus != null && !_lastFocus.IsDestroyed)
			{
				if (base.World.CanMakeSynchronousChanges)
				{
					try
					{
						_lastFocus.Defocus(base.User);
					}
					catch (Exception exception)
					{
						base.Debug.Error($"Exception running Defocus() on {_lastFocus}:\n{DebugManager.PreprocessException(exception)}");
					}
				}
				else
				{
					IFocusable defocus = _lastFocus;
					base.World.RunSynchronously(delegate
					{
						try
						{
							defocus.Defocus(base.User);
						}
						catch (Exception exception2)
						{
							base.Debug.Error($"Exception running Defocus() on {defocus}:\n{DebugManager.PreprocessException(exception2)}");
						}
					});
				}
			}
			_lastFocus = null;
		}

		public void BeforeInputUpdate()
		{
			if (Focus != null)
			{
				base.Input.BlockManager.AddBlocker(KeyboardBlock.GLOBAL_BLOCK);
				if (base.World == Userspace.UserspaceWorld)
				{
					base.InputInterface.RegisterGlobalBlock(KeyboardBlock.GLOBAL_BLOCK);
				}
			}
			else
			{
				if (base.World != Userspace.UserspaceWorld)
				{
					return;
				}
				lock (_activeFocuses)
				{
					_activeFocuses.RemoveWhere((FocusManager f) => f.IsRemoved);
					if (_activeFocuses.Count > 0)
					{
						base.Input.BlockManager.AddBlocker(KeyboardBlock.GLOBAL_BLOCK);
					}
				}
			}
		}

		public void AfterInputUpdate()
		{
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			_currentFocus = new SyncRef<IFocusable>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => _currentFocus, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static FocusManager __New()
		{
			return new FocusManager();
		}
	}
