		{
			if (ShowVisual.Value)
			{
				string text = HandSide.Value.ToString();
				if (_activeVisual.Target != null && _activeVisual.Target.Name != text)
				{
					_activeVisual.Target.Destroy();
				}
				if (DisableSlider.Value)
				{
					base.Slot.GetComponent<Slider>()?.Destroy();
				}
				if (_activeVisual.Target != null)
				{
					return;
				}
				if (DisableSlider.Value)
				{
					Slider componentOrAttach = base.Slot.GetComponentOrAttach<Slider>();
					componentOrAttach.Persistent = false;
