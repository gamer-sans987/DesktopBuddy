		private Elements.Core.IntRect? FindPlacement(Facet facet, Elements.Core.float2 point, Elements.Core.float2? forceSize = null, List<Elements.Core.IntRect> rects = null)
		{
			bool flag = false;
			if (rects == null)
			{
				rects = Pool.BorrowList<Elements.Core.IntRect>();
				flag = true;
			}
			Elements.Core.int2 canvasSize = GridSize;
			try
			{
				if (flag)
				{
					GetCurrentRects(rects);
				}
				Elements.Core.float2 offeredSize;
				Elements.Core.float2? @float;
				if (forceSize.HasValue)
				{
					Elements.Core.float2 b = MathX.Sign(forceSize.Value);
					Elements.Core.IntRect? intRect = ComputePlacementRect(forceSize.Value, in point, in canvasSize, forcedSize: true);
					if (!intRect.HasValue)
					{
						return null;
					}
					if (IntersectsAny(intRect.Value, rects))
					{
						return null;
					}
					offeredSize = (Elements.Core.float2)intRect.Value.Size * ActualCellSize - Padding.Value;
					@float = facet.FitSize(offeredSize);
					if (!@float.HasValue)
					{
						return null;
					}
					intRect = ComputePlacementRect(@float.Value * b, in point, in canvasSize, forcedSize: true);
					if (IntersectsAny(intRect.Value, rects))
					{
						return null;
					}
					return intRect;
				}
				Elements.Core.IntRect rect = new Elements.Core.IntRect(ComputeGridPoint(in point, in canvasSize), Elements.Core.int2.One);
				if (IntersectsAny(rect, rects))
				{
					return null;
				}
				foreach (Elements.Core.float2 actualPreferredSize in facet.ActualPreferredSizes)
				{
					Elements.Core.IntRect? result = ComputePlacementRect(actualPreferredSize + Padding.Value, in point, in canvasSize, forcedSize: false);
					if (result.HasValue && !IntersectsAny(result.Value, rects))
					{
						return result;
					}
				}
				bool flag2 = true;
				bool flag3 = true;
				bool flag4 = true;
				bool flag5 = true;
				while (flag2 || flag3 || flag4 || flag5)
				{
					if (flag2)
					{
						flag2 = TryGrowUp(ref rect, canvasSize.y, rects);
					}
					if (flag3)
					{
						flag3 = TryGrowRight(ref rect, canvasSize.x, rects);
					}
					if (flag4)
					{
						flag4 = TryGrowDown(ref rect, rects);
					}
					if (flag5)
					{
						flag5 = TryGrowLeft(ref rect, rects);
					}
				}
				foreach (Elements.Core.float2 actualPreferredSize2 in facet.ActualPreferredSizes)
				{
					Elements.Core.float2 a = actualPreferredSize2;
					Elements.Core.int2 gridSize = ComputeGridSize(a + (Elements.Core.float2)Padding);
					if (!(gridSize > rect.Size).Any())
					{
						Elements.Core.int2 gridPoint = ComputeGridPointUnclamped(a + (Elements.Core.float2)Padding, in point, forcedSize: false) - rect.Position;
						return new Elements.Core.IntRect(ClampGridPoint(gridPoint, in gridSize, rect.Size) + rect.Position, in gridSize);
					}
				}
				offeredSize = (Elements.Core.float2)rect.Size * ActualCellSize;
				Elements.Core.float2 a2 = Elements.Core.float2.Zero;
				foreach (Elements.Core.float2 preferredSize in facet.PreferredSizes)
				{
					a2 = MathX.Max(in a2, preferredSize + (Elements.Core.float2)Padding);
				}
				@float = facet.FitSize(MathX.Min(a2.Mask(a2 > 0f, float.PositiveInfinity), in offeredSize) - (Elements.Core.float2)Padding);
				if (!@float.HasValue)
				{
					return null;
				}
				Elements.Core.float2 point2 = point - (Elements.Core.float2)rect.Position * ActualCellSize;
				Elements.Core.IntRect? intRect2 = ComputePlacementRect(@float.Value + (Elements.Core.float2)Padding, in point2, rect.Size, forcedSize: false);
				if (!intRect2.HasValue)
				{
					return null;
				}
				return intRect2.Value.Translate(rect.Position);
			}
			finally
			{
				if (flag)
				{
					Pool.Return(ref rects);
				}
			}
		}

		private Elements.Core.IntRect? FindInsertionPlacement(Facet facet, Elements.Core.int2 startPoint, Elements.Core.int2 searchDirection, bool verticalFirst, Elements.Core.int2? overrideSize = null)
		{
			List<Elements.Core.IntRect> list = Pool.BorrowList<Elements.Core.IntRect>();
			try
			{
				GetCurrentRects(list);
				Elements.Core.int2 gridSize = GridSize;
				Elements.Core.float2 a = ActualCellSize;
				Elements.Core.int2? @int = overrideSize;
				Elements.Core.float2? @float = (@int.HasValue ? new Elements.Core.float2?(@int.GetValueOrDefault()) : ((Elements.Core.float2?)null));
				Elements.Core.float2? forceSize = (@float.HasValue ? new Elements.Core.float2?(a * @float.GetValueOrDefault()) : ((Elements.Core.float2?)null));
				Elements.Core.float2 actualCellSize = ActualCellSize;
				int num = MathX.Repeat(startPoint.x, gridSize.x);
				int num2 = MathX.Repeat(startPoint.y, gridSize.y);
				searchDirection = MathX.Sign(in searchDirection);
				if (verticalFirst)
				{
					if (searchDirection.y == 0)
					{
						return null;
					}
					for (int i = 0; i < gridSize.x; i++)
					{
						for (int j = 0; j < gridSize.y; j++)
						{
							Elements.Core.IntRect? result = FindPlacement(facet, new Elements.Core.float2((float)num * actualCellSize.x, (float)num2 * actualCellSize.y), forceSize, list);
							if (result.HasValue)
							{
								return result;
							}
							num2 = MathX.Repeat(num2 + searchDirection.y, gridSize.y);
						}
						if (searchDirection.x == 0)
						{
							break;
						}
						num = MathX.Repeat(num + searchDirection.x, gridSize.x);
					}
				}
				else
				{
					if (searchDirection.x == 0)
					{
						return null;
					}
					for (int k = 0; k < gridSize.y; k++)
					{
						for (int l = 0; l < gridSize.x; l++)
						{
							Elements.Core.IntRect? result2 = FindPlacement(facet, new Elements.Core.float2((float)num * actualCellSize.x, (float)num2 * actualCellSize.y), forceSize, list);
							if (result2.HasValue)
							{
								return result2;
							}
							num = MathX.Repeat(num + searchDirection.x, gridSize.x);
						}
						if (searchDirection.y == 0)
						{
							break;
						}
						num2 = MathX.Repeat(num2 + searchDirection.y, gridSize.y);
					}
				}
			}
			finally
			{
				Pool.Return(ref list);
			}
			return null;
		}

		private static bool TryGrowUp(ref Elements.Core.IntRect rect, int canvasHeight, List<Elements.Core.IntRect> rects)
		{
			if (rect.height + rect.y >= canvasHeight)
			{
				return false;
			}
			Elements.Core.IntRect intRect = new Elements.Core.IntRect(rect.x, rect.y, rect.width, rect.height + 1);
			if (IntersectsAny(intRect, rects))
			{
				return false;
			}
			rect = intRect;
			return true;
		}

		private static bool TryGrowLeft(ref Elements.Core.IntRect rect, List<Elements.Core.IntRect> rects)
		{
			if (rect.x <= 0)
			{
				return false;
			}
			Elements.Core.IntRect intRect = new Elements.Core.IntRect(rect.x - 1, rect.y, rect.width + 1, rect.height);
			if (IntersectsAny(intRect, rects))
			{
				return false;
			}
			rect = intRect;
			return true;
		}

		private static bool TryGrowRight(ref Elements.Core.IntRect rect, int canvasWidth, List<Elements.Core.IntRect> rects)
		{
			if (rect.width + rect.x >= canvasWidth)
			{
				return false;
			}
			Elements.Core.IntRect intRect = new Elements.Core.IntRect(rect.x, rect.y, rect.width + 1, rect.height);
			if (IntersectsAny(intRect, rects))
			{
				return false;
			}
			rect = intRect;
			return true;
		}

		private static bool TryGrowDown(ref Elements.Core.IntRect rect, List<Elements.Core.IntRect> rects)
		{
			if (rect.y <= 0)
			{
				return false;
			}
			Elements.Core.IntRect intRect = new Elements.Core.IntRect(rect.x, rect.y - 1, rect.width, rect.height + 1);
			if (IntersectsAny(intRect, rects))
			{
				return false;
			}
			rect = intRect;
			return true;
		}

		private static bool IntersectsAny(Elements.Core.IntRect rect, List<Elements.Core.IntRect> rects)
		{
			foreach (Elements.Core.IntRect rect2 in rects)
			{
				if (rect.Intersects(rect2))
				{
					return true;
				}
			}
			return false;
		}

		private Elements.Core.int2 ComputeGridSize(in Elements.Core.float2 size)
		{
			return MathX.CeilToInt(MathX.Abs(in size) / ActualCellSize);
		}

		private Elements.Core.int2 ComputeGridPointUnclamped(in Elements.Core.float2 size, in Elements.Core.float2 point, bool forcedSize)
		{
			Elements.Core.int2 a = RoundPoint(point / ActualCellSize);
			if (!forcedSize)
			{
				a -= ComputeGridSize(in size) / 2;
			}
			return a;
		}

		private Elements.Core.int2 ComputeGridPoint(in Elements.Core.float2 point, in Elements.Core.int2 canvasSize)
		{
			return ClampGridPoint(ComputeGridPointUnclamped(Elements.Core.float2.Zero, in point, forcedSize: true), Elements.Core.int2.One, in canvasSize);
		}

		private Elements.Core.int2 RoundPoint(in Elements.Core.float2 p)
		{
			return new Elements.Core.int2(MathX.FloorToInt(p.x), MathX.FloorToInt(p.y));
		}

		private Elements.Core.IntRect? ComputePlacementRect(in Elements.Core.float2 size, in Elements.Core.float2 point, in Elements.Core.int2 canvasSize, bool forcedSize)
		{
			Elements.Core.int2 b = ComputeGridSize(in size);
			if ((b > canvasSize).Any())
			{
				return null;
			}
			Elements.Core.int2 a = ComputeGridPointUnclamped(in size, in point, forcedSize);
			a = a.Mask(size >= 0f, a - b + 1);
			return new Elements.Core.IntRect(ClampGridPoint(a, in b, in canvasSize), in b);
		}

		private static Elements.Core.int2 ClampGridPoint(Elements.Core.int2 gridPoint, in Elements.Core.int2 gridSize, in Elements.Core.int2 canvasSize)
		{
			gridPoint = MathX.Max(in gridPoint, 0);
			gridPoint += MathX.Min(canvasSize - (gridPoint + gridSize), 0);
			return gridPoint;
		}

		private void GetCurrentRects(List<Elements.Core.IntRect> rects, List<string> names = null)
		{
			GetCurrentRects(rects, ActualCellSize, CenteringOffset, Padding, names);
		}

		private void GetCurrentRects(List<Elements.Core.IntRect> rects, Elements.Core.float2 actualCellSize, Elements.Core.float2 centeringOffset, Elements.Core.float2 padding, List<string> names = null)
		{
			Elements.Core.float2 b = padding * 0.5f;
			foreach (Slot child in base.ContentRoot.Slot.Children)
			{
				RectTransform component = child.GetComponent<RectTransform>();
				if (component != null)
				{
					Elements.Core.Rect rect = Elements.Core.Rect.FromMinMax((Elements.Core.float2)component.OffsetMin, (Elements.Core.float2)component.OffsetMax);
					ref Elements.Core.float2 position = ref rect.position;
					position -= centeringOffset + b;
					ref Elements.Core.float2 size = ref rect.size;
					size += padding;
					rects.Add(Elements.Core.IntRect.FromMinMax(MathX.FloorToInt((rect.ExtentMin + 0.01f) / actualCellSize), MathX.CeilToInt((rect.ExtentMax - 0.01f) / actualCellSize)));
					if (names != null)
					{
						NestedCanvas componentInChildren = child.GetComponentInChildren<NestedCanvas>();
						names.Add(componentInChildren.TargetCanvas.Target.Slot.GetComponentInParents<Facet>().Slot.Name);
					}
				}
			}
		}

