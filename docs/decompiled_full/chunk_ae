		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Icon, 
				4 => Color, 
				5 => _currentController, 
				6 => _lastDefaultIcon, 
				7 => _lastDefaultColor, 
