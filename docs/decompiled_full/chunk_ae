	public class ColliderUserTracker : CollisionListenerComponent
	{
		public readonly RawOutput<bool> IsLocalUserInside;

		public readonly RawOutput<bool> IsAnyUserInside;

		public readonly RawOutput<int> NumberOfUsersInside;

		protected readonly SyncBag<UserRef> _usersInside;

		private CharacterController _localCollision;

		protected override void OnChanges()
		{
			_usersInside.RemoveAll((UserRef u) => u.Target == null);
			IsAnyUserInside.Value = _usersInside.Count > 0;
			NumberOfUsersInside.Value = _usersInside.Count;
		}

		protected override void OnDispose()
		{
			_localCollision = null;
			base.OnDispose();
		}

		protected override void OnContactStart(ICollider collider, ICollider other)
		{
			if (other.ColliderOwner is CharacterController localCollision && other.Slot.IsUnderLocalUser)
			{
				if (!_usersInside.Any<KeyValuePair<RefID, UserRef>>((KeyValuePair<RefID, UserRef> u) => u.Value.Target == base.LocalUser))
				{
					_usersInside.Add().Target = base.LocalUser;
				}
				IsLocalUserInside.Value = true;
				_localCollision = localCollision;
			}
		}

		protected override void OnContactEnd(ICollider collider, ICollider other)
		{
			if (other?.ColliderOwner != _localCollision)
			{
				return;
			}
			CharacterController _previousCollision = _localCollision;
			base.Physics.SchedulePostUpdateAction(this, delegate
			{
				if (_previousCollision == _localCollision)
				{
					_usersInside.RemoveAll((UserRef u) => u.Target == base.LocalUser);
					IsLocalUserInside.Value = false;
				}
			});
		}

		public override void OnUserLeft(User user)
		{
			if (base.World.IsAuthority)
			{
				_usersInside.RemoveAll((UserRef u) => u.Target == user);
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			IsLocalUserInside = new RawOutput<bool>();
			IsAnyUserInside = new RawOutput<bool>();
			NumberOfUsersInside = new RawOutput<int>();
			_usersInside = new SyncBag<UserRef>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => TriggersOnly, 
				4 => IsLocalUserInside, 
				5 => IsAnyUserInside, 
				6 => NumberOfUsersInside, 
				7 => _usersInside, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public new static ColliderUserTracker __New()
		{
			return new ColliderUserTracker();
		}
	}
