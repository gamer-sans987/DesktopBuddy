		{
			if (_samplers.TryGetValue(point, out HapticPointSampler value))
			{
				value.Slot.Destroy();
				_samplers.Remove(point);
			}
		}

		protected void RebuildMapping()
		{
			ClearMapping();
			_manager?.MarkMappersDirty();
		}

		protected void ClearMapping()
		{
			foreach (KeyValuePair<HapticPoint, HapticPointSampler> sampler in _samplers)
			{
				sampler.Value.Slot.Destroy();
			}
			_samplers.Clear();
		}

		protected bool IsMapped(HapticPoint point)
		{
			return _samplers.ContainsKey(point);
		}

		protected HapticPointSampler CreateSampler(HapticPoint point, Slot root = null)
		{
			root = root ?? base.Slot;
			Slot slot = root.AddSlot("HapticPoint");
			slot.PersistentSelf = false;
			slot.LocalScale = Elements.Core.float3.One * base.Slot.LocalScaleToSpace(1f, root);
			HapticPointSampler hapticPointSampler = slot.AttachComponent<HapticPointSampler>();
			hapticPointSampler.Radius.Value = point.Radius;
			hapticPointSampler.HapticPointIndex.Value = point.Index;
			hapticPointSampler.ShowDebugVisual.DriveFrom(ShowDebugVisuals);
			_samplers.Add(point, hapticPointSampler);
			return hapticPointSampler;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Priority = new Sync<int>();
			ShowDebugVisuals = new Sync<bool>();
		}
