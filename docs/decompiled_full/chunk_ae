		private void ComputeSweepParameters<TShape>(in TShape shape, BodyVelocity velocity, in SweepConfiguration configuration, out float minimumProgressionT, out float convergenceThresholdT, out int maxIterationCount) where TShape : unmanaged, IConvexShape
		{
			if (configuration.IsDefault)
			{
				base.Simulation.ComputeSweepParameters(in shape, in velocity, 1f, out minimumProgressionT, out convergenceThresholdT);
				maxIterationCount = 25;
			}
			else if (configuration.asRatio)
			{
				base.Simulation.ComputeSweepParameters(in shape, in velocity, 1f, out minimumProgressionT, out convergenceThresholdT, configuration.minimumProgression, configuration.convergenceThreshold);
				maxIterationCount = configuration.maximumIterationCount;
			}
			else
			{
				minimumProgressionT = configuration.minimumProgression;
				convergenceThresholdT = configuration.convergenceThreshold;
				maxIterationCount = configuration.maximumIterationCount;
			}
		}

		protected override int SweepAll<TSHape>(in TSHape shape, in Elements.Core.float3 origin, in Elements.Core.floatQ orientation, in Elements.Core.float3 sweep, List<RaycastHit> results, Predicate<ICollider> filter, bool hitTriggers, in SweepConfiguration configuration)
		{
			RigidPose pose = new RigidPose((System.Numerics.Vector3)origin, (System.Numerics.Quaternion)orientation);
			BodyVelocity velocity = new BodyVelocity((System.Numerics.Vector3)sweep);
			float magnitude;
			Elements.Core.float3 direction = sweep.GetNormalized(out magnitude);
			SweepAllHandler hitHandler = new SweepAllHandler(this, results, filter, hitTriggers, 1f / magnitude, in origin, in direction);
			int count = results.Count;
			ComputeSweepParameters(in shape, velocity, in configuration, out var minimumProgressionT, out var convergenceThresholdT, out var maxIterationCount);
			base.Simulation.Sweep(shape, in pose, in velocity, 1f, base.BufferPool, ref hitHandler, minimumProgressionT, convergenceThresholdT, maxIterationCount);
