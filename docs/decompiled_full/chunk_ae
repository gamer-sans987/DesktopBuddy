			if (LocalUserShouldSample)
			{
				if (_samplerCollider == null)
				{
					Slot slot2 = base.Slot.AddLocalSlot("Collider");
					_samplerCollider = slot2.AttachComponent<SphereCollider>();
					_samplerCollider.Radius.DriveFrom(Radius);
					_samplerCollider.Type.Value = ColliderType.HapticSampler;
					_samplerCollider.ContactStart += OnContactStart;
					_samplerCollider.ContactStay += OnContactStay;
					_samplerCollider.ContactEnd += OnContactEnd;
				}
			}
			else if (_samplerCollider != null)
			{
				UnregisterCollider();
			}
		}

		protected override void OnDestroy()
		{
			_debugVisual.Target?.Slot?.Destroy();
			base.OnDestroy();
		}

		private void OnContactStart(ICollider collider, ICollider other)
		{
			if (base.IsDisposed)
			{
				UniLog.Warning($"Running OnContactStart on a Disposed haptic point sampler.\nCollider: {collider}\nOther: {other}", stackTrace: true);
				return;
			}
			HapticVolume component = other.Slot.GetComponent<HapticVolume>();
			HapticPoint targetHapticPoint = TargetHapticPoint;
			if (component == null || targetHapticPoint == null)
			{
				_sources.Add(other, default(HapticSourceData));
			}
			else
			{
				HapticSampler sampler = targetHapticPoint.RegisterSource(component, component.Sensation, component.IntensitySampler);
				HapticSourceData hapticSourceData = new HapticSourceData(sampler, component);
				UpdateData(hapticSourceData);
				_sources.Add(other, hapticSourceData);
			}
			UpdateDebugVisual();
		}

		private void OnContactStay(ICollider collider, ICollider other)
		{
			HapticSourceData value;
			if (base.IsDisposed)
			{
				UniLog.Warning($"Running OnContactStay on a Disposed haptic point sampler.\nCollider: {collider}\nOther: {other}", stackTrace: true);
			}
			else if (_sources.TryGetValue(other, out value) && value.sampler != null)
			{
				UpdateData(value);
			}
		}

		private void UpdateData(HapticSourceData source)
		{
			source.sampler.LocalPosition = base.Slot.Parent.LocalPointToSpace(base.Slot.LocalPosition, source.volume.Slot);
			source.sampler.PositionTime = DateTime.UtcNow;
		}

		private void OnContactEnd(ICollider collider, ICollider other)
		{
			if (_sources.TryGetValue(other, out var value))
			{
				if (value.sampler != null)
				{
					TargetHapticPoint?.UnregisterSource(value.volume, base.World);
				}
				_sources.Remove(other);
			}
			UpdateDebugVisual();
		}

		private void UpdateDebugVisual()
		{
			if (_debugVisual.Target != null)
			{
				RunSynchronously(delegate
				{
					GizmoHelper.SetMaterialColor(_debugVisual.Target, ((_sources.Count > 0) ? Elements.Core.colorX.Cyan : Elements.Core.colorX.Gray).SetA(0.73f));
				});
			}
		}

		private void UnregisterCollider()
		{
			if (_samplerCollider != null)
			{
				_samplerCollider.ContactStart -= OnContactStart;
				_samplerCollider.ContactStay -= OnContactStay;
				_samplerCollider.ContactEnd -= OnContactEnd;
				_samplerCollider.Slot.Destroy();
				_samplerCollider = null;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Radius = new Sync<float>();
			ShowDebugVisual = new Sync<bool>();
			ShowDebugVisual.MarkNonPersistent();
			_debugVisual = new SlotCleanupRef<OverlayFresnelMaterial>();
		}
	}
