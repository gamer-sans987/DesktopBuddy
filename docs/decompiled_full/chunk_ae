		private void AnalyzeContactsWorker(int workerIndex)
		{
			int index;
			while ((index = Interlocked.Increment(ref analysisJobIndex)) < analysisJobCount)
			{
				ref AnalyzeContactsJob reference = ref jobs[index];
				AnalyzeContactsForCharacterRegion(reference.Start, reference.ExclusiveEnd, workerIndex);
			}
		}

		/// <summary>
		/// Updates all character support states and motion constraints based on the current character goals and all the contacts collected since the last call to AnalyzeContacts. 
		/// Attach to a simulation callback where the most recent contact is available and before the solver executes.
		/// </summary>
		private void AnalyzeContacts(float dt, IThreadDispatcher threadDispatcher)
		{
			if (threadDispatcher == null || characters.Count < 64)
			{
				pool.Take(1, out analyzeContactsWorkerCaches);
				analyzeContactsWorkerCaches[0] = new AnalyzeContactsWorkerCache(characters.Count, pool);
				AnalyzeContactsForCharacterRegion(0, characters.Count, 0);
			}
			else
			{
				analysisJobCount = Math.Min(characters.Count, threadDispatcher.ThreadCount * 4);
				if (analysisJobCount > 0)
				{
					pool.Take(threadDispatcher.ThreadCount, out analyzeContactsWorkerCaches);
					pool.Take(analysisJobCount, out jobs);
					for (int i = 0; i < threadDispatcher.ThreadCount; i++)
					{
						analyzeContactsWorkerCaches[i] = new AnalyzeContactsWorkerCache(characters.Count, pool);
					}
					int num = characters.Count / analysisJobCount;
					int num2 = characters.Count - num * analysisJobCount;
					int start = 0;
					for (int j = 0; j < analysisJobCount; j++)
					{
						ref AnalyzeContactsJob reference = ref jobs[j];
						reference.Start = start;
						reference.ExclusiveEnd = reference.Start + ((j < num2) ? (num + 1) : num);
						start = reference.ExclusiveEnd;
					}
					analysisJobIndex = -1;
					threadDispatcher.DispatchWorkers(analyzeContactsWorker);
					pool.Return(ref jobs);
				}
			}
			for (int k = 0; k < contactCollectionWorkerCaches.Length; k++)
			{
				contactCollectionWorkerCaches[k].Dispose(pool);
			}
			pool.Return(ref contactCollectionWorkerCaches);
			if (!analyzeContactsWorkerCaches.Allocated)
			{
				return;
			}
			for (int l = 0; l < analyzeContactsWorkerCaches.Length; l++)
			{
				ref AnalyzeContactsWorkerCache reference2 = ref analyzeContactsWorkerCaches[l];
				for (int m = 0; m < reference2.ConstraintHandlesToRemove.Count; m++)
				{
					Simulation.Solver.Remove(reference2.ConstraintHandlesToRemove[m]);
				}
			}
			for (int n = 0; n < analyzeContactsWorkerCaches.Length; n++)
			{
				ref AnalyzeContactsWorkerCache reference3 = ref analyzeContactsWorkerCaches[n];
				for (int num3 = 0; num3 < reference3.StaticConstraintsToAdd.Count; num3++)
				{
					ref PendingStaticConstraint reference4 = ref reference3.StaticConstraintsToAdd[num3];
					ref CharacterControllerData reference5 = ref characters[reference4.characterIndex];
					reference5.MotionConstraintHandle = Simulation.Solver.Add(reference5.BodyHandle, ref reference4.description);
				}
				for (int num4 = 0; num4 < reference3.DynamicConstraintsToAdd.Count; num4++)
				{
					ref PendingDynamicConstraint reference6 = ref reference3.DynamicConstraintsToAdd[num4];
					ref CharacterControllerData reference7 = ref characters[reference6.characterIndex];
					reference7.MotionConstraintHandle = Simulation.Solver.Add(reference7.BodyHandle, reference7.Support.BodyHandle, ref reference6.description);
				}
				ref BodySet activeSet = ref Simulation.Bodies.ActiveSet;
				for (int num5 = 0; num5 < reference3.Jumps.Count; num5++)
				{
					ref Jump reference8 = ref reference3.Jumps[num5];
					activeSet.Velocities[reference8.characterBodyIndex].Linear += reference8.characterVelocityChange;
					if (reference8.supportBodyIndex >= 0)
					{
						BodyReference.ApplyImpulse(in Simulation.Bodies.ActiveSet, reference8.supportBodyIndex, reference8.characterVelocityChange / (0f - activeSet.LocalInertias[reference8.characterBodyIndex].InverseMass), in reference8.supportImpulseOffset);
					}
				}
				reference3.Dispose(pool);
			}
			pool.Return(ref analyzeContactsWorkerCaches);
		}

		public void EnsureCapacity(int characterCapacity)
		{
			characters.EnsureCapacity(characterCapacity, pool);
		}

		public void Resize(int characterCapacity)
		{
			int capacityForCount = BepuUtilities.Memory.BufferPool.GetCapacityForCount<int>(Math.Max(characters.Count, characterCapacity));
			if (capacityForCount != characters.Span.Length)
			{
				characters.Resize(capacityForCount, pool);
			}
		}

		/// <summary>
		/// Returns pool-allocated resources.
		/// </summary>
		public void Dispose()
		{
			if (!disposed)
			{
				GC.SuppressFinalize(this);
				disposed = true;
				Simulation.Timestepper.BeforeCollisionDetection -= PrepareForContacts;
				Simulation.Timestepper.CollisionsDetected -= AnalyzeContacts;
				characters.Dispose(pool);
				bodyHandleToCharacterIndex = null;
				pool = null;
			}
		}
