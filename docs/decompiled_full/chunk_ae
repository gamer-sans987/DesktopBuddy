		public void OnTouch(in TouchEventInfo eventInfo)
		{
			if (eventInfo.touch != EventState.Begin || eventInfo.type == TouchType.Physical || !CanTouchInteract(eventInfo.source))
			{
				return;
			}
			Slot source = eventInfo.source.Slot;
			StartTask(async delegate
			{
				ContextMenu contextMenu = await base.LocalUser.ToggleContextMenu(this, source);
				if (contextMenu != null)
				{
					GenerateMenuItems(contextMenu, null);
