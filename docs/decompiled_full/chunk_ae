						touchable = componentsInParent;
						point = current.Point;
						direction = Elements.Core.float3.Forward;
						directPoint = point;
						if (list2.Count > 0)
						{
							directPoint = list2[0].hit.Point;
							direction = list2[list2.Count - 1].exitDirection;
						}
						touch = pointerData.pointer.PrimaryPress.Held;
