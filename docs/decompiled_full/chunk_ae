		}

		public void RecalculateFacets()
		{
			Elements.Core.float2 actualCellSize = ActualCellSize;
			_ = Padding.Value;
			if (HasLastCalculatedData)
			{
				List<Elements.Core.IntRect> list = Pool.BorrowList<Elements.Core.IntRect>();
				GetCurrentRects(list, _lastCalculatedCellSize.Value.Value, _lastCalculatedCenteringOffset.Value.Value, _lastCalculatedPadding.Value.Value);
				int num = 0;
				foreach (Slot child in base.ContentRoot.Slot.Children)
				{
					RectTransform component = child.GetComponent<RectTransform>();
