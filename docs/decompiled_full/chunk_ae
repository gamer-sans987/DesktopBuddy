		public override ICollider Update()
		{
			Slot slot = base.Slot.ActiveUserRoot.Slot;
			if (slot.GlobalPosition.y < FallRespawnPosition.Value)
			{
				base.Slot.ActiveUserRoot.Spawn();
				CharacterController.LinearVelocity = Elements.Core.float3.Zero;
			}
			float value = AutoAlignVerticalWithGravitySpeed.Value;
			if (ThreeAxisActive)
			{
				if (base.ThreeAxisInput.Align.Held)
				{
					value = ManualAlignVerticalWithGravitySpeed.Value;
				}
				Turn.Update((Elements.Core.float3)base.ThreeAxisInput.TurnDelta);
			}
			else
			{
				Turn.Update(base.NormalInput.TurnDelta);
			}
			if (_waitingForInitialization)
			{
				bool flag = false;
				if (base.Time.LocalWorldTime > (double)MinInitializationDelay.Value)
				{
					flag = base.Physics.RaycastOne(CharacterController.GlobalBoundingBox.Center, CharacterController.Slot.Down, delegate(ICollider c)
					{
						if (!c.CharacterCollider)
						{
							return false;
						}
						return (InitializationColliderRoot.Target == null || c.Slot.IsChildOf(InitializationColliderRoot.Target, includeSelf: true)) ? true : false;
					}).HasValue;
				}
				if (!flag && !(base.Time.LocalWorldTime > (double)MaxInitializationDelay.Value))
				{
					CharacterController.ForceKinematic = true;
					return null;
				}
				_waitingForInitialization = false;
				CharacterController.ForceKinematic = false;
			}
			if (Gripping.Value != EnvironmentGripping.Disabled)
			{
				ILocomotionReference registeredComponent = base.Slot.ActiveUserRoot.GetRegisteredComponent((ILocomotionReference r) => r.Side == Chirality.Left);
				ILocomotionReference registeredComponent2 = base.Slot.ActiveUserRoot.GetRegisteredComponent((ILocomotionReference r) => r.Side == Chirality.Right);
				if (_currentGrip != null && !CheckKeepGrip(registeredComponent) && !CheckKeepGrip(registeredComponent2))
				{
					ClearGrip();
				}
				CheckAquireGrip(registeredComponent);
				CheckAquireGrip(registeredComponent2);
			}
			else
			{
				ClearGrip();
			}
			if (_currentGrip != null)
			{
				CharacterController.ForceKinematic = true;
				Elements.Core.float3 a = _currentGripReference.GlobalPosition;
				AdjustRotation(_currentGripReference.GlobalRotation, ref _lastHandRotation, slot, GripHandRotationMode, invert: true, HandGripRotationSmoothSpeed.Value);
				if (slot.Parent != _lastObjectRotationSpace)
				{
					if (_lastObjectRotationSpace == null || _lastObjectRotationSpace.IsDestroyed)
					{
						_lastObjectRotation = slot.Parent.GlobalRotationToLocal(_currentGrip.GlobalRotation);
					}
					else
					{
						_lastObjectRotation = slot.Parent.SpaceRotationToLocal(in _lastObjectRotation, _lastObjectRotationSpace);
					}
					_lastObjectRotationSpace = slot.Parent;
				}
				AdjustRotation(_currentGrip.GlobalRotation, ref _lastObjectRotation, slot.Parent, GripObjectRotationMode, invert: false, null);
				slot.GlobalPosition += a - _currentGripReference.GlobalPosition;
				Elements.Core.float3 b = _currentGrip.LocalPointToGlobal(in _currentGripPosition);
				Elements.Core.float3 v = _currentGripReference.GlobalPosition - b;
				_gripVelocity[_gripVelocityIndex] = v * base.Time.InvertedDelta;
				_gripVelocityIndex++;
				_gripVelocityIndex %= _gripVelocity.Length;
				slot.GlobalPosition -= v;
				if (base.Slot.ActiveUserRoot != null)
				{
					base.Slot.ActiveUserRoot.RootSpaceHint = _currentGrip;
				}
				_lastGripping = true;
			}
			else if (_lastGripping)
			{
				_lastGripping = false;
				CharacterController.ForceKinematic = false;
				Elements.Core.float3 v2 = MathX.Average(_gripVelocity);
				CharacterController.LinearVelocity = -v2 * GripVelocityMultiplier;
			}
			if (_lastGripping)
			{
				_lastGripTime = base.Time.WorldTime;
			}
			else
			{
				_currentGrippable = null;
			}
			Elements.Core.float3 v3 = base.Move.Value.Value;
			if (Mode.Value == MovementMode.GroundTraction)
			{
				v3 = v3.x_z.Normalized * v3.Magnitude;
			}
			v3 = MathX.ClampMagnitude(in v3, MaximumNormalizedSpeed.Value);
			_movementDelta = v3 * CharacterController.Speed.Value * base.Time.Delta;
			v3 = base.Slot.ActiveUserRoot.Slot.LocalDirectionToGlobal(in v3);
			v3 = base.Slot.ActiveUserRoot.HeadFacingRotation.Inverted * v3;
			CharacterController.MoveDirection = v3;
			CharacterController.Jump = base.Jump.Pressed || base.Jump.Held;
			if (AirDecelerationSpeed.Value > 0f && CharacterController.CurrentGround == null && CharacterController.Jump)
			{
				CharacterController.LinearVelocity = MathX.Lerp(CharacterController.LinearVelocity, Elements.Core.float3.Zero, AirDecelerationSpeed.Value * base.Time.Delta);
			}
			if (value > 0f)
			{
				Elements.Core.float3 a2 = CharacterController.ActualGravity;
				if (a2 == Elements.Core.float3.Zero)
				{
					a2 = Elements.Core.float3.Down;
				}
				if (!MathX.Approximately(MathX.Angle(CharacterController.ActualCharacterRoot.Down, in a2), 0f))
				{
					Elements.Core.floatQ a3 = Elements.Core.floatQ.FromToRotation(CharacterController.ActualCharacterRoot.Down, in a2);
					Elements.Core.float3 headPosition = base.Slot.ActiveUserRoot.HeadPosition;
					CharacterController.ActualCharacterRoot.GlobalRotation = MathX.Slerp(CharacterController.ActualCharacterRoot.GlobalRotation, a3 * CharacterController.ActualCharacterRoot.GlobalRotation, base.Time.Delta * value);
					base.Slot.ActiveUserRoot.HeadPosition = headPosition;
				}
			}
			if (_lastGrippable != _currentGrippable)
			{
				_lastGrippable?.OnGripEnd(this, _lastGrippingNode);
				_lastGrippable = _currentGrippable;
				_lastGrippingNode = _currentGrippingNode;
				_lastGrippable?.OnGripBegin(this, _lastGrippingNode);
			}
			else
			{
				_lastGrippable?.OnGripStay(this, _lastGrippingNode);
			}
			return CharacterController.CurrentGround;
		}

		private bool CheckKeepGrip(ILocomotionReference reference)
		{
			if (reference == null)
			{
				return false;
			}
			if (_currentGrip.IsDestroyed || !_currentGrip.IsActive)
			{
				return false;
			}
			if (_currentGrippingReference == reference && reference.LocomotionGrip.Held && (_currentGrippable == null || _currentGrippable.CanGrip(this)))
			{
				return true;
			}
			return false;
		}

		private void ClearGrip()
		{
			if (_currentGrip != null)
			{
				this.LocalGripEnd?.Invoke(_currentGrip, _currentGripReference.GlobalPosition, (_currentGrippingReference.Side != Chirality.Left) ? Chirality.Right : Chirality.Left);
			}
			if (base.Slot.ActiveUserRoot?.RootSpaceHint == _currentGrip)
			{
				base.Slot.ActiveUserRoot.RootSpaceHint = null;
			}
			_currentGrippingReference = null;
			_currentGrip = null;
			_currentGripReference = null;
		}

		private void CheckAquireGrip(ILocomotionReference reference)
		{
			if (reference == null || (!reference.LocomotionGrip.Pressed && (!GripOnHold || _currentGrip != null || !reference.LocomotionGrip.Held)))
			{
				return;
			}
			Slot slot = base.Slot.ActiveUserRoot.Slot;
			List<ICollider> list = Pool.BorrowList<ICollider>();
			Slot gripReference = reference.GripReference;
			base.Physics.SphereOverlap(gripReference.GlobalPosition, gripReference.LocalScaleToGlobal(GripRadius), list, CheckGripCollider);
			for (int i = 0; i < list.Count; i++)
			{
				ICollider collider = list[i];
				ILocomotionGrippable componentInParents = collider.Slot.GetComponentInParents<ILocomotionGrippable>();
				if (componentInParents == null || componentInParents.CanGrip(this))
				{
					ClearGrip();
					Array.Clear(_gripVelocity, 0, _gripVelocity.Length);
					_gripVelocityIndex = 0;
					_currentGrip = collider.Slot;
					_currentGrippable = componentInParents;
					_currentGripReference = gripReference;
					_currentGrippingReference = reference;
					_currentGripPosition = _currentGrip.GlobalPointToLocal(_currentGripReference.GlobalPosition);
					_currentGripRotation = _currentGrip.GlobalRotationToLocal(_currentGripReference.GlobalRotation);
					if (base.Slot.ActiveUserRoot != null)
					{
						base.Slot.ActiveUserRoot.RootSpaceHint = _currentGrip;
					}
					switch (reference.Side)
					{
					case Chirality.Left:
						_currentGrippingNode = BodyNode.LeftHand;
						break;
					case Chirality.Right:
						_currentGrippingNode = BodyNode.RightHand;
						break;
					default:
						_currentGrippingNode = BodyNode.NONE;
						break;
					}
					_lastHandRotation = slot.GlobalRotationToLocal(_currentGripReference.GlobalRotation);
					_lastObjectRotation = slot.Parent.GlobalRotationToLocal(_currentGrip.GlobalRotation);
					_lastObjectRotationSpace = slot.Parent;
					gripReference?.TryVibrateMedium();
					this.LocalGripBegin?.Invoke(_currentGrip, gripReference.GlobalPosition, reference.Side);
					break;
				}
			}
			Pool.Return(ref list);
		}

		private bool CheckGripCollider(ICollider c)
		{
			if (c.Slot.ActiveUserRoot == base.Slot.ActiveUserRoot)
			{
				return false;
			}
			return Gripping.Value switch
			{
				EnvironmentGripping.AnyObjects => true, 
				EnvironmentGripping.CharacterColliders => c.CharacterCollider, 
				EnvironmentGripping.GrippableObjects => c.Slot.GetComponentInParents<ILocomotionGrippable>() != null, 
				_ => false, 
			};
		}

