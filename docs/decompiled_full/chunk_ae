		[SyncMethod(typeof(Action), new string[] { })]
		public void SetFromPreciseBounds()
		{
			StartTask(SetFromPreciseBoundsAsync);
		}

		private async Task SetFromPreciseBoundsAsync()
		{
			await default(ToBackground);
			CylinderBounds cylinder = await ComputeExactCylinder(base.Slot, this).ConfigureAwait(continueOnCapturedContext: false);
			if (!(cylinder.radius < 0f))
			{
				await default(ToWorld);
				Offset.Value = cylinder.offset;
				Radius.Value = cylinder.radius;
				Height.Value = cylinder.height;
			}
		}

		public static async Task<CylinderBounds> ComputeExactCylinder(Slot slot, IBounded exclude)
		{
			await default(ToBackground);
			List<Elements.Core.float3> points = new List<Elements.Core.float3>();
			float minHeight = float.MaxValue;
			float maxHeight = float.MinValue;
			await slot.ForeachExactBoundedPoint(delegate(Elements.Core.float3 p)
			{
				points.Add(p.x_z);
				minHeight = MathX.Min(p.y, minHeight);
				maxHeight = MathX.Max(p.y, maxHeight);
			}, includeInactive: false, slot, (IBounded b) => b != exclude).ConfigureAwait(continueOnCapturedContext: false);
			Elements.Core.BoundingSphere boundingSphere = Elements.Core.BoundingSphere.RitterBoundingSphere(points);
			if (!boundingSphere.IsValid || minHeight > maxHeight)
			{
				return new CylinderBounds
				{
					radius = -1f,
					height = -1f
				};
			}
			return new CylinderBounds
			{
				offset = boundingSphere.Center + new Elements.Core.float3(0f, (minHeight + maxHeight) * 0.5f),
				radius = boundingSphere.Radius,
				height = maxHeight - minHeight
			};
		}

