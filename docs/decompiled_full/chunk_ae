		public static void CloseContextMenu(this User user, IWorldElement summoner)
		{
			ContextMenu userContextMenu = user.GetUserContextMenu();
			if (userContextMenu != null && (summoner == null || userContextMenu.CurrentSummoner == summoner))
			{
				userContextMenu.Close();
			}
		}
