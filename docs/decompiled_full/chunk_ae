					await model.LoadObjectAsync(gloveURL);
					model.SetIdentityTransform();
					BoxCollider box = model.AttachComponent<BoxCollider>();
					OverlayFresnelMaterial material = root.AttachComponent<OverlayFresnelMaterial>();
					material.BlendMode.Value = BlendMode.Additive;
					material.FrontNearColor.Value = Elements.Core.colorX.Black;
					material.FrontFarColor.Value = (new Elements.Core.colorX(1.25f, 1.1f, 0.8f) * 0.75f).SetA(1f);
					material.SetBehindColorFromFront((Elements.Core.colorX c) => (c * 0.5f).SetA(1f));
					material.Exponent.Value = 4f;
					root.ForeachComponentInChildren(delegate(MeshRenderer m)
					{
						m.ReplaceAllMaterials(material);
					});
					model.ForeachComponentInChildren(delegate(IAvatarObject o)
					{
						o.Destroy();
					}, includeLocal: false, cacheItems: true);
					model.ForeachComponentInChildren(delegate(IAvatarObjectComponent o)
					{
						o.Destroy();
					}, includeLocal: false, cacheItems: true);
					do
					{
						await default(NextUpdate);
						box.SetFromLocalBounds();
					}
					while (!box.IsRemoved && box.Size.Value == Elements.Core.float3.Zero);
					HandPoser componentInChildren = model.GetComponentInChildren<HandPoser>();
					_rootPos.Value = base.Slot.GlobalPointToLocal(componentInChildren.CurrentHandRoot.GlobalPosition);
				});
			}
			else
			{
				_activeVisual.Target?.Destroy();
			}
		}

