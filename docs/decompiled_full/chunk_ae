		{
			if (!left)
			{
				return base.RightLocomotionReference;
			}
			return base.LeftLocomotionReference;
		}

		private void TryActivate(GrabWorldInputs input, bool isLeft)
		{
			if ((bool)input.Grab)
			{
				usingLeft = isLeft;
				currentAnchor = base.LocalUserSpace.GlobalPointToLocal(GetLocomotionReference(isLeft).DirectionReference.GlobalPosition);
			}
		}

		private void CheckDeactivate(GrabWorldInputs input)
		{
			if (!input.Grab)
			{
				currentAnchor = null;
			}
		}

