			base.Input.RegisterInputGroup(_inputLeft, this);
			base.Input.RegisterInputGroup(_inputRight, this);
			activeLerp = 0f;
			Turn.Activate(controller);
		}

		public override void DeactivateModule()
		{
			base.DeactivateModule();
			base.Input.UnregisterInputGroup(ref _inputLeft);
			base.Input.UnregisterInputGroup(ref _inputRight);
			_visual.Target.ActiveSelf = false;
			Turn.Deactivate();
