		private void InputInterface_HapticPointsChanged()
		{
			RunSynchronously(delegate
			{
				if (base.IsUnderLocalUser)
				{
					RebuildMapping();
				}
			});
		}

		protected override void OnStart()
		{
			base.OnStart();
			UpdateLinking();
		}

		protected override void OnDispose()
		{
			base.Slot.ActiveUserRootChanged -= OnActiveUserRootChanged;
			base.InputInterface.HapticPointsChanged -= InputInterface_HapticPointsChanged;
			Unregister();
			base.OnDispose();
		}

		private void Unregister()
		{
			ClearMapping();
			if (_manager != null)
			{
				_manager.UnregisterMapper(this);
				_manager = null;
			}
		}

		private void UpdateLinking()
		{
			if (base.LocalUserRoot != null && base.IsUnderLocalUser)
			{
				HapticManager registeredComponent = base.LocalUserRoot.GetRegisteredComponent<HapticManager>();
				if (registeredComponent != _manager)
				{
					Unregister();
					_manager = registeredComponent;
					_manager.RegisterMapper(this);
				}
			}
			else
			{
				Unregister();
			}
		}

		private void OnActiveUserRootChanged(Slot slot)
		{
			RunSynchronously(UpdateLinking);
		}

