	public class ConeCollider : PrimitiveShapeCollider<ConvexHull>, IHighlightable, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		private const float RESIZE_THRESHOLD = 0.001f;

		private const float MAX_SIZE_RATIO = 0.001f;

		private const int CONVEX_HULL_POINTS = 32;

		private const float CONVEX_HULL_ANGLE_INCREMENT = MathF.PI / 16f;

		public readonly Sync<float> Height;

		public readonly Sync<float> Radius;

		public override bool HasBoundingBox => true;

		public override bool IsBoundingBoxAvailable => true;

		public override Elements.Core.BoundingBox LocalBoundingBox => Elements.Core.BoundingBox.CenterSize(base.LocalBoundsOffset, new Elements.Core.float3((float)Radius * 2f, Height, (float)Radius * 2f));

		public override Elements.Core.BoundingBox GlobalBoundingBox => LocalBoundingBox.Transform(base.Slot.LocalToGlobal);

		protected override bool ShapeChanged
		{
			get
			{
				if (!Height.WasChanged)
				{
					return Radius.WasChanged;
				}
				return true;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			Height.Value = 1f;
			Radius.Value = 0.5f;
		}

		public override Task<Elements.Core.BoundingBox> ComputeExactBounds(Slot space)
		{
			return Task.FromResult(LocalBoundingBox.Transform(base.Slot.GetLocalToSpaceMatrix(space)));
		}

		public override Task ForeachExactBoundedPoint(Slot space, Action<Elements.Core.float3> action)
		{
			float num = (float)Height * 0.5f;
			for (float num2 = 0f; num2 < 1f; num2 += 1f / 128f)
			{
				for (float num3 = 0f; num3 < 1f; num3 += 1f / 128f)
				{
					Elements.Core.float2 @float = MathX.PointOnCircle(num3) * ((float)Radius * (1f - num2));
					Elements.Core.float3 localPoint = new Elements.Core.float3(@float.x, num2 * (float)Height - num, @float.y) + (Elements.Core.float3)Offset;
					localPoint = base.Slot.LocalPointToSpace(in localPoint, space);
					action(localPoint);
				}
			}
			return Task.CompletedTask;
		}

		public Slot GenerateHighlight(Slot root, IAssetProvider<Material> highlightMaterial, bool trackPosition = true)
		{
			Slot slot = root.AddSlot(base.Slot.Name);
			if (trackPosition)
			{
				slot.SetupCopyTransform(base.Slot);
			}
			else
			{
				slot.CopyTransform(base.Slot);
			}
			Slot slot2 = slot.AddSlot("Offset");
			ConeMesh coneMesh = slot2.AttachMesh<ConeMesh>(highlightMaterial);
			coneMesh.RadiusBase.DriveFrom(Radius);
			coneMesh.Height.DriveFrom(Height);
			slot2.Position_Field.DriveFrom(Offset);
			return slot;
		}

		protected override ConvexHull CreateShape(PhysicsSimulation simulation, ref Elements.Core.float3 offset, ref float speculativeMargin, float? mass, out BodyInertia inertia)
		{
			Elements.Core.float3 size = new Elements.Core.float3(Radius.Value, Height.Value, Radius.Value);
			ProcessColliderSize(ref size);
			float num = size.y * 0.5f;
			float num2 = (size.x + size.z) * 0.5f;
			speculativeMargin = MathX.Min(speculativeMargin, num, num2);
			if (num > num2)
			{
				num2 = MathX.Max(0.001f * num, num2);
			}
			else
			{
				num = MathX.Max(0.001f * num2, num);
			}
			float num3 = MathX.Min(num, num2);
			float num4 = 1f;
			if (num3 < 0.001f)
			{
				num4 = 0.001f / num3;
				num *= num4;
				num2 *= num4;
			}
			Span<System.Numerics.Vector3> points = stackalloc System.Numerics.Vector3[33];
			points[0] = new System.Numerics.Vector3(0f, num, 0f);
			for (int i = 0; i < 32; i++)
			{
				float num5 = (float)i * (MathF.PI / 16f);
				points[i + 1] = new System.Numerics.Vector3(MathX.Sin(num5) * num2, 0f - num, MathX.Cos(num5) * num2);
			}
			System.Numerics.Vector3 center;
			ConvexHull source = new ConvexHull(points, simulation.BufferPool, out center);
			if (num4 != 1f)
			{
				BepuUtilities.Matrix3x3.CreateScale(System.Numerics.Vector3.One * (1f / num4), out var linearTransform);
				BepuPhysics.Collidables.ConvexHullHelper.CreateTransformedShallowCopy(in source, in linearTransform, simulation.BufferPool, out var target);
				simulation.BufferPool.Return(ref source.Points);
				simulation.BufferPool.Return(ref source.BoundingPlanes);
				source = target;
