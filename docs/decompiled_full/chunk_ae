	public abstract class PhysicsSimulation : IDisposable
	{
		public const float MIN_SIZE = 1E-06f;

		public const float MAX_SIZE = 1000000f;

		public const float MAX_BOUNDS_SIZE = 1E+10f;

		public const float MAX_OFFSET = 1000000f;

		public const float MAX_DELTA = 0.05f;

		public const float DELTA_INTERPOLATION_SPEED = 0.025f;

		public const float MAX_DELTA_DELTA = 0.005f;

		private const int INITIAL_CAPACITY = 128;

		public int TotalMovedStatics;

		public int TotalMovedBodies;

		private Exception _refineException;

		private int _countMovedStatics;

		private int _countMovedBodies;

		private int _frameIndex;

		private float _lastDelta;

		private ICollider[] _staticColliders;

		private ICollider[] _bodyColliders;

		protected CollidableProperty<CollisionMask> _contactMask;

		protected CollidableProperty<CollisionMask> _responseMask;

		public World World { get; private set; }

		internal Simulation Simulation { get; private set; }

		internal BepuUtilities.Memory.BufferPool BufferPool { get; private set; }

		internal IThreadDispatcher ThreadDispatcher { get; private set; }

		internal ContactEventManager ContactEventManager { get; private set; }

		internal AutoResetEvent OnTimestepDone { get; set; }

		internal AutoResetEvent OnRefineDone { get; set; }

		public event Action PreContactDispatch;

		internal void MovedStatic()
		{
			_countMovedStatics++;
		}

		internal void MovedBody()
		{
			_countMovedBodies++;
		}

		public PhysicsSimulation(World world)
		{
			World = world;
		}

		internal void Initialize(IThreadDispatcher threadDispatcher)
		{
			_staticColliders = new ICollider[128];
			_bodyColliders = new ICollider[128];
			ThreadDispatcher = threadDispatcher;
			BufferPool = new BepuUtilities.Memory.BufferPool();
			OnRefineDone = new AutoResetEvent(initialState: true);
			_contactMask = new CollidableProperty<CollisionMask>(BufferPool);
			_responseMask = new CollidableProperty<CollisionMask>(BufferPool);
			ContactEventManager = new ContactEventManager(this);
			Simulation = CreateSimulation();
			_contactMask.Initialize(Simulation);
			_responseMask.Initialize(Simulation);
			ContactEventManager.Initialize();
		}

		protected abstract Simulation CreateSimulation();

		internal void Refine()
		{
			try
			{
				Simulation.BroadPhase.StaticTree.RefitAndRefine(BufferPool, _frameIndex++);
				if (_frameIndex == int.MaxValue)
				{
					_frameIndex = 0;
				}
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception when running refine on {GetType()}\n{ex}");
				_refineException = ex;
			}
			OnRefineDone.Set();
		}

		internal void Sync()
		{
			OnRefineDone.WaitOne();
			if (_refineException != null)
			{
				throw _refineException;
			}
		}

		internal void RunTimestep()
		{
			try
			{
				TotalMovedStatics = _countMovedStatics;
				TotalMovedBodies = _countMovedBodies;
				_countMovedBodies = 0;
				_countMovedStatics = 0;
				float num = MathX.Min(World.Time.Delta, 0.05f);
				float num2;
				if (_lastDelta == 0f)
				{
					num2 = num;
				}
				else
				{
					num2 = MathX.Lerp(_lastDelta, num, 0.025f);
					num2 = MathX.Clamp(num2, _lastDelta - 0.005f, _lastDelta + 0.005f);
				}
				Simulation.Timestep(num2, ThreadDispatcher);
				_lastDelta = num2;
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception updating {GetType().Name} in World {World?.RawName}\n" + ex);
				throw;
			}
			finally
			{
				OnTimestepDone?.Set();
			}
		}

		internal void FinishUpdate()
		{
			try
			{
				this.PreContactDispatch?.Invoke();
				Simulation.Profiler.Start(ContactEventManager);
				ContactEventManager.DispatchEvents();
				Simulation.Profiler.End(ContactEventManager);
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception updating {GetType().Name} in World {World?.RawName}\n" + ex);
				throw;
			}
		}

