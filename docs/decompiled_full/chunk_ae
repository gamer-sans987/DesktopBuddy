	[DefaultUpdateOrder(-1000000)]
	public class LocomotionController : UserRootComponent
	{
		public const string LOCOMOTION_SETTING_BASE = "Input.LocomotionMode";

		public const string LOCOMOTION_MODULE = "Input.LocomotionMode.LastModule";

		public const string LOCOMOTION_MODULE_PREV = "Input.LocomotionMode.PreviousModule";

		public const string LEGACY_PRIMARY_LOCOMOTION_CONTROLLER = "Input.PrimaryLocomotionController";

		public readonly Sync<bool> ScalingEnabled;

		public readonly SyncRefList<Component> SupressSources;

		public readonly SyncRefList<Component> InputSupressSources;

		public readonly SyncRefList<ILocomotionModule> LocomotionModules;

		public readonly Sync<int> ActiveModuleIndex;

		[OldName("SyncActiveLocomotionModule")]
		public readonly Sync<bool> FindUserPreferredModule;

		protected readonly SyncRef<ICollider> _currentGroundCollider;

		protected readonly SyncRef<ICollider> _lastGroundCollider;

		public readonly SyncDelegate<Action<LocomotionController>> OnInitialized;

		protected readonly SyncRefList<Slot> _parentHierarchy;

		protected readonly SyncRef<CharacterController> _dummyCharacterController;

		private ILocomotionModule _lastActiveModule;

		private GeneralLocomotionInputs _inputs;

		public ILocomotionModule ActiveModule
		{
			get
			{
				if (LocomotionModules.Count == 0)
				{
					return null;
				}
				if (ActiveModuleIndex.Value < 0)
				{
					return null;
				}
				return LocomotionModules[ActiveModuleIndex.Value % LocomotionModules.Count];
			}
			set
			{
				if (value == null)
				{
					ActiveModuleIndex.Value = -1;
					return;
				}
				int num = LocomotionModules.IndexOf(value);
				if (num < 0)
				{
					UniLog.Warning("Assigned Active Module isn't in the list of LocomotionModules, adding.", stackTrace: true);
					LocomotionModules.Add(value);
					ActiveModuleIndex.Value = LocomotionModules.Count - 1;
				}
				else
				{
					ActiveModuleIndex.Value = num;
				}
				ValidateLocomotionMode();
			}
		}

		public bool CanScale
		{
			get
			{
				ILocomotionModule lastActiveModule = LastActiveModule;
				if (lastActiveModule != null && lastActiveModule.CanScale)
				{
					return !IsInputSupressed;
				}
				return false;
			}
		}

		public bool CanCrouch
		{
			get
			{
				ILocomotionModule lastActiveModule = LastActiveModule;
				if (lastActiveModule != null && lastActiveModule.CanCrouch)
				{
					return !IsInputSupressed;
				}
				return false;
			}
		}

		public Elements.Core.float3 MovementDelta => LastActiveModule?.MovementDelta ?? Elements.Core.float3.Zero;

		public bool IsSupressed => SupressSources.Count > 0;

		public bool IsInputSupressed => InputSupressSources.Count > 0;

		public Slot LocomotionModulesRoot => base.Slot.FindChildOrAdd("Locomotion Modules");

		public bool IsOnGround => _currentGroundCollider.Target != null;

		public LocomotionState LocomotionState
		{
			get
			{
				if (IsOnGround)
				{
					return LocomotionState.OnGround;
				}
				ILocomotionModule activeModule = ActiveModule;
				if (activeModule == null)
				{
					return LocomotionState.Floating;
				}
				switch (activeModule.LocomotionArchetype)
				{
				case LocomotionArchetype.Teleport:
				case LocomotionArchetype.NoClip:
				case LocomotionArchetype.Fly:
				case LocomotionArchetype.ThreeAxisNoClip:
				case LocomotionArchetype.ThreeAxisFly:
				case LocomotionArchetype.ZeroG:
				case LocomotionArchetype.GrabWorld:
				case LocomotionArchetype.NoLocomotion:
					return LocomotionState.Floating;
				case LocomotionArchetype.Walk:
					return LocomotionState.InAir;
				default:
					return LocomotionState.Floating;
				}
			}
		}

		public ICollider CurrentGroundCollider => _currentGroundCollider.Target;

		public ICollider LastGroundCollider => _lastGroundCollider.Target;

		private ILocomotionModule LastActiveModule
		{
			get
			{
				if (_lastActiveModule == null || _lastActiveModule.IsDestroyed)
				{
					return null;
				}
				return _lastActiveModule;
			}
		}

		public bool CanUseCurrentModule => CanUseModule(ActiveModule);

		public ILocomotionModule TryFindModule(Predicate<ILocomotionModule> filter)
		{
			return LocomotionModules.FirstOrDefault((ILocomotionModule m) => m != null && filter(m));
		}

		protected override void OnStart()
		{
			base.OnStart();
			if (base.IsUnderLocalUser)
			{
				_inputs = new GeneralLocomotionInputs();
				base.Input.RegisterInputGroup(_inputs, this);
				if (FindUserPreferredModule.Value)
				{
					StartTask(ActivatePreferredModule);
				}
			}
		}

		private async Task ActivatePreferredModule()
		{
			LocomotionSettings locomotionSettings = await Settings.GetActiveSettingAsync<LocomotionSettings>();
			HashSet<LocomotionArchetype> hashSet = Pool.BorrowHashSet<LocomotionArchetype>();
			foreach (ILocomotionModule locomotionModule2 in LocomotionModules)
			{
				if (locomotionModule2.LocomotionArchetype.HasValue)
				{
					hashSet.Add(locomotionModule2.LocomotionArchetype.Value);
				}
			}
			LocomotionArchetype? preferredArchetype = locomotionSettings.GetPreferredArchetype(hashSet);
			Pool.Return(ref hashSet);
			if (preferredArchetype.HasValue)
			{
				ILocomotionModule locomotionModule = TryFindModule((ILocomotionModule m) => m.LocomotionArchetype == preferredArchetype);
				if (locomotionModule != null)
				{
					ActiveModule = locomotionModule;
				}
			}
		}

		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			if (!base.IsUnderLocalUser || base.LocalUserRoot == null)
			{
				return;
			}
			if (_dummyCharacterController.Target == null)
			{
				CharacterController characterController = (_dummyCharacterController.Target = base.Slot.GetComponentOrAttach<CharacterController>());
				CharacterController characterController2 = characterController;
				characterController2.CharacterRoot.Target = base.Slot.ActiveUserRoot.Slot;
				characterController2.HeadReference.Target = characterController2.Slot.ActiveUserRoot.HeadSlot;
			}
			OnInitialized.Target?.Invoke(this);
			OnInitialized.Target = null;
			if (LocomotionModules.Count > 1)
			{
				if (_inputs.NextModule.Pressed)
				{
					ActiveModuleIndex.Value = MathX.Repeat(ActiveModuleIndex.Value + 1, LocomotionModules.Count);
				}
				if (_inputs.PreviousModule.Pressed)
				{
					ActiveModuleIndex.Value = MathX.Repeat(ActiveModuleIndex.Value - 1, LocomotionModules.Count);
				}
			}
			if (CanScale && ScalingEnabled.Value)
			{
				Analog value = _inputs.SelfScaleDelta.Value;
				AdjustGlobalScale(value);
			}
			SupressSources.RemoveAll(null);
			InputSupressSources.RemoveAll(null);
			ILocomotionModule locomotionModule = (IsSupressed ? null : ActiveModule);
			locomotionModule?.SetInputsActive(!IsInputSupressed);
			if (_lastActiveModule != locomotionModule)
			{
				if (locomotionModule == null)
				{
					_dummyCharacterController.Target.Enabled = true;
					_dummyCharacterController.Target.SimulatingUser.Target = base.LocalUser;
				}
				else
				{
					_dummyCharacterController.Target.Enabled = false;
					_dummyCharacterController.Target.SimulatingUser.Target = null;
				}
				ILocomotionModule lastActiveModule = _lastActiveModule;
				if (lastActiveModule != null && lastActiveModule.IsDestroyed)
				{
					_lastActiveModule = null;
				}
				_lastActiveModule?.DeactivateModule();
				locomotionModule?.ActivateModule(this, _lastActiveModule);
				_lastActiveModule = locomotionModule;
			}
			if (locomotionModule != null)
			{
				ICollider collider = locomotionModule.Update();
				if (collider != _currentGroundCollider.Target)
				{
					_currentGroundCollider.Target = collider;
					if (collider != null)
					{
						_lastGroundCollider.Target = collider;
					}
				}
			}
			else
			{
				_dummyCharacterController.Target.ForceKinematic = true;
			}
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (!base.IsUnderLocalUser && base.World.Focus == FrooxEngine.World.WorldFocus.Focused)
			{
				ValidateLocomotionMode();
			}
		}

		public override void OnFocusChanged(World.WorldFocus focus)
		{
			if (focus == FrooxEngine.World.WorldFocus.Focused && base.IsUnderLocalUser)
			{
				ValidateLocomotionMode();
			}
		}

		public void NextLocomotionModule()
		{
			if (ActiveModuleIndex.Value < 0)
			{
				ActiveModuleIndex.Value = 0;
			}
			else
			{
				ActiveModuleIndex.Value++;
			}
			ValidateLocomotionMode();
		}

		public void ValidateLocomotionMode()
		{
			ILocomotionModule activeModule = ActiveModule;
			while (!CanUseCurrentModule)
			{
				ActiveModuleIndex.Value++;
				if (ActiveModule == activeModule)
				{
					ActiveModule = null;
					break;
				}
			}
		}

		public bool CanUseModule(ILocomotionModule module)
		{
			User user = base.Slot.ActiveUser;
			return base.Permissions.Check(this, (LocomotionPermissions p) => p.CanUseLocomotion(module, user), user);
		}

		public void NestIntoSpace(Slot space)
		{
			if (base.Slot.Parent != space && !_parentHierarchy.Contains(space))
			{
				_parentHierarchy.Add(base.Slot.Parent);
				base.Slot.Parent = space;
			}
		}

		public void PopOutOfSpace(Slot space)
		{
			if (base.Slot.Parent == space)
			{
				Slot parent = null;
				if (_parentHierarchy.Count > 0)
				{
					parent = _parentHierarchy[_parentHierarchy.Count - 1];
					_parentHierarchy.RemoveAt(_parentHierarchy.Count - 1);
				}
				base.Slot.Parent = parent;
			}
			else
			{
				_parentHierarchy.RemoveAll(space);
			}
		}

		public void ClearParentHierarchy()
		{
			_parentHierarchy.Clear();
		}

		public void AdjustGlobalScale(float delta)
		{
			if (delta != 0f)
			{
				float globalScale = base.World.LocalUser.Root.GlobalScale;
				SetGlobalScale(globalScale * (1f + delta));
			}
		}

		public void SetGlobalScale(float newScale)
		{
			newScale = MathX.Clamp(newScale, 1E-06f, 1E+16f);
			UserRoot root = base.World.LocalUser.Root;
			Elements.Core.float3 feetPosition = root.FeetPosition;
			List<LocomotionPermissions> list = Pool.BorrowList<LocomotionPermissions>();
			base.Permissions.GetValidators(this, list, base.Slot.ActiveUser);
			foreach (LocomotionPermissions item in list)
			{
