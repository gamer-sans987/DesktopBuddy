		public override void SetInputsActive(bool active)
		{
			if (_inputLeft != null)
			{
				_inputLeft.Active = active;
			}
			if (_inputRight != null)
			{
				_inputRight.Active = active;
			}
		}

		public override ICollider Update()
		{
			if (currentAnchor.HasValue)
			{
				CheckDeactivate(usingLeft ? _inputLeft : _inputRight);
			}
			if (!currentAnchor.HasValue)
			{
				TryActivate(_inputLeft, isLeft: true);
			}
			if (!currentAnchor.HasValue)
			{
				TryActivate(_inputRight, isLeft: false);
			}
			Turn.Update((float)_inputLeft.TurnDelta + (float)_inputRight.TurnDelta);
			_movementDelta = Elements.Core.float3.Zero;
			if (currentAnchor.HasValue)
			{
				ILocomotionReference locomotionReference = GetLocomotionReference(usingLeft);
				_visual.Target.GlobalPosition = locomotionReference.GripReference.GlobalPosition;
				Elements.Core.float3 b = base.LocalUserSpace.GlobalPointToLocal(locomotionReference.GripReference.GlobalPosition);
				Elements.Core.float3 b2 = currentAnchor.Value - b;
				Slot slot = base.LocalUserRoot.Slot;
				slot.LocalPosition += b2;
				_movementDelta = b2;
			}
			activeLerp = MathX.Progress01(activeLerp, base.Time.Delta * 5f, currentAnchor.HasValue);
			_crossMesh.Target.Size.Value = 0.1f;
			_crossMesh.Target.BarSize = activeLerp * 0.002f;
			_visual.Target.ActiveSelf = activeLerp > 0f;
			return null;
		}

