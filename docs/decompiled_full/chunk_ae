			{
				d.Vibrate(time);
			});
		}

		private double GetValueSafe(Func<IVibrationDeviceComponent, double> getter)
		{
			IVibrationDeviceComponent target = GetTarget();
			if (_accessingTarget || target == null)
			{
				return 0.0;
			}
			try
			{
				_accessingTarget = true;
				return getter(target);
			}
			finally
			{
				_accessingTarget = false;
			}
		}

		private void PerformSafe(Action<IVibrationDeviceComponent> action)
		{
			IVibrationDeviceComponent target = GetTarget();
			if (_accessingTarget || target == null)
			{
				return;
			}
			try
			{
				_accessingTarget = true;
				action(target);
			}
			finally
			{
				_accessingTarget = false;
			}
		}

		private IVibrationDeviceComponent GetTarget()
		{
			if (TargetComponent.Target != null)
			{
				return TargetComponent.Target;
			}
			if (DynamicLookupTarget.Target != null)
