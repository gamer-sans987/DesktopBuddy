		{
			UpdateTask();
			Update();
		}

		private async Task UpdateTask(CancellationToken cancellationToken)
		{
			await default(ToWorld);
			while (!cancellationToken.IsCancellationRequested)
			{
				RunInUpdateScope(Update);
				await default(NextUpdate);
			}
		}

