			if (!RecalculateOnSizeChange.Value)
			{
				return;
			}
			if (_lastCalculatedCellSize.Value.HasValue && MathX.Approximately(ActualCellSize, _lastCalculatedCellSize.Value.Value) && _lastCalculatedCenteringOffset.Value.HasValue && MathX.Approximately(CenteringOffset, _lastCalculatedCenteringOffset.Value.Value))
			{
				Elements.Core.float2? value = _lastCalculatedPadding.Value;
				Elements.Core.float2 b = Padding.Value;
				if (value.HasValue && !(value.GetValueOrDefault() != b))
