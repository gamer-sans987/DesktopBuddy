		protected override void OnCommonUpdate()
		{
			AudioClip asset = AudioClip.Asset;
			if (_lastClip != asset)
			{
				_lastPlaybackState = PlaybackState.Unknown;
				if (AudioClip.Target != null && !AudioClip.Target.IsAssetAvailable)
				{
					return;
				}
				_clipPlayer.Target.Clip.Target = AudioClip.Target;
				if (_clipLengthTimeText.IsLinkValid)
				{
					_clipLengthTimeText.Target.Value = ((asset == null) ? "---" : FormatTime(asset.Data?.Duration ?? 0.0));
				}
				if (_waveformMaterial.Target != null)
				{
					_waveformMaterial.Target.Texture.Target = AudioClip.Target.GetWaveformTexture(WAVEFORM_COLOR, BACKGROUND_COLOR);
				}
				_lastClip = AudioClip.Asset;
			}
			if (_clipPlayer.Target == null || _audioOutput.Target == null)
			{
				return;
			}
			if (_playbackTimeText.Target != null)
			{
				if (asset == null)
				{
					_playbackTimeText.Target.Value = "";
					_lastPlaybackTime = null;
				}
				else
				{
					int num = (int)_clipPlayer.Target.Position;
					if (num != _lastPlaybackTime)
					{
						_playbackTimeText.Target.Value = FormatTime(_clipPlayer.Target.Position);
						_lastPlaybackTime = num;
					}
				}
			}
			else
			{
				_lastPlaybackTime = null;
			}
			if (_playbackRingArc.Target != null)
			{
				_playbackRingArc.Target.Value = 5.969026f * _clipPlayer.Target.NormalizedPosition * 57.29578f;
			}
			if (_volumeRingArc.Target != null)
			{
				_volumeRingArc.Target.Value = MathX.Pow(_audioOutput.Target.Volume, 1f / VOLUME_POWER) * 57.29578f * (MathF.PI / 2f);
			}
			PlaybackState playbackState = GetPlaybackState();
			if (playbackState != _lastPlaybackState)
			{
				if (_iconTextureURL.Target != null)
				{
					_iconTextureURL.Target.Value = GetIcon(playbackState);
				}
				_lastPlaybackState = playbackState;
			}
			if (_lastLoopState != _clipPlayer.Target.Loop)
			{
				if (_loopIconURL.Target != null)
				{
					_loopIconURL.Target.Value = (_clipPlayer.Target.Loop ? OfficialAssets.Common.Icons.Reload : OfficialAssets.Common.Icons.Right_Arrow);
				}
				_lastLoopState = _clipPlayer.Target.Loop;
			}
			bool value = _audioOutput.Target.Spatialize.Value;
			if (value != _lastSpatialState)
			{
				if (_spatialIconURL.Target != null)
				{
					_spatialIconURL.Target.Value = (value ? OfficialAssets.Common.Icons.Audio : OfficialAssets.Common.Icons.Broadcast);
				}
				_lastSpatialState = value;
			}
		}

