	{
		public static float? CombineInputs(float? primary, float? secondary, DualInputHandling handling)
		{
			if (!primary.HasValue)
			{
				return null;
			}
			if (!secondary.HasValue)
			{
				return primary.Value;
			}
			switch (handling)
			{
			case DualInputHandling.PrimaryOnly:
				return primary.Value;
			case DualInputHandling.Maximum:
				if (primary.Value > secondary.Value)
				{
					return primary.Value;
				}
				return secondary.Value;
			case DualInputHandling.Average:
				return (primary.Value + secondary.Value) * 0.5f;
			case DualInputHandling.Sum:
				return primary.Value + secondary.Value;
			default:
				throw new Exception("Invalid DualInputHandling: " + handling);
