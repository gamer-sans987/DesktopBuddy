	public class SimpleThreadDispatcher : IThreadDispatcher, IDisposable
	{
		private struct Worker
		{
			public Thread Thread;

			public AutoResetEvent Signal;
		}

		private int threadCount;

		private Worker[] workers;

		private AutoResetEvent finished;

		private BepuUtilities.Memory.BufferPool[] bufferPools;

		private volatile Action<int> workerBody;

		private int workerIndex;

		private int completedWorkerCounter;

		private volatile bool disposed;

		public int ThreadCount => threadCount;

		public SimpleThreadDispatcher(int threadCount)
		{
			this.threadCount = threadCount;
			workers = new Worker[threadCount - 1];
			for (int i = 0; i < workers.Length; i++)
			{
				workers[i] = new Worker
				{
					Thread = new Thread(WorkerLoop),
					Signal = new AutoResetEvent(initialState: false)
				};
				workers[i].Thread.IsBackground = true;
				workers[i].Thread.Start(workers[i].Signal);
			}
			finished = new AutoResetEvent(initialState: false);
			bufferPools = new BepuUtilities.Memory.BufferPool[threadCount];
			for (int j = 0; j < bufferPools.Length; j++)
			{
				bufferPools[j] = new BepuUtilities.Memory.BufferPool();
			}
		}

		private void DispatchThread(int workerIndex)
		{
			workerBody(workerIndex);
			if (Interlocked.Increment(ref completedWorkerCounter) == threadCount)
			{
				finished.Set();
			}
		}

		private void WorkerLoop(object untypedSignal)
		{
			AutoResetEvent autoResetEvent = (AutoResetEvent)untypedSignal;
			while (true)
			{
				autoResetEvent.WaitOne();
				if (disposed)
				{
					break;
				}
				DispatchThread(Interlocked.Increment(ref workerIndex) - 1);
			}
		}

		private void SignalThreads()
		{
			for (int i = 0; i < workers.Length; i++)
			{
				workers[i].Signal.Set();
			}
		}

		public void DispatchWorkers(Action<int> workerBody)
		{
			workerIndex = 1;
			completedWorkerCounter = 0;
			this.workerBody = workerBody;
			SignalThreads();
			DispatchThread(0);
			finished.WaitOne();
			this.workerBody = null;
		}

		public void Dispose()
		{
			if (!disposed)
			{
				disposed = true;
				SignalThreads();
				for (int i = 0; i < bufferPools.Length; i++)
				{
					bufferPools[i].Clear();
				}
				Worker[] array = workers;
				for (int j = 0; j < array.Length; j++)
				{
					Worker worker = array[j];
					worker.Thread.Join();
					worker.Signal.Dispose();
				}
				finished.Dispose();
			}
		}

		public BepuUtilities.Memory.BufferPool GetThreadMemoryPool(int workerIndex)
		{
			return bufferPools[workerIndex];
		}
	}
