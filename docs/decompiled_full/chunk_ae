		{
			UpdateTask();
		}

		private void UpdateTask()
		{
			if (base.Slot.ActiveUserRoot != null)
			{
				if (UseUserHeadHeightWhenAvailable.Value && _headUpdateCancellation == null)
				{
					_headUpdateCancellation = new CancellationTokenSource();
					StartTask(UpdateTask, _headUpdateCancellation.Token);
				}
			}
			else if (_headUpdateCancellation != null)
			{
				_headUpdateCancellation.Cancel();
				_headUpdateCancellation = null;
			}
		}

		private void Update()
		{
			float num = DefaultHeight.Value;
			float num2 = DefaultWidth.Value;
			UserRoot activeUserRoot = base.Slot.ActiveUserRoot;
			if (UseUserHeadHeightWhenAvailable.Value && activeUserRoot != null)
			{
				float y = activeUserRoot.LocalHeadPosition.y;
				num = y + HeadHeightOffset.Value;
				float lerp = MathX.InverseLerp(CrouchStart, CrouchEnd, y);
				num2 = MathX.Lerp(DefaultWidth, CrouchTargetWidth, lerp);
			}
			if (TargetHeight.IsLinkValid)
			{
				TargetHeight.Target.Value = num;
			}
			if (TargetWidth.IsLinkValid)
			{
				TargetWidth.Target.Value = num2;
			}
			if (TargetOffset.IsLinkValid)
			{
				TargetOffset.Target.Value = (RootAtBottom.Value ? new Elements.Core.float3(0f, MathX.Max(num * 0.5f, num2)) : Elements.Core.float3.Zero);
			}
		}

