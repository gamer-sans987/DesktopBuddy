		{
			Elements.Core.float3 a = Elements.Core.float3.Zero;
			int num = 0;
			for (FingerType fingerType = FingerType.Thumb; fingerType < (FingerType)5; fingerType++)
			{
				if (fingerType != FingerType.Thumb)
				{
					HandPoser.Finger finger = handPoser[fingerType];
					if (finger.Proximal.Root.Target != null)
					{
						a += finger.Proximal.Root.Target.GlobalPosition;
						num++;
					}
				}
			}
			return a / num;
		}

		public static void AutoUpgradeTool(ITool tooltip)
		{
			((Component)tooltip).StartTask(async delegate
			{
				int frames = 0;
				while (!tooltip.Slot.ForeachComponentInChildren((IBounded b) => !b.Enabled || !(b is MeshRenderer) || b.IsBoundingBoxAvailable) && frames < 90)
				{
					frames++;
					await default(NextUpdate);
				}
				GripPoseReference left = tooltip.Slot.AddSlot("Left Grip Pose").AttachComponent<GripPoseReference>();
				GripPoseReference right = tooltip.Slot.AddSlot("Right Grip Pose").AttachComponent<GripPoseReference>();
				left.HandSide.Value = Chirality.Left;
				right.HandSide.Value = Chirality.Right;
				Transform transform = await ComputeHeuristicReferencePose(tooltip, Chirality.Left);
				left.Slot.LocalPosition = transform.position;
				left.Slot.LocalRotation = transform.rotation;
				left.Slot.LocalScale = transform.scale;
				transform = await ComputeHeuristicReferencePose(tooltip, Chirality.Right);
				right.Slot.LocalPosition = transform.position;
				right.Slot.LocalRotation = transform.rotation;
				right.Slot.LocalScale = transform.scale;
				if (!(tooltip is RawDataTool))
				{
					left.TipReference.Target = left.Slot.AddSlot("Tip");
					right.TipReference.Target = right.Slot.AddSlot("Tip");
					left.TipReference.Target.CopyTransform(tooltip.Slot);
					right.TipReference.Target.CopyTransform(tooltip.Slot);
				}
			});
		}

		private static async Task<Transform> ComputeHeuristicReferencePose(ITool tooltip, Chirality side)
		{
			Slot root = tooltip.Slot;
			float maxSize = root.LocalScaleToGlobal(1f);
			Elements.Core.BoundingBox bounds = root.ComputeBoundingBox(includeInactive: false, root, (IBounded bounded) => bounded is MeshRenderer && bounded.Enabled && MathX.MaxComponent(bounded.GlobalBoundingBox.Size) < maxSize && bounded.Slot.IsActive);
			Elements.Core.float3 forward = Elements.Core.float3.Forward;
			Elements.Core.float3 tip = Elements.Core.float3.Zero;
			Elements.Core.Ray? ray = await ComputeHeuristicsTip(tooltip);
			if (ray.HasValue)
			{
				forward = ray.Value.direction;
				tip = ray.Value.origin;
				forward = root.GlobalDirectionToLocal(in forward);
			}
			else
			{
				maxSize *= 3f;
				Elements.Core.BoundingBox boundingBox = root.ComputeBoundingBox(includeInactive: false, root, (IBounded bounded) => bounded is MeshRenderer && bounded.Enabled && MathX.MaxComponent(bounded.GlobalBoundingBox.Size) < maxSize && bounded.Slot.IsActive);
				float num = 0f;
				for (int num2 = 0; num2 < 3; num2++)
				{
					float num3 = boundingBox.Size[num2];
					if (num3 > num)
					{
						num = num3;
						forward = Elements.Core.float3.Zero.SetComponent(1f, num2);
					}
				}
				UniLog.Log("Detected forward from bounding box: " + forward);
			}
			bool flag = MathX.MaxComponent(bounds.Size) < 0.175f;
			Elements.Core.float3 b = root.GlobalPointToLocal(in tip) - bounds.Center;
			int num4 = 0;
			float num5 = 0f;
			for (int num6 = 0; num6 < 3; num6++)
			{
				float num7 = MathX.Abs(MathX.Dot(Elements.Core.float3.Zero.SetComponent(1f, num6), in forward));
				if (num7 > num5)
				{
					num5 = num7;
					num4 = num6;
				}
			}
			int num8 = 0;
			num5 = 0f;
			for (int num9 = 0; num9 < 3; num9++)
			{
				if (num9 != num4)
				{
					float num10 = MathX.Abs(MathX.Dot(Elements.Core.float3.Zero.SetComponent(1f, num9), in b));
					if (num10 > num5)
					{
						num5 = num10;
						num8 = num9;
					}
				}
			}
			Elements.Core.float3 v = Elements.Core.float3.Zero.SetComponent(1f, num8);
			v *= MathX.Sign(MathX.Dot(in v, in b));
			if (side == Chirality.Left)
			{
				v *= -1;
			}
			int n = 0;
			for (int num11 = 0; num11 < 3; num11++)
			{
				if (num11 != num4 && num11 != num8)
				{
					n = num11;
					break;
				}
			}
			Elements.Core.float3 up = MathX.Cross(in v, in forward);
			Elements.Core.floatQ rotation = Elements.Core.floatQ.LookRotation(in forward, in up);
			return new Transform((!flag) ? (bounds.Center + forward * bounds.Size[num4] * -0.4f + v * bounds.Size[num8] * ((side != Chirality.Left) ? 1 : (-1)) * -0.3f + up * bounds.Size[n] * 0.4f) : (bounds.Center - forward * (0.135f + bounds.Size[num4]) - v * 0.035f * ((side != Chirality.Left) ? 1 : (-1))), in rotation, Elements.Core.float3.One);
		}

		public static async Task<Elements.Core.Ray?> ComputeHeuristicsTip(ITool tooltip)
		{
			Slot root = tooltip.Slot;
			Elements.Core.float3 direction = tooltip.TipForward;
			Elements.Core.float3 origin = tooltip.Tip;
			if ((tooltip as Tool)?.TipReference.Target != null || !(tooltip is RawDataTool))
			{
				UniLog.Log("Detected using tooltip reference");
				return new Elements.Core.Ray(in origin, in direction);
			}
			FrooxEngine.PhotonDust.PointEmitter componentInChildren = root.GetComponentInChildren<FrooxEngine.PhotonDust.PointEmitter>();
			if (componentInChildren != null)
			{
				direction = componentInChildren.Slot.LocalDirectionToGlobal(componentInChildren.Direction.Value.Normalized);
				origin = componentInChildren.Slot.GlobalPosition;
				UniLog.Log("Detected using point emitter");
				return new Elements.Core.Ray(in origin, in direction);
			}
			ProtoFluxNode componentInChildren2 = root.GetComponentInChildren((ProtoFluxNode n) => n.GetType().Name.Contains("RaycastOne"));
			if (componentInChildren2 != null)
			{
				INodeOutput nodeOutput = (componentInChildren2.GetSyncMember("Direction") as ISyncRef).Target as INodeOutput;
				INodeOutput nodeOutput2 = (componentInChildren2.GetSyncMember("Origin") as ISyncRef).Target as INodeOutput;
				INodeOutput nodeOutput3 = (componentInChildren2.GetSyncMember("Root") as ISyncRef).Target as INodeOutput;
				ProtoFluxNode dirEval = null;
				ProtoFluxNode originEval = null;
				ProtoFluxNode rootEval = null;
				if (nodeOutput != null)
				{
					dirEval = (ProtoFluxNode)nodeOutput.FindNearestParent<Slot>().Parent.AddSlot("INJECTED_DIRECTION_EVAL").AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(ValueEvaluationPoint<Elements.Core.float3>)));
					dirEval.TryConnectInput(dirEval.GetInput(0), nodeOutput, allowExplicitCast: false, undoable: false);
				}
				if (nodeOutput2 != null)
				{
					originEval = (ProtoFluxNode)nodeOutput2.FindNearestParent<Slot>().Parent.AddSlot("INJECTED_ORIGIN_EVAL").AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(ValueEvaluationPoint<Elements.Core.float3>)));
					originEval.TryConnectInput(originEval.GetInput(0), nodeOutput2, allowExplicitCast: false, undoable: false);
				}
				if (nodeOutput3 != null)
				{
					rootEval = (ProtoFluxNode)nodeOutput3.FindNearestParent<Slot>().Parent.AddSlot("INJECTED_ROOT_EVAL").AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(ObjectEvaluationPoint<Slot>)));
					rootEval.TryConnectInput(rootEval.GetInput(0), nodeOutput3, allowExplicitCast: false, undoable: false);
				}
				while (true)
				{
					ProtoFluxNode protoFluxNode = dirEval;
					if (protoFluxNode == null || protoFluxNode.IsBuilt)
					{
						ProtoFluxNode protoFluxNode2 = originEval;
						if (protoFluxNode2 == null || protoFluxNode2.IsBuilt)
						{
							ProtoFluxNode protoFluxNode3 = rootEval;
							if (protoFluxNode3 == null || protoFluxNode3.IsBuilt)
							{
								break;
							}
						}
					}
					await default(NextUpdate);
				}
				Elements.Core.float3 localDirection = Elements.Core.float3.Forward;
				Elements.Core.float3 localPoint = Elements.Core.float3.Zero;
				Slot slot = null;
				if (dirEval != null)
				{
					ValueEvaluationPoint<Elements.Core.float3> valueEvaluationPoint = (ValueEvaluationPoint<Elements.Core.float3>)dirEval.NodeInstance;
					localDirection = dirEval.Group.EvaluateImmediatelly(valueEvaluationPoint.Input, default(NodeContextPath));
					UniLog.Log("Evaluated direction: " + localDirection);
				}
				if (originEval != null)
				{
					ValueEvaluationPoint<Elements.Core.float3> valueEvaluationPoint2 = (ValueEvaluationPoint<Elements.Core.float3>)originEval.NodeInstance;
					localPoint = originEval.Group.EvaluateImmediatelly(valueEvaluationPoint2.Input, default(NodeContextPath));
					UniLog.Log("Evaluated origin: " + localPoint);
				}
				if (rootEval != null)
				{
					ObjectEvaluationPoint<Slot> objectEvaluationPoint = (ObjectEvaluationPoint<Slot>)rootEval.NodeInstance;
					slot = rootEval.Group.EvaluateImmediatelly(objectEvaluationPoint.Input, default(NodeContextPath));
					UniLog.Log("Evaluated root: " + slot);
				}
				if (slot == null)
				{
					slot = root.World.RootSlot;
				}
				direction = slot.LocalDirectionToGlobal(in localDirection);
				origin = slot.LocalPointToGlobal(in localPoint);
				dirEval?.Slot?.Destroy();
				originEval?.Slot?.Destroy();
				rootEval?.Slot?.Destroy();
				UniLog.Log("Detected using raycast");
				return new Elements.Core.Ray(in origin, in direction);
			}
			FrooxEngine.PhotonDust.SphereEmitter componentInChildren3 = root.GetComponentInChildren((FrooxEngine.PhotonDust.SphereEmitter e) => e.DirectionMode.Value == SphereEmitterDirection.Forced);
			if (componentInChildren3 != null)
			{
				direction = componentInChildren3.Slot.LocalDirectionToGlobal(componentInChildren3.ForcedDirection.Value.Normalized);
				origin = componentInChildren3.Slot.GlobalPosition;
				UniLog.Log("Detected using sphere emitter");
				return new Elements.Core.Ray(in origin, in direction);
			}
			UniLog.Log("Failed to detect forward and tip");
			return null;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			HandSide = new Sync<Chirality>();
			_rootPos = new Sync<Elements.Core.float3>();
			TipReference = new SyncRef<Slot>();
			ShowVisual = new Sync<bool>();
