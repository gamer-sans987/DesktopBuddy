		{
			base.Debug.Cylinder(base.Slot.LocalPointToGlobal((Elements.Core.float3)Offset), base.Slot.LocalScaleToGlobal(Height), base.Slot.LocalScaleToGlobal(Radius), in color, base.Slot.GlobalRotation, duration);
		}

