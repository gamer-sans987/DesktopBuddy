				return CellSize.Value.Value;
			}
			if (CellCount.Value.HasValue)
			{
				return rectSize / (Elements.Core.float2)CellCount.Value.Value;
			}
			return Elements.Core.float2.Zero;
		}

		public Elements.Core.float2 ComputeCenteringOffsetForRect(in Elements.Core.float2 rectSize)
		{
			return (rectSize - (Elements.Core.float2)ComputeGridSizeForRect(in rectSize) * ComputeActualSizeForRect(in rectSize)) * 0.5f;
		}

		private Elements.Core.Rect ToVisualRect(Elements.Core.IntRect gridRect)
		{
			return new Elements.Core.Rect((Elements.Core.float2)gridRect.Position * ActualCellSize + CenteringOffset + Padding.Value * 0.5f, (Elements.Core.float2)gridRect.Size * ActualCellSize - Padding.Value);
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			RecalculateOnSizeChange.Value = true;
			CellSize.Value = Elements.Core.float2.One * 64;
			Padding.Value = Elements.Core.float2.One * 4;
