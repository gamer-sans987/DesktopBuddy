		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Highlight, 
				4 => Icon, 
				5 => Sprite, 
				6 => Label, 
				7 => Color, 
				8 => _menu, 
				9 => _highlighted, 
				10 => _arc, 
