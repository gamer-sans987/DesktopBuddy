					Elements.Core.floatQ localRotation = base.Slot.GlobalRotationToLocal(actualCharacterRoot.GlobalRotation);
					localRotation = randomWithWeight.TeleportExit.Target.LocalRotationToGlobal(in localRotation);
					Elements.Core.float3 localScale = base.Slot.GlobalScaleToLocal(actualCharacterRoot.GlobalScale);
					localScale = randomWithWeight.TeleportExit.Target.LocalScaleToGlobal(in localScale);
					Elements.Core.float3 localVector = base.Slot.GlobalVectorToLocal(character.LinearVelocity);
					localVector = randomWithWeight.TeleportExit.Target.LocalVectorToGlobal(in localVector);
					if ((bool)randomWithWeight.TransformRotation)
					{
						actualCharacterRoot.GlobalRotation = localRotation;
					}
					if ((bool)randomWithWeight.TransformScale)
					{
						actualCharacterRoot.GlobalScale = localScale;
					}
					actualCharacterRoot.GlobalPosition = localPoint;
					if (!randomWithWeight.TeleportExitVelocity.Value.HasValue)
					{
						character.LinearVelocity = localVector;
					}
					else
					{
						character.LinearVelocity = randomWithWeight.TeleportExit.Target.LocalDirectionToGlobal(randomWithWeight.TeleportExitVelocity.Value.Value);
					}
				}
				else
				{
					Elements.Core.float3 globalPosition = randomWithWeight.RandomExitPointGenerator.Target?.GeneratePoint(randomWithWeight.TeleportExit.Target) ?? randomWithWeight.TeleportExit.Target.GlobalPosition;
					actualCharacterRoot.GlobalPosition = globalPosition;
					if (randomWithWeight.TeleportExitVelocity.Value.HasValue)
					{
