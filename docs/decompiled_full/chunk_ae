		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Target, 
				4 => Key, 
				5 => Format, 
				6 => Locale, 
				7 => ArgumentSources, 
				8 => ArgumentValues, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

