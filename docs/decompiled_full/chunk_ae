			if (list.Count > 0)
			{
				FootstepClip randomWithWeight = list.GetRandomWithWeight((FootstepClip c) => c.Weight.Value);
				float val = MathX.InverseLerp(randomWithWeight.PitchMinVelocityReference, randomWithWeight.PitchMaxVelocityReference, magnitude);
				val = MathX.Clamp01(val);
				float num = MathX.Lerp(randomWithWeight.VelocityMinPitch, randomWithWeight.VelocityMaxPitch, val);
				num += RandomX.Range(randomWithWeight.MinPitchVariation, randomWithWeight.MaxPitchVariation);
				MathX.Clamp01(MathX.InverseLerp(randomWithWeight.VolumeMinVelocityReference, randomWithWeight.VolumeMaxVelocityReference, magnitude));
				float num2 = MathX.Lerp(randomWithWeight.VelocityMinVolume, randomWithWeight.VelocityMaxVolume, val);
				num2 += RandomX.Range(randomWithWeight.MinVolumeVariation, randomWithWeight.MaxVolumeVariation);
				num2 = MathX.Clamp01(num2);
				num2 *= weight;
				AudioOutput audioOutput = base.World.PlayOneShot(point, randomWithWeight.Clip.Target, num2, spatialize: true, false, num, ParentUnder.Target);
				if (MinDistance.Value.HasValue)
				{
					audioOutput.MinDistance.Value = MinDistance.Value.Value;
				}
				if (MaxDistance.Value.HasValue)
				{
					audioOutput.MaxDistance.Value = MaxDistance.Value.Value;
				}
				if (RolloffMode.Value.HasValue)
				{
					audioOutput.RolloffMode.Value = RolloffMode.Value.Value;
				}
			}
			Pool.Return(ref list);
		}

