			{
				Manager = manager;
				User = user;
			}

			private ref ColliderData AllocateColliderData()
			{
				if (boneIndex >= bones.Count)
				{
					bones.Add(Manager.RegisterCollider(this));
				}
				return ref Manager.GetColliderData(bones[boneIndex++]);
			}

			public void MoveIndex(int oldIndex, int newIndex)
			{
				if (boneIndex >= 0)
				{
					bones[bones.IndexOf(oldIndex)] = newIndex;
				}
			}

			public void Update()
			{
				UserRoot root = User.Root;
				if (root == null || !root.Slot.IsActive)
				{
					RemoveAllColliders();
					return;
				}
				boneIndex = 0;
				List<DynamicBonePlayerColliders> list = Pool.BorrowList<DynamicBonePlayerColliders>();
				root.GetRegisteredComponents(list);
				bool flag = true;
				bool flag2 = true;
				bool flag3 = true;
				bool flag4 = true;
				foreach (DynamicBonePlayerColliders item in list)
				{
					if ((bool)item.DisableDefaultHeadColliders)
					{
						flag = false;
					}
					if ((bool)item.DisableDefaultBodyColliders)
					{
						flag2 = false;
					}
					if ((bool)item.DisableDefaultLeftHandColliders)
					{
						flag3 = false;
					}
					if ((bool)item.DisableDefaultRightHandColliders)
					{
						flag4 = false;
					}
					foreach (IDynamicBoneCollider collider in item.Colliders)
					{
						if (collider is DynamicBoneSphereCollider dynamicBoneSphereCollider && collider.Enabled && collider.Slot.IsActive)
						{
							ref ColliderData reference = ref AllocateColliderData();
							reference.radius = dynamicBoneSphereCollider.Slot.LocalScaleToGlobal(dynamicBoneSphereCollider.Radius);
							reference.position = dynamicBoneSphereCollider.Slot.GlobalPosition;
							reference.mask = 16;
							reference.type = DynamicBoneCollisionDataType.Regular;
						}
					}
				}
				Pool.Return(ref list);
				float globalScale = root.GlobalScale;
				float handRadius = 0.04f * globalScale;
				Slot leftHandSlot = root.LeftHandSlot;
				Slot rightHandSlot = root.RightHandSlot;
				if (flag3)
				{
					AppendHandColliders(leftHandSlot, Chirality.Left, handRadius, User.IsLocalUser);
				}
				if (flag4)
				{
					AppendHandColliders(rightHandSlot, Chirality.Right, handRadius, User.IsLocalUser);
				}
				Slot headSlot = root.HeadSlot;
				if (headSlot != null)
				{
					_ = root.HeadRotation * Elements.Core.float3.Forward;
					Elements.Core.float3 position = headSlot.LocalPointToGlobal(HEAD_OFFSET);
					if (flag)
					{
						float radius = 0.16f * globalScale;
						ref ColliderData reference2 = ref AllocateColliderData();
						reference2.radius = radius;
						reference2.position = position;
						reference2.mask = 1;
						reference2.type = DynamicBoneCollisionDataType.Regular;
					}
					if (flag2)
					{
						Elements.Core.float3 to = root.HipsPosition;
						Elements.Core.float3 from = root.NeckPosition;
						float radius2 = 0.125f * globalScale;
						for (int i = 0; i < 3; i++)
						{
							float t = (float)i * (1f / 3f);
							Elements.Core.float3 position2 = MathX.Lerp(in from, in to, t);
							ref ColliderData reference3 = ref AllocateColliderData();
							reference3.radius = radius2;
							reference3.position = position2;
							reference3.mask = 8;
							reference3.type = DynamicBoneCollisionDataType.Regular;
						}
						Chirality[] array = new Chirality[2]
						{
							Chirality.Left,
							Chirality.Right
						};
						foreach (Chirality num in array)
						{
							Elements.Core.float3 to2 = ((num == Chirality.Left) ? root.LeftFootPosition : root.RightFootPosition);
							Elements.Core.float3 from2 = ((num == Chirality.Left) ? root.LeftKneePosition : root.RightKneePosition);
							Elements.Core.float3 from3 = ((num == Chirality.Left) ? root.LeftHipPosition : root.RightHipPosition);
							for (int k = 0; k < 6; k++)
							{
								float num2 = (float)k * (1f / 6f);
								Elements.Core.float3 position3 = ((!(num2 < 0.5f)) ? MathX.Lerp(in from2, in to2, (num2 - 0.5f) * 2f) : MathX.Lerp(in from3, in from2, num2 * 2f));
								ref ColliderData reference4 = ref AllocateColliderData();
								reference4.radius = MathX.Lerp(0.1f, 0.075f, num2);
								reference4.position = position3;
								reference4.mask = 8;
								reference4.type = DynamicBoneCollisionDataType.Regular;
							}
						}
						array = new Chirality[2]
						{
							Chirality.Left,
							Chirality.Right
						};
						foreach (Chirality chirality in array)
						{
							Elements.Core.float3 to3 = ((chirality == Chirality.Left) ? root.LeftHandPosition : root.RightHandPosition);
							Elements.Core.float3 from4 = ((chirality == Chirality.Left) ? root.LeftElbowPosition : root.RightElbowPosition);
							Elements.Core.float3 from5 = ((chirality == Chirality.Left) ? root.LeftUpperArmPosition : root.RightUpperArmPosition);
							for (int l = 0; l < 8; l++)
							{
								float num3 = (float)l * 0.125f;
								Elements.Core.float3 position4 = ((!(num3 < 0.5f)) ? MathX.Lerp(in from4, in to3, (num3 - 0.5f) * 2f) : MathX.Lerp(in from5, in from4, num3 * 2f));
								ref ColliderData reference5 = ref AllocateColliderData();
								reference5.radius = MathX.Lerp(0.075f, 0.05f, num3);
								reference5.position = position4;
								reference5.mask = (byte)(((chirality == Chirality.Left) ? 2 : 4) | 8);
								reference5.type = DynamicBoneCollisionDataType.Regular;
							}
						}
					}
				}
				TrimColliders();
			}

			private void AppendHandColliders(Slot handSlot, Chirality chirality, float handRadius, bool isLocal)
			{
				if (handSlot == null)
				{
					return;
				}
				Elements.Core.float4x4 localToGlobal = handSlot.LocalToGlobal;
				byte mask = (byte)((chirality == Chirality.Left) ? 2 : 4);
				for (int i = 0; i < 3; i++)
				{
					Elements.Core.float3 @float = localToGlobal.TransformPoint3x4(Elements.Core.float3.Forward * 0.06f * (i + 1));
					float radius = handRadius * ((i == 1) ? 1.25f : 1f);
					ref ColliderData reference = ref AllocateColliderData();
					reference.radius = radius;
					reference.position = @float;
					reference.mask = mask;
					if (isLocal)
					{
						reference.type = ((chirality == Chirality.Left) ? DynamicBoneCollisionDataType.LeftHand : DynamicBoneCollisionDataType.RightHand);
						if (chirality == Chirality.Left)
						{
							Manager.LastLeftHandPositon = @float;
						}
						else
						{
							Manager.LastRightHandPosition = @float;
						}
					}
					else
					{
						reference.type = DynamicBoneCollisionDataType.Regular;
					}
				}
			}

			private void TrimColliders()
			{
				for (int num = bones.Count - 1; num > boneIndex; num--)
				{
					Manager.UnregisterCollider(bones[num]);
					bones.RemoveAt(num);
				}
			}

			public void RemoveAllColliders()
			{
				boneIndex = -1;
				bones.Sort();
				for (int num = bones.Count - 1; num >= 0; num--)
				{
					Manager.UnregisterCollider(bones[num]);
				}
				bones.Clear();
			}
		}

