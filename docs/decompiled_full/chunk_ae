	public class SlideLocomotion : NoclipLocomotion
	{
		public readonly Sync<float> MaxSnapDistance;

		public readonly Sync<float> SnapCheckOffset;

		public readonly Sync<float> SnapMinObjectSize;

		public override LocaleString LocomotionName => "Locomotion.Slide.Name".AsLocaleKey();

		public override LocaleString LocomotionDescription => "Locomotion.Slide.Description".AsLocaleKey();

		protected override Uri DefaultIcon => OfficialAssets.Common.Icons.Car;

		protected override Elements.Core.colorX DefaultColor => Elements.Core.colorX.Magenta;

		public override LocomotionArchetype? LocomotionArchetype => null;

		protected override void OnAwake()
		{
			base.OnAwake();
			MaxSnapDistance.Value = 2f;
			SnapCheckOffset.Value = 1f;
			SnapMinObjectSize.Value = 1f;
		}

		public override ICollider Update()
		{
			base.Update();
			Elements.Core.float3 v = base.LocalUserRoot.Slot.Down;
			float num = base.LocalUserRoot.Slot.LocalScaleToGlobal(SnapCheckOffset);
			float num2 = base.LocalUserRoot.Slot.LocalScaleToGlobal(MaxSnapDistance);
			List<RaycastHit> list = Pool.BorrowList<RaycastHit>();
			base.Physics.RaycastAll(base.LocalUserRoot.FeetPosition - base.LocalUserRoot.Slot.LocalVectorToGlobal(v * num), in v, num2 + num, list);
			ICollider result = null;
			foreach (RaycastHit item in list)
			{
				RaycastHit current = item;
				if (!(MathX.MaxComponent(current.Collider.GetBoundingBoxInSpace(base.LocalUserRoot.Slot).Size) < (float)SnapMinObjectSize) && !current.Collider.Slot.IsChildOf(base.LocalUserRoot.Slot, includeSelf: true))
				{
					Elements.Core.float3 @float = base.LocalUserRoot.Slot.GlobalPointToLocal(in current.Point);
					Slot slot = base.LocalUserRoot.Slot;
					slot.LocalPosition += base.LocalUserRoot.Slot.LocalVectorToParent(@float._y_);
					result = current.Collider;
					break;
				}
			}
			Pool.Return(ref list);
			return result;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			MaxSnapDistance = new Sync<float>();
			SnapCheckOffset = new Sync<float>();
			SnapMinObjectSize = new Sync<float>();
		}

