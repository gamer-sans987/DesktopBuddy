	public abstract class Collider<TShape> : Collider where TShape : unmanaged, IShape
	{
		protected abstract TShape CreateShape(PhysicsSimulation simulation, ref Elements.Core.float3 offset, ref float speculativeMargin, float? mass, out BodyInertia inertia);

		protected abstract void RemoveShape(TypedIndex shapeIndex, PhysicsSimulation simulation);

		protected override TypedIndex RegisterShape(PhysicsSimulation simulation, ref float speculativeMargin, float? mass, out BodyInertia inertia)
		{
			ClearShapeChanged();
			Elements.Core.float3 a = Offset.Value;
			if (a != Elements.Core.float3.Zero)
			{
				ProcessColliderOffset(ref a);
			}
			TShape shape = CreateShape(simulation, ref a, ref speculativeMargin, mass, out inertia);
			TypedIndex typedIndex = simulation.Simulation.Shapes.Add(in shape);
			if (a != Elements.Core.float3.Zero)
			{
				simulation.BufferPool.Take(1, out Buffer<CompoundChild> buffer);
				ref CompoundChild reference = ref buffer[0];
				reference.LocalPose = new RigidPose((System.Numerics.Vector3)a);
				reference.ShapeIndex = typedIndex;
				Compound shape2 = new Compound(buffer);
				if (mass.HasValue)
				{
					Symmetric3x3.Invert(in inertia.InverseInertiaTensor, out var inverse);
					CompoundBuilder.GetOffsetInertiaContribution((System.Numerics.Vector3)a, mass.Value, out var contribution);
					Symmetric3x3.Add(in contribution, in inverse, out inverse);
					Symmetric3x3.Invert(in inverse, out inertia.InverseInertiaTensor);
				}
				return simulation.Simulation.Shapes.Add(in shape2);
			}
			return typedIndex;
		}

		protected override void UnregisterShape(PhysicsSimulation simulation)
		{
			if (_shapeIndex.Type == 6)
			{
				TypedIndex shapeIndex = simulation.Simulation.Shapes.GetShape<Compound>(_shapeIndex.Index).Children[0].ShapeIndex;
				simulation.Simulation.Shapes.RemoveAndDispose(_shapeIndex, simulation.BufferPool);
				RemoveShape(shapeIndex, simulation);
			}
			else
			{
				RemoveShape(_shapeIndex, simulation);
			}
			_shapeIndex = default(TypedIndex);
		}

		public override string ToString()
		{
			return $"Offset: {Offset.Value}, " + base.ToString();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
		}
	}
