		private void AdjustRotation(Elements.Core.floatQ current, ref Elements.Core.floatQ last, Slot deltaSpace, GripRotation mode, bool invert, float? lerp)
		{
			if (mode != GripRotation.None)
			{
				Elements.Core.floatQ a = deltaSpace.LocalRotationToGlobal(in last);
				if (lerp.HasValue)
				{
					current = MathX.Slerp(in a, current, lerp.Value * base.Time.Delta);
				}
				Slot slot = base.Slot.ActiveUserRoot.Slot;
				Elements.Core.floatQ a2 = ((!invert) ? (current * a.Inverted) : (a * current.Inverted));
				last = deltaSpace.GlobalRotationToLocal(in current);
				Elements.Core.floatQ globalRotation = a2 * slot.GlobalRotation;
				if (mode == GripRotation.VerticalOnly)
				{
					Elements.Core.float3 up = slot.Up;
					slot.GlobalRotation = globalRotation;
					slot.Up = up;
				}
				else
				{
					slot.GlobalRotation = globalRotation;
				}
			}
		}

