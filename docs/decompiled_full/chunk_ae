		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		private void UpdatePreviousCollision<TManifold>(ref PreviousCollision collision, ref TManifold manifold, bool isTouching) where TManifold : unmanaged, IContactManifold<TManifold>
		{
			for (int i = 0; i < manifold.Count; i++)
			{
				Unsafe.Add(ref collision.featureId0, i) = manifold.GetFeatureId(i);
			}
			collision.contactCount = manifold.Count;
			collision.fresh = true;
			collision.wasTouching = isTouching;
		}

		private bool IsTouching<TManifold>(ref TManifold manifold) where TManifold : unmanaged, IContactManifold<TManifold>
		{
			for (int i = 0; i < manifold.Count; i++)
			{
				if (manifold.GetDepth(ref manifold, i) >= 0f)
				{
					return true;
				}
			}
			return false;
		}

		private void HandleManifoldForCollidable<TManifold>(int workerIndex, CollidableReference source, CollidableReference other, ref TManifold manifold) where TManifold : unmanaged, IContactManifold<TManifold>
		{
			if (!IsEventSource(source) || (!IsListener(other) && !IsListener(source)))
			{
				return;
			}
			int num = eventSourceIndicies[source];
			ref EventSource reference = ref eventSources[num];
			int num2 = -1;
			bool flag = false;
			for (int i = 0; i < reference.previousCollisions.Count; i++)
			{
				ref PreviousCollision reference2 = ref reference.previousCollisions[i];
				if (reference2.collidable.Packed != other.Packed)
				{
					continue;
				}
				num2 = i;
				for (int j = 0; j < manifold.Count; j++)
				{
					if (manifold.GetDepth(ref manifold, j) >= 0f)
					{
						flag = true;
						break;
					}
				}
				if (!reference2.wasTouching && flag)
				{
					StartedTouching(num, other, ref manifold, workerIndex);
				}
				else if (reference2.wasTouching && !flag)
				{
					StoppedTouching(num, other, ref manifold, workerIndex);
				}
				UpdatePreviousCollision(ref reference2, ref manifold, flag);
				break;
			}
			if (num2 >= 0)
			{
				return;
			}
			ref QuickList<PendingWorkerAdd> reference3 = ref pendingWorkerAdds[workerIndex];
			EnsureThreadStorageCapacity(ref reference3, workerIndex);
			ref PendingWorkerAdd reference4 = ref reference3.AllocateUnsafely();
			reference4.listenerIndex = num;
			reference4.collision.collidable = other;
			for (int k = 0; k < manifold.Count; k++)
			{
				manifold.GetContact(k, out var _, out var _, out var depth, out var _);
				if (depth >= 0f)
				{
					flag = true;
					break;
				}
			}
			if (flag)
			{
				StartedTouching(num, other, ref manifold, workerIndex);
			}
			UpdatePreviousCollision(ref reference4.collision, ref manifold, flag);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void HandleManifold<TManifold>(int workerIndex, CollidablePair pair, ref TManifold manifold) where TManifold : unmanaged, IContactManifold<TManifold>
		{
			HandleManifoldForCollidable(workerIndex, pair.A, pair.B, ref manifold);
			HandleManifoldForCollidable(workerIndex, pair.B, pair.A, ref manifold);
		}

		private void DispatchEvents(ref QuickList<CollisionEvent>[] events, ColliderEventHandler handler, bool flagAsTouched)
		{
			for (int i = 0; i < events.Length; i++)
			{
				ref QuickList<CollisionEvent> reference = ref events[i];
				for (int j = 0; j < reference.Count; j++)
				{
					ref CollisionEvent reference2 = ref reference[j];
					DispatchEvent(eventSources[reference2.eventSourceIndex].body, reference2.other, handler, flagAsTouched);
				}
				if (reference.Span.Allocated)
				{
					reference.Dispose(PhysicsSimulation.ThreadDispatcher?.GetThreadMemoryPool(i) ?? Pool);
				}
				reference = default(QuickList<CollisionEvent>);
			}
		}

		private void DispatchEvent(BodyHandle eventSourceBody, CollidableReference other, ColliderEventHandler handler, bool flagAsTouched)
		{
			ICollider collider = PhysicsSimulation.GetCollider(eventSourceBody);
			ICollider collider2 = PhysicsSimulation.GetCollider(other);
			if (IsListener(eventSourceBody) && !IsEventSource(other))
			{
				handler(collider, collider2);
			}
			if (IsListener(other))
			{
				handler(collider2, collider);
			}
			if (flagAsTouched && !IsTouching(other))
			{
				lastTouching.Add(in other, Pool);
				SetIsTouching(other);
			}
		}

		public void DispatchEvents()
		{
			Simulation simulation = Simulation;
			BepuUtilities.Memory.BufferPool pool = Pool;
			for (int i = 0; i < lastTouching.Count; i++)
			{
				ClearIsTouching(lastTouching[i]);
			}
			lastTouching.Clear();
			DispatchEvents(ref startedCollisions, RunCollisionStart, flagAsTouched: true);
			for (int j = 0; j < eventSourceCount; j++)
			{
				ref EventSource reference = ref eventSources[j];
				bool flag = simulation.Bodies.HandleToLocation[reference.body.Value].SetIndex > 0;
				for (int num = reference.previousCollisions.Count - 1; num >= 0; num--)
				{
					ref PreviousCollision reference2 = ref reference.previousCollisions[num];
					bool flag2 = reference2.collidable.Mobility == CollidableMobility.Static || simulation.Bodies.HandleToLocation[reference2.collidable.BodyHandle.Value].SetIndex > 0;
					if (!reference2.fresh && !(flag && flag2))
					{
						if (reference2.contactCount > 0)
						{
							EmptyManifold contactManifold = default(EmptyManifold);
							if (reference2.wasTouching)
							{
								StoppedTouching(j, reference2.collidable, ref contactManifold, 0);
							}
						}
						reference.previousCollisions.FastRemoveAt(num);
						if (reference.previousCollisions.Count == 0)
						{
							reference.previousCollisions.Dispose(pool);
							reference.previousCollisions = default(QuickList<PreviousCollision>);
						}
					}
					else
					{
						if (reference2.wasTouching)
						{
							DispatchEvent(reference.body, reference2.collidable, RunCollisionStay, flagAsTouched: true);
						}
						reference2.fresh = false;
					}
				}
			}
			DispatchEvents(ref endedCollisions, RunCollisionEnd, flagAsTouched: false);
			for (int k = 0; k < pendingWorkerAdds.Length; k++)
			{
				ref QuickList<PendingWorkerAdd> reference3 = ref pendingWorkerAdds[k];
				for (int l = 0; l < reference3.Count; l++)
				{
					ref PendingWorkerAdd reference4 = ref reference3[l];
					ref QuickList<PreviousCollision> previousCollisions = ref eventSources[reference4.listenerIndex].previousCollisions;
					previousCollisions.EnsureCapacity(Math.Max(8, previousCollisions.Count + 1), pool);
					previousCollisions.AllocateUnsafely() = reference3[l].collision;
				}
				if (reference3.Span.Allocated)
				{
					reference3.Dispose(PhysicsSimulation.ThreadDispatcher?.GetThreadMemoryPool(k) ?? Pool);
				}
				reference3 = default(QuickList<PendingWorkerAdd>);
			}
		}

		public void Dispose()
		{
			GC.SuppressFinalize(this);
			eventSourceIndicies.Dispose();
			eventSourceFlags.Dispose(Pool);
			bodyListenerFlags.Dispose(Pool);
			staticListenerFlags.Dispose(Pool);
			staticTouchingFlags.Dispose(Pool);
			bodyTouchingFlags.Dispose(Pool);
			lastTouching.Dispose(Pool);
			eventSources = null;
			for (int i = 0; i < pendingWorkerAdds.Length; i++)
			{
			}
		}
	}
