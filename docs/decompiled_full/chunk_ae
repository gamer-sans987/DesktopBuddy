		public override float ComputeIntensity(HapticSampler sampler)
		{
			VelocitySamplerData velocitySamplerData;
			if (!sampler.CustomData.TryGetValue(this, out object value))
			{
				velocitySamplerData = new VelocitySamplerData();
				sampler.CustomData.TryAdd(this, velocitySamplerData);
			}
			else
			{
				velocitySamplerData = (VelocitySamplerData)value;
			}
			float value2 = velocitySamplerData.UpdateVelocity(sampler, VelocitySmoothTime);
			float x = MathX.Clamp01(MathX.FilterInvalid(MathX.InverseLerp(StartVelocity, EndVelocity, value2)));
			x = MathX.Pow(x, Power);
			return MathX.LerpUnclamped(StartIntensity, EndIntensity, x);
		}

