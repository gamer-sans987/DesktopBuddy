			_pubsub.OnRewardRedeemed += PubSub_OnRewardRedeemed;
			TaskCompletionSource<object> taskCompletionSource = new TaskCompletionSource<object>();
			lock (_lock)
			{
				if (targetChannel != currentChannel)
				{
