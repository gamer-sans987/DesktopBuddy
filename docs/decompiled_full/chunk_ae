					break;
				}
			}
			pointerData.point = directPoint;
			pointerData.direction = direction;
			Pool.Return(ref list);
			Pool.Return(ref list2);
			return touchable;
		}

		public void PointerToRay(Pointer pointer, out Elements.Core.float3 origin, out Elements.Core.float3 direction)
		{
			Elements.Core.float2 uv = (Elements.Core.float2)pointer.Position / (Elements.Core.float2)base.InputInterface.WindowResolution;
			Elements.Core.float3 localUserViewPosition = base.World.LocalUserViewPosition;
			Elements.Core.floatQ q = base.World.LocalUserViewRotation;
			Elements.Core.float3 v = MathX.UVToPerspectiveCameraDirection(fieldOfView: base.World.LocalUserDesktopFOV, uv: uv, aspectRatio: base.InputInterface.WindowAspectRatio);
