	internal struct MainPoseIntegratorCallbacks : IPoseIntegratorCallbacks
	{
		public const float MAX_CHARACTER_VELOCITY = 1000f;

		private MainPhysicsSimulation simulation;

		private CollidableProperty<CollisionMask> contactMask;

		private float dt;

		public AngularIntegrationMode AngularIntegrationMode => AngularIntegrationMode.ConserveMomentum;

		private static void ClampVelocity(ref System.Numerics.Vector3 velocity)
		{
			velocity = new System.Numerics.Vector3(MathX.Clamp(velocity.X, -1000f, 1000f), MathX.Clamp(velocity.Y, -1000f, 1000f), MathX.Clamp(velocity.Z, -1000f, 1000f));
		}

		public MainPoseIntegratorCallbacks(MainPhysicsSimulation simulation, CollidableProperty<CollisionMask> contactMask)
		{
			this.simulation = simulation;
			this.contactMask = contactMask;
			dt = 0f;
		}

		public void Initialize(Simulation simulation)
		{
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void IntegrateVelocity(int bodyIndex, in RigidPose pose, in BodyInertia localInertia, int workerIndex, ref BodyVelocity velocity)
		{
			if (localInertia.InverseMass > 0f)
			{
				BodyHandle bodyHandle = simulation.Simulation.Bodies.ActiveSet.IndexToHandle[bodyIndex];
				if ((contactMask[bodyHandle].PackedData & 0x80) != 0)
				{
					CharacterController characterController = simulation.GetCharacterController(bodyHandle);
					characterController.GetCurrentCharacter();
					Elements.Core.float3 v = characterController.ActualGravity;
					velocity.Linear = (velocity.Linear + (System.Numerics.Vector3)(dt * v)) * MathX.DampingFactor(characterController.ActualLinearDamping, dt);
					velocity.Angular *= MathX.DampingFactor(characterController.ActualAngularDamping, dt);
					ClampVelocity(ref velocity.Linear);
					ClampVelocity(ref velocity.Angular);
				}
			}
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void PrepareForIntegration(float dt)
		{
			this.dt = dt;
		}

		void IPoseIntegratorCallbacks.IntegrateVelocity(int bodyIndex, in RigidPose pose, in BodyInertia localInertia, int workerIndex, ref BodyVelocity velocity)
		{
			IntegrateVelocity(bodyIndex, in pose, in localInertia, workerIndex, ref velocity);
		}
	}
	public class MeshColliderData : MeshPhysicsData<BepuPhysics.Collidables.Mesh>
	{
		public bool DualSided { get; private set; }

		public override bool DataReady
		{
			get
			{
				if (base.DataReady && _data.BoundsSize.X < 1E+10f && _data.BoundsSize.Y < 1E+10f)
				{
					return _data.BoundsSize.Z < 1E+10f;
				}
				return false;
			}
		}

		public void MarkDualSided()
		{
			DualSided = true;
		}

		protected override Elements.Assets.MeshVariantDescriptor GenerateDescriptor(MeshMetadata metadata)
		{
			return new Elements.Assets.MeshVariantDescriptor((!DualSided) ? MeshDataType.MeshCollider : MeshDataType.DualSidedMeshCollider, MeshCompression.LZ4, (metadata != null && metadata.TotalPointCount > 0) ? 2 : 0);
		}

		protected override async Task<(BepuPhysics.Collidables.Mesh, int)> LoadData(string file)
		{
			await base.Mesh.RequestReadLock(this);
			int version = base.Mesh.Version;
			bool _lockReleased = false;
			try
			{
				using FileStream stream = File.OpenRead(file);
				BepuMeshHelper.DeserializeMeshCollider(base.Mesh.Data, DualSided, MeshCompression.LZ4, stream, base.bufferPool, _bufferLock, delegate
				{
					base.Mesh.ReleaseReadLock(this);
					_lockReleased = true;
				}, out var mesh);
				Elements.Core.BoundingBox bounds = base.Mesh.Bounds;
				mesh.BoundsCenter = bounds.Center;
				mesh.BoundsSize = bounds.Size;
				return (mesh, version);
			}
			finally
			{
				if (!_lockReleased)
				{
					base.Mesh.ReleaseReadLock(this);
				}
			}
		}

		protected override async Task<(BepuPhysics.Collidables.Mesh, int)> BuildData()
		{
			await base.Mesh.RequestReadLock(this);
			int version = base.Mesh.Version;
			bool _lockReleased = false;
			try
			{
				BepuMeshHelper.ComputeMeshCollider(base.Mesh.Data, DualSided, base.bufferPool, _bufferLock, delegate
				{
					base.Mesh.ReleaseReadLock(this);
					_lockReleased = true;
				}, out var mesh);
				Elements.Core.BoundingBox bounds = base.Mesh.Bounds;
				mesh.BoundsCenter = bounds.Center;
				mesh.BoundsSize = bounds.Size;
				return (mesh, version);
			}
			finally
			{
				if (!_lockReleased)
				{
					base.Mesh.ReleaseReadLock(this);
				}
			}
		}

		protected override void Free(ref BepuPhysics.Collidables.Mesh data)
		{
			if (data.Tree.Metanodes.Length == 0)
			{
				base.bufferPool.Return(ref data.Triangles);
				base.bufferPool.Return(ref data.Tree.Leaves);
				base.bufferPool.Return(ref data.Tree.Nodes);
			}
			else
			{
				data.Dispose(base.bufferPool);
			}
			data = default(BepuPhysics.Collidables.Mesh);
		}
	}
	[DataModelType]
	public interface IMeshPhysicsData
	{
		Mesh Mesh { get; }

		bool DataReady { get; }

		int DataVersion { get; }

		void Initialize(Mesh mesh);

		void EnsureUpToDate(IMeshPhysicsDataRequester requester);

		void FreeData(int version);
	}
	[DataModelType]
	public abstract class MeshPhysicsData<D> : IMeshPhysicsData
	{
		private object _versionLock = new object();

		protected object _bufferLock = new object();

		private HashSet<IMeshPhysicsDataRequester> _computeRequests = new HashSet<IMeshPhysicsDataRequester>();

		private bool _computeRequested;

		private bool _computeRunning;

		private bool _disposed;

		protected D _data;

		private int _dataVersion = -1;

		private int _dataRefCount;

		private D _oldData;

		private int _oldDataVersion = -1;

		private int _oldDataRefCount;

		public Mesh Mesh { get; private set; }

		public virtual bool DataReady => _dataVersion >= 0;

		public int DataVersion => _dataVersion;

		protected BepuUtilities.Memory.BufferPool bufferPool { get; private set; }

		public void Initialize(Mesh mesh)
		{
			if (Mesh != null)
			{
				throw new InvalidOperationException("Already initialized");
			}
			Mesh = mesh;
			bufferPool = new BepuUtilities.Memory.BufferPool();
		}

		public void GetData(out D data, out int version)
		{
			lock (_versionLock)
			{
				data = _data;
				version = _dataVersion;
				_dataRefCount++;
			}
		}

		public void FreeData(int version)
		{
			if (version < 0)
			{
				throw new ArgumentException("Invalid version: " + version);
			}
			lock (_versionLock)
			{
				if (version == _dataVersion)
				{
					_dataRefCount--;
				}
				else
				{
					if (version != _oldDataVersion)
					{
						throw new InvalidOperationException($"Version {version} isn't pinned!");
					}
					if (--_oldDataRefCount == 0 && !_disposed)
					{
						Task.Run((Action)FreeOldVersion);
					}
				}
				if (_disposed && _dataRefCount == 0 && _oldDataRefCount == 0)
				{
					Task.Run((Action)Dispose);
				}
			}
		}

		private void FreeOldVersion()
		{
			lock (_bufferLock)
			{
				Free(ref _oldData);
			}
			lock (_versionLock)
			{
				_oldDataVersion = -1;
				if (_computeRequested)
				{
					_computeRequested = false;
					EnsureUpToDate(null);
				}
			}
		}

		protected abstract void Free(ref D data);

		protected abstract Elements.Assets.MeshVariantDescriptor GenerateDescriptor(MeshMetadata metadata);

		public void EnsureUpToDate(IMeshPhysicsDataRequester requestee)
		{
			if (Mesh.Version == DataVersion)
			{
				return;
			}
			lock (_versionLock)
			{
				if (_disposed || Mesh.Version == DataVersion)
				{
					return;
				}
				if (requestee != null)
				{
					_computeRequests.Add(requestee);
				}
				if (_computeRequested || _computeRunning)
				{
					return;
				}
				if (_oldDataVersion >= 0)
				{
					_computeRequested = true;
					return;
				}
				_computeRunning = true;
			}
			Mesh.Engine.GlobalCoroutineManager.StartBackgroundTask(async delegate
			{
				await default(ToBackground);
				D data;
				int dataVersion;
				if (Mesh.AssetURL == null)
				{
					(data, dataVersion) = await BuildData();
				}
				else
				{
					Elements.Assets.MeshVariantDescriptor meshVariantDescriptor = GenerateDescriptor(Mesh.Metadata);
					if (meshVariantDescriptor.ValidateCloudVariant(Mesh.Metadata) == null)
					{
						string file = await Mesh.Engine.AssetManager.RequestVariant(Mesh.AssetURL, meshVariantDescriptor.VariantIdentifier, meshVariantDescriptor, generateVariant: true).ConfigureAwait(continueOnCapturedContext: false);
						while (Mesh.LoadState != AssetLoadState.FullyLoaded)
						{
							await Task.Delay(100);
							if (Mesh.LoadState == AssetLoadState.Failed || Mesh.LoadState == AssetLoadState.Unloaded)
							{
								return;
							}
						}
						(data, dataVersion) = await LoadData(file);
					}
					else
					{
						data = default(D);
						dataVersion = 0;
					}
				}
				lock (_versionLock)
				{
					_oldData = _data;
					_oldDataVersion = _dataVersion;
					_oldDataRefCount = _dataRefCount;
					_data = data;
					_dataVersion = dataVersion;
					_dataRefCount = 0;
					if (_oldDataRefCount == 0 && _oldDataVersion >= 0)
					{
						Task.Run((Action)FreeOldVersion);
					}
					foreach (IMeshPhysicsDataRequester computeRequest in _computeRequests)
					{
						computeRequest.MeshPhysicsDataUpdated();
					}
					_computeRequests.Clear();
					_computeRunning = false;
					if (_disposed)
					{
						Dispose();
					}
				}
			});
		}

		protected abstract Task<(D, int)> LoadData(string file);

		protected abstract Task<(D, int)> BuildData();

		internal void Unload()
		{
			lock (_versionLock)
			{
				if (_disposed)
				{
					throw new Exception("Already disposed!");
				}
				_disposed = true;
				if (!_computeRunning && _dataRefCount == 0 && _oldDataRefCount == 0)
				{
					Task.Run((Action)Dispose);
				}
			}
		}

		private void Dispose()
		{
			lock (_bufferLock)
			{
				if (_dataVersion >= 0)
				{
					Free(ref _data);
				}
				if (_oldDataVersion >= 0)
				{
					Free(ref _oldData);
				}
				_dataVersion = -1;
				_oldDataVersion = -1;
				bufferPool.Clear();
			}
		}
	}
