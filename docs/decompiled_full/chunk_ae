	public class CollisionListenerComponent : Component
	{
		public readonly Sync<bool> TriggersOnly;

		private SlimList<ICollider> _registeredColliders;

		public override int Version => 1;

		protected override void OnAwake()
		{
			base.OnAwake();
			base.Slot.ComponentAdded += Slot_ComponentAdded;
			base.Slot.ComponentRemoved += Slot_ComponentRemoved;
			foreach (Component component in base.Slot.Components)
			{
				Slot_ComponentAdded(component);
			}
			TriggersOnly.Value = true;
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			if (control.GetTypeVersion(GetType()) == 0)
			{
				control.OnLoaded(this, UpgradeTriggersOnly);
			}
		}

		private void Slot_ComponentRemoved(Component component)
		{
			if (component is ICollider collider)
			{
				Unregister(collider);
				_registeredColliders.Remove(collider);
			}
		}

		protected override void OnDestroy()
		{
			base.OnDestroy();
			UnregisterAll();
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			UnregisterAll();
			base.Slot.ComponentAdded -= Slot_ComponentAdded;
			base.Slot.ComponentRemoved -= Slot_ComponentRemoved;
		}

		private void UnregisterAll()
		{
			if (_registeredColliders.Count <= 0)
			{
				return;
			}
			foreach (ICollider registeredCollider in _registeredColliders)
			{
				Unregister(registeredCollider);
			}
			_registeredColliders.Clear();
		}

		private void Unregister(ICollider collider)
		{
			collider.ContactStart -= HandleContactStart;
			collider.ContactStay -= HandleContactStay;
			collider.ContactEnd -= HandleContactEnd;
		}

		private void Slot_ComponentAdded(Component component)
		{
			if (component is ICollider collider)
			{
				collider.ContactStart += HandleContactStart;
				collider.ContactStay += HandleContactStay;
				collider.ContactEnd += HandleContactEnd;
				_registeredColliders.Add(collider);
			}
		}

		private void HandleContactStart(ICollider collider, ICollider other)
		{
			if (TriggersOnly.Value && !Collider.IsTrigger(collider.ColliderType))
			{
				return;
			}
			try
			{
				base.World.UpdateManager.NestCurrentlyUpdating(this);
				OnContactStart(collider, other);
			}
			finally
			{
				base.World.UpdateManager.PopCurrentlyUpdating(this);
			}
		}

		private void HandleContactStay(ICollider collider, ICollider other)
		{
			if (TriggersOnly.Value && !Collider.IsTrigger(collider.ColliderType))
			{
				return;
			}
			try
			{
				base.World.UpdateManager.NestCurrentlyUpdating(this);
				OnContactStay(collider, other);
			}
			finally
			{
				base.World.UpdateManager.PopCurrentlyUpdating(this);
			}
		}

		private void HandleContactEnd(ICollider collider, ICollider other)
		{
			if (TriggersOnly.Value && !Collider.IsTrigger(collider.ColliderType))
			{
				return;
			}
			try
			{
				base.World.UpdateManager.NestCurrentlyUpdating(this);
				OnContactEnd(collider, other);
			}
			finally
			{
				base.World.UpdateManager.PopCurrentlyUpdating(this);
			}
		}

		protected void UpgradeTriggersOnly()
		{
			if (base.Slot.GetComponent((Collider c) => Collider.IsTrigger(c.Type.Value)) == null)
			{
				TriggersOnly.Value = false;
			}
		}

		protected virtual void OnContactStart(ICollider collider, ICollider other)
		{
		}

		protected virtual void OnContactStay(ICollider collider, ICollider other)
		{
