	public abstract class MeshColliderCharacterControllerModifier : CharacterControllerModifier
	{
		protected override float ComputeBaseParameter(in Elements.Core.float3 contactPosition, in Elements.Core.float3 contactNormal)
		{
			MeshCollider meshCollider = base.Slot.GetComponent<MeshCollider>();
			if (meshCollider == null)
