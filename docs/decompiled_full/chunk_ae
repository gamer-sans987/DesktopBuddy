		public bool ShouldAwaken(BodyReference body)
		{
			ColliderType registeredType = ((Collider)simulation.GetCollider(body.Handle)).RegisteredType;
			switch (awakeningType)
			{
			case ColliderType.Static:
			case ColliderType.StaticTrigger:
			case ColliderType.StaticTriggerAuto:
				return registeredType switch
				{
					ColliderType.Trigger => false, 
					ColliderType.Active => true, 
					ColliderType.CharacterController => true, 
					_ => throw new Exception($"Invalid other type: {registeredType}, awakeningType: {awakeningType}"), 
				};
			case ColliderType.HapticStaticTrigger:
			case ColliderType.HapticStaticTriggerAuto:
				return registeredType == ColliderType.HapticSampler;
