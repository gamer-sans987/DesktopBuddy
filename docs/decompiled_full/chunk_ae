		private static readonly ColliderEventHandler RunCollisionStart = delegate(ICollider self, ICollider other)
		{
			self.RunContactStart(other);
		};

		private static readonly ColliderEventHandler RunCollisionStay = delegate(ICollider self, ICollider other)
		{
			self.RunContactStay(other);
		};

		private static readonly ColliderEventHandler RunCollisionEnd = delegate(ICollider self, ICollider other)
		{
			self.RunContactEnd(other);
		};

		private CollidableProperty<int> eventSourceIndicies;

		private IndexSet eventSourceFlags;

		private IndexSet staticListenerFlags;

		private IndexSet bodyListenerFlags;

		private IndexSet staticTouchingFlags;

		private IndexSet bodyTouchingFlags;

		private QuickList<CollidableReference> lastTouching;

		private int eventSourceCount;

		private EventSource[] eventSources;

		private QuickList<PendingWorkerAdd>[] pendingWorkerAdds;

		private QuickList<CollisionEvent>[] startedCollisions;

		private QuickList<CollisionEvent>[] endedCollisions;

		public PhysicsSimulation PhysicsSimulation { get; private set; }

		public Simulation Simulation => PhysicsSimulation.Simulation;

		public BepuUtilities.Memory.BufferPool Pool => PhysicsSimulation.BufferPool;

		public ContactEventManager(PhysicsSimulation physicsSimulation, int initialListenerCapacity = 64)
		{
			PhysicsSimulation = physicsSimulation;
			eventSources = new EventSource[initialListenerCapacity];
		}

		public void Initialize()
		{
			eventSourceIndicies = new CollidableProperty<int>(Simulation, Pool);
			int num = PhysicsSimulation.ThreadDispatcher?.ThreadCount ?? 1;
			pendingWorkerAdds = new QuickList<PendingWorkerAdd>[num];
			startedCollisions = new QuickList<CollisionEvent>[num];
			endedCollisions = new QuickList<CollisionEvent>[num];
			eventSourceFlags = new IndexSet(Pool, 256);
			staticListenerFlags = new IndexSet(Pool, 256);
			bodyListenerFlags = new IndexSet(Pool, 256);
			staticTouchingFlags = new IndexSet(Pool, 256);
			bodyTouchingFlags = new IndexSet(Pool, 256);
			lastTouching.EnsureCapacity(64, Pool);
		}

		public void RegisterListener(CollidableReference collidable)
		{
			if (collidable.Mobility == CollidableMobility.Static)
			{
				staticListenerFlags.Add(collidable.RawHandleValue, Pool);
			}
			else
			{
				bodyListenerFlags.Add(collidable.RawHandleValue, Pool);
			}
		}

		public void RegisterListener(BodyHandle body)
		{
			RegisterListener(Simulation.Bodies.GetBodyReference(body).CollidableReference);
		}

		public void RegisterListener(StaticHandle staticHandle)
		{
			RegisterListener(new CollidableReference(staticHandle));
		}

		public void UnregisterListener(CollidableReference collidable)
		{
			if (collidable.Mobility == CollidableMobility.Static)
			{
				staticListenerFlags.Remove(collidable.RawHandleValue);
			}
			else
			{
				bodyListenerFlags.Remove(collidable.RawHandleValue);
			}
		}

		public void CollidableRemoved(CollidableReference collidable)
		{
			if (!IsTouching(collidable))
			{
				return;
			}
			ClearIsTouching(collidable);
			lastTouching.FastRemove(collidable);
			for (int i = 0; i < eventSourceCount; i++)
			{
				ref EventSource reference = ref eventSources[i];
				for (int num = reference.previousCollisions.Count - 1; num >= 0; num--)
				{
					if (reference.previousCollisions[num].collidable == collidable)
					{
						DispatchEvent(reference.body, collidable, RunCollisionEnd, flagAsTouched: false);
						reference.previousCollisions.FastRemoveAt(num);
					}
				}
			}
		}

		public void CollidableRemoved(BodyHandle handle)
		{
			CollidableRemoved(Simulation.Bodies.GetBodyReference(handle).CollidableReference);
		}

		public void CollidableRemoved(StaticHandle handle)
		{
			CollidableRemoved(new CollidableReference(handle));
		}

		public void UnregisterListener(BodyHandle handle)
		{
			UnregisterListener(Simulation.Bodies.GetBodyReference(handle).CollidableReference);
		}

		public void UnregisterListener(StaticHandle handle)
		{
			UnregisterListener(new CollidableReference(handle));
		}

		public void RegisterEventSource(BodyHandle body)
		{
			eventSourceFlags.Add(body.Value, Pool);
			if (eventSourceCount >= eventSources.Length)
			{
				Array.Resize(ref eventSources, eventSources.Length * 2);
			}
			eventSources[eventSourceCount] = new EventSource(body);
			eventSourceIndicies.Allocate(body) = eventSourceCount;
			eventSourceCount++;
		}

		public void UnregisterEventSource(BodyHandle body)
		{
			int num = eventSourceIndicies[body];
			ref EventSource reference = ref eventSources[num];
			if (reference.previousCollisions.Span.Allocated)
			{
				for (int i = 0; i < reference.previousCollisions.Count; i++)
				{
					ref PreviousCollision reference2 = ref reference.previousCollisions[i];
					if (reference2.wasTouching)
					{
						DispatchEvent(body, reference2.collidable, RunCollisionEnd, flagAsTouched: false);
					}
				}
				reference.previousCollisions.Dispose(Pool);
			}
			eventSourceCount--;
			ref EventSource reference3 = ref eventSources[eventSourceCount];
			if (num < eventSourceCount)
			{
				eventSourceIndicies[reference3.body] = num;
				reference = reference3;
			}
			reference3 = default(EventSource);
		}

		public bool IsEventSource(CollidableReference collidable)
		{
			if (collidable.Mobility == CollidableMobility.Static)
			{
				return false;
			}
			return eventSourceFlags.Contains(collidable.RawHandleValue);
		}

		public bool IsEventSource(BodyHandle body)
		{
			return eventSourceFlags.Contains(body.Value);
		}

		public bool IsListener(CollidableReference collidable)
		{
			if (collidable.Mobility == CollidableMobility.Static)
			{
				return staticListenerFlags.Contains(collidable.RawHandleValue);
			}
			return bodyListenerFlags.Contains(collidable.RawHandleValue);
		}

		public bool IsListener(BodyHandle handle)
		{
			return bodyListenerFlags.Contains(handle.Value);
		}

		public bool IsTouching(CollidableReference collidable)
		{
			if (collidable.Mobility == CollidableMobility.Static)
			{
				return staticTouchingFlags.Contains(collidable.RawHandleValue);
			}
			return bodyTouchingFlags.Contains(collidable.RawHandleValue);
		}

		public bool IsTouching(BodyHandle handle)
		{
			return bodyTouchingFlags.Contains(handle.Value);
		}

		public bool IsTouching(StaticHandle handle)
		{
			return staticTouchingFlags.Contains(handle.Value);
		}

		private void SetIsTouching(CollidableReference collidable)
		{
			if (collidable.Mobility == CollidableMobility.Static)
			{
				staticTouchingFlags.Add(collidable.RawHandleValue, Pool);
			}
			else
			{
				bodyTouchingFlags.Add(collidable.RawHandleValue, Pool);
			}
		}

		private void ClearIsTouching(CollidableReference collidable)
		{
			if (collidable.Mobility == CollidableMobility.Static)
			{
				staticTouchingFlags.Remove(collidable.RawHandleValue);
			}
			else
			{
				bodyTouchingFlags.Remove(collidable.RawHandleValue);
			}
		}

		private void StartedTouching<TManifold>(int eventSourceIndex, CollidableReference other, ref TManifold contactManifold, int workerIndex) where TManifold : unmanaged, IContactManifold<TManifold>
		{
			EnqueueCollisionEvent(eventSourceIndex, other, workerIndex, ref startedCollisions);
		}

		private void StoppedTouching<TManifold>(int eventSourceIndex, CollidableReference other, ref TManifold contactManifold, int workerIndex) where TManifold : unmanaged, IContactManifold<TManifold>
		{
