					}
				}
				if (randomWithWeight.ParentAfterTeleport.Target != null)
				{
					actualCharacterRoot.Parent = randomWithWeight.ParentAfterTeleport.Target;
				}
				randomWithWeight.TeleportExit.Target.ForeachComponentInParents(delegate(CharacterTeleporter t)
				{
					t.CharacterTeleported(character);
				});
				center = other.GlobalBoundingBox.Center;
				foreach (Action<Elements.Core.float3> item2 in TeleportExited)
				{
					item2?.Invoke(center);
				}
				foreach (Action<Elements.Core.float3> item3 in randomWithWeight.TeleportExited)
				{
					item3?.Invoke(center);
				}
			}
