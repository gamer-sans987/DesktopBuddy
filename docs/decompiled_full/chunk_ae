			}
		}

		public Elements.Core.float2 ActualCellSize
		{
			get
			{
				Elements.Core.Rect localComputeRect = base.RectTransform.LocalComputeRect;
				return ComputeActualSizeForRect(in localComputeRect.size);
			}
		}

