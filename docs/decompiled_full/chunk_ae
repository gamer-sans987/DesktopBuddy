		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			int typeVersion = control.GetTypeVersion(GetType());
			if (typeVersion == 0)
			{
				RunSynchronously(delegate
				{
					if (CharacterController.RegisteredCollider is CapsuleCollider capsuleCollider)
					{
						capsuleCollider.Radius.Value = 0.2f;
						capsuleCollider.Height.Value = 1.9f;
					}
				});
			}
			if (typeVersion < 2)
			{
				RunSynchronously(delegate
				{
					CharacterController.Margin.Value = 0.05f;
					FallRespawnPosition.Value = -250f;
				});
			}
			if (typeVersion < 3)
			{
				RunSynchronously(delegate
				{
					MaxInitializationDelay.Value *= 5f;
				});
			}
			if (typeVersion < 5)
			{
				RunSynchronously(delegate
				{
					base.Slot.Name = __legacyName.Value;
					__legacyName.Value = null;
					if (CharacterController.Speed.Value == 8f && CharacterController.SlidingSpeed.Value == 6f && CharacterController.AirSpeed.Value == 1f)
					{
						UseSpeedFromUserSettings.Value = true;
						CharacterController.Speed.Value = 4f;
						CharacterController.SlidingSpeed.Value = 3f;
						CharacterController.AirSpeed.Value = 1f;
					}
					else
					{
						UseSpeedFromUserSettings.Value = false;
					}
				});
			}
			if (typeVersion < 6)
			{
				RunSynchronously(delegate
				{
					if (LocomotionName == "Fly")
					{
						base.Slot.Name_Field.DriveLocalized("Locomotion.Fly.Name");
						Description.DriveLocalized("Locomotion.Fly.Description");
					}
					else if (LocomotionName == "Zero-G")
					{
						base.Slot.Name_Field.DriveLocalized("Locomotion.ZeroG.Name");
						Description.DriveLocalized("Locomotion.ZeroG.Description");
					}
					else if (LocomotionName == "Walk/Run")
					{
						base.Slot.Name_Field.DriveLocalized("Locomotion.WalkRun.Name");
						Description.DriveLocalized("Locomotion.WalkRun.Description");
					}
					else if (LocomotionName == "Walk/Run (with gripping)")
					{
						base.Slot.Name_Field.DriveLocalized("Locomotion.WalkRunGripping.Name");
						Description.DriveLocalized("Locomotion.WalkRunGripping.Description");
					}
					UpdateIconAndColor();
				});
			}
			if (typeVersion < 7)
			{
				RunSynchronously(delegate
				{
					AllowCrouch.Value = !MathX.Approximately(CharacterController.Gravity.Value, Elements.Core.float3.Zero);
				});
			}
			if (typeVersion < 8)
			{
				RunSynchronously(delegate
				{
					base.Slot.SetIdentityTransform();
				});
			}
			if (typeVersion < 9)
			{
				RunSynchronously(delegate
				{
					switch (base.Slot.Name_Field.GetLocalizedDriver()?.Key.Value)
					{
					case "Locomotion.Fly.Name":
						_defaultIcon.Value = OfficialAssets.Graphics.Icons.Locomotion.Fly;
						_defaultColor.Value = RadiantUI_Constants.Hero.CYAN;
						break;
					case "Locomotion.ZeroG.Name":
						_defaultIcon.Value = OfficialAssets.Graphics.Icons.Locomotion.ZeroG;
						_defaultColor.Value = RadiantUI_Constants.Hero.PURPLE;
						break;
					case "Locomotion.WalkRun.Name":
						_defaultIcon.Value = OfficialAssets.Graphics.Icons.Locomotion.Walk;
						_defaultColor.Value = RadiantUI_Constants.Hero.YELLOW;
						break;
					case "Locomotion.WalkRunGripping.Name":
						_defaultIcon.Value = OfficialAssets.Graphics.Icons.Locomotion.Walk;
						_defaultColor.Value = RadiantUI_Constants.Hero.YELLOW;
						break;
					}
					UpdateIconAndColor();
				});
			}
			if (typeVersion >= 10)
			{
				return;
			}
			RunSynchronously(delegate
			{
				switch (base.Slot.Name_Field.GetLocalizedDriver()?.Key.Value)
				{
				case "Locomotion.Fly.Name":
					Archetype.Value = FrooxEngine.LocomotionArchetype.Fly;
					break;
				case "Locomotion.ZeroG.Name":
					Archetype.Value = FrooxEngine.LocomotionArchetype.ZeroG;
					break;
				case "Locomotion.WalkRun.Name":
					Archetype.Value = FrooxEngine.LocomotionArchetype.Walk;
					break;
				case "Locomotion.WalkRunGripping.Name":
					Archetype.Value = FrooxEngine.LocomotionArchetype.Walk;
					break;
				}
				UpdateIconAndColor();
			});
		}

		public float ProcessFOV(float fov)
		{
			float target = 0f;
			if (ThreeAxisActive)
			{
				if (base.ThreeAxisInput != null)
				{
					target = MathX.Clamp01(base.ThreeAxisInput.Move.Value.Value.Magnitude - 1f);
				}
			}
			else if (base.NormalInput != null)
			{
				target = MathX.Clamp01(base.NormalInput.Move.Value.Value.Magnitude - 1f);
			}
			_runLerp = MathX.SmoothDamp(_runLerp, target, ref _runLerpVelocity, 50f, float.MaxValue, base.Time.Delta);
			fov += _runLerp * 10f;
			return fov;
		}

