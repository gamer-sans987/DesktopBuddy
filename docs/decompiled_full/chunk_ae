	[StructLayout(LayoutKind.Sequential, Size = 1)]
	public struct DynamicCharacterMotionFunctions : IConstraintFunctions<DynamicCharacterMotionPrestep, DynamicCharacterMotionProjection, CharacterMotionAccumulatedImpulse>
	{
		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		private static void ComputeJacobians(in Vector3Wide offsetA, in Vector3Wide offsetB, in QuaternionWide basisQuaternion, out Matrix3x3Wide basis, out Matrix2x3Wide horizontalAngularJacobianA, out Matrix2x3Wide horizontalAngularJacobianB, out Vector3Wide verticalAngularJacobianA, out Vector3Wide verticalAngularJacobianB)
		{
			Matrix3x3Wide.CreateFromQuaternion(in basisQuaternion, out basis);
			Vector3Wide.CrossWithoutOverlap(in offsetA, in basis.X, out horizontalAngularJacobianA.X);
			Vector3Wide.CrossWithoutOverlap(in offsetA, in basis.Y, out verticalAngularJacobianA);
			Vector3Wide.CrossWithoutOverlap(in offsetA, in basis.Z, out horizontalAngularJacobianA.Y);
			Vector3Wide.CrossWithoutOverlap(in basis.X, in offsetB, out horizontalAngularJacobianB.X);
			Vector3Wide.CrossWithoutOverlap(in basis.Y, in offsetB, out verticalAngularJacobianB);
			Vector3Wide.CrossWithoutOverlap(in basis.Z, in offsetB, out horizontalAngularJacobianB.Y);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void Prestep(Bodies bodies, ref TwoBodyReferences bodyReferences, int count, float dt, float inverseDt, ref BodyInertias inertiaA, ref BodyInertias inertiaB, ref DynamicCharacterMotionPrestep prestepData, out DynamicCharacterMotionProjection projection)
		{
			ComputeJacobians(in prestepData.OffsetFromCharacter, in prestepData.OffsetFromSupport, in prestepData.SurfaceBasis, out var _, out var horizontalAngularJacobianA, out var horizontalAngularJacobianB, out var verticalAngularJacobianA, out var verticalAngularJacobianB);
			Symmetric3x3Wide.MatrixSandwich(in horizontalAngularJacobianA, in inertiaA.InverseInertiaTensor, out var result);
			Symmetric3x3Wide.MatrixSandwich(in horizontalAngularJacobianB, in inertiaB.InverseInertiaTensor, out var result2);
			Symmetric2x2Wide.Add(in result, in result2, out var result3);
			Vector<float> vector = inertiaA.InverseMass + inertiaB.InverseMass;
			result3.XX += vector;
			result3.YY += vector;
			Symmetric2x2Wide.InvertWithoutOverlap(in result3, out projection.HorizontalEffectiveMass);
			Symmetric3x3Wide.VectorSandwich(in verticalAngularJacobianA, in inertiaA.InverseInertiaTensor, out var sandwich);
			Symmetric3x3Wide.VectorSandwich(in verticalAngularJacobianB, in inertiaB.InverseInertiaTensor, out var sandwich2);
			Vector<float> vector2 = sandwich + sandwich2 + vector;
			projection.VerticalEffectiveMass = Vector<float>.One / vector2;
			projection.SurfaceBasis = prestepData.SurfaceBasis;
			projection.OffsetFromCharacter = prestepData.OffsetFromCharacter;
			projection.OffsetFromSupport = prestepData.OffsetFromSupport;
			projection.TargetVelocity.X = prestepData.TargetVelocity.X;
			projection.TargetVelocity.Y = -prestepData.TargetVelocity.Y;
			projection.InertiaA = inertiaA;
			projection.InertiaB = inertiaB;
			projection.MaximumHorizontalImpulse = prestepData.MaximumHorizontalForce * dt;
			projection.MaximumVerticalForce = prestepData.MaximumVerticalForce * dt;
			projection.VerticalBiasVelocity = System.Numerics.Vector.Max(Vector<float>.Zero, prestepData.Depth * inverseDt);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		private static void ApplyHorizontalImpulse(in Matrix3x3Wide basis, in Matrix2x3Wide angularJacobianA, in Matrix2x3Wide angularJacobianB, in Vector2Wide constraintSpaceImpulse, in BodyInertias inertiaA, in BodyInertias inertiaB, ref BodyVelocities velocityA, ref BodyVelocities velocityB)
		{
			Vector3Wide.Scale(in basis.X, in constraintSpaceImpulse.X, out var result);
			Vector3Wide.Scale(in basis.Z, in constraintSpaceImpulse.Y, out var result2);
			Vector3Wide.Add(in result, in result2, out var result3);
			Vector3Wide.Scale(in result3, in inertiaA.InverseMass, out var result4);
			Vector3Wide.Add(in velocityA.Linear, in result4, out velocityA.Linear);
			Vector3Wide.Scale(in result3, in inertiaB.InverseMass, out var result5);
			Vector3Wide.Subtract(in velocityB.Linear, in result5, out velocityB.Linear);
			Matrix2x3Wide.Transform(in constraintSpaceImpulse, in angularJacobianA, out var result6);
			Symmetric3x3Wide.TransformWithoutOverlap(in result6, in inertiaA.InverseInertiaTensor, out var result7);
			Vector3Wide.Add(in velocityA.Angular, in result7, out velocityA.Angular);
			Matrix2x3Wide.Transform(in constraintSpaceImpulse, in angularJacobianB, out var result8);
			Symmetric3x3Wide.TransformWithoutOverlap(in result8, in inertiaB.InverseInertiaTensor, out var result9);
			Vector3Wide.Add(in velocityB.Angular, in result9, out velocityB.Angular);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		private static void ApplyVerticalImpulse(in Matrix3x3Wide basis, in Vector3Wide angularJacobianA, in Vector3Wide angularJacobianB, in Vector<float> constraintSpaceImpulse, in BodyInertias inertiaA, in BodyInertias inertiaB, ref BodyVelocities velocityA, ref BodyVelocities velocityB)
		{
			Vector3Wide.Scale(in basis.Y, in constraintSpaceImpulse, out var result);
			Vector3Wide.Scale(in result, in inertiaA.InverseMass, out var result2);
			Vector3Wide.Add(in velocityA.Linear, in result2, out velocityA.Linear);
			Vector3Wide.Scale(in result, in inertiaB.InverseMass, out var result3);
			Vector3Wide.Subtract(in velocityB.Linear, in result3, out velocityB.Linear);
			Vector3Wide.Scale(in angularJacobianA, in constraintSpaceImpulse, out var result4);
			Symmetric3x3Wide.TransformWithoutOverlap(in result4, in inertiaA.InverseInertiaTensor, out var result5);
			Vector3Wide.Add(in velocityA.Angular, in result5, out velocityA.Angular);
			Vector3Wide.Scale(in angularJacobianB, in constraintSpaceImpulse, out var result6);
			Symmetric3x3Wide.TransformWithoutOverlap(in result6, in inertiaB.InverseInertiaTensor, out var result7);
			Vector3Wide.Add(in velocityB.Angular, in result7, out velocityB.Angular);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void WarmStart(ref BodyVelocities velocityA, ref BodyVelocities velocityB, ref DynamicCharacterMotionProjection projection, ref CharacterMotionAccumulatedImpulse accumulatedImpulse)
		{
			ComputeJacobians(in projection.OffsetFromCharacter, in projection.OffsetFromSupport, in projection.SurfaceBasis, out var basis, out var horizontalAngularJacobianA, out var horizontalAngularJacobianB, out var verticalAngularJacobianA, out var verticalAngularJacobianB);
			ApplyHorizontalImpulse(in basis, in horizontalAngularJacobianA, in horizontalAngularJacobianB, in accumulatedImpulse.Horizontal, in projection.InertiaA, in projection.InertiaB, ref velocityA, ref velocityB);
			ApplyVerticalImpulse(in basis, in verticalAngularJacobianA, in verticalAngularJacobianB, in accumulatedImpulse.Vertical, in projection.InertiaA, in projection.InertiaB, ref velocityA, ref velocityB);
		}

		[MethodImpl(MethodImplOptions.AggressiveInlining)]
		public void Solve(ref BodyVelocities velocityA, ref BodyVelocities velocityB, ref DynamicCharacterMotionProjection projection, ref CharacterMotionAccumulatedImpulse accumulatedImpulse)
		{
			ComputeJacobians(in projection.OffsetFromCharacter, in projection.OffsetFromSupport, in projection.SurfaceBasis, out var basis, out var horizontalAngularJacobianA, out var horizontalAngularJacobianB, out var verticalAngularJacobianA, out var verticalAngularJacobianB);
			Vector2Wide a = default(Vector2Wide);
			Vector3Wide.Dot(in basis.X, in velocityA.Linear, out a.X);
			Vector3Wide.Dot(in basis.Z, in velocityA.Linear, out a.Y);
			Matrix2x3Wide.TransformByTransposeWithoutOverlap(in velocityA.Angular, in horizontalAngularJacobianA, out var result);
			Vector2Wide b = default(Vector2Wide);
			Vector3Wide.Dot(in basis.X, in velocityB.Linear, out b.X);
			Vector3Wide.Dot(in basis.Z, in velocityB.Linear, out b.Y);
			Matrix2x3Wide.TransformByTransposeWithoutOverlap(in velocityB.Angular, in horizontalAngularJacobianB, out var result2);
			Vector2Wide.Add(in result, in result2, out var result3);
			Vector2Wide.Subtract(in a, in b, out var result4);
			Vector2Wide.Add(in result3, in result4, out var result5);
			Vector2Wide.Subtract(in projection.TargetVelocity, in result5, out var result6);
			Symmetric2x2Wide.TransformWithoutOverlap(in result6, in projection.HorizontalEffectiveMass, out var result7);
			Vector2Wide b2 = accumulatedImpulse.Horizontal;
			Vector2Wide.Add(in accumulatedImpulse.Horizontal, in result7, out accumulatedImpulse.Horizontal);
			Vector2Wide.Length(in accumulatedImpulse.Horizontal, out var length);
			Vector<float> scalar = System.Numerics.Vector.Min(Vector<float>.One, projection.MaximumHorizontalImpulse / System.Numerics.Vector.Max(new Vector<float>(1E-16f), length));
			Vector2Wide.Scale(in accumulatedImpulse.Horizontal, in scalar, out accumulatedImpulse.Horizontal);
			Vector2Wide.Subtract(in accumulatedImpulse.Horizontal, in b2, out result7);
			ApplyHorizontalImpulse(in basis, in horizontalAngularJacobianA, in horizontalAngularJacobianB, in result7, in projection.InertiaA, in projection.InertiaB, ref velocityA, ref velocityB);
			Vector3Wide.Dot(in basis.Y, in velocityA.Linear, out var result8);
			Vector3Wide.Dot(in velocityA.Angular, in verticalAngularJacobianA, out var result9);
			Vector3Wide.Dot(in basis.Y, in velocityB.Linear, out var result10);
			Vector3Wide.Dot(in velocityB.Angular, in verticalAngularJacobianB, out var result11);
			Vector<float> vector = (projection.VerticalBiasVelocity - result8 + result10 - result9 - result11) * projection.VerticalEffectiveMass;
			Vector<float> vertical = accumulatedImpulse.Vertical;
			accumulatedImpulse.Vertical = System.Numerics.Vector.Min(Vector<float>.Zero, System.Numerics.Vector.Max(accumulatedImpulse.Vertical + vector, -projection.MaximumVerticalForce));
			ApplyVerticalImpulse(in basis, in verticalAngularJacobianA, in verticalAngularJacobianB, accumulatedImpulse.Vertical - vertical, in projection.InertiaA, in projection.InertiaB, ref velocityA, ref velocityB);
		}
	}
