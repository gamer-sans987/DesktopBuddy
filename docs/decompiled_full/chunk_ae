		public DynamicBoneChainManager(World world)
		{
			World = world;
			_simulate = SimulateChain;
			world.UserLeft += OnUserLeft;
			_bonesTree = new BoundingBoxTree();
			_collidersTree = new BoundingBoxTree();
			bones = new DynamicBoneChain[128];
			colliders = new ColliderData[128];
		}

		private void OnUserLeft(User user)
		{
			usersToRemove.Add(user);
		}

		private void SimulateChain(int index)
		{
			DynamicBoneChain chain = bones[index];
			if (chain.IsRemoved)
			{
				return;
			}
			try
			{
				chain.RunSimulation();
			}
			catch (Exception value)
			{
				UniLog.Log($"Exception running chain.RunSimulation()\n{chain}\n{value}", stackTrace: true);
				World.RunSynchronously(delegate
				{
					chain.Enabled = false;
				});
			}
		}

		public void Update()
		{
			totalStopwatch.Restart();
			stageStopwatch.Restart();
			if (updateScheduled)
			{
				onUpdateDone.WaitOne();
				updateScheduled = false;
			}
			if (chainsToRemove.Count > 0)
			{
				chainsToRemove.Sort((int a, int b) => -a.CompareTo(b));
				foreach (int item in chainsToRemove)
				{
					int num = _bonesTree.RemoveNode(item);
					if (num >= 0)
					{
						DynamicBoneChain dynamicBoneChain = bones[num];
						bones[item] = dynamicBoneChain;
						bones[num] = null;
						if (dynamicBoneChain != null)
						{
							dynamicBoneChain.ManagerIndex = item;
						}
					}
				}
				chainsToRemove.Clear();
			}
			UpdatePlayerColliders();
			for (int num2 = 0; num2 < _bonesTree.Count; num2++)
			{
				DynamicBoneChain dynamicBoneChain2 = bones[num2];
				if (dynamicBoneChain2.IsRemoved)
				{
					continue;
				}
				try
				{
					World.UpdateManager.NestCurrentlyUpdating(dynamicBoneChain2);
					dynamicBoneChain2.Prepare();
				}
				catch (Exception value)
				{
					UniLog.Log($"Exception running chain.Prepare()\n{dynamicBoneChain2}\n{value}", stackTrace: true);
					dynamicBoneChain2.Enabled = false;
				}
				finally
				{
					World.UpdateManager.PopCurrentlyUpdating(dynamicBoneChain2);
				}
			}
			PrepareTime = stageStopwatch.GetElapsedMilliseconds();
			stageStopwatch.Restart();
			CollisionHandler handler = new CollisionHandler
			{
				colliders = colliders,
				bones = bones
			};
			_bonesTree.GetOverlaps(_collidersTree, ref handler);
			LastCollisions = handler.totalCollisions;
			OverlapsTime = stageStopwatch.GetElapsedMilliseconds();
			stageStopwatch.Restart();
			Parallel.For(0, _bonesTree.Count, _simulate);
			SimulationTime = stageStopwatch.GetElapsedMilliseconds();
			stageStopwatch.Restart();
			for (int num3 = 0; num3 < _bonesTree.Count; num3++)
			{
				DynamicBoneChain dynamicBoneChain3 = bones[num3];
				if (dynamicBoneChain3.IsRemoved)
				{
					continue;
				}
				try
				{
					World.UpdateManager.NestCurrentlyUpdating(dynamicBoneChain3);
					dynamicBoneChain3.FinishSimulation();
					UpdateBounds(dynamicBoneChain3, ref dynamicBoneChain3.GlobalBounds);
				}
				catch (Exception value2)
				{
					UniLog.Log($"Exception running chain.RunSimulation()\n{dynamicBoneChain3}\n{value2}", stackTrace: true);
					dynamicBoneChain3.Enabled = false;
				}
				finally
				{
					World.UpdateManager.PopCurrentlyUpdating(dynamicBoneChain3);
				}
			}
			updateScheduled = true;
			Engine.WorkProcessor.Enqueue(UpdateAccelerationStructures, WorkType.HighPriority);
			FinishTime = stageStopwatch.GetElapsedMilliseconds();
			stageStopwatch.Stop();
			totalStopwatch.Stop();
			TotalUpdateTime = totalStopwatch.GetElapsedMilliseconds();
		}

		internal void UpdateBounds(DynamicBoneChain chain, ref Elements.Core.BoundingBox bounds)
		{
			if (bounds.IsValid)
			{
				_bonesTree.UpdateNode(chain.ManagerIndex, bounds);
			}
		}

		public void UpdatePlayerColliders()
		{
			foreach (User item in usersToRemove)
			{
				if (userColliders.TryGetValue(item, out UserColliders value))
				{
					value.RemoveAllColliders();
					userColliders.Remove(item);
				}
			}
			usersToRemove.Clear();
			foreach (User allUser in World.AllUsers)
			{
				if (allUser.HeadDevice != HeadOutputDevice.Headless && !allUser.IsCollisionLocallyBlocked)
				{
					if (!userColliders.TryGetValue(allUser, out UserColliders value2))
					{
						value2 = new UserColliders(this, allUser);
						userColliders.Add(allUser, value2);
					}
					if (allUser.IsPresentInWorld)
					{
						value2.Update();
					}
					else
					{
						value2.RemoveAllColliders();
					}
				}
			}
		}

		public void UpdateAccelerationStructures()
		{
			for (int i = 0; i < _collidersTree.Count; i++)
			{
				ref ColliderData reference = ref colliders[i];
				_collidersTree.UpdateNode(i, Elements.Core.BoundingBox.CenterRadius(Collider.ClampPosition(MathX.FilterInvalid(reference.position)), MathX.Clamp(MathX.FilterInvalid(reference.radius), 0f, 1000000f)));
			}
			_bonesTree.RefitAndRefine();
			_collidersTree.RefitAndRefine();
			onUpdateDone.Set();
		}

		private ref ColliderData GetColliderData(int index)
		{
			return ref colliders[index];
		}

		private int RegisterCollider(UserColliders handler)
		{
			int num = _collidersTree.CreateNode(new Elements.Core.BoundingBox(Elements.Core.float3.Zero));
			colliders = EnsureStorage(colliders, num);
			ref ColliderData reference = ref colliders[num];
			reference.radius = 0f;
			reference.position = Elements.Core.float3.Zero;
			reference.owner = handler;
			return num;
		}

		public void UnregisterCollider(int index)
		{
			if (index < 0)
			{
				throw new ArgumentOutOfRangeException("index");
			}
			int num = _collidersTree.RemoveNode(index);
			if (num >= 0)
			{
				colliders[index] = colliders[num];
				colliders[num] = default(ColliderData);
				colliders[index].owner.MoveIndex(num, index);
			}
		}

		public void RegisterChain(DynamicBoneChain chain)
		{
			int num = _bonesTree.CreateNode(new Elements.Core.BoundingBox(Elements.Core.float3.Zero));
			bones = EnsureStorage(bones, num);
			bones[num] = chain;
			chain.ManagerIndex = num;
		}

		private static T[] EnsureStorage<T>(T[] array, int index)
		{
			if (index >= array.Length)
			{
				return array.EnsureSize(MathX.Max(array.Length * 2, index + 1), keepData: true);
			}
			return array;
		}

		public void UnregisterChain(DynamicBoneChain chain)
		{
			if (chain.ManagerIndex < 0)
			{
				throw new InvalidOperationException("Dynamic Bone Chain isn't registered: " + chain);
			}
			bones[chain.ManagerIndex] = null;
			chainsToRemove.Add(chain.ManagerIndex);
			chain.ManagerIndex = -1;
		}
	}
