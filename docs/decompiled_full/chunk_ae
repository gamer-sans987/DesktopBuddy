	[Category(new string[] { "Transform/Interaction" })]
	public class KnobControl : Component
	{
		public readonly SyncRef<IField<float>> Target;

		public readonly SyncDelegate<Action<float>> Callback;

		public readonly Sync<Elements.Core.float3> RotationAxis;

		public readonly Sync<float> Rate;

		public readonly Sync<float> Min;

		public readonly Sync<float> Max;

		protected readonly Sync<float> _lastRotation;

		protected readonly Sync<Elements.Core.float3> _lastAxis;

		protected readonly SyncRef<User> _lastUser;

		private double lastChangedTime;

		protected override void OnAwake()
		{
			base.Slot.Rotation_Field.OnValueChange += RotationChanged;
			RotationAxis.Value = Elements.Core.float3.Up;
			Rate.Value = 1f;
			Min.Value = float.NegativeInfinity;
			Max.Value = float.PositiveInfinity;
		}

		protected override void OnDestroy()
		{
			base.Slot.Rotation_Field.OnValueChange -= RotationChanged;
		}

		private void RotationChanged(IField<Elements.Core.floatQ> field)
		{
			if (!base.World.CanMakeSynchronousChanges || (_lastUser.Target != null && !_lastUser.Target.IsLocalUser))
			{
				return;
			}
			_lastUser.Target = base.LocalUser;
			lastChangedTime = base.Time.WorldTime;
			float num = ComputeRotation();
			if (MathX.Approximately(num, _lastRotation.Value))
			{
				return;
			}
			if (_lastAxis.Value != (Elements.Core.float3)RotationAxis)
			{
				_lastAxis.Value = RotationAxis;
			}
			else
			{
				float num2 = MathX.DeltaAngle(_lastRotation.Value, num);
				num2 *= (float)Rate * 0.0027777778f;
				if (!MathX.Approximately(num2, 0f))
				{
					if (Target.Target != null)
					{
						Target.Target.Value = MathX.Clamp(Target.Target.Value + num2, Min, Max);
					}
					Callback.Target?.Invoke(num2);
				}
			}
			_lastRotation.Value = num;
		}

		protected override void OnCommonUpdate()
		{
			if (_lastUser.Target != null && _lastUser.Target.IsLocalUser && base.Time.WorldTime > lastChangedTime)
			{
				_lastUser.Target = null;
			}
		}

		private float ComputeRotation()
		{
			return MathX.AngleAroundAxis(base.Slot.LocalRotation, RotationAxis.Value);
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Target = new SyncRef<IField<float>>();
			Callback = new SyncDelegate<Action<float>>();
			RotationAxis = new Sync<Elements.Core.float3>();
			Rate = new Sync<float>();
			Min = new Sync<float>();
			Max = new Sync<float>();
			_lastRotation = new Sync<float>();
			_lastAxis = new Sync<Elements.Core.float3>();
			_lastUser = new SyncRef<User>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Target, 
				4 => Callback, 
				5 => RotationAxis, 
				6 => Rate, 
				7 => Min, 
				8 => Max, 
				9 => _lastRotation, 
				10 => _lastAxis, 
				11 => _lastUser, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static KnobControl __New()
		{
			return new KnobControl();
		}
	}
