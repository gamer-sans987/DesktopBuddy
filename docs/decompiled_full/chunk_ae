	public class AppThreadDispatcher : IThreadDispatcher, IDisposable
	{
		private World world;

		private BepuUtilities.Memory.BufferPool[] bufferPools;

		private AutoResetEvent _continue;

		private int _activeJobs;

		public int ThreadCount { get; private set; }

		public AppThreadDispatcher(World world, int count)
		{
			ThreadCount = count;
			this.world = world;
			bufferPools = new BepuUtilities.Memory.BufferPool[ThreadCount];
			for (int i = 0; i < bufferPools.Length; i++)
			{
				bufferPools[i] = new BepuUtilities.Memory.BufferPool();
			}
			_continue = new AutoResetEvent(initialState: false);
		}

		public void DispatchWorkers(Action<int> workerBody)
		{
			_activeJobs = ThreadCount;
			for (int i = 1; i < ThreadCount; i++)
			{
				int _index = i;
				world.Engine.WorkProcessor.Enqueue(delegate
				{
					workerBody(_index);
					if (Interlocked.Decrement(ref _activeJobs) == 0)
					{
						_continue.Set();
					}
				}, WorkType.HighPriority, wakeUp: false);
			}
			if (ThreadCount > 1)
			{
				world.Engine.WorkProcessor.WakeUp(WorkType.HighPriority, ThreadCount - 1);
			}
			workerBody(0);
			if (Interlocked.Decrement(ref _activeJobs) != 0)
			{
				_continue.WaitOne();
			}
		}

		public void Dispose()
		{
			GC.SuppressFinalize(this);
			for (int i = 0; i < bufferPools.Length; i++)
			{
				bufferPools[i].Clear();
			}
			bufferPools = null;
			_continue.Dispose();
		}

		public BepuUtilities.Memory.BufferPool GetThreadMemoryPool(int workerIndex)
		{
			return bufferPools[workerIndex];
		}
	}
	public class AppTimestepper : ITimestepper
	{
		private Tree.RefitAndRefineMultithreadedContext activeRefineContext;

		private int frameIndex;

		public event TimestepperStageHandler BeforeCollisionDetection;

		public event TimestepperStageHandler CollisionsDetected;

		public AppTimestepper()
		{
			activeRefineContext = new Tree.RefitAndRefineMultithreadedContext();
		}

		public void Timestep(Simulation simulation, float dt, IThreadDispatcher threadDispatcher = null)
		{
			simulation.Sleep(threadDispatcher);
			simulation.IntegrateVelocitiesBoundsAndInertias(dt, threadDispatcher);
			this.BeforeCollisionDetection?.Invoke(dt, threadDispatcher);
			simulation.Profiler.Start(simulation.BroadPhase);
			if (frameIndex == int.MaxValue)
			{
				frameIndex = 0;
			}
			if (threadDispatcher != null)
			{
				activeRefineContext.RefitAndRefine(ref simulation.BroadPhase.ActiveTree, simulation.BufferPool, threadDispatcher, frameIndex);
			}
			else
			{
				simulation.BroadPhase.ActiveTree.RefitAndRefine(simulation.BufferPool, frameIndex);
			}
			simulation.Profiler.Start(simulation.BroadPhaseOverlapFinder);
			simulation.BroadPhaseOverlapFinder.DispatchOverlaps(dt, threadDispatcher);
			simulation.Profiler.End(simulation.BroadPhaseOverlapFinder);
			simulation.Profiler.Start(simulation.NarrowPhase);
			simulation.NarrowPhase.Flush(threadDispatcher);
			simulation.Profiler.End(simulation.NarrowPhase);
			frameIndex++;
			simulation.Profiler.End(simulation.BroadPhase);
			this.CollisionsDetected?.Invoke(dt, threadDispatcher);
			simulation.Solve(dt, threadDispatcher);
			simulation.IntegratePoses(dt, threadDispatcher);
			simulation.IncrementallyOptimizeDataStructures(threadDispatcher);
		}
	}
