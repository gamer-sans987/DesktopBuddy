	[DataModelType]
	public static class ContextMenuExtensions
	{
		public static ContextMenu GetUserContextMenu(this User user)
		{
			return user?.Root?.GetRegisteredComponent<ContextMenu>();
		}

		public static bool IsContextMenuOpen(this User user)
		{
			ContextMenu userContextMenu = user.GetUserContextMenu();
			if (userContextMenu == null)
			{
				return true;
			}
			return userContextMenu.MenuState != ContextMenu.State.Closed;
		}

		public static async Task<ContextMenu> ToggleContextMenu(this User user, IWorldElement summoner, Slot pointer, ContextMenuOptions options = default(ContextMenuOptions))
		{
			ContextMenu userContextMenu = user.GetUserContextMenu();
			if (userContextMenu != null)
			{
				if (userContextMenu.MenuState != ContextMenu.State.Closed && userContextMenu.CurrentSummoner == summoner)
				{
					userContextMenu.Close();
					return null;
				}
				return await user.OpenContextMenu(summoner, pointer, options);
			}
			return null;
		}

		public static async Task<ContextMenu> OpenContextMenu(this User user, IWorldElement summoner, Slot pointer, ContextMenuOptions options = default(ContextMenuOptions))
		{
			ContextMenu menu = user.GetUserContextMenu();
			if (menu != null)
			{
				InteractionHandler commonTool = pointer.GetComponentInParents<InteractionHandler>() ?? pointer.GetComponentInParents<InteractionHandlerRelay>()?.CommonTool.Target;
				if (commonTool != null)
				{
					pointer = commonTool.PointReference;
				}
				if (await menu.OpenMenu(summoner, pointer, options))
				{
					if (!options.keepPosition)
					{
						if (commonTool != null)
						{
							commonTool.StartTask(async delegate
							{
								await commonTool.PositionContextMenu(menu);
							});
						}
						else
						{
							float num = 0.2f;
							menu.Slot.GlobalPosition = pointer.LocalPointToGlobal(Elements.Core.float3.Forward * num);
							Elements.Core.float3 to = (menu.Slot.GlobalPosition - user.Root.HeadPosition).Normalized;
							menu.Slot.GlobalRotation = Elements.Core.floatQ.LookRotation(MathX.Lerp(pointer.Forward, in to, 0.5f), user.Root.Slot.Up);
						}
					}
					return menu;
				}
			}
			return null;
		}

		public static Task<bool> ContextMenuConfirm(this User user, IWorldElement summoner, Slot pointer, LocaleString actionName, Uri actionIcon, Elements.Core.colorX actionColor, ButtonEventHandler actionCallback, bool hidden = false)
		{
			return user.World.Coroutines.StartTask(async delegate
			{
				ContextMenu contextMenu = await user.OpenContextMenu(summoner, pointer, new ContextMenuOptions
				{
					disableFlick = true,
					hidden = hidden
				});
				if (contextMenu == null)
				{
					return false;
				}
				TaskCompletionSource<bool> completion = new TaskCompletionSource<bool>();
				ContextMenuItem contextMenuItem = contextMenu.AddItem(in actionName, actionIcon, new Elements.Core.colorX?(actionColor), actionCallback);
				ContextMenuItem contextMenuItem2 = contextMenu.AddRefItem("General.Cancel".AsLocaleKey(), OfficialAssets.Graphics.Icons.General.CancelCircle, new Elements.Core.colorX?(Elements.Core.colorX.Gray), OnCancelMenu, summoner);
				contextMenuItem.Button.LocalPressed += delegate
				{
					completion.TrySetResult(result: true);
				};
				contextMenuItem2.Button.LocalPressed += delegate
				{
					completion.TrySetResult(result: false);
				};
				return await completion.Task;
			});
		}

