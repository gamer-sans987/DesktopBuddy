	public class FootstepSoundSplatmapSplitter : Component, IFootstepSoundMaterial, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public readonly AssetRef<Texture2D> SplatMap;

		public readonly SyncRef<IFootstepSoundMaterial> R_SoundMaterial;

		public readonly SyncRef<IFootstepSoundMaterial> G_SoundMaterial;

		public readonly SyncRef<IFootstepSoundMaterial> B_SoundMaterial;

		public readonly SyncRef<IFootstepSoundMaterial> A_SoundMaterial;

		public readonly Sync<bool> BlendSounds;

		[Range(0f, 1f, "0.00")]
		public readonly Sync<float> MinimumThreshold;

		[Range(0f, 2f, "0.00")]
		public readonly Sync<float> R_Weight;

		[Range(0f, 2f, "0.00")]
		public readonly Sync<float> G_Weight;

		[Range(0f, 2f, "0.00")]
		public readonly Sync<float> B_Weight;

		[Range(0f, 2f, "0.00")]
		public readonly Sync<float> A_Weight;

		private bool _isProcessing;

		private IFootstepSoundMaterial GetSoundMaterial(int index)
		{
			return index switch
			{
				0 => R_SoundMaterial.Target, 
				1 => G_SoundMaterial.Target, 
				2 => B_SoundMaterial.Target, 
				3 => A_SoundMaterial.Target, 
				_ => null, 
			};
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			MinimumThreshold.Value = 0.1f;
			R_Weight.Value = 1f;
			G_Weight.Value = 1f;
			B_Weight.Value = 1f;
			A_Weight.Value = 1f;
		}

		public void PlayFootstepClip(Chirality side, Elements.Core.float3 point, Elements.Core.float3 impactVelocity, bool hasLanded, RaycastHit hit, float weight)
		{
			Bitmap2D bitmap2D = SplatMap.Asset?.Data;
			if (bitmap2D == null || !bitmap2D.Format.SupportsRead() || _isProcessing)
			{
				return;
			}
			_isProcessing = true;
			try
			{
				Elements.Assets.Triangle triangle = hit.GetTriangle();
				Elements.Core.float2 @float = triangle.InterpolateUV0(triangle.GetBarycentricCoordinate(hit.Collider.Slot.GlobalPointToLocal(in hit.Point)));
				Elements.Core.color color = bitmap2D.SampleUV(new Elements.Core.float2(@float.x, 1f - @float.y), WrapMode.Repeat);
				float num = 0f;
				int index = -1;
				Span<float> span = stackalloc float[4];
				float num2 = 0f;
				for (int i = 0; i < 4; i++)
				{
					float num3 = color[i];
					float num4 = num3;
					num3 = num4 * i switch
					{
						0 => R_Weight.Value, 
						1 => G_Weight.Value, 
						2 => B_Weight.Value, 
						3 => A_Weight.Value, 
						_ => 0f, 
					};
					if (!(num3 < MinimumThreshold.Value))
					{
						span[i] = num3;
						num2 += weight;
						if (num3 > num)
						{
							num = num3;
							index = i;
						}
					}
				}
				if (BlendSounds.Value)
				{
					float num5 = 1f / num2;
					for (int j = 0; j < 4; j++)
					{
						if (span[j] != 0f)
						{
							GetSoundMaterial(j)?.PlayFootstepClip(side, point, impactVelocity, hasLanded, hit, span[j] * num5 * weight);
						}
					}
				}
				else
				{
					GetSoundMaterial(index)?.PlayFootstepClip(side, point, impactVelocity, hasLanded, hit);
				}
			}
			finally
			{
				_isProcessing = false;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			SplatMap = new AssetRef<Texture2D>();
			R_SoundMaterial = new SyncRef<IFootstepSoundMaterial>();
			G_SoundMaterial = new SyncRef<IFootstepSoundMaterial>();
			B_SoundMaterial = new SyncRef<IFootstepSoundMaterial>();
			A_SoundMaterial = new SyncRef<IFootstepSoundMaterial>();
			BlendSounds = new Sync<bool>();
			MinimumThreshold = new Sync<float>();
			R_Weight = new Sync<float>();
			G_Weight = new Sync<float>();
			B_Weight = new Sync<float>();
			A_Weight = new Sync<float>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => SplatMap, 
				4 => R_SoundMaterial, 
				5 => G_SoundMaterial, 
				6 => B_SoundMaterial, 
				7 => A_SoundMaterial, 
				8 => BlendSounds, 
				9 => MinimumThreshold, 
				10 => R_Weight, 
				11 => G_Weight, 
				12 => B_Weight, 
				13 => A_Weight, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static FootstepSoundSplatmapSplitter __New()
		{
			return new FootstepSoundSplatmapSplitter();
		}
	}
