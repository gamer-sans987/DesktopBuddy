	public static class RaycastExtensions
	{
		public static void PortalRaycastAll(this PhysicsManager physics, in Elements.Core.float3 origin, in Elements.Core.float3 direction, float maxDistance, List<RaycastHit> results, List<RaycastPortalHit> portalHits = null, Func<ICollider, int, bool> filter = null, Func<RaycastHit, int, bool> hitFilter = null, int maxDepth = 10, bool hitTriggers = false, bool infiniteDistanceThroughPortal = false, int depth = 0)
		{
			int count = results.Count;
			physics.RaycastAll(in origin, in direction, maxDistance, results, (ICollider c) => filter?.Invoke(c, depth) ?? true, hitTriggers);
			if (hitFilter != null)
			{
				for (int num = results.Count - 1; num >= count; num--)
				{
					if (!hitFilter(results[num], depth))
					{
						results.RemoveAt(num);
					}
				}
			}
			if (maxDepth <= 0 || results.Count <= count)
			{
				return;
			}
			RaycastHit hit = results[count];
			IRaycastPortal component = hit.Collider.Slot.GetComponent<IRaycastPortal>();
			if (component == null || !component.TransferRay(in hit, in direction, out var origin2, out var direction2, ref filter, ref hitTriggers))
			{
				return;
			}
			float maxDistance2 = (infiniteDistanceThroughPortal ? float.MaxValue : (maxDistance - hit.Distance));
			if (PhysicsManager.IsValidRaycast(in origin2, in direction2, maxDistance2))
			{
				results.RemoveRange(count, results.Count - count);
				portalHits?.Add(new RaycastPortalHit(component, in hit, in origin2, in direction2));
				physics.PortalRaycastAll(in origin2, in direction2, maxDistance2, results, portalHits, filter, hitFilter, maxDepth - 1, hitTriggers, infiniteDistanceThroughPortal: false, depth + 1);
				for (int num2 = count; num2 < results.Count; num2++)
				{
					RaycastHit value = results[num2];
					value.Distance += hit.Distance;
					results[num2] = value;
				}
			}
		}
	}
