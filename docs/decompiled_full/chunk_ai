					Uri uri = ((!Channels.Value.x) ? null : (await base.Engine.LocalDB.SaveAssetAsync(texture).ConfigureAwait(continueOnCapturedContext: false)));
					Uri rAsset = uri;
					uri = ((!Channels.Value.y) ? null : (await base.Engine.LocalDB.SaveAssetAsync(gBitmap).ConfigureAwait(continueOnCapturedContext: false)));
					Uri gAsset = uri;
					uri = ((!Channels.Value.z) ? null : (await base.Engine.LocalDB.SaveAssetAsync(bBitmap).ConfigureAwait(continueOnCapturedContext: false)));
					Uri bAsset = uri;
					uri = ((!Channels.Value.w) ? null : (await base.Engine.LocalDB.SaveAssetAsync(aBitmap).ConfigureAwait(continueOnCapturedContext: false)));
					Uri aAsset = uri;
					await default(ToWorld);
					RTexture.Target = assetsSlot.AttachTexture(rAsset);
					GTexture.Target = assetsSlot.AttachTexture(gAsset);
					BTexture.Target = assetsSlot.AttachTexture(bAsset);
					ATexture.Target = assetsSlot.AttachTexture(aAsset);
					IsProcessing.Value = false;
				}
			}
		}

