			Elements.Core.float3 from = base.Slot.LocalScale;
			Elements.Core.float3 to = base.Slot.Parent.GlobalScaleToLocal(scale) * Elements.Core.float3.One;
			Elements.Core.float3 feetPosition;
			if (time > 0f)
			{
