		private async Task UpdateLoadStatus()
		{
			do
			{
				await Task.Delay(200);
				await default(ToWorld);
				int num = 0;
				int num2 = 0;
				foreach (MeshRenderer renderer in Renderers)
				{
					if (renderer != null)
					{
						num++;
						if (renderer.IsLoaded)
						{
							num2++;
						}
					}
				}
				IsLoaded.Value = num == num2;
				LoadProgress.Value = (float)num2 / (float)num;
				ProgressWeight.Value = num;
			}
			while (!IsLoaded);
		}

