		{
			if (!string.IsNullOrWhiteSpace(_lastSessionId))
			{
				base.Engine.Cloud.Sessions.UnregisterSessionIdChanges(_lastSessionId, OnSessionChanged);
			}
			_lastSessionId = null;
		}

		private bool LastActiveSessionDifferent()
		{
			if (_lastActiveSessions == null)
			{
				return true;
			}
			if (_lastActiveSessions.Count != SessionURLs.Count)
			{
				return true;
			}
			for (int i = 0; i < _lastActiveSessions.Count; i++)
