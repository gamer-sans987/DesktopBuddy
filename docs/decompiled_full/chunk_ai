		public void MarkProtected(bool forcePersistent)
		{
			IsProtected = true;
			ForcedPersistent = forcePersistent;
			if (Parent != base.World.RootSlot && Parent != null)
			{
				Parent.MarkProtected(forcePersistent);
			}
