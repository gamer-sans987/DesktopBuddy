		public Slot FindParent(Predicate<Slot> filter, int maxDepth = -1)
		{
			Slot parent = Parent;
			if (parent == null)
			{
				return null;
			}
			do
			{
				if (filter(parent))
				{
					return parent;
				}
				if (maxDepth == 0)
				{
					return null;
				}
				if (maxDepth > 0)
				{
					maxDepth--;
				}
				parent = parent.Parent;
			}
			while (parent != null);
