	public class UsersAssetLoadProgress<A> : Component where A : class, IAsset
	{
		public class LoadProgress : SyncObject
		{
			public readonly UserRef User;

			[Range(0f, 1f, "0.00")]
			public readonly Sync<float?> DownloadProgress;

			public readonly Sync<AssetLoadState> LoadState;

			protected override void InitializeSyncMembers()
			{
				base.InitializeSyncMembers();
				User = new UserRef();
				DownloadProgress = new Sync<float?>();
				LoadState = new Sync<AssetLoadState>();
			}

			public override ISyncMember GetSyncMember(int index)
			{
				return index switch
				{
					0 => User, 
					1 => DownloadProgress, 
					2 => LoadState, 
					_ => throw new ArgumentOutOfRangeException(), 
				};
			}

			public static UsersAssetLoadProgress<A>.LoadProgress __New()
			{
				return new LoadProgress();
			}
		}

		public readonly AssetRef<A> Asset;

		[NonPersistent]
		public readonly SyncList<LoadProgress> ProgressInfo;

		public readonly RawOutput<int> TotalUsers;

		public readonly RawOutput<int> UsersNotLoaded;

		public readonly RawOutput<int> UsersLoading;

		public readonly RawOutput<int> UsersPartiallyLoaded;

		public readonly RawOutput<int> UsersFullyLoaded;

		public readonly RawOutput<int> UsersFailedToLoad;

		private LoadProgress _cachedProgress;

		protected override void OnAwake()
		{
			base.OnAwake();
			Asset.ListenToAssetUpdates = true;
		}

		protected override void OnChanges()
		{
			LoadProgress progressForUser = GetProgressForUser(base.LocalUser);
			A asset = Asset.Asset;
			progressForUser.LoadState.Value = asset?.LoadState ?? AssetLoadState.Unloaded;
			if (progressForUser.LoadState.Value == AssetLoadState.FullyLoaded)
			{
				progressForUser.DownloadProgress.Value = 1f;
			}
			else
			{
				progressForUser.DownloadProgress.Value = asset?.DownloadProgress;
				if (asset != null)
				{
					RunInSeconds(0.5f, base.MarkChangeDirty);
				}
			}
			Dictionary<User, LoadProgress> dictionary = Pool.BorrowDictionary<User, LoadProgress>();
			foreach (LoadProgress item in ProgressInfo)
			{
				if (item.User.Target != null)
				{
					dictionary[item.User.Target] = item;
				}
			}
			int num = 0;
			int num2 = 0;
			int num3 = 0;
			int num4 = 0;
			int num5 = 0;
			int num6 = 0;
			foreach (User allUser in base.World.AllUsers)
			{
				num++;
				if (!dictionary.TryGetValue(allUser, out var value))
				{
					num2++;
					continue;
				}
				switch (value.LoadState.Value)
				{
				case AssetLoadState.Created:
				case AssetLoadState.LoadStarted:
					num3++;
					break;
				case AssetLoadState.PartiallyLoaded:
					num4++;
					break;
				case AssetLoadState.FullyLoaded:
					num5++;
					break;
				case AssetLoadState.Failed:
					num6++;
					break;
				default:
					num2++;
					break;
				}
			}
			Pool.Return(ref dictionary);
			TotalUsers.Value = num;
			UsersNotLoaded.Value = num2;
			UsersLoading.Value = num3;
			UsersPartiallyLoaded.Value = num4;
			UsersFullyLoaded.Value = num5;
			UsersFailedToLoad.Value = num6;
		}

		public LoadProgress GetProgressForUser(User user, bool addIfNotExists = true)
		{
			if (user.IsLocalUser && _cachedProgress != null && !_cachedProgress.IsRemoved)
			{
				return _cachedProgress;
			}
			foreach (LoadProgress item in ProgressInfo)
			{
				if (item.User.Target == user)
				{
					_cachedProgress = item;
					return item;
				}
			}
			if (addIfNotExists)
			{
				_cachedProgress = ProgressInfo.Add();
				_cachedProgress.User.Target = user;
				return _cachedProgress;
			}
			return null;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Asset = new AssetRef<A>();
			ProgressInfo = new SyncList<LoadProgress>();
			ProgressInfo.MarkNonPersistent();
			TotalUsers = new RawOutput<int>();
			UsersNotLoaded = new RawOutput<int>();
			UsersLoading = new RawOutput<int>();
			UsersPartiallyLoaded = new RawOutput<int>();
			UsersFullyLoaded = new RawOutput<int>();
			UsersFailedToLoad = new RawOutput<int>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Asset, 
				4 => ProgressInfo, 
				5 => TotalUsers, 
				6 => UsersNotLoaded, 
				7 => UsersLoading, 
				8 => UsersPartiallyLoaded, 
				9 => UsersFullyLoaded, 
				10 => UsersFailedToLoad, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static UsersAssetLoadProgress<A> __New()
		{
			return new UsersAssetLoadProgress<A>();
		}
	}
