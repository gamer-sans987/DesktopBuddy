	{
		public enum CloseAction
		{
			LeaveOrOpenCloseScreen,
			Discard,
			Save,
			SaveAs
		}

		public World TargetWorld;

		public readonly Sync<CloseAction> Action;

		public readonly Sync<bool> WaitingConfirm;

		public readonly SyncDelegate<Action> OnClosed;

		public World ActualTargetWorld
		{
			get
			{
				World world = TargetWorld;
				if (world == null)
				{
					Engine engine = base.Engine;
					if (engine == null)
					{
						return null;
					}
					WorldManager worldManager = engine.WorldManager;
					if (worldManager == null)
					{
						return null;
					}
					world = worldManager.FocusedWorld;
				}
				return world;
			}
		}

		public void Pressed(IButton button, ButtonEventData eventData)
		{
			if (base.World != Userspace.UserspaceWorld)
			{
				return;
			}
			World actualTargetWorld = ActualTargetWorld;
			if (actualTargetWorld == null)
			{
				return;
			}
			Userspace.CanSave(actualTargetWorld);
			bool num = actualTargetWorld == Userspace.LocalHome;
			bool flag = Userspace.ShouldSave(actualTargetWorld);
			if (num)
			{
				return;
			}
			switch (Action.Value)
			{
			case CloseAction.LeaveOrOpenCloseScreen:
				if (flag)
				{
					base.Slot.OpenModalOverlay(new Elements.Core.float2(0.75f, 0.75f)).Slot.AttachComponent<WorldCloseDialog>().TargetWorld = actualTargetWorld;
				}
				else if (!WaitingConfirm.Value)
				{
					WaitingConfirm.Value = true;
					RunInSeconds(2f, delegate
					{
						WaitingConfirm.Value = false;
					});
				}
				else
				{
					WaitingConfirm.Value = false;
					Userspace.ExitWorld(actualTargetWorld);
					OnClosed.Target?.Invoke();
				}
				break;
			case CloseAction.Discard:
				if (actualTargetWorld.HasUnsavedChanges() && !WaitingConfirm.Value)
				{
					WaitingConfirm.Value = true;
					RunInSeconds(2f, delegate
					{
						WaitingConfirm.Value = false;
					});
				}
				else
				{
					WaitingConfirm.Value = false;
					Userspace.ExitWorld(actualTargetWorld);
					OnClosed.Target?.Invoke();
				}
				break;
			case CloseAction.Save:
				Userspace.SaveWorldAuto(actualTargetWorld, SaveType.Overwrite, exitOnSave: true);
				OnClosed.Target?.Invoke();
				break;
			case CloseAction.SaveAs:
				Userspace.SaveWorldAuto(actualTargetWorld, SaveType.SaveAs, exitOnSave: true);
				OnClosed.Target?.Invoke();
				break;
			}
		}

