	public readonly struct DependencyCollection
	{
		private readonly HashSet<IWorldElement> elements;

		private readonly HashSet<Slot> hierarchy;

		private readonly HashSet<Slot> rootHierarchy;

		public readonly Slot root;

		public readonly bool assetOnly;

		public readonly bool saveNonPersistent;

		public DependencyCollection(Slot root, bool assetOnly, bool saveNonPersistent, HashSet<Slot> rootHierarchy)
		{
			this.root = root;
			this.assetOnly = assetOnly;
			this.saveNonPersistent = saveNonPersistent;
			this.rootHierarchy = rootHierarchy;
			elements = Pool.BorrowHashSet<IWorldElement>();
			hierarchy = Pool.BorrowHashSet<Slot>();
		}

		public bool IsInRootHierarchy(IWorldElement element)
		{
			return rootHierarchy.Contains(element.FindNearestParent<Slot>());
		}

		public bool IsInDependencyHierarchy(Slot slot)
		{
			return hierarchy.Contains(slot);
		}

		public void AddDependencySlot(Slot slot)
		{
			HashSet<Slot> slotHierarchy = Pool.BorrowHashSet<Slot>();
			slot.GenerateHierarchy(slotHierarchy);
			elements.RemoveWhere((IWorldElement e) => slotHierarchy.Contains(e.FindNearestParent<Slot>()));
			elements.Add(slot);
			foreach (Slot item in slotHierarchy)
			{
				hierarchy.Add(item);
			}
			Pool.Return(ref slotHierarchy);
		}

		public bool Contains(IWorldElement element)
		{
			return elements.Contains(element);
		}

		public bool AddElement(IWorldElement element)
		{
			if (elements.Add(element))
			{
				if (element is Slot slot)
				{
					slot.GenerateHierarchy(hierarchy);
				}
				return true;
			}
			return false;
		}

		public static HashSet<IWorldElement> GetDependenciesAndReturn(ref DependencyCollection collection)
		{
			HashSet<IWorldElement> result = collection.elements;
			HashSet<Slot> hashSet = collection.hierarchy;
			Pool.Return(ref hashSet);
			collection = default(DependencyCollection);
			return result;
		}
