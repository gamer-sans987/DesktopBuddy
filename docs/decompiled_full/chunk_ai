		[SyncMethod(typeof(Delegate), null)]
		private void OnCreate(IButton button, ButtonEventData eventData)
		{
			Create(button);
		}

		public void Create(IButton button = null)
		{
			if (button != null)
			{
				button.Enabled = false;
				button.LabelText = this.GetLocalized("General.Creating");
			}
			StartTask(async delegate
			{
				await default(ToBackground);
				try
				{
					List<Bitmap2D> bitmaps = new List<Bitmap2D>();
					List<Bitmap2D> list = bitmaps;
					list.Add(await (PosX.Asset?.GetOriginalTextureData()));
					list = bitmaps;
					list.Add(await (NegX.Asset?.GetOriginalTextureData()));
					list = bitmaps;
					list.Add(await (PosY.Asset?.GetOriginalTextureData()));
					list = bitmaps;
					list.Add(await (NegY.Asset?.GetOriginalTextureData()));
					list = bitmaps;
					list.Add(await (PosZ.Asset?.GetOriginalTextureData()));
					list = bitmaps;
					list.Add(await (NegZ.Asset?.GetOriginalTextureData()));
					int num = 0;
					TextureFormat? textureFormat = null;
					bool mipmaps = true;
					foreach (Bitmap2D item in bitmaps)
					{
						if (item != null)
						{
							num = MathX.Max(num, item.Size.x, item.Size.y);
							if (!textureFormat.HasValue)
							{
								textureFormat = item.Format;
							}
							if (!item.HasMipMaps)
							{
								mipmaps = false;
							}
						}
					}
					if (num == 0)
					{
						await default(ToWorld);
						button.Enabled = false;
						button.LabelText = "Create";
						return;
					}
					num = MathX.NearestPowerOfTwo(num);
					for (int i = 0; i < bitmaps.Count; i++)
					{
						bitmaps[i] = bitmaps[i]?.GetRescaled(Elements.Core.int2.One * num);
					}
					int index = 2;
					int index2 = 3;
					switch (TopBottomRotation.Value)
					{
					case Rotation.Rotate180:
						bitmaps[index] = bitmaps[index]?.Rotate180();
						bitmaps[index2] = bitmaps[index2]?.Rotate180();
						break;
					case Rotation.Rotate90CW:
						bitmaps[index] = bitmaps[index]?.Rotate90CW();
						bitmaps[index2] = bitmaps[index2]?.Rotate90CCW();
						break;
					case Rotation.Rotate90CCW:
						bitmaps[index] = bitmaps[index]?.Rotate90CCW();
						bitmaps[index2] = bitmaps[index2]?.Rotate90CW();
						break;
					}
					BitmapCube bitmapCube = new BitmapCube(num, num, textureFormat.Value, mipmaps, bitmaps[0].Profile);
					for (int j = 0; j < bitmaps.Count; j++)
					{
						Bitmap2D bitmap2D = bitmaps[j];
						if (bitmap2D != null)
						{
							bitmapCube.FillFrom(bitmap2D, (BitmapCube.Face)j, mipmaps);
						}
					}
					Uri asset = await base.Engine.LocalDB.SaveAssetAsync(bitmapCube).ConfigureAwait(continueOnCapturedContext: false);
					await default(ToWorld);
					Slot slot = base.LocalUserSpace.AddSlot("Cubemap");
					StaticCubemap cubemap = slot.AttachCubemap(asset);
					CubemapImporter.CreateSphere(slot, cubemap);
					slot.PositionInFrontOfUser();
					button.Enabled = true;
					button.LabelText = "Create";
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception creating cubemap:\n" + ex);
					await default(ToWorld);
					button.Enabled = true;
					button.LabelText = "<color=#f00>Error! Check log!</color>";
				}
			});
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			TopBottomRotation = new Sync<Rotation>();
			PosX = new AssetRef<Texture2D>();
			NegX = new AssetRef<Texture2D>();
			PosY = new AssetRef<Texture2D>();
			NegY = new AssetRef<Texture2D>();
			PosZ = new AssetRef<Texture2D>();
			NegZ = new AssetRef<Texture2D>();
