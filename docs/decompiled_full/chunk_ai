			}
			return Elements.Core.floatQ.Identity;
		}

		private static Elements.Core.float3 ScaleFilter(Elements.Core.float3 value, IField<Elements.Core.float3> field)
		{
			if (!value.IsInfinity && !value.IsNaN)
			{
				return value;
			}
			return Elements.Core.float3.One;
