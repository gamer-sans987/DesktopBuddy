		[SyncMethod(typeof(Delegate), null)]
		private void MenuItemTouched(ITouchable touchedTouchable, in TouchEventInfo touchInfo)
		{
			if (!_menuUpdated)
			{
				return;
			}
			TouchSource source = touchInfo.source;
			if (source == null || !source.SafeTouchSource || (touchInfo.hover != EventState.Begin && touchInfo.hover != EventState.End && touchInfo.touch != EventState.Begin))
			{
				return;
			}
			Item item = touchedTouchable.Slot.GetComponent<ReferenceTag<Item>>()?.Reference.Target;
			if (item == null)
			{
				return;
			}
			if (touchInfo.hover == EventState.End)
			{
				item.Highlight.Value = false;
			}
			if (item.Pressed.Target == null || !item.Enabled.Value)
			{
				return;
			}
			if (touchInfo.hover == EventState.Begin)
			{
				item.Highlight.Value = true;
			}
			if (touchInfo.touch == EventState.Begin)
			{
				if (touchInfo.type == TouchType.Physical && base.Time.WorldTime - item.LastPress.Value < 0.5)
				{
					return;
				}
				PressItem(item);
			}
			if (touchInfo.touch == EventState.Begin)
			{
				touchInfo.source.Slot.TryVibrateMedium();
			}
			else if (touchInfo.hover == EventState.Begin)
			{
				touchInfo.source.Slot.TryVibrateShort();
			}
		}

		private void PressItem(Item item)
