			int num = 0;
			CoroutineHandle val;
			while (worldQueue.TryDequeue(out val))
			{
				IUpdatable updatable = val.updatable;
				if (updatable != null)
				{
					World?.UpdateManager.NestCurrentlyUpdating(updatable);
				}
				num++;
				RunStep(val);
				if (updatable != null)
				{
