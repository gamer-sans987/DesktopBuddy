	public static class WorldThumbnailHelper
	{
		public static Task<Bitmap2D> CaptureThumbnail<T>(this World world, Elements.Core.int2 size, bool excludeUsers) where T : class, IWorldSessionThumbnailSource
		{
			return world.Coroutines.StartTask(async delegate
			{
				await default(ToWorld);
				List<T> globallyRegisteredComponents = world.GetGloballyRegisteredComponents((T s) => s.HasThumbnail && s.Enabled && s.Slot.ActiveSelf);
				if (globallyRegisteredComponents.Count > 0)
				{
					return await globallyRegisteredComponents.GetRandomWithWeight((T c) => c.Weight).GetThumbnail(size).ConfigureAwait(continueOnCapturedContext: false);
				}
				Elements.Core.float3 a;
				if (world.LocalUser.Root?.HeadSlot != null)
				{
					Slot headSlot = world.LocalUser.Root.HeadSlot;
					a = headSlot.GlobalPosition;
					if (!excludeUsers)
					{
						a += headSlot.Forward * world.LocalUser.Root.GlobalScale;
					}
				}
				else
				{
					a = Elements.Core.float3.Up * 2;
				}
				return await CaptureThumbnailSource.CaptureThumbnail(world, size, a, Elements.Core.floatQ.Identity, excludeUsers);
			});
		}
	}
