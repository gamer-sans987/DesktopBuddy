				foreach (MeshRenderer componentsInChild in _root.GetComponentsInChildren<MeshRenderer>())
				{
					if (componentsInChild.Mesh.Target is StaticMesh staticMesh && providers.Add(staticMesh))
					{
						button.LabelText = $"Processing {providers.Count}...";
						await staticMesh.Process(delegate(MeshX m)
