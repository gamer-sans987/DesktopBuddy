		internal void Setup(WorldOrb orb, FrooxEngine.Store.Record record)
		{
			_url = record.GetUrl(base.Cloud.Platform);
			BuildRecordUI();
			_worldOrb.Target = orb;
			_name.Target.TargetString = record.Name;
			_description.Target.TargetString = record.Description;
			_path.Target.TargetString = record.Path;
			_readonly.Target.State.Value = record.IsReadOnly;
			if (record.Tags != null)
			{
				StringBuilder stringBuilder = new StringBuilder();
				foreach (string tag in record.Tags)
				{
					stringBuilder.Append(tag + ", ");
				}
				_tags.Target.TargetString = stringBuilder.ToString();
			}
			if (record.IsForPatrons)
			{
				_publicSetting.Value = PublicSetting.Patreons;
			}
			else if (record.IsPublic)
			{
				_publicSetting.Value = PublicSetting.Anyone;
			}
			else
			{
				_publicSetting.Value = PublicSetting.OnlyMe;
			}
			if (IdUtil.GetOwnerType(record.OwnerId) == OwnerType.Group)
			{
				_privateOptionText.Target.Content.Value = "Only Group Members";
			}
			_ownerUser.Target = base.LocalUser;
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnCancel(IButton button, ButtonEventData eventData)
		{
			if (_ownerUser.Target == base.LocalUser)
			{
				Close();
			}
		}

		private async Task Save(IButton button, ButtonEventData eventData)
		{
			CloudResult<FrooxEngine.Store.Record> cloudResult = await base.Engine.RecordManager.FetchRecord(_url).ConfigureAwait(continueOnCapturedContext: false);
			if (cloudResult.IsOK)
			{
				FrooxEngine.Store.Record record = cloudResult.Entity;
				record.Name = _name.Target.TargetString.Trim();
				record.Description = _description.Target.TargetString?.Trim();
				record.Path = _path.Target.TargetString;
				if (!string.IsNullOrWhiteSpace(_tags.Target.TargetString))
				{
					record.Tags = new HashSet<string>();
					string[] array = _tags.Target.TargetString.Split(',');
					for (int i = 0; i < array.Length; i++)
					{
						string text = array[i].Trim();
						if (text.Length > 0)
						{
							record.Tags.Add(text);
						}
					}
				}
				else
				{
					record.Tags = null;
				}
				bool flag = _publicSetting.Value == PublicSetting.Anyone;
				bool flag2 = _publicSetting.Value == PublicSetting.Patreons;
				bool isListed = flag && (record.Submissions?.Count ?? 0) > 0;
				bool publicChanged = record.IsPublic != flag || record.IsForPatrons != flag2;
				record.IsPublic = flag;
				record.IsListed = isListed;
				record.IsForPatrons = flag2;
				record.IsReadOnly = _readonly.Target.State.Value;
				if ((await base.Engine.RecordManager.SaveRecord(record).ConfigureAwait(continueOnCapturedContext: false)).saved)
				{
					await default(ToWorld);
					if (_worldOrb.Target != null)
					{
						_worldOrb.Target.WorldName = record.Name;
					}
					Close();
				}
				if (publicChanged)
				{
					RecordPublisher.UpdateReferencedRecords(base.Engine, record);
				}
			}
			else
			{
				UniLog.Error("Error saving record changes: " + cloudResult.State.ToString() + "\n" + cloudResult.Content);
				await default(ToWorld);
				button.LabelText = "<color=#f00>Error!</color>";
			}
		}

		private void Close()
		{
			base.Slot.GetComponentInParents<IUIContainer>()?.CloseContainer();
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnSave(IButton button, ButtonEventData eventData)
		{
			if (_ownerUser.Target == base.LocalUser)
			{
				button.LabelText = this.GetLocalized("General.Saving");
				button.Enabled = false;
				StartGlobalTask(async delegate
				{
					await Save(button, eventData);
				});
			}
		}

