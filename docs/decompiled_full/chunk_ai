		public static void RemoveConvexHulls(Slot root, bool visualsOnly)
		{
			for (int num = root.ChildrenCount - 1; num >= 0; num--)
			{
				Slot slot = root[num];
				MeshRenderer component = slot.GetComponent<MeshRenderer>();
				ConvexHullCollider component2 = slot.GetComponent<ConvexHullCollider>();
				if (visualsOnly)
				{
					if (component != null && component2 != null && component2.Mesh.Target == component.Mesh.Target)
					{
						component.Destroy();
					}
				}
				else if (component2 != null)
				{
					slot.Destroy();
				}
			}
		}

		private async Task RunConvexDecomposition(Slot root, MeshCollider source, IButton button)
		{
			Mesh mesh = source?.Mesh.Asset;
			if (mesh == null)
			{
				return;
			}
			string oldLabel = button.LabelText;
			button.LabelTextField.SetLocalized("General.Processing");
			button.Enabled = false;
			object _lock = new object();
			await mesh.RequestReadLock(_lock).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToBackground);
			MeshX meshX = mesh.Data;
			if (MergeDoubles.Target.IsChecked)
			{
				meshX = meshX.GetMergedDoubles();
			}
			Task<List<ComputedConvexHull>> decomposeTask = VHACDInterface.Decompose(meshX, Resolution.Target.ParsedValue, Depth.Target.ParsedValue, Concavity.Target.ParsedValue, PlaneDownsampling.Target.ParsedValue, ConvexHullDownsampling.Target.ParsedValue, Alpha.Target.ParsedValue, Beta.Target.ParsedValue, Gamma.Target.ParsedValue, Delta.Target.ParsedValue, PCA.Target.IsChecked, Mode.Value, MaxVerticesPerHull.Target.ParsedValue, MinVolumePerHull.Target.ParsedValue, ConvexHullApproximation.Target.IsChecked);
			await decomposeTask;
			await default(ToBackground);
			mesh.ReleaseReadLock(_lock);
			List<ComputedConvexHull> result = decomposeTask.Result;
			UniLog.Log($"Got {result?.Count} from V-HACD decomposition");
			if (result == null || result.Count == 0)
			{
				base.Debug.Warning("Error running convex decomposition, returned no hulls");
				return;
			}
			List<Uri> savedUris = new List<Uri>();
			foreach (ComputedConvexHull item in result)
			{
				if (item.Mesh.VertexCount != 0)
				{
					item.Mesh.RecalculateNormals();
					List<Uri> list = savedUris;
					list.Add(await base.Engine.LocalDB.SaveAssetAsync(item.Mesh));
				}
			}
			await default(ToWorld);
			if (root.IsDestroyed)
			{
				return;
			}
			Slot slot = base.World.AssetsSlot.AddSlot(root.Name + " Convex Hulls");
			for (int i = 0; i < savedUris.Count; i++)
			{
				Elements.Core.colorX value = (Elements.Core.colorX)ColorHSV.Hue((float)i / (float)savedUris.Count);
				WireframeMaterial wireframeMaterial = slot.AttachComponent<WireframeMaterial>();
				wireframeMaterial.ScreenSpace.Value = true;
				wireframeMaterial.Thickness.Value = 2f;
				wireframeMaterial.LineColor.Value = value;
				wireframeMaterial.FillColor.Value = value.SetA(0.48f);
				wireframeMaterial.InnerLineColor.Value = value.SetA(0.73f);
				wireframeMaterial.InnerFillColor.Value = value.SetA(0.35f);
				wireframeMaterial.ZWrite.Value = ZWrite.Off;
				wireframeMaterial.DoubleSided.Value = true;
				wireframeMaterial.RenderQueue.Value = 3000;
				Slot slot2 = root.AddSlot("Convex Hull #" + i);
				MeshRenderer meshRenderer = slot2.AttachComponent<MeshRenderer>();
				ConvexHullCollider convexHullCollider = slot2.AttachComponent<ConvexHullCollider>();
				StaticMesh target = (slot ?? slot2).AttachStaticMesh(savedUris[i]);
				if (!source.IsDestroyed)
				{
					convexHullCollider.CharacterCollider.Value = source.CharacterCollider;
					convexHullCollider.Type.Value = source.Type;
					convexHullCollider.IgnoreRaycasts.Value = source.IgnoreRaycasts;
				}
				meshRenderer.Mesh.Target = target;
				convexHullCollider.Mesh.Target = target;
				meshRenderer.Material.Target = wireframeMaterial;
			}
			if (button != null)
			{
				button.LabelText = oldLabel;
				button.Enabled = true;
			}
		}

