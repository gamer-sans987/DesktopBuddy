		public bool OpenLink(WorldStartSettings startInfo = null)
		{
			if (URL.Value == null && !HasAnyActiveSessionURL)
			{
				return false;
			}
			if (URL.Value != _lastUrl || LastActiveSessionDifferent())
			{
				_isOpening = false;
			}
			if (!_isOpening)
			{
				_isOpening = true;
				_lastUrl = URL.Value;
				_lastActiveSession = new List<Uri>(ActiveSessionURLs);
				StartTask(async delegate
				{
					if (startInfo == null)
					{
						startInfo = new WorldStartSettings
						{
							AutoFocus = AutoFocus,
							GetExisting = GetExisting,
							Relation = WorldRelation
						};
					}
					startInfo.Link = this;
					World obj = await Userspace.OpenWorld(startInfo);
					_isOpening = false;
					if (obj == null)
					{
						string text = "You do not have permission to open this";
						NotificationMessage.SpawnTextMessage(color: new Elements.Core.colorX(1f, 0.2f, 0.3f), root: base.Slot, message: text);
