		private CircleSegmentShaderMesh.Generator GetMenuSegment(int index, int menuItems, out int extraIndex)
		{
			if (!_segmentCircle)
			{
				throw new Exception("LogoCircle is disabled");
			}
			extraIndex = -1;
			if (index == 0)
			{
				return segments[2];
			}
			if (index == menuItems - 1)
			{
				return segments[5];
			}
			int num = (menuItems - 4) / 2;
			index--;
			if (index < num)
			{
				extraIndex = index;
				return segments[6 + index];
			}
			if (index == num)
			{
				return segments[3];
			}
			if (index == num + 1)
			{
				return segments[4];
			}
			index -= 2;
			extraIndex = index;
			return segments[6 + index];
		}

