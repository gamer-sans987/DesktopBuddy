					await default(ToWorld);
					Slot assetsSlot = base.World.AssetsSlot.FindChildOrAdd("Separated Textures");
					await default(ToBackground);
					Bitmap2D texture = (Channels.Value.x ? SetupSplitChannel(inputTexture, ColorChannel.R) : null);
