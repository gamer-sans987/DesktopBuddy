		[SyncMethod(typeof(Delegate), null)]
		private void OnRecompressTextures(IButton button, ButtonEventData eventData)
		{
			Slot obj = Root.Target ?? base.World.RootSlot;
			HashSet<StaticTexture2D> providers = new HashSet<StaticTexture2D>();
			foreach (MeshRenderer componentsInChild in obj.GetComponentsInChildren<MeshRenderer>())
			{
				foreach (IAssetProvider<Material> material in componentsInChild.Materials)
				{
					if (material == null)
					{
						continue;
					}
					((Component)material).ForeachSyncMember(delegate(IAssetRef r)
					{
						StaticTexture2D staticTexture2D = r.Target as StaticTexture2D;
						if (staticTexture2D?.URL.Value != null)
						{
							providers.Add(staticTexture2D);
						}
					});
				}
			}
			StartTask(async delegate
			{
				try
				{
					int count = 0;
					foreach (StaticTexture2D provider in providers)
					{
						await default(ToWorld);
						Sync<string> content = _message.Target.Content;
						DefaultInterpolatedStringHandler defaultInterpolatedStringHandler = new DefaultInterpolatedStringHandler(15, 2);
						defaultInterpolatedStringHandler.AppendLiteral("Processing ");
						int num = count + 1;
						count = num;
						defaultInterpolatedStringHandler.AppendFormatted(num);
						defaultInterpolatedStringHandler.AppendLiteral(" of ");
						defaultInterpolatedStringHandler.AppendFormatted(providers.Count);
						content.Value = defaultInterpolatedStringHandler.ToStringAndClear();
						Texture2D asset = provider.Asset;
						if (asset != null)
						{
							await default(ToBackground);
							string format = null;
							await default(ToBackground);
							string file = await base.Engine.AssetManager.GatherAssetFile(provider.URL.Value, 0f);
							await default(ToBackground);
							if (File.Exists(file))
							{
								using FileStream fstream = File.OpenRead(file);
								format = (await fstream.GetFileTypeAsync())?.Extension?.ToLower();
							}
							UniLog.Log($"{provider.URL.Value}, format: {format}");
							if (format == null || (!format.Contains("webp") && !format.Contains("jpg") && !format.Contains("jpeg") && !format.Contains("png") && !format.Contains("exr")))
							{
								UniLog.Log("Loading...");
								Bitmap2D bitmap2D = await asset.GetOriginalTextureData();
								format = bitmap2D.OriginalFormat;
								UniLog.Log("Decoded format: " + format);
								if (format == null || (!format.Contains("webp") && !format.Contains("jpg") && !format.Contains("jpeg") && !format.Contains("png") && !format.Contains("exr")))
								{
									UniLog.Log("Recompressing...");
									Uri uri = await base.Engine.LocalDB.SaveAssetAsync(bitmap2D).ConfigureAwait(continueOnCapturedContext: false);
									UniLog.Log($"Recompressed: {uri}");
									await default(ToWorld);
									if (!provider.IsDestroyed)
									{
										provider.URL.Value = uri;
									}
								}
							}
						}
					}
					await default(ToWorld);
					_message.Target.Content.Value = "Finished!";
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception when recompressing textures:\n{value}");
					await default(ToWorld);
					_message.Target.Content.Value = "<color=#f00>Error!</color>";
				}
			});
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnRecalculateAllMikktspace(IButton button, ButtonEventData eventData)
		{
			button.Enabled = false;
			Slot _root = Root.Target ?? base.World.RootSlot;
			HashSet<StaticMesh> providers = new HashSet<StaticMesh>();
