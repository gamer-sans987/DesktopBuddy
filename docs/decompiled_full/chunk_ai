		}

		private static string GetBetterBlinkCandidate(string a, string b)
		{
			if (a == null)
			{
				return b;
			}
			if (b == null)
			{
				return a;
			}
			int nameScore = GetNameScore(a);
			int nameScore2 = GetNameScore(b);
			if (nameScore > nameScore2)
			{
				return a;
			}
			if (nameScore2 > nameScore)
			{
				return b;
			}
			if (a.Length < b.Length)
			{
				return a;
			}
			return b;
		}

