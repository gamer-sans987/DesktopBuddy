	internal readonly struct AssetPreserveDependencies
	{
		private readonly HashSet<Slot> rootHierarchy;

		private readonly HashSet<IAssetRef> externalReferences;

		private readonly HashSet<IAssetRef> walkedReferences;

		public readonly Slot root;

		public bool? IsExternalReference(IAssetRef r)
		{
			if (externalReferences.Contains(r))
			{
				return true;
			}
			if (walkedReferences.Contains(r))
			{
				return false;
			}
			return null;
		}

		public void RegisterWalkedReference(IAssetRef r)
		{
			walkedReferences.Add(r);
		}

		public void RegisterExternalReference(IAssetRef r)
		{
			externalReferences.Add(r);
		}

		public bool IsInRootHierarchy(IWorldElement element)
		{
			return rootHierarchy.Contains(element.FindNearestParent<Slot>());
		}

		public AssetPreserveDependencies(Slot root, HashSet<Slot> rootHierarchy)
		{
			this.root = root;
			this.rootHierarchy = rootHierarchy;
			externalReferences = Pool.BorrowHashSet<IAssetRef>();
			walkedReferences = Pool.BorrowHashSet<IAssetRef>();
		}

		public static void Return(ref AssetPreserveDependencies dependencies)
		{
			HashSet<Slot> hashSet = dependencies.rootHierarchy;
			HashSet<IAssetRef> hashSet2 = dependencies.externalReferences;
			HashSet<IAssetRef> hashSet3 = dependencies.walkedReferences;
			Pool.Return(ref hashSet);
			Pool.Return(ref hashSet2);
			Pool.Return(ref hashSet3);
			dependencies = default(AssetPreserveDependencies);
		}
	}
