			SyncArray<float> target = TargetArray.Target;
			int value = TargetArrayOffset.Target.Value;
			int num = MathX.Min(Points.Value, 524288);
			target.EnsureExactCount(num);
			value++;
			value = MathX.Repeat(value, num - 1);
			TargetArrayOffset.Target.Value = value;
			value -= 2;
			if (value < 0)
