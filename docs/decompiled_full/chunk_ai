		public static Chirality? TryDetermineChirality(this Slot slot)
		{
			HandPoser componentInParents = slot.GetComponentInParents<HandPoser>();
			if (componentInParents != null)
			{
				return componentInParents.Side;
			}
			AvatarPoseNode componentInParents2 = slot.GetComponentInParents<AvatarPoseNode>();
			if (componentInParents2 != null)
			{
				Chirality chirality = componentInParents2.Node.Value.GetChirality();
				if (chirality == Chirality.Left || chirality == Chirality.Right)
				{
					return chirality;
				}
			}
			BipedRig componentInParents3 = slot.GetComponentInParents<BipedRig>();
			Slot slot2;
			if (componentInParents3 != null)
			{
				slot2 = slot;
				do
				{
					Chirality chirality2 = componentInParents3.GetBoneType(slot2).GetChirality();
					if (chirality2 == Chirality.Left || chirality2 == Chirality.Right)
					{
						return chirality2;
					}
					slot2 = slot2.Parent;
				}
				while (slot2 != componentInParents3.Slot.Parent);
			}
			Slot objectRoot = slot.GetObjectRoot();
			slot2 = slot;
			do
			{
				string name = slot2.Name;
				List<string> names = NameHeuristicsHelper.SplitName(name);
				Chirality? chirality3 = NameHeuristicsHelper.NameToBoneChirality(name, names);
				if (chirality3.HasValue)
				{
					return chirality3.Value;
				}
				slot2 = slot2.Parent;
			}
			while (slot2 != objectRoot.Parent);
			return null;
		}
	}
