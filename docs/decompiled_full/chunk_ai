				{
					feetPosition = FeetPosition;
					base.Slot.LocalScale = MathX.Lerp(in from, in to, f);
					FeetPosition = feetPosition;
					await default(NextUpdate);
					if (cancellationToken.IsCancellationRequested)
					{
						return;
					}
				}
