		private Bitmap2D SetupSplitChannel(Bitmap2D input, ColorChannel channel)
		{
			Bitmap2D bitmap2D = new Bitmap2D(input.Size.x, input.Size.y, input.Format, input.HasMipMaps, input.Profile);
			bitmap2D.FillFrom(input);
			bitmap2D.IsolateChannel(channel);
			if (ResolutionOverride.Value.HasValue)
			{
				bitmap2D = bitmap2D.GetRescaled(ResolutionOverride?.Value ?? input.Size, input.HasMipMaps);
			}
			return bitmap2D;
		}

