			float num = float.MaxValue;
			foreach (Item independentMenuItem in independentMenuItems)
			{
				if (independentMenuItem.Pressed.Target != null && MathX.Abs(MathX.DeltaAngle(angle, independentMenuItem.AngleMiddle)) <= (float)independentMenuItem.ArcLength && (item == null || num > (float)independentMenuItem.RadiusStart))
				{
					item = independentMenuItem;
					num = independentMenuItem.RadiusStart;
				}
			}
			if (item != null && lastAngleHighlighted != item)
			{
				CancelAngleHighlight();
				item.Highlight.Value = true;
				lastAngleHighlighted = item;
				return true;
			}
			return false;
		}

