		private void WriteValue(bool force)
		{
			if (Points.Value <= 0 || SourceValue.Target == null || TargetArray.Target == null || TargetArrayOffset.Target == null || (!Drive.Value && RecordingUser.Target != base.LocalUser && RecordingUser.Target == null && !base.World.IsAuthority) || (!force && base.Time.WorldTime - _lastUpdateTime < (double)UpdateInterval.Value))
