		{
			T val = GetComponent(filter);
			if (val == null)
			{
				val = this.AttachComponent<T>(runOnAttachBehavior: true, (Action<T>)null);
				attached = true;
			}
			else
			{
				attached = false;
			}
			return val;
		}

		public T EnsureSingleComponent<T>(Predicate<T> filter = null) where T : C, new()
		{
			bool attached;
			int removed;
