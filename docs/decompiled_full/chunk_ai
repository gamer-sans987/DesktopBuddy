			if (num >= 0)
			{
				TitleButton titleButton = _titleButtons[num];
				if ((eventInfo.hover == EventState.Begin || eventInfo.hover == EventState.Stay) && titleButton.Enabled.Value && _highlightedButton.Target != titleButton)
				{
					eventInfo.source.Slot.TryVibrateShort();
					_highlightedButton.Target = titleButton;
				}
				if (eventInfo.hover == EventState.End && _highlightedButton.Target == titleButton)
				{
					_highlightedButton.Target = null;
				}
				if (eventInfo.touch == EventState.Begin && titleButton.Enabled.Value)
				{
					titleButton.Pressed.Target?.Invoke(titleButton);
					titleButton._lastPress.SetNow();
					eventInfo.source.Slot.TryVibrateMedium();
				}
			}
		}

