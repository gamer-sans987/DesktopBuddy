	public enum VolumeMeterMethod
	{
		Magnitude,
		Delta
	}
	[Category(new string[] { "Media/Utility" })]
	public abstract class VolumeMeterBase : Component
	{
		[Range(0f, 1f, "0.00")]
		public readonly Sync<float> Smoothing;

		public readonly Sync<float> Power;

		public readonly Sync<VolumeMeterMethod> Method;

		public readonly SyncRef<IWorldAudioDataSource> Source;

		private static float[] buffer;

		private static float[] references;

		protected virtual int? OverrideChannelCount => null;

		protected abstract void StoreVolume(Span<float> volumes);

		protected abstract void ClearVolume();

		protected override void OnAwake()
		{
			base.OnAwake();
			Smoothing.Value = 0f;
			Power.Value = 1f;
		}

		protected override void OnAudioUpdate()
		{
			Engine engine = base.World?.Engine;
			if (base.IsDisposed || engine == null)
			{
				return;
			}
			if (!base.Enabled)
			{
				ClearVolume();
				return;
			}
			IWorldAudioDataSource target = Source.Target;
			if (target != null)
			{
				int num = OverrideChannelCount ?? target.ChannelCount;
				int simulationFrameSize = engine.AudioSystem.SimulationFrameSize;
				buffer = buffer.EnsureExactSize(simulationFrameSize * num);
				switch (num)
				{
				case 0:
					Array.Clear(buffer, 0, buffer.Length);
					break;
				case 1:
					target.Read(buffer.AsMonoBuffer(), base.Audio.Simulator);
					break;
				case 2:
					target.Read(buffer.AsStereoBuffer(), base.Audio.Simulator);
					break;
				case 4:
					target.Read(buffer.AsQuadBuffer(), base.Audio.Simulator);
					break;
				case 6:
					target.Read(buffer.AsSurround51Buffer(), base.Audio.Simulator);
					break;
				case 8:
					target.Read(buffer.AsSurround71Buffer(), base.Audio.Simulator);
					break;
				default:
					throw new NotImplementedException("Unsupported channel count: " + num);
				}
				Span<float> volumes = stackalloc float[num];
				int num2 = simulationFrameSize * num;
				switch (Method.Value)
				{
				case VolumeMeterMethod.Magnitude:
				{
					for (int k = 0; k < num2; k += num)
					{
						for (int l = 0; l < num; l++)
						{
							volumes[l] += MathX.Abs(buffer[k + l]);
						}
					}
					break;
				}
				case VolumeMeterMethod.Delta:
				{
					references = references.EnsureExactSize(num);
					for (int i = 0; i < num2; i += num)
					{
						for (int j = 0; j < num; j++)
						{
							float num3 = buffer[i + j];
							float num4 = MathX.Abs(references[j] - num3);
							volumes[j] += num4;
							references[j] = num3;
						}
					}
					break;
				}
				}
				if (simulationFrameSize > 0)
				{
					for (int m = 0; m < num; m++)
					{
						float value = volumes[m] / (float)simulationFrameSize;
						value = MathX.FilterInvalid(value);
						value = MathX.Clamp01(value);
						value = MathX.Pow(value, Power.Value);
						volumes[m] = value;
					}
				}
				StoreVolume(volumes);
			}
			else
			{
				ClearVolume();
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Smoothing = new Sync<float>();
			Power = new Sync<float>();
			Method = new Sync<VolumeMeterMethod>();
			Source = new SyncRef<IWorldAudioDataSource>();
		}
	}
