				segments[0].ArcAngle = num2;
				segments[1].AngleStart = _separator * 1.5f + num4 + 180f;
				segments[1].ArcAngle = num2;
				segments[2].AngleStart = _separator * 0.5f;
				segments[2].ArcAngle = num4;
				segments[3].AngleStart = _separator * 2.5f + num4 + num2;
				segments[3].ArcAngle = num4;
				segments[4].AngleStart = _separator * 0.5f + 180f;
				segments[4].ArcAngle = num4;
				segments[5].AngleStart = _separator * 2.5f + num4 + num2 + 180f;
				segments[5].ArcAngle = num4;
				for (int i = 0; i < 6; i++)
				{
					segments[i].RadiusStart = _radius;
					segments[i].Thickness = _thickness;
					segments[i].FillColor = FillColor.Value;
					segments[i].BorderColor = OutlineColor.Value;
				}
				float menuSegmentArc = MenuSegmentArc;
				int num5 = _itemCount - 4;
				float num6 = (float)(num5 / 2) * menuSegmentArc + (float)(num5 / 2 - 1) * _separator;
				float num7 = _separator * 0.5f;
				float num8 = 0f;
				menuItemShowLerp = menuItemShowLerp.EnsureSize(_itemCount);
				menuItemCenters = menuItemCenters.EnsureSize(_itemCount);
				for (int j = 0; j < _itemCount; j++)
				{
					if (j == 0 || j == _itemCount / 2)
					{
						num8 = num6 * num;
					}
					int extraIndex;
					CircleSegmentShaderMesh.Generator menuSegment = GetMenuSegment(j, _itemCount, out extraIndex);
					float num9 = num7;
					float num10 = menuSegmentArc;
					Elements.Core.colorX b = OutlineColor;
					Elements.Core.colorX b2 = FillColor;
					float num11 = 0f;
					float num12 = 0f;
					float num13 = 0f;
					float num14 = 0f;
					if (j < _circleItemOverrides.Count)
					{
						MenuSegment menuSegment2 = _circleItemOverrides[j];
						num11 = menuSegment2.AngleStart;
						num12 = menuSegment2.ArcLength;
						num13 = menuSegment2.RadiusStart;
						num14 = menuSegment2.Thickness;
						if ((bool)menuSegment2.OverrideColor)
						{
							b = menuSegment2.OutlineColor;
							b2 = menuSegment2.FillColor;
						}
					}
					if (extraIndex == -1)
					{
						menuSegment.AngleStart = MathX.LerpUnclamped(menuSegment.AngleStart, num9 + num11, val);
						menuSegment.ArcAngle = MathX.LerpUnclamped(menuSegment.ArcAngle, num10 + num12, val);
						menuSegment.RadiusStart = MathX.LerpUnclamped(menuSegment.RadiusStart, _menuRadius + num13, val);
						menuSegment.Thickness = MathX.LerpUnclamped(menuSegment.Thickness, _menuThickness + num14, val);
						menuSegment.FillColor = MathX.LerpUnclamped(in menuSegment.FillColor, in b2, val);
						menuSegment.BorderColor = MathX.LerpUnclamped(in menuSegment.BorderColor, in b, val);
						menuItemShowLerp[j] = MathX.Clamp01(val);
					}
					else
					{
						num10 = MathX.Min(num8, num10);
						num8 -= num10 + _separator;
						num8 = MathX.Max(num8, 0f);
						menuSegment.AngleStart = num7 + num11;
						menuSegment.ArcAngle = num10 + num12;
						menuSegment.RadiusStart = _menuRadius + num13;
						menuSegment.Thickness = _menuThickness + num14;
						menuSegment.FillColor = b2;
						menuSegment.BorderColor = b;
						menuItemShowLerp[j] = menuSegment.ArcAngle / menuSegmentArc;
					}
					float radius = menuSegment.RadiusStart + menuSegment.Thickness / 2f;
					float num15 = menuSegment.AngleStart + menuSegment.ArcAngle / 2f;
					menuItemCenters[j] = CircleSegmentShaderMesh.Generator.ComputePoint(0f - num15, radius);
					num7 += menuSegmentArc + _separator;
				}
			}
			for (int k = 0; k < _independentSegments.Count; k++)
			{
				MenuSegment menuSegment3 = _independentSegments[k];
				CircleSegmentShaderMesh.Generator generator = segments[INDEPENDENT_ITEMS_START + k];
				generator.AngleStart = menuSegment3.AngleStart;
				generator.ArcAngle = menuSegment3.ArcLength;
				generator.RadiusStart = menuSegment3.RadiusStart;
				generator.Thickness = menuSegment3.Thickness;
				if ((bool)menuSegment3.OverrideColor)
				{
					generator.BorderColor = menuSegment3.OutlineColor;
					generator.FillColor = menuSegment3.FillColor;
				}
				else
				{
					generator.BorderColor = OutlineColor;
					generator.FillColor = FillColor;
				}
			}
			for (int l = 0; l < segments.Count; l++)
			{
				segments[l].BorderSize = OutlineWidth.Value;
				segments[l].Update();
			}
			Pool.Return(ref _independentSegments);
			Pool.Return(ref _circleItemOverrides);
			uploadHint[MeshUploadHint.Flag.Geometry] = value;
		}

