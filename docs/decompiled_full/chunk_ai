	{
		public readonly AssetRef<Texture2D> Overlay;

		public bool HasThumbnail => true;

		public abstract float Weight { get; }

		public abstract bool ExcludeUsers { get; }

		public Task<Bitmap2D> GetThumbnail(Elements.Core.int2 size)
		{
			return CaptureThumbnail(base.World, size, base.Slot.GlobalPosition, base.Slot.GlobalRotation, ExcludeUsers, Overlay, VerifyOverlay);
		}

		public static async Task<Bitmap2D> CaptureThumbnail(World world, Elements.Core.int2 size, Elements.Core.float3 position, Elements.Core.floatQ orientation, bool excludeUsers, Texture2D overlay = null, Predicate<Bitmap2D> verifyOverlay = null)
		{
			if (!world.Render.IsRenderingSupported)
			{
				return null;
			}
			RenderTask renderTask = RenderTask.Equirectangular(position, orientation, size);
			if (excludeUsers)
			{
				renderTask.excludeObjects = new List<Slot>();
				foreach (User allUser in world.AllUsers)
				{
					Slot slot = allUser.Root?.Slot;
					if (slot != null)
					{
						renderTask.excludeObjects.Add(slot);
					}
				}
			}
			Bitmap2D texture = await world.Render.RenderToBitmap(renderTask).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToBackground);
			if (overlay != null)
			{
				Bitmap2D bitmap2D = await overlay.GetOriginalTextureData();
				if (verifyOverlay == null || verifyOverlay(bitmap2D))
				{
					texture.AlphaBlend(bitmap2D);
				}
			}
			return texture;
		}

		protected virtual bool VerifyOverlay(Bitmap2D bitmap)
		{
			return true;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Overlay = new AssetRef<Texture2D>();
		}
	}
