		public static Slot GetNearestSharedParent(params Slot[] slots)
		{
			Slot slot = slots[0];
			for (int i = 1; i < slots.Length; i++)
			{
				slot = slot.GetNearestSharedParent(slots[i]);
			}
			return slot;
		}

		public static Slot GetNearestSharedParent(this Slot self, Slot other)
		{
			int num = self.HierachyDepth;
			int num2 = other.HierachyDepth;
			while (self != other)
			{
				if (num > num2)
				{
					self = self.Parent;
					num--;
				}
				else
				{
					other = other.Parent;
					num2--;
				}
			}
			return self;
		}

