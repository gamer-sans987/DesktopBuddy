		public static Grabber GetLocalUserGrabberWithItems(this World world, Slot searchRoot = null)
		{
			Grabber grabber = null;
			foreach (Grabber registeredComponent in world.LocalUser.Root.GetRegisteredComponents<Grabber>())
			{
				grabber = Userspace.TryGetGrabberWithItems(registeredComponent);
				if (grabber != null)
				{
					break;
				}
			}
			if (grabber == null && searchRoot != null)
			{
				grabber = searchRoot.GetComponentInParentsOrChildren<Grabber>();
				grabber = Userspace.TryGetGrabberWithItems(grabber);
			}
			return grabber;
		}
