		private Elements.Core.int2? GetMinMaxSize(ResolutionSizeHandling scaling, Elements.Core.int2 a, Elements.Core.int2 b, Elements.Core.int2 c, Elements.Core.int2 d)
		{
			return scaling switch
			{
				ResolutionSizeHandling.UseSmallest => new Elements.Core.int2(MathX.Min(a.x, b.x, c.x, d.x), MathX.Min(a.y, b.y, c.y, d.y)), 
				ResolutionSizeHandling.UseLargest => new Elements.Core.int2(MathX.Max(a.x, b.x, c.x, d.x), MathX.Max(a.y, b.y, c.y, d.y)), 
				_ => null, 
			};
		}

		private float? GetChannel(Bitmap2D input, ColorChannel channel, int x, int y)
		{
			if (x >= input.Size.x || y >= input.Size.y)
			{
				return null;
			}
			return channel switch
			{
				ColorChannel.R => input[x, y].R, 
				ColorChannel.G => input[x, y].G, 
				ColorChannel.B => input[x, y].B, 
				ColorChannel.A => input[x, y].A, 
				_ => null, 
			};
		}

		private async Task Process()
		{
			Elements.Core.int2? resolutionOverride = ResolutionOverride.Value;
			Elements.Core.int2 resolution;
			Elements.Core.int2 fallbackResolution = (resolution = new Elements.Core.int2(MINIMUM_TEXTURE_SIZE, MINIMUM_TEXTURE_SIZE));
			await default(ToWorld);
			IsProcessing.Value = true;
			await default(ToBackground);
			Bitmap2D r = new Bitmap2D(fallbackResolution.x, fallbackResolution.y, TextureFormat.RGBAHalf, mipmaps: true, ColorProfile.sRGB);
			Bitmap2D g = new Bitmap2D(fallbackResolution.x, fallbackResolution.y, TextureFormat.RGBAHalf, mipmaps: true, ColorProfile.sRGB);
			Bitmap2D b = new Bitmap2D(fallbackResolution.x, fallbackResolution.y, TextureFormat.RGBAHalf, mipmaps: true, ColorProfile.sRGB);
			Bitmap2D a = new Bitmap2D(fallbackResolution.x, fallbackResolution.y, TextureFormat.RGBAHalf, mipmaps: true, ColorProfile.sRGB);
			r.Fill(0, 0, fallbackResolution.x, fallbackResolution.y, new Elements.Core.color(RFallbackValue, RFallbackValue));
			g.Fill(0, 0, fallbackResolution.x, fallbackResolution.y, new Elements.Core.color(GFallbackValue, GFallbackValue));
			b.Fill(0, 0, fallbackResolution.x, fallbackResolution.y, new Elements.Core.color(BFallbackValue, BFallbackValue));
			a.Fill(0, 0, fallbackResolution.x, fallbackResolution.y, new Elements.Core.color(AFallbackValue, AFallbackValue));
			Task<Bitmap2D> task = Task.FromResult<Bitmap2D>(null);
			Task<Bitmap2D> task2 = Task.FromResult<Bitmap2D>(null);
			Task<Bitmap2D> task3 = Task.FromResult<Bitmap2D>(null);
			Task<Bitmap2D> task4 = Task.FromResult<Bitmap2D>(null);
			Texture2D rTexture = RTexture?.Target?.Asset as Texture2D;
			Texture2D gTexture = GTexture?.Target?.Asset as Texture2D;
			Texture2D bTexture = BTexture?.Target?.Asset as Texture2D;
			Texture2D aTexture = ATexture?.Target?.Asset as Texture2D;
			if (rTexture != null)
			{
				task = rTexture.GetOriginalTextureData();
			}
			if (gTexture != null)
			{
				task2 = gTexture.GetOriginalTextureData();
			}
			if (bTexture != null)
			{
				task3 = bTexture.GetOriginalTextureData();
			}
			if (aTexture != null)
			{
				task4 = aTexture.GetOriginalTextureData();
			}
			Bitmap2D[] array = await Task.WhenAll<Bitmap2D>(task, task2, task3, task4);
			if (rTexture != null)
			{
				r = array[0];
			}
			if (gTexture != null)
			{
				g = array[1];
			}
			if (bTexture != null)
			{
				b = array[2];
			}
			if (aTexture != null)
			{
				a = array[3];
			}
			resolution = resolutionOverride ?? GetMinMaxSize(ResolutionSizing, r.Size, g.Size, b.Size, a.Size) ?? fallbackResolution;
			Bitmap2D output = new Bitmap2D(resolution.x, resolution.y, TextureFormat.RGBAHalf, GenerateMips.Value, ColorProfile.sRGB);
			r = r.GetRescaled(resolution, GenerateMips.Value);
			g = g.GetRescaled(resolution, GenerateMips.Value);
			b = b.GetRescaled(resolution, GenerateMips.Value);
			a = a.GetRescaled(resolution, GenerateMips.Value);
			Parallel.For(0, resolution.y, delegate(int y)
			{
				for (int i = 0; i < resolution.x; i++)
				{
					float num = GetChannel(r, RColorChannel.Value, i, y) ?? RFallbackValue.Value;
					float num2 = GetChannel(g, GColorChannel.Value, i, y) ?? GFallbackValue.Value;
					float num3 = GetChannel(b, BColorChannel.Value, i, y) ?? BFallbackValue.Value;
					float num4 = GetChannel(a, AColorChannel.Value, i, y) ?? AFallbackValue.Value;
					num = (RInvert.Value ? (1f - num) : num);
					num2 = (GInvert.Value ? (1f - num2) : num2);
					num3 = (BInvert.Value ? (1f - num3) : num3);
					num4 = (AInvert.Value ? (1f - num4) : num4);
					output[i, y] = new Elements.Core.color(num, num2, num3, num4);
				}
			});
			Uri asset = await base.Engine.LocalDB.SaveAssetAsync(output).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToWorld);
			StaticTexture2D target = base.World.AssetsSlot.FindChildOrAdd("Combined Textures").AttachTexture(asset);
			OutputTexture.Target = target;
			IsProcessing.Value = false;
		}

		[SyncMethod(typeof(Action), new string[] { })]
		public void PackTextures()
		{
			StartTask(Process);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void Pack(IButton button, ButtonEventData eventData)
		{
			button.Enabled = false;
			button.LabelText = this.GetLocalized("General.Processing");
			StartTask(async delegate
			{
				_ = 1;
				try
				{
					await Process();
					await default(ToWorld);
					button.LabelText = this.GetLocalized("Inspector.Wizard.PackTexture");
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception packing texture\n" + ex);
					button.LabelText = this.GetLocalized("Inspector.Error");
				}
				finally
				{
					button.Enabled = true;
					IsProcessing.Value = false;
				}
			});
		}

