			}
			writer.Write7BitEncoded((ulong)_element.ReferenceID);
			base.World.Types.EncodeType(writer, _element.GetType());
		}

		protected override void InternalDecodeFull(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			RefID refID = reader.Read7BitEncoded();
			ulong tick = base.World.SyncTick;
			if (inboundMessage is ConfirmationMessage confirmationMessage)
			{
				tick = confirmationMessage.ConfirmTime;
			}
			if (refID == RefID.Null)
			{
				InternalSetElement(null, sync: false);
				return;
			}
			Type elementType = base.World.Types.DecodeType(reader);
			ISyncMember syncMember = base.World.TryRetrieveFromTrash(tick, refID);
			if (syncMember == null)
			{
				InternalCreateElement(refID, elementType, sync: false);
			}
			else
			{
				InternalSetElement((SyncElement)syncMember, sync: false);
			}
		}

