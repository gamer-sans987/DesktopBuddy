		public bool Matches(HapticPoint point)
		{
			if (MathX.Approximately(PointRadius.Value, point.Radius))
			{
				return Matches(point.Position);
			}
			return false;
		}

		public bool Matches(HapticPointPosition position)
		{
			if (position.PositionType != MappingTarget.Value)
			{
				return false;
			}
			if (!(position is VoidHapticPointPosition))
			{
				if (!(position is TorsoHapticPointPosition torsoHapticPointPosition))
				{
					if (!(position is HeadHapticPointPosition headHapticPointPosition))
					{
						if (!(position is ArmHapticPosition armHapticPosition))
						{
							if (!(position is LegHapticPosition legHapticPosition))
							{
								if (!(position is ControllerHapticPosition controllerHapticPosition))
								{
									if (position is TagHapticPosition tagHapticPosition)
									{
										return tagHapticPosition.Tag == Tag.Value;
									}
									throw new NotImplementedException($"Unsupported haptic point position: {position}");
								}
								return controllerHapticPosition.Side == ControllerSide.Value;
							}
							if (legHapticPosition.Side == (Chirality)LegSide && MathX.Approximately(legHapticPosition.PositionAlong, ArmPositionAlong))
							{
								return MathX.Approximately(legHapticPosition.AngleAround, ArmAngleAround);
							}
							return false;
						}
						if (armHapticPosition.Side == (Chirality)ArmSide && MathX.Approximately(armHapticPosition.PositionAlong, ArmPositionAlong))
						{
							return MathX.Approximately(armHapticPosition.AngleAround, ArmAngleAround);
						}
						return false;
					}
					if (MathX.Approximately(headHapticPointPosition.PitchAngle, HeadPitchAngle))
					{
						return MathX.Approximately(headHapticPointPosition.YawAngle, HeadYawAngle);
					}
					return false;
				}
				if (torsoHapticPointPosition.Side == TorsoSide.Value && MathX.Approximately(torsoHapticPointPosition.HorizontalPosition, TorsoHorizontalPosition))
				{
					return MathX.Approximately(torsoHapticPointPosition.VerticalPosition, TorsoVerticalPosition);
				}
				return false;
			}
			return true;
		}

		public HapticPointPosition GetPosition()
		{
			return MappingTarget.Value switch
			{
				HapticPositionType.Torso => new TorsoHapticPointPosition(TorsoHorizontalPosition, TorsoVerticalPosition, TorsoSide), 
				HapticPositionType.Head => new HeadHapticPointPosition(HeadPitchAngle, HeadYawAngle), 
				HapticPositionType.Arm => new ArmHapticPosition(ArmSide, ArmPositionAlong, ArmAngleAround), 
				HapticPositionType.Leg => new LegHapticPosition(LegSide, LegPositionAlong, LegAngleAround), 
				HapticPositionType.Controller => new ControllerHapticPosition(ControllerSide), 
				HapticPositionType.Tag => new TagHapticPosition(Tag.Value ?? ""), 
				_ => VoidHapticPointPosition.SINGLETON, 
			};
		}

