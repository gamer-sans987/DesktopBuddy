	public static class PackageCreator
	{
		public static async Task BuildPackage(Engine engine, SkyFrost.Base.Record record, SavedGraph savedGraph, System.IO.Stream writeStream, bool includeVariants)
		{
			RecordPackage package = RecordPackage.Create(writeStream);
			record.AssetManifest = new List<DBAsset>();
			await CollectAssets(engine, record, savedGraph, package, includeVariants).ConfigureAwait(continueOnCapturedContext: false);
			string tempFilePath = engine.LocalDB.GetTempFilePath(".brson");
			DataTreeConverter.Save(savedGraph.Root, tempFilePath, DataTreeConverter.Compression.Brotli);
			string signature = AssetUtil.GenerateHashSignature(tempFilePath);
			Uri assetURL = RecordPackage.GetAssetURL(signature);
			package.WriteAsset(signature, tempFilePath);
			record.RecordId = "R-Main";
			record.AssetURI = assetURL.OriginalString;
			package.WriteRecord(record);
			package.Dispose();
		}

		private static async Task CollectAssets(Engine engine, SkyFrost.Base.Record record, SavedGraph savedGraph, RecordPackage package, bool includeVariants)
		{
			foreach (DataTreeValue urlNode in savedGraph.URLNodes)
			{
				if (urlNode.IsNull)
				{
					continue;
				}
				Uri url = urlNode.TryExtractURL();
				if (url == null)
				{
					continue;
				}
				bool isValidDBuri = engine.Cloud.Assets.IsValidDBUri(url);
				if (!isValidDBuri && !(url.Scheme == "local"))
				{
					continue;
				}
				AssetRecord assetRecord = await engine.LocalDB.TryFetchAssetRecordWithMetadataAsync(url).ConfigureAwait(continueOnCapturedContext: false);
				string assetSignature;
				string text;
				long bytes;
				if (assetRecord == null)
				{
					if (!isValidDBuri)
					{
						UniLog.Warning("Failed to fetch asset record for asset packaging: " + url);
						continue;
					}
					assetSignature = engine.Cloud.Assets.DBSignature(url);
					text = await (await engine.AssetManager.GatherAsset(url, 0f).ConfigureAwait(continueOnCapturedContext: false)).GetFile();
					if (text == null)
					{
						UniLog.Warning("Failed to gather asset for packaging: " + url);
						continue;
					}
					bytes = new FileInfo(text).Length;
				}
				else
				{
					assetSignature = assetRecord.cloudsig;
					text = assetRecord.path;
					bytes = assetRecord.bytes;
				}
				Uri assetURL = RecordPackage.GetAssetURL(assetSignature);
				urlNode.UpdateValue(assetURL);
				if (package.HasAsset(assetSignature))
				{
					continue;
				}
				package.WriteAsset(assetSignature, text);
				record.AssetManifest.Add(new DBAsset
				{
					Hash = assetSignature,
					Bytes = bytes
				});
				IAssetMetadata assetMetadata = await engine.LocalDB.TryFetchAssetMetadataAsync(assetSignature).ConfigureAwait(continueOnCapturedContext: false);
				if (assetMetadata != null)
				{
					assetMetadata.AssetIdentifier = assetSignature;
					package.WriteMetadata(assetMetadata);
				}
				if (!includeVariants)
				{
					continue;
				}
				await engine.LocalDB.GetAllVariantsAsync(url);
				foreach (AssetRecord item in await engine.LocalDB.GetAllVariantsAsync(url).ConfigureAwait(continueOnCapturedContext: false))
				{
					Uri uri = new Uri(item.url);
					string path = item.path;
					if (File.Exists(path))
					{
						string variantIdentifier = uri.Query.Substring(1);
						if (!package.HasVariant(assetSignature, variantIdentifier))
						{
							package.WriteVariant(assetSignature, variantIdentifier, path);
						}
					}
				}
			}
		}
	}
	public static class PackageImporter
	{
		public static async Task ImportPackage(string file, Slot root, IProgressIndicator progress = null)
		{
			progress?.UpdateProgress(0f, "Importer.Package.Progress.DecodingPackage".AsLocaleKey(), default(LocaleString));
			using RecordPackage package = RecordPackage.Decode(file);
			await ImportPackage(package, root, progress);
		}

		public static async Task ImportPackage(RecordPackage package, Slot root, IProgressIndicator progress = null)
		{
			_ = 7;
			try
			{
				Engine engine = root.Engine;
				await default(ToBackground);
				progress?.UpdateProgress(0.01f, "Importer.Package.Progress.DecodingObject".AsLocaleKey(), default(LocaleString));
				SkyFrost.Base.Record record = package.MainRecord;
				if (record == null)
				{
					throw new NotSupportedException("Package is missing main record! Cannot import.");
				}
				if (record.RecordType != "object")
				{
					throw new NotSupportedException("Currently only object packages are supported");
				}
				string assetSignature = RecordPackage.GetAssetSignature(new Uri(record.AssetURI));
				DataTreeDictionary dataTreeDictionary;
				using (System.IO.Stream stream = package.ReadAsset(assetSignature))
				{
					dataTreeDictionary = DataTreeConverter.LoadAuto(stream);
				}
				if (dataTreeDictionary == null)
				{
					throw new Exception("Failed to load main asset");
				}
				SavedGraph mainGraph = new SavedGraph(dataTreeDictionary);
				int totalUrlNodes = mainGraph.URLNodes.Count;
				int processedNodes = 0;
				Dictionary<Uri, Uri> assetMapping = new Dictionary<Uri, Uri>();
				foreach (DataTreeValue urlNode in mainGraph.URLNodes)
				{
					processedNodes++;
					if (urlNode.IsNull)
					{
						continue;
					}
					Uri url = urlNode.TryExtractURL();
					if (url == null || url.Scheme != "packdb")
					{
						continue;
					}
					if (!assetMapping.TryGetValue(url, out Uri newUrl))
					{
						string signature = RecordPackage.GetAssetSignature(url);
						float lerp = (float)processedNodes / (float)totalUrlNodes;
						progress?.UpdateProgress(MathX.Lerp(0.01f, 0.99f, lerp), "Importer.Package.Progress.ImportingAssets".AsLocaleKey(), signature);
						AssetRecord assetRecord = await engine.LocalDB.TryFetchAssetByCloudSignatureAsync(signature);
						if (assetRecord != null)
						{
							newUrl = new Uri(assetRecord.url);
						}
						else
						{
							string tempFilePath = engine.LocalDB.GetTempFilePath();
							using (FileStream targetStream = File.OpenWrite(tempFilePath))
							{
								package.ExtractAsset(signature, targetStream);
							}
							newUrl = await engine.LocalDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move, null, signature);
						}
						if (await engine.LocalDB.TryFetchAssetMetadataAsync(newUrl.OriginalString) == null)
						{
							IAssetMetadata assetMetadata = package.TryGetMetadata(signature);
							if (assetMetadata != null)
							{
								assetMetadata.AssetIdentifier = newUrl.OriginalString;
								await engine.LocalDB.SaveAssetMetadataAsync(assetMetadata);
								UniLog.Log("Imported metadata for " + signature + " from package");
							}
						}
						foreach (string variantIdentifier in package.EnumerateVariantsForAsset(signature))
						{
							UniLog.Log("Variant " + signature + " - " + variantIdentifier);
							Uri variantUrl = new Uri(newUrl, "?" + variantIdentifier);
							if (await engine.LocalDB.TryFetchAssetRecordAsync(variantUrl) == null)
							{
								string tempFilePath2 = engine.LocalDB.GetTempFilePath();
								using (FileStream targetStream2 = File.OpenWrite(tempFilePath2))
								{
									package.ExtractVariant(signature, variantIdentifier, targetStream2);
								}
								await engine.LocalDB.StoreCacheRecordAsync(variantUrl, tempFilePath2);
								UniLog.Log($"Imported variant for {signature}: {variantIdentifier} from package");
							}
						}
						assetMapping.Add(url, newUrl);
					}
					urlNode.UpdateValue(newUrl);
					newUrl = null;
				}
				progress?.UpdateProgress(1f, "Importer.Package.Progress.LoadingObject".AsLocaleKey(), default(LocaleString));
				await default(ToWorld);
				root.LoadObject(mainGraph.Root, record);
				root.ForeachComponentInChildren(delegate(IPackageImportEventReceiver p)
				{
					p.OnPackageImported();
				}, includeLocal: false, cacheItems: true);
				progress?.ProgressDone("Importer.Package.Progress.Imported".AsLocaleKey());
			}
			catch (Exception)
			{
				progress?.ProgressFail("Importer.Package.Progress.Fail".AsLocaleKey());
			}
		}
	}
