					break;
				}
				bool lockTaken = false;
				processingLoopLock.TryEnter(ref lockTaken);
				if (!lockTaken)
				{
					continue;
				}
				if (runMessageProcessing && !stopProcessing)
				{
					SyncLoopStage = SyncLoopStage.RunningMessageProcessing;
					if (InitialStateLoaded)
					{
						SyncWorldTime();
						ProcessSyncMessages(lastDeltaSyncTime, ref runMessageProcessing);
					}
					else
					{
						ProcessInitialState();
					}
				}
				processingLoopLock.Exit();
			}
			lastProcessingStopped.Set();
			SyncLoopStage = SyncLoopStage.ProcessingStopped;
		}

		private void SyncWorldTime()
		{
			StreamMessage streamMessage = Interlocked.Exchange(ref _syncWorldTime, null);
			if (streamMessage != null)
			{
				World.Time.SyncWorldTime(streamMessage.StreamTime, streamMessage.SecondsSinceReceived);
			}
		}

		private void ProcessInitialState()
		{
			if (_initialState != null && ProcessMessage(_initialState, 0uL))
			{
				InitialStateLoaded = true;
				World.InitializeAllocationForLocalUser();
				World.StartRunning();
				World.Coroutines.StartTask(async delegate
				{
					await default(NextUpdate);
					await CommonAvatarBuilder.SetupAvatarAccessKey(World);
				});
				_initialState = null;
				_initialStateDecoded.SetResult(result: true);
				_initialStateDecoded = null;
			}
		}

		private void ProcessSyncMessages(ulong lastDeltaSyncTime, ref bool runMessageProcessing)
		{
			int count = messagesToProcess.Count;
			int num = 0;
			SyncMessage result;
			while (messagesToProcess.TryPeek(out result))
			{
				CurrentlyProcessingSyncMessage = result;
				if (ProcessMessage(result, lastDeltaSyncTime))
				{
					CurrentlyProcessingSyncMessage = null;
					TotalProcessedMessages++;
					num++;
					messagesToProcess.TryDequeue(out SyncMessage result2);
					if (result != result2)
					{
						throw new Exception("The front of the message queue has been modified outside the sync loop!");
					}
					if (stopProcessing && num >= count)
					{
						break;
					}
					continue;
				}
				CurrentlyProcessingSyncMessage = null;
				runMessageProcessing = false;
				break;
			}
		}

		private void GenerateDeltaBatchAndSend()
		{
			SyncLoopStage = SyncLoopStage.GeneratingDeltaBatch;
			DeltaBatch deltaBatch = World.SyncController.CollectDeltaMessages();
			LastGeneratedDeltaChanges = deltaBatch.DataRecordCount;
			if (deltaBatch.DataRecordCount > 0)
			{
				if (World.IsAuthority)
				{
					List<User> list = Pool.BorrowList<User>();
					World.GetOthers(newUsersToInitialize, list);
					Connections.GetConnections(list, deltaBatch.Targets);
					Pool.Return(ref list);
				}
				else
				{
					deltaBatch.Targets.Add(Connections.HostConnection);
					HashSet<RefID> hashSet = Pool.BorrowHashSet<RefID>();
					for (int i = 0; i < deltaBatch.DataRecordCount; i++)
					{
						hashSet.Add(deltaBatch.GetDataRecord(i).targetID);
					}
					changesToConfirm.Add(World.SyncTick, hashSet);
				}
				Messages.Outgoing.EnqueueForTransmission(deltaBatch, isOrigin: true, useBackgroundEncoder: false);
			}
			else
			{
				deltaBatch.Dispose();
			}
		}

		private void GenerateCorrectionsAndSend()
		{
			if (World.IsAuthority)
			{
				SyncLoopStage = SyncLoopStage.GeneratingCorrections;
				List<SyncElement> list = Pool.BorrowList<SyncElement>();
				World.LinkManager.GetReleasedDrives(list);
				if (list.Count > 0)
				{
					FullBatch fullBatch = World.SyncController.EncodeFullBatch(list);
					List<User> list2 = Pool.BorrowList<User>();
					World.GetOthers(newUsersToInitialize, list2);
					Connections.GetConnections(list2, fullBatch.Targets);
					Pool.Return(ref list2);
					Messages.Outgoing.EnqueueForTransmission(fullBatch, isOrigin: true, useBackgroundEncoder: false);
				}
				Pool.Return(ref list);
			}
		}

		private void GenerateStreamsAndSend()
		{
			if (World.State != FrooxEngine.World.WorldState.Running)
			{
				return;
			}
			SyncLoopStage = SyncLoopStage.EncodingStreams;
			List<StreamMessage> list = Pool.BorrowList<StreamMessage>();
			World.SyncController.GatherStreams(list);
			foreach (StreamMessage item in list)
			{
				Messages.Outgoing.EnqueueStreamMessage(item, isOrigin: true);
			}
			Pool.Return(ref list);
		}

		private bool ProcessMessage(SyncMessage message, ulong lastDeltaSyncTime)
		{
			try
			{
				if (World.IsAuthority)
				{
					if (!Connections.TryGetUser(message, out User user))
					{
						message.Dispose();
						return true;
					}
					message.LinkSenderUser(user);
				}
				else if (InitialStateLoaded)
				{
					message.LinkSenderUser(World.HostUser);
				}
				if (!(message is DeltaBatch deltaBatch))
				{
					if (!(message is StreamMessage streamMessage))
					{
						if (!(message is FullBatch fullBatch))
						{
							if (!(message is ConfirmationMessage confirmBatch))
							{
								if (message is DisconnectMessage disconnect)
								{
									ProcessDisconnectMessage(disconnect);
									return true;
								}
								throw new NotSupportedException($"Unsupported sync message type: {message.GetType()}");
							}
							ProcessConfirmBatch(confirmBatch);
							return true;
						}
						ProcessFullBatch(fullBatch);
						return true;
					}
					ProcessStreamMessage(streamMessage);
					return true;
				}
				return ProcessDeltaBatch(deltaBatch, lastDeltaSyncTime);
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception in processing message! Message: {message}, sender: {message.Sender}, user: {message.SenderUser}, sender sync tick: {message.SenderSyncTick}, sender state version: {message.SenderStateVersion}, confirmation time: {(message as ConfirmationMessage)?.ConfirmTime}, local sync tick: {World.SyncTick}, local state version: {World.StateVersion}\n{ex}");
				throw ex;
			}
		}

		private bool ProcessDeltaBatch(DeltaBatch deltaBatch, ulong lastDeltaSyncTime)
		{
			if (World.State != FrooxEngine.World.WorldState.Running)
			{
				throw new Exception("Cannot process Delta Messages when the world isn't running. (State == " + World.State);
			}
			if (World.IsAuthority && deltaBatch.SenderStateVersion >= lastDeltaSyncTime)
			{
				return false;
			}
			ValidateDeltabatchAndRetransmit(deltaBatch);
			ApplyDataRecords(deltaBatch);
			if (!World.IsAuthority)
			{
				World.UpdateStateVersion(deltaBatch.SenderStateVersion);
			}
			else
			{
				World.IncrementStateVersion();
			}
			deltaBatch.Dispose();
			return true;
		}

		private void ProcessFullBatch(FullBatch fullBatch)
		{
			if (World.State == FrooxEngine.World.WorldState.Initializing && !World.IsAuthority)
			{
				World.Time.SyncWorldTime(fullBatch.SenderTime, fullBatch.SecondsSinceReceived);
			}
			ApplyDataRecords(fullBatch);
			if (!World.IsAuthority)
			{
				World.UpdateStateVersion(fullBatch.SenderStateVersion);
			}
			fullBatch.Dispose();
		}

		private void ProcessStreamMessage(StreamMessage streamMessage)
		{
			try
			{
				if (World.State == FrooxEngine.World.WorldState.Running)
				{
					World.SyncController.ApplyStreams(streamMessage);
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception processing StreamMessage.\nMessage: {streamMessage}\nWorld: {World}\n{value}");
			}
			finally
			{
				try
				{
					streamMessage.Dispose();
				}
				catch (Exception value2)
				{
					UniLog.Error($"Exception disposing of stream message:\n{value2}");
				}
			}
		}

		private void ProcessConfirmBatch(ConfirmationMessage confirmBatch)
		{
			HashSet<RefID> hashSet = changesToConfirm[confirmBatch.ConfirmTime];
			World.UpdateManager.CurrentlyUpdatingUser = confirmBatch.SenderUser;
			TotalCorrections += confirmBatch.DataRecordCount;
			for (int i = 0; i < confirmBatch.DataRecordCount; i++)
			{
				World.SyncController.DecodeCorrection(i, confirmBatch);
			}
			World.UpdateManager.CurrentlyUpdatingUser = null;
			World.SyncController.ApplyConfirmations(hashSet, confirmBatch.ConfirmTime);
			Pool.Return(ref hashSet);
			changesToConfirm.Remove(confirmBatch.ConfirmTime);
			if (!World.IsAuthority)
			{
				World.UpdateStateVersion(confirmBatch.SenderStateVersion);
				World.DestroyTrash(confirmBatch.ConfirmTime);
			}
			confirmBatch.Dispose();
		}

		private void ProcessDisconnectMessage(DisconnectMessage disconnect)
		{
			closedConnections.Enqueue(disconnect.Sender);
			Session.Assets.ConnectionClosed(disconnect.Sender);
			disconnect.Dispose();
		}

		private void ValidateDeltabatchAndRetransmit(DeltaBatch batch)
		{
			World.SyncController.ValidateDeltaMessages(batch);
			RawValueList<RefID> list = Pool.BorrowRawValueList<RefID>();
			batch.GetConflictingDataRecords(list);
			batch.RemoveInvalidRecords();
			if (World.IsAuthority)
			{
				if (batch.DataRecordCount > 0)
				{
					DeltaBatch deltaBatch = new DeltaBatch(World.StateVersion, World.SyncTick, null, batch);
					deltaBatch.SetSenderTime(batch.SenderTime);
					List<User> list2 = Pool.BorrowList<User>();
					list2.Add(Connections.GetUser(batch.Sender));
					list2.AddRange(newUsersToInitialize);
					World.SwapForOthers(list2);
					Connections.GetConnections(list2, deltaBatch.Targets);
					Pool.Return(ref list2);
					Messages.Outgoing.EnqueueForTransmission(deltaBatch, isOrigin: false, useBackgroundEncoder: false);
				}
				ConfirmationMessage confirmationMessage = new ConfirmationMessage(batch.SenderSyncTick, World.StateVersion, World.SyncTick);
				confirmationMessage.SetSenderTime(World.Time.WorldTime);
				TotalCorrections += list.Count;
				foreach (RefID item in list)
				{
					World.SyncController.EncodeFull(item, confirmationMessage);
				}
				confirmationMessage.Targets.Add(batch.Sender);
				Messages.Outgoing.EnqueueForTransmission(confirmationMessage, isOrigin: true, useBackgroundEncoder: false);
			}
			Pool.Return(ref list);
		}

		private int ApplyDataRecords(BinaryMessageBatch toProcess)
		{
			World.UpdateManager.CurrentlyUpdatingUser = toProcess.SenderUser;
			try
			{
				int num = toProcess.DataRecordCount;
				int num2 = num;
				FullBatch batch = toProcess as FullBatch;
				DeltaBatch deltaBatch = toProcess as DeltaBatch;
				while (num > 0)
				{
					for (int i = 0; i < toProcess.DataRecordCount; i++)
					{
						if (!toProcess.IsProcessed(i) && ((deltaBatch == null) ? World.SyncController.DecodeFullMessage(i, batch) : World.SyncController.DecodeDeltaMessage(i, deltaBatch)))
						{
							toProcess.MarkDataRecordAsProcessed(i);
							num--;
						}
					}
					if (num == num2)
					{
						return num;
					}
					num2 = num;
				}
				return 0;
			}
			finally
			{
				World.UpdateManager.CurrentlyUpdatingUser = null;
			}
		}

		public void Dispose()
		{
			GC.SuppressFinalize(this);
			try
			{
				syncThreadEvent.Set();
				worldUpdateFinished.Set();
				lastProcessingStopped.Dispose();
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception disposing {GetType().Name}:\n{value}");
			}
		}
	}
