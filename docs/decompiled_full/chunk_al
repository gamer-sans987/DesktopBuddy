		public void Update(float deltaTime)
		{
			_lastDeltaTime = deltaTime;
			CursorLock cursorLock = null;
			foreach (World world in Engine.WorldManager.Worlds)
			{
				if (world.State == World.WorldState.Running && world.Focus != World.WorldFocus.Background)
				{
					CursorLock lockCursor = world.Input.LockCursor;
					if (lockCursor != null && (cursorLock == null || cursorLock.priority < lockCursor.priority))
					{
						cursorLock = lockCursor;
					}
				}
			}
			bool flag = false;
			if (cursorLock == null)
			{
				flag = Engine.WorldManager.GetWorld((World w) => w.State == World.WorldState.Running && w.Focus != World.WorldFocus.Background && w.Input.UnlockCursor) != null;
			}
			IsCursorLocked = !flag && IsWindowFocused;
			CursorLockPosition = cursorLock?.position;
			ClearBlockers();
			this.BeforeInputsUpdate?.Invoke();
			if (!HeadOutputDevice.IsVRViewSupported())
			{
				_nextVRactive = false;
			}
			else if (!HeadOutputDevice.IsScreenViewSupported())
			{
				_nextVRactive = true;
			}
			else if (VR_HotswitchingEnabled)
			{
				if (_supressHotswitching)
				{
					if (_nextVRactive == _vrActive && _vrActive == _userPresentInHeadset)
					{
						_supressHotswitching = false;
					}
				}
				else
				{
					_nextVRactive = _userPresentInHeadset;
				}
			}
			if (_nextVRactive != _vrActive)
			{
				_vrActive = _nextVRactive;
				try
				{
					this.VRActiveChanged?.Invoke(_vrActive);
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception running VRActiveChanged events:\n" + ex);
				}
			}
			TypeDelta = "";
			if (_stateToProcess != null)
			{
				ProcessInputState(_stateToProcess, deltaTime);
				_stateToProcess = null;
				if (_onInputStateProcessed.Count > 0)
				{
					lock (_onInputStateProcessed)
					{
						foreach (Action item in _onInputStateProcessed)
						{
							item();
						}
					}
					_onInputStateProcessed.Clear();
				}
			}
			TypeDelta = _virtualTypeDelta + TypeDelta;
			_virtualTypeDelta = null;
			_virtualPresses.Clear();
			foreach (UpdateBucket inputDriverUpdateBucket in inputDriverUpdateBuckets)
			{
				List<IInputDriver> list = null;
				foreach (IInputDriver inputDriver in inputDriverUpdateBucket.inputDrivers)
				{
					try
					{
						inputDriver.UpdateInputs(deltaTime);
					}
					catch (Exception value)
					{
						UniLog.Error($"Exception when updating driver: {inputDriver}:\n{value}");
						if (list == null)
						{
							list = new List<IInputDriver>();
						}
						list.Add(inputDriver);
					}
				}
				if (list == null)
				{
					continue;
				}
				foreach (IInputDriver item2 in list)
				{
					inputDriverUpdateBucket.inputDrivers.Remove(item2);
				}
			}
			Elements.Core.float3 target = SeatedModeOffset;
			if (_supressSeatedMode > 0)
			{
				target = Elements.Core.float3.Zero;
				_supressSeatedMode--;
			}
			_actualSeatedModeOffset = MathX.ConstantLerp(in _actualSeatedModeOffset, in target, deltaTime * 2f);
			Elements.Core.float3 b = GlobalTrackingOffset;
			GlobalTrackingOffset = CustomTrackingOffset + _actualSeatedModeOffset;
			CustomTrackingOffset = Elements.Core.float3.Zero;
			if (GlobalTrackingOffset != b)
			{
				this.GlobalTrackingOffsetChanged?.Invoke(b, GlobalTrackingOffset);
			}
			for (int num = 0; num < inputDevices.Count; num++)
			{
				ITrackedDevice trackedDevice = inputDevices[num] as ITrackedDevice;
				if (trackedDevice != null && trackedDevice.CorrespondingBodyNode.GetRelativeNode() == BodyNode.Root)
				{
					RefVal<Elements.Core.float3> positionRef = trackedDevice.PositionRef;
					positionRef.Value += GlobalTrackingOffset;
				}
				if (trackedDevice != null && trackedDevice.CorrespondingBodyNode != BodyNode.NONE && trackedDevice.IsDeviceActive && trackedDevice.IsTracking)
				{
					int correspondingBodyNode = (int)trackedDevice.CorrespondingBodyNode;
					ITrackedDevice trackedDevice2 = bodyNodes[correspondingBodyNode];
					if (trackedDevice2 == null || !trackedDevice2.IsDeviceActive || !trackedDevice2.IsTracking || trackedDevice2.Priority < trackedDevice.Priority)
					{
						bodyNodes[correspondingBodyNode] = trackedDevice;
					}
				}
			}
			LeftVirtualController.IsDeviceActive = LeftVirtualController == GetControllerNode(Chirality.Left);
			RightVirtualController.IsDeviceActive = RightVirtualController == GetControllerNode(Chirality.Right);
			if (_hapticPointsChanged)
			{
				_hapticPointsChanged = false;
				this.HapticPointsChanged?.Invoke();
			}
			this.AfterInputsUpdate?.Invoke();
			ActivityHeuristic.Update();
		}

