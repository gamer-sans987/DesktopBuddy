			}
			IDirectHapticSource value;
			return directSources.TryRemove(key, out value);
		}

		public void SampleSources(float timeOffset = 0f, Predicate<string> hintFilter = null)
		{
			Span<float> span = stackalloc float[SENSATION_CLASS_COUNT];
			Span<int> span2 = stackalloc int[SENSATION_CLASS_COUNT];
			if (Input.HapticsEnabled)
			{
				hapticHints.Clear();
				List<string> list = null;
				if (hintFilter != null)
				{
					list = Pool.BorrowList<string>();
				}
				foreach (KeyValuePair<HapticSourceID, IDirectHapticSource> directSource in directSources)
				{
					if (directSource.Key.world.Focus != World.WorldFocus.Background)
					{
						for (int i = 0; i < SENSATION_CLASS_COUNT; i++)
						{
							span[i] += directSource.Value.GetIntensity((SensationClass)i);
						}
					}
				}
				foreach (KeyValuePair<HapticSourceID, HapticSampler> hapticSource in hapticSources)
				{
					if (hapticSource.Key.world.Focus == World.WorldFocus.Background)
					{
						continue;
					}
					HapticSampler value = hapticSource.Value;
					int sensation = (int)value.Sensation;
					if (sensation < 0 || sensation >= span2.Length)
					{
						continue;
					}
					DateTime initialImpactTime = value.InitialImpactTime;
					DateTime initialGlobalImpactTime = value.InitialGlobalImpactTime;
					value.InitialImpactTime = value.InitialImpactTime.AddSeconds(0f - timeOffset);
					value.InitialGlobalImpactTime = value.InitialGlobalImpactTime.AddSeconds(0f - timeOffset);
					float num = value.IntensitySampler.ComputeIntensity(value, list);
					value.InitialImpactTime = initialImpactTime;
					value.InitialGlobalImpactTime = initialGlobalImpactTime;
					if (list != null && list.Count > 0)
					{
						foreach (string item in list)
						{
							if (hintFilter(item))
							{
								hapticHints.Add(new HapticHint(item, num, value.Sensation, hapticSource.Key));
							}
						}
						list.Clear();
					}
					span[sensation] += num;
					span2[sensation]++;
				}
				if (list != null)
				{
					Pool.Return(ref list);
				}
			}
			for (int j = 0; j < SENSATION_CLASS_COUNT; j++)
			{
				this[(SensationClass)j] = span[j];
			}
		}

