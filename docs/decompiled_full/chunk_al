		protected override void InternalEncodeFull(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			writer.Write7BitEncoded((ulong)elements.Count);
			foreach (KeyValuePair<K, T> element in elements)
			{
				EncodeKey(writer, element.Key);
				EncodeElement(writer, element.Value);
			}
		}

		protected override void InternalEncodeDelta(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			if (addedElements == null)
			{
				writer.Write7BitEncoded(0uL);
			}
			else
			{
				writer.Write7BitEncoded((ulong)addedElements.Count);
				foreach (AddRecord addedElement in addedElements)
				{
					writer.Write(addedElement.isNew);
					EncodeKey(writer, addedElement.key);
					EncodeElement(writer, addedElement.value);
				}
			}
			if (removedElements == null)
			{
				writer.Write7BitEncoded(0uL);
				return;
			}
			writer.Write7BitEncoded((ulong)removedElements.Count);
			foreach (K removedElement in removedElements)
			{
				EncodeKey(writer, removedElement);
			}
		}

		protected override void InternalDecodeFull(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			uint num = (uint)reader.Read7BitEncoded();
			for (int i = 0; i < num; i++)
			{
				K key = DecodeKey(reader);
				T element = DecodeElement(reader);
				InternalAdd(key, element, isNew: false, sync: false, change: true);
			}
		}

		protected override void InternalDecodeDelta(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			uint num = (uint)reader.Read7BitEncoded();
			for (int i = 0; i < num; i++)
			{
				bool isNew = reader.ReadBoolean();
				K key = DecodeKey(reader);
				T element = DecodeElement(reader);
				InternalAdd(key, element, isNew, sync: false, change: true);
			}
			uint num2 = (uint)reader.Read7BitEncoded();
			for (int j = 0; j < num2; j++)
			{
				K key2 = DecodeKey(reader);
				InternalRemove(key2, sync: false, change: true);
			}
		}

		protected override void InternalClearDirty()
		{
			if (addedElements != null)
			{
				Pool.Return(ref addedElements);
			}
			if (removedElements != null)
			{
				Pool.Return(ref removedElements);
			}
		}
	}
