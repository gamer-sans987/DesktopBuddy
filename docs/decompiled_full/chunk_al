		public async Task AllowHosts(List<string> hosts)
		{
			await Engine.GlobalCoroutineManager.StartTask(async delegate
			{
				await default(NextUpdate);
				foreach (string host in hosts)
				{
					string text = host.Trim().ToLower();
					int port = 80;
					if (Uri.TryCreate(text, UriKind.Absolute, out Uri result) && !string.IsNullOrEmpty(result.Host))
					{
						text = result.Host;
						port = result.Port;
					}
					else
					{
						string[] array = text.Split(':');
						text = array[0];
						if (array.Length > 1 && int.TryParse(array[1], out var result2))
						{
							port = result2;
						}
					}
					UniLog.Log("Allowing host: " + text + ", Port: " + port);
					Engine.Security.TemporarilyAllowHTTP(text);
					Engine.Security.TemporarilyAllowWebsocket(text, port);
					Engine.Security.TemporarilyAllowOSC_Sender(text, port);
					if (text == "localhost")
					{
						Engine.Security.TemporarilyAllowOSC_Receiver(port);
					}
				}
			});
		}

		public Task Shutdown()
		{
			if (updateLoopFinished == null)
			{
				throw new InvalidOperationException("Engine is not running");
			}
			ShutdownRequested = true;
			return updateLoopFinished.Task;
		}

		private void OnEnvironmentShutdownCallback()
		{
			shutdownComplete = true;
		}

		private void UpdateLoop()
		{
			_ = DateTime.UtcNow;
			DateTime dateTime = DateTime.UtcNow;
			while (!shutdownComplete)
			{
				Engine.RunUpdateLoop();
				SystemInfo.FrameFinished();
				Engine.PerfStats.Update(SystemInfo);
				float num = 0f;
				if (TickRate > 0f)
				{
					num = 1f / TickRate;
				}
				dateTime = dateTime.AddTicks((long)(10000000f * num));
				TimeSpan timeSpan = dateTime - DateTime.UtcNow;
				if (timeSpan.TotalMilliseconds > 0.0)
				{
					int num2 = (int)timeSpan.TotalMilliseconds;
					if (num2 > 0)
					{
						Thread.Sleep(num2);
					}
				}
				else
				{
					dateTime = DateTime.UtcNow;
				}
				if (ShutdownRequested)
				{
					Userspace.ExitApp(saveHomes: false);
				}
			}
			try
			{
				Engine.Dispose();
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception disposing engine:\n" + ex);
			}
			updateLoopFinished.SetResult(result: true);
		}

