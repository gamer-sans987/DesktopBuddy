				User.Value = value;
			}
		}

		Type ISyncRef.TargetType => User.TargetType;

		public ReferenceState State => User.State;

		public void Clear()
		{
			User.Clear();
		}

		public bool TrySet(IWorldElement target)
		{
			return User.TrySet(target);
		}

		public void SetFromIdAuto(string id)
		{
			if (id.StartsWith("U-"))
			{
				SetFromCloudId(id);
			}
			else
			{
				SetFromMachineId(id);
			}
		}

		public void SetFromCloudId(string id)
		{
			User user = base.World.FindUser((User u) => u.UserID == id);
			if (user != null)
			{
				User.Target = user;
				return;
			}
			User.Target = null;
			_userId.Value = id;
		}

		public void SetFromMachineId(string id)
		{
			User user = base.World.FindUser((User u) => u.MachineID == id);
			if (user != null)
			{
				User.Target = user;
				return;
			}
			User.Target = null;
			_machineId.Value = id;
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			if (base.World.IsAuthority)
			{
				base.World.UserJoined += World_UserJoined;
			}
			User.OnTargetChange += User_OnTargetChange;
			User.OnObjectAvailable += OnUserAvailable;
			base.World.RunSynchronously(delegate
			{
				if (!base.IsDisposed && Target == null)
				{
					foreach (User allUser in base.World.AllUsers)
					{
						World_UserJoined(allUser);
					}
				}
			});
		}

		private void User_OnTargetChange(SyncRef<User> reference)
		{
			if (base.World.CanMakeSynchronousChanges && reference.Target?.UserID != _userId.Value && reference.Target?.MachineID != _machineId.Value)
			{
				_machineId.Value = null;
				_userId.Value = null;
			}
		}

		private void World_UserJoined(User newUser)
		{
			if (User.Target == null)
			{
				if (!string.IsNullOrEmpty(newUser.UserID) && !string.IsNullOrEmpty(_userId) && newUser.UserID == _userId.Value)
				{
					User.Target = newUser;
				}
				else if (!string.IsNullOrEmpty(newUser.MachineID) && !string.IsNullOrEmpty(_machineId) && newUser.MachineID == _machineId.Value)
				{
					User.Target = newUser;
				}
			}
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			User.OnObjectAvailable -= OnUserAvailable;
			base.World.UserJoined -= World_UserJoined;
		}

		private void OnUserAvailable(SyncRef<User> reference)
		{
			if (base.World.CanMakeSynchronousChanges)
			{
				_machineId.Value = reference.Target.MachineID;
				_userId.Value = reference.Target.UserID;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			User = new SyncRef<User>();
			_machineId = new Sync<string>();
			_userId = new Sync<string>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => User, 
				1 => _machineId, 
				2 => _userId, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static UserRef __New()
		{
			return new UserRef();
		}
	}
