	public class DisplayManager
	{
		private Dictionary<int, Display> _displays = new Dictionary<int, Display>();

		public InputInterface Input { get; private set; }

		public DisplayManager(InputInterface input)
		{
			Input = input;
		}

		public void Update(List<DisplayState> displays, float deltaTime)
		{
			if (displays == null)
			{
				return;
			}
			foreach (DisplayState display in displays)
			{
				if (!_displays.TryGetValue(display.displayIndex, out Display value))
				{
					value = new Display(display.displayIndex);
					Input.RegisterDisplay(value);
					_displays.Add(display.displayIndex, value);
				}
				value.UpdateProperties((Elements.Core.int2)display.resolution, display.refreshRate, display.orientation, (Elements.Core.float2)display.dpi, (Elements.Core.int2)display.offset, display.isPrimary);
			}
		}
	}
