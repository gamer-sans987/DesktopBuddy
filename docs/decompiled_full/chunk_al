	public class SyncDictionary<K, T> : ConflictingSyncElement, IEnumerable<KeyValuePair<K, T>>, IEnumerable, ISyncDictionary, ISyncMember, IChangeable, IWorldElement, ILinkable, IInitializable where T : class, ISyncMember, new()
	{
		private Dictionary<K, T> elements;

		private bool _wasCleared;

		private Dictionary<K, T> _addedElements;

		private HashSet<K> _removedElements;

		public Type KeyType => typeof(K);

		public int Count => elements.Count;

		public override IEnumerable<ILinkable> LinkableChildren => ((IEnumerable<KeyValuePair<K, T>>)elements).Select((Func<KeyValuePair<K, T>, ILinkable>)((KeyValuePair<K, T> p) => p.Value));

