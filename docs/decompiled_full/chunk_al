		private HashSet<ControllerProperty> blockedProperties = new HashSet<ControllerProperty>();

		private Dictionary<Type, IList> globalBlockers = new Dictionary<Type, IList>();

		private List<ControllerProperty> stagedProperties = new List<ControllerProperty>();

		private Dictionary<Type, IList> stagedBlockers = new Dictionary<Type, IList>();

		private List<PropertyBlock> registeredProperties = new List<PropertyBlock>();

		private Dictionary<Type, IList> registeredBlockers = new Dictionary<Type, IList>();

		private HashSet<ControllerProperty> groupBlockedProperties = new HashSet<ControllerProperty>();

		private int submittedGroupPropertyIndex;

		public World World { get; private set; }

		public Engine Engine => World?.Engine;

		public IReadOnlyDictionary<Type, IList> GlobalBlockers => globalBlockers;

		public InputBlockManager(World world)
		{
			World = world;
		}

		public bool IsPropertyBlocked(ControllerProperty property)
		{
			if (!blockedProperties.Contains(property))
			{
				return groupBlockedProperties.Contains(property);
			}
			return true;
		}

		public bool IsBlocked<T>(Predicate<T> check)
		{
			if (globalBlockers.TryGetValue(typeof(T), out IList value))
			{
				foreach (T item in (List<T>)value)
				{
					if (check(item))
					{
						return true;
					}
				}
			}
			return false;
		}

		public IList<T> GetBlockers<T>()
		{
			if (globalBlockers.TryGetValue(typeof(T), out IList value))
			{
				return (IList<T>)value;
			}
			return null;
		}

		public void ClearBlocks()
		{
			blockedProperties.Clear();
			foreach (KeyValuePair<Type, IList> globalBlocker in globalBlockers)
			{
				globalBlocker.Value.Clear();
			}
		}

		public void LoadGlobalBlocks()
		{
			Engine.InputInterface.GetBlockedProperties(blockedProperties);
			Engine.InputInterface.GetGlobalBlockers(globalBlockers);
		}

		public void RegisterProperty(ControllerProperty property, bool blockWithinGroup)
		{
			registeredProperties.Add(new PropertyBlock(property, blockWithinGroup));
		}

		public void RegisterBlocker<T>(T blocker)
		{
			EnsureBlockerList<T>(globalBlockers);
			EnsureBlockerList<T>(stagedBlockers);
			EnsureBlockerList<T>(registeredBlockers).Add(blocker);
		}

		public void AddBlocker<T>(T blocker)
		{
			EnsureBlockerList<T>(globalBlockers).Add(blocker);
		}

		private List<T> EnsureBlockerList<T>(Dictionary<Type, IList> dictionary)
		{
			List<T> list;
			if (dictionary.TryGetValue(typeof(T), out IList value))
			{
				list = (List<T>)value;
			}
			else
			{
				list = new List<T>();
				dictionary.Add(typeof(T), list);
			}
			return list;
		}

		public void SubmitRegisteredBlocksGlobally()
		{
			foreach (PropertyBlock registeredProperty in registeredProperties)
			{
				Engine.InputInterface.RegisterBlockedProperty(registeredProperty.property);
			}
			foreach (KeyValuePair<Type, IList> registeredBlocker in registeredBlockers)
			{
				Engine.InputInterface.RegisterGlobalBlockers(registeredBlocker.Key, registeredBlocker.Value);
			}
		}

		public void SubmitGroupPriorityLevelBlocks()
		{
			while (submittedGroupPropertyIndex < registeredProperties.Count)
			{
				PropertyBlock propertyBlock = registeredProperties[submittedGroupPropertyIndex];
				if (propertyBlock.blockInGroup)
				{
					groupBlockedProperties.Add(propertyBlock.property);
				}
				submittedGroupPropertyIndex++;
			}
		}

		public void StageRegisteredBlocks()
		{
			foreach (PropertyBlock registeredProperty in registeredProperties)
			{
				stagedProperties.Add(registeredProperty.property);
			}
			foreach (KeyValuePair<Type, IList> registeredBlocker in registeredBlockers)
			{
				IList list = stagedBlockers[registeredBlocker.Key];
				foreach (object item in registeredBlocker.Value)
				{
					list.Add(item);
				}
			}
			ClearRegisteredBlocks();
		}

		public void SubmitStagedBlocks()
		{
			foreach (ControllerProperty stagedProperty in stagedProperties)
			{
				blockedProperties.Add(stagedProperty);
			}
			foreach (KeyValuePair<Type, IList> stagedBlocker in stagedBlockers)
			{
				IList list = globalBlockers[stagedBlocker.Key];
				foreach (object item in stagedBlocker.Value)
				{
					list.Add(item);
				}
			}
			ClearStagedBlocks();
		}

		public void ClearRegisteredBlocks()
		{
			registeredProperties.Clear();
			foreach (KeyValuePair<Type, IList> registeredBlocker in registeredBlockers)
			{
				registeredBlocker.Value.Clear();
			}
			groupBlockedProperties.Clear();
			submittedGroupPropertyIndex = 0;
		}

		public void ClearStagedBlocks()
		{
			stagedProperties.Clear();
			foreach (KeyValuePair<Type, IList> stagedBlocker in stagedBlockers)
			{
				stagedBlocker.Value.Clear();
			}
		}

		public void Clear()
		{
			ClearBlocks();
			ClearRegisteredBlocks();
			ClearStagedBlocks();
		}
	}
