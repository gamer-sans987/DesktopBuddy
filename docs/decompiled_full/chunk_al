	public abstract class SlotHierarchyEventHandler<H, M> where H : SlotHierarchyEventHandler<H, M> where M : SlotHierarchyEventManger<H, M>
	{
		protected SlimList<H> _children;

		public Slot Slot { get; private set; }

		public M Manager { get; private set; }

		public H Parent { get; private set; }

		public int ChildrenCount => _children.Count;

		public H this[int index] => _children[index];

		public abstract bool HasListeners { get; }

		public SlotHierarchyEventHandler(M manager, Slot slot)
		{
			Slot = slot;
			Manager = manager;
			Slot.ParentChanged += Slot_ParentChanged;
			Slot.Disposing += Slot_Disposing;
			if (!slot.IsRootSlot)
			{
				Slot_ParentChanged(Slot);
			}
		}

		protected virtual void OnParentChanged()
		{
		}

		private void Slot_Disposing(Worker obj)
		{
			Destroy(isSlotDisposing: true);
		}

		private void Slot_ParentChanged(Slot slot)
		{
			H parent = Parent;
			Slot parent2 = slot.Parent;
			H handler = Manager.GetHandler(parent2, createIfDoesNotExist: true);
			handler.RegisterChild((H)this);
			Parent = handler;
			parent?.UnregisterChild((H)this);
			OnParentChanged();
		}

		public H TryGetChildHandler(Slot childSlot)
		{
			foreach (H child in _children)
			{
				if (child.Slot == childSlot)
				{
					return child;
				}
			}
			return null;
		}

		private void RegisterChild(H handler)
		{
			_children.Add(handler);
		}

		private void UnregisterChild(H handler)
		{
			if (_children.Remove(handler))
			{
				CheckRemove();
			}
		}

		protected bool CheckRemove()
		{
			if (!HasListeners && _children.Count == 0 && !Slot.IsRootSlot)
			{
				Destroy(isSlotDisposing: false);
				return true;
			}
			return false;
		}

		protected virtual void Destroy(bool isSlotDisposing)
		{
			Parent?.UnregisterChild((H)this);
			Manager.HandlerRemoved((H)this);
			if (!isSlotDisposing)
			{
				Slot.ParentChanged -= Slot_ParentChanged;
				Slot.Disposing -= Slot_Disposing;
			}
			Slot = null;
			Manager = null;
			Parent = null;
			_children.Clear();
		}

		public override string ToString()
		{
			return $"EventHandler for {Slot?.Name} ({Slot?.ReferenceID})";
		}

		public string HierarchyToString()
		{
			StringBuilder stringBuilder = Pool.BorrowStringBuilder();
			DebugToString(0, stringBuilder);
			string result = stringBuilder.ToString();
			Pool.Return(ref stringBuilder);
			return result;
		}

		private void DebugToString(int indentLevel, StringBuilder str)
		{
			for (int i = 0; i < indentLevel; i++)
			{
				str.Append("-");
			}
			StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(3, 2, str);
			handler.AppendFormatted(Slot?.Name);
			handler.AppendLiteral(" (");
			handler.AppendFormatted(Slot?.ReferenceID);
			handler.AppendLiteral(")");
			str.AppendLine(ref handler);
			foreach (H child in _children)
			{
				child.DebugToString(indentLevel + 1, str);
			}
		}
	}
