	public class MultiTapInput : IInputNode<bool>, IInputNode
	{
		public readonly List<IInputNode<bool>> Sources = new List<IInputNode<bool>>();

		private bool _active;

		private List<DateTime> _detectionStartTime = new List<DateTime>();

		private List<int> _tapCount = new List<int>();

		private List<bool> _lastValues = new List<bool>();

		public bool Toggle { get; set; }

		public int TapCount { get; set; } = 2;

		public float Interval { get; set; } = 0.25f;

		public bool IgnoreNull { get; set; }

		public MultiTapInput(IInputNode<bool> source, bool toggle, int tapCount = 2, float interval = 0.25f, bool ignoreNull = false)
		{
			Sources.Add(source);
			Toggle = toggle;
			TapCount = tapCount;
			Interval = interval;
			IgnoreNull = ignoreNull;
		}

		public MultiTapInput(IEnumerable<IInputNode<bool>> sources, bool toggle, int tapCount = 2, float interval = 0.25f)
		{
			Sources.AddRange(sources);
			Toggle = toggle;
			TapCount = tapCount;
			Interval = interval;
		}

		public bool? Evaluate(in InputEvaluationContext context)
		{
			if (Sources.Count > 1024)
			{
				throw new Exception("Too many sources");
			}
			_lastValues.EnsureExactCount(Sources.Count);
			_tapCount.EnsureExactCount(Sources.Count);
			_detectionStartTime.EnsureExactCount(Sources.Count);
			Span<bool?> span = stackalloc bool?[Sources.Count];
			Span<bool> span2 = stackalloc bool[Sources.Count];
			bool flag = false;
			bool flag2 = false;
			for (int i = 0; i < Sources.Count; i++)
			{
				span[i] = Sources[i]?.Evaluate(in context);
				if (!span[i].HasValue)
				{
					if (IgnoreNull)
					{
						span[i] = false;
					}
					else
					{
						flag = true;
					}
				}
				else if (span[i].Value)
				{
					flag2 = true;
				}
			}
			if (flag)
			{
				if (Toggle && _active)
				{
					return true;
				}
				Reset(fullReset: true);
				return null;
			}
			bool flag3 = false;
			for (int j = 0; j < span.Length; j++)
			{
				if (span[j].Value && !_lastValues[j])
				{
					span2[j] = true;
					flag3 = true;
				}
			}
			if (_active)
			{
				if (Toggle)
				{
					if (flag3)
					{
						ResetNode();
					}
				}
				else if (!flag2)
				{
					ResetNode();
				}
			}
			else
			{
				for (int k = 0; k < span.Length; k++)
				{
					if (span2[k])
					{
						if (_tapCount[k] == 0)
						{
							_detectionStartTime[k] = DateTime.UtcNow;
						}
						_tapCount[k]++;
						if (_tapCount[k] >= TapCount)
						{
							_active = true;
						}
					}
					else if (_tapCount[k] > 0 && (DateTime.UtcNow - _detectionStartTime[k]).TotalSeconds > (double)Interval)
					{
						_detectionStartTime[k] = default(DateTime);
						_tapCount[k] = 0;
					}
				}
			}
			for (int l = 0; l < span.Length; l++)
			{
				_lastValues[l] = span[l].Value;
			}
			return _active;
		}

		public void ResetNode()
		{
