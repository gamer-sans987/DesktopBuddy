	public class CategoryNode<T>
	{
		public readonly CategoryNode<T> Parent;

		public readonly string Name;

		private SortedDictionary<string, CategoryNode<T>> _subcategories;

		private List<T> _elements;

		private bool _sorted;

		public IEnumerable<CategoryNode<T>> Subcategories => _subcategories.Values;

		public IEnumerable<T> Elements
		{
			get
			{
				EnsureSorted();
				return _elements;
			}
		}

		public int ElementCount => _elements.Count;

		public int TotalElementCount { get; private set; }

		public Func<T, string> GetElementName { get; private set; }

		public CategoryNode(Func<T, string> getElementName)
		{
			Name = "<root>";
			Parent = null;
			_subcategories = new SortedDictionary<string, CategoryNode<T>>();
			_elements = new List<T>();
			GetElementName = getElementName;
		}

		public CategoryNode(string name, CategoryNode<T> parent)
		{
			Name = name;
			Parent = parent;
			_subcategories = new SortedDictionary<string, CategoryNode<T>>();
			_elements = new List<T>();
			GetElementName = parent.GetElementName;
		}

		internal void IncrementTotalElements()
		{
			TotalElementCount++;
			Parent?.IncrementTotalElements();
		}

		public void AddElement(T element)
		{
			_elements.Add(element);
			_sorted = false;
			IncrementTotalElements();
		}

		public T GetElement(int index)
		{
			EnsureSorted();
			return _elements[index];
		}

		private void EnsureSorted()
		{
			if (!_sorted)
			{
				_elements.Sort((T a, T b) => GetElementName(a).CompareTo(GetElementName(b)));
				_sorted = true;
			}
		}

		public string GetPath()
		{
			if (Parent == null)
			{
				return "";
			}
			return Parent.GetPath() + "/" + Name;
		}

		public CategoryNode<T> GetSubcategory(string path)
		{
			string text = null;
			string text2 = null;
			path = path ?? "";
			if (path.Length > 1024)
			{
				return null;
			}
			path = path.Replace('\\', '/');
			int num = path.IndexOf("/");
			if (num == 0)
			{
				path = path.Substring(1);
				num = path.IndexOf("/");
			}
			if (num > 0)
			{
				text = path.Substring(num + 1);
				text2 = path.Substring(0, num);
			}
			else
			{
				text2 = path;
			}
			if (string.IsNullOrEmpty(text2))
			{
				return this;
			}
			if (!_subcategories.TryGetValue(text2, out CategoryNode<T> value))
			{
				value = new CategoryNode<T>(text2, this);
				_subcategories.Add(text2, value);
			}
			if (text == null)
			{
				return value;
			}
			return value.GetSubcategory(text);
		}
	}
