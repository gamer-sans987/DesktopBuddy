					{
						_rightDimple = OSC_Driver.ReadFloat(message);
					}
					break;
				}
				break;
			case 26:
				switch (address[25])
				{
				case 'L':
					if (!(address == "/sl/xrfb/facew/EyesClosedL"))
					{
						if (address == "/sl/xrfb/facew/LipPressorL")
						{
							_lipPressL = OSC_Driver.ReadFloat(message);
						}
					}
					else
					{
						_leftOpenness = 1f - MathX.Sqrt(OSC_Driver.ReadFloat(message));
					}
					break;
				case 'R':
					if (!(address == "/sl/xrfb/facew/EyesClosedR"))
					{
						if (address == "/sl/xrfb/facew/LipPressorR")
						{
							_lipPressR = OSC_Driver.ReadFloat(message);
						}
					}
					else
					{
						_rightOpenness = 1f - MathX.Sqrt(OSC_Driver.ReadFloat(message));
