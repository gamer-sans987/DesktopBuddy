	public abstract class MovedHierarchyEventHandler<H, M> : SlotHierarchyEventHandler<H, M>, IComparable<H> where H : MovedHierarchyEventHandler<H, M> where M : MovedHierarchyEventManager<H, M>
	{
		private const byte MOVE_DIRTY_FLAG = 1;

		private const byte SCALE_DIRTY_FLAG = 2;

		private const byte ANY_DIRTY_FLAG = 3;

		private const int EVENT_MASK_SHIFT = 2;

		private const byte MOVED_EVENT = 4;

		private const byte SCALED_EVENT = 8;

		private const byte ANY_EVENT = 12;

		private byte _flags;

		public override bool HasListeners
		{
			get
			{
				if (this._slotMoved == null)
				{
					return this._slotScaled != null;
				}
				return true;
			}
		}

		public int Depth { get; private set; }

		public bool MoveDirty => (_flags & 1) != 0;

		public bool ScaleDirty => (_flags & 2) != 0;

		public byte DirtyFlags => (byte)(_flags & 3);

		public bool AnyDirty => DirtyFlags != 0;

		public bool TracksMovedEvent => (_flags & 4) != 0;

		public bool TracksScaleEvent => (_flags & 8) != 0;

		public byte Events => (byte)(_flags & 0xC);

		public event SlotEvent SlotMoved
		{
			add
			{
				_slotMoved += value;
				if (!TracksMovedEvent)
				{
					_flags |= 4;
					base.Parent?.ChildEventsChanged(this);
				}
			}
			remove
			{
				if (this._slotMoved != null)
				{
					_slotMoved -= value;
					if (!CheckRemove() && this._slotMoved == null)
					{
						TryUnflagMoved();
					}
				}
			}
		}

		public event SlotEvent SlotScaled
		{
			add
			{
				_slotScaled += value;
				if (!TracksScaleEvent)
				{
					_flags |= 8;
					base.Parent?.ChildEventsChanged(this);
				}
			}
			remove
			{
				if (this._slotScaled != null)
				{
					_slotScaled -= value;
					if (!CheckRemove() && this._slotMoved == null)
					{
						TryUnflagScaled();
					}
				}
			}
		}

		private event SlotEvent _slotMoved;

		private event SlotEvent _slotScaled;

		private void TryUnflagMoved()
		{
			for (int i = 0; i < _children.Count; i++)
			{
				if (_children[i].TracksMovedEvent)
				{
					return;
				}
			}
			_flags = (byte)(_flags & -5);
			base.Parent?.ChildEventsChanged(this);
		}

		private void TryUnflagScaled()
		{
			for (int i = 0; i < _children.Count; i++)
			{
				if (_children[i].TracksScaleEvent)
				{
					return;
				}
			}
			_flags = (byte)(_flags & -9);
			base.Parent?.ChildEventsChanged(this);
		}

		protected abstract void RegisterMoved();

		public void MarkMoved(bool scaleChanged)
		{
			if (!AnyDirty)
			{
				RegisterMoved();
			}
			_flags |= (byte)((!scaleChanged) ? 1 : 3);
		}

		private void ChildEventsChanged(MovedHierarchyEventHandler<H, M> child)
		{
			byte events = child.Events;
			if (events == Events)
			{
				return;
			}
			bool num = TracksMovedEvent != child.TracksMovedEvent;
			bool flag = TracksScaleEvent != child.TracksScaleEvent;
			if ((num && TracksMovedEvent) || (flag && TracksScaleEvent))
			{
				byte b = 0;
				foreach (H child2 in _children)
				{
					b |= child2.Events;
				}
				_flags = (byte)((_flags & -13) | b);
			}
			else
			{
				_flags |= events;
			}
			base.Parent?.ChildEventsChanged(this);
		}

		protected override void OnParentChanged()
		{
			if (base.Parent == null)
			{
				Depth = 0;
			}
			else
			{
				Depth = base.Parent.Depth + 1;
				if (Events != 0)
				{
					base.Parent?.ChildEventsChanged(this);
				}
			}
			MarkMoved(scaleChanged: true);
		}

		public int SendMovedEvent(byte parentChangedMask = 0)
		{
			Slot slot = base.Slot;
			if (slot == null)
			{
				return 0;
			}
			byte b = (byte)(DirtyFlags | parentChangedMask);
			if (b == 0)
			{
				return 0;
			}
			b = (byte)(b & (Events >> 2));
			if (b == 0)
			{
				slot.ClearTransformDirty();
				ClearDirtyFlags();
				return 0;
			}
			try
			{
				this._slotMoved?.Invoke(slot);
				if ((b & 2) != 0)
				{
					this._slotScaled?.Invoke(slot);
				}
				slot.ClearTransformDirty();
			}
			catch (Exception exception)
			{
				UniLog.Error($"Exception running Moved Event on\n{slot?.ParentHierarchyToString() ?? "NULL"}\n\n{DebugManager.PreprocessException(exception)}", stackTrace: false);
			}
			ClearDirtyFlags();
			int num = 1;
			for (int num2 = _children.Count - 1; num2 >= 0; num2--)
			{
				num += _children[num2].SendMovedEvent(b);
			}
			return num;
		}

		private void ClearDirtyFlags()
		{
			_flags = (byte)(_flags & -4);
		}

		public MovedHierarchyEventHandler(M manager, Slot slot)
			: base(manager, slot)
		{
			MarkMoved(scaleChanged: true);
		}

		protected override void Destroy(bool isSlotDisposing)
		{
			base.Destroy(isSlotDisposing);
		}

		public int CompareTo(H other)
		{
			return Depth.CompareTo(other.Depth);
		}
	}
