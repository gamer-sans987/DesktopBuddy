	public class WindowsInputInjector : IInputDriver, ISystemInputInjector, IDisposable
	{
		private enum TouchStatus
		{
			Uninitialized,
			Released,
			Hovering,
			Touching
		}

		private class TouchData
		{
			public readonly Pointer touch;

			public readonly uTouchInjection.Pointer pointer;

			public bool allocated;

			public TouchStatus status;

			public TouchData(Pointer touch, uTouchInjection.Pointer pointer)
			{
				this.touch = touch;
				this.pointer = pointer;
			}
		}

		public const int MAX_TOUCHES = 10;

		private InputSimulator _inputSimulator;

		private List<TouchData> _touches = new List<TouchData>();

		private Elements.Core.int2? _mousePosition;

		private Elements.Core.int2? _leftClick;

		private Elements.Core.int2? _rightClick;

		private Elements.Core.int2? _middleClick;

		public int UpdateOrder => 0;

		public static event Lib.DebugLogDelegate onDebugLog;

		public static event Lib.DebugLogDelegate onDebugErr;

		[DllImport("user32.dll")]
		[return: MarshalAs(UnmanagedType.Bool)]
		private static extern bool SetCursorPos(int x, int y);

		public WindowsInputInjector()
		{
			_inputSimulator = new InputSimulator();
			Lib.SetDebugMode(DebugMode.None);
			Lib.SetLogFunc(WindowsInputInjector.onDebugLog);
			Lib.SetErrorFunc(WindowsInputInjector.onDebugErr);
			Lib.Initialize(10);
			for (int i = 0; i < 10; i++)
			{
				_touches.Add(new TouchData(new Pointer(i, PointerType.Touch), new uTouchInjection.Pointer(i)));
			}
		}

		private void SetCursorPos(Elements.Core.int2 position)
		{
			SetCursorPos(position.x, position.y);
		}

		public void CollectDeviceInfos(DataTreeList list)
		{
		}

		public Pointer InjectTouch()
		{
			lock (_touches)
			{
				for (int i = 0; i < _touches.Count; i++)
				{
					TouchData touchData = _touches[i];
					if (!touchData.allocated)
					{
						touchData.allocated = true;
						return touchData.touch;
					}
				}
			}
			return null;
		}

		public void RemoveInjectedTouch(Pointer touch)
		{
			lock (_touches)
			{
				for (int i = 0; i < _touches.Count; i++)
				{
					TouchData touchData = _touches[i];
					if (touchData.touch == touch)
					{
						if (!touchData.allocated)
						{
							throw new InvalidOperationException("This touch isn't currently allocated");
						}
						touchData.allocated = false;
						return;
					}
				}
			}
			throw new InvalidOperationException("This touch doesn't belong to the touch injection driver");
		}

		public void InjectString(string str)
		{
			StringBuilder buffer = new StringBuilder();
			foreach (char c in str)
			{
				switch (c)
				{
				case '\b':
					InjectKey(Key.Backspace);
					break;
				case '\n':
				case '\r':
					InjectKey(Key.Return);
					break;
				case '\t':
					InjectKey(Key.Tab);
					break;
				default:
					buffer.Append(c);
					break;
				case '\0':
				case '\a':
				case '\f':
					break;
				}
			}
			SubmitBuffer();
			void InjectKey(Key key)
			{
				SubmitBuffer();
				InjectKeyPress(key);
			}
			void SubmitBuffer()
			{
				if (buffer.Length > 0)
				{
					_inputSimulator.Keyboard.TextEntry(buffer.ToString());
					buffer.Clear();
				}
			}
		}

		public void InjectKeyPress(Key key)
		{
			bool shift;
			VirtualKeyCode keyCode = key.ToWindows(out shift);
			if (shift)
			{
				_inputSimulator.Keyboard.ModifiedKeyStroke(VirtualKeyCode.LSHIFT, keyCode);
			}
			else
			{
				_inputSimulator.Keyboard.KeyPress(keyCode);
			}
		}

		private static bool RequiresShift(Key key)
		{
			key.ToWindows(out var shift);
			return shift;
		}

		public void InjectKeyPress(List<Key> keys)
		{
			foreach (Key key in keys)
			{
				bool shift;
				VirtualKeyCode keyCode = key.ToWindows(out shift);
				if (shift)
				{
					_inputSimulator.Keyboard.ModifiedKeyStroke(VirtualKeyCode.LSHIFT, keyCode);
				}
			}
			keys.RemoveAll((Key k) => RequiresShift(k));
			if (keys.Count == 0)
			{
				return;
			}
			int num = keys.Count((Key k) => k.IsModifier());
			bool shift2;
			if (num == 0 || num == keys.Count)
			{
				_inputSimulator.Keyboard.KeyPress(keys.Select((Key k) => k.ToWindows(out shift2)).ToArray());
				return;
			}
			_inputSimulator.Keyboard.ModifiedKeyStroke(from k in keys
				where k.IsModifier()
				select k.ToWindows(out shift2), from k in keys
				where !k.IsModifier()
				select k.ToWindows(out shift2));
		}

		public void RegisterInputs(InputInterface inputInterface)
		{
			UniLog.Log("Windows input injector initialized");
		}

		public void UpdateInputs(float deltaTime)
		{
			for (int i = 0; i < _touches.Count; i++)
			{
				TouchData touchData = _touches[i];
				Elements.Core.int2 position = MathX.RoundToInt(touchData.touch.Position.Value);
				if (touchData.allocated)
				{
					touchData.pointer.areaSize = 1;
					if (touchData.status == TouchStatus.Released)
					{
						touchData.pointer.Release(in position);
					}
					if (touchData.touch.PrimaryPress.Held)
					{
						touchData.pointer.Touch(in position);
						touchData.status = TouchStatus.Touching;
					}
					else
					{
						touchData.pointer.Hover(in position);
						touchData.status = TouchStatus.Hovering;
					}
				}
				else if (touchData.status != TouchStatus.Released)
				{
					touchData.pointer.Release(in position);
					touchData.status = TouchStatus.Released;
				}
			}
			Lib.Update();
			if (_mousePosition.HasValue)
			{
				SetCursorPos(_mousePosition.Value);
				_mousePosition = null;
			}
			if (_leftClick.HasValue)
			{
				SetCursorPos(_leftClick.Value);
				_inputSimulator.Mouse.LeftButtonClick();
				_leftClick = null;
			}
			if (_rightClick.HasValue)
			{
				SetCursorPos(_rightClick.Value);
				_inputSimulator.Mouse.RightButtonClick();
				_rightClick = null;
			}
			if (_middleClick.HasValue)
			{
				SetCursorPos(_middleClick.Value);
				_inputSimulator.Mouse.XButtonClick(1);
				_middleClick = null;
			}
		}

		private static void OnDebugLog(string msg)
		{
			UniLog.Log("TouchInjection: " + msg);
		}

		private static void OnDebugErr(string msg)
		{
			UniLog.Error("TouchInjection: " + msg, stackTrace: false);
		}

		public void SetMousePosition(Elements.Core.int2 position)
		{
			_mousePosition = position;
		}

		public void SendLeftClick(Elements.Core.int2 position)
		{
			_leftClick = position;
		}

		public void SendRightClick(Elements.Core.int2 position)
		{
			_rightClick = position;
		}

		public void SendMiddleClick(Elements.Core.int2 position)
		{
			_middleClick = position;
		}

		public void Dispose()
		{
			Lib.Finalize();
		}

		static WindowsInputInjector()
		{
			WindowsInputInjector.onDebugLog = OnDebugLog;
			WindowsInputInjector.onDebugErr = OnDebugErr;
		}
	}
