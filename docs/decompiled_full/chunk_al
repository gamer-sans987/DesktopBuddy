		public int RemoveAll(Predicate<KeyValuePair<K, T>> predicate)
		{
			List<K> list = new List<K>();
			using (IEnumerator<KeyValuePair<K, T>> enumerator = GetEnumerator())
			{
				while (enumerator.MoveNext())
				{
					KeyValuePair<K, T> current = enumerator.Current;
					if (predicate(current))
					{
						list.Add(current.Key);
					}
				}
			}
			foreach (K item in list)
			{
				Remove(item);
			}
			return list.Count;
		}

