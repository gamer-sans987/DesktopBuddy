			if (!val.HasValue)
			{
				ResetConversion();
				return null;
			}
			return Convert(val.Value, in context);
		}

		public void ResetNode()
		{
			Source?.ResetNode();
			ResetConversion();
		}

		protected abstract O Convert(I input, in InputEvaluationContext context);

		protected virtual void ResetConversion()
		{
		}

		public ConversionInputNode(IInputNode<I> source)
		{
			Source = source;
		}

		O? IInputNode<O>.Evaluate(in InputEvaluationContext context)
		{
			return Evaluate(in context);
