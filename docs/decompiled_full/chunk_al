		public async Task CreateWorldOrUpdate(List<string> tags, Func<World, Task> action, WorldAction worldTemplate = null)
		{
			CloudResult<SearchResults<SkyFrost.Base.Record>> cloudResult = await Engine.Cloud.Records.FindRecords<SkyFrost.Base.Record>(new SearchParameters
			{
				Count = 1,
				SortBy = SearchSortParameter.LastUpdateDate,
				SortDirection = SearchSortDirection.Descending,
				RecordType = "world",
				RequiredTags = tags,
				ByOwner = Engine.Cloud.CurrentUser.Username,
				OwnerType = OwnerType.User,
				Private = true
			}).ConfigureAwait(continueOnCapturedContext: false);
			if (!cloudResult.IsOK)
			{
				UniLog.Warning("Failed searching worlds");
				return;
			}
			if (cloudResult.Entity.Records.Count > 0)
			{
				UniLog.Log($"World found, updating: {cloudResult.Entity.Records[0]}");
				await UpdateWorld(cloudResult.Entity.Records[0].GetUrl(Engine.Cloud.Platform), action);
				return;
			}
			UniLog.Log("World doesn't exist, creating new...");
			await RunAction(async delegate(World w)
			{
				w.Tags = tags;
				await action(w);
				FrooxEngine.Store.Record record = w.CreateNewRecord(Engine.Cloud.CurrentUserID);
				RecordOwnerTransferer transferer = new RecordOwnerTransferer(Engine, record.OwnerId);
				await Userspace.SaveWorld(w, record, transferer);
