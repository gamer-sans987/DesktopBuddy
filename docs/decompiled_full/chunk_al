			Joystick.UpdateValue(MathX.RadialDeadzone(in axis, Deadzone), deltaTime);
		}

		public override void Bind(InputGroup group)
		{
			if (group.Side != base.Side)
			{
				return;
			}
			if (!(group is InteractionHandlerInputs interactionHandlerInputs))
			{
				if (!(group is LaserHoldInputs laserHoldInputs))
				{
					if (!(group is TeleportInputs teleportInputs))
					{
						if (group is GrabWorldInputs grabWorldInputs)
						{
							grabWorldInputs.Grab.AddBinding(InputNode.Analog2D(Joystick).Y().ToDigital(0.5f), this);
							grabWorldInputs.TurnDelta.AddBinding(InputNode.Analog2D(Joystick).X().LocomotionTurn(), this);
							return;
						}
						UniLog.Log($"Cannot bind {group.GetType()} to {GetType()}");
					}
					else
					{
						teleportInputs.Teleport.AddBinding(InputNode.Analog2D(Joystick).Y().ToDigital(0.8f), this);
						teleportInputs.Backstep.AddBinding(InputNode.Analog2D(Joystick).Y().Negate()
							.ToDigital(0.8f), this);
						teleportInputs.TurnDelta.AddBinding(InputNode.Analog2D(Joystick).X().LocomotionTurn(), this);
					}
				}
				else
				{
					laserHoldInputs.Align.AddBinding(InputNode.Digital(TriggerClick), this);
					laserHoldInputs.Slide.AddBinding(InputNode.Analog2D(Joystick).Y(), this);
					laserHoldInputs.Rotate.AddBinding(InputNode.Analog2D(Joystick).X(), this);
				}
			}
			else
			{
				interactionHandlerInputs.Interact.AddBinding(InputNode.Digital(TriggerClick), this);
				interactionHandlerInputs.Secondary.AddBinding(InputNode.Digital(JoystickClick), this);
				interactionHandlerInputs.Grab.AddBinding(InputNode.Digital(GripClick), this);
				interactionHandlerInputs.Menu.AddBinding(InputNode.Digital(ButtonBY), this);
				interactionHandlerInputs.UserspaceToggle.AddBinding(InputNode.Digital(ButtonAX), this);
				interactionHandlerInputs.Strength.AddBinding(InputNode.Analog(Trigger), this);
				interactionHandlerInputs.Axis.AddBinding(InputNode.Analog2D(Joystick), this);
			}
		}

		public override void BindNodeActions(InputGroup group, IInputNode node, string name = null)
		{
			if (!(node is IDualAxisInputNode dualAxisInputNode))
			{
				if (!(node is AnyInput anyInput))
				{
					if (!(node is LeftRightSelector<bool> leftRightSelector))
					{
						if (!(node is LeftRightSelector<Elements.Core.float2> leftRightSelector2))
						{
							if (node is SumInputs<float> sumInputs && name == "ReleaseStrength")
							{
								sumInputs.Inputs.Add(InputNode.Analog2D(base.Side, "Joystick").Magnitude());
							}
						}
						else if (name == "AnchorAxis")
						{
							leftRightSelector2.SetNode(base.Side, InputNode.Analog2D(base.Side, "Joystick"));
						}
					}
					else
					{
						switch (name)
						{
						case "Jump":
						case "Align":
							leftRightSelector.SetNode(base.Side, InputNode.Digital(base.Side, "JoystickClick"));
							break;
						case "AnchorAction":
							leftRightSelector.SetNode(base.Side, InputNode.Digital(base.Side, "JoystickClick"));
							break;
						}
					}
				}
				else if (name == "Jump")
				{
					anyInput.Inputs.Add(InputNode.Digital(base.Side, "JoystickClick"));
				}
			}
			else
			{
				dualAxisInputNode.SetInput(base.Side, InputNode.Analog2D(base.Side, "Joystick"));
			}
		}

		public override void ApplyState(CosmosControllerState state, float deltaTime)
		{
			VIVE.UpdateState(state.vive);
			ButtonAX.UpdateState(state.buttonAX);
			ButtonBY.UpdateState(state.buttonBY);
			Bumper.UpdateState(state.bumper);
			GripClick.UpdateState(state.gripClick);
			UpdateJoystick(FilterAxis((Elements.Core.float2)state.joystickRaw), deltaTime);
			JoystickTouch.UpdateState(state.joystickTouch);
			JoystickClick.UpdateState(state.joystickClick);
			Trigger.UpdateValue(FilterTrigger(state.trigger), deltaTime);
			TriggerTouch.UpdateState(state.triggerTouch);
			TriggerClick.UpdateState(state.triggerClick);
		}
	}
