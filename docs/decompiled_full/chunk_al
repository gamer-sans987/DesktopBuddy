				UniLog.Log("Registering Vive Finger Tracking");
				LeftHand = new Hand(inputInterface, Chirality.Left, PRIORITY);
				RightHand = new Hand(inputInterface, Chirality.Right, PRIORITY);
				LeftHand.SetTracking(tracking: false, forceUpdate: true);
				RightHand.SetTracking(tracking: false, forceUpdate: true);
				registered = true;
			}
			if (!registered)
			{
				return;
			}
			ITrackedDevice bodyNode = inputInterface.GetBodyNode(BodyNode.Head);
			ITrackedDevice trackedDevice = null;
			ITrackedDevice trackedDevice2 = null;
			for (int i = 0; i < inputInterface.InputDeviceCount; i++)
			{
				if (!(inputInterface.GetDevice(i) is ITrackedDevice { IsTracking: not false } trackedDevice3))
				{
					continue;
				}
				if (trackedDevice3.CorrespondingBodyNode == BodyNode.LeftHand)
				{
					if (trackedDevice3 == LeftHand.Wrist)
					{
						continue;
					}
					if (trackedDevice == null || trackedDevice3.Priority > trackedDevice.Priority)
					{
						trackedDevice = trackedDevice3;
					}
				}
				if (trackedDevice3.CorrespondingBodyNode == BodyNode.RightHand && trackedDevice3 != RightHand.Wrist && (trackedDevice2 == null || trackedDevice3.Priority > trackedDevice2.Priority))
				{
					trackedDevice2 = trackedDevice3;
				}
			}
			Elements.Core.floatQ b = Elements.Core.floatQ.Euler(in RotationOffset);
			Elements.Core.floatQ b2 = b.Inverted;
			Elements.Core.floatQ a = bodyNode.Rotation;
			matrix = Elements.Core.float4x4.Transform(bodyNode.Position, Elements.Core.floatQ.Multiply(ref a, ref b), Elements.Core.float3.One);
			rotation = Elements.Core.floatQ.Multiply(ref a, ref b2);
			UpdateHand(LeftHand, TrackingEnabled ? state.left : null, trackedDevice);
			UpdateHand(RightHand, TrackingEnabled ? state.right : null, trackedDevice2);
		}

		private void UpdateHand(Hand hand, ViveHandState? viveHand, ITrackedDevice? reference)
		{
			if (viveHand == null)
			{
				hand.SetTracking(tracking: false);
				return;
			}
			hand.SetTracking(tracking: true, forceUpdate: false, hasForearm: false, hasPalm: false);
			hand.Confidence = viveHand.confidence;
			hand.PinchStrength = viveHand.pinchStrength;
			Elements.Core.floatQ b = Elements.Core.floatQ.AxisAngle(Elements.Core.float3.Right, -90f);
			hand.Wrist.RawPosition = Transform((Elements.Core.float3)viveHand.points[0], isUnderWrist: false);
			hand.Wrist.RawRotation = Transform((Elements.Core.floatQ)viveHand.rotation * b);
			hand.Palm.RawPosition = Transform((Elements.Core.float3)viveHand.position, isUnderWrist: false);
			hand.Palm.RawRotation = Transform((Elements.Core.floatQ)viveHand.rotation * b);
			if (reference != null)
			{
				int num = ((!(MathX.Distance(reference.Position, hand.Wrist.RawPosition) > (float)_settings.SnapDistance)) ? (reference.Priority - 1) : PRIORITY);
				if (num != hand.Wrist.Priority)
				{
					hand.Wrist.Priority = num;
					foreach (Finger item in hand)
					{
						foreach (FingerSegment item2 in item)
						{
							item2.Priority = (_settings.UseFingersWhenSnapped ? PRIORITY : num);
						}
					}
				}
			}
			wristMatrix = Elements.Core.float4x4.Transform(hand.Wrist.RawPosition, hand.Wrist.RawRotation, Elements.Core.float3.One);
			wristMatrix = wristMatrix.Inverse * matrix;
			wristRotation = hand.Wrist.RawRotation.Inverted;
			wristRotation *= rotation;
			hand.Thumb.Metacarpal.RawPosition = Transform((Elements.Core.float3)viveHand.points[1]);
			hand.Thumb.Proximal.RawPosition = Transform((Elements.Core.float3)viveHand.points[2]);
			hand.Thumb.Distal.RawPosition = Transform((Elements.Core.float3)viveHand.points[3]);
			hand.Thumb.Tip.RawPosition = Transform((Elements.Core.float3)viveHand.points[4]);
			hand.Index.Metacarpal.RawPosition = Transform(MathX.Lerp((Elements.Core.float3)viveHand.points[0], (Elements.Core.float3)viveHand.points[5], MetacarpalLerp));
			hand.Index.Proximal.RawPosition = Transform((Elements.Core.float3)viveHand.points[5]);
			hand.Index.Intermediate.RawPosition = Transform((Elements.Core.float3)viveHand.points[6]);
			hand.Index.Distal.RawPosition = Transform((Elements.Core.float3)viveHand.points[7]);
			hand.Index.Tip.RawPosition = Transform((Elements.Core.float3)viveHand.points[8]);
			hand.Middle.Metacarpal.RawPosition = Transform(MathX.Lerp((Elements.Core.float3)viveHand.points[0], (Elements.Core.float3)viveHand.points[9], MetacarpalLerp));
			hand.Middle.Proximal.RawPosition = Transform((Elements.Core.float3)viveHand.points[9]);
			hand.Middle.Intermediate.RawPosition = Transform((Elements.Core.float3)viveHand.points[10]);
			hand.Middle.Distal.RawPosition = Transform((Elements.Core.float3)viveHand.points[11]);
			hand.Middle.Tip.RawPosition = Transform((Elements.Core.float3)viveHand.points[12]);
			hand.Ring.Metacarpal.RawPosition = Transform(MathX.Lerp((Elements.Core.float3)viveHand.points[0], (Elements.Core.float3)viveHand.points[13], MetacarpalLerp));
			hand.Ring.Proximal.RawPosition = Transform((Elements.Core.float3)viveHand.points[13]);
			hand.Ring.Intermediate.RawPosition = Transform((Elements.Core.float3)viveHand.points[14]);
			hand.Ring.Distal.RawPosition = Transform((Elements.Core.float3)viveHand.points[15]);
			hand.Ring.Tip.RawPosition = Transform((Elements.Core.float3)viveHand.points[16]);
			hand.Pinky.Metacarpal.RawPosition = Transform(MathX.Lerp((Elements.Core.float3)viveHand.points[0], (Elements.Core.float3)viveHand.points[17], MetacarpalLerp));
			hand.Pinky.Proximal.RawPosition = Transform((Elements.Core.float3)viveHand.points[17]);
			hand.Pinky.Intermediate.RawPosition = Transform((Elements.Core.float3)viveHand.points[18]);
			hand.Pinky.Distal.RawPosition = Transform((Elements.Core.float3)viveHand.points[19]);
			hand.Pinky.Tip.RawPosition = Transform((Elements.Core.float3)viveHand.points[20]);
			hand.ComputeRotationsFromPositions();
			Elements.Core.float3 a = Elements.Core.float3.Zero;
			Elements.Core.float3 a2 = Elements.Core.float3.Zero;
			foreach (Finger item3 in hand)
			{
				if (item3.FingerType != FingerType.Thumb)
				{
					a += item3.Metacarpal.RawRotation * Elements.Core.float3.Forward;
					a2 += item3.Metacarpal.RawRotation * Elements.Core.float3.Up;
				}
			}
			a = a.Normalized;
			a2 = a2.Normalized;
			foreach (Finger item4 in hand)
			{
				if (item4.FingerType != FingerType.Thumb)
				{
					Elements.Core.float3 from = item4.Metacarpal.RawRotation * Elements.Core.float3.Forward;
					Elements.Core.float3 @float = item4.Metacarpal.RawRotation * Elements.Core.float3.Up;
					from = MathX.Lerp(in from, in a, 0.5f);
					@float = MathX.Lerp(in from, in a2, 0.5f);
					item4.Metacarpal.RawRotation = Elements.Core.floatQ.LookRotation(in from, in @float);
				}
			}
		}

		public Elements.Core.float3 Transform(in Elements.Core.float3 pos, bool isUnderWrist = true)
		{
			if (isUnderWrist)
			{
				return wristMatrix.TransformPoint3x4(in pos);
			}
			return matrix.TransformPoint3x4(in pos);
		}

		public Elements.Core.floatQ Transform(in Elements.Core.floatQ rot)
		{
			return rotation * rot;
		}
	}
	public class GigglePuck : InputDevice
	{
		public const int NOT_FOUND_DISCONNECT_THRESHOLD = 5;

		public const float DEFAULT_RADIUS = 0.05f;

		public const int PORT = 8888;

		public const float MOTOR_SPEED_SCALE = 0.66f;

		public const string MOTOR_PATH = "/motor";

		public const string AVATAR_MOTOR_PATH = "/avatar/parameters/motor";

		private bool _lastWasVibrating;

		private DateTime _lastVibrationStart;

		private HapticPoint _point;

		private OscSender _sender;

		private GiggleTechSettings _currentSettings;

		private GiggleTechSettings.Device _currentDevice;

		private bool _lastWasActive;

		public static TimeSpan ActivationVibrationDuration => TimeSpan.FromMilliseconds(100L);

		public string IP { get; private set; }

		public bool IsConnected { get; private set; }

		public int NotFoundCounter { get; private set; }

		public int HapticPointIndex => _point.Index;

		public GigglePuck(string ip, InputInterface input)
		{
			IsConnected = true;
			IP = ip;
			_point = new HapticPoint(input, 0.05f, new VoidHapticPointPosition());
			input.RegisterHapticPoint(_point);
			IPAddress address = IPAddress.Parse(ip);
			_sender = new OscSender(address, 8888);
			_sender.Connect();
			Settings.RegisterValueChanges<GiggleTechSettings>(OnGiggleTechSettingsChanged);
		}

		private void OnGiggleTechSettingsChanged(GiggleTechSettings settings)
		{
			if (settings != _currentSettings || _currentDevice == null)
			{
				_currentSettings = settings;
				_currentDevice = _currentSettings?.GetEntryForPuck(IP);
				UniLog.Log($"Found device entry for GigglePuck {IP}: {_currentDevice != null}\nSettingOwnerID: {settings.SettingOwnerId}");
			}
			if (_currentDevice != null && !_currentDevice.HapticPointMapping.Matches(_point))
			{
				_point.UpdatePosition(_currentDevice.HapticPointMapping.PointRadius, _currentDevice.HapticPointMapping.GetPosition());
			}
		}

		public void SetConnected()
		{
			IsConnected = true;
			NotFoundCounter = 0;
		}

		public void SetDisconnected()
		{
			IsConnected = false;
		}

		public void MarkFound()
		{
			NotFoundCounter = 0;
		}

		public void MarkNotFound()
		{
			if (++NotFoundCounter == 5)
			{
				SetDisconnected();
			}
		}

		public void Update()
		{
			if (!IsConnected || _currentDevice == null)
			{
				return;
			}
			if (!_currentDevice.UseDevice.Value || _point.Position is VoidHapticPointPosition)
			{
				if (_lastWasActive)
				{
					SendHaptics(0f);
					_lastWasActive = false;
				}
				return;
			}
			float num = 0f;
			_point.SampleSources();
			num = MathX.Max(_point.Force, _point.Vibration);
			num *= _currentDevice.IntensityScale.Value;
			num = MathX.FilterInvalid(num);
			num = MathX.Clamp01(num);
			bool flag = !MathX.Approximately(num, 0f);
			if (flag && !_lastWasVibrating)
			{
				_lastVibrationStart = DateTime.UtcNow;
			}
			_lastWasVibrating = flag;
			if (flag)
			{
				num = MathX.Lerp(_currentDevice.MinimumIntensity.Value, 1f, num);
			}
			if (flag && DateTime.UtcNow - _lastVibrationStart < ActivationVibrationDuration)
			{
				num = MathX.Max(num, _currentDevice.InitialActivationIntensity.Value);
			}
			_lastWasActive = true;
			SendHaptics(num);
		}

		private void SendHaptics(float intensity)
		{
			_point.UpdateActivationIntensity(intensity);
			intensity *= 0.66f;
			intensity = MathX.Clamp(intensity, 0f, 0.66f);
			int num = MathX.RoundToInt(intensity * 255f);
			_sender.Send(new OscMessage("/motor", num));
			_sender.Send(new OscMessage("/avatar/parameters/motor", num));
		}
	}
	public class GiggleTechDriver : IInputDriver, IDisposable
	{
		private CancellationTokenSource _cancellationToken;

		private Dictionary<string, GigglePuck> _gigglePucks = new Dictionary<string, GigglePuck>();

		private List<IPAddress> _forcedGigglePucks = new List<IPAddress>();

		public InputInterface Input { get; private set; }

		public int UpdateOrder => 0;

		public event Action<GigglePuck> OnGigglePuckConnected;

		public event Action<GigglePuck> OnGigglePuckDisconnected;

		public void UpdateForcedGigglePucks(List<IPAddress> ipList)
		{
			lock (_gigglePucks)
			{
				_forcedGigglePucks.Clear();
				_forcedGigglePucks.AddRange(ipList);
			}
		}

		public void GetCurrentGigglePucks(List<GigglePuck> list)
		{
			lock (_gigglePucks)
			{
				list.AddRange(_gigglePucks.Values);
			}
		}

		public void CollectDeviceInfos(DataTreeList list)
		{
			lock (_gigglePucks)
			{
				foreach (KeyValuePair<string, GigglePuck> gigglePuck in _gigglePucks)
				{
					_ = gigglePuck;
					DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
					dataTreeDictionary.Add("Name", "GiggleTech");
					dataTreeDictionary.Add("Type", "Haptics");
					dataTreeDictionary.Add("Model", "GigglePuck");
					list.Add(dataTreeDictionary);
				}
			}
		}

		public void RegisterInputs(InputInterface inputInterface)
		{
			_cancellationToken = new CancellationTokenSource();
			Input = inputInterface;
			Task.Run((Func<Task?>)FindDevices);
		}

		public void UpdateInputs(float deltaTime)
		{
			lock (_gigglePucks)
			{
				foreach (KeyValuePair<string, GigglePuck> gigglePuck in _gigglePucks)
				{
					gigglePuck.Value.Update();
				}
			}
		}

		private async Task FindDevices()
		{
			UniLog.Log("Starting search for GigglePucks");
			try
			{
				while (!_cancellationToken.IsCancellationRequested)
				{
					IPAddress[] addresses = null;
					try
					{
						addresses = await Dns.GetHostAddressesAsync("giggletech.local");
					}
					catch (SocketException)
					{
					}
					HashSet<string> hashSet = Pool.BorrowHashSet<string>();
					lock (_gigglePucks)
					{
						if (_forcedGigglePucks.Count > 0)
						{
							IPAddress[] array = addresses;
							int num = ((array != null) ? array.Length : 0);
							addresses = addresses.EnsureExactSize(num + _forcedGigglePucks.Count, keepData: true);
							for (int i = 0; i < _forcedGigglePucks.Count; i++)
							{
								addresses[num + i] = _forcedGigglePucks[i];
							}
						}
						foreach (KeyValuePair<string, GigglePuck> gigglePuck2 in _gigglePucks)
						{
							hashSet.Add(gigglePuck2.Key);
						}
						if (addresses != null)
						{
							IPAddress[] array2 = addresses;
							for (int j = 0; j < array2.Length; j++)
							{
								string text = array2[j].ToString();
								hashSet.Remove(text);
								if (_gigglePucks.TryGetValue(text, out GigglePuck value))
								{
									value.MarkFound();
									if (!value.IsConnected)
									{
										UniLog.Log("GigglePuck reconnected at: " + text);
										value.SetConnected();
										this.OnGigglePuckConnected?.Invoke(value);
									}
								}
								else
								{
									UniLog.Log("Found new GigglePuck at: " + text);
									value = new GigglePuck(text, Input);
									Input.RegisterInputDevice(value, "GigglePuck (" + text + ")");
									_gigglePucks.Add(text, value);
									this.OnGigglePuckConnected?.Invoke(value);
								}
							}
						}
						foreach (string item in hashSet)
						{
							GigglePuck gigglePuck = _gigglePucks[item];
							if (gigglePuck.IsConnected)
							{
								gigglePuck.MarkNotFound();
								if (!gigglePuck.IsConnected)
								{
									this.OnGigglePuckDisconnected?.Invoke(gigglePuck);
									UniLog.Log("GigglePuck disconnected at: " + item);
								}
							}
						}
					}
					await Task.Delay(TimeSpan.FromSeconds(15L));
				}
				_cancellationToken.Dispose();
			}
			catch (Exception ex2)
			{
				UniLog.Error("Exception when searching for GigglePucks:\n" + ex2);
			}
		}

		public void Dispose()
		{
			_cancellationToken.Cancel();
		}
	}
