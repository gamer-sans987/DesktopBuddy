					int length = buffer.CopySamples(span, ref position, ref lastSample, invResampleRate);
					position -= buffer.Length;
					span = span.Slice(0, length);
					ProcessNewSamples(span);
					return;
				}
				catch (Exception value2)
				{
					UniLog.Error($"Exception writing new audio samples. Position: {value}, Buffer.Length: {buffer.Length}, Target.Length: {span.Length}, Rate: {invResampleRate}\n{value2}");
					position = 0.0;
					return;
				}
			}
			ProcessNewSamples(MemoryMarshal.Cast<S, StereoSample>(buffer));
		}

		/// <summary>
		/// Processes incoming samples for consumption by the engine.
		/// </summary>
		private void ProcessNewSamples(Span<StereoSample> buffer)
		{
			float num = 1f / (float)AudioSystem.SampleRate;
			lock (_lock)
			{
				this._newRawSamples?.Invoke(buffer);
				if (this._newFilteredSamples == null)
				{
					return;
				}
				if (AudioSystem.NoiseSupression)
				{
					if (_denoiser == null)
					{
						_denoiser = new BufferDenoiser<MonoSample>();
					}
					Span<MonoSample> buffer2 = stackalloc MonoSample[buffer.Length];
					buffer.CopySamples(buffer2);
					_denoiser.Denoise(ref buffer2, finish: false);
					buffer = buffer.Slice(0, buffer2.Length);
					buffer2.CopySamples(buffer);
				}
				float num2 = 0f;
				for (int i = 0; i < buffer.Length; i++)
				{
					num2 = MathX.Max(buffer[i].AbsoluteAmplitude, num2);
				}
				bool flag = AudioSystem.VoiceNormalization;
				if (num2 >= AudioSystem.NoiseGateThreshold)
				{
					noiseGateHold = 0f;
					if (noiseGateMultiplier < 1f)
					{
						float num3 = num / AudioSystem.NoiseGateAttack;
						for (int j = 0; j < buffer.Length; j++)
						{
							noiseGateMultiplier += num3;
							if (noiseGateMultiplier >= 1f)
							{
								noiseGateMultiplier = 1f;
								break;
							}
							ref StereoSample reference = ref buffer[j];
							reference *= noiseGateMultiplier;
						}
					}
				}
				else if (noiseGateMultiplier > 0f)
				{
					int k = 0;
					if (noiseGateHold < AudioSystem.NoiseGateHold)
					{
						float num4 = (float)buffer.Length * num;
						float num5 = noiseGateHold;
						noiseGateHold += num4;
						noiseGateHold = MathX.Min(AudioSystem.NoiseGateHold, noiseGateHold);
						float num6 = noiseGateHold - num5;
						k += MathX.RoundToInt(num6 * (float)AudioSystem.SampleRate);
					}
					float num7 = num / AudioSystem.NoiseGateRelease;
					for (; k < buffer.Length; k++)
					{
						noiseGateMultiplier -= num7;
						if (noiseGateMultiplier <= 0f)
						{
							noiseGateMultiplier = 0f;
							break;
						}
						ref StereoSample reference2 = ref buffer[k];
						reference2 *= noiseGateMultiplier;
					}
					buffer.Slice(k).Fill(default(StereoSample));
				}
				else
				{
					flag = false;
					buffer.Fill(default(StereoSample));
				}
				if (flag)
				{
					float num8 = 1f / num2;
					normalizationMultiplier = Math.Min(num8, normalizationMultiplier);
					if (num2 < AudioSystem.NormalizationThreshold)
					{
						num8 = normalizationMultiplier;
					}
					float lerp = ((num8 > normalizationMultiplier) ? 0.000125f : 1.0416667E-05f);
					for (int l = 0; l < buffer.Length; l++)
					{
						normalizationMultiplier = MathX.Lerp(normalizationMultiplier, num8, lerp);
						ref StereoSample reference3 = ref buffer[l];
						reference3 *= normalizationMultiplier;
					}
				}
				this._newFilteredSamples(buffer);
			}
		}

