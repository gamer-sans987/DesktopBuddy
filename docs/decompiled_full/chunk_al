		public void UpdateInputs(float deltaTime)
		{
			if (!registered && leap.IsServiceConnected && inputInterface.GetBodyNode(BodyNode.Head).IsTracking)
			{
				UniLog.Log("Registering Leap");
				inputInterface.RegisterInputDevice(this, "Settings.LeapMotion.Name");
				frame = new Leap.Frame();
				LeftHand = new Hand(inputInterface, Chirality.Left, PRIORITY);
				RightHand = new Hand(inputInterface, Chirality.Right, PRIORITY);
				LeftHand.SetTracking(tracking: false, forceUpdate: true);
				RightHand.SetTracking(tracking: false, forceUpdate: true);
				registered = true;
			}
			if (!registered)
			{
				return;
			}
			ITrackedDevice bodyNode = inputInterface.GetBodyNode(BodyNode.Head);
			ITrackedDevice trackedDevice = null;
			ITrackedDevice trackedDevice2 = null;
			for (int i = 0; i < inputInterface.InputDeviceCount; i++)
			{
				if (!(inputInterface.GetDevice(i) is ITrackedDevice { IsTracking: not false } trackedDevice3))
				{
					continue;
				}
				if (trackedDevice3.CorrespondingBodyNode == BodyNode.LeftHand)
				{
					if (trackedDevice3 == LeftHand.Wrist)
					{
						continue;
					}
					if (trackedDevice == null || trackedDevice3.Priority > trackedDevice.Priority)
					{
						trackedDevice = trackedDevice3;
					}
				}
				if (trackedDevice3.CorrespondingBodyNode == BodyNode.RightHand && trackedDevice3 != RightHand.Wrist && (trackedDevice2 == null || trackedDevice3.Priority > trackedDevice2.Priority))
				{
					trackedDevice2 = trackedDevice3;
				}
			}
			Elements.Core.floatQ b = Elements.Core.floatQ.Euler(in RotationOffset);
			Elements.Core.floatQ b2 = b.Inverted;
			Elements.Core.floatQ a = bodyNode.Rotation;
			matrix = Elements.Core.float4x4.Transform(bodyNode.Position, Elements.Core.floatQ.Multiply(ref a, ref b), new Elements.Core.float3(-0.001f, 0.001f, 0.001f));
			rotation = Elements.Core.floatQ.Multiply(ref a, ref b2);
			if (LeapEnabled)
			{
				leap.Frame(frame);
			}
			Leap.Hand hand = null;
			Leap.Hand hand2 = null;
			if (LeapEnabled)
			{
				for (int j = 0; j < frame.Hands.Count; j++)
				{
					Leap.Hand hand3 = frame.Hands[j];
					Leap.Hand hand4 = (hand3.IsLeft ? hand : hand2);
					int num = (hand3.IsLeft ? _lastLeftHand : _lastRightHand);
					if (hand4 == null || hand4.Id != num || hand4.Confidence < hand3.Confidence * 0.75f)
					{
						if (hand3.IsLeft)
						{
							hand = hand3;
						}
						else
						{
							hand2 = hand3;
						}
					}
				}
			}
			if (hand != null)
			{
				_lastLeftHand = hand.Id;
				UpdateHand(LeftHand, hand, trackedDevice);
			}
			else
			{
				LeftHand.SetTracking(tracking: false);
			}
			if (hand2 != null)
			{
				_lastRightHand = hand2.Id;
				UpdateHand(RightHand, hand2, trackedDevice2);
			}
			else
			{
				RightHand.SetTracking(tracking: false);
			}
		}

		private void UpdateHand(Hand hand, Leap.Hand leapHand, ITrackedDevice reference)
		{
			hand.SetTracking(tracking: true);
			hand.Confidence = leapHand.Confidence;
			hand.Forearm.RawPosition = Transform(leapHand.Arm.PrevJoint, isUnderWrist: false);
			hand.Forearm.RawRotation = Transform(leapHand.Arm.Rotation, isUnderWrist: false);
			hand.Wrist.RawPosition = Transform(leapHand.WristPosition, isUnderWrist: false);
			hand.Wrist.RawRotation = Transform(leapHand.Rotation, isUnderWrist: false) * _wristCompensation;
			if (reference != null)
			{
				int num = ((!(MathX.Distance(reference.Position, hand.Wrist.RawPosition) > (float)_settings.SnapDistance)) ? (reference.Priority - 1) : PRIORITY);
				if (num != hand.Wrist.Priority)
				{
					hand.Wrist.Priority = num;
					foreach (Finger item in hand)
					{
						foreach (FingerSegment item2 in item)
						{
							item2.Priority = (_settings.UseFingersWhenSnapped ? PRIORITY : num);
						}
					}
				}
			}
			wristMatrix = Elements.Core.float4x4.Transform(hand.Wrist.RawPosition, hand.Wrist.RawRotation, Elements.Core.float3.One);
			wristMatrix = wristMatrix.Inverse * matrix;
			wristRotation = hand.Wrist.RawRotation.Inverted;
			wristRotation *= rotation;
			hand.Palm.RawPosition = Transform(leapHand.PalmPosition, isUnderWrist: true);
			hand.Palm.RawRotation = Transform(leapHand.Rotation, isUnderWrist: true);
			hand.GrabStrength = leapHand.GrabStrength;
			hand.PinchStrength = leapHand.PinchStrength;
			for (int i = 0; i < leapHand.Fingers.Count; i++)
			{
				Leap.Finger finger = leapHand.Fingers[i];
				switch (finger.Type)
				{
				case Leap.Finger.FingerType.TYPE_INDEX:
					UpdateFinger(hand.Index, finger);
					break;
				case Leap.Finger.FingerType.TYPE_MIDDLE:
					UpdateFinger(hand.Middle, finger);
					break;
				case Leap.Finger.FingerType.TYPE_PINKY:
					UpdateFinger(hand.Pinky, finger);
					break;
				case Leap.Finger.FingerType.TYPE_RING:
					UpdateFinger(hand.Ring, finger);
					break;
				case Leap.Finger.FingerType.TYPE_THUMB:
					UpdateFinger(hand.Thumb, finger);
					break;
				}
			}
		}

		private void UpdateFinger(Finger finger, Leap.Finger leapFinger)
		{
			for (int i = 0; i < leapFinger.bones.Length; i++)
			{
				Leap.Bone bone = leapFinger.bones[i];
				FingerSegment fingerSegment;
				switch (bone.Type)
				{
				case Leap.Bone.BoneType.TYPE_METACARPAL:
					if (finger.FingerType == FingerType.Thumb)
					{
						continue;
					}
					fingerSegment = finger.Metacarpal;
					break;
				case Leap.Bone.BoneType.TYPE_PROXIMAL:
					fingerSegment = ((finger.FingerType != FingerType.Thumb) ? finger.Proximal : finger.Metacarpal);
					break;
				case Leap.Bone.BoneType.TYPE_INTERMEDIATE:
					fingerSegment = ((finger.FingerType != FingerType.Thumb) ? finger.Intermediate : finger.Proximal);
					break;
				case Leap.Bone.BoneType.TYPE_DISTAL:
					fingerSegment = finger.Distal;
					break;
				default:
					continue;
				}
				fingerSegment.RawPosition = Transform(bone.PrevJoint, isUnderWrist: true);
				fingerSegment.RawRotation = Transform(bone.Rotation, isUnderWrist: true);
				fingerSegment.Width = Transform(bone.Width);
			}
			finger.Tip.RawPosition = Transform(leapFinger.TipPosition, isUnderWrist: true);
			finger.Tip.RawRotation = finger.Distal.RawRotation;
			finger.Tip.Width = Transform(leapFinger.Width);
		}

		public float Transform(float size)
		{
			return size * 0.001f;
		}

		public Elements.Core.float3 Transform(Leap.Vector pos, bool isUnderWrist)
		{
			Elements.Core.float3 point = new Elements.Core.float3(pos.x + ActualLeapOffset.x, pos.y + ActualLeapOffset.y, pos.z + ActualLeapOffset.z);
			if (isUnderWrist)
			{
				return wristMatrix.TransformPoint3x4(in point);
			}
			return matrix.TransformPoint3x4(in point);
		}

		public Elements.Core.floatQ Transform(LeapQuaternion rot, bool isUnderWrist)
		{
			Elements.Core.floatQ b = rot.ToEngine();
			if (isUnderWrist)
			{
				return wristRotation * b * _fingerCompensation;
			}
			return rotation * b;
		}

