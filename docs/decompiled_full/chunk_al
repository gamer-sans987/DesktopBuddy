	public class MultiValueStream<T> : ValueStreamBase<T>
	{
		protected readonly Sync<int> _count;

		private List<T> dataPoints;

		private T[] frame;

		public int Count
		{
			get
			{
				return _count.Value;
			}
			set
			{
				if (value < 0)
				{
					throw new ArgumentOutOfRangeException();
				}
				_count.Value = value;
			}
		}

		public T this[int index]
		{
			get
			{
				EnscureCorrectFrameSize();
				return frame[index];
			}
			set
			{
				CheckOwnership();
				EnscureCorrectFrameSize();
				frame[index] = value;
			}
		}

		protected override int? FrameCount => frame?.Length;

		protected override void SetPoint(float lerp)
		{
			if (lerp <= 0f)
			{
				for (int i = 0; i < frame.Length; i++)
				{
					frame[i] = dataPoints[i];
				}
			}
			else
			{
				for (int j = 0; j < frame.Length; j++)
				{
					frame[j] = Interpolate(dataPoints[j], dataPoints[j + frame.Length], lerp);
				}
			}
		}

		protected override void FlushFrames()
		{
			if (dataPoints != null && frame != null && dataPoints.Count > frame.Length)
			{
				dataPoints.RemoveRange(0, dataPoints.Count - frame.Length);
			}
		}

		protected override void RemoveFrames(int count)
		{
			dataPoints.RemoveRange(0, count * frame.Length);
		}

		protected override void EncodeFrame(BitBinaryWriterX writer)
		{
			EnscureCorrectFrameSize();
			switch (base.Encoding)
			{
			case ValueEncoding.Full:
			{
				for (int j = 0; j < frame.Length; j++)
				{
					Coder<T>.Encode(frame[j], writer);
				}
				break;
			}
			case ValueEncoding.Quantized:
			{
				for (int i = 0; i < frame.Length; i++)
				{
					Coder<T>.EncodeQuantized(frame[i], base.FullFrameMin, base.FullFrameMax, base.FullFrameBits, writer);
				}
				break;
			}
			}
		}

		protected override void DecodeFrame(BitBinaryReaderX reader, StreamMessage message, bool discard)
		{
			EnscureCorrectFrameSize();
			bool flag = IsInterpolated;
			if (flag && dataPoints == null)
			{
				dataPoints = new List<T>();
			}
			for (int i = 0; i < frame.Length; i++)
			{
				T val = base.Encoding switch
				{
					ValueEncoding.Full => Coder<T>.Decode(reader), 
					ValueEncoding.Quantized => Coder<T>.DecodeQuantized(base.FullFrameMin, base.FullFrameMax, base.FullFrameBits, reader), 
					_ => default(T), 
				};
				if (!discard)
				{
					if (flag)
					{
						dataPoints.Add(val);
					}
					else
					{
						frame[i] = val;
					}
				}
			}
		}

		private void EnscureCorrectFrameSize()
		{
			if (frame == null || frame.Length != Count)
			{
				frame = new T[Count];
				T val = Coder<T>.Default;
				for (int i = 0; i < frame.Length; i++)
				{
					frame[i] = val;
				}
				ClearTimePoints();
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			_count = new Sync<int>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => _active, 
				1 => _group, 
				2 => _name, 
				3 => _period, 
				4 => _phase, 
				5 => IsInterpolated, 
				6 => InterpolationOffset, 
				7 => _encoding, 
				8 => _fullFrameBits, 
				9 => _deltaFrameBits, 
				10 => _fullFrameMin, 
				11 => _fullFrameMax, 
				12 => _deltaFrameMin, 
				13 => _deltaFrameMax, 
				14 => _count, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static MultiValueStream<T> __New()
		{
			return new MultiValueStream<T>();
		}
	}
