		private int _lastLeftHand;

		private int _lastRightHand;

		private static Elements.Core.floatQ _wristCompensation = Elements.Core.floatQ.LookRotation(Elements.Core.float3.Forward, Elements.Core.float3.Down);

		private static Elements.Core.floatQ _fingerCompensation = Elements.Core.floatQ.LookRotation(Elements.Core.float3.Forward, Elements.Core.float3.Down);

		public static int PRIORITY => 10;

		public Elements.Core.float3 ActualLeapOffset => (_settings?.Offset.Value ?? default(Elements.Core.float3)) / 0.001f;

		public Hand LeftHand { get; private set; }

		public Hand RightHand { get; private set; }

