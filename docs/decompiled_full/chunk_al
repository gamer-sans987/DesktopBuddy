		private int CompareInputGroups(InputGroup a, InputGroup b)
		{
			int num = a.Priority.CompareTo(b.Priority);
			if (num != 0)
			{
				return num;
			}
			if (a.Side == b.Side)
			{
				return 0;
			}
			if (!a.Side.HasValue && b.Side.HasValue)
			{
				return 1;
			}
			if (a.Side.HasValue && !b.Side.HasValue)
			{
				return -1;
			}
			if (a.Side == PrimaryHand)
			{
				return -1;
			}
			return 1;
		}

