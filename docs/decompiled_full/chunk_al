		/// <summary>
		/// Writes samples from the input buffer to the internal audio system.
		/// </summary>
		/// <param name="buffer">The buffer to ingest samples from.</param>
		/// <param name="position">The last position of the last sample read.</param>
		/// <param name="lastSample">The last sample read.</param>
		public void WriteSamples<S>(Span<S> buffer, ref double position, ref S lastSample) where S : unmanaged, IAudioSample<S>
		{
			if (AudioSystem.IsMuted && AudioSystem.DefaultAudioInput == this)
			{
				return;
			}
			if (resample || typeof(S) != typeof(StereoSample))
			{
				int minLength = MathX.CeilToInt((float)buffer.Length * resampleRate * 2f);
				resampleBuffer = resampleBuffer.EnsureSize(minLength);
