	{
		public readonly Digital Value = new Digital();

		public override bool CurrentValue => Value.PressedOrHeld;

		public bool Pressed => Value.Pressed;

		public bool Held => Value.Held;

		public bool Released => Value.Released;

		public bool AnyState => Value.AnyState;

		public DigitalAction(string name)
			: base(name)
		{
		}

		public void AddBinding(Digital digital)
		{
			AddBinding(InputNode.Digital(digital), digital.Device);
		}

		public override void Evaluate(InputGroup group, int priority, float deltaTime)
		{
			if (!group.Active || !Active)
			{
				return;
			}
			if (ExternalInput.HasValue)
			{
				_hasValue = true;
				_intermediateResult |= ExternalInput.Value;
				ExternalInput = null;
			}
			foreach (InputBinding<bool> binding in _bindings)
			{
				if (binding.Priority != priority)
				{
					continue;
				}
				IInputDevice implicitDevice = binding.ImplicitDevice;
				if (implicitDevice == null || implicitDevice.IsDeviceActive)
				{
					bool? flag = binding.Node.Evaluate(new InputEvaluationContext(group, binding, this));
					if (flag.HasValue)
					{
						_hasValue = true;
						_intermediateResult |= flag.Value;
					}
				}
			}
		}

		public override void FinishEvaluation(float deltaTime)
		{
			Value.UpdateState(_intermediateResult);
		}

		public static implicit operator bool(DigitalAction action)
		{
