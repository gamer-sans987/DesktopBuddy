	public sealed class SoundFlowPlaybackDevice : AudioOutputDriver
	{
		private sealed class PlaybackState : IDisposable
		{
			private readonly int _length;

			private readonly CancellationTokenSource _cancelSource;

			public readonly SoundFlowPlaybackDevice Owner;

			public readonly AudioPlaybackDevice Device;

			public readonly QueueDataProvider Queue;

			public readonly SoundPlayer Player;

			private readonly Task _renderLoop;

			public int AvailableSamples => Queue.SamplesAvailable / 2;

			public int Length => _length / 2;

			public PlaybackState(SoundFlowPlaybackDevice owner)
			{
				MiniAudioEngine engine = SoundFlowAudioDriver.engine;
				AudioFormat format = SoundFlowAudioDriver.Format;
				_cancelSource = new CancellationTokenSource();
				Owner = owner;
				Device = SoundFlowAudioDriver.engine.InitializePlaybackDevice(Owner.Info, format);
				Queue = new QueueDataProvider(SoundFlowAudioDriver.Format, _length = Owner.AudioSystem.OutputFrameSize * 2);
				Player = new SoundPlayer(engine, format, Queue);
				Device.MasterMixer.AddComponent(Player);
				_renderLoop = Task.Run(async delegate
				{
					await RenderLoop(_cancelSource.Token);
				});
				Device.Start();
				Player.Play();
			}

			private async Task RenderLoop(CancellationToken token)
			{
				try
				{
					bool first = true;
					while (!token.IsCancellationRequested)
					{
						int simulationFrameSize = Owner.AudioSystem.SimulationFrameSize;
						int sampleRate = Owner.AudioSystem.SampleRate;
						await Task.Delay(TimeSpan.FromMilliseconds((float)simulationFrameSize / (float)sampleRate / 8f), token);
						int num = AvailableSamples + SoundFlowAudioDriver.INPUT_BUFFER_SUBMIT_SIZE;
						if (Owner.RenderAudio != null && !token.IsCancellationRequested && num <= Length)
						{
							if (AvailableSamples == 0 && !first)
							{
								Owner.IncrementUnderruns();
							}
							QueueAudio();
							first = false;
						}
					}
				}
				catch (OperationCanceledException)
				{
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception in audio device loop:\n{value}");
				}
			}

			private void QueueAudio()
			{
				Span<StereoSample> buffer = stackalloc StereoSample[SoundFlowAudioDriver.INPUT_BUFFER_SUBMIT_SIZE];
				Owner.Read(buffer);
				Queue.AddSamples(buffer.AsSampleBuffer());
			}

			public void Dispose()
			{
				_cancelSource.Cancel();
				_renderLoop.Wait();
				Player.Stop();
				Device.Stop();
				Queue.CompleteAdding();
				Player.Dispose();
				Device.Dispose();
				Queue.Dispose();
				_cancelSource.Dispose();
			}
		}

		private PlaybackState? _state;

		public override int AvailablePlaybackSamples => _state?.AvailableSamples ?? (-1);

		public override int OutputSampleRate => SoundFlowAudioDriver.AudioSystem.SampleRate;

		internal DeviceInfo Info { get; private set; }

		public SoundFlowPlaybackDevice(DeviceInfo info)
			: base(info.Name, info.Name, info.IsDefault, SoundFlowAudioDriver.AudioSystem)
		{
			Info = info;
		}

		protected override void OnStart()
		{
			_state = new PlaybackState(this);
		}

		protected override void OnStop()
		{
			_state?.Dispose();
		}

		public override void FrameSizeChanged()
		{
			OnStop();
			OnStart();
		}

		public void Connected(DeviceInfo info)
		{
			Info = info;
			Connected();
		}

		private void IncrementUnderruns()
		{
			base.BufferUnderruns++;
		}
	}
	public sealed class SoundFlowRecordingDevice : AudioInput
	{
		private AudioCaptureDevice? _device;

		private StereoSample _lastSample;

		private double _lastpos;

		internal DeviceInfo Info { get; private set; }

		public SoundFlowRecordingDevice(DeviceInfo info)
			: base(info.Name, info.Name, SoundFlowAudioDriver.inputInterface, AudioInputType.CaptureDevice, info.IsDefault)
		{
			SetSampleRate(SoundFlowAudioDriver.Format.SampleRate);
			Info = info;
			base.ActiveChanged += ActiveStateChanged;
		}

		private void ActiveStateChanged(AudioInput input, bool isActive)
		{
			if (isActive)
			{
				OnStart();
			}
			else
			{
				OnStop();
			}
		}

		public void Connected(DeviceInfo info)
		{
			Info = info;
			Connected();
		}

		private void OnStart()
		{
			SetSampleRate(SoundFlowAudioDriver.Format.SampleRate);
			_device = SoundFlowAudioDriver.engine.InitializeCaptureDevice(Info, SoundFlowAudioDriver.Format);
			_device.OnAudioProcessed += OnAudioProcessed;
			_device.Start();
		}

		private void OnAudioProcessed(Span<float> samples, Capability capability)
		{
			WriteSamples(samples.AsAudioBuffer<StereoSample>(), ref _lastpos, ref _lastSample);
		}

		private void OnStop()
		{
			if (_device != null)
			{
				_device.Stop();
				_device.OnAudioProcessed -= OnAudioProcessed;
				_device.Dispose();
			}
		}
	}
