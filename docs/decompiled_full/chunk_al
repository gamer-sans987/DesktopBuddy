		public DataTreeNode ToRawDataTreeNode()
		{
			if (IsNull)
			{
				return new DataTreeValue((string)null);
			}
			if (Element is IField<Uri> field)
			{
				return new DataTreeValue(field.Value);
			}
			if (Element is IField<string> field2)
			{
				return new DataTreeValue(field2.Value);
			}
			if (Element is IField<TimeSpan> field3)
			{
				return new DataTreeValue(field3.Value);
			}
			if (Element is IField)
			{
				return new DataTreeValue((IConvertible)((IField)Element).BoxedValue);
			}
			if (Element is SyncList<SyncVar>)
			{
				SyncList<SyncVar> obj = (SyncList<SyncVar>)Element;
				DataTreeList dataTreeList = new DataTreeList();
				{
					foreach (SyncVar item in obj)
					{
						dataTreeList.Add(item.ToRawDataTreeNode());
					}
					return dataTreeList;
				}
			}
			if (Element is SyncDictionary<string, SyncVar>)
			{
				SyncDictionary<string, SyncVar> obj2 = (SyncDictionary<string, SyncVar>)Element;
				DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
				{
					foreach (KeyValuePair<string, SyncVar> item2 in obj2)
					{
						dataTreeDictionary.Add(item2.Key, item2.Value.ToRawDataTreeNode());
					}
					return dataTreeDictionary;
				}
			}
			throw new Exception("Unsupported ElementType for RawDataTree node conversion: " + ElementType);
		}

		public void FromRawDataTreeNode(DataTreeNode node)
		{
			if (node is DataTreeValue dataTreeValue)
			{
				if (dataTreeValue.IsNull)
				{
					SetNull();
					return;
				}
				if (dataTreeValue.IsURL)
				{
					AsField<Uri>().Value = dataTreeValue.Extract<Uri>();
					return;
				}
				Type elementType = typeof(Sync<>).MakeGenericType(dataTreeValue.Value.GetType());
				ElementType = elementType;
				((IField)Element).BoxedValue = dataTreeValue.Value;
				return;
			}
			if (node is DataTreeList dataTreeList)
			{
				SyncList<SyncVar> syncList = AsVarList();
				{
					foreach (DataTreeNode child in dataTreeList.Children)
					{
						syncList.Add().FromRawDataTreeNode(child);
					}
					return;
				}
			}
			DataTreeDictionary obj = (DataTreeDictionary)node;
			SyncDictionary<string, SyncVar> syncDictionary = AsVarDict();
			foreach (KeyValuePair<string, DataTreeNode> child2 in obj.Children)
			{
				syncDictionary.Add(child2.Key).FromRawDataTreeNode(child2.Value);
			}
		}
