		public bool? Evaluate(in InputEvaluationContext context)
		{
			bool? flag = null;
			foreach (IInputNode<bool> input in Inputs)
			{
				bool valueOrDefault = input.Evaluate(in context) == true;
				flag = (flag.HasValue ? (valueOrDefault & flag) : new bool?(valueOrDefault));
			}
			return flag;
		}

		public void ResetNode()
		{
			foreach (IInputNode<bool> input in Inputs)
			{
				input.ResetNode();
			}
		}

