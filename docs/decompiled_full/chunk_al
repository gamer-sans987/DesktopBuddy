			}
			int num = chain.ComputeLength();
			T[] array = data;
			if (data == null || data.Length < num)
			{
				int num2 = Math.Max(num, (data != null) ? (data.Length * 2) : 0);
				data = new T[num2];
			}
			bool flag = array != data;
			if (!flag)
			{
				for (int i = 0; i < list.Count; i++)
				{
					SegmentInfo item = list[i];
					for (int j = i + 1; j < list.Count; j++)
					{
						SegmentInfo item2 = list[j];
