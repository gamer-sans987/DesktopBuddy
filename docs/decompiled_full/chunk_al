		protected override void InternalEncodeFull(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			RawValueList<ulong> list = Pool.BorrowRawValueList<ulong>();
			for (int i = 0; i < records.Count; i++)
			{
				list.Add((ulong)records[i].node.ReferenceID);
			}
			writer.WriteDeltaCodedSequence(list);
			Pool.Return(ref list);
		}

		protected override void InternalDecodeFull(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			InternalClear(sync: false, change: true, forceTrash: true);
			RawValueList<ulong> list = Pool.BorrowRawValueList<ulong>();
			reader.ReadDeltaCodedSequence(list);
			records.Capacity = list.Count;
			ulong tick = base.World.SyncTick;
			if (inboundMessage is ConfirmationMessage confirmationMessage)
			{
				tick = confirmationMessage.ConfirmTime;
			}
			foreach (ulong item in list)
			{
				ISyncMember syncMember = base.World.TryRetrieveFromTrash(tick, item);
				if (syncMember == null)
				{
					InternalInsert(item, records.Count, sync: false, change: false);
				}
				else
				{
					InternalInsertNode((T)syncMember, records.Count, sync: false, change: false);
				}
			}
			SendElementsAdded(0, records.Count);
			Pool.Return(ref list);
		}

		protected override void InternalEncodeDelta(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			List<DeltaRecord> deltaRecords = GetDeltaRecords();
			uint num = 0u;
			RefID refID = RefID.MaxValue;
			foreach (DeltaRecord item in deltaRecords)
			{
				if (item.message != DeltaMessage.Empty)
				{
					num++;
				}
				if (item.IsAddition)
				{
					refID = Math.Min((ulong)refID, (ulong)item.id);
				}
			}
			writer.Write7BitEncoded(num);
			writer.Write7BitEncoded((ulong)refID);
			foreach (DeltaRecord item2 in deltaRecords)
			{
				if (item2.message != DeltaMessage.Empty)
				{
					item2.Encode(writer, refID);
				}
			}
		}

		protected override void InternalDecodeDelta(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			uint num = (uint)reader.Read7BitEncoded();
			RefID offset = reader.Read7BitEncoded();
			for (uint num2 = 0u; num2 < num; num2++)
			{
				DeltaRecord deltaRecord = DeltaRecord.Decode(reader, offset);
				switch (deltaRecord.message)
				{
				case DeltaMessage.Clear:
					InternalClear(sync: false);
					break;
				case DeltaMessage.Add:
					InternalInsert(deltaRecord.id, records.Count, sync: false);
					break;
				case DeltaMessage.Insert:
					InternalInsert(deltaRecord.id, deltaRecord.index, sync: false);
					break;
				case DeltaMessage.Remove:
					InternalRemove(deltaRecord.index, sync: false);
					break;
				}
			}
		}

		protected override void InternalClearDirty()
		{
			if (_deltaRecords == null)
			{
				return;
			}
			foreach (DeltaRecord deltaRecord in _deltaRecords)
			{
				if (deltaRecord.IsAddition)
				{
					deltaRecord.record.isDirty = false;
				}
			}
			Pool.Return(ref _deltaRecords);
			_deltaRecords = null;
		}

		public override void Dispose()
		{
			foreach (NodeRecord record in records)
			{
				UnregisterChildElement(record.node);
				record.node.Dispose();
			}
			records.Clear();
			records = null;
			if (_deltaRecords != null)
			{
				Pool.Return(ref _deltaRecords);
			}
			this.ElementsAdded = null;
			this.ElementsRemoved = null;
			this.ElementsRemoving = null;
			this._genElementsAdded = null;
			this._genElementsRemoved = null;
			this._genListCleared = null;
			base.Dispose();
		}

		protected override DataTreeNode InternalSave(SaveControl control)
		{
			DataTreeList dataTreeList = new DataTreeList();
			foreach (NodeRecord record in records)
			{
				dataTreeList.Add(record.node.Save(control));
			}
			return dataTreeList;
		}

		protected override void InternalLoad(DataTreeNode node, LoadControl control)
		{
			foreach (DataTreeNode child in ((DataTreeList)node).Children)
			{
				InternalInsert(RefID.Null, records.Count).Load(child, control);
			}
		}
	}
