	public class TapToggle : IInputNode<bool>, IInputNode
	{
		public readonly IInputNode<bool> Source;

		private bool _active;

		private DateTime _tapStart;

		private bool _lastState;

		public float Interval { get; set; } = 0.2f;

		public TapToggle(IInputNode<bool> source, float interval = 0.2f)
		{
			Source = source;
			Interval = interval;
		}

		public bool? Evaluate(in InputEvaluationContext context)
		{
			bool? flag = Source?.Evaluate(in context);
			if (!flag.HasValue)
			{
				if (_active)
				{
					return true;
				}
				return null;
			}
			if (flag.Value && !_lastState)
			{
				if (_active)
				{
					_active = false;
				}
				else
				{
					_tapStart = DateTime.UtcNow;
				}
			}
			else if (!flag.Value && _lastState && !_active && (DateTime.UtcNow - _tapStart).TotalSeconds <= (double)Interval)
			{
				_active = true;
			}
			_lastState = flag.Value;
			return _active;
		}

		public void ResetNode()
		{
			_active = false;
			_lastState = false;
			Source?.ResetNode();
		}

		bool? IInputNode<bool>.Evaluate(in InputEvaluationContext context)
		{
			return Evaluate(in context);
		}
	}
	public class ToggleInput : IInputNode<bool>, IInputNode
	{
		public IInputNode<bool> Toggle;

		public IInputNode<bool> SetOff;

		private bool _state;

		private bool _lastToggle;

		public ToggleInput(IInputNode<bool> toggle, IInputNode<bool> setoff = null)
		{
			Toggle = toggle;
			SetOff = setoff;
		}

		public bool? Evaluate(in InputEvaluationContext context)
		{
			bool? flag = Toggle?.Evaluate(in context);
			bool? flag2 = SetOff?.Evaluate(in context);
			if (!flag.HasValue)
			{
				_state = false;
				_lastToggle = false;
				return null;
			}
			if (flag.Value && !_lastToggle)
			{
				_state = !_state;
			}
			if (flag2.HasValue && flag2.Value)
			{
				_state = false;
			}
			_lastToggle = flag.Value;
			return _state;
		}

		public void ResetNode()
		{
			Toggle?.ResetNode();
			SetOff?.ResetNode();
			_state = false;
			_lastToggle = false;
		}

