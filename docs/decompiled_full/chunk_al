		public Eye this[EyeSide side] => side switch
		{
			EyeSide.Left => LeftEye, 
			EyeSide.Right => RightEye, 
			EyeSide.Combined => CombinedEye, 
			_ => throw new Exception("Invalid side: " + side), 
		};

		float IEyeDataSource.ConvergenceDistance => ConvergenceDistance;

		public Eyes(InputInterface input, string name, bool supportsPupilTracking)
		{
			SupportsPupilTracking = supportsPupilTracking;
			UniLog.Log($"Eyes allocated: {name}, SupportsPupilTracking: {supportsPupilTracking}");
			input.RegisterInputDevice(this, name);
			LeftEye = new Eye(this, EyeSide.Left, name + " - Left");
			RightEye = new Eye(this, EyeSide.Right, name + " - Right");
			CombinedEye = new Eye(this, EyeSide.Combined, name + " - Combined");
			InputInterface.InitDeviceFields(this);
		}

		public void SetTracking(bool state)
		{
			IsTracking = state;
			LeftEye.IsTracking = state;
			RightEye.IsTracking = state;
			CombinedEye.IsTracking = state;
		}

		public void FilterEyeDirection()
		{
			if (!LeftEye.IsTracking && RightEye.IsTracking)
			{
				LeftEye.Direction = RightEye.Direction;
			}
			if (!RightEye.IsTracking && LeftEye.IsTracking)
			{
				RightEye.Direction = LeftEye.Direction;
			}
		}

		public void ComputeCombinedEyeParameters()
		{
			CombinedEye.Widen = (LeftEye.Widen + RightEye.Widen) * 0.5f;
			CombinedEye.Frown = (LeftEye.Frown + RightEye.Frown) * 0.5f;
			CombinedEye.Squeeze = (LeftEye.Squeeze + RightEye.Squeeze) * 0.5f;
			CombinedEye.InnerBrowVertical = MathX.Average(LeftEye.InnerBrowVertical, RightEye.InnerBrowVertical);
			CombinedEye.OuterBrowVertical = MathX.Average(LeftEye.OuterBrowVertical, RightEye.OuterBrowVertical);
		}

		public void FinishUpdate()
		{
			FilterEyeDirection();
			IsTracking = LeftEye.IsTracking || RightEye.IsTracking;
		}

