		private SyncElement InternalCreateElement(RefID id, Type elementType, bool sync = true, bool change = true)
		{
			if (id != RefID.Null)
			{
				base.World.ReferenceController.AllocationBlockBegin(in id);
			}
			else if (base.IsLocalElement)
			{
				base.World.ReferenceController.LocalAllocationBlockBegin();
			}
			SyncElement syncElement = (SyncElement)Activator.CreateInstance(elementType);
			syncElement.Initialize(base.World, this);
			if (id != RefID.Null)
			{
				base.World.ReferenceController.AllocationBlockEnd();
			}
			else if (base.IsLocalElement)
			{
				base.World.ReferenceController.LocalAllocationBlockEnd();
			}
			InternalSetElement(syncElement, sync, change);
			return syncElement;
		}

		private void InternalSetElement(SyncElement element, bool sync = true, bool change = true)
		{
			BeginModification();
			SyncElement element2 = _element;
			bool flag = false;
			_element = element;
			if (base.IsInInitPhase)
			{
				if (element != null)
				{
					RegisterNewInitializable(element);
				}
			}
			else
			{
				element?.EndInitPhase();
				if (sync && base.GenerateSyncData)
				{
					if (!base.IsSyncDirty)
					{
						flag = true;
					}
					InvalidateSyncElement();
				}
			}
			if (change)
			{
				BlockModification();
				SyncElementChanged();
				UnblockModification();
			}
			if (element != null)
			{
				RegisterChildElement(element);
			}
			if (element2 != null)
			{
				if (flag)
				{
					base.World.MoveToTrash(element2);
				}
				else
				{
					element2.Dispose();
				}
			}
			EndModification();
		}

		protected override void InternalEncodeFull(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			if (_element == null)
