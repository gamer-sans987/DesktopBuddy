	public class AudioInputRecorder
	{
		private Func<bool> _recordCheck;

		private bool _isRecording;

		private bool _recordingRaw;

		private float? _minStartThreshold;

		public AudioInput Input { get; private set; }

		public AudioX Audio { get; private set; }

		public AudioInputRecorder(AudioInput input, AudioEncodeSettings encodeSettings, Func<bool> recordCheck = null, float? minStartThreshold = null)
		{
			encodeSettings.SampleRate = input.Engine.AudioSystem.SampleRate;
			encodeSettings.Channels = ChannelConfiguration.Stereo;
			Audio = new AudioX(encodeSettings);
			Input = input;
			_recordCheck = recordCheck;
			_minStartThreshold = minStartThreshold;
		}

		public void StartRecording(bool useRaw)
		{
			if (_isRecording)
			{
				throw new InvalidOperationException("Already recording");
			}
			if (useRaw)
			{
				Input.NewRawSamples += OnNewSamples;
			}
			else
			{
				Input.NewFilteredSamples += OnNewSamples;
			}
			_recordingRaw = useRaw;
			_isRecording = true;
		}

		public void StopRecording()
		{
			if (!_isRecording)
			{
				throw new InvalidOperationException("Not recording");
			}
			if (_recordingRaw)
			{
				Input.NewRawSamples -= OnNewSamples;
			}
			else
			{
				Input.NewFilteredSamples -= OnNewSamples;
			}
			_isRecording = false;
		}

		public AudioX FinishRecording()
		{
			if (_isRecording)
			{
				StopRecording();
			}
			AudioX audio = Audio;
			Audio = null;
			Input = null;
			lock (audio)
			{
				audio.FinishEncode();
			}
			_recordCheck = null;
			return audio;
		}

		private void OnNewSamples(Span<StereoSample> buffer)
		{
			if (_recordCheck != null && !_recordCheck())
			{
				return;
			}
			AudioX audio = Audio;
			if (audio == null)
			{
				return;
			}
			if (_minStartThreshold.HasValue)
			{
				int num = -1;
				for (int i = 0; i < buffer.Length; i++)
				{
					if (buffer[i].AbsoluteAmplitude > _minStartThreshold)
					{
						num = i;
						_minStartThreshold = null;
					}
				}
				if (num < 0)
				{
					return;
				}
				buffer = buffer.Slice(MathX.Max(0, num - 128));
			}
			lock (audio)
			{
				Audio?.WriteSamples(buffer);
			}
		}
	}
