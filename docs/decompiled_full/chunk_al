	public class WorkerBag<W> : SyncRefIDBagBase<W> where W : class, IWorker
	{
		protected override void EncodeElement(BinaryWriter writer, W element)
		{
			base.World.Types.EncodeType(writer, element.WorkerType);
		}

		protected override W DecodeElement(BinaryReader reader)
		{
			return (W)TypeManager.Instantiate(base.World.Types.DecodeType(reader));
		}

		protected override DataTreeNode InternalSave(SaveControl control)
		{
			DataTreeList dataTreeList = new DataTreeList();
			foreach (KeyValuePair<RefID, W> element in elements)
			{
				if (!element.Value.IsPersistent && !control.SaveNonPersistent)
				{
					continue;
				}
				try
				{
					if (element.Value is MissingComponent missingComponent)
					{
						DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
						dataTreeDictionary.Add("Type", control.SaveType(missingComponent.Type.Value));
						dataTreeDictionary.Add("Data", missingComponent.Data.ToRawDataTreeNode());
						dataTreeList.Add(dataTreeDictionary);
					}
					else
					{
						dataTreeList.Add(WorkerSaveLoad.SaveWorker(element.Value, control));
					}
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception saving worker, skipping with partial data loss: {element.Value}\n{value}");
				}
			}
			return dataTreeList;
		}

		protected override void InternalLoad(DataTreeNode node, LoadControl control)
		{
			foreach (DataTreeNode child in (node as DataTreeList).Children)
			{
				WorkerSaveLoad.WorkerData workerData = WorkerSaveLoad.ExtractWorker(child, control);
				IWorkerLoader workerLoader = control.FindLoader(workerData);
				Type type = workerLoader?.FindType(workerData, control);
				if (type == typeof(void) || !control.AllowType(type))
				{
					continue;
				}
				if (!typeof(Worker).IsAssignableFrom(type))
				{
					type = null;
				}
				IWorker worker = null;
				if (type != null)
				{
					try
					{
						worker = TypeManager.Instantiate(type);
					}
					catch (Exception ex)
					{
						UniLog.Error("Exception instantiating worker type: " + type?.ToString() + "\n" + ex);
					}
				}
				if (worker == null)
				{
					if (base.IsLocalElement)
					{
						base.World.ReferenceController.LocalAllocationBlockBegin();
					}
					MissingComponent missingComponent = TypeManager.Instantiate<MissingComponent>();
					InternalAdd(base.World.ReferenceController.PeekID(), (W)(object)missingComponent, isNew: false, sync: true, change: true);
					if (base.IsLocalElement)
					{
						base.World.ReferenceController.LocalAllocationBlockEnd();
					}
					missingComponent.Type.Value = workerData.workerTypename;
					missingComponent.Data.FromRawDataTreeNode(workerData.loadNode);
					WorkerSaveLoad.WorkerData workerData2 = workerData;
					UniLog.Warning("Unsupported worker type, couldn't load: " + workerData2.ToString() + ", LegacyTypes: " + control.LegacyTypes);
				}
				else
				{
					RefID key = base.World.ReferenceController.PeekID();
					InternalAdd(key, (W)worker, isNew: false, sync: true, change: true);
					workerLoader.LoadWorker(worker, workerData.loadNode, control);
				}
			}
		}

		protected override void InternalCopy(ISyncMember source, Action<ISyncMember, ISyncMember> copy)
		{
			throw new Exception("WorkerBags cannot be copied!");
		}

		public IEnumerable<W> Where(Predicate<W> predicate)
		{
			return from e in elements
				where predicate(e.Value)
				select e.Value;
		}
