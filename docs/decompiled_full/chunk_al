		private void UpdateActiveState(bool supressStartException)
		{
			lock (lockobj)
			{
				if (activeState)
				{
					try
					{
						if (device.DataFlow == DataFlow.Capture)
						{
							if (capture == null)
							{
								capture = new WasapiCapture(eventSync: true, AudioClientShareMode.Shared, 0);
								capture.Device = device;
								capture.Initialize();
								capture.DataAvailable += Capture_DataAvailable;
								capture.Stopped += Capture_Stopped;
							}
							if (capture.RecordingState != RecordingState.Recording)
							{
								capture.Start();
							}
						}
						else
						{
							if (loopbackCapture == null)
							{
								loopbackCapture = new WasapiLoopbackCapture(0);
								loopbackCapture.Device = device;
								loopbackCapture.Initialize();
								loopbackCapture.DataAvailable += Capture_DataAvailable;
								loopbackCapture.Stopped += Capture_Stopped;
							}
							if (loopbackCapture.RecordingState != RecordingState.Recording)
							{
								loopbackCapture.Start();
							}
						}
						return;
					}
					catch (Exception ex)
					{
						DisposeCapture();
						if (!supressStartException)
						{
							UniLog.Error("Exception starting audio capture:\n" + ex);
						}
						return;
					}
				}
				DisposeCapture();
			}
		}

		private void DisposeCapture()
		{
			if (capture == null && loopbackCapture == null)
			{
				return;
			}
			try
			{
				if (capture != null)
				{
					capture.Stop();
					capture.Dispose();
					capture = null;
				}
				if (loopbackCapture != null)
				{
					loopbackCapture.Stop();
					loopbackCapture.Dispose();
					loopbackCapture = null;
				}
			}
			catch (Exception ex)
			{
				UniLog.Log("Exception stopping audio capture:\n" + ex);
			}
		}

		private void Capture_Stopped(object sender, RecordingStoppedEventArgs e)
		{
			if (!e.HasError)
			{
				return;
			}
			UniLog.Log($"Audio capture stopped, restarting: {e.Exception}");
			Task.Run(async delegate
			{
				lock (lockobj)
				{
					DisposeCapture();
				}
				do
				{
					await Task.Delay(1000);
					UpdateActiveState(supressStartException: true);
				}
				while (activeState && capture == null);
			});
		}

		private void Capture_DataAvailable(object sender, DataAvailableEventArgs e)
		{
			try
			{
				Span<float> buffer = MemoryMarshal.Cast<byte, float>(e.Data.AsSpan().Slice(e.Offset, e.ByteCount));
				int channels = e.Format.Channels;
				audioInput.SetSampleRate(e.Format.SampleRate);
				switch (channels)
				{
				case 1:
					audioInput.WriteSamples(buffer.AsAudioBuffer<MonoSample>(), ref lastPosition, ref lastMonoSample);
					break;
				case 2:
					audioInput.WriteSamples(buffer.AsAudioBuffer<StereoSample>(), ref lastPosition, ref lastStereoSample);
					break;
				case 4:
					audioInput.WriteSamples(buffer.AsAudioBuffer<QuadSample>(), ref lastPosition, ref lastQuadSample);
					break;
				case 6:
					audioInput.WriteSamples(buffer.AsAudioBuffer<Surround51Sample>(), ref lastPosition, ref lastSurround51sample);
					break;
				case 8:
					audioInput.WriteSamples(buffer.AsAudioBuffer<Surround71Sample>(), ref lastPosition, ref lastSurround71sample);
					break;
				default:
					throw new Exception("Unsupported channel count: " + channels);
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception in processing audio input data. Channels: {e.Format.Channels}, BitsPerSample: {e.Format.BitsPerSample}, SampleRate: {e.Format.SampleRate}, WaveFormat: {e.Format.WaveFormatTag}\n{value}", stackTrace: false);
			}
		}
