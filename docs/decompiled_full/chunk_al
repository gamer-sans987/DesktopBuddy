				return null;
			}
			foreach (KeyValuePair<K, T> element in elements)
			{
				if (element.Value == val)
				{
					return $"[{element.Key}]";
				}
			}
			return null;
		}

		private T InternalAdd(RefID? id, K key, bool sync = true, bool change = true)
		{
			BeginModification();
			if (elements.ContainsKey(key))
			{
				K val = key;
				throw new ArgumentException("The dictionary already contains key: " + val);
			}
			if (id.HasValue)
			{
				base.World.ReferenceController.AllocationBlockBegin(id.Value);
			}
			else if (base.IsLocalElement)
			{
				base.World.ReferenceController.LocalAllocationBlockBegin();
			}
			T val2 = new T();
			val2.Initialize(base.World, this);
			if (id.HasValue)
			{
				base.World.ReferenceController.AllocationBlockEnd();
			}
			else if (base.IsLocalElement)
			{
				base.World.ReferenceController.LocalAllocationBlockEnd();
			}
			InternalAddNode(val2, key, sync, change);
			EndModification();
			return val2;
		}

		private void InternalAddNode(T element, K key, bool sync = true, bool change = true)
		{
			BeginModification();
			RegisterChildElement(element);
			if (elements.ContainsKey(key))
			{
				K val = key;
				throw new ArgumentException("SyncDictionary already contains given key: " + val?.ToString() + ", Elements: " + elements[key]);
			}
			elements.Add(key, element);
			if (base.IsInInitPhase)
			{
				RegisterNewInitializable(element);
			}
			else
			{
				if (element.IsInInitPhase)
				{
					element.EndInitPhase();
				}
				if (sync && base.GenerateSyncData)
				{
					GetAddedElements().Add(key, element);
					InvalidateSyncElement();
				}
			}
			if (change)
			{
				BlockModification();
				SyncElementChanged();
				RunElementAdded(key, element);
				UnblockModification();
			}
			EndModification();
		}

		private bool InternalRemove(K key, bool sync = true, bool change = true)
		{
			if (base.IsInInitPhase)
			{
				throw new Exception("Cannot remove elements during initialization phase!");
			}
			BeginModification();
			if (elements.TryGetValue(key, out var value))
			{
				bool flag = false;
				elements.Remove(key);
				UnregisterChildElement(value);
				if (sync && base.GenerateSyncData)
				{
					if (!GetAddedElements().Remove(key))
					{
						GetRemovedElements().Add(key);
						flag = true;
					}
					InvalidateSyncElement();
				}
				if (change)
				{
					BlockModification();
					SyncElementChanged();
					RunElementRemoved(key, value);
					UnblockModification();
				}
				if (flag)
				{
					base.World.MoveToTrash(value);
				}
				else
				{
					value.Dispose();
				}
				EndModification();
				return true;
			}
			EndModification();
			return false;
		}

		private void InternalClear(bool sync = true, bool change = true, bool forceTrash = false)
		{
			if (elements.Count == 0)
			{
				return;
			}
			BeginModification();
			if (change)
			{
				BlockModification();
				RunBeforeClear();
				UnblockModification();
			}
			foreach (KeyValuePair<K, T> element in elements)
			{
				if (sync || forceTrash)
				{
					base.World.MoveToTrash(element.Value);
				}
				else
				{
					element.Value.Dispose();
				}
			}
			elements.Clear();
			if (sync && base.GenerateSyncData)
			{
				if (_removedElements != null)
				{
					Pool.Return(ref _removedElements);
					_removedElements = null;
				}
				if (_addedElements != null)
				{
					Pool.Return(ref _addedElements);
					_addedElements = null;
				}
				_wasCleared = true;
				InvalidateSyncElement();
			}
			if (change)
			{
				BlockModification();
				SyncElementChanged();
				RunCleared();
				UnblockModification();
			}
			EndModification();
		}

		private void RunElementAdded(K key, T element)
		{
			this.ElementAdded?.Invoke(this, key, element);
			this._genElementAdded?.Invoke(this, key, element);
		}

		private void RunElementRemoved(K key, T element)
		{
			this.ElementRemoved?.Invoke(this, key, element);
			this._genElementRemoved?.Invoke(this, key, element);
		}

		private void RunCleared()
		{
			if (this.Cleared != null)
			{
				this.Cleared(this);
			}
		}

		private void RunBeforeClear()
		{
			if (this.BeforeClear != null)
			{
				this.BeforeClear(this);
			}
		}

		protected override void InternalCopy(ISyncMember source, Action<ISyncMember, ISyncMember> copy)
		{
			SyncDictionary<K, T> obj = (SyncDictionary<K, T>)source;
			Clear();
			foreach (KeyValuePair<K, T> item in obj)
			{
				copy(item.Value, Add(item.Key));
			}
		}

		protected override void InternalEncodeFull(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			writer.Write7BitEncoded((ulong)elements.Count);
			if (elements.Count <= 0)
			{
				return;
			}
			RefID refID = elements.Min((KeyValuePair<K, T> r) => r.Value.ReferenceID);
			writer.Write7BitEncoded((ulong)refID);
			foreach (KeyValuePair<K, T> element in elements)
			{
				Coder<K>.Encode(element.Key, writer);
				writer.Write7BitEncoded((ulong)(element.Value.ReferenceID - refID));
			}
		}

		protected override void InternalDecodeFull(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			InternalClear(sync: false, change: true, forceTrash: true);
			ulong num = reader.Read7BitEncoded();
			if (num == 0)
			{
				return;
			}
			RefID refID = reader.Read7BitEncoded();
			ulong tick = base.World.SyncTick;
			if (inboundMessage is ConfirmationMessage confirmationMessage)
			{
				tick = confirmationMessage.ConfirmTime;
			}
			for (ulong num2 = 0uL; num2 < num; num2++)
			{
				K key = Coder<K>.Decode(reader);
				RefID refID2 = reader.Read7BitEncoded() + refID;
				ISyncMember syncMember = base.World.TryRetrieveFromTrash(tick, refID2);
				if (syncMember == null)
				{
					InternalAdd(refID2, key, sync: false);
				}
				else
				{
					InternalAddNode(syncMember as T, key, sync: false);
				}
			}
		}

		protected override void InternalEncodeDelta(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			writer.Write(_wasCleared);
			if (_removedElements != null)
			{
				writer.Write7BitEncoded((ulong)_removedElements.Count);
				foreach (K removedElement in _removedElements)
				{
					Coder<K>.Encode(removedElement, writer);
				}
			}
			else
			{
				writer.Write7BitEncoded(0uL);
			}
			if (_addedElements != null)
			{
				writer.Write7BitEncoded((ulong)_addedElements.Count);
				if (_addedElements.Count <= 0)
				{
					return;
				}
				RefID refID;
				if (_addedElements.Count > 1)
				{
					refID = _addedElements.Min((KeyValuePair<K, T> r) => r.Value.ReferenceID);
					writer.Write7BitEncoded((ulong)refID);
				}
				else
				{
					refID = 0uL;
				}
				{
					foreach (KeyValuePair<K, T> addedElement in _addedElements)
					{
						Coder<K>.Encode(addedElement.Key, writer);
						writer.Write7BitEncoded((ulong)(addedElement.Value.ReferenceID - refID));
					}
					return;
				}
			}
			writer.Write7BitEncoded(0uL);
		}

		protected override void InternalDecodeDelta(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			if (reader.ReadBoolean())
			{
				InternalClear(sync: false);
			}
			ulong num = reader.Read7BitEncoded();
			for (ulong num2 = 0uL; num2 < num; num2++)
			{
				K key = Coder<K>.Decode(reader);
				InternalRemove(key, sync: false);
			}
			ulong num3 = reader.Read7BitEncoded();
			RefID refID;
			switch (num3)
			{
			case 1uL:
				refID = 0uL;
				break;
			default:
				refID = reader.Read7BitEncoded();
				break;
			case 0uL:
				return;
			}
			for (ulong num4 = 0uL; num4 < num3; num4++)
			{
				K key2 = Coder<K>.Decode(reader);
				RefID value = reader.Read7BitEncoded() + refID;
				InternalAdd(value, key2, sync: false);
			}
		}

		protected override void InternalClearDirty()
		{
			_wasCleared = false;
			if (_removedElements != null)
			{
				Pool.Return(ref _removedElements);
				_removedElements = null;
			}
			if (_addedElements != null)
			{
				Pool.Return(ref _addedElements);
				_addedElements = null;
			}
		}

		public override void Dispose()
		{
			foreach (KeyValuePair<K, T> element in elements)
			{
				element.Value.Dispose();
			}
			elements.Clear();
			base.Dispose();
		}

		protected override DataTreeNode InternalSave(SaveControl control)
		{
			DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
			foreach (KeyValuePair<K, T> element in elements)
			{
				dataTreeDictionary.Add(Coder<K>.EncodeToString(element.Key), element.Value.Save(control));
			}
			return dataTreeDictionary;
		}

		protected override void InternalLoad(DataTreeNode node, LoadControl control)
		{
			foreach (KeyValuePair<string, DataTreeNode> child in (node as DataTreeDictionary).Children)
			{
				K key = Coder<K>.DecodeFromString(child.Key);
				InternalAdd(null, key).Load(child.Value, control);
			}
		}
	}
