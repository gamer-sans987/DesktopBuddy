	public class MappableTrackedObject : OffsetableTrackedObject
	{
		private bool _trackerEnabled;

		private TrackerSettings _settings;

		private TrackerSettings.Tracker _tracker;

		public override bool IsMapped => base.CorrespondingBodyNode != BodyNode.NONE;

		public virtual string UniqueID { get; set; }

		public override bool ShouldMappingBeActive
		{
			get
			{
				if (_trackerEnabled)
				{
					return base.ShouldMappingBeActive;
				}
				return false;
			}
		}

		public bool FreezeTracking
		{
			get
			{
				Sync<bool> sync = _tracker?.FreezeTracking;
				if (sync == null)
				{
					return false;
				}
				return sync;
			}
		}

		public string LegacyBodyNodeVar => base.LegacyBasePath + ".BodyNode";

		public void Initialize(string uniqueIdentifier)
		{
			Initialize(uniqueIdentifier, BodyNode.NONE, MappingTarget.NONE, Elements.Core.float3.Zero, Elements.Core.floatQ.Identity);
		}

		public override void Initialize(string uniqueIdentifier, BodyNode defaultBodyNode, MappingTarget defaultTarget, Elements.Core.float3 defaultPositionOffset, Elements.Core.floatQ defaultRotationOffset)
		{
			Settings.RegisterValueChanges<TrackerSettings>(OnTrackerSettingsChanged);
			base.Initialize(uniqueIdentifier, defaultBodyNode, defaultTarget, defaultPositionOffset, defaultRotationOffset);
		}

		private void OnTrackerSettingsChanged(TrackerSettings settings)
		{
			_trackerEnabled = settings.UseTrackers.Value;
			if (settings != _settings || _tracker == null)
			{
				_tracker = settings.GetTracker(UniqueID);
				_settings = settings;
			}
			if (_tracker != null)
			{
				_trackerEnabled &= _tracker.UseTracker.Value;
				base.BodyNodePositionOffset = _tracker.MappedPosition.Value;
				base.BodyNodeRotationOffset = _tracker.MappedRotation.Value;
				base.CorrespondingBodyNode = _tracker.MappedBodyNode.Value;
				base.MappingTargets = _tracker.MappingTargets;
				base.Input.TriggerBodyNodeChanged(this);
			}
		}

		public virtual void Map(BodyNode bodyNode, MappingTarget targets, Elements.Core.float3 positionOffset, Elements.Core.floatQ rotationOffset)
		{
			Settings.UpdateActiveSetting(delegate(TrackerSettings s)
			{
				TrackerSettings.Tracker tracker = s.GetTracker(UniqueID);
				if (tracker != null)
				{
					tracker.MappedBodyNode.Value = bodyNode;
					tracker.MappingTargets = targets;
					tracker.MappedPosition.Value = positionOffset;
					tracker.MappedRotation.Value = rotationOffset;
				}
			});
		}

		public override void UpdateOffset(Elements.Core.float3 positionOffset, Elements.Core.floatQ rotationOffset)
		{
			Settings.UpdateActiveSetting(delegate(TrackerSettings s)
			{
				TrackerSettings.Tracker tracker = s.GetTracker(UniqueID);
				if (tracker != null)
				{
					tracker.MappedPosition.Value = positionOffset;
					tracker.MappedRotation.Value = rotationOffset;
				}
			});
		}

		public virtual void Unmap()
		{
			Settings.UpdateActiveSetting(delegate(TrackerSettings s)
			{
				s.GetTracker(UniqueID)?.Unmap();
			});
		}
	}
