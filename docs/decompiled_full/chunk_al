		private static bool IsTracking(DateTime? timestamp)
		{
			if (!timestamp.HasValue)
			{
				return false;
			}
			if ((DateTime.UtcNow - timestamp.Value).TotalSeconds > 10.0)
			{
				return false;
			}
			return true;
		}
	}
