			if (flag.Value)
			{
				return OnTrue?.Evaluate(in context);
			}
			return OnFalse?.Evaluate(in context);
		}

		public void ResetNode()
		{
			OnTrue?.ResetNode();
			OnFalse?.ResetNode();
			Condition?.ResetNode();
		}

