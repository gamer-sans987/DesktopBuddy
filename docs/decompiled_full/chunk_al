	public class OWO_Driver : IInputDriver
	{
		private class HapticPointData
		{
			public readonly HapticPoint point;

			public readonly OWOMuscles muscle;

			public bool HasHints => point.Hints.Count > 0;

			public float LastMaxIntensity { get; private set; }

			public float ActivationIntensity { get; private set; }

			public bool IsActivated => ActivationIntensity > 0f;

			public HapticPointData(HapticPoint point, OWOMuscles muscle)
			{
				this.point = point;
				this.muscle = muscle;
			}

			public void Sample()
			{
				point.SampleSources(0f, IsSupportedHint);
				LastMaxIntensity = MathX.Max(point.Force, point.Pain, point.Vibration);
				if (LastMaxIntensity < ActivationIntensity * 0.5f)
				{
					ActivationIntensity = 0f;
				}
			}

			public void Activate()
			{
				ActivationIntensity = LastMaxIntensity;
			}

			private static bool IsSupportedHint(string hint)
			{
				return SensationMap.Contains(hint.ToLower());
			}
		}

		private static readonly string[] Sensations;

		private static readonly HashSet<string> SensationMap;

		private OWOTCPClient owoClient;

		private InputInterface input;

		private List<HapticPointData> _points = new List<HapticPointData>();

		public int UpdateOrder => 0;

		private static int GetSensationIndex(string name)
		{
			return Sensations.FindIndex((string s) => s != null && name.EndsWith(s, StringComparison.InvariantCultureIgnoreCase));
		}

		static OWO_Driver()
		{
			Sensations = new string[25]
			{
				"Ball", "Dart", "DaggerWound", null, "ShotWithExit", null, "Axe", "Punch", "Grip", "Shot",
				"Insects", "FreeFall", "LoadObject", "LoadHeavyObject", "FastDriving", "DriveSlow", "InsectBites", "MachineGunshots", "PushingSomethingHeavy", "PushSomething",
				"SevereAbdominalWound", "SlightBleedingWound", "Oppression", "StrangePresence", "Tickle"
			};
			SensationMap = new HashSet<string>();
			string[] sensations = Sensations;
			foreach (string text in sensations)
			{
				if (text != null)
				{
					SensationMap.Add("owo." + text.ToLower());
				}
			}
		}

		public void CollectDeviceInfos(DataTreeList list)
		{
			DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
			dataTreeDictionary.Add("Name", "OWO Suit");
			dataTreeDictionary.Add("Type", "Haptics");
			dataTreeDictionary.Add("Model", "OWO");
			list.Add(dataTreeDictionary);
		}

		public void RegisterInputs(InputInterface inputInterface)
		{
			string[] commandLineArgs = Environment.GetCommandLineArgs();
			string text = null;
			for (int i = 0; i < commandLineArgs.Length; i++)
			{
				string text2 = commandLineArgs[i].ToLower();
				bool flag = i + 1 < commandLineArgs.Length;
				if (text2.EndsWith("EnableOWO".ToLower()) && flag)
				{
					text = commandLineArgs[i + 1];
					break;
				}
			}
			if (string.IsNullOrWhiteSpace(text))
			{
				return;
			}
			input = inputInterface;
			UniLog.Log("Initializing OWO, target IP: " + text);
			owoClient = new OWOTCPClient();
			owoClient.Connect(text);
			CreateHapticPoint(0.1f, OWOMuscles.Pectoral_L, new TorsoHapticPointPosition(-0.5f, 0.75f, TorsoSide.Front));
			CreateHapticPoint(0.1f, OWOMuscles.Pectoral_R, new TorsoHapticPointPosition(0.5f, 0.75f, TorsoSide.Front));
			CreateHapticPoint(0.08f, OWOMuscles.Dorsal_L, new TorsoHapticPointPosition(-0.5f, 0.75f, TorsoSide.Back));
			CreateHapticPoint(0.08f, OWOMuscles.Dorsal_R, new TorsoHapticPointPosition(0.5f, 0.75f, TorsoSide.Back));
			CreateHapticPoint(0.085f, OWOMuscles.Abdominal_L, new TorsoHapticPointPosition(-0.5f, 0.25f, TorsoSide.Front));
			CreateHapticPoint(0.085f, OWOMuscles.Abdominal_R, new TorsoHapticPointPosition(0.5f, 0.25f, TorsoSide.Front));
			CreateHapticPoint(0.085f, OWOMuscles.Lumbar_L, new TorsoHapticPointPosition(-0.5f, 0.25f, TorsoSide.Back));
			CreateHapticPoint(0.085f, OWOMuscles.Lumbar_R, new TorsoHapticPointPosition(0.5f, 0.25f, TorsoSide.Back));
			CreateHapticPoint(0.05f, OWOMuscles.Arm_L, new ArmHapticPosition(Chirality.Left, 0.2f, 0f));
			CreateHapticPoint(0.05f, OWOMuscles.Arm_R, new ArmHapticPosition(Chirality.Right, 0.2f, 0f));
			foreach (HapticPointData point in _points)
			{
				input.RegisterHapticPoint(point.point);
			}
		}

		private void CreateHapticPoint(float radius, OWOMuscles muscle, HapticPointPosition position)
		{
			_points.Add(new HapticPointData(new HapticPoint(input, radius, position), muscle));
		}

		public void UpdateInputs(float deltaTime)
		{
			if (owoClient == null)
			{
				return;
			}
			HapticPointData hapticPointData = null;
			foreach (HapticPointData point in _points)
			{
				point.Sample();
				if ((point.HasHints || hapticPointData == null || !hapticPointData.HasHints) && (hapticPointData == null || point.LastMaxIntensity > hapticPointData.LastMaxIntensity || (point.HasHints && !hapticPointData.HasHints)))
				{
					hapticPointData = point;
				}
			}
			if (hapticPointData.IsActivated || hapticPointData.LastMaxIntensity == 0f)
			{
				return;
			}
			hapticPointData.Activate();
			if (hapticPointData.HasHints)
			{
				HapticHint hapticHint = default(HapticHint);
				foreach (HapticHint hint in hapticPointData.point.Hints)
				{
					if (hint.intensity > hapticHint.intensity)
					{
						hapticHint = hint;
					}
				}
				owoClient.SendSensation(GetSensationIndex(hapticHint.hint), hapticPointData.muscle);
				return;
			}
			float lastMaxIntensity = hapticPointData.LastMaxIntensity;
			string text = null;
			if (lastMaxIntensity == hapticPointData.point.Force)
			{
				text = ((lastMaxIntensity < 0.25f) ? "Dart" : ((!(lastMaxIntensity < 0.5f)) ? "Punch" : "Ball"));
			}
			else if (lastMaxIntensity == hapticPointData.point.Pain)
			{
				text = ((lastMaxIntensity < 0.25f) ? "Shot" : ((lastMaxIntensity < 0.5f) ? "ShotWithExit" : ((!(lastMaxIntensity < 0.75f)) ? "Insects" : "SevereAbdominalWound")));
			}
			else if (lastMaxIntensity == hapticPointData.point.Vibration)
			{
				text = ((lastMaxIntensity < 0.25f) ? "FastDriving" : ((!(lastMaxIntensity < 0.5f)) ? "LoadObject" : "FreeFall"));
			}
			if (text != null)
			{
				owoClient.SendSensation(GetSensationIndex(text), hapticPointData.muscle);
			}
		}
	}
	public abstract class OSC_Driver : IInputDriver, IDisposable
	{
		private bool disposed;

		private Thread thread;

		private OscReceiver oscReceiver;

		public abstract int UpdateOrder { get; }

		public abstract void CollectDeviceInfos(DataTreeList list);

		public virtual void Dispose()
		{
			disposed = true;
			oscReceiver?.Close();
		}

		public virtual void RegisterInputs(InputInterface inputInterface)
		{
			UniLog.Log("Starting OSC processing thread");
			thread = new Thread(ReceiveTrackingData);
			thread.Start();
		}

		public abstract void UpdateInputs(float deltaTime);

		protected void SetPort(int port)
		{
			OscReceiver obj = this.oscReceiver;
			if ((obj == null || obj.Port != port) && port != 0)
			{
				try
				{
					UniLog.Log($"Starting {GetType().Name} OSC listener on on port {port}");
					OscReceiver oscReceiver = new OscReceiver(port);
					oscReceiver.Connect();
					OscReceiver obj2 = this.oscReceiver;
					this.oscReceiver = oscReceiver;
					obj2?.Close();
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception when starting " + GetType().Name + " OSC receiver:\n" + ex);
				}
			}
		}

		protected abstract void UpdateData(OscMessage message);

		private void ReceiveTrackingData()
		{
			do
			{
				Thread.Sleep(100);
				OscReceiver oscReceiver = this.oscReceiver;
				if (oscReceiver == null)
				{
					continue;
				}
				try
				{
					UniLog.Log($"Processing {GetType().Name} OSC on on port {oscReceiver.Port}");
					while (oscReceiver.State == OscSocketState.Connected)
					{
						OscPacket oscPacket = oscReceiver.Receive();
						if (oscPacket is OscBundle oscBundle)
						{
							foreach (OscPacket item in oscBundle)
							{
								if (item is OscMessage message)
								{
									UpdateData(message);
								}
								else
								{
									UniLog.Warning("Unexpected Osc packet type within bundle: " + item);
								}
							}
						}
						else if (oscPacket is OscMessage message2)
						{
							UpdateData(message2);
						}
						else
						{
							UniLog.Warning("Unexpected root Osc packet: " + oscPacket);
						}
					}
				}
				catch (Exception ex)
				{
					if (ex.Message != "The receiver socket has been disconnected")
					{
						UniLog.Error("Exception in OSC listener thread:\n" + ex);
					}
				}
				try
				{
					UniLog.Log($"Disposing of {GetType().Name} OSC on on port {oscReceiver.Port}");
					oscReceiver.Dispose();
				}
				catch (Exception ex2)
				{
					UniLog.Error("Exception disposing of OSC receiver:\n" + ex2);
				}
			}
			while (!disposed);
			UniLog.Log("OSC processing thread for " + GetType().Name + " completed");
		}

		protected static float ReadFloat(OscMessage message)
		{
			return (float)message[0];
		}

		protected static Elements.Core.float3 ReadFloat3(OscMessage message)
		{
			return new Elements.Core.float3((float)message[0], (float)message[1], (float)message[2]);
		}
	}
	public class SystemInfo : StandaloneSystemInfo
	{
		public SystemInfo()
		{
			HardwareInfo hardwareInfo;
			try
			{
				hardwareInfo = new HardwareInfo();
			}
			catch (Exception ex)
			{
				UniLog.Warning("Failed to initialize HardwareInfo: " + ex.Message);
				return;
			}
			try
			{
				hardwareInfo.RefreshOperatingSystem();
				base.OperatingSystem = hardwareInfo.OperatingSystem.Name;
			}
			catch (Exception ex2)
			{
				UniLog.Warning("Failed to retrieve OS info: " + ex2.Message);
			}
			try
			{
				hardwareInfo.RefreshMemoryStatus();
				base.MemoryBytes = (long)hardwareInfo.MemoryStatus.TotalPhysical;
			}
			catch (Exception ex3)
			{
				UniLog.Warning("Failed to retrieve memory info: " + ex3.Message);
			}
			try
			{
				hardwareInfo.RefreshCPUList(includePercentProcessorTime: false);
				CPU cPU = hardwareInfo.CpuList.FirstOrDefault();
				if (cPU != null)
				{
					base.CPU = cPU.Name;
					base.PhysicalCores = (int)cPU.NumberOfCores;
				}
			}
			catch (Exception ex4)
			{
				UniLog.Warning("Failed to retrieve CPU info: " + ex4.Message);
			}
			try
			{
				hardwareInfo.RefreshVideoControllerList();
				VideoController videoController = FindBestVideoAdapter(hardwareInfo.VideoControllerList);
				if (videoController != null)
				{
					base.GPU = videoController.Name;
					base.VRAMBytes = (long)videoController.AdapterRAM;
				}
			}
			catch (Exception ex5)
			{
				UniLog.Warning("Failed to retrieve GPU info: " + ex5.Message);
			}
		}

		public static VideoController FindBestVideoAdapter(List<VideoController> controllers)
		{
			if (controllers == null)
			{
				return null;
			}
			VideoController videoController = null;
			foreach (VideoController controller in controllers)
			{
				if (videoController == null || controller.AdapterRAM > videoController.AdapterRAM || (string.IsNullOrWhiteSpace(videoController.VideoProcessor) && !string.IsNullOrWhiteSpace(controller.VideoProcessor)))
				{
					videoController = controller;
				}
			}
			return videoController;
		}
	}
