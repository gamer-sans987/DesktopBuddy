			}
			else
			{
				@float = LeftAxis?.Evaluate(in context);
				float2 = RightAxis?.Evaluate(in context);
				num = LeftSpeed?.Evaluate(in context);
				num2 = RightSpeed?.Evaluate(in context);
			}
			if (!@float.HasValue && !float2.HasValue)
			{
				return null;
			}
			MovementSettings activeSetting = Settings.GetActiveSetting<MovementSettings>();
			if (activeSetting == null)
			{
				return Elements.Core.float3.Zero;
			}
			Elements.Core.float2? axis;
			Elements.Core.float2? axis2;
			float? num3;
			float? num4;
			Chirality primarySide;
			Chirality secondarySide;
			SidewaysMovementMode sidewaysMovementMode;
			SidewaysMovementMode sidewaysMovementMode2;
			if (context.group.InputInterface.PrimaryHand == Chirality.Left)
			{
				axis = @float;
				axis2 = float2;
				num3 = num;
				num4 = num2;
				primarySide = Chirality.Left;
				secondarySide = Chirality.Right;
				sidewaysMovementMode = activeSetting.LeftSidewaysMode;
				sidewaysMovementMode2 = activeSetting.RightSidewaysMode;
			}
			else
			{
				axis = float2;
				axis2 = @float;
				num3 = num2;
				num4 = num;
				primarySide = Chirality.Right;
				secondarySide = Chirality.Left;
				sidewaysMovementMode = activeSetting.RightSidewaysMode;
				sidewaysMovementMode2 = activeSetting.LeftSidewaysMode;
			}
			UserRoot userRoot = context.group.World?.LocalUser?.Root;
			if (userRoot == null)
			{
				return Elements.Core.float3.Zero;
			}
			if (!axis.HasValue)
			{
				axis = axis2;
				num3 = num4;
				axis2 = null;
				num4 = null;
				primarySide = secondarySide;
			}
			if (!axis2.HasValue && (sidewaysMovementMode2.HasTurning() || sidewaysMovementMode == SidewaysMovementMode.TurnOnly))
			{
				sidewaysMovementMode = SidewaysMovementMode.TurnAndMove;
			}
			bool value = activeSetting.UseHeadDirectionForMovement.Value;
			bool value2 = activeSetting.SmoothTurnExclusiveMode.Value;
			Sync<float> movementDeadzone = activeSetting.MovementDeadzone;
			Sync<float> turningDeadzone = activeSetting.TurningDeadzone;
			Sync<float> movementExponent = activeSetting.MovementExponent;
			switch (sidewaysMovementMode)
			{
			case SidewaysMovementMode.TurnOnly:
				axis = axis?.x_;
				break;
			case SidewaysMovementMode.TurnAndMove:
				axis = LocomotionInputHelper.FilterLocomotionAxis(in axis, value2);
				break;
			}
			switch (sidewaysMovementMode2)
			{
			case SidewaysMovementMode.TurnOnly:
				axis2 = axis2?.x_;
				break;
			case SidewaysMovementMode.TurnAndMove:
				axis2 = LocomotionInputHelper.FilterLocomotionAxis(in axis2, value2);
				break;
			}
			Elements.Core.float2 axis3 = axis ?? Elements.Core.float2.Zero;
			Elements.Core.float2 axis4 = axis2 ?? Elements.Core.float2.Zero;
			axis3 = ((!sidewaysMovementMode.HasTurning()) ? MathX.RadialDeadzone(in axis3, movementDeadzone) : MathX.ElementWiseDeadzone(axis3, new Elements.Core.float2(turningDeadzone, movementDeadzone)));
			axis4 = ((!sidewaysMovementMode2.HasTurning()) ? MathX.RadialDeadzone(in axis4, movementDeadzone) : MathX.ElementWiseDeadzone(axis4, new Elements.Core.float2(turningDeadzone, movementDeadzone)));
			axis3 = MathX.PowMagnitude(axis3, movementExponent);
			axis4 = MathX.PowMagnitude(axis4, movementExponent);
			Slot headSlot = userRoot.HeadSlot;
			if (headSlot == null)
			{
				return Elements.Core.float3.Zero;
			}
			if (sidewaysMovementMode != SidewaysMovementMode.Strafe)
			{
				axis3 = axis3._y;
			}
			if (sidewaysMovementMode2 != SidewaysMovementMode.Strafe)
			{
				axis4 = axis4._y;
			}
			float magnitude = new Elements.Core.float2(MathX.Max(MathX.Abs(axis3.x), MathX.Abs(axis4.x)), MathX.Max(MathX.Abs(axis3.y), MathX.Abs(axis4.y))).Magnitude;
			if (magnitude <= 0f)
			{
				return Elements.Core.float3.Zero;
			}
			if (magnitude > 1f)
			{
				float num5 = 1f / magnitude;
				axis3 *= num5;
				axis4 *= num5;
			}
			Elements.Core.float3 a = Elements.Core.float3.Zero;
			float num6 = 0f;
			if (sidewaysMovementMode == SidewaysMovementMode.Strafe)
			{
				num6 += axis3.x;
			}
			if (sidewaysMovementMode2 == SidewaysMovementMode.Strafe)
			{
				num6 += axis4.x;
			}
			a += headSlot.LocalDirectionToSpace(new Elements.Core.float3(num6 * (num4 ?? 1f)), userRoot.Slot);
			if (value)
			{
				float z = axis3.y * (num3 ?? 1f) + axis4.y * (num4 ?? 1f);
				a += headSlot.LocalDirectionToSpace(new Elements.Core.float3(0f, 0f, z), userRoot.Slot);
			}
			else
			{
				ILocomotionReference registeredComponent = userRoot.GetRegisteredComponent((ILocomotionReference r) => r.Side == primarySide);
				ILocomotionReference registeredComponent2 = userRoot.GetRegisteredComponent((ILocomotionReference r) => r.Side == secondarySide);
				if (registeredComponent?.DirectionReference != null)
				{
					a += registeredComponent.DirectionReference.LocalDirectionToSpace(Elements.Core.float3.Forward * axis3.y * (num3 ?? 1f), userRoot.Slot);
				}
				if (registeredComponent2?.DirectionReference != null)
				{
					a += registeredComponent2.DirectionReference.LocalDirectionToSpace(Elements.Core.float3.Forward * axis4.y * (num4 ?? 1f), userRoot.Slot);
				}
			}
			return a;
		}

