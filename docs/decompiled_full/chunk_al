		private void WriteCopySegment(SegmentInfo info, T[] source)
		{
			DataSegment segment = info.segment;
			if (info.written)
			{
				return;
			}
			if (info.walked)
			{
				if (info.backup == null)
				{
					info.backup = new T[segment.Length];
					Array.Copy(source, segment.OriginalDataBegin, info.backup, 0, info.backup.Length);
				}
				return;
			}
			info.walked = true;
			foreach (SegmentInfo overwrite in info.overwrites)
			{
				WriteCopySegment(overwrite, source);
			}
			if (info.backup != null)
			{
				Array.Copy(info.backup, 0, data, segment.Begin, segment.Length);
			}
			else
			{
				Array.Copy(source, segment.OriginalDataBegin, data, segment.Begin, segment.Length);
			}
			info.written = true;
		}

