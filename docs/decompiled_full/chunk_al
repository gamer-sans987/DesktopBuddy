			if (!base.IsInInitPhase && sync && base.GenerateSyncData)
			{
				if (addedElements == null)
				{
					addedElements = Pool.BorrowList<AddRecord>();
				}
				addedElements.Add(new AddRecord(key, element, isNew));
				InvalidateSyncElement();
			}
			if (change)
			{
