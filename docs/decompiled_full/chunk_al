			}
		}

		public bool IsImplicit => Period != 0;

		public abstract uint Period { get; }

		public abstract uint Phase { get; }

		protected virtual bool SequenceAsyncDecodes => true;

		public event Action<IDestroyable> Destroyed;

		internal void Initialize(User user)
		{
			User = user;
			InitializeWorker(user);
			OnInit();
			EndInitializationStageForMembers();
			IsInitialized = true;
		}

		protected override void SyncMemberChanged(IChangeable member)
		{
			if (base.World.State == FrooxEngine.World.WorldState.Running)
			{
				if (member == _group)
				{
					User.StreamGroupManager.AssignToGroup(this, _oldGroup);
					_groupAssigned = true;
					_oldGroup = GroupIndex;
				}
				if (IsInitialized && _groupAssigned)
				{
					User.StreamGroupManager.StreamModified(this);
				}
			}
		}

		public abstract bool IsExplicitUpdatePoint(ulong timePoint);

		public bool IsImplicitUpdatePoint(ulong timePoint)
		{
			if (!IsImplicit)
			{
				return false;
			}
			return (timePoint - Phase) % Period == 0;
		}

		protected void CheckOwnership(bool allowJustAdded = true)
		{
			if (base.World.LocalUser != User && (Active || !User.WasStreamJustAdded(this) || !allowJustAdded))
			{
				throw new Exception("Only User owning the stream can modify it, unless it was just added!");
			}
		}

		public abstract void Encode(BitBinaryWriterX writer);

		public abstract void Decode(BitBinaryReaderX reader, StreamMessage message);

		protected virtual bool InternalAsyncEncode(BitBinaryWriterX writer)
		{
			throw new NotSupportedException();
		}

		protected virtual void InternalAsyncDecode(BitBinaryReaderX reader, StreamMessage message)
		{
			throw new NotSupportedException();
		}

		public virtual void Update()
		{
		}

		protected virtual void OnInit()
		{
		}

		protected void TriggerAsyncEncode()
		{
			if (IsRemoved)
			{
				return;
			}
			bool lockTaken = false;
			try
			{
				_asyncEncodeLock.Enter(ref lockTaken);
				if (!_asyncEncodeScheduled)
				{
					_asyncEncodeScheduled = true;
					if (!_asyncEncodeRunning)
					{
						ScheduleAsyncEncode();
					}
				}
			}
			finally
			{
				if (lockTaken)
				{
					_asyncEncodeLock.Exit();
				}
			}
		}

		public bool AsyncEncode(BitBinaryWriterX writer)
		{
			bool lockTaken = false;
			try
			{
				_asyncEncodeLock.Enter(ref lockTaken);
				_asyncEncodeRunning = true;
				_asyncEncodeScheduled = false;
			}
			finally
			{
				if (lockTaken)
				{
					_asyncEncodeLock.Exit();
				}
			}
			bool result = InternalAsyncEncode(writer);
			lockTaken = false;
			try
			{
				_asyncEncodeLock.Enter(ref lockTaken);
				_asyncEncodeRunning = false;
				if (_asyncEncodeScheduled)
				{
					ScheduleAsyncEncode();
				}
			}
			finally
			{
				if (lockTaken)
				{
					_asyncEncodeLock.Exit();
				}
			}
			return result;
		}

		private ActionBlock<AsyncDecodeMessage> EnsureAsyncProcessor()
		{
			if (_asyncMessageProcessor != null)
			{
				return _asyncMessageProcessor;
			}
			lock (this)
			{
				if (_asyncMessageProcessor == null)
				{
					_asyncMessageProcessor = new ActionBlock<AsyncDecodeMessage>((Action<AsyncDecodeMessage>)ProcessAsyncMessage, new ExecutionDataflowBlockOptions
					{
						EnsureOrdered = true,
						MaxDegreeOfParallelism = 1
					});
				}
				return _asyncMessageProcessor;
			}
		}

		private void ProcessAsyncMessage(AsyncDecodeMessage process)
		{
			try
			{
				InternalAsyncDecode(process.reader, process.message);
				process.reader.BaseStream.Dispose();
				process.message.Dispose();
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception in AsyncDecode. Message: {process.message}.\n" + ex, stackTrace: false);
			}
		}

		public void AsyncDecodeAndDispose(BitBinaryReaderX reader, StreamMessage message)
		{
			AsyncDecodeMessage process = new AsyncDecodeMessage(reader, message);
			if (!SequenceAsyncDecodes)
			{
				ProcessAsyncMessage(process);
			}
			else
			{
				EnsureAsyncProcessor().Post(new AsyncDecodeMessage(reader, message));
			}
		}

		private void ScheduleAsyncEncode()
		{
			World world = base.World;
			if (world != null)
			{
				if (_asyncEncode == null)
				{
					_asyncEncode = RunAsyncEncode;
				}
				world?.RunInBackground(_asyncEncode, WorkType.HighPriority);
			}
		}

		private void RunAsyncEncode()
		{
			base.World.SyncController.AsyncStreamEncode(this);
		}

		public void Destroy()
		{
			User.RemoveStream(this);
		}

		internal void InternalRunDestruction()
		{
			this.Destroyed?.Invoke(this);
			this.Destroyed = null;
		}

		protected override void InitializeSyncMembers()
		{
			_active = new Sync<bool>();
			_group = new Sync<ushort>();
			_name = new Sync<string>();
		}
	}
