		{
			if (!stopwatch.IsRunning)
			{
				stopwatch.Start();
			}
			frames++;
			double totalSeconds = stopwatch.Elapsed.TotalSeconds;
			double num = totalSeconds - lastElapsed;
			lastElapsed = totalSeconds;
			ImmediateFPS = (float)(1.0 / num);
			if (totalSeconds >= 1.0)
			{
				FPS = (float)((double)frames / totalSeconds);
				stopwatch.Restart();
				frames = 0;
				lastElapsed = 0.0;
			}
		}
