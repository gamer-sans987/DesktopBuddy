	public class Digital : ControllerProperty
	{
		public bool Held { get; private set; }

		public bool Pressed { get; private set; }

		public bool Released { get; private set; }

		public bool AnyState
		{
			get
			{
				if (!Pressed && !Held)
				{
					return Released;
				}
				return true;
			}
		}

		public bool PressedOrHeld
		{
			get
			{
				if (!Pressed)
				{
					return Held;
				}
				return true;
			}
		}

		public void UpdateState(bool held)
		{
			Pressed = false;
			Released = false;
			if (!Held && held)
			{
				Pressed = true;
			}
			if (Held && !held)
			{
				Released = true;
			}
			Held = held;
		}

		public override string ToString()
		{
			if (Pressed)
			{
				return "Pressed";
			}
			if (Held)
			{
				return "Held";
			}
			if (Released)
			{
				return "Released";
			}
			return "---";
		}
	}
	public class RepeatDigital : ControllerProperty
	{
		internal float repeatTimer;

		public InputInterface Input { get; private set; }

		public bool Held { get; private set; }

		public bool Pressed { get; private set; }

		public bool Released { get; private set; }

		public bool RepeatPressed { get; private set; }

		public RepeatDigital(InputInterface inputInterface)
		{
			Input = inputInterface;
		}

		public void UpdateState(bool held, float deltaTime)
		{
			Pressed = false;
			Released = false;
			RepeatPressed = false;
			repeatTimer -= deltaTime;
			if (!Held && held)
			{
				Pressed = true;
				RepeatPressed = true;
				repeatTimer = Input.KeyRepeatWait;
			}
			if (Held && !held)
			{
				Released = true;
			}
			if (held && repeatTimer <= 0f)
			{
				RepeatPressed = true;
				repeatTimer += Input.KeyRepeatInterval;
			}
			Held = held;
		}
	}
