	public class FingerSegment : TrackedObject
	{
		public Finger Finger { get; private set; }

		public FingerSegmentType SegmentType { get; private set; }

		public FingerSegment? PreviousSegment => SegmentType switch
		{
			FingerSegmentType.Proximal => Finger[FingerSegmentType.Metacarpal], 
			FingerSegmentType.Intermediate => Finger[FingerSegmentType.Proximal], 
			FingerSegmentType.Distal => Finger[(Finger.FingerType == FingerType.Thumb) ? FingerSegmentType.Proximal : FingerSegmentType.Intermediate], 
			FingerSegmentType.Tip => Finger[FingerSegmentType.Distal], 
			_ => null, 
		};

		public FingerSegment? NextSegment => SegmentType switch
		{
			FingerSegmentType.Metacarpal => Finger[FingerSegmentType.Proximal], 
			FingerSegmentType.Proximal => Finger[(Finger.FingerType == FingerType.Thumb) ? FingerSegmentType.Distal : FingerSegmentType.Intermediate], 
			FingerSegmentType.Intermediate => Finger[FingerSegmentType.Distal], 
			FingerSegmentType.Distal => Finger[FingerSegmentType.Tip], 
			_ => null, 
		};

		public Hand Hand => Finger.Hand;

		public float Width { get; set; }

		public FingerSegment(Finger finger, FingerSegmentType segmentType, int priority)
		{
			base.Priority = priority;
			Finger = finger;
			SegmentType = segmentType;
			Width = 0.01f;
			base.CorrespondingBodyNode = finger.FingerType.ComposeFinger(segmentType, Hand.Chirality);
			InputInterface.InitDeviceFields(this);
			Hand.Input.RegisterInputDevice(this, base.CorrespondingBodyNode.ToString());
		}

		public void ComputeRotationFromPosition()
		{
			FingerSegment previousSegment = PreviousSegment;
			FingerSegment nextSegment = NextSegment;
			Elements.Core.float3 up = Elements.Core.float3.Up;
			if (Finger.FingerType == FingerType.Thumb)
			{
				up = ((Hand.Chirality == Chirality.Left) ? Elements.Core.float3.Right : Elements.Core.float3.Left);
			}
			Elements.Core.float3 to = ((nextSegment == null) ? (base.RawPosition - previousSegment.RawPosition) : (nextSegment.RawPosition - base.RawPosition));
			if (previousSegment != null)
			{
				up = previousSegment.RawRotation * Elements.Core.float3.Up;
				up = Elements.Core.floatQ.FromToRotation(previousSegment.RawRotation * Elements.Core.float3.Forward, in to) * up;
			}
			base.RawRotation = Elements.Core.floatQ.LookRotation(in to, in up);
		}
	}
