		{
			return Evaluate(in context);
		}
	}
	public class AnalogToDigital : ConversionInputNode<float, bool>
	{
		private bool _lastState;

		public float ActivationLevel { get; set; }

		public float DeactivationLevel { get; set; }

		public AnalogToDigital(IInputNode<float> input, float activation = 0.6f, float deactivation = 0.4f)
			: base(input)
		{
			ActivationLevel = activation;
			DeactivationLevel = deactivation;
		}

		protected override bool Convert(float input, in InputEvaluationContext context)
		{
			if (_lastState)
			{
				if (input < DeactivationLevel)
				{
					_lastState = false;
				}
			}
			else if (input >= ActivationLevel)
			{
				_lastState = true;
			}
			return _lastState;
		}
	}
