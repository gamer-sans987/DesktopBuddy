		protected new enum InternalFlags
		{
			IsPreassigned = 16,
			END
		}

		private T _target;

		private ReferenceState _state;

		private bool IsPreassigned
		{
			get
			{
				return _flags.GetFlag(16);
			}
			set
			{
				_flags.SetFlag(16, value);
			}
		}

		public ReferenceState State
		{
			get
			{
				if (_state == ReferenceState.Available && _target.IsRemoved)
				{
					return ReferenceState.Removed;
				}
				return _state;
			}
			set
			{
				_state = value;
			}
		}

		public T RawTarget => _target;

		IWorldElement ISyncRef.RawTarget => RawTarget;

		protected virtual bool CanReferenceLocalElements => base.IsLocalElement;

		public override RefID Value
		{
			[MethodImpl(MethodImplOptions.AggressiveInlining)]
			get
			{
				return base.Value;
			}
			[MethodImpl(MethodImplOptions.AggressiveInlining)]
			set
			{
				if (!(value == Value))
				{
					base.Value = value;
				}
			}
		}

		public virtual T Target
		{
			[MethodImpl(MethodImplOptions.AggressiveInlining)]
			get
			{
				if (_target == null || _target.IsRemoved)
				{
					return null;
				}
				return _target;
			}
			set
			{
				if (base.IsHooked && !base.IsWithinHookCallback && !base.ActiveLink.IsModificationAllowed && !base.IsInInitPhase && !base.IsLoading && base.ActiveLink is RefHook<T> { RefSetHook: not null } refHook)
				{
					try
					{
						BeginHook();
						refHook.RefSetHook(this, value);
						return;
					}
					finally
					{
						EndHook();
					}
				}
				if (value == _target)
				{
					return;
				}
				if (value == null)
				{
					Value = RefID.Null;
					return;
				}
				if (value.World != base.World)
				{
					if (value.IsRemoved)
					{
						throw new ArgumentException($"Target is destroyed!\nReference:\n{this.ParentHierarchyToString()}\nTarget:\n{value?.ParentHierarchyToString()}");
					}
					throw new ArgumentException($"Target belongs to a different world.\nTarget World: {value.World}\nReference World:\n{base.World}\nTarget:\n{value?.ParentHierarchyToString()}");
				}
				if (value.IsLocalElement && !CanReferenceLocalElements)
				{
					throw new ArgumentException("Cannot reference local targets from non-local reference.\nTarget: " + value.ParentHierarchyToString() + "\nReference: " + this.ParentHierarchyToString());
				}
				T target = _target;
				_target = value;
				IsPreassigned = true;
				if (!InternalSetRefID(value.ReferenceID, target))
				{
					_target = target;
				}
				IsPreassigned = false;
			}
		}

		public bool IsTargetRemoved
		{
			get
			{
				if (_target != null)
				{
					return _target.IsRemoved;
				}
				return false;
			}
		}

		public Type TargetType => typeof(T);

		IWorldElement ISyncRef.Target
		{
			get
			{
				return Target;
			}
			set
			{
				if (value == null)
				{
					Target = null;
				}
				else if (!TrySet(value))
				{
					throw new Exception("Target is of type " + (value?.GetType())?.ToString() + ", expected: " + typeof(T)?.ToString() + "\nOn:" + this.ParentHierarchyToString());
				}
			}
		}

		public event ReferenceEvent<T> OnReferenceChange;

		public event ReferenceEvent<T> OnObjectAvailable;

		public event ReferenceEvent<T> OnTargetChange;

		public static implicit operator T(SyncRef<T> reference)
		{
			return reference.Target;
		}

		public void Clear()
		{
			Target = null;
		}

		public bool TrySet(IWorldElement target)
		{
			if (!(target is T target2))
			{
				return false;
			}
			Target = target2;
			return true;
		}

		protected virtual bool InternalSetRefID(in RefID id, T prevTarget)
		{
			return InternalSetValue(in id);
		}

		protected virtual void RunReferenceChanged()
		{
			if (this.OnReferenceChange != null)
			{
				this.OnReferenceChange(this);
			}
		}

		protected virtual void RunObjectAvailable()
		{
			this.OnObjectAvailable?.Invoke(this);
			RunTargetChanged();
		}

		protected virtual void RunTargetInvalid()
		{
		}

		private void RunTargetChanged()
		{
			this.OnTargetChange?.Invoke(this);
		}

		protected override void ValueChanged()
		{
			T target = _target;
			_target = null;
			RunReferenceChanged();
			if (Value == RefID.Null)
			{
				State = ReferenceState.Null;
				RunTargetChanged();
			}
			else
			{
				State = ReferenceState.Waiting;
				if (IsPreassigned)
				{
					SetTarget(target);
				}
				else
				{
					base.World.ReferenceController.RequestObject(Value, this);
				}
			}
			base.ValueChanged();
		}

		void IWorldElementReceiver.OnWorldElementAvailable(IWorldElement element)
		{
			if (Target == null && element.ReferenceID == Value)
			{
				SetTarget(element);
			}
		}

		private void SetTarget(IWorldElement element)
		{
			_target = element as T;
			if (_target == null)
			{
				State = ReferenceState.Invalid;
				RunTargetInvalid();
			}
			else if (!_target.IsRemoved)
			{
				State = ReferenceState.Available;
				RunObjectAvailable();
			}
			else
			{
				State = ReferenceState.Removed;
				RunTargetChanged();
			}
		}

		protected void InvalidateTarget()
		{
			_target = null;
			State = ReferenceState.Invalid;
		}

		protected override void InternalEncodeFull(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			writer.Write7BitEncoded((ulong)Value);
		}

		protected override void InternalDecodeFull(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			InternalSetValue((RefID)reader.Read7BitEncoded(), sync: false);
		}

		protected override void InternalEncodeDelta(BinaryWriter writer, BinaryMessageBatch outboundMessage)
		{
			writer.Write7BitEncoded((ulong)Value);
		}

		protected override void InternalDecodeDelta(BinaryReader reader, BinaryMessageBatch inboundMessage)
		{
			InternalSetValue((RefID)reader.Read7BitEncoded(), sync: false);
		}

		protected override DataTreeNode InternalSave(SaveControl control)
		{
			return control.SaveReference(Value);
		}

		protected override void InternalLoad(DataTreeNode node, LoadControl control)
		{
			control.RequestReference(node, this);
		}

		public override void Dispose()
		{
			_target = null;
			this.OnReferenceChange = null;
			this.OnObjectAvailable = null;
			this.OnTargetChange = null;
			base.Dispose();
		}
	}
