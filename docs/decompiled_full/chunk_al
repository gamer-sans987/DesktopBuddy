		private ScreenLocomotionDirection GenerateScreenDirection(float? overrideFast = null, float? overrideSlow = null, LocomotionReference? overrideReference = null)
		{
			ScreenLocomotionDirection screenLocomotionDirection = new ScreenLocomotionDirection();
			screenLocomotionDirection.Forward = InputNode.Key(Key.W);
			screenLocomotionDirection.Backward = InputNode.Key(Key.S);
			screenLocomotionDirection.Left = InputNode.Key(Key.A);
			screenLocomotionDirection.Right = InputNode.Key(Key.D);
			screenLocomotionDirection.Up = InputNode.Key(Key.Space);
			screenLocomotionDirection.Down = InputNode.Key(Key.C);
			screenLocomotionDirection.Fast = InputNode.Any(InputNode.MultiTap(new KeyboardInputSource[4]
			{
				InputNode.Key(Key.W),
				InputNode.Key(Key.A),
				InputNode.Key(Key.S),
				InputNode.Key(Key.D)
			}), InputNode.Key(Key.Shift));
			screenLocomotionDirection.Slow = InputNode.Key(Key.Z).Toggle();
			if (overrideFast.HasValue)
			{
				screenLocomotionDirection.FastMultiplier = overrideFast.Value;
			}
			if (overrideSlow.HasValue)
			{
				screenLocomotionDirection.SlowMultiplier = overrideSlow.Value;
			}
			if (overrideReference.HasValue)
			{
				screenLocomotionDirection.OverrideReference = overrideReference.Value;
			}
			return screenLocomotionDirection;
