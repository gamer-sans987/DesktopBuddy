		public void GetGlobalBlockers(Dictionary<Type, IList> target)
		{
			foreach (KeyValuePair<Type, IList> globalBlocker in _globalBlockers)
			{
				if (!target.TryGetValue(globalBlocker.Key, out IList value))
				{
					value = (IList)Activator.CreateInstance(globalBlocker.Value.GetType());
					target.Add(globalBlocker.Key, value);
				}
				foreach (object item in globalBlocker.Value)
				{
					value.Add(item);
				}
			}
		}

		public bool IsBlocked<T>(Predicate<T> check)
		{
			if (_globalBlockers.TryGetValue(typeof(T), out IList value))
			{
				foreach (T item in (List<T>)value)
				{
					if (check(item))
					{
						return true;
					}
				}
			}
			return false;
		}

		private void ClearBlockers()
		{
			_globallyBlockedProperties.Clear();
			foreach (KeyValuePair<Type, IList> globalBlocker in _globalBlockers)
			{
				globalBlocker.Value.Clear();
			}
		}

		internal static void InitDeviceFields(IInputDevice device)
		{
			foreach (FieldInfo item in device.GetType().EnumerateAllInstanceFields())
			{
				if (item.IsInitOnly && item.GetValue(device) == null)
				{
					QuantizationDefaultsAttribute customAttribute = item.GetCustomAttribute<QuantizationDefaultsAttribute>();
					object obj = Activator.CreateInstance(item.FieldType);
					item.SetValue(device, obj);
					if (obj is ControllerProperty controllerProperty)
					{
						controllerProperty.Initialize(device, device.PropertyCount, item.Name, customAttribute);
						device.RegisterProperty(controllerProperty);
					}
				}
			}
		}

		public static string LogDeviceFields(IInputDevice device)
		{
			StringBuilder stringBuilder = new StringBuilder();
			Type type = device.GetType();
			stringBuilder.AppendLine("Device Type: " + type);
			foreach (FieldInfo item in type.EnumerateAllInstanceFields())
			{
				if (item.IsInitOnly)
				{
					object value = item.GetValue(device);
					if (value != null)
					{
						stringBuilder.AppendLine(item.Name + ":\t" + value.ToString());
					}
				}
			}
			return stringBuilder.ToString();
		}

