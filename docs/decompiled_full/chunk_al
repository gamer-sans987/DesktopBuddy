	public class InputBindingManager : IDisposable
	{
		private static readonly Action<IInputUpdateReceiver> _beforeInputUpdate = delegate(IInputUpdateReceiver i)
		{
			i.BeforeInputUpdate();
		};

		private static readonly Action<IInputUpdateReceiver> _afterInputUpdate = delegate(IInputUpdateReceiver i)
		{
			i.AfterInputUpdate();
		};

		private List<IInputUpdateReceiver> _receivers = new List<IInputUpdateReceiver>();

		private List<InputGroup> _inputGroups = new List<InputGroup>();

		private bool _runningUpdate;

		private List<IInputUpdateReceiver> _receiversToAdd;

		private List<IInputUpdateReceiver> _receiversToRemove;

		private List<InputGroup> _inputGroupsToAdd;

		private List<InputGroup> _inputGroupsToRemove;

		private HashSet<IWorldElement> _cursorUnlockers = new HashSet<IWorldElement>();

		private Dictionary<IWorldElement, CursorLock> _cursorLockers = new Dictionary<IWorldElement, CursorLock>();

		private bool _rebuildBindings;

		private DebugSettings _debugSettings;

		public Engine Engine => World?.Engine;

		public World World { get; private set; }

		public InputBlockManager BlockManager { get; private set; }

		public Chirality PrimaryHand => Engine.InputInterface.PrimaryHand;

		public bool UnlockCursor
		{
			get
			{
				if (_cursorUnlockers.Count > 0)
				{
					return _cursorLockers.Count == 0;
				}
				return false;
			}
		}

		public CursorLock LockCursor
		{
			get
			{
				if (_cursorLockers.Count == 0)
				{
					return null;
				}
				CursorLock cursorLock = null;
				foreach (KeyValuePair<IWorldElement, CursorLock> cursorLocker in _cursorLockers)
				{
					if (cursorLock == null || cursorLock.priority < cursorLocker.Value.priority)
					{
						cursorLock = cursorLocker.Value;
					}
				}
				return cursorLock;
			}
		}

		public InputBindingManager(World world)
		{
			World = world;
			BlockManager = new InputBlockManager(world);
			world.InputInterface.BindingGeneratorAdded += InputInterface_BindingGeneratorAdded;
			world.InputInterface.ControllerRegistered += InputInterface_ControllerRegistered;
			Settings.RegisterComponentChanges<DebugSettings>(OnDebugSettingsChanged);
		}

		private void InputInterface_ControllerRegistered(IStandardController obj)
		{
			InvalidateBindings();
		}

		private void OnDebugSettingsChanged(DebugSettings settings)
		{
			_debugSettings = settings;
		}

		private void InputInterface_BindingGeneratorAdded(IBindingGenerator obj)
		{
			InvalidateBindings();
		}

		public void InvalidateBindings()
		{
			_rebuildBindings = true;
		}

		public void RegisterInputGroup(InputGroup group, IWorldElement owner, Action onUpdate = null, Action onEvaluate = null)
		{
			group.RegisterManager(this, owner, onUpdate, onEvaluate);
			Engine.InputInterface.Bind(group);
			if (_runningUpdate)
			{
				Pool.BorrowIfNull(ref _inputGroupsToAdd);
				_inputGroupsToAdd.Add(group);
			}
			else
			{
				_inputGroups.Add(group);
			}
		}

		public void UnregisterInputGroup<G>(ref G group) where G : InputGroup
		{
			if (_runningUpdate)
			{
				Pool.BorrowIfNull(ref _inputGroupsToRemove);
				_inputGroupsToRemove.Add(group);
			}
			else
			{
				_inputGroups.Remove(group);
			}
			group = null;
		}

		public void RegisterInputEventReceiver(IInputUpdateReceiver receiver)
		{
			if (receiver == null)
			{
				throw new ArgumentNullException("receiver");
			}
			if (_runningUpdate)
			{
				Pool.BorrowIfNull(ref _receiversToAdd);
				_receiversToAdd.Add(receiver);
			}
			else
			{
				_receivers.Add(receiver);
			}
		}

		public void UnregisterInputEventReceiver(IInputUpdateReceiver receiver)
		{
			if (_runningUpdate)
			{
				Pool.BorrowIfNull(ref _receiversToRemove);
				_receiversToRemove.Add(receiver);
			}
			else
			{
				_receivers.Remove(receiver);
			}
		}

		public void RegisterCursorUnlock(IWorldElement element)
		{
			if (!_cursorUnlockers.Add(element))
			{
				throw new Exception("Trying to register cursor unlock twice! Element:\n" + element.ParentHierarchyToString());
			}
		}

		public CursorLock RegisterCursorLock(IWorldElement element, Elements.Core.int2 position, int priority = 0)
		{
			if (_cursorLockers.ContainsKey(element))
			{
				throw new Exception("Trying to register cursor lock twice! Element:\n" + element.ParentHierarchyToString());
			}
			CursorLock cursorLock = new CursorLock();
			cursorLock.position = position;
			_cursorLockers.Add(element, cursorLock);
			return cursorLock;
		}

		public void UnregisterCursorUnlock(IWorldElement element)
		{
			_cursorUnlockers.Remove(element);
		}

		public void UnregisterCursorLock(IWorldElement element)
		{
			_cursorLockers.Remove(element);
		}

		public void Update()
		{
			_runningUpdate = true;
			_cursorUnlockers.RemoveWhere((IWorldElement e) => e.IsRemoved);
			if (_cursorLockers.Count > 0)
			{
				List<IWorldElement> list = Pool.BorrowList<IWorldElement>();
				foreach (KeyValuePair<IWorldElement, CursorLock> cursorLocker in _cursorLockers)
				{
					if (cursorLocker.Key.IsRemoved)
					{
						list.Add(cursorLocker.Key);
					}
				}
				foreach (IWorldElement item in list)
				{
					_cursorLockers.Remove(item);
				}
				Pool.Return(ref list);
			}
			BlockManager.Clear();
			BlockManager.LoadGlobalBlocks();
			HashSet<InputGroup> hashSet = Pool.BorrowHashSet<InputGroup>();
			foreach (InputGroup inputGroup in _inputGroups)
			{
				if (inputGroup.Owner.IsRemoved)
				{
					hashSet.Add(inputGroup);
				}
			}
			foreach (InputGroup item2 in hashSet)
			{
				InputGroup group = item2;
				UnregisterInputGroup(ref group);
			}
			Pool.Return(ref hashSet);
			HashSet<IInputUpdateReceiver> hashSet2 = Pool.BorrowHashSet<IInputUpdateReceiver>();
			_receivers.RemoveAll((IInputUpdateReceiver r) => r.IsRemoved);
			_receivers.Sort((IInputUpdateReceiver a, IInputUpdateReceiver b) => a.UpdateOrder.CompareTo(b.UpdateOrder));
			SendInputUpdateEvents(_beforeInputUpdate, hashSet2);
			if (_rebuildBindings)
			{
				_rebuildBindings = false;
				foreach (InputGroup inputGroup2 in _inputGroups)
				{
					inputGroup2.ClearBindings();
					Engine.InputInterface.Bind(inputGroup2);
				}
			}
			_inputGroups.Sort(CompareInputGroups);
			int? num = null;
			foreach (InputGroup inputGroup3 in _inputGroups)
			{
				if (num.HasValue && inputGroup3.Priority != num)
				{
					BlockManager.SubmitStagedBlocks();
				}
				num = inputGroup3.Priority;
				if (inputGroup3.Active)
				{
					inputGroup3.Update(World.Time.Delta);
					inputGroup3.LastEvaluated = true;
					if (inputGroup3.SubmitBlocksToGlobal)
					{
						BlockManager.SubmitRegisteredBlocksGlobally();
						inputGroup3.SubmitBlocksToGlobal = false;
					}
					switch (inputGroup3.BlockMode)
					{
					case InputBlockMode.NoBlock:
						BlockManager.ClearRegisteredBlocks();
						break;
					case InputBlockMode.OneTimeBlock:
						BlockManager.StageRegisteredBlocks();
						inputGroup3.BlockMode = InputBlockMode.NoBlock;
						break;
					case InputBlockMode.AlwaysBlock:
						BlockManager.StageRegisteredBlocks();
						break;
					}
				}
				else if (inputGroup3.LastEvaluated)
				{
					inputGroup3.Update(World.Time.Delta);
					inputGroup3.LastEvaluated = false;
				}
			}
			BlockManager.SubmitStagedBlocks();
			SendInputUpdateEvents(_afterInputUpdate, hashSet2);
			Pool.Return(ref hashSet2);
			_runningUpdate = false;
			if (_receiversToAdd != null)
			{
				foreach (IInputUpdateReceiver item3 in _receiversToAdd)
				{
					_receivers.Add(item3);
				}
				Pool.Return(ref _receiversToAdd);
			}
			if (_receiversToRemove != null)
			{
				foreach (IInputUpdateReceiver item4 in _receiversToRemove)
				{
					_receivers.Remove(item4);
				}
				Pool.Return(ref _receiversToRemove);
			}
			if (_inputGroupsToAdd != null)
			{
				foreach (InputGroup item5 in _inputGroupsToAdd)
				{
					_inputGroups.Add(item5);
				}
				Pool.Return(ref _inputGroupsToAdd);
			}
			if (_inputGroupsToRemove != null)
			{
				foreach (InputGroup item6 in _inputGroupsToRemove)
				{
					_inputGroups.Remove(item6);
				}
				Pool.Return(ref _inputGroupsToRemove);
			}
			if (!World.IsUserspace())
			{
				Sync<bool> sync = _debugSettings?.DebugInputBindings;
				if (sync != null && (bool)sync)
				{
					World.Debug.Text(DebugText(), 0.1f);
				}
			}
		}

		private void SendInputUpdateEvents(Action<IInputUpdateReceiver> action, HashSet<IInputUpdateReceiver> sentEvents)
		{
			sentEvents.Clear();
			int num = 0;
			int num2 = 0;
			while (num < _receivers.Count || num2 < _inputGroups.Count)
			{
				if (num >= _receivers.Count || (num2 < _inputGroups.Count && _receivers[num].UpdateOrder > _inputGroups[num2].Priority))
				{
					if (_inputGroups[num2].Owner is IInputUpdateReceiver inputUpdateReceiver && sentEvents.Add(inputUpdateReceiver))
					{
						IUpdatable updatable = inputUpdateReceiver;
						if (updatable != null)
						{
							World.UpdateManager.NestCurrentlyUpdating(updatable);
						}
						try
						{
							action(inputUpdateReceiver);
						}
						catch (Exception value)
						{
							UniLog.Error($"Exception running BeforeInputUpdate on:\n{inputUpdateReceiver}\n{value}", stackTrace: false);
						}
						finally
						{
							if (updatable != null)
							{
								World.UpdateManager.PopCurrentlyUpdating(updatable);
							}
						}
					}
					num2++;
					continue;
				}
				IInputUpdateReceiver inputUpdateReceiver2 = _receivers[num];
				IComponentBase componentBase = inputUpdateReceiver2;
				if (componentBase == null || componentBase.Enabled)
				{
					IUpdatable updatable2 = inputUpdateReceiver2;
					if (updatable2 != null)
					{
						World.UpdateManager.NestCurrentlyUpdating(updatable2);
					}
					try
					{
						sentEvents.Add(inputUpdateReceiver2);
						action(inputUpdateReceiver2);
					}
					catch (Exception value2)
					{
						UniLog.Error($"Exception running Input Update Event on:\n{inputUpdateReceiver2}\n{value2}", stackTrace: false);
					}
					finally
					{
						if (updatable2 != null)
						{
							World.UpdateManager.PopCurrentlyUpdating(updatable2);
						}
					}
				}
				num++;
			}
		}

