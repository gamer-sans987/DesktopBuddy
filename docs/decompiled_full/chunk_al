					SetPoint(0f);
					return;
				}
				trailingTime += base.World.Time.Delta;
				leadingTime += base.World.Time.Delta;
				double val = timePoints[timePoints.Count - 1];
				trailingTime = MathX.Min(trailingTime, val);
				leadingTime = MathX.Min(leadingTime, val);
				timeTransition = MathX.Progress01(timeTransition, base.World.Time.Delta / (float)InterpolationOffset);
				double currentTime = CurrentTime;
				int num = -1;
				for (int num2 = timePoints.Count - 1; num2 >= 0; num2--)
				{
					if (currentTime >= timePoints[num2])
					{
						num = num2;
						break;
					}
				}
				if (num > 0)
				{
					int num3 = MathX.Min(num, timePoints.Count - 2);
					if (num3 > 0)
					{
						timePoints.RemoveRange(0, num3);
						RemoveFrames(num3);
					}
				}
				float point = (float)MathX.InverseLerp(timePoints[0], timePoints[1], currentTime);
				SetPoint(point);
			}
			catch (Exception value2)
			{
				UniLog.Error($"Exception updating Value Stream {this}\nTimePoints: {timePoints?.Count}, Initial: {value}, Frames: {FrameCount}, Initial: {frameCount}\n{value2}");
