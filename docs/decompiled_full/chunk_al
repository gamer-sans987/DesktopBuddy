		public override float CurrentValue => Value.Value;

		public AnalogAction(string name)
			: base(name)
		{
		}

		public void AddBinding(Analog analog)
		{
			AddBinding(InputNode.Analog(analog), analog.Device);
		}

		public override void BeginEvaluation()
		{
			base.BeginEvaluation();
			_maxMagnitude = 0f;
		}

		public override void Evaluate(InputGroup group, int priority, float deltaTime)
		{
			if (!group.Active || !Active)
			{
				return;
			}
			if (ExternalInput.HasValue)
			{
				_hasValue = true;
				_intermediateResult += ExternalInput.Value;
				_maxMagnitude = MathX.Max(_maxMagnitude, MathX.Abs(ExternalInput.Value));
				ExternalInput = null;
			}
			foreach (InputBinding<float> binding in _bindings)
			{
				if (binding.Priority != priority)
				{
					continue;
				}
				IInputDevice implicitDevice = binding.ImplicitDevice;
				if (implicitDevice == null || implicitDevice.IsDeviceActive)
				{
					float? num = binding.Node.Evaluate(new InputEvaluationContext(group, binding, this));
					if (num.HasValue)
					{
						_hasValue = true;
						_intermediateResult += num.Value;
						_maxMagnitude = MathX.Max(_maxMagnitude, MathX.Abs(num.Value));
					}
				}
			}
		}

		public override void FinishEvaluation(float deltaTime)
		{
			float num = MathX.Abs(_intermediateResult);
			if (num > _maxMagnitude)
			{
				_intermediateResult *= _maxMagnitude / num;
			}
			Value.UpdateValue(_intermediateResult, deltaTime);
		}

		public static implicit operator float(AnalogAction action)
		{
			return action.CurrentValue;
		}

		public override string ToString()
		{
			return $"{base.Name}: {Value.Value:F2}";
		}
