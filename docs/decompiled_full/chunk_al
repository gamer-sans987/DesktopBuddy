	public abstract class VR_LocomotionTurnBase<T> : IInputNode<T>, IInputNode where T : struct
	{
		public float SnapTurnActivation { get; set; } = 0.8f;

		public float SnapTurnDeactivation { get; set; } = 0.5f;

		protected abstract bool ThreeAxis { get; }

		protected abstract void Evaluate(in InputEvaluationContext context, out Elements.Core.float2? primary, out Elements.Core.float2? secondary, out Chirality primarySide);

		public T? Evaluate(in InputEvaluationContext context)
		{
			Evaluate(in context, out var primary, out var secondary, out var primarySide);
			if (!primary.HasValue && !secondary.HasValue)
			{
				ResetState();
				return null;
			}
			MovementSettings activeSetting = Settings.GetActiveSetting<MovementSettings>();
			if (activeSetting == null)
			{
				return null;
			}
			bool value = activeSetting.SmoothTurnExclusiveMode.Value;
			SidewaysMovementMode sidewaysMovementMode;
			SidewaysMovementMode sidewaysMovementMode2;
			if (primarySide == Chirality.Left)
			{
				sidewaysMovementMode = activeSetting.LeftSidewaysMode;
				sidewaysMovementMode2 = activeSetting.RightSidewaysMode;
			}
			else
			{
				sidewaysMovementMode = activeSetting.RightSidewaysMode;
				sidewaysMovementMode2 = activeSetting.LeftSidewaysMode;
			}
			if (!secondary.HasValue && (sidewaysMovementMode2.HasTurning() || sidewaysMovementMode == SidewaysMovementMode.TurnOnly))
			{
				sidewaysMovementMode = SidewaysMovementMode.TurnAndMove;
			}
			Sync<float> movementExponent = activeSetting.MovementExponent;
			Sync<float> movementDeadzone = activeSetting.MovementDeadzone;
			Sync<float> turningDeadzone = activeSetting.TurningDeadzone;
			Elements.Core.float2 axis = LocomotionInputHelper.FilterLocomotionAxis(in primary, value) ?? Elements.Core.float2.Zero;
			Elements.Core.float2 axis2 = LocomotionInputHelper.FilterLocomotionAxis(in secondary, value) ?? Elements.Core.float2.Zero;
			axis = MathX.ElementWiseDeadzone(axis, new Elements.Core.float2(turningDeadzone, movementDeadzone));
			axis2 = MathX.ElementWiseDeadzone(axis2, new Elements.Core.float2(turningDeadzone, movementDeadzone));
			axis = MathX.PowMagnitude(axis, movementExponent);
			axis2 = MathX.PowMagnitude(axis2, movementExponent);
			if (activeSetting.UseSmoothTurn.Value)
			{
				return ComputeSmoothTurn(axis, axis2, sidewaysMovementMode, sidewaysMovementMode2, (float)activeSetting.SmoothTurnSpeed * context.group.DeltaTime);
			}
			return ComputeSnapTurn(axis, axis2, sidewaysMovementMode, sidewaysMovementMode2, activeSetting.SnapTurnAngle);
		}

		public virtual void ResetNode()
		{
			ResetState();
		}

		protected abstract void ResetState();

		protected abstract T ComputeSmoothTurn(Elements.Core.float2 primary, Elements.Core.float2 secondary, SidewaysMovementMode primaryMode, SidewaysMovementMode secondaryMode, float speed);

		protected abstract T ComputeSnapTurn(Elements.Core.float2 primary, Elements.Core.float2 secondary, SidewaysMovementMode primaryMode, SidewaysMovementMode secondaryMode, float angle);

		protected float SnapTurn(float axis, ref bool activated)
		{
			if (activated)
			{
				if (MathX.Abs(axis) < SnapTurnDeactivation)
				{
					activated = false;
				}
			}
			else if (MathX.Abs(axis) >= SnapTurnActivation)
			{
				activated = true;
				return MathX.Sign(axis);
			}
			return 0f;
		}

		T? IInputNode<T>.Evaluate(in InputEvaluationContext context)
		{
			return Evaluate(in context);
		}
	}
