		public static async Task InitializeFrooxEngine(Engine engine, LaunchOptions options)
		{
			if (FrooxEngineInitialized)
			{
				throw new Exception("FrooxEngine is already initialized!");
			}
			if (engine.VerboseInit)
			{
				UniLog.Log("\tInitializing Libraries");
			}
			LibraryInitializer.Initialize(engine);
			if (engine.VerboseInit)
			{
				UniLog.Log("\tGathering all types");
			}
			string text = Directory.EnumerateFiles(".", "ProtoFluxBindings.dll", SearchOption.AllDirectories).FirstOrDefault();
			if (text != null)
			{
				Assembly.LoadFrom(text);
			}
			text = Directory.EnumerateFiles(".", "ProtoFlux.Nodes.FrooxEngine.dll", SearchOption.AllDirectories).FirstOrDefault();
			if (text != null)
			{
				Assembly.LoadFrom(text);
			}
			GlobalTypeRegistry.Initialize(engine.AssemblyMetadataRoot, options.FastCompatibility);
			ConcurrentBag<Type> typesCollection = new ConcurrentBag<Type>();
			UniLog.Log("Scanning assemblies");
			ActionBlock<Assembly> actionBlock = new ActionBlock<Assembly>(delegate(Assembly assembly)
			{
				DataModelAssemblyAttribute customAttribute = assembly.GetCustomAttribute<DataModelAssemblyAttribute>();
				if (engine.VerboseInit)
				{
					UniLog.Log("Assembly: " + assembly?.ToString() + "\t" + customAttribute);
				}
				if (customAttribute == null)
				{
					return;
				}
				try
				{
					Type[] types = assembly.GetTypes();
					AssemblyTypeRegistry assemblyTypeRegistry = GlobalTypeRegistry.RegisterAssembly(assembly, customAttribute.AssemblyType, types);
					UniLog.Log($"Data Model Assembly: {assemblyTypeRegistry.AssemblyName}, Type Count: {assemblyTypeRegistry.TypeCount} (total: {assemblyTypeRegistry.TotalTypeCount}, Compatibility Hash: {assemblyTypeRegistry.CompatibilityHash}, Type: {assemblyTypeRegistry.AssemblyType})");
					Type[] array = types;
					foreach (Type item2 in array)
					{
						typesCollection.Add(item2);
					}
				}
				catch (ReflectionTypeLoadException ex)
				{
					UniLog.Error($"Exception getting types from assembly {assembly}.\n{ex}\nLoader Exceptions: {string.Join("\n----\n", ex.LoaderExceptions.Select((Exception e) => e.ToString()))}");
				}
				catch (Exception ex2)
				{
					UniLog.Error($"Exception getting types from assembly {assembly}:\n" + ex2);
					throw;
				}
			}, new ExecutionDataflowBlockOptions
			{
				MaxDegreeOfParallelism = engine.ProcessorCount,
				EnsureOrdered = false
			});
			Assembly[] assemblies = AppDomain.CurrentDomain.GetAssemblies();
			foreach (Assembly item in assemblies)
			{
				actionBlock.Post(item);
			}
			actionBlock.Complete();
			await actionBlock.Completion.ConfigureAwait(continueOnCapturedContext: false);
			GlobalTypeRegistry.FinalizeTypes();
			foreach (AssemblyTypeRegistry dependencyAssembly in GlobalTypeRegistry.DependencyAssemblies)
			{
				UniLog.Log($"Dependency Assembly: {dependencyAssembly.AssemblyName}, TypeCount: {dependencyAssembly.TypeCount}, (total: {dependencyAssembly.TotalTypeCount}, Compatibility Hash: {dependencyAssembly.CompatibilityHash}");
			}
			if (options.ValidateTypes)
			{
				UniLog.Log("Validating all types");
				HashSet<Type> hashSet = new HashSet<Type>();
				GlobalTypeRegistry.ValidateAllTypes(hashSet, engine.InitProgress);
				UniLog.Log($"All types validated. Invalid type count: {hashSet.Count}.\n" + string.Join("\n", hashSet.Select((Type t) => t.GetNiceFullName())));
			}
			List<Type> allTypes = typesCollection.ToList();
			Task task = Task.Run(delegate
			{
				if (engine.VerboseInit)
				{
					UniLog.Log("\tInitializing connector fields for core classes");
				}
				InitializeConnectorFields(allTypes, typeof(PlatformInterface), typeof(IPlatformConnector), connectorMandatory: false);
			});
			Task task2 = Task.Run(delegate
			{
				if (engine.VerboseInit)
				{
					UniLog.Log("\tInitializing workers");
				}
				WorkerInitializer.Initialize(allTypes, engine.VerboseInit);
			});
			await Task.WhenAll(task, task2);
		}

		private static void InitializeConnectorFields(List<Type> allTypes, Type type, bool connectorMandatory, Type defaultConnector = null, bool verbose = false)
		{
			MethodInfo? method = type.GetMethod("InstantiateConnector", BindingFlags.Static | BindingFlags.NonPublic);
			if (method == null)
			{
				throw new Exception($"Implementable Class {type} doesn't have InstantiateConnector() method");
			}
			Type returnType = method.ReturnType;
			InitializeConnectorFields(allTypes, type, returnType, connectorMandatory, defaultConnector, verbose);
		}

		private static void InitializeConnectorFields(List<Type> allTypes, Type type, Type connectorType, bool connectorMandatory, Type defaultConnector = null, bool verbose = false)
		{
			Type[] array = allTypes.Where((Type t) => connectorType.IsAssignableFrom(t) && t.IsClass && t != defaultConnector).ToArray();
			FieldInfo field = type.GetField("__connectorType", BindingFlags.Static | BindingFlags.NonPublic | BindingFlags.FlattenHierarchy);
			FieldInfo field2 = type.GetField("__connectorTypes", BindingFlags.Static | BindingFlags.NonPublic | BindingFlags.FlattenHierarchy);
			if (field != null)
			{
				if (array.Length > 1)
				{
					string text = "";
					Type[] array2 = array;
					for (int num = 0; num < array2.Length; num++)
					{
						text = text + array2[num]?.ToString() + "\n";
					}
					throw new Exception("Multiple connector candidates for " + type?.ToString() + "\nFound candiates:\n" + text);
				}
				if (array.Length == 0)
				{
					if (defaultConnector != null)
					{
						field.SetValue(null, defaultConnector);
						return;
					}
					if (connectorMandatory)
					{
						throw new Exception("No connector candidates for " + type);
					}
					if (verbose)
					{
						UniLog.Warning("No connectors for: " + type);
					}
				}
				else
				{
					field.SetValue(null, array[0]);
				}
			}
			else
			{
				if (!(field2 != null))
				{
					throw new Exception($"Class {type} doesn't have appropriate fields for storing connector types");
				}
				field2.SetValue(null, array);
			}
		}
	}
