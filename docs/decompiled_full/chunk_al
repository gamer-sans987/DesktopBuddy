		public void RegisterGlobalBlock<T>(T blocker)
		{
			List<T> list;
			if (!_globalBlockers.TryGetValue(typeof(T), out IList value))
			{
				list = new List<T>();
				_globalBlockers.Add(typeof(T), list);
			}
			else
			{
				list = (List<T>)value;
			}
