	public class ReferenceStream<T> : ImplicitStream where T : class, IWorldElement
	{
		private RefID _targetRefID;

		private T _target;

		private bool _receivedFirstData;

		private bool _updateTarget;

		public T Target
		{
			get
			{
				return _target;
			}
			set
			{
				CheckOwnership();
				_target = value;
				_targetRefID = value?.ReferenceID ?? RefID.Null;
			}
		}

		public override bool HasValidData
		{
			get
			{
				if (!_receivedFirstData)
				{
					return base.IsOwnedByLocalUser;
				}
				return true;
			}
		}

		public override void Update()
		{
			base.Update();
			if (base.IsOwnedByLocalUser || !_updateTarget)
			{
				return;
			}
			if (_targetRefID == RefID.Null)
			{
				_target = null;
				return;
			}
			_target = base.World.ReferenceController.GetObjectOrNull(in _targetRefID) as T;
			if (_target != null)
			{
				_updateTarget = false;
			}
		}

		public override void Decode(BitBinaryReaderX reader, StreamMessage message)
		{
			_receivedFirstData = true;
			if (reader.ReadBit())
			{
				RefID refID = reader.ReadRefID();
				if (refID != _targetRefID)
				{
					_targetRefID = refID;
					_updateTarget = true;
				}
			}
			else
			{
				_targetRefID = RefID.Null;
				_updateTarget = true;
			}
		}

		public override void Encode(BitBinaryWriterX writer)
		{
			if (_targetRefID == RefID.Null)
			{
				writer.WriteBit(bit: false);
				return;
			}
			writer.WriteBit(bit: true);
			writer.Write(_targetRefID);
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => _active, 
				1 => _group, 
				2 => _name, 
				3 => _period, 
				4 => _phase, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static ReferenceStream<T> __New()
		{
			return new ReferenceStream<T>();
		}
	}
