			try
			{
				if (elements.TryGetValue(key, out var value))
				{
					elements.Remove(key);
					if (sync && base.GenerateSyncData)
					{
						if (removedElements == null)
						{
							removedElements = Pool.BorrowList<K>();
						}
						removedElements.Add(key);
						InvalidateSyncElement();
					}
					if (change)
					{
						SyncElementChanged();
						ElementRemoved(key, value);
					}
					return true;
				}
				return false;
			}
			finally
			{
