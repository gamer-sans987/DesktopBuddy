		private void UpdateEyes(float deltaTime)
		{
			if (!IsTracking(lastMessageTime) || !ReceivedFullEyeData)
			{
				eyes.IsEyeTrackingActive = ReceivedFullEyeData;
				eyes.IsTracking = false;
				return;
			}
			eyes.IsTracking = true;
			eyes.IsEyeTrackingActive = true;
			UpdateEye(eyes.LeftEye, leftEyeX, leftEyeY, leftEyeLid);
			UpdateEye(eyes.RightEye, rightEyeX, rightEyeY, rightEyeLid);
			static void UpdateEye(Eye eye, float x, float y, float lid)
			{
				float z = MathX.Sqrt(1f - (x * x + y * y));
				eye.UpdateWithDirection(new Elements.Core.float3(x, y, z).Normalized);
				eye.Openness = lid;
			}
		}

		private void UpdateMouth(float deltaTime)
		{
			if (!IsTracking(lastMessageTime))
			{
				mouth.IsTracking = false;
