	public class UserRef : SyncObject, ISyncRef<User>, ISyncRef, ISyncMember, IChangeable, IWorldElement, ILinkable, IInitializable
	{
		public readonly SyncRef<User> User;

		protected readonly Sync<string> _machineId;

		protected readonly Sync<string> _userId;

		public User Target
