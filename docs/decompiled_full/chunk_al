		protected override void InternalLoad(DataTreeNode node, LoadControl control)
		{
			DataTreeDictionary dataTreeDictionary = (DataTreeDictionary)node;
			TypeData typeData = control.DecodeType(dataTreeDictionary.TryGetNode("Type"));
			if (typeData.type == null)
			{
				if (typeData.typename != null)
				{
					UniLog.Error("Unsupported element type, couldn't load: " + typeData.typename);
				}
				InternalSetElement(null);
			}
			else
			{
				InternalCreateElement(RefID.Null, typeData.type).Load(dataTreeDictionary["Data"], control);
			}
		}

