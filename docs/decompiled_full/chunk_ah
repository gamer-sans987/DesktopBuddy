		protected override void OnCommonUpdate()
		{
			Elements.Core.BoundingBox boundingBox = new Elements.Core.BoundingBox(Elements.Core.float3.Zero);
			int num = (int)Direction.Value / 2;
			bool flag = (int)Direction.Value % 2 == 1;
			for (int i = 0; i < TargetCount; i++)
			{
				Slot slot = this[flag ? (TargetCount - i - 1) : i];
				if (slot == null)
				{
					continue;
				}
				slot.GlobalPosition = base.Slot.GlobalPosition;
				Elements.Core.BoundingBox boundingBox2 = slot.ComputeBoundingBox(includeInactive: false, base.Slot, _boundedFilter);
				if (!boundingBox2.IsValid)
				{
					boundingBox2 = new Elements.Core.BoundingBox(base.Slot.GlobalPointToLocal(slot.GlobalPosition));
				}
				Elements.Core.float3 localPoint = Elements.Core.float3.Zero;
				for (int j = 0; j < 3; j++)
				{
					if (j == num)
					{
						float num2 = boundingBox.max[j];
						float num3 = boundingBox2.min[j];
						float value = num2 - num3;
						num2 += boundingBox2.Size[j];
						num2 += Separation.Value;
						localPoint = localPoint.SetComponent(value, j);
						boundingBox.max = boundingBox.max.SetComponent(num2, j);
					}
					else
					{
						Align alignment = GetAlignment(j, element: true);
						float num4 = boundingBox2.Size[j];
						float num5 = boundingBox2.min[j];
						float num6 = boundingBox2.max[j];
						float num7 = alignment switch
						{
							Align.Mid => (0f - num4) / 2f - num5, 
							Align.Pos => 0f - num5, 
							Align.Neg => 0f - num4 - num5, 
							_ => throw new Exception("Invalid alignment"), 
						};
						num5 += num7;
						num6 += num7;
						boundingBox.Encapsulate(Elements.Core.float3.Zero.SetComponent(num5, j));
						boundingBox.Encapsulate(Elements.Core.float3.Zero.SetComponent(num6, j));
						localPoint = localPoint.SetComponent(num7, j);
					}
				}
				slot.GlobalPosition = base.Slot.LocalPointToGlobal(in localPoint);
			}
			boundingBox.max = boundingBox.max.SetComponent(boundingBox.max[num] - Separation.Value, num);
			Elements.Core.float3 a = Elements.Core.float3.Zero;
			Elements.Core.float3 size = boundingBox.Size;
			Elements.Core.float3 center = boundingBox.Center;
			for (int k = 0; k < 3; k++)
			{
				Align alignment2 = GetAlignment(k, element: false);
				float num8 = 0f - center[k];
				switch (alignment2)
				{
				case Align.Neg:
					num8 -= size[k] / 2f;
					break;
				case Align.Pos:
					num8 += size[k] / 2f;
					break;
				}
				a = a.SetComponent(num8, k);
			}
			if (!(a != Elements.Core.float3.Zero))
			{
				return;
			}
			Elements.Core.float3 b = base.Slot.LocalVectorToGlobal(in a);
			for (int l = 0; l < TargetCount; l++)
			{
				Slot slot2 = this[l];
				if (slot2 != null)
				{
					slot2.GlobalPosition += b;
				}
			}
		}

		private Align GetAlignment(int axis, bool element)
		{
			switch (axis)
			{
			case 0:
				if (!element)
				{
					return GlobalAxisXAlign.Value;
				}
				return ElementAxisXAlign.Value;
			case 1:
				if (!element)
				{
					return GlobalAxisYAlign.Value;
				}
				return ElementAxisYAlign.Value;
			case 2:
				if (!element)
				{
					return GlobalAxisZAlign.Value;
				}
				return ElementAxisZAlign.Value;
