		private Elements.Core.float3 ComputeKneeOffset(Slot kneeOffset, Slot foot, Elements.Core.float3 newPosition)
		{
			Elements.Core.float3 a = base.Slot.GlobalPointToLocal(kneeOffset.Parent.LocalPointToGlobal(in newPosition));
			Elements.Core.float3 b = base.Slot.GlobalPointToLocal(foot.GlobalPosition);
			Elements.Core.float3 @float = a - b;
			a = b + (@float.x_z.Normalized * 0.5f + @float._y_);
			return base.Slot.LocalPointToSpace(in a, kneeOffset.Parent);
		}

