					return;
				}
				encodedAudioStream.LocalForceMute = true;
			}
			else if (encodedAudioStream != null)
			{
				encodedAudioStream.LocalForceMute = false;
			}
			_currentStream?.Write(buffer, ref _writeState);
		}

