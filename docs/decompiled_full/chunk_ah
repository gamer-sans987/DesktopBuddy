		{
			PositionDrive.TryLink(base.Slot.Position_Field);
			RotationDrive.TryLink(base.Slot.Rotation_Field);
		}

		protected override void OnCommonUpdate()
		{
			RunUpdate();
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			bool flag = RunAfterFinalPoseUpdate.Value;
			if (flag && !PositionAtLocalUser.Value && TargetUser.Target != base.LocalUser)
			{
				flag = false;
			}
			if (_finalPoseUpdateRegistered != flag)
			{
				_finalPoseUpdateRegistered = flag;
				if (flag)
				{
					base.World.FinalUserPoseUpdated += OnFinalPoseUpdated;
				}
				else
				{
					Unregister();
				}
			}
		}

		private void Unregister()
		{
			if (_finalPoseUpdateRegistered)
			{
				_finalPoseUpdateRegistered = false;
				base.World.FinalUserPoseUpdated -= OnFinalPoseUpdated;
			}
		}

		private void OnFinalPoseUpdated()
		{
			if (IsRemoved || !base.Enabled || !base.Slot.IsActive)
			{
				return;
