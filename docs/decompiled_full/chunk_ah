			}
			throw new Exception("Unsupported visual source: " + source.ParentHierarchyToString());
		}

		private async Task SetupBodyNodeReference(TrackedDevicePositioner devicePositioner, Slot reference, Slot model)
		{
			switch (devicePositioner.CorrespondingBodyNode.Value)
			{
			case BodyNode.Head:
				_headReference.Target = reference;
				await DebugAvatarBuilder.SpawnHeadsetModel(model, Elements.Core.colorX.White);
				break;
			case BodyNode.LeftController:
			case BodyNode.RightController:
			{
				Chirality chirality = ((devicePositioner.CorrespondingBodyNode.Value != BodyNode.LeftController) ? Chirality.Right : Chirality.Left);
				IStandardController controllerNode = base.InputInterface.GetControllerNode(chirality);
				await AvatarControllerSpawner.SpawnControllerModel(model, controllerNode.GetType(), controllerNode.DeviceModel, base.LocalUser.HeadDevice, chirality);
				break;
			}
			case BodyNode.LeftHand:
				_leftHandReference.Target = reference;
				break;
			case BodyNode.RightHand:
				_rightHandReference.Target = reference;
				break;
			}
			model.ForeachComponentInChildren(delegate(MeshRenderer r)
			{
