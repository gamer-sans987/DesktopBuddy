		private async Task SpawnCloudAvatar(User user, AvatarManager avatarManager)
		{
			if (IdUtil.GetOwnerType(user.UserID) != OwnerType.User)
			{
				return;
			}
			Uri recordUri = (await base.Engine.Cloud.Variables.Read<Uri>(user.UserID, base.Cloud.Platform.FavoriteVariable(FavoriteEntity.Avatar)))?.Entity;
			if (recordUri == null || !base.Cloud.Records.ExtractRecordID(recordUri, out var ownerId, out var _))
			{
				return;
			}
			string accessKey = null;
			if (!user.IsLocalUser && ownerId == user.UserID)
			{
				DateTime waitTime = DateTime.UtcNow;
				while (!user.HasNewAvatarAccessKey)
				{
					if (user.IsDisposed || (DateTime.UtcNow - waitTime).TotalSeconds > 30.0)
					{
						return;
					}
					await default(NextUpdate);
				}
				accessKey = (user.LastAvatarAccessKey = user.AvatarAccessKey);
			}
			await default(ToBackground);
			CloudResult<SkyFrost.Base.Record> recordResult = await base.Engine.Cloud.Records.GetRecordCached<SkyFrost.Base.Record>(recordUri, accessKey);
			if (recordResult.IsError)
			{
				return;
			}
			Uri assetURL = new Uri(recordResult.Entity.AssetURI);
			string text = await base.Engine.AssetManager.GatherAssetFile(assetURL, 100f);
			if (!File.Exists(text))
			{
				return;
			}
			DataTreeDictionary node = DataTreeConverter.Load(text, assetURL);
			await default(ToWorld);
			await WaitForValidUserRoot(user);
			if (user.IsDestroyed)
			{
				return;
			}
			Slot avatar = base.World.AddSlot("Avatar");
			bool cleanupAvatar = false;
			try
			{
				avatar.LoadObject(node, recordResult?.Entity);
				avatar = avatar.GetComponent<InventoryItem>()?.Unpack() ?? avatar;
				await default(NextUpdate);
				ExplicitlyAllowAvatarObject(avatar, user);
				if (!avatarManager.Equip(avatar, isManualEquip: false, forceDestroyOld: true))
				{
					cleanupAvatar = true;
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception when trying to spawn and equip cloud avatar for {user}:\n{value}", stackTrace: false);
				cleanupAvatar = true;
			}
			if (cleanupAvatar)
			{
				avatar.Destroy();
			}
		}

		private async Task SpawnTemplateAvatar(User user, AvatarManager avatarManager, AvatarTemplate template)
		{
			await WaitForValidUserRoot(user);
			if (!user.IsDestroyed)
			{
				Slot avatar = template.TemplateRoot.Target.Duplicate();
				avatar.ActiveSelf = true;
				await default(NextUpdate);
				ExplicitlyAllowAvatarObject(avatar, user);
				avatarManager.Equip(avatar);
			}
		}

		private async Task WaitForValidUserRoot(User user)
		{
			while (!user.IsDestroyed && (user.Root == null || (user.Root?.HeadSlot == null && user.Root.ReceivedFirstPositionalData) || user.Root.LocalHeadPosition.y <= 0.01f))
			{
				await default(NextUpdate);
			}
		}

