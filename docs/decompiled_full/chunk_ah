			protected override void OnAwake()
			{
				base.OnAwake();
				BlockCloudAvatar.Value = true;
				OnlyForRole.Value = Role.Anyone;
				Weight.Value = 1f;
				MaxUsers.Value = int.MaxValue;
			}

			public bool CanSpawn(User user)
			{
				if (TemplateRoot.Target == null)
				{
					return false;
				}
				if (Weight.Value <= 0f)
				{
					return false;
				}
				if (users.Count >= MaxUsers.Value)
				{
					return false;
				}
				if (OnlyForRole.Value == Role.HostOnly && !user.IsHost)
				{
					return false;
				}
				if (OnlyForRole.Value == Role.GuestOnly && user.IsHost)
				{
					return false;
				}
				return true;
			}

