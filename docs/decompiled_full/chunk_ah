			if (hit.HasValue && (filter == null || filter(hit.Value.Collider)))
			{
				ScreenController screen = base.World.GetScreen();
				float? obj;
				if (screen == null)
				{
					obj = null;
				}
				else
				{
					RaycastHit value = hit.Value;
					obj = screen.GetPointViewDistance(in value.Point);
