		private void BuildHeightUI(UIBuilder ui)
		{
			ui.Style.Height = 64f;
			QuantityTextEditorParser<Distance, float> quantityTextEditorParser = ui.HorizontalElementWithLabel("Settings.UserMetricsSettings.UserHeight".AsLocaleKey(), 0.4f, () => ui.QuantityField<Distance, float>(new Distance(0.0), new Distance(2.2), parseContinuously: false));
			quantityTextEditorParser.ParsedValue.SyncWithSetting<float, UserMetricsSettings>("UserHeight");
			quantityTextEditorParser.FormatUnit.Value = "cm";
			quantityTextEditorParser.DefaultUnit.Value = "cm";
			quantityTextEditorParser.FormatNumber.Value = "F0";
			quantityTextEditorParser.IgnoreOutOfRange.Value = true;
			_heightField.Target = quantityTextEditorParser;
			ui.HorizontalLayout(4f);
			ui.ValueRadio("General.Units.Metric".AsLocaleKey(), _useImperial, value: false);
			ui.ValueRadio("General.Units.Imperial".AsLocaleKey(), _useImperial, value: true);
			ui.NestOut();
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (_calibrator.Target?.TargetUser.Target != base.LocalUser)
			{
				return;
			}
			QuantityTextEditorParser<Distance, float> target = _heightField.Target;
			if (target == null)
			{
				return;
			}
			if (_useImperial.Value)
			{
				if (target.DefaultUnit.Value != "ft")
				{
					target.CompoundFormatUnits.Clear();
					target.CompoundFormatUnits.Add("'");
					target.CompoundFormatUnits.Add("\"");
					target.CompoundOverrideNames.Value = true;
					target.CompoundSeparator.Value = " ";
					target.FormatNumber.Value = "F0";
					target.FormatUnit.Value = "ft";
					target.DefaultUnit.Value = "ft";
				}
			}
			else if (target.DefaultUnit.Value != "cm")
			{
				target.CompoundFormatUnits.Clear();
				target.FormatNumber.Value = "F0";
				target.FormatUnit.Value = "cm";
				target.DefaultUnit.Value = "cm";
			}
		}

		protected override void OnCommonUpdate()
		{
			FullBodyCalibrator target = _calibrator.Target;
			if (target == null)
			{
				base.Slot.Destroy();
			}
			else if (target.TargetUser.Target == base.LocalUser)
			{
				Page page = ((_currentPage.Value == Page.CalibrationFinished) ? Page.CalibrationFinished : (target.CalibratingPose ? Page.CalibratingTPose : (target.HasCalibratingAvatar ? Page.CalibratingAvatar : (target.HasCalibratedTrackers ? Page.CalibratingTrackers : Page.MappingTrackers))));
				if (page != (Page)_currentPage)
				{
					OpenPage((page > (Page)_currentPage) ? SlideSwapRegion.Slide.Left : SlideSwapRegion.Slide.Right, page);
				}
				if (_confirmTrackers.Target != null)
				{
					_confirmTrackers.Target.Enabled = (target.HasTrackerCandiates || target.HasCalibratedTrackers) && (float)_heightField.Target.ParsedValue > 0.8f;
				}
				if (_heightField.Target != null && _heightWarning.Target != null)
				{
					_heightWarning.Target.Slot.ActiveSelf = (float)_heightField.Target.ParsedValue < 1.4f;
				}
				if (_calibrateAvatar.Target != null)
				{
					_calibrateAvatar.Target.Enabled = target.CanCalibrateAvatar;
				}
				if (_currentPage.Value == Page.CalibratingAvatar)
				{
					UpdateAvatarMapping(_hipsMapping.Target, target.HasCalibratedHips, target.HasMappedHips, "Hips");
					UpdateAvatarMapping(_feetMapping.Target, target.HasCalibratedFeet, target.HasMappedFeet, "Feet");
					UpdateAvatarMapping(_chestMapping.Target, target.HasCalibratedChest, mapped: true, "Chest");
					UpdateAvatarMapping(_elbowsMapping.Target, target.HasCalibratedElbows, mapped: true, "Elbows");
					UpdateAvatarMapping(_kneesMapping.Target, target.HasCalibratedKnees, mapped: true, "Knees");
				}
				else if (_currentPage.Value == Page.CalibratingTrackers)
				{
					UpdateTrackerMapping(_hipsMapping.Target, target.HasCalibratedHips, target.HipsTracking, "Hips");
					UpdateTrackerMapping(_feetMapping.Target, target.HasCalibratedFeet, target.FeetTracking, "Feet");
					UpdateTrackerMapping(_chestMapping.Target, target.HasCalibratedChest, target.ChestTracking, "Chest");
					UpdateTrackerMapping(_elbowsMapping.Target, target.HasCalibratedElbows, target.ElbowsTracking, "Elbows");
					UpdateTrackerMapping(_kneesMapping.Target, target.HasCalibratedKnees, target.KneesTracking, "Knees", (target.HasCalibratedFeet && target.FeetTracking) ? null : this.GetLocalized("FullBody.FeetNotTracking"));
				}
			}
		}

		private void UpdateTrackerMapping(Text text, bool mapped, bool tracking, string name, string errorOverride = null)
		{
			if (text == null)
			{
				return;
			}
			Elements.Core.colorX colorX;
			string value;
			if (mapped)
			{
				if (tracking)
				{
					colorX = RadiantUI_Constants.Hero.GREEN;
					value = this.GetLocalized("FullBody.TrackerMapped");
				}
				else
				{
					colorX = RadiantUI_Constants.Hero.ORANGE;
					value = errorOverride ?? this.GetLocalized("FullBody.NotTracking");
				}
			}
			else
			{
				colorX = RadiantUI_Constants.Hero.RED;
				value = this.GetLocalized("FullBody.NoTracker");
			}
			text.Content.Value = $"{this.GetLocalized("FullBody." + name)}: <color={colorX.ToHexString()}>{value}</color>";
		}

		private void UpdateAvatarMapping(Text text, bool calibrated, bool mapped, string name)
		{
			if (text == null)
			{
				return;
			}
			Elements.Core.colorX colorX;
			string localized;
			if (calibrated)
			{
				if (mapped)
				{
					colorX = RadiantUI_Constants.Hero.GREEN;
					localized = this.GetLocalized("FullBody.AvatarPointMapped");
				}
				else
				{
					colorX = RadiantUI_Constants.Hero.RED;
					localized = this.GetLocalized("FullBody.AvatarPointNotMapped");
				}
			}
			else
			{
				colorX = RadiantUI_Constants.Neutrals.MID;
				localized = this.GetLocalized("FullBody.AvatarPointNoTracker");
			}
			text.Content.Value = $"{this.GetLocalized("FullBody." + name)}: <color={colorX.ToHexString()}>{localized}</color>";
		}

