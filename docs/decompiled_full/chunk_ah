			ConeCollider coneCollider = slot.AttachComponent<ConeCollider>();
			coneCollider.Radius.Value = radiusBase;
			coneCollider.Height.Value = height;
			slot.LocalRotation = Elements.Core.floatQ.Euler(90f, 0f, 0f);
			slot.LocalPosition += Elements.Core.float3.Forward * 0.05f;
			MAT material = slot.AttachComponent<MAT>();
			ConeMesh coneMesh = slot.AttachMesh<ConeMesh>(material);
			coneMesh.RadiusTop.Value = radiusTop;
			coneMesh.RadiusBase.Value = radiusBase;
			coneMesh.Height.Value = height;
			Slot slot2 = base.Slot.AddSlot("Tip");
			slot2.GlobalPosition = coneMesh.TopPoint;
			TipReference.Target = slot2;
			return new DebugVisual<MAT>
			{
				material = material,
				cone = coneMesh,
				visual = slot,
				tip = slot2
			};
		}

