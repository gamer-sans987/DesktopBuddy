		public bool CalibratingPose
		{
			get
			{
				return _calibratingPose;
			}
			set
			{
				if (value != _calibratingPose.Value)
				{
					if (value)
					{
						IKSolverVR solver = _userBody._vrIkAvatar.Target.IK.Target.Solver;
						IKSolverVR solver2 = _platformBody._vrIkAvatar.Target.IK.Target.Solver;
						Slot target = solver2.BoneReferences.root.Target;
						Slot target2 = solver2.BoneReferences.head.Target;
						Elements.Core.float3 spacePoint = target.GlobalPointToLocal(target2.GlobalPosition).x_z;
						Elements.Core.floatQ spaceRotation = Elements.Core.floatQ.LookRotation(target.GlobalDirectionToLocal(target2.Forward).x_z.Normalized);
						Slot simulationSpace = solver2.GetSimulationSpace();
						spacePoint = simulationSpace.SpacePointToLocal(in spacePoint, target);
						spaceRotation = simulationSpace.SpaceRotationToLocal(in spaceRotation, target);
						solver.DefaultRootPosition.Value = spacePoint;
						solver.DefaultRootRotation.Value = spaceRotation;
						solver2.DefaultRootPosition.Value = spacePoint;
						solver2.DefaultRootRotation.Value = spaceRotation;
					}
					_calibratingPose.Value = value;
				}
			}
		}

