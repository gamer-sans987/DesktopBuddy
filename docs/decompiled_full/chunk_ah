		protected override void OnChanges()
		{
			base.OnChanges();
			TwitchInterface twitchInterface = Interface.Target;
			bool flag = true;
			if (twitchInterface != null && !twitchInterface.Simulate)
			{
				flag = false;
				twitchInterface = null;
			}
			if (_registeredInterface != twitchInterface)
			{
				if (flag)
				{
					Clear();
				}
				Unregister();
				_registeredInterface = twitchInterface;
				if (_registeredInterface != null)
				{
					_registeredInterface.OnConnecting += OnConnecting;
					_registeredInterface.OnConnected += OnConnected;
					_registeredInterface.OnConnectionError += OnConnectionError;
					_registeredInterface.OnDisconnected += OnDisconnected;
					_registeredInterface.OnStreamUp += OnStreamUp;
					_registeredInterface.OnStreamDown += OnStreamDown;
					_registeredInterface.OnMessageReceived += OnMessageReceived;
					_registeredInterface.OnMessageCleared += OnMessageCleared;
					_registeredInterface.OnChatCleared += OnChatCleared;
					_registeredInterface.OnRewardRedeemed += OnRewardRedeemed;
					_registeredInterface.OnRaidNotification += OnRaidNotification;
					_registeredInterface.OnChannelStateChanged += OnChannelStateChanged;
					_registeredInterface.OnUserBanned += OnUserBanned;
					_registeredInterface.OnGiftedSubscription += OnGiftedSubscription;
					_registeredInterface.OnFollow += OnFollow;
					_registeredInterface.OnNewSubscriber += OnNewSubscriber;
					_registeredInterface.OnReSubscriber += OnReSubscriber;
				}
			}
			if (Interface.Target == null)
			{
				_channelName.Target.TargetString = "<i>No Twitch interface...</i>";
				_channelName.Target.Editor.Target.Enabled = false;
			}
			else
			{
				_channelName.Target.Editor.Target.Enabled = true;
				if (!_channelName.Target.Editor.Target.IsEditing)
				{
					string text = Interface.Target?.Channel.Value;
					if (string.IsNullOrWhiteSpace(text))
					{
						_channelName.Target.TargetString = "<i>Type channel name here...</i>";
					}
					else
					{
						_channelName.Target.TargetString = text;
					}
				}
			}
			int num = Interface.Target?.ViewerCount.Value ?? 0;
			_viewerCount.Target.Content.Value = num.ToString();
			Sync<Elements.Core.colorX> color = _viewerCount.Target.Color;
			TwitchInterface target = Interface.Target;
			color.Value = ((target != null && target.StreamLive.Value) ? new Elements.Core.colorX(0.8f, 0f, 0f) : new Elements.Core.colorX(0.25f));
		}

