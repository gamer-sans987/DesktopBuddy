			if (!base.IsDisposed && !BlockRemoteEquip && !IsEquipped)
			{
				InteractionHandler interactionHandler = eventData.source.FindInteractionHandler();
				if (interactionHandler != null && interactionHandler.ActiveTool == null)
				{
					interactionHandler.Equip(this, lockEquip: true);
				}
			}
		}

		void ITouchable.OnTouch(in TouchEventInfo eventInfo)
