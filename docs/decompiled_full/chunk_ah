	public static class ObjectRootBlockExtensions
	{
		/// <summary>
		/// Finds all components of type T in parents (including current slot), stopping after SearchBlock component is encountered.
		/// </summary>
		/// <typeparam name="T">The type of the component to find</typeparam>
		/// <param name="slot">The slot to begin the search on</param>
		/// <param name="results">A list to which to add found components</param>
		/// <param name="filter">Optional predicate to filter the found components</param>
		public static void GetComponentsInParentsUntilBlock<T>(this Slot slot, List<T> results, Predicate<T> filter = null) where T : class
		{
			Slot slot2 = slot;
			while (slot2 != null && !slot2.IsRootSlot)
			{
				slot2.GetComponents(results, filter);
				if (slot2.GetComponent<SearchBlock>() == null)
				{
					slot2 = slot2.Parent;
					continue;
				}
				break;
			}
		}

		/// <summary>
		/// Finds all components of type T in parents (including current slot), stopping after SearchBlock component is encountered.
		/// </summary>
		/// <typeparam name="T">The type of the component to find</typeparam>
		/// <param name="slot">The slot to begin the search on</param>
		/// <param name="filter">Optional predicate to filter the found components</param>
		/// <returns>List of all found components</returns>
		public static List<T> GetComponentsInParentsUntilBlock<T>(this Slot slot, Predicate<T> filter = null) where T : class
		{
			List<T> list = new List<T>();
			slot.GetComponentsInParentsUntilBlock(list, filter);
			return list;
		}

		/// <summary>
		/// Finds the first component of type T in parents, searching until SearchBlock component is encountered
		/// </summary>
		/// <typeparam name="T">The type of the component to find</typeparam>
		/// <param name="slot">The slot to start the search on</param>
		/// <param name="filter">Optional predicate to filter the  found components.</param>
		/// <returns>First found component or null if no component is found</returns>
		public static T GetComponentInParentsUntilBlock<T>(this Slot slot, Predicate<T> filter = null) where T : class
		{
			Slot slot2 = slot;
			while (slot2 != null && !slot2.IsRootSlot)
			{
				T component = slot2.GetComponent(filter);
				if (component != null)
				{
					return component;
				}
				if (slot2.GetComponent<SearchBlock>(null, excludeDisabled: true) != null)
				{
