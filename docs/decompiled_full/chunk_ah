	{
		public readonly SyncRefList<Slot> Anchors;

		[OldName("Anchor0")]
		[NonPersistent]
		protected readonly SyncRef<Slot> _legacyAnchor0;

		[OldName("Anchor1")]
		[NonPersistent]
		protected readonly SyncRef<Slot> _legacyAnchor1;

		[OldName("Format")]
		public readonly Sync<string> FormatUnit;

		public readonly Sync<string> FormatNumber;

		public readonly SyncFieldList<string> CompoundFormatUnits;

		public readonly Sync<bool> CompoundUseLongNames;

		public readonly Sync<bool> CompoundOverrideNames;

		public readonly Sync<bool> CompoundDiscardLastFraction;

		public readonly Sync<string> CompoundSeparator;

		public readonly Sync<CompoundZeroHandling> CompoundZeroHandling;

		public readonly RootSpace MeasurementSpace;

		public readonly FieldDrive<string> DistanceText;

		private float lastDist = float.NaN;

		private bool lastDirty;

		public override int Version => 1;

		protected override void OnAwake()
		{
			base.OnAwake();
			FormatNumber.Value = "F2";
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			lastDirty = true;
		}

		protected override void OnCommonUpdate()
		{
			if (!DistanceText.IsLinkValid)
			{
				return;
			}
			float num = 0f;
			Elements.Core.float3? @float = null;
			foreach (Slot anchor in Anchors)
			{
				if (anchor != null)
				{
					Elements.Core.float3 b = MeasurementSpace.Space.GlobalPointToLocal(anchor.GlobalPosition);
					if (@float.HasValue)
					{
						num += MathX.Distance(@float.Value, in b);
					}
					@float = b;
				}
			}
			if (num == 0f)
			{
				DistanceText.Target.Value = "---";
			}
			else if (num != lastDist || lastDirty)
			{
				lastDirty = false;
				lastDist = num;
				DistanceText.Target.Value = ValueToString(num);
			}
		}

		private string ValueToString(double val)
		{
			Distance distance = default(Distance);
			Unit<Distance> unit = null;
			Distance q = distance.New(val);
			if (CompoundFormatUnits.Count > 0)
			{
				List<CompoundFormatInfo<Distance>.Info> list = new List<CompoundFormatInfo<Distance>.Info>();
				foreach (string compoundFormatUnit in CompoundFormatUnits)
				{
					if (QuantityHelper.GetUnitByName<Distance>(compoundFormatUnit) is Unit<Distance> unit2)
					{
						list.Add(new CompoundFormatInfo<Distance>.Info(unit2, CompoundOverrideNames.Value ? compoundFormatUnit : null));
					}
				}
				if (list.Count > 0)
				{
					CompoundFormatInfo<Distance> formatInfo = new CompoundFormatInfo<Distance>(CompoundSeparator, FormatNumber, CompoundZeroHandling, CompoundUseLongNames, CompoundDiscardLastFraction, list);
					return q.FormatCompound(formatInfo);
				}
				return q.FormatAuto(FormatNumber);
			}
			if (FormatUnit.Value != null)
			{
				unit = QuantityHelper.GetUnitByName<Distance>(FormatUnit) as Unit<Distance>;
			}
			if (unit == null)
			{
				return q.FormatAuto(FormatNumber);
			}
			return q.FormatAs(unit, FormatNumber);
		}

