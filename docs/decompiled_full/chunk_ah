		{
			int deviceIndex = property.Device.DeviceIndex;
			Device device = Devices.FirstOrDefault((Device d) => d.DeviceIndex.Value == deviceIndex);
			if (device == null)
			{
				device = Devices.Add();
				device.DeviceIndex.Value = deviceIndex;
			}
			return device;
		}

		protected override void OnCommonUpdate()
		{
			if (base.User != base.LocalUser)
			{
				return;
			}
			foreach (Device device2 in Devices)
			{
				IInputDevice device = base.InputInterface.GetDevice(device2.DeviceIndex);
				if (device.IsDeviceActive != device2.LastActive)
				{
					device2.LastActive = device.IsDeviceActive;
					foreach (Driver<bool> digital_Driver in device2.Digital_Drivers)
					{
						digital_Driver.Stream.Target.Active = device2.LastActive;
					}
					foreach (Driver<float> analog_Driver in device2.Analog_Drivers)
					{
						analog_Driver.Stream.Target.Active = device2.LastActive;
					}
					foreach (Driver<Elements.Core.float2> analog2D_Driver in device2.Analog2D_Drivers)
					{
						analog2D_Driver.Stream.Target.Active = device2.LastActive;
					}
					foreach (Driver<Elements.Core.float3> analog3D_Driver in device2.Analog3D_Drivers)
					{
						analog3D_Driver.Stream.Target.Active = device2.LastActive;
					}
				}
				if (!device.IsDeviceActive)
				{
					continue;
				}
				foreach (Driver<bool> digital_Driver2 in device2.Digital_Drivers)
				{
					digital_Driver2.Stream.Target.Value = device.GetProperty<Digital>(digital_Driver2.PropertyIndex).Held;
				}
				foreach (Driver<float> analog_Driver2 in device2.Analog_Drivers)
				{
					analog_Driver2.Stream.Target.Value = device.GetProperty<Analog>(analog_Driver2.PropertyIndex).Value;
				}
				foreach (Driver<Elements.Core.float2> analog2D_Driver2 in device2.Analog2D_Drivers)
				{
					analog2D_Driver2.Stream.Target.Value = device.GetProperty<Analog2D>(analog2D_Driver2.PropertyIndex).Value;
				}
				foreach (Driver<Elements.Core.float3> analog3D_Driver2 in device2.Analog3D_Drivers)
				{
					analog3D_Driver2.Stream.Target.Value = device.GetProperty<Analog3D>(analog3D_Driver2.PropertyIndex).Value;
				}
			}
