		}

		public Slot SpawnPoint(Slot root, Elements.Core.float3 position, bool grabbable = false)
		{
			Slot slot = root.AddSlot("Point");
			slot.AttachMesh(MeterPointMesh, GetMaterial(MeterMode));
			slot.GlobalPosition = position;
			slot.GlobalScale = Elements.Core.float3.One;
			if (grabbable)
			{
				slot.AttachComponent<SphereCollider>().Radius.Value = 0.007f;
				slot.AttachComponent<Slider>().Rotatable.Value = true;
			}
			slot.CreateSpawnUndoPoint();
			return slot;
		}

		private void FinishMeter()
		{
			_lastPoint.Target = null;
			_currentLineTransform.Target = null;
			_currentMeter.Target = null;
		}

		private void AppendPoint(Slot newPoint)
		{
			Slot target = _lastPoint.Target;
			Slot parent = target.Parent;
			LineTransform target2 = _currentLineTransform.Target;
			DistanceMeter target3 = _currentMeter.Target;
			parent.AttachComponent<SearchBlock>();
			LineSegment lineSegment = parent.AddSlot("Line").AttachComponent<LineSegment>();
			lineSegment.Setup(collider: true, GetMaterial(MeterMode));
			lineSegment.Anchor0.Target = target;
			lineSegment.Anchor1.Target = newPoint;
			lineSegment.Sides.Value = 6;
			lineSegment.Radius.Value = 0.0035f;
			SnapLine snapLine = parent.AttachComponent<SnapLine>();
			snapLine.Anchor0.Target = target;
			snapLine.Anchor1.Target = newPoint;
			target3.Slot.Parent = target.Parent;
			target2.Point0Anchor.Target = target;
			target2.Point1Anchor.Target = newPoint;
			target3.Anchors.Add(newPoint);
			target3.Slot.DestroyWhenDestroyed(newPoint);
			newPoint.DestroyWhenDestroyed(target3.Slot);
			_lastPoint.Target = newPoint;
		}

		private void CreateMeter(Slot initialPoint)
		{
			Slot parent = initialPoint.Parent;
			Slot slot = parent.AddSlot("Label");
			DistanceMeter distanceMeter = slot.AttachComponent<DistanceMeter>();
			distanceMeter.Anchors.Add(initialPoint);
			if (FormatUnit.Value != null)
			{
				distanceMeter.FormatUnit.Value = FormatUnit.Value;
			}
			if (FormatNumber.Value != null)
			{
				distanceMeter.FormatNumber.Value = FormatNumber.Value;
			}
			slot.AttachComponent<Slider>().Scalable.Value = true;
			slot.DestroyWhenDestroyed(parent);
			initialPoint.DestroyWhenDestroyed(parent);
			LineTransform lineTransform = slot.AttachComponent<LineTransform>();
			lineTransform.LinePoint.Value = 0.5f;
			lineTransform.OffsetPoint.Value = Elements.Core.float3.Up * 0.03f * 1.2f;
			lineTransform.RotationOffset.Value = Elements.Core.floatQ.AxisAngle(Elements.Core.float3.Up, -90f);
			Slot slot2 = slot.AddSlot("Text");
			slot2.AttachComponent<FlipAtUser>();
			TextRenderer textRenderer = slot2.AttachComponent<TextRenderer>();
			textRenderer.SetupBoxCollider();
			textRenderer.Material.Target = LabelFontMaterial;
			textRenderer.Size.Value = 0.29999998f;
			distanceMeter.DistanceText.Target = textRenderer.Text;
			if ((bool)MeasureInObjectSpace)
			{
				distanceMeter.MeasurementSpace.UseLocalSpaceOfParent(parent);
			}
			_lastPoint.Target = initialPoint;
			_currentMeter.Target = distanceMeter;
			_currentLineTransform.Target = lineTransform;
		}

