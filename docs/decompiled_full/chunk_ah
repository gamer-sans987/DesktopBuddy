			}
			set
			{
				Offset.Value = new Elements.Core.float3(Offset.Value.xy, value);
			}
		}

		public Elements.Core.float2 AxisPlaneOffset
		{
			get
			{
				return Offset.Value.xy;
			}
			set
			{
				Offset.Value = new Elements.Core.float3(in value, AxisLineOffset);
			}
		}

