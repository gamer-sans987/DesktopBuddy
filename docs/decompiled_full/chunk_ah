			}
			if (IsEquipped)
			{
				return false;
			}
			InteractionHandler interactionHandler = source.Slot.FindInteractionHandler();
			if (interactionHandler == null)
			{
				return false;
			}
			if (interactionHandler.ActiveTool != null)
			{
				return false;
			}
			IGrabbable component = base.Slot.GetComponent<IGrabbable>();
			if (component != null && !component.CanGrab(interactionHandler.Grabber))
			{
				return false;
			}
			return true;
		}

		public void OnTouch(in TouchEventInfo eventInfo)
		{
			if (eventInfo.touch == EventState.Begin && CanTouchInteract(eventInfo.source) && !base.LocalUserRoot.Slot.IsChildOf(base.Slot, includeSelf: true))
			{
				string argValue = EquipName.Value;
				if (string.IsNullOrWhiteSpace(EquipName))
				{
					argValue = this.GetLocalized(DEFAULT_EQUIP_NAME);
				}
				base.LocalUser.ContextMenuConfirm(this, eventInfo.source.Slot, this.GetLocalized("Interaction.NamedEquipTool", null, "name", argValue), OfficialAssets.Graphics.Icons.General.Fist, new Elements.Core.colorX(0.8f, 0.8f, 1f), OnEquipConfirm);
			}
		}

