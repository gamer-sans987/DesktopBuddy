				return;
			}
			EncodedAudioStream<S> encodedAudioStream = _currentStream as EncodedAudioStream<S>;
			if (world.Focus != FrooxEngine.World.WorldFocus.Focused || base.LocalUser.IsSilenced || (ContactsDialog.RecordingVoiceMessage && lastDeviceIndex == base.AudioSystem.DefaultAudioInputIndex))
			{
				if (encodedAudioStream == null)
