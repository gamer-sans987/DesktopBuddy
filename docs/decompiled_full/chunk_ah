			num = ((User != base.LocalUser) ? (-1) : ((num >= 0) ? MathX.Clamp(num, 0, base.AudioSystem.AudioInputs.Count) : base.AudioSystem.DefaultAudioInputIndex));
			if (lastDeviceIndex == num && lastFilteredData == UseFilteredData.Value)
			{
