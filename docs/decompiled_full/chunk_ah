		private async Task SetupCalibrationReference(Slot slot, BodyNode node)
		{
			slot = slot.AddSlot("Model");
			switch (node)
			{
			case BodyNode.Hips:
				await slot.LoadObjectAsync(OfficialAssets.Graphics.Avatar_Creator.Pelvis);
				slot.LocalRotation = Elements.Core.floatQ.Euler(0f, 0f, 0f);
				break;
			case BodyNode.LeftFoot:
				await slot.LoadObjectAsync(OfficialAssets.Graphics.Avatar_Creator.LeftFoot);
				slot.LocalRotation = Elements.Core.floatQ.Euler(0f, 0f, 0f);
				break;
			case BodyNode.RightFoot:
				await slot.LoadObjectAsync(OfficialAssets.Graphics.Avatar_Creator.RightFoot);
				slot.LocalRotation = Elements.Core.floatQ.Euler(0f, 0f, 0f);
				break;
			case BodyNode.Chest:
			case BodyNode.LeftLowerArm:
			case BodyNode.RightLowerArm:
			case BodyNode.LeftLowerLeg:
			case BodyNode.RightLowerLeg:
				slot.AttachSphere(base.Slot.LocalScaleToGlobal(0.05f), null);
				break;
			default:
				throw new Exception("Unsupported body node: " + node);
			}
			slot.ForeachComponentInChildren(delegate(MeshRenderer r)
			{
				r.Material.Target = _calibrationReferenceMaterial.Target;
			});
		}

