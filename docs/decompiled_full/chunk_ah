				Elements.Core.float3 a = reference.LocalRotation * Elements.Core.float3.Forward;
				Elements.Core.float3 a2 = reference.LocalRotation * Elements.Core.float3.Up;
				Elements.Core.floatQ localRotation = Elements.Core.floatQ.LookRotation(a * new Elements.Core.float3(-1f, 1f, 1f), a2 * new Elements.Core.float3(-1f, 1f, 1f));
