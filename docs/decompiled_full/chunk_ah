			if (UsePosition && base.Slot.Position_Field.IsDriven && !base.Slot.Position_Field.IsHooked)
			{
				return false;
			}
			if (UseRotation && base.Slot.Rotation_Field.IsDriven && !base.Slot.Rotation_Field.IsHooked)
			{
				return false;
			}
			if (UseScale && base.Slot.Scale_Field.IsDriven && !base.Slot.Scale_Field.IsHooked)
			{
				return false;
			}
			if (CustomGrabCheck.Target != null && !CustomGrabCheck.Target(this, grabber))
			{
				return false;
			}
			if (!base.Permissions.Check(this, (GrabbablePermissions p) => p.CanGrab(this)))
			{
				return false;
			}
