	public class Glue : Component
	{
		public enum Mode
		{
			ParentObjects,
			BakeMeshes,
			BakeSkinnedMeshes
		}

		private class GlueCandidate
		{
			public Elements.Core.float3 position;

			public bool detected;
		}

		public readonly Sync<Mode> GlueMode;

		public readonly Sync<bool> Active;

		public readonly Sync<float> DryTime;

		public readonly Sync<double> Expire;

		public readonly SyncRef<User> GluingUser;

		protected readonly Sync<bool> _forceDry;

		protected readonly Sync<bool> isDrying;

		protected readonly Sync<double> dryStartTime;

		private Dictionary<Slot, GlueCandidate> candidates;

		private List<Slot> undetected;

		public bool IsActive => Active.Value;

		public bool IsDrying
		{
			get
			{
				return isDrying.Value;
			}
			private set
			{
				isDrying.Value = value;
			}
		}

		public float DryProgress
		{
			get
			{
				if (IsDrying)
				{
					return MathX.Clamp01((float)(base.Time.WorldTime - dryStartTime.Value) / DryTime.Value);
				}
				return 0f;
			}
		}

		public void ForceDry()
		{
			_forceDry.Value = true;
		}

		protected override void OnInit()
		{
			DryTime.Value = 2f;
		}

		protected override void OnAttach()
		{
			Expire.Value = base.Time.WorldTime + 30.0;
			GluingUser.Target = base.LocalUser;
		}

		protected override void OnCommonUpdate()
		{
			if (((GluingUser.Target != null || !base.World.IsAuthority) && GluingUser.Target != base.LocalUser) || !IsActive)
			{
				return;
			}
			if (base.Time.WorldTime >= Expire.Value)
			{
				base.Slot.Destroy();
			}
			if (candidates == null)
			{
				candidates = new Dictionary<Slot, GlueCandidate>();
			}
			if (undetected == null)
			{
				undetected = new List<Slot>();
			}
			float num = (base.Slot.GlobalScale.x + base.Slot.GlobalScale.y + base.Slot.GlobalScale.z) / 3f;
			num /= 2f;
			bool flag = false;
			List<ICollider> list = Pool.BorrowList<ICollider>();
			base.Physics.SphereOverlap(base.Slot.GlobalPosition, num, list);
			foreach (ICollider item in list)
			{
				if (item.Slot.GetComponentInParents<IComponentGizmo>() != null || item.Slot.GetComponentInParents<ITool>() != null)
				{
					continue;
				}
				Slot slot = item.Slot;
				Elements.Core.float3 b = slot.GlobalPosition;
				if (candidates.TryGetValue(slot, out GlueCandidate value))
				{
					if (value.position != b)
					{
						flag = true;
					}
				}
				else
				{
					flag = true;
					value = new GlueCandidate();
					candidates.Add(slot, value);
				}
				value.position = b;
				value.detected = true;
			}
			Pool.Return(ref list);
			foreach (KeyValuePair<Slot, GlueCandidate> candidate in candidates)
			{
				if (!candidate.Value.detected)
				{
					undetected.Add(candidate.Key);
				}
				candidate.Value.detected = false;
			}
			if (undetected.Count > 0)
			{
				flag = true;
				foreach (Slot item2 in undetected)
				{
					candidates.Remove(item2);
				}
				undetected.Clear();
			}
			if (candidates.Count < 2)
			{
				flag = true;
			}
			if (flag && IsDrying)
			{
				IsDrying = false;
			}
			if (!flag && !IsDrying)
			{
				IsDrying = true;
				dryStartTime.Value = base.Time.WorldTime;
			}
			if (_forceDry.Value || (!flag && IsDrying && DryProgress >= 1f))
			{
				Dry();
			}
		}

		private void Dry()
		{
			HashSet<ObjectRoot> roots = new HashSet<ObjectRoot>();
			Slot slot = null;
			foreach (KeyValuePair<Slot, GlueCandidate> candidate in candidates)
			{
				Slot key = candidate.Key;
				Slot bone = key.GetBone();
				if (bone != null)
				{
					if (slot == null || MathX.Distance(base.Slot.GlobalPosition, bone.GlobalPosition) < MathX.Distance(base.Slot.GlobalPosition, slot.GlobalPosition))
					{
						slot = bone;
					}
					continue;
				}
				ObjectRoot objectRoot = key.GetComponentInParents<ObjectRoot>();
				if (objectRoot == null)
				{
					Grabbable componentInParents = key.GetComponentInParents<Grabbable>();
					if (componentInParents != null)
					{
						objectRoot = componentInParents.Slot.AttachComponent<ObjectRoot>();
					}
				}
				if (objectRoot == null)
				{
					objectRoot = key.AttachComponent<ObjectRoot>();
				}
				roots.Add(objectRoot);
			}
			if (roots.Count > 0)
			{
				roots.RemoveWhere((ObjectRoot root) => roots.Any((ObjectRoot other) => root.Slot.IsChildOfElement(other)));
				if (slot != null)
				{
					foreach (ObjectRoot item in roots)
					{
						item.Slot.Parent = slot;
						item.Slot.GetComponentsInChildren<IGrabbable>().ForEach(delegate(IGrabbable c)
						{
							c.Destroy();
						});
						item.Destroy();
					}
				}
				else
				{
					ObjectRoot objectRoot2 = null;
					foreach (ObjectRoot item2 in roots)
					{
						if (objectRoot2 == null)
						{
							objectRoot2 = item2;
						}
						else if ((!item2.IsPersistent && objectRoot2.IsPersistent) || (item2.Slot.HierachyDepth < objectRoot2.Slot.HierachyDepth && item2.IsPersistent == objectRoot2.IsPersistent))
						{
							objectRoot2 = item2;
						}
					}
					roots.Remove(objectRoot2);
					ObjectRoot objectRoot3 = objectRoot2.MergeInto(roots, "Glued");
					objectRoot3.Slot.SetPivotAtCenter();
					if (GlueMode.Value == Mode.BakeMeshes || GlueMode.Value == Mode.BakeSkinnedMeshes)
					{
						objectRoot3.Slot.CreatePivotAtCenter().BakeMeshes(destroyOriginal: true, undoable: true, includeInactive: false, GlueMode.Value == Mode.BakeSkinnedMeshes, ComponentHandling.AlwaysAdd);
					}
				}
			}
			base.Slot.Destroy();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			GlueMode = new Sync<Mode>();
			Active = new Sync<bool>();
			DryTime = new Sync<float>();
			Expire = new Sync<double>();
			GluingUser = new SyncRef<User>();
			_forceDry = new Sync<bool>();
			isDrying = new Sync<bool>();
			dryStartTime = new Sync<double>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => GlueMode, 
				4 => Active, 
				5 => DryTime, 
				6 => Expire, 
				7 => GluingUser, 
				8 => _forceDry, 
				9 => isDrying, 
				10 => dryStartTime, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

