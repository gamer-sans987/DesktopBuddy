		private Predicate<IBounded> _boundedFilter;

		public int TargetCount => _targets.Count;

		public Slot this[int index] => _targets[index].TargetSlot.Target;

		private bool AcceptBounded(IBounded bounded)
		{
			for (int i = 0; i < ExcludeList.Count; i++)
			{
				if (ExcludeList[i] == bounded)
				{
					return false;
				}
			}
