	{
		public const int FINGER_NODE_COUNT = 24;

		public readonly SyncRef<User> User;

		public readonly SyncRef<ValueStream<bool>> LeftIsTracking;

		public readonly SyncRef<ValueStream<bool>> RightIsTracking;

		public readonly SyncRef<MultiValueStream<Elements.Core.floatQ>> Stream;

		public readonly Sync<bool> TracksMetacarpals;

		public readonly SyncRef<UserPoseController> PoseController;

		bool IFingerPoseSource.TracksMetacarpals => TracksMetacarpals.Value;

		public void Setup(User user, uint period, uint phase)
		{
			User.Target = user;
			LeftIsTracking.Target = user.GetStreamOrAdd("Hand.Left.IsTracking", delegate(ValueStream<bool> s)
			{
				s.SetUpdatePeriod(period, phase);
				s.Encoding = ValueEncoding.Quantized;
			});
			RightIsTracking.Target = user.GetStreamOrAdd("Hand.Right.IsTracking", delegate(ValueStream<bool> s)
			{
				s.SetUpdatePeriod(period, phase);
				s.Encoding = ValueEncoding.Quantized;
			});
			MultiValueStream<Elements.Core.floatQ> streamOrAdd = user.GetStreamOrAdd("Finger.Rotations", delegate(MultiValueStream<Elements.Core.floatQ> s)
			{
				s.Count = 48;
				s.SetUpdatePeriod(period, phase);
				s.SetInterpolation();
				s.Encoding = ValueEncoding.Quantized;
				s.FullFrameBits = 12;
			});
			Stream.Target = streamOrAdd;
		}

		protected override void OnCommonUpdate()
		{
			if (User.Target != base.LocalUser)
			{
				return;
			}
			Hand device = base.InputInterface.GetDevice((Hand h) => h.Chirality == Chirality.Left && h.IsDeviceActive && h.IsTracking);
			Hand device2 = base.InputInterface.GetDevice((Hand h) => h.Chirality == Chirality.Right && h.IsDeviceActive && h.IsTracking);
			MultiValueStream<Elements.Core.floatQ> target = Stream.Target;
			UserPoseController target2 = PoseController.Target;
			bool flag = device != null;
			bool flag2 = device2 != null;
			bool flag3 = true;
			List<Elements.Core.floatQ> list = null;
			if (flag)
			{
				flag3 &= device.TracksMetacarpals;
				for (int num = 0; num < 24; num++)
				{
					ITrackedDevice bodyNode = base.InputInterface.GetBodyNode((BodyNode)(19 + num));
					target[num] = bodyNode.Rotation;
				}
			}
			else if (target2 != null && target2.LeftFingersTracking)
			{
				flag = true;
				flag3 &= target2.TracksMetacarpals;
				list = Pool.BorrowList<Elements.Core.floatQ>();
				target2.GetFingerPoses(Chirality.Left, null, list);
				for (int num2 = 0; num2 < 24; num2++)
				{
					target[num2] = list[num2];
				}
			}
			if (flag2)
			{
				flag3 &= device2.TracksMetacarpals;
				for (int num3 = 0; num3 < 24; num3++)
				{
					ITrackedDevice bodyNode2 = base.InputInterface.GetBodyNode((BodyNode)(48 + num3));
					target[num3 + 24] = bodyNode2.Rotation;
				}
			}
			else if (target2 != null && target2.RightFingersTracking)
			{
				flag2 = true;
				flag3 &= target2.TracksMetacarpals;
				if (list == null)
				{
					list = Pool.BorrowList<Elements.Core.floatQ>();
				}
				else
				{
					list.Clear();
				}
				target2.GetFingerPoses(Chirality.Right, null, list);
				for (int num4 = 0; num4 < 24; num4++)
				{
					target[num4 + 24] = list[num4];
				}
			}
			if (list != null)
			{
				Pool.Return(ref list);
			}
			LeftIsTracking.Target.Value = flag;
			RightIsTracking.Target.Value = flag2;
			if (flag || flag2)
			{
				TracksMetacarpals.Value = flag3;
			}
		}

		public bool AreFingersTracking(Chirality chirality)
		{
			return chirality switch
			{
				Chirality.Left => LeftIsTracking.Target?.Value ?? false, 
				Chirality.Right => RightIsTracking.Target?.Value ?? false, 
				_ => false, 
			};
		}

		public void GetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			Chirality chirality;
			int num = node.GetFingerNodeIndex(out chirality);
			if (num < 0)
			{
				throw new Exception("Body node isn't a finger: " + node);
			}
			MultiValueStream<Elements.Core.floatQ> target = Stream.Target;
			if (chirality == Chirality.Right)
			{
				num += 24;
			}
			if (num >= target.Count)
			{
				throw new Exception("Insufficient number of streams. Finger index: " + num + ", Stream.Count: " + target.Count);
			}
			position = Elements.Core.float3.Zero;
			rotation = target[num];
		}

		public bool TryGetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			Chirality chirality;
			int num = node.GetFingerNodeIndex(out chirality);
			if (num < 0)
			{
				position = default(Elements.Core.float3);
				rotation = Elements.Core.floatQ.Identity;
				return false;
			}
			MultiValueStream<Elements.Core.floatQ> target = Stream.Target;
			if (chirality == Chirality.Right)
			{
				num += 24;
			}
			if (target == null || num >= target.Count)
			{
				position = default(Elements.Core.float3);
				rotation = Elements.Core.floatQ.Identity;
				return false;
			}
			position = Elements.Core.float3.Zero;
			rotation = target[num];
			return true;
		}

		public void GetFingerData(List<BodyNode> nodes, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			foreach (BodyNode node in nodes)
			{
				GetFingerData(node, out var _, out var rotation);
				rotations.Add(rotation);
			}
		}

		public void GetFingerData(Chirality chirality, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			int num = ((chirality != Chirality.Left) ? 24 : 0);
			MultiValueStream<Elements.Core.floatQ> target = Stream.Target;
			if (24 + num > target.Count)
			{
				throw new Exception("Insufficient number of streams. Chirality: " + chirality.ToString() + ", Stream.Count: " + target.Count);
			}
			for (int i = 0; i < 24; i++)
			{
				rotations.Add(target[i + num]);
			}
		}

