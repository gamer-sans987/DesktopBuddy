		protected override void OnAwake()
		{
			base.OnAwake();
			PositionNode.Value = UserRoot.UserNode.Feet;
			RotationNode.Value = UserRoot.UserNode.Feet;
			BaseWeight.Value = 1f;
			Capacity.Value = -1;
			OrientUser.Value = true;
			OtherUserCheckRadius.Value = 0.5f;
		}

		public bool CanSpawn(UserRoot root)
		{
			if (!base.Slot.IsActive || !base.Enabled)
			{
				return false;
			}
			if (Capacity.Value >= 0)
			{
				int count = base.Slot.GetComponentsInChildren<UserRoot>().Count;
				return Capacity.Value > count;
			}
			return true;
		}

		public void Spawn(UserRoot root)
		{
			int num = 0;
			bool flag;
			Elements.Core.float3 point;
			do
			{
				flag = true;
				point = GetPoint();
				if (OtherUserCheckRadius.Value > 0f && base.Physics.SphereOverlapOne(in point, OtherUserCheckRadius, (ICollider c) => c.Slot.ActiveUserRoot != null) != null)
				{
					flag = false;
				}
			}
			while (!flag && num++ < 100);
			if (ParentUser.Value)
			{
				root.Slot.Parent = ParentOverride.Target ?? base.Slot;
			}
			point = root.Slot.Parent.GlobalPointToLocal(in point);
			root.PositionReliably(delegate
			{
				if ((bool)OrientUser)
				{
					root.SetGlobalRotation(RotationNode, base.Slot.GlobalRotation);
				}
				if ((bool)ScaleUser)
				{
					root.Slot.GlobalScale = base.Slot.GlobalScale;
				}
				Elements.Core.float3 position = root.Slot.Parent.LocalPointToGlobal(in point);
				root.SetGlobalPosition(PositionNode, in position);
			});
		}

