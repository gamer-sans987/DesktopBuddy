	public class SpawnArc : Component, IUserSpawnArea, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public readonly Sync<float> Weight;

		public readonly Sync<int> Capacity;

		public readonly Sync<float> Radius;

		public readonly Sync<float> Arc;

		public readonly Sync<int> UsersPerArc;

		public readonly Sync<float> CenterArcOffset;

		public readonly Sync<bool> GrowBothSides;

		public readonly Sync<float> RowHeightOffset;

		public readonly Sync<bool> OrientUser;

		public readonly Sync<bool> ParentUser;

		public readonly Sync<bool> TiltUsers;

		public readonly Sync<UserRoot.UserNode> PositionNode;

		public readonly Sync<UserRoot.UserNode> RotationNode;

		protected readonly Sync<bool> _showTest;

		protected readonly Sync<int> _testSlots;

		private List<User> _users = new List<User>();

		float IUserSpawnArea.Weight => Weight;

		private float ArcSlotOffset => Arc.Value / (float)UsersPerArc.Value;

		protected override void OnAwake()
		{
			Capacity.Value = -1;
			Radius.Value = 1f;
			Arc.Value = 120f;
			UsersPerArc.Value = 12;
			CenterArcOffset.Value = 10f;
			GrowBothSides.Value = true;
			RowHeightOffset.Value = 0.3f;
			OrientUser.Value = true;
			ParentUser.Value = true;
			PositionNode.Value = UserRoot.UserNode.Head;
			RotationNode.Value = UserRoot.UserNode.Feet;
			_testSlots.Value = 32;
		}

		public bool CanSpawn(UserRoot root)
		{
			if ((int)Capacity >= 0)
			{
				return _users.Count((User u) => !u.IsDestroyed) < (int)Capacity;
			}
			return true;
		}

		public void Spawn(UserRoot root)
		{
			int num = _users.FindIndex((User u) => u?.IsDestroyed ?? true);
			if (num < 0)
			{
				num = _users.Count;
				_users.Add(root.ActiveUser);
			}
			else
			{
				_users[num] = root.ActiveUser;
			}
			GetLocalSpawnCoordinates(num, out var point, out var rotation);
			if ((bool)ParentUser)
			{
				root.Slot.Parent = base.Slot;
			}
			root.PositionReliably(delegate
			{
				if ((bool)OrientUser)
				{
					root.SetGlobalRotation(RotationNode, base.Slot.LocalRotationToGlobal(in rotation));
				}
				root.SetGlobalPosition(PositionNode, base.Slot.LocalPointToGlobal(in point));
			});
		}

		public void GetLocalSpawnCoordinates(int spotIndex, out Elements.Core.float3 point, out Elements.Core.floatQ rotation)
		{
			if (spotIndex == 0)
			{
				point = CirclePointAtAngle(0f);
			}
			else
			{
				spotIndex--;
				int num = spotIndex % UsersPerArc.Value;
				int num2 = spotIndex / UsersPerArc.Value;
				if ((bool)GrowBothSides)
				{
					int num3 = (((num & 1) == 0) ? 1 : (-1));
					float angle = ((float)CenterArcOffset + (float)(num / 2) * ArcSlotOffset) * (float)num3;
					point = CirclePointAtAngle(angle);
				}
				else
				{
					point = CirclePointAtAngle((float)(num + 1) * ArcSlotOffset);
				}
