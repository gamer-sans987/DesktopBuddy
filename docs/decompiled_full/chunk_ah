			}
			UnregisterEvents();
			if (num >= 0)
			{
				_currentStream = Stream.Target;
				if (UseFilteredData.Value)
				{
					base.AudioSystem.AudioInputs[num].NewFilteredSamples += OnNewAudioData;
				}
				else
				{
					base.AudioSystem.AudioInputs[num].NewRawSamples += OnNewAudioData;
				}
				lastFilteredData = UseFilteredData.Value;
			}
			lastDeviceIndex = num;
		}

		private void UnregisterEvents()
		{
			if (lastDeviceIndex >= 0)
			{
				_currentStream = null;
				if (lastFilteredData)
				{
					base.AudioSystem.AudioInputs[lastDeviceIndex].NewFilteredSamples -= OnNewAudioData;
				}
				else
				{
					base.AudioSystem.AudioInputs[lastDeviceIndex].NewRawSamples -= OnNewAudioData;
				}
				lastDeviceIndex = -1;
				_writeState = default(CircularBufferWriteState<StereoSample>);
			}
		}

