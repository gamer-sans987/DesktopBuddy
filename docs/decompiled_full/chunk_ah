			PauseLocomotionAnimation = new Sync<bool>();
			OverrideLocomotionVelocity = new Sync<Elements.Core.float3?>();
			OverrideLocomotionAngularVelocity = new Sync<float?>();
			SimulationSpeedRatio = new Sync<float>();
			_defaultConfig = new SyncRef<LocomotionAnimationConfiguration>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => ScreenController, 
				4 => BodyHorizontalAngle, 
				5 => RenderDebugVisuals, 
				6 => PauseLocomotionAnimation, 
				7 => OverrideLocomotionVelocity, 
				8 => OverrideLocomotionAngularVelocity, 
				9 => SimulationSpeedRatio, 
				10 => _defaultConfig, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static UserPoseController __New()
		{
			return new UserPoseController();
		}
