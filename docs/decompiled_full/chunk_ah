		private Slot SetupBodyNode(Slot slot, string name, BodyNode node, User user)
		{
			Slot slot2 = slot.AddSlot(name);
			TransformStreamDriver transformStreamDriver = slot2.AttachComponent<TransformStreamDriver>();
			TrackedDevicePositioner trackedDevicePositioner = slot2.AttachComponent<TrackedDevicePositioner>();
			trackedDevicePositioner.AutoBodyNode.Value = node;
			trackedDevicePositioner.PoseFilter.Target = user.Root.GetRegisteredComponent<UserPoseController>();
			ValueStream<Elements.Core.float3> orAddPositionStream = GetOrAddPositionStream(user, node.ToString());
			ValueStream<Elements.Core.floatQ> orAddRotationStream = GetOrAddRotationStream(user, node.ToString());
			transformStreamDriver.PositionStream.Target = orAddPositionStream;
			transformStreamDriver.RotationStream.Target = orAddRotationStream;
			transformStreamDriver.Position.Target = slot2.Position_Field;
			transformStreamDriver.Rotation.Target = slot2.Rotation_Field;
			return slot2;
		}

		private void SetupStreamSync(Slot slot, User user, string name, bool allowOffsets = false, bool scale = false, bool resetOnDestroy = false, bool rootSpace = false, bool beforePhysics = false)
		{
			ValueStream<Elements.Core.float3> orAddPositionStream = GetOrAddPositionStream(user, name + ".Position");
			ValueStream<Elements.Core.floatQ> orAddRotationStream = GetOrAddRotationStream(user, name + ".Rotation");
			TransformStreamDriver transformStreamDriver = slot.AttachComponent<TransformStreamDriver>();
			transformStreamDriver.ResetStreamsOnDestroy.Value = resetOnDestroy;
			transformStreamDriver.AllowOffsets.Value = allowOffsets;
			transformStreamDriver.PositionStream.Target = orAddPositionStream;
			transformStreamDriver.RotationStream.Target = orAddRotationStream;
			transformStreamDriver.Position.Target = slot.Position_Field;
			transformStreamDriver.Rotation.Target = slot.Rotation_Field;
			transformStreamDriver.RunBeforePhysics.Value = beforePhysics;
			if (scale)
			{
				ValueStream<Elements.Core.float3> orAddScaleStream = GetOrAddScaleStream(user, name + ".Scale");
				transformStreamDriver.ScaleStream.Target = orAddScaleStream;
				transformStreamDriver.Scale.Target = slot.Scale_Field;
			}
			if (rootSpace)
			{
				bool created;
				ReferenceStream<Slot> streamOrAdd = GetStreamOrAdd<ReferenceStream<Slot>>(user, name + ".RootSpace", out created);
				if (created)
				{
					streamOrAdd.SetUpdatePeriod(orAddPositionStream.Period, orAddPositionStream.Phase);
				}
				transformStreamDriver.RootSpaceStream.Target = streamOrAdd;
			}
		}

		private void InstallLocomotionModules(LocomotionController locomotion)
		{
