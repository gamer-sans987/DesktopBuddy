	public class LightTool : Tool
	{
		public enum Mode
		{
			PointLight,
			Spotlight,
			MoveSun
		}

		public readonly Sync<Mode> LightMode;

		public readonly Sync<Elements.Core.colorX> Color;

		public readonly Sync<float> Intensity;

		public readonly Sync<ShadowType> ShadowType;

		[Range(0f, 1f, "0.00")]
		public readonly Sync<float> ShadowStrength;

		public readonly Sync<float> Range;

		public readonly Sync<float> SpotAngle;

		public readonly SyncRef<Slot> PointLightVisual;

		public readonly SyncRef<Slot> SpotlightVisual;

		public readonly SyncRef<Slot> DirectionalLightVisual;

		public readonly SyncList<FieldDrive<Elements.Core.colorX>> ColorIndicators;

		public readonly Sync<bool> ShowGizmo;

		protected readonly SyncRef<LegacySegmentCircleMenuController.Item> _pointLightItem;

		protected readonly SyncRef<LegacySegmentCircleMenuController.Item> _spotLightItem;

		protected readonly SyncRef<LegacySegmentCircleMenuController.Item> _directionalLightItem;

		protected readonly SyncRef<LegacySegmentCircleMenuController.Item> _shadowsItem;

		protected readonly SlotCleanupRef<ColorDialogInterface> _colorPicker;

		private Light _light;

		private float _referenceRange;

		private Elements.Core.float3 _referencePosition;

		private Elements.Core.floatQ _referenceRotation;

		private Elements.Core.float3 _visualLocalScale;

		private Slot _visualParent;

		public static Elements.Core.colorX ACTIVE_LIGHT_MODE_COLOR => new Elements.Core.colorX(1f, 0.8f, 0.2f);

		public static Elements.Core.colorX INACTIVE_LIGHT_MODE_COLOR => new Elements.Core.colorX(0.3f, 0.1f, 0f);

		public override bool UsesLaser => false;

		public override string PrimaryDescription => this.GetLocalized("Tutorial.Tooltip.LightPrimary");

		public override string SecondaryDescription => this.GetLocalized("Tutorial.Tooltip.LightSecondary");

		protected override Elements.Core.float3 DefaultLocalTip
		{
			get
			{
				Elements.Core.float3 globalPoint = LightMode.Value switch
				{
					Mode.PointLight => PointLightVisual.Target?.GlobalPosition ?? Elements.Core.float3.Zero, 
					Mode.Spotlight => SpotlightVisual.Target?.GlobalPosition ?? Elements.Core.float3.Zero, 
					Mode.MoveSun => DirectionalLightVisual.Target?.GlobalPosition ?? Elements.Core.float3.Zero, 
					_ => Elements.Core.float3.Zero, 
				};
				return base.Slot.GlobalPointToLocal(in globalPoint) + Elements.Core.float3.Forward * 0.05f;
			}
		}

		public override bool CanUseWhenHolding => true;

		protected override void OnAwake()
		{
			base.OnAwake();
			Color.Value = Elements.Core.colorX.White;
			Intensity.Value = 1f;
			ShadowType.Value = Renderite.Shared.ShadowType.None;
			ShadowStrength.Value = 1f;
			Range.Value = 10f;
			SpotAngle.Value = 60f;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (PointLightVisual.Target != null)
			{
				PointLightVisual.Target.ActiveSelf = LightMode.Value == Mode.PointLight;
			}
			if (SpotlightVisual.Target != null)
			{
				SpotlightVisual.Target.ActiveSelf = LightMode.Value == Mode.Spotlight;
			}
			if (DirectionalLightVisual.Target != null)
			{
				DirectionalLightVisual.Target.ActiveSelf = LightMode.Value == Mode.MoveSun;
			}
			if (_pointLightItem.Target != null)
			{
				LegacyUIStyle.SetItemColor(_pointLightItem.Target, GetLightItemColor(LightMode.Value == Mode.PointLight));
			}
			if (_spotLightItem.Target != null)
			{
				LegacyUIStyle.SetItemColor(_spotLightItem.Target, GetLightItemColor(LightMode.Value == Mode.Spotlight));
			}
			if (_directionalLightItem.Target != null)
			{
				LegacyUIStyle.SetItemColor(_directionalLightItem.Target, GetLightItemColor(LightMode.Value == Mode.MoveSun));
			}
			if (_shadowsItem.Target != null)
			{
				_shadowsItem.Target.Label.Target.Text.Value = "Shadows: " + ShadowType.Value;
			}
			foreach (FieldDrive<Elements.Core.colorX> colorIndicator in ColorIndicators)
			{
				if (colorIndicator.Target != null)
				{
					colorIndicator.Target.Value = Color.Value;
				}
			}
		}

		private Elements.Core.colorX GetLightItemColor(bool enabled)
		{
			if (!enabled)
			{
				return INACTIVE_LIGHT_MODE_COLOR;
			}
			return ACTIVE_LIGHT_MODE_COLOR;
		}

		private void SetColor(Elements.Core.colorX color)
		{
			Color.Value = color;
		}

		public override void Update(float primaryStrength, Elements.Core.float2 secondaryAxis, Digital primary, Digital secondary)
		{
			if (secondary.Held)
			{
				if (secondaryAxis.Magnitude > 0.5f)
				{
					float h = MathX.Atan2(in secondaryAxis) / (MathF.PI * 2f);
					Color.Value = new ColorHSV(h, 1f, 1f).ToRGB(ColorProfile.Linear);
				}
				else
				{
					Color.Value = Elements.Core.colorX.White;
				}
			}
		}

		public override void OnPrimaryPress()
		{
			switch (LightMode.Value)
			{
			case Mode.PointLight:
			case Mode.Spotlight:
			{
				Slot target;
				LightType value;
				if (LightMode.Value == Mode.PointLight)
				{
					target = PointLightVisual.Target;
					value = LightType.Point;
				}
				else
				{
					target = SpotlightVisual.Target;
					value = LightType.Spot;
				}
				if (target != null)
				{
					_referenceRange = Range.Value;
					_visualParent = target.Parent;
					_referencePosition = base.Slot.GlobalPointToLocal(target.GlobalPosition);
					_referenceRotation = base.Slot.GlobalRotationToLocal(target.GlobalRotation);
					_visualLocalScale = target.LocalScale;
					target.Parent = null;
					Slot slot = base.LocalUserSpace.AddSlot("Point Light");
					slot.CreateSpawnUndoPoint();
					slot.GlobalPosition = target.GlobalPosition;
					slot.Forward = base.Slot.Forward;
					_light = slot.AttachComponent<Light>();
					_light.LightType.Value = value;
					SetLightProperties(_light);
					if ((bool)ShowGizmo)
					{
						_light.ActivateGizmo();
					}
				}
				break;
			}
			case Mode.MoveSun:
				_light = base.World.RootSlot.GetComponentInChildren((Light l) => l.LightType.Value == LightType.Directional);
				if (_light != null)
				{
					base.World.BeginUndoBatch("Undo.MoveSun".AsLocaleKey());
					_light.Intensity.CreateUndoPoint();
					_light.ShadowStrength.CreateUndoPoint();
					_light.ShadowType.CreateUndoPoint();
					_light.Color.CreateUndoPoint();
					_light.Slot.Rotation_Field.CreateUndoPoint();
					base.World.EndUndoBatch();
				}
				break;
			}
		}

		private void SetLightProperties(Light light)
		{
			light.ShadowType.Value = ShadowType;
			light.ShadowStrength.Value = ShadowStrength;
			light.Color.Value = Color;
			light.Intensity.Value = Intensity;
			light.SpotAngle.Value = SpotAngle;
		}

		public override void OnPrimaryHold()
		{
			switch (LightMode.Value)
			{
			case Mode.PointLight:
			case Mode.Spotlight:
				UpdateLightRange();
				break;
			case Mode.MoveSun:
				if (_light != null)
				{
					_light.Slot.Forward = -base.Slot.Forward;
					_light.Intensity.Value = MathX.Clamp01(MathX.Dot(base.Slot.Forward, Elements.Core.float3.Up) * 10f) * (float)Intensity;
					_light.Enabled = MathX.Dot(base.Slot.Forward, Elements.Core.float3.Up) > 0f;
					_light.Color.Value = Color;
					_light.ShadowType.Value = ShadowType;
				}
				break;
			}
		}

		public override void OnPrimaryRelease()
		{
			switch (LightMode.Value)
			{
			case Mode.PointLight:
			case Mode.Spotlight:
			{
				UpdateLightRange();
				Slot slot = ((LightMode.Value != Mode.PointLight) ? SpotlightVisual.Target : PointLightVisual.Target);
				if (slot != null)
				{
					_light.RemoveGizmo();
					Slot slot2 = slot.Duplicate(_light.Slot);
					slot2.AttachComponent<ObjectRoot>();
					LightOrb lightOrb = _light.Slot.AttachComponent<LightOrb>();
					_light.Slot.AttachComponent<Grabbable>().Scalable.Value = true;
					PBS_Metallic material = _light.Slot.AttachComponent<PBS_Metallic>();
					material.AlbedoColor.Value = new Elements.Core.colorX(0.1f);
					material.Smoothness.Value = 0.8f;
					material.Metallic.Value = 0.2f;
					material.EmissiveColor.Value = Elements.Core.colorX.Black;
					slot2.ForeachComponentInChildren(delegate(MeshRenderer r)
					{
						r.Material.Target = material;
					});
					lightOrb.EmissionColor.Target = material.EmissiveColor;
					lightOrb.Light.Target = _light;
					lightOrb.FlipOnTouch.Value = true;
					slot.Parent = _visualParent;
					slot.GlobalPosition = base.Slot.LocalPointToGlobal(in _referencePosition);
					slot.GlobalRotation = base.Slot.LocalRotationToGlobal(in _referenceRotation);
					slot.Scale_Field.TweenFromTo(Elements.Core.float3.Zero, _visualLocalScale, 0.1f, CurvePreset.Smoother);
				}
				break;
			}
			}
			_light = null;
			_visualParent = null;
		}

