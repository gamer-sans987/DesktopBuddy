			foreach (Slot child in LocomotionModules.Target.Children)
			{
				child.Duplicate(locomotionModulesRoot).SetIdentityTransform();
			}
			locomotion.LocomotionModules.AddRange(locomotionModulesRoot.GetComponentsInChildren<ILocomotionModule>());
			if (ForceDefaultLocomotionModule.Target != null)
			{
				locomotion.OnInitialized.Target = LocomotionControllerInitialized;
				for (int i = 0; i < LocomotionModules.Target.ChildrenCount && !ForceDefaultLocomotionModule.Target.IsChildOfElement(LocomotionModules.Target[i]); i++)
				{
				}
			}
			locomotion.ValidateLocomotionMode();
		}

		[SyncMethod(typeof(Delegate), null)]
		private void LocomotionControllerInitialized(LocomotionController locomotionController)
		{
			for (int i = 0; i < LocomotionModules.Target.ChildrenCount; i++)
			{
				if (ForceDefaultLocomotionModule.Target.IsChildOfElement(LocomotionModules.Target[i]))
				{
					Slot locomotionModulesRoot = locomotionController.LocomotionModulesRoot;
					if (locomotionModulesRoot.ChildrenCount > i)
					{
						locomotionController.ActiveModule = locomotionModulesRoot[i].GetComponentInChildren<ILocomotionModule>();
					}
					break;
				}
			}
		}

