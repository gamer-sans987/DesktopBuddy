			private ValueStream<T> GetStream<T>(SyncList<Driver<T>> drivers, ControllerProperty property, T minValue, T maxValue)
			{
				Driver<T> driver = drivers.FirstOrDefault((Driver<T> d) => d.PropertyIndex.Value == property.Index);
				if (driver == null)
				{
					ValueStream<T> valueStream = OwnerUser.AddStream<ValueStream<T>>();
					valueStream.Name = $"Input.{DeviceIndex.Value}.{property.Name}";
					valueStream.Encoding = ValueEncoding.Quantized;
					if (typeof(T) != typeof(bool))
					{
						IQuantizationDefaults<T> quantizationDefaults = property.Quantization as IQuantizationDefaults<T>;
						valueStream.SetUpdatePeriod(quantizationDefaults?.Period ?? 2, (quantizationDefaults?.Phase).GetValueOrDefault());
						if (quantizationDefaults == null || quantizationDefaults.Interpolate)
						{
							valueStream.SetInterpolation();
						}
						if (quantizationDefaults != null)
						{
							valueStream.FullFrameBits = quantizationDefaults.Bits;
							valueStream.FullFrameMin = quantizationDefaults.Min;
							valueStream.FullFrameMax = quantizationDefaults.Max;
						}
						else
						{
							valueStream.FullFrameBits = 10;
							valueStream.FullFrameMin = minValue;
							valueStream.FullFrameMax = maxValue;
						}
					}
					else
					{
						IQuantizationDefaults<T> quantizationDefaults2 = property.Quantization as IQuantizationDefaults<T>;
						valueStream.SetUpdatePeriod(quantizationDefaults2?.Period ?? 2, (quantizationDefaults2?.Phase).GetValueOrDefault());
					}
					driver = drivers.Add();
					driver.Stream.Target = valueStream;
					driver.PropertyIndex.Value = property.Index;
				}
				return driver.Stream.Target;
			}

