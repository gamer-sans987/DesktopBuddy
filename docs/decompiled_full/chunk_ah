				float num5 = num2 + item2.AngleOffset.Value * (MathF.PI / 180f);
				Elements.Core.float3 spacePoint = Elements.Core.floatQ.AxisAngleRad(normal, num5) * ortho;
				Elements.Core.floatQ spaceRotation = Elements.Core.floatQ.AxisAngleRad(normal, num5 + num4);
				if (item2.Root.Target != null)
				{
					item2.Root.Target.LocalPosition = item2.Root.Target.Parent.SpacePointToLocal(in spacePoint, base.Slot);
					item2.Root.Target.LocalRotation = item2.Root.Target.Parent.SpaceRotationToLocal(in spaceRotation, base.Slot);
				}
				num2 += num3;
			}
		}

