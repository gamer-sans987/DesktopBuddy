				}
				if (_lastPoint.Target == null)
				{
					Slot slot = raycastHit.Collider.Slot.AddSlot("Meter");
					slot.GlobalScale = Elements.Core.float3.One;
					CreateMeter(SpawnPoint(slot, raycastHit.Point));
					break;
				}
				AppendPoint(SpawnPoint(raycastHit.Collider.Slot, raycastHit.Point));
				if (!MultiPoint.Value)
				{
					FinishMeter();
				}
				break;
			}
			case Mode.Perpendicular:
			{
				RaycastHit raycastHit = RaycastTarget();
				if (raycastHit.Collider != null)
				{
					Slot slot = raycastHit.Collider.Slot.AddSlot("Meter");
					slot.GlobalScale = Elements.Core.float3.One;
					Slot initialPoint = SpawnPoint(slot, raycastHit.Point, grabbable: true);
					Slot newPoint = SpawnPoint(slot, raycastHit.Point);
					RaycastDriver raycastDriver = newPoint.AttachComponent<RaycastDriver>();
					raycastDriver.Origin.Target = initialPoint;
					raycastDriver.Direction.Value = initialPoint.GlobalDirectionToLocal(in raycastHit.Normal);
					raycastDriver.IgnoreHierarchy.Target = slot;
					if ((bool)RaycastIgnoresUsers)
					{
						raycastDriver.Filter.Target = FilterUsers;
					}
					CreateMeter(initialPoint);
					AppendPoint(newPoint);
					FinishMeter();
				}
				break;
			}
			case Mode.Drag:
			{
				Slot slot = base.World.AddSlot("Meter");
				slot.GlobalPosition = base.Tip;
				if (_lastPoint.Target == null)
				{
					Slot initialPoint = SpawnPoint(slot, base.Tip, grabbable: true);
					CreateMeter(initialPoint);
				}
				Slot newPoint = SpawnPoint(slot, base.Tip, grabbable: true);
				AppendPoint(newPoint);
				break;
			}
			}
		}

