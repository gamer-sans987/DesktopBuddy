			}
			bounds = root.ComputeBoundingBox(includeInactive: false, _visual, null, searchBlock);
			float num = MathX.MaxComponent(bounds.Size);
			if (num <= 0f)
			{
				return false;
			}
			if (num >= (float)MaxItemSize)
			{
				return false;
			}
			return true;
		}

		public float? GetReceiveDistance(IGrabbable grabbable, Grabber grabber)
		{
			if (grabber == IgnoreGrabber.Target)
			{
				return null;
			}
			if (grabbable.Slot.IsChildOf(base.Slot, includeSelf: true))
			{
				return null;
			}
			if (!VerifyItemSize(grabbable.Slot, out var bounds))
			{
				return null;
			}
			bounds.Size *= 0.5f;
			bool flag = AcceptPoint(bounds.Center);
			if (!flag)
			{
				for (int i = 0; i < 8; i++)
				{
					if (AcceptPoint(bounds.GetVertexPoint(i)))
					{
						flag = true;
						break;
					}
				}
			}
			if (!flag)
			{
				return null;
			}
			return bounds.Center.Magnitude;
		}

		public void Receive(IGrabbable grabbable, Grabber grabber)
		{
			grabbable.Slot.SetParent(_content);
			base.Slot.TryVibrateMedium();
			_material.Target.EmissiveColor.TweenFromTo(Elements.Core.colorX.Yellow, Elements.Core.colorX.Black, 0.25f);
		}

		private bool AcceptPoint(Elements.Core.float3 point)
		{
			Elements.Core.float3 v = point;
			if (v.z < 0f)
			{
				return false;
			}
			if (MathX.MaxComponent(MathX.Abs(in v) - new Elements.Core.float3(_collider.Target.Size.Value.x * 0.5f + (float)MaxPlaneDistance, _collider.Target.Size.Value.y * 0.5f + (float)MaxPlaneDistance, MaxHeightDistance)) > 0f)
			{
				return false;
			}
			return true;
		}

		private IEnumerator<Context> RecalculateLength()
		{
			do
			{
				yield return Context.WaitForNextUpdate();
				Elements.Core.BoundingBox boundingBox = _content.Target.ComputeBoundingBox(includeInactive: false, base.Slot);
				float value = ((GrowDirection.Value != Direction.Left) ? (boundingBox.max.x + (float)MinLength) : (0f - boundingBox.min.x + (float)MinLength));
				_targetLength.Value = value;
			}
			while (!_content.Target.AreBoundingBoxesAvailable());
		}

