	public class SimpleAwayIndicator : Component, IMeshBakeEventReceiver, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable, ICustomInspector
	{
		public readonly SyncRef<User> User;

		public readonly AssetRef<Material> AwayMaterial;

		public readonly SyncRef<MeshRenderer> Renderer;

		protected readonly SyncAssetList<Material> _oldMaterials;

		public override int Version => 1;

		private bool IsSetToAway => _oldMaterials.Count > 0;

		public override void OnFocusChanged(World.WorldFocus focus)
		{
			if (User.Target == base.World.LocalUser && Renderer.Target != null)
			{
				if (focus == FrooxEngine.World.WorldFocus.Focused && _oldMaterials.Count > 0)
				{
					Restore();
				}
				if (focus == FrooxEngine.World.WorldFocus.Background && _oldMaterials.Count == 0)
				{
					SetAway();
				}
			}
		}

		[SyncMethod(typeof(Action), new string[] { })]
		public void SetAway()
		{
			if (_oldMaterials.Count <= 0)
			{
				for (int i = 0; i < Renderer.Target.Materials.Count; i++)
				{
					_oldMaterials.Add(Renderer.Target.Materials[i]);
					Renderer.Target.Materials[i] = AwayMaterial.Target;
				}
			}
		}

		[SyncMethod(typeof(Action), new string[] { })]
		public void Restore()
		{
			if (_oldMaterials.Count != 0)
			{
				for (int i = 0; i < MathX.Min(Renderer.Target.Materials.Count, _oldMaterials.Count); i++)
				{
					Renderer.Target.Materials[i] = _oldMaterials[i];
				}
				_oldMaterials.Clear();
			}
		}

		public static void SetupForHierarchy(Slot root, IAssetProvider<Material> awayMaterial, User user = null)
		{
			foreach (MeshRenderer componentsInChild in root.GetComponentsInChildren<MeshRenderer>())
			{
				SimpleAwayIndicator simpleAwayIndicator = componentsInChild.Slot.AttachComponent<SimpleAwayIndicator>();
				simpleAwayIndicator.User.Target = user;
				simpleAwayIndicator.AwayMaterial.Target = awayMaterial;
				simpleAwayIndicator.Renderer.Target = componentsInChild;
			}
		}

		public void OnMeshBaked(MeshRenderer bakedMesh, bool destroyOriginal)
		{
			if (bakedMesh.Slot.GetComponent((SimpleAwayIndicator i) => i.Renderer.Target == bakedMesh) == null)
			{
				SimpleAwayIndicator simpleAwayIndicator = bakedMesh.Slot.AttachComponent<SimpleAwayIndicator>();
				simpleAwayIndicator.User.Target = User.Target;
				simpleAwayIndicator.Renderer.Target = bakedMesh;
				simpleAwayIndicator.AwayMaterial.Target = AwayMaterial.Target;
			}
			if (destroyOriginal)
			{
				Destroy();
			}
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			if (control.GetTypeVersion(GetType()) >= 1)
			{
				return;
			}
			control.OnLoaded(this, delegate
			{
				IAssetProvider<Material> target = AwayMaterial.Target;
				if (target != null && target is PBS_RimMetallic pBS_RimMetallic && pBS_RimMetallic.Transparent.Value)
				{
					Elements.Core.colorX value = pBS_RimMetallic.AlbedoColor.Value;
					if (!(value.baseColor != new Elements.Core.color(1f, 0.25f)) && pBS_RimMetallic.Metallic.Value == 0.2f && pBS_RimMetallic.Smoothness.Value == 0.8f)
					{
						AwayMaterial.Target = CreateAwayMaterial(target.Slot);
					}
				}
			});
		}

		public static IAssetProvider<Material> CreateAwayMaterial(Slot root)
		{
			FresnelMaterial fresnelMaterial = root.AttachComponent<FresnelMaterial>();
			fresnelMaterial.BlendMode.Value = BlendMode.Opaque;
			fresnelMaterial.NearColor.Value = new Elements.Core.colorX(0f, 0f, 0f);
			fresnelMaterial.FarColor.Value = new Elements.Core.colorX(0.1f, 0.1f, 0.1f);
			return fresnelMaterial;
		}

		public void BuildInspectorUI(UIBuilder ui)
		{
			WorkerInspector.BuildInspectorUI(this, ui);
			ui.Button("Inspector.SimpleAwayIndicator.TestAway".AsLocaleKey(), OnTestAway);
			ui.Button("Inspector.SimpleAwayIndicator.TestRestore".AsLocaleKey(), OnTestRestore);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnTestAway(IButton button, ButtonEventData eventData)
		{
			SetAway();
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnTestRestore(IButton button, ButtonEventData eventData)
		{
			Restore();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			User = new SyncRef<User>();
			AwayMaterial = new AssetRef<Material>();
			Renderer = new SyncRef<MeshRenderer>();
			_oldMaterials = new SyncAssetList<Material>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => User, 
				4 => AwayMaterial, 
				5 => Renderer, 
				6 => _oldMaterials, 
				_ => throw new ArgumentOutOfRangeException(), 
