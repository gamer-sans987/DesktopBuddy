		private Text AddMessage(string messageId, string message, Elements.Core.colorX background, Alignment alignment = Alignment.MiddleLeft, bool setHighlight = false, float minMultiplier = 1f)
		{
			if (message == null)
			{
				UniLog.Warning("Message is null!", stackTrace: true);
				return null;
			}
			while (_messagesRoot.Target.ChildrenCount > MathX.Max(0, MaxMessages.Value))
			{
				_messagesRoot.Target[0].Destroy();
			}
			UIBuilder uIBuilder;
			if (_cachedUiBuilder != null && _cachedUiBuilderRoot == _messagesRoot.Target)
			{
				uIBuilder = _cachedUiBuilder;
			}
			else
			{
				uIBuilder = (_cachedUiBuilder = new UIBuilder(_messagesRoot.Target));
				_cachedUiBuilderRoot = _messagesRoot.Target;
			}
			StringToken stringToken = StringTokenizer.Tokenize(message, TextRenderer.RichTextTags);
			int rawLength = stringToken.GetRawLength();
			int num = stringToken.OfType<StringOpeningTag>().Count((StringOpeningTag t) => t.Tag.Substring == "sprite");
			float num2 = MathX.Max(MathX.Ceil(((float)rawLength + (float)num * 1.5f) / (base.CanvasSize.x * 0.1f)), minMultiplier);
			uIBuilder.Style.PreferredHeight = 24f * num2;
			uIBuilder.Style.TextAutoSizeMax = uIBuilder.Style.PreferredHeight;
			uIBuilder.Style.MinHeight = uIBuilder.Style.PreferredHeight;
			uIBuilder.Panel(background.SetA(0.73f));
			uIBuilder.Root.Name = messageId;
			Text result = uIBuilder.Text((LocaleString)message, bestFit: true, alignment);
			_messagesScrollRect.Target.NormalizedPosition.Value = new Elements.Core.float2(0f, 1f);
			if (setHighlight)
			{
				SetHighlight(message, background);
			}
			uIBuilder.NestOut();
			return result;
		}

		private void SetHighlight(string message, Elements.Core.colorX background)
		{
			_highlightText.Target.Content.Value = message;
			_highlightText.Target.Font.Target = _fontCollection.Target;
			_highlightPanel.Target.Tint.Value = background.SetA(0.73f);
		}

