		private Elements.Core.float3 ComputePosition(float axisPosition)
		{
			Elements.Core.float3 v = Axis.Value.Normalized;
			return v * axisPosition + Elements.Core.floatQ.LookRotation(in v) * AxisPlaneOffset.xy_;
		}

		private void AssignValues()
		{
			float num = ComputeAxisPosition();
			if (_position.IsLinkValid)
			{
