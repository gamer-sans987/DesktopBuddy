		private static string GetColor(string color)
		{
			if (string.IsNullOrWhiteSpace(color))
			{
				return "#000";
			}
			ColorHSV colorHSV = new ColorHSV(Elements.Core.colorX.FromHexCode(color));
			colorHSV.v = MathX.Min(colorHSV.v, 0.6f);
			return colorHSV.ToRGB().ToHexString();
		}

		private static string EscapeEmoteName(string emojiName)
		{
			return emojiName.Replace("<", "lt").Replace(">", "gt");
		}

