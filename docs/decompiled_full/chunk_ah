		public readonly Sync<bool> RunAfterFinalPoseUpdate;

		private bool _finalPoseUpdateRegistered;

		protected override void OnAwake()
		{
			base.OnAwake();
			TargetRotationOffset.Value = Elements.Core.floatQ.Identity;
