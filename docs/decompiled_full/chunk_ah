		public readonly Sync<float> Arc;

		public readonly Sync<bool> FillWholeArc;

		public readonly Sync<float> RotationOffset;

		public readonly SyncList<Item> Items;

		protected override void OnAwake()
		{
			base.OnAwake();
			Axis.Value = Elements.Core.float3.Up;
			Radius.Value = 1f;
			Arc.Value = 360f;
		}

		public override void AddChild(Slot child)
		{
			if (!Items.Any((Item item) => item.Root.Target == child))
			{
				Items.Add().Root.Target = child;
			}
		}

		public override void RemoveChild(Slot child)
		{
			Items.RemoveAll((Item item) => item.Root.Target == child || item.Root.Target == null);
		}

		protected override void OnChanges()
		{
			int num = Items.Count;
			if (num == 0)
			{
				return;
			}
			foreach (Item item in Items)
			{
				if (item.Root.Target != null)
				{
					item._position.ForceLink(item.Root.Target.Position_Field);
					item._rotation.ForceLink(item.Root.Target.Rotation_Field);
				}
			}
			if (FillWholeArc.Value && num > 1)
			{
				num--;
			}
			float num2 = Offset.Value * (MathF.PI / 180f);
			float num3 = Arc.Value / (float)num * (MathF.PI / 180f);
			Elements.Core.float3 normal = Axis.Value;
			MathX.Orthonormals(in normal, out var ortho, out var _);
			ortho = ortho.Normalized * Radius;
			float num4 = (float)RotationOffset * (MathF.PI / 180f);
			foreach (Item item2 in Items)
