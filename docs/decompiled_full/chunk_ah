			});
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			IsRecording.Value = RecordingUser.Target != null;
			if (RecordingUser.Target != base.LocalUser && _recorder != null)
			{
				FinishRecording();
			}
		}

		public override void OnPrimaryPress()
		{
			if (RecordingUser.Target == base.LocalUser)
			{
				FinishRecording();
			}
			else
			{
				StartRecording();
			}
		}

		public override void OnPrimaryRelease()
		{
			if (Mode.Value == RecordMode.Hold)
			{
				FinishRecording();
			}
		}

		private void StartRecording()
		{
			if (base.World.Focus != FrooxEngine.World.WorldFocus.Background)
			{
				_isSafeRecording = !ToolSimulator.IsSimulating;
				RecordingUser.Target = base.LocalUser;
				RecordingStartTime.SetNow();
				AudioEncodeSettings audioEncodeSettings = Format.Value switch
				{
					RecordFormat.WAV => new WavEncodeSettings(), 
					RecordFormat.OGG_Vorbis => new VorbisEncodeSettings
					{
						Quality = Quality
					}, 
					RecordFormat.FLAC => new FlacEncodeSettings(), 
					_ => throw new Exception("Invalid encode format: " + Format), 
				};
				audioEncodeSettings.Channels = ChannelConfiguration.Stereo;
				audioEncodeSettings.SampleRate = base.Engine.AudioSystem.SampleRate;
				_recorder = new AudioInputRecorder(base.AudioSystem.DefaultAudioInput, audioEncodeSettings, CanRecord);
				_recorder.StartRecording(Source.Value == DataSource.Raw);
			}
		}

		private bool CanRecord()
		{
			if (base.World.Focus == FrooxEngine.World.WorldFocus.Background)
			{
				return false;
			}
			if (!_isSafeRecording && (base.LocalUser.VoiceMode < VoiceMode.Normal || base.LocalUser.RecordingVoiceMessage))
			{
				return false;
			}
			return true;
		}

		private void FinishRecording()
		{
			if (_recorder == null)
			{
				return;
			}
			_recorder.StopRecording();
			AudioInputRecorder finishedRecorder = _recorder;
			_recorder = null;
			if (!base.IsDisposed)
			{
				StartTask(async delegate
				{
					await SaveAndSpawnRecording(finishedRecorder);
				});
				if (RecordingUser.Target == base.LocalUser)
				{
					RecordingUser.Target = null;
				}
			}
		}

		private async Task SaveAndSpawnRecording(AudioInputRecorder recorder)
		{
			if (recorder.Audio.SampleCount != 0)
			{
				string name = $"Audio Recording by {base.LocalUser.UserName} - {DateTime.Now.ToLongTimeString()} {DateTime.Now.ToShortDateString()}";
				Slot s = base.LocalUserSpace.AddSlot("Audio Recording");
				s.PositionInFrontOfUser(Elements.Core.float3.Backward);
				s.PersistentSelf = false;
				s.AttachComponent<AudioMetadata>().SetFromCurrentWorld();
				await default(ToBackground);
				AudioX audio = recorder.FinishRecording();
				Uri uri = await base.Engine.LocalDB.SaveAssetAsync(audio).ConfigureAwait(continueOnCapturedContext: false);
				await default(ToWorld);
				s.PersistentSelf = true;
				AudioPlayerInterface obj = await s.SpawnEntity<AudioPlayerInterface, LegacyAudioPlayer>(FavoriteEntity.AudioPlayer);
				obj.InitializeEntity(name);
				obj.SetSource(uri);
			}
		}

		protected override void OnDispose()
		{
			FinishRecording();
			base.OnDispose();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Format = new Sync<RecordFormat>();
			Quality = new Sync<float>();
			Mode = new Sync<RecordMode>();
			Source = new Sync<DataSource>();
			RecordingUser = new SyncRef<User>();
			RecordingStartTime = new SyncTime();
			IsRecording = new RawOutput<bool>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => _equipLink, 
				4 => TipReference, 
				5 => BlockGripEquip, 
				6 => BlockRemoteEquip, 
				7 => EquipName, 
				8 => _overrideActiveTool, 
				9 => _gripPosesGenerated, 
				10 => Format, 
				11 => Quality, 
				12 => Mode, 
				13 => Source, 
				14 => RecordingUser, 
				15 => RecordingStartTime, 
				16 => IsRecording, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

