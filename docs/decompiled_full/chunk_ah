		private FullBodyTrackers ClassifyTrackers()
		{
			for (int i = 0; i < _candidates.Length; i++)
			{
				if (_candidates[i] == null)
				{
					_candidates[i] = new List<PotentialBodyNode>();
				}
				else
				{
					_candidates[i].Clear();
				}
			}
			Elements.Core.float3 a = base.InputInterface.GetBodyNode(BodyNode.Head).Position;
			Elements.Core.floatQ rotation = base.InputInterface.GetBodyNode(BodyNode.Head).Rotation;
			Elements.Core.float3 to = base.InputInterface.GetBodyNode(BodyNode.LeftHand).Position;
			Elements.Core.float3 to2 = base.InputInterface.GetBodyNode(BodyNode.RightHand).Position;
			Elements.Core.float3 a2 = a + Elements.Core.float3.Down * 1.6f;
			Elements.Core.float3 b = a2 + Elements.Core.float3.Up * 0.45f;
			SetRefPosition(CandidateNode.Feet, a2);
			SetRefPosition(CandidateNode.Hips, a2 + Elements.Core.float3.Up * 0.9f);
			SetRefPosition(CandidateNode.Chest, a2 + Elements.Core.float3.Up * 1.35f);
			SetRefPosition(CandidateNode.Knees, b);
			SetRefPosition(CandidateNode.LeftElbow, MathX.Lerp(in a, in to, 0.6f));
			SetRefPosition(CandidateNode.RightElbow, MathX.Lerp(in a, in to2, 0.6f));
			base.Slot.LocalScaleToGlobal(0.5f);
			List<ITrackedDevice> list = Pool.BorrowList<ITrackedDevice>();
			foreach (Tracker tracker in _trackers)
			{
				if (!tracker.TrackedDevice.Target.AutoBodyNode.Value.HasValue && tracker.TrackedDevice.Target.TrackedDevice != null && tracker.TrackedDevice.Target.TrackedDevice.IsTracking)
				{
					list.Add(tracker.TrackedDevice.Target.TrackedDevice);
				}
			}
			foreach (ITrackedDevice item in list)
			{
				Elements.Core.float3 a3 = item.Position;
				float num = float.MaxValue;
				CandidateNode candidateNode = CandidateNode.Feet;
				for (CandidateNode candidateNode2 = CandidateNode.Feet; candidateNode2 < CandidateNode.COUNT; candidateNode2++)
				{
					float num2 = MathX.Distance(in a3, GetRefPosition(candidateNode2));
					if (!(num2 > 0.5f) && num2 < num)
					{
						num = num2;
						candidateNode = candidateNode2;
					}
				}
				if (num < float.MaxValue)
				{
					if (candidateNode == CandidateNode.Knees)
					{
						float distance = MathX.Distance(in a3, GetRefPosition(CandidateNode.Feet));
						GetCandidates(CandidateNode.Feet).Add(new PotentialBodyNode(item, distance));
					}
					else
					{
						GetCandidates(candidateNode).Add(new PotentialBodyNode(item, num));
					}
				}
			}
			Pool.Return(ref list);
			List<PotentialBodyNode> candidates = GetCandidates(CandidateNode.Hips);
			List<PotentialBodyNode> candidates2 = GetCandidates(CandidateNode.Chest);
			List<PotentialBodyNode> candidates3 = GetCandidates(CandidateNode.Feet);
			List<PotentialBodyNode> candidates4 = GetCandidates(CandidateNode.Knees);
			candidates.Sort((PotentialBodyNode potentialBodyNode7, PotentialBodyNode potentialBodyNode8) => potentialBodyNode7.distance.CompareTo(potentialBodyNode8.distance));
			candidates3.Sort((PotentialBodyNode potentialBodyNode7, PotentialBodyNode potentialBodyNode8) => potentialBodyNode7.distance.CompareTo(potentialBodyNode8.distance));
			FullBodyTrackers result = default(FullBodyTrackers);
			if (candidates3.Count >= 2)
			{
				PotentialBodyNode potentialBodyNode = candidates3[0];
				PotentialBodyNode potentialBodyNode2 = candidates3[1];
				Elements.Core.float3 @float = rotation.Inverted * potentialBodyNode.tracker.Position;
				Elements.Core.float3 float2 = rotation.Inverted * potentialBodyNode2.tracker.Position;
				if (@float.x > float2.x)
				{
					PotentialBodyNode potentialBodyNode3 = potentialBodyNode;
					potentialBodyNode = potentialBodyNode2;
					potentialBodyNode2 = potentialBodyNode3;
				}
				result.leftFoot = potentialBodyNode.tracker;
				result.rightFoot = potentialBodyNode2.tracker;
			}
			for (int num3 = 2; num3 < candidates3.Count; num3++)
			{
				Elements.Core.float3 a4 = candidates3[num3].tracker.Position;
				candidates4.Add(new PotentialBodyNode(candidates3[num3].tracker, MathX.Distance(in a4, in b)));
			}
			candidates4.Sort((PotentialBodyNode potentialBodyNode7, PotentialBodyNode potentialBodyNode8) => potentialBodyNode7.distance.CompareTo(potentialBodyNode8.distance));
			if (candidates4.Count >= 2)
			{
				PotentialBodyNode potentialBodyNode4 = candidates4[0];
				PotentialBodyNode potentialBodyNode5 = candidates4[1];
				Elements.Core.float3 float3 = rotation.Inverted * potentialBodyNode4.tracker.Position;
				Elements.Core.float3 float4 = rotation.Inverted * potentialBodyNode5.tracker.Position;
				if (float3.x > float4.x)
				{
					PotentialBodyNode potentialBodyNode6 = potentialBodyNode4;
					potentialBodyNode4 = potentialBodyNode5;
					potentialBodyNode5 = potentialBodyNode6;
				}
				result.leftKnee = potentialBodyNode4.tracker;
				result.rightKnee = potentialBodyNode5.tracker;
			}
			if (candidates.Count >= 1)
			{
				result.hips = candidates[0].tracker;
			}
			Elements.Core.float3 b2 = GetRefPosition(CandidateNode.Chest);
			for (int num4 = 1; num4 < candidates.Count; num4++)
			{
				Elements.Core.float3 a5 = candidates[num4].tracker.Position;
				if (result.hips.Position.y < a5.y)
				{
					candidates2.Add(new PotentialBodyNode(candidates[num4].tracker, MathX.Distance(in a5, in b2)));
				}
			}
			candidates2.Sort((PotentialBodyNode potentialBodyNode7, PotentialBodyNode potentialBodyNode8) => potentialBodyNode7.distance.CompareTo(potentialBodyNode8.distance));
			if (candidates2.Count >= 1)
			{
				result.chest = candidates2[0].tracker;
			}
			List<PotentialBodyNode> candidates5 = GetCandidates(CandidateNode.LeftElbow);
			List<PotentialBodyNode> candidates6 = GetCandidates(CandidateNode.RightElbow);
			if (candidates5.Count >= 1)
			{
				result.leftElbow = candidates5[0].tracker;
			}
			if (candidates6.Count >= 1)
			{
				result.rightElbow = candidates6[0].tracker;
			}
			return result;
		}

