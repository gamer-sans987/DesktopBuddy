		public void BuildDevices(User user, UserRoot userRoot, Slot userSlot, out Slot head, out List<InteractionHandler> commmonTools)
		{
			UserInfo userInfo = userSlot.AttachComponent<UserInfo>();
			UserPoseController userPoseController = userSlot.AttachComponent<UserPoseController>();
			ScreenController target = userSlot.AttachComponent<ScreenController>();
			userRoot.ScreenController.Target = target;
			if (userPoseController != null)
			{
				userPoseController.ScreenController.Target = target;
			}
			userSlot.AttachComponent<TrackingOffsetCompensator>();
			HeadOutputDevice headDevice = user.HeadDevice;
			List<ControllerInfo> list = new List<ControllerInfo>
			{
				new ControllerInfo
				{
					bodyNode = BodyNode.LeftController,
					controllerSide = Chirality.Left
				},
				new ControllerInfo
				{
					bodyNode = BodyNode.RightController,
					controllerSide = Chirality.Right
				}
			};
			bool flag = headDevice.IsCamera();
			bool flag2 = headDevice.HasVoice();
			bool flag3 = true;
			if (ForceNoVoice)
			{
				flag2 = false;
			}
			bool flag4 = !flag;
			bool value = user.EyeTracking.Value;
			bool mouthTracking = user.MouthTracking;
			UniLog.Log("User " + user.UserName + " Role: " + user.Role?.RoleName.Value + ", HasFingerTracking: " + flag4 + ", HasEyeTracking: " + value + ", HasLipTracking: " + mouthTracking);
			Slot slot = userSlot.AddSlot("View");
			TransformStreamDriver transformStreamDriver = slot.AttachComponent<TransformStreamDriver>();
			ViewReferenceController viewReferenceController = slot.AttachComponent<ViewReferenceController>();
			AvatarObjectSlot avatarObjectSlot = slot.AddSlot("BodyNode").AttachComponent<AvatarObjectSlot>();
			ValueStream<Elements.Core.float3> orAddPositionStream = GetOrAddPositionStream(user, "View");
			ValueStream<Elements.Core.floatQ> orAddRotationStream = GetOrAddRotationStream(user, "View");
			transformStreamDriver.PositionStream.Target = orAddPositionStream;
			transformStreamDriver.RotationStream.Target = orAddRotationStream;
			transformStreamDriver.Position.Target = slot.Position_Field;
			transformStreamDriver.Rotation.Target = slot.Rotation_Field;
			avatarObjectSlot.Node.Value = BodyNode.View;
			viewReferenceController.Init(orAddPositionStream, orAddRotationStream, avatarObjectSlot);
			head = SetupBodyNode(userSlot, "Head", BodyNode.Head, user);
			Slot slot2 = userSlot.AddSlot("ListenerRoot");
			PositionAtUser positionAtUser = slot2.AttachComponent<PositionAtUser>();
			positionAtUser.TargetUser.Target = user;
			positionAtUser.PositionSource.Value = UserRoot.UserNode.View;
			positionAtUser.RotationSource.Value = UserRoot.UserNode.View;
			positionAtUser.UpdateOrder = int.MinValue;
			positionAtUser.RunAfterFinalPoseUpdate.Value = true;
			Slot slot3 = slot2.AddSlot("Listener");
			AudioListener audioListener = slot3.AttachComponent<AudioListener>();
			audioListener.ActiveUser.Target = user;
			CloningReferenceSpatialVariableCollector<AudioDSP_Effect> cloningReferenceSpatialVariableCollector = slot3.AttachComponent<CloningReferenceSpatialVariableCollector<AudioDSP_Effect>>();
			cloningReferenceSpatialVariableCollector.VariableName.Value = "Resonite.Audio.Filters";
			cloningReferenceSpatialVariableCollector.Mode.Value = CloningReferenceSpatialVariableCollector.CloneMode.Slot;
			cloningReferenceSpatialVariableCollector.MakeClonesLocal.Value = true;
			cloningReferenceSpatialVariableCollector.ReferenceList.Target = audioListener.Effects;
			userRoot.PrimaryListener.Target = audioListener;
			ContextMenu contextMenu = null;
			if (!flag)
			{
				contextMenu = userSlot.AddSlot("Context Menu").AttachComponent<ContextMenu>();
				contextMenu.Owner.Target = user;
			}
			if (flag2)
			{
				bool created;
				OpusStream<MonoSample> streamOrAdd = GetStreamOrAdd<OpusStream<MonoSample>>(user, "Voice", out created);
				userSlot.AttachComponent<UserAudioStream<MonoSample>>().Stream.Target = streamOrAdd;
				userSlot.AttachComponent<AvatarVoiceInfo>().AudioSource.Target = streamOrAdd;
			}
			commmonTools = new List<InteractionHandler>();
			InteractionHandler target2 = null;
			InteractionHandler target3 = null;
			foreach (ControllerInfo item in list)
			{
				BodyNode bodyNode = item.bodyNode;
				Slot slot4 = SetupBodyNode(userSlot, bodyNode.ToString(), item.bodyNode, user);
				userInfo.Controllers.Add(slot4);
				AvatarControllerInfo avatarControllerInfo = slot4.AttachComponent<AvatarControllerInfo>();
				avatarControllerInfo.ControllerSide.Value = item.controllerSide;
				avatarControllerInfo.TargetUser.Target = user;
				slot4.AttachComponent<ControllerHapticPointMapper>().Side.Value = item.bodyNode.GetChirality();
				if (flag3)
				{
					InteractionHandlerStreamDriver interactionHandlerStreamDriver = userRoot.Slot.AttachComponent<InteractionHandlerStreamDriver>();
					interactionHandlerStreamDriver.Setup(item.controllerSide, user, 2u, 0u);
					InteractionHandler interactionHandler = slot4.AddSlot("CommonTool").AttachComponent<InteractionHandler>(runOnAttachBehavior: false);
					interactionHandler.Side.Value = item.controllerSide;
					interactionHandler.InitializeTool(interactionHandlerStreamDriver, (bool)SetupItemShelves && !user.KioskMode);
					interactionHandler.ContextMenu.Target = contextMenu;
					if (item.controllerSide == Chirality.Left)
					{
						target2 = interactionHandler;
					}
					else if (item.controllerSide == Chirality.Right)
					{
						target3 = interactionHandler;
					}
					commmonTools.Add(interactionHandler);
				}
			}
			if (list.Count > 0 || flag4)
			{
				Slot slot5 = SetupBodyNode(userSlot, "Left Hand", BodyNode.LeftHand, user);
				Slot slot6 = SetupBodyNode(userSlot, "Right Hand", BodyNode.RightHand, user);
				SetupBodyNode(userSlot, "Left Foot", BodyNode.LeftFoot, user);
				SetupBodyNode(userSlot, "Right Foot", BodyNode.RightFoot, user);
				VibrationDeviceRelay vibrationDeviceRelay = slot5.AttachComponent<VibrationDeviceRelay>();
				VibrationDeviceRelay vibrationDeviceRelay2 = slot6.AttachComponent<VibrationDeviceRelay>();
				vibrationDeviceRelay.TargetComponent.Target = target2;
				vibrationDeviceRelay2.TargetComponent.Target = target3;
				FingerPoseStreamManager fingerPoseStreamManager = userSlot.AttachComponent<FingerPoseStreamManager>();
				fingerPoseStreamManager.Setup(user, 4u, 0u);
				fingerPoseStreamManager.PoseController.Target = userPoseController;
				userSlot.AttachComponent<AvatarFingerPoseInfo>().FingerPoseSource.Target = fingerPoseStreamManager;
				TrackedHand trackedHand = slot5.AttachComponent<TrackedHand>();
				TrackedHand trackedHand2 = slot6.AttachComponent<TrackedHand>();
				trackedHand.User.Target = user;
				trackedHand2.User.Target = user;
				trackedHand.HandChirality.Value = Chirality.Left;
				trackedHand2.HandChirality.Value = Chirality.Right;
			}
			if (base.World != Userspace.UserspaceWorld)
			{
				userSlot.AttachComponent<PhotoCaptureManager>();
			}
			if (value)
			{
				EyeTrackingStreamManager eyeTrackingStreamManager = userSlot.AttachComponent<EyeTrackingStreamManager>();
				eyeTrackingStreamManager.Setup(user, 4u, 0u, user.PupilTracking.Value);
				userSlot.AttachComponent<AvatarEyeTrackingInfo>().EyeDataSource.Target = eyeTrackingStreamManager;
			}
			if (mouthTracking)
			{
				MouthTrackingStreamManager mouthTrackingStreamManager = userSlot.AttachComponent<MouthTrackingStreamManager>();
				mouthTrackingStreamManager.Setup(user, 4u, 0u);
				userSlot.AttachComponent<AvatarMouthTrackingInfo>().MouthDataSource.Target = mouthTrackingStreamManager;
			}
		}

		public void BuildAvatar(UserRoot userRoot)
		{
			User user = userRoot.ActiveUser;
			Slot slot = userRoot.Slot;
			if ((user.IsHost && DefaultHostSilenced.Value) || (!user.IsHost && DefaultClientSilenced.Value))
			{
				user.IsSilenced = true;
			}
			DynamicVariableSpace dynamicVariableSpace = slot.AttachComponent<DynamicVariableSpace>();
			dynamicVariableSpace.SpaceName.Value = "User";
			dynamicVariableSpace.OnlyDirectBinding.Value = true;
			slot.AttachComponent<SearchBlock>();
			HeadOutputDevice headDevice = user.HeadDevice;
			BuildDevices(user, userRoot, slot, out Slot _, out List<InteractionHandler> _);
			TrackerController trackerController = slot.AttachComponent<TrackerController>();
			trackerController.PositionStreamConfigurator.Target = SetupPositionStream;
			trackerController.RotationStreamConfigurator.Target = SetupRotationStream;
			if ((uint)(headDevice - 4) <= 1u)
			{
				StaticCameraDevice staticCameraDevice = slot.AttachComponent<StaticCameraDevice>();
				staticCameraDevice.Owner.Target = user;
				if (headDevice == HeadOutputDevice.StaticCamera)
				{
					slot.GlobalPosition += Elements.Core.float3.Up * 3f;
					slot.AttachComponent<Grabbable>();
					DroneCamera droneCamera = slot.AttachComponent<DroneCamera>();
					droneCamera.CameraUser.Target = user;
					droneCamera.FieldOfViewSource.Target = staticCameraDevice.FieldOfView;
					droneCamera.AspectRatioSource.Target = staticCameraDevice.AspectRatio;
				}
				if (headDevice == HeadOutputDevice.StaticCamera360)
				{
					slot.GlobalPosition = Elements.Core.float3.Up * 1.5f;
					slot.AttachComponent<Slider>();
				}
			}
			SetupStreamSync(slot, user, "Root", allowOffsets: true, scale: true, resetOnDestroy: true, rootSpace: true, beforePhysics: true);
			if ((bool)SetupLocomotion && headDevice.IsNewInteractionMode())
			{
				LocomotionController locomotionController = slot.AttachComponent<LocomotionController>();
				locomotionController.FindUserPreferredModule.Value = FindUserPreferredModule;
				if (LocomotionModules.Target != null)
				{
					InstallLocomotionModules(locomotionController);
				}
				if (!AllowLocomotion.Value)
				{
					locomotionController.SupressSources.Add(this);
				}
			}
			if (Userspace.KioskMode && !user.IsHost)
			{
				if (base.World.RootSlot.GetComponentInChildren<DebugTrackingAligner>() == null)
				{
					base.Slot.AttachComponent<DebugTrackingAligner>();
				}
				UserRoot root = base.World.AllUsers.First((User u) => u.IsHost).Root;
				slot.SetParent(root.Slot, keepGlobalTransform: false);
				slot.GetComponent<LocomotionController>()?.SupressSources.Add(this);
			}
			else
			{
				if (AlignTracking.Value && base.World.RootSlot.GetComponentInChildren<DebugTrackingAligner>() == null)
				{
					base.Slot.AttachComponent<DebugTrackingAligner>();
				}
				if (ParentClientsToServer.Value)
				{
					UserRoot root2 = base.World.AllUsers.First((User u) => u.IsHost).Root;
					slot.SetParent(root2.Slot, keepGlobalTransform: false);
				}
			}
			if (AutoInject.Target != null)
			{
				AutoInject.Target.Duplicate(userRoot.Slot);
			}
			slot.AttachComponent<HapticManager>();
			AvatarManager avatarManager = slot.AttachComponent<AvatarManager>();
			avatarManager.AutoAddNameBadge.Value = SetupNameBadges.Value;
			avatarManager.AutoAddIconBadge.Value = SetupIconBadges.Value;
			avatarManager.EmptySlotHandler.Target = EmptyAvatarSlotHandler.Target ?? this;
			if (headDevice != HeadOutputDevice.StaticCamera || headDevice != HeadOutputDevice.StaticCamera360)
			{
				avatarManager.NameTagText.Value = StringParsingHelper.SanitizeFormatTags(user.UserName);
				StartTask(async delegate
				{
					CloudResult<SkyFrost.Base.User> cloudResult = await base.Engine.Cloud.Users.GetUserCached(user.UserID);
