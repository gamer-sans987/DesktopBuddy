				float num2 = MathX.Clamp(b2.Magnitude * (float)MathX.Sign(MathX.Dot(in b, in b2)), 0f - num, num);
				float num3 = ComputeAxisPosition();
				AxisLineOffset += num2 - num3;
				AxisPlaneOffset = (Elements.Core.floatQ.LookRotation(in b).Inverted * position).xy;
				AssignValues();
			});
			_scale.SetupValueSetHook(delegate(IField<Elements.Core.float3> field, Elements.Core.float3 scale)
			{
				ReferenceScale.Value = scale;
			});
		}

		protected override void OnAttach()
		{
			_position.Target = base.Slot.Position_Field;
		}

		private float ComputeAxisPosition()
		{
			double num = TimeBase.Target?.Value ?? base.Time.WorldTime;
			num *= (double)(float)Speed;
			num += (double)AxisLineOffset;
			num %= (double)(float)Range;
			if (num < 0.0)
			{
				num += (double)(float)Range;
			}
			return (float)num - (float)Range * 0.5f;
