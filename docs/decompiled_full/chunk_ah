			public enum Role
			{
				Anyone,
				HostOnly,
				GuestOnly
			}

			public readonly SyncRef<Slot> TemplateRoot;

			public readonly Sync<Role> OnlyForRole;

			public readonly Sync<float> Weight;

			public readonly Sync<int> MaxUsers;

			public readonly Sync<bool> BlockCloudAvatar;

