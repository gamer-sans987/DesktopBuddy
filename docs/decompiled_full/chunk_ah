	[OldTypeName("FrooxEngine.TooltipSimulator", null)]
	public class ToolSimulator : Component
	{
		[OldName("Tooltip")]
		public readonly SyncRef<ITool> Tool;

		public readonly SyncRef<User> SimulatingUser;

		public readonly Sync<bool> Primary;

		public readonly Sync<bool> Secondary;

		public readonly Sync<float> Strength;

		public readonly Sync<Elements.Core.float2> Axis;

		private ITool _lastTool;

		private Digital _primary = new Digital();

		private Digital _secondary = new Digital();

		public static bool IsSimulating;

		protected override void OnCommonUpdate()
		{
			if ((SimulatingUser.Target == null) ? (!base.World.IsAuthority) : (!SimulatingUser.Target.IsLocalUser))
			{
				return;
			}
			try
			{
				IsSimulating = true;
				if (Tool.Target != _lastTool)
				{
					if (_lastTool != null)
					{
						try
						{
							base.World.UpdateManager.NestCurrentlyUpdating(_lastTool);
							if (_primary.Held)
							{
								_lastTool.OnPrimaryRelease();
							}
							if (_secondary.Held)
							{
								_lastTool.OnSecondaryRelease();
							}
						}
						finally
						{
							base.World.UpdateManager.PopCurrentlyUpdating(_lastTool);
						}
					}
					_lastTool = Tool.Target;
					_primary.UpdateState(held: false);
					_secondary.UpdateState(held: false);
				}
				if (_lastTool == null)
				{
					return;
				}
				try
				{
					base.World.UpdateManager.NestCurrentlyUpdating(_lastTool);
					_primary.UpdateState(Primary.Value);
					_secondary.UpdateState(Secondary.Value);
					if (_primary.Pressed)
					{
						_lastTool.OnPrimaryPress();
					}
					else if (_primary.Held)
					{
						_lastTool.OnPrimaryHold();
					}
					else if (_primary.Released)
					{
						_lastTool.OnPrimaryRelease();
					}
					if (_secondary.Pressed)
					{
						_lastTool.OnSecondaryPress();
					}
					else if (_secondary.Held)
					{
						_lastTool.OnSecondaryHold();
					}
					else if (_secondary.Released)
					{
						_lastTool.OnSecondaryRelease();
					}
					_lastTool.Update(Strength, Axis, _primary, _secondary);
				}
				finally
				{
					base.World.UpdateManager.PopCurrentlyUpdating(_lastTool);
				}
			}
			finally
			{
				IsSimulating = false;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Tool = new SyncRef<ITool>();
			SimulatingUser = new SyncRef<User>();
			Primary = new Sync<bool>();
			Secondary = new Sync<bool>();
			Strength = new Sync<float>();
			Axis = new Sync<Elements.Core.float2>();
