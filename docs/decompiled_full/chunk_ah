				for (int i = 0; i < componentsInChild.Materials.Count; i++)
				{
					IAssetProvider<Material> assetProvider = componentsInChild.Materials[i];
					if (assetProvider != null)
					{
						PBS_Slice pBS_Slice = assetProvider as PBS_Slice;
						if (pBS_Slice == null)
						{
							pBS_Slice = ((!(assetProvider is IPBS_Specular)) ? ((PBS_Slice)assetProvider.Slot.AttachComponent<PBS_SliceMetallic>()) : ((PBS_Slice)assetProvider.Slot.AttachComponent<PBS_SliceSpecular>()));
							MaterialHelper.CopyMaterialProperties(assetProvider, pBS_Slice);
							componentsInChild.Materials[i] = pBS_Slice;
						}
						if (!_sliceMaterials.Contains(pBS_Slice))
						{
							_sliceMaterials.Add(pBS_Slice);
						}
					}
				}
			}
			UpdateSlicers();
			HighlightHelper.FlashHighlight(slot, null, Elements.Core.colorX.Red);
		}

