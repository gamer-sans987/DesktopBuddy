			private void UpdateReference(TrackedDevicePositioner trackedDevice, Elements.Core.float3 offset, FieldDrive<Elements.Core.float3> pos, FieldDrive<Elements.Core.floatQ> rot, User targetUser)
			{
				Slot reference = ((!trackedDevice.UsingExternalObjectSlot) ? trackedDevice.BodyNodeRoot.Target : trackedDevice.ObjectSlot.Target.Slot.Parent.GetComponent<TrackedDevicePositioner>().BodyNodeRoot.Target);
				UpdateReference(reference, offset, pos, rot, targetUser);
			}

			private void UpdateReference(Slot reference, Elements.Core.float3 offset, FieldDrive<Elements.Core.float3> pos, FieldDrive<Elements.Core.floatQ> rot, User targetUser)
			{
				if (pos.IsLinkValid && rot.IsLinkValid && reference != null)
				{
					Slot slot = _vrIkAvatar.Target.Slot;
					Slot parent = slot.Parent;
					Slot slot2 = targetUser.Root.Slot;
					Elements.Core.float3 a = slot2.SpacePointToLocal(reference.LocalPosition, reference.Parent);
					Elements.Core.floatQ localRotation = slot2.SpaceRotationToLocal(reference.LocalRotation, reference.Parent);
					Elements.Core.float3 value = parent.LocalPointToSpace(a + offset, slot);
					Elements.Core.floatQ value2 = parent.LocalRotationToSpace(in localRotation, slot);
					pos.Target.Value = value;
					rot.Target.Value = value2;
				}
			}

