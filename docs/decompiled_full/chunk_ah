		internal void MapTrackers()
		{
			FullBodyTrackers fullBodyTrackers = ClassifyTrackers();
			MappableTrackedObject tracker = fullBodyTrackers.hips as MappableTrackedObject;
			MappableTrackedObject tracker2 = fullBodyTrackers.chest as MappableTrackedObject;
			MappableTrackedObject tracker3 = fullBodyTrackers.leftFoot as MappableTrackedObject;
			MappableTrackedObject tracker4 = fullBodyTrackers.rightFoot as MappableTrackedObject;
			MappableTrackedObject tracker5 = fullBodyTrackers.leftElbow as MappableTrackedObject;
			MappableTrackedObject tracker6 = fullBodyTrackers.rightElbow as MappableTrackedObject;
			MappableTrackedObject tracker7 = fullBodyTrackers.leftKnee as MappableTrackedObject;
			MappableTrackedObject tracker8 = fullBodyTrackers.rightKnee as MappableTrackedObject;
			MapTracker(tracker, BodyNode.Hips);
			MapTracker(tracker2, BodyNode.Chest, 0.25f);
			MapTracker(tracker3, BodyNode.LeftFoot);
			MapTracker(tracker4, BodyNode.RightFoot);
			MapTracker(tracker5, BodyNode.LeftLowerArm);
			MapTracker(tracker6, BodyNode.RightLowerArm);
			MapTracker(tracker7, BodyNode.LeftLowerLeg, 0.2f);
			MapTracker(tracker8, BodyNode.RightLowerLeg, 0.2f);
		}

		private void MapTracker(MappableTrackedObject tracker, BodyNode bodyNode, float forwardOffset = 0f, float upOffset = 0f)
		{
			IKSolverVR.References boneReferences = _platformBody._vrIkAvatar.Target.IK.Target.Solver.BoneReferences;
			if (tracker != null)
			{
				Slot slot = boneReferences[bodyNode];
				Slot root = GetRoot(tracker);
				Elements.Core.float3 globalDirection = boneReferences.root.Target.Forward;
				Elements.Core.float3 globalDirection2 = boneReferences.root.Target.Up;
				globalDirection = base.Slot.GlobalDirectionToLocal(in globalDirection).x_z.Normalized * forwardOffset;
				globalDirection = base.Slot.LocalVectorToSpace(in globalDirection, root);
				globalDirection2 = base.Slot.GlobalDirectionToLocal(in globalDirection2)._y_.Normalized * upOffset;
				globalDirection2 = base.Slot.LocalVectorToSpace(in globalDirection2, root);
				Elements.Core.float3 positionOffset = root.GlobalPointToLocal(slot.GlobalPosition) + globalDirection + globalDirection2;
				Elements.Core.floatQ rotationOffset = root.GlobalRotationToLocal(slot.GlobalRotation);
				tracker.Map(bodyNode, MappingTarget.VR, positionOffset, rotationOffset);
			}
		}

