		public int? TargetDeviceIndex;

		private int lastDeviceIndex = -1;

		private bool lastFilteredData;

		private AudioStream<S> _currentStream;

		private CircularBufferWriteState<StereoSample> _writeState;

		public User User => Stream.Target?.User;

		protected override void OnAwake()
		{
