			_slicers.Clear();
			_sliceMaterials.Clear();
		}

		private void CreateSlicer()
		{
			Slot slot = base.LocalUserSpace.AddSlot("Slicer");
			slot.GlobalPosition = base.Tip;
			slot.Forward = TipForward;
			GenericSlicer target = slot.AttachComponent<GenericSlicer>();
			_slicers.Add(target);
			UpdateSlicers();
		}

		private void UpdateSlicers()
		{
			PruneDestroyedReferences();
			_slicers.RemoveAll((SyncRef<GenericSlicer> s) => s == null);
			if (_slicers.Count == 0)
			{
				CreateSlicer();
				return;
			}
			for (int num = 0; num < _slicers.Count; num++)
			{
				GenericSlicer genericSlicer = _slicers[num];
				genericSlicer.Targets.EnsureExactCount(_sliceMaterials.Count);
				for (int num2 = 0; num2 < _sliceMaterials.Count; num2++)
				{
					PBS_Slice pBS_Slice = _sliceMaterials[num2];
					pBS_Slice.Slicers.EnsureExactCount(_slicers.Count);
					pBS_Slice.EdgeEmissiveColor.Value = EdgeColor.Value;
					pBS_Slice.EdgeTransitionStart.Value = EdgeStart.Value;
					pBS_Slice.EdgeTransitionEnd.Value = EdgeEnd.Value;
					genericSlicer.Targets[num2].Position.ForceLink(pBS_Slice.Slicers[num].Position);
					genericSlicer.Targets[num2].Normal.ForceLink(pBS_Slice.Slicers[num].Normal);
				}
			}
		}

		private void PruneDestroyedReferences()
		{
			_sliceMaterials.RemoveAll((SyncRef<PBS_Slice> r) => r == null);
		}

