	[Category(new string[] { "Users/Common Avatar System/Nameplate" })]
	public class AvatarNameplateVisibilityDriver : Component
	{
		public readonly Sync<bool> AlwaysShowToContacts;

		private bool _hideLocally;

		private NamePlateSettings _settings;

		public readonly FieldDrive<bool> Visible;

		public bool ShouldBeVisible
		{
			get
			{
				if (_hideLocally)
				{
					return false;
				}
				NameplateVisibility nameplateVisibility = _settings?.NameplateVisibility.Value ?? NameplateVisibility.All;
				if (nameplateVisibility == NameplateVisibility.None)
				{
					return false;
				}
				bool flag = !(_settings?.UseCustomNameplates.Value ?? true);
				if (flag && !base.Slot.IsLocalElement)
				{
					return false;
				}
				if (base.Slot.ActiveUserRoot != null)
				{
					if (base.Slot.IsLocalElement && !base.Slot.ActiveUser.HasProxyAvatar && (!flag || base.Slot.ActiveUser.IsRenderingLocallyBlocked))
					{
						return false;
					}
					if (nameplateVisibility == NameplateVisibility.NonContacts && !AlwaysShowToContacts.Value && (base.IsUnderLocalUser || base.Cloud.Contacts.IsContact(base.Slot.ActiveUser?.UserID)))
					{
						return false;
					}
				}
				return true;
			}
		}

		private void UpdateVisibility()
		{
			RunSynchronously(delegate
			{
				if (Visible.IsLinkValid)
				{
					Visible.Target.Value = ShouldBeVisible;
				}
			});
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			Visible.SetupValueSetHook(delegate(IField<bool> field, bool value)
			{
				_hideLocally = !value;
				MarkChangeDirty();
			});
			base.Slot.ActiveUserRootChanged += OnActiveUserRootChanged;
			BanManager.OnAllBlockingChanged += OnAllBlockingChanged;
			BanManager.OnBlockingChanged += OnBlockingChanged;
			Settings.RegisterValueChanges<NamePlateSettings>(OnNamePlateSettingsChanged);
		}

		private void OnAllBlockingChanged()
		{
			UpdateVisibility();
		}

		private void OnNamePlateSettingsChanged(NamePlateSettings settings)
		{
			_settings = settings;
			UpdateVisibility();
		}

		private void OnBlockingChanged(UserRestrictionsSettings.Entry entry)
		{
			if (base.Slot.ActiveUser != null && entry.Matches(base.Slot.ActiveUser))
			{
				UpdateVisibility();
			}
		}

