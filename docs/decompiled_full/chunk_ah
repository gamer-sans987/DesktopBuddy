		private void OnMessageReceived(OnMessageReceivedArgs e)
		{
			if (_spriteSheet.Target == null)
			{
				Slot slot = base.Slot.AddSlot("Emotes");
				slot.PersistentSelf = false;
				_spriteSheet.Target = slot.AttachComponent<DynamicSpriteFont>();
				_fontCollection.Target = slot.AttachComponent<FontCollection>();
				_fontCollection.Target.FontSets.Add(base.World.GetDefaultFont());
				_fontCollection.Target.FontSets.Add(_spriteSheet.Target);
				_generatedSprites.Clear();
			}
			_ = _spriteSheet.Target;
			ChatMessage chatMessage = e.ChatMessage;
			string color = GetColor(chatMessage.ColorHex);
			int bits = chatMessage.Bits;
			Elements.Core.colorX a = Elements.Core.colorX.White;
			if (chatMessage.CheerBadge != null)
			{
				switch (chatMessage.CheerBadge.Color)
				{
				case BadgeColor.Gray:
					a = Elements.Core.colorX.FromHexCode("#B6B6B9");
					break;
				case BadgeColor.Purple:
					a = Elements.Core.colorX.FromHexCode("#D6A2EE");
					break;
				case BadgeColor.Green:
					a = Elements.Core.colorX.FromHexCode("#10EAD8");
					break;
				case BadgeColor.Blue:
					a = Elements.Core.colorX.FromHexCode("#86B0F6");
					break;
				case BadgeColor.Red:
					a = Elements.Core.colorX.FromHexCode("#FD5855");
					break;
				}
				a = MathX.Lerp(in a, Elements.Core.colorX.White, 0.5f);
			}
			string text = $"<b><color={color}>{chatMessage.DisplayName}</color></b>";
			string message = chatMessage.Message;
			if (TwitchInterface.GlobalBadges != null)
			{
				StringBuilder stringBuilder = Pool.BorrowStringBuilder();
				foreach (KeyValuePair<string, string> badge in chatMessage.Badges)
				{
					string text2 = badge.Key + "-" + badge.Value;
					bool flag = false;
					if (_generatedSprites.Add(text2))
					{
						if (TwitchInterface.GlobalBadges.Sets.TryGetValue(badge.Key, out var value) && value.Versions.TryGetValue(badge.Value, out var value2))
						{
							DynamicSpriteFont.SpriteGlyph spriteGlyph = _spriteSheet.Target.Glyphs.Add();
							spriteGlyph.SpriteURL.Value = new Uri(value2.Image_Url_2x ?? value2.Image_Url_1x);
							spriteGlyph.SpriteName.Value = text2;
							spriteGlyph.Advance.Value = Elements.Core.float2.One * 1.2f;
							flag = true;
						}
					}
					else
					{
						flag = true;
					}
					if (flag)
					{
						StringBuilder stringBuilder2 = stringBuilder;
						StringBuilder stringBuilder3 = stringBuilder2;
						StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(16, 1, stringBuilder2);
						handler.AppendLiteral("<sprite name=\"");
						handler.AppendFormatted(text2);
						handler.AppendLiteral("\">");
						stringBuilder3.Append(ref handler);
					}
				}
				text = stringBuilder.ToString() + text;
				Pool.Return(ref stringBuilder);
			}
			if (chatMessage.EmoteSet?.Emotes != null && chatMessage.EmoteSet.Emotes.Count > 0)
			{
				StringBuilder stringBuilder4 = Pool.BorrowStringBuilder();
				int num = 0;
				chatMessage.EmoteSet.Emotes.Sort((Emote emote, Emote b) => emote.StartIndex.CompareTo(b.StartIndex));
				foreach (Emote emote in chatMessage.EmoteSet.Emotes)
				{
					string text3 = EscapeEmoteName(emote.Name);
					if (_generatedSprites.Add(text3))
					{
						DynamicSpriteFont.SpriteGlyph spriteGlyph2 = _spriteSheet.Target.Glyphs.Add();
						spriteGlyph2.SpriteURL.Value = new Uri(emote.ImageUrl);
						spriteGlyph2.SpriteName.Value = text3;
						spriteGlyph2.Advance.Value = Elements.Core.float2.One * 1.25f;
						spriteGlyph2.Size.Value = 1.25f;
					}
					int startIndex = emote.StartIndex;
					StringBuilder stringBuilder2;
					StringBuilder.AppendInterpolatedStringHandler handler;
					if (num < startIndex)
					{
						int num2 = startIndex - num;
						stringBuilder2 = stringBuilder4;
						StringBuilder stringBuilder5 = stringBuilder2;
						handler = new StringBuilder.AppendInterpolatedStringHandler(10, 1, stringBuilder2);
						handler.AppendLiteral("<noparse=");
						handler.AppendFormatted(num2);
						handler.AppendLiteral(">");
						stringBuilder5.Append(ref handler);
						stringBuilder4.Append(message, num, num2);
					}
					stringBuilder2 = stringBuilder4;
					StringBuilder stringBuilder6 = stringBuilder2;
					handler = new StringBuilder.AppendInterpolatedStringHandler(16, 1, stringBuilder2);
					handler.AppendLiteral("<sprite name=\"");
					handler.AppendFormatted(text3);
					handler.AppendLiteral("\">");
					stringBuilder6.Append(ref handler);
					num = emote.EndIndex + 1;
				}
				if (num < message.Length)
				{
					int num3 = message.Length - num;
					StringBuilder stringBuilder2 = stringBuilder4;
					StringBuilder stringBuilder7 = stringBuilder2;
					StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(10, 1, stringBuilder2);
					handler.AppendLiteral("<noparse=");
					handler.AppendFormatted(num3);
					handler.AppendLiteral(">");
					stringBuilder7.Append(ref handler);
					stringBuilder4.Append(message, num, num3);
				}
				message = stringBuilder4.ToString();
				Pool.Return(ref stringBuilder4);
			}
			else
			{
				message = StringParsingHelper.SanitizeFormatTags(message);
			}
			if (chatMessage.IsHighlighted)
			{
				a = Elements.Core.colorX.FromHexCode("#755EBCFF");
				message = "<color=white>" + message + "</color>";
				SetHighlight(text + ": " + message, a);
			}
			AddMessage(chatMessage.Id, text + ": " + message, a).Font.Target = _fontCollection.Target;
			if (bits > 0)
			{
				SetHighlight($"{text} cheered with {bits} bits", a);
				_highlightText.Target.Font.Target = _fontCollection.Target;
			}
		}

