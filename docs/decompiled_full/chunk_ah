		internal void CalibrateAvatar()
		{
			VRIKAvatar targetUserVRIKAvatar = TargetUserVRIKAvatar;
			UserRoot root = TargetUser.Target.Root;
			AvatarManager avatarManager = root.GetRegisteredComponent<AvatarManager>();
			Slot slot = base.World.AddSlot("Dummy Head");
			slot.PersistentSelf = false;
			slot.AttachComponent<AvatarPoseNode>().Node.Value = BodyNode.Head;
			slot.AttachComponent<AvatarDestroyOnDequip>();
			avatarManager.Equip(slot);
			Slot avatarRoot = targetUserVRIKAvatar.Slot.GetObjectRoot();
			_targetCustomAvatar.Target = targetUserVRIKAvatar;
			_avatarHipsOffset.Target = avatarRoot.GetComponentInChildren((IAvatarObject o) => o.Node == BodyNode.Hips).Slot.FindChild("Target");
			_avatarLeftFootOffset.Target = avatarRoot.GetComponentInChildren((IAvatarObject o) => o.Node == BodyNode.LeftFoot).Slot.FindChild("Target");
			_avatarRightFootOffset.Target = avatarRoot.GetComponentInChildren((IAvatarObject o) => o.Node == BodyNode.RightFoot).Slot.FindChild("Target");
			_avatarLeftKneeDefaultOffset.Target = _avatarLeftFootOffset.Target.FindChild("KneeTarget");
			_avatarRightKneeDefaultOffset.Target = _avatarRightFootOffset.Target.FindChild("KneeTarget");
			Slot slot2 = avatarRoot.Duplicate(base.World.RootSlot);
			slot2.Name += " - Calibration Reference";
			VRIKAvatar componentInChildren = slot2.GetComponentInChildren<VRIKAvatar>();
			slot2.Parent = _visualizationRoot.Target;
			AvatarHeightCompensation.Value = componentInChildren.HeightCompensation;
			slot2.ForeachComponentInChildren(delegate(AvatarPoseNode n)
			{
				n.Dequip();
			});
			_customAvatar.Map(componentInChildren, TargetUser.Target, fixToes: false);
			foreach (MaterialSet platformBodyMaterialSet in _platformBodyMaterialSets)
			{
				platformBodyMaterialSet.ActiveSetIndex.Value = 1;
			}
			AvatarReferences avatarReferences = GetAvatarReferences(_customAvatar);
			_avatarHipHandle.Target = SetupAvatarCalibrationHandle(avatarReferences.hipsOffset, rotatable: true, limitRange: true, "Hips");
			_avatarLeftFootHandle.Target = SetupAvatarCalibrationHandle(avatarReferences.leftFootOffset, rotatable: true, limitRange: true, "Left Foot");
			_avatarRightFootHandle.Target = SetupAvatarCalibrationHandle(avatarReferences.rightFootOffset, rotatable: true, limitRange: true, "Right Foot");
			Slot slot3 = avatarReferences.leftFootOffset.FindChild("KneeTarget");
			Slot slot4 = avatarReferences.rightFootOffset.FindChild("KneeTarget");
			_avatarLeftKneeHandle.Target = SetupAvatarCalibrationHandle(slot3, rotatable: false, limitRange: false, "Left Knee", 0.05f);
			_avatarRightKneeHandle.Target = SetupAvatarCalibrationHandle(slot4, rotatable: false, limitRange: false, "Right Knee", 0.05f);
			_avatarLeftKneeOffset.Target = slot3.Position_Field;
			_avatarRightKneeOffset.Target = slot4.Position_Field;
			IKSolverVR.References boneReferences = componentInChildren.IK.Target.Solver.BoneReferences;
			Slot target = boneReferences.leftCalf.Target;
			Slot target2 = boneReferences.rightCalf.Target;
			ArrowMesh arrowMesh = target.AttachMesh<ArrowMesh>(_calibrationReferenceMaterial.Target);
			ArrowMesh arrowMesh2 = target2.AttachMesh<ArrowMesh>(_calibrationReferenceMaterial.Target);
			float localScale = 0.02f;
			localScale = base.Slot.LocalScaleToSpace(localScale, arrowMesh.Slot);
			arrowMesh.AdjustBodyRadius(localScale);
			arrowMesh2.AdjustBodyRadius(localScale);
			PositionDeltaDriver positionDeltaDriver = target.AttachComponent<PositionDeltaDriver>();
			PositionDeltaDriver positionDeltaDriver2 = target2.AttachComponent<PositionDeltaDriver>();
			positionDeltaDriver.Origin.Target = target;
			positionDeltaDriver.Target.Target = _avatarLeftKneeHandle.Target;
			positionDeltaDriver.VectorSpace.UseLocalSpaceOf(target);
			positionDeltaDriver.Vector.Target = arrowMesh.Vector;
			positionDeltaDriver2.Origin.Target = target2;
			positionDeltaDriver2.Target.Target = _avatarRightKneeHandle.Target;
			positionDeltaDriver2.VectorSpace.UseLocalSpaceOf(target2);
			positionDeltaDriver2.Vector.Target = arrowMesh2.Vector;
			slot2.SetIdentityTransform();
			slot2.GetComponentInChildren<BipedRig>()?.GenerateDebugSkeleton(_calibrationReferenceMaterial.Target, base.Slot.LocalScaleToGlobal(0.01f));
			List<IGrabbable> grabbables = avatarRoot.GetComponentsInChildren((IGrabbable g) => g.Enabled);
			grabbables.ForEach(delegate(IGrabbable g)
			{
				g.Enabled = false;
			});
			StartTask(async delegate
			{
				await new Updates(2);
				avatarManager.Equip(avatarRoot);
				grabbables.ForEach(delegate(IGrabbable g)
				{
					g.Enabled = true;
				});
				Slot leftHand = base.Slot.AddSlot("LeftHand");
				Slot rightHand = base.Slot.AddSlot("RightHand");
				Task<bool> task = leftHand.LoadObjectAsync(base.Cloud.Platform.GetSpawnObjectUri("VR_Glove_Left"));
				Task<bool> rightHandTask = rightHand.LoadObjectAsync(base.Cloud.Platform.GetSpawnObjectUri("VR_Glove_Right"));
				await task;
				await rightHandTask;
				leftHand.ForeachComponentInChildren(delegate(MeshRenderer r)
				{
					r.ReplaceAllMaterials(_leftHandOverrideMaterial.Target);
				});
				rightHand.ForeachComponentInChildren(delegate(MeshRenderer r)
				{
					r.ReplaceAllMaterials(_rightHandOverrideMaterial.Target);
				});
				AvatarObjectSlot leftSlot = base.LocalUserRoot.GetRegisteredComponent((AvatarObjectSlot s) => s.Node.Value == BodyNode.LeftHand);
				AvatarObjectSlot rightSlot = base.LocalUserRoot.GetRegisteredComponent((AvatarObjectSlot s) => s.Node.Value == BodyNode.RightHand);
				leftHand.Parent = leftSlot.Slot;
				rightHand.Parent = rightSlot.Slot;
				leftHand.GetComponentInChildren<AvatarPoseNode>()?.Equip(leftSlot);
				rightHand.GetComponentInChildren<AvatarPoseNode>()?.Equip(rightSlot);
				leftHand.GetComponentInChildren<AvatarObjectScale>()?.OnEquip(leftSlot);
				rightHand.GetComponentInChildren<AvatarObjectScale>()?.OnEquip(rightSlot);
				leftHand.GetComponentsInChildren<AvatarToolAnchor>().ForEach(delegate(AvatarToolAnchor a)
				{
					a.OnEquip(leftSlot);
				});
				rightHand.GetComponentsInChildren<AvatarToolAnchor>().ForEach(delegate(AvatarToolAnchor a)
				{
					a.OnEquip(rightSlot);
				});
				leftHand.ForeachComponentInChildren(delegate(AvatarHandDataAssigner a)
				{
					a.OnEquip(leftSlot);
				});
				rightHand.ForeachComponentInChildren(delegate(AvatarHandDataAssigner a)
				{
					a.OnEquip(rightSlot);
				});
				_leftHandOverride.Target = leftHand;
				_rightHandOverride.Target = rightHand;
			});
		}

