			}
		}

		protected override void OnCommonUpdate()
		{
			BevelStripeMesh target = _shelfMesh.Target;
			if (target != null)
			{
				target.Thickness = Thickness;
				target.Height = Width;
				float num = MathX.Max(_targetLength, MinLength);
				if (MathX.Abs(target.Width - num) < 0.001f || updatesSinceFocus < 4)
				{
					target.Width = num;
				}
				else
				{
					target.Width = MathX.Lerp(target.Width, num, base.Time.Delta * ((target.Width < num) ? 4f : 2f));
