			keywords.UpdateKeyword("VERTEX_COLOR_ALBEDO", UseVertexColors);
			if (OcclusionMap.WasChanged || MetallicGlossMap.WasChanged || keywords.NeedsInitialization)
			{
				keywords.UpdateKeyword("OCCLUSION_METALLIC", ref _occlusionMetallic, OcclusionMap.Target != null || MetallicGlossMap.Target != null);
			}
			if (ShadowRampMask.WasChanged || OutlineMask.WasChanged || ThicknessMap.WasChanged || keywords.NeedsInitialization)
			{
				keywords.UpdateKeyword("RAMPMASK_OUTLINEMASK_THICKNESS", ref _rampOutlineThickness, ShadowRampMask.Target != null || OutlineMask.Target != null || ThicknessMap.Target != null);
			}
			if (BlendMode.WasChanged || keywords.NeedsInitialization)
			{
				keywords.SetKeyword("Cutout", BlendMode.Value == FrooxEngine.BlendMode.Cutout);
				keywords.SetKeyword("AlphaBlend", BlendMode.Value == FrooxEngine.BlendMode.Alpha);
				keywords.SetKeyword("Transparent", BlendMode.Value == FrooxEngine.BlendMode.Transparent);
			}
			keywords.UpdateKeyword("NORMAL_MAP", NormalMap);
			keywords.UpdateKeyword("EMISSION_MAP", EmissionMap);
			keywords.UpdateKeyword("MATCAP", Matcap);
			keywords.UpdateVertexColorInterpolationSpace(VertexColorInterpolationSpace);
		}

