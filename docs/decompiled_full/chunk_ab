				keywords.SetKeyword("OBJECT_SPACE", LocalSpace.Value);
			}
			if (AlbedoTexture.WasChanged || DetailAlbedoTexture.WasChanged || keywords.NeedsInitialization)
			{
				bool flag = DetailAlbedoTexture.Target != null;
				bool state = !flag && AlbedoTexture.Target != null;
				keywords.SetKeyword("_ALBEDOTEX", state);
				keywords.SetKeyword("_DETAIL_ALBEDOTEX", flag);
			}
			if (NormalMap.WasChanged || DetailNormalMap.WasChanged || keywords.NeedsInitialization)
			{
				bool flag2 = DetailNormalMap.Target != null;
				bool state2 = !flag2 && NormalMap.Target != null;
