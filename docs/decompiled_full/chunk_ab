		protected override void UpdateMaterial(ref MaterialUpdateWriter writer)
		{
			writer.UpdateInstancing(enabled: true, ref _lastInstancing);
			float num = FillColor.Value.a;
			writer.SetFloat(_Thickness, Thickness);
			writer.SetColor(_LineColor, LineColor.Value);
			writer.SetColor(_FillColor, FillColor.Value);
			if (UseFresnel.Value)
			{
				writer.SetFloat(_Exp, Exp.Value);
				writer.SetColor(_LineFarColor, LineFarColor.Value);
				writer.SetColor(_FillFarColor, FillFarColor.Value);
				num = MathX.Max(FillFarColor.Value.a, num);
			}
			if (DoubleSided.Value)
			{
				writer.SetColor(_InnerLineColor, InnerLineColor.Value);
				writer.SetColor(_InnerFillColor, InnerFillColor.Value);
				num = MathX.Max(InnerFillColor.Value.a, num);
				if (UseFresnel.Value)
				{
					writer.SetColor(_InnerLineFarColor, InnerLineFarColor.Value);
					writer.SetColor(_InnerFillFarColor, InnerFillFarColor.Value);
					num = MathX.Max(InnerFillFarColor.Value.a, num);
				}
			}
			writer.SetTexture(_MainTex, Texture.Asset);
			writer.SetRenderQueue(RenderQueue.Value);
			writer.SetFloat(_ZWrite, ZWrite.Value.GetZWrite(num < 0.75f) ? 1 : 0);
			writer.SetFloat(_OffsetFactor, OffsetFactor);
			writer.SetFloat(_OffsetUnits, OffsetUnits);
		}

