		private void GetBoneList(IButton button, ButtonEventData eventData)
		{
			if (Asset?.Data == null)
			{
				return;
			}
			StringBuilder stringBuilder = new StringBuilder();
			IReadOnlyList<BoneMetadata> boneMetadata = Asset.BoneMetadata;
			for (int i = 0; i < Asset.Data.BoneCount; i++)
			{
				Elements.Assets.Bone bone = Asset.Data.GetBone(i);
				if (boneMetadata[i].TotalVertexCount == 0)
				{
					stringBuilder.Append("<color=#f00>");
				}
				StringBuilder stringBuilder2 = stringBuilder;
				StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(6, 4, stringBuilder2);
				handler.AppendFormatted(bone.Index);
				handler.AppendLiteral(": ");
				handler.AppendFormatted(bone.Name);
				handler.AppendLiteral(" - ");
				handler.AppendFormatted(boneMetadata[i]);
				handler.AppendLiteral("\n");
				handler.AppendFormatted(bone.BindPose);
				stringBuilder2.Append(ref handler);
				if (boneMetadata[i].TotalVertexCount == 0)
				{
					stringBuilder.Append("</color>");
				}
				stringBuilder.AppendLine("\n-----------------------");
			}
			Slot slot = base.LocalUserSpace.AddSlot("Bone List");
			UniversalImporter.SpawnText(slot, "Bone List Report", stringBuilder.ToString());
			slot.PositionInFrontOfUser(Elements.Core.float3.Backward);
		}

