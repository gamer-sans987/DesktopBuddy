	public class ShaderKeywords
	{
		public Shader MetadataShader { get; private set; }

		public bool Initialized { get; private set; }

		public bool NeedsInitialization => !Initialized;

		public uint Variant { get; private set; }

		public uint GetProperVariant()
		{
			uint num = Variant;
			foreach (List<string> variantGroup in MetadataShader.Metadata.VariantGroups)
			{
				if (variantGroup[0] == "_")
				{
					continue;
				}
				bool flag = true;
				uint num2 = 0u;
				for (int i = 0; i < variantGroup.Count; i++)
				{
					uint num3 = (uint)(1 << MetadataShader.Metadata.GetKeywordIndex(variantGroup[i]));
					if (i == 0)
					{
						num2 = num3;
					}
					if ((num & num3) != 0)
					{
						flag = false;
						break;
					}
				}
				if (flag)
				{
					num |= num2;
				}
			}
			return num;
		}

		public ShaderKeywords(Shader metadataShader)
		{
			MetadataShader = metadataShader;
		}

		public void SetKeyword(string keyword, bool state)
		{
			int keywordIndex = MetadataShader.Metadata.GetKeywordIndex(keyword);
			if (keywordIndex >= 0)
			{
				uint num = (uint)(1 << keywordIndex);
				if (state)
				{
					Variant |= num;
				}
				else
				{
					Variant &= ~num;
				}
			}
		}

		public void UpdateKeyword(string keyword, Sync<bool> state)
		{
			if (state.GetWasChangedAndClear() || NeedsInitialization)
			{
				SetKeyword(keyword, state.Value);
			}
		}

		public void UpdateKeyword(string keyword, ref bool? lastState, bool state)
		{
			if (lastState != state || NeedsInitialization)
			{
				SetKeyword(keyword, state);
				lastState = state;
			}
		}

		public void UpdateKeyword<V>(string keyword, Sync<V?> field) where V : struct
		{
			if (field.WasChanged || NeedsInitialization)
			{
				SetKeyword(keyword, field.Value.HasValue);
			}
		}

