		protected override void UpdateMaterial(ref MaterialUpdateWriter writer)
		{
			writer.UpdateInstancing(enabled: true, ref _lastInstancing);
			writer.UpdateColor(_EdgeColor, EdgeColor);
			writer.UpdateColor(_EdgeEmissionColor, EdgeEmissiveColor);
			writer.UpdateFloat(_EdgeTransitionStart, EdgeTransitionStart);
			writer.UpdateFloat(_EdgeTransitionEnd, EdgeTransitionEnd);
			Span<Elements.Core.float4> span = writer.AllocateFloat4Array(_Slicers, 8);
			int num = ((!HideSlicers.Value) ? MathX.Min(Slicers.Count, 8) : 0);
			for (int i = 0; i < num; i++)
			{
				Slicer slicer = Slicers[i];
				span[i] = new Elements.Core.float4(slicer.Normal.Value, 0f - MathX.Dot(slicer.Normal.Value, (Elements.Core.float3)slicer.Position));
			}
			for (int j = num; j < 8; j++)
			{
				span[j] = Elements.Core.float4.Zero;
			}
			writer.UpdateCulling(_Cull, Culling);
			writer.UpdateTexture(_MainTex, AlbedoTexture, ColorProfile.sRGB, ColorProfileRequirement.Default, base.AssetManager.DarkCheckerTexture);
			writer.UpdateColor(_Color, AlbedoColor);
			writer.UpdateST(_MainTex_ST, TextureScale, TextureOffset);
			writer.UpdateColor(_EmissionColor, EmissiveColor);
			writer.UpdateTexture(_EmissionMap, EmissiveMap, ColorProfile.sRGB, ColorProfileRequirement.Default, base.AssetManager.DarkCheckerTexture);
			writer.UpdateNormalMap(_NormalMap, NormalMap);
			writer.UpdateFloat(_NormalScale, NormalScale);
			writer.UpdateTexture(_DetailAlbedoMap, DetailAlbedoTexture, ColorProfile.sRGB, ColorProfileRequirement.Default);
			writer.UpdateNormalMap(_DetailNormalMap, DetailNormalMap);
			writer.UpdateFloat(_DetailNormalMapScale, DetailNormalScale);
			if (DetailTextureOffset.WasChanged || DetailTextureScale.WasChanged)
			{
				DetailTextureOffset.WasChanged = false;
				DetailTextureScale.WasChanged = false;
				writer.SetST(_DetailAlbedoMap_ST, (Elements.Core.float2)DetailTextureScale, (Elements.Core.float2)DetailTextureOffset);
				writer.SetST(_DetailNormalMap_ST, (Elements.Core.float2)DetailTextureScale, (Elements.Core.float2)DetailTextureOffset);
			}
			writer.UpdateTexture(_OcclusionMap, OcclusionMap, ColorProfile.sRGB, ColorProfileRequirement.Default);
			writer.UpdateFloat(_AlphaClip, AlphaClip);
			writer.UpdateFloat(_OffsetFactor, OffsetFactor);
			writer.UpdateFloat(_OffsetUnits, OffsetUnits);
			if (!AlphaHandling.WasChanged && !RenderQueue.WasChanged)
			{
				return;
			}
			AlphaHandling.WasChanged = false;
			RenderQueue.WasChanged = false;
			int num2 = RenderQueue.Value;
			if (num2 < 0)
			{
				switch (AlphaHandling.Value)
				{
				case FrooxEngine.AlphaHandling.Opaque:
					num2 = 2000;
					break;
				case FrooxEngine.AlphaHandling.AlphaClip:
					num2 = 2450;
					break;
				case FrooxEngine.AlphaHandling.AlphaBlend:
					num2 = 3000;
					break;
				}
			}
			writer.SetRenderQueue(num2);
		}

