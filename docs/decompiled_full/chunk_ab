	}
	public abstract class StaticAssetProvider<A, M, D> : AssetProvider<A>, IAssetRequester, IStaticAssetProvider, IAssetProvider, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable where A : Asset, new() where M : class, IAssetMetadata, new() where D : class, IEngineAssetVariantDescriptor
	{
		public readonly Sync<Uri> URL;

		private object _lock = new object();

		private A _asset;

		private Uri _originalRequestedUrl;

		private Uri _requestedUrl;

		private bool _isLoaded;

		private D _variantDescriptor;

		private M _metadata;

		private AssetLoadingData _loadingData;

		private CancellationTokenSource _cancellation;

		public override A Asset
		{
			get
			{
				if (IsAssetAvailable)
				{
					return _asset;
				}
				return null;
			}
		}

		public override bool IsAssetAvailable
		{
			get
			{
				A asset = _asset;
				if (asset == null)
				{
					return false;
				}
				if (URL.Value != _originalRequestedUrl)
				{
					return false;
				}
				if (asset.LoadState != AssetLoadState.PartiallyLoaded)
				{
					return asset.LoadState == AssetLoadState.FullyLoaded;
				}
				return true;
			}
		}

		public abstract EngineAssetClass AssetClass { get; }

		public A RawAsset => _asset;

		protected virtual bool FetchMetadata => true;

		Uri IStaticAssetProvider.URL
		{
			get
			{
				return URL.Value;
			}
			set
			{
				URL.Value = value;
			}
		}

		Asset IStaticAssetProvider.Asset => Asset;

		bool IStaticAssetProvider.IsAvailable => IsAssetAvailable;

		protected virtual bool WaitOnMetadataFromCloud => false;

		protected abstract ValueTask<D> UpdateVariantDescriptor(M metadata, D currentDescriptor);

		protected override void FreeAsset()
		{
			FreeAsset();
		}

		protected void FreeAsset(bool keepVariantData = false)
		{
			if (!keepVariantData)
			{
				UnregisterLoadingData();
			}
			if (_asset != null)
			{
				A asset = _asset;
				_asset = null;
				if (!keepVariantData)
				{
					_variantDescriptor = null;
					_metadata = null;
				}
				asset.RemoveRequest(this);
				AssetRemoved();
				OnAssetUnloaded();
				_isLoaded = false;
			}
		}

		private void UnregisterLoadingData()
		{
			if (_loadingData != null)
			{
				_loadingData?.UnregisterProvider(this);
				_loadingData = null;
			}
		}

		protected override void UpdateAsset()
		{
			_cancellation?.Cancel();
			_cancellation = new CancellationTokenSource();
			CancellationToken _token = _cancellation.Token;
			StartTask(async delegate
			{
				await UpdateAssetAsync(_token).ConfigureAwait(continueOnCapturedContext: false);
			});
		}

		private async Task UpdateAssetAsync(CancellationToken cancellationToken)
		{
			Uri originalURL = URL.Value;
			Uri assetURL = ProcessURL(originalURL);
			bool urlChanged = _asset?.AssetURL != assetURL;
			if (urlChanged)
			{
				_requestedUrl = null;
				_originalRequestedUrl = null;
				FreeAsset();
			}
			if (!(assetURL != null))
			{
				return;
			}
			if (assetURL.Scheme == "local")
			{
				base.World.AssetManager.RegisterLocalAsset(assetURL);
			}
			UnregisterLoadingData();
			if (_loadingData == null && base.World.AssetManager.TrackAssetLoading)
			{
				_loadingData = base.World.AssetManager.RegisterLoadingAsset(assetURL, this);
			}
			await default(ToBackground);
			if (cancellationToken.IsCancellationRequested || base.IsDisposed)
			{
				return;
			}
			Engine _engine = base.Engine;
			if (FetchMetadata)
			{
				if (_metadata == null)
				{
					M metadata = await _engine.AssetManager.RequestMetadata<M>(assetURL, _engine.Platform == Platform.Android || WaitOnMetadataFromCloud).ConfigureAwait(continueOnCapturedContext: false);
					if (cancellationToken.IsCancellationRequested)
					{
						return;
					}
					_metadata = metadata;
				}
			}
			else
			{
				_metadata = null;
			}
			if (base.IsDisposed)
			{
				return;
			}
			D val = await UpdateVariantDescriptor(_metadata, _variantDescriptor);
			lock (_lock)
			{
				if (base.IsDisposed || cancellationToken.IsCancellationRequested)
				{
					return;
				}
				if (val != null)
				{
					_variantDescriptor = val;
				}
				if (Asset == null || urlChanged || val != null)
				{
					FreeAsset(keepVariantData: true);
					_requestedUrl = assetURL;
					_originalRequestedUrl = originalURL;
					if (_variantDescriptor != null)
					{
						_engine.AssetManager.RequestAsset<A>(assetURL, _variantDescriptor, this, _metadata);
					}
				}
			}
		}

		protected virtual void OnAssetLoaded()
		{
		}

		protected virtual void OnAssetUpdated()
		{
		}

		protected virtual void OnAssetUnloaded()
		{
		}

		public void AssignAsset(Asset asset)
		{
			if (_asset != null)
			{
				throw new InvalidOperationException($"Asset already assigned to provider: {this}\nExisting asset: {_asset}\nAsset: {asset}");
			}
			if (!(asset.AssetURL != _requestedUrl))
			{
				if (_loadingData != null && !_loadingData.RegisterAsset(this, asset))
				{
					UnregisterLoadingData();
				}
				_asset = (A)asset;
			}
		}

		public void AssetLoadStateUpdated(Asset asset)
		{
			if (asset != _asset)
			{
				return;
			}
			switch (asset.LoadState)
			{
			case AssetLoadState.Failed:
				_loadingData?.RegisterFailed(this, asset);
				_loadingData = null;
				break;
			case AssetLoadState.PartiallyLoaded:
			case AssetLoadState.FullyLoaded:
			{
				if (!_isLoaded)
				{
					_isLoaded = true;
					AssetCreated();
					OnAssetLoaded();
				}
				else
				{
					AssetUpdated();
					OnAssetUpdated();
				}
				Uri _url = asset.AssetURL;
				string value = _variantDescriptor?.VariantIdentifier;
				if (asset.LoadState == AssetLoadState.FullyLoaded)
				{
					_loadingData?.RegisterFullyLoaded(this, asset);
					_loadingData = null;
				}
				if (asset.LoadState == AssetLoadState.FullyLoaded && _url.Scheme == "local" && !string.IsNullOrEmpty(value))
				{
					Task.Run(() => base.Engine.AssetManager.GatherAssetFile(_url, -100f));
				}
				break;
			}
			case AssetLoadState.Unloaded:
				_isLoaded = false;
				AssetRemoved();
				OnAssetUnloaded();
				break;
			}
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			string text = URL.Value?.Scheme;
			if (text == null || !(text != base.Cloud.Platform.DBScheme) || !(text != "http") || !(text != "https") || !(text != "ftp"))
			{
				return;
			}
			control.OnLoaded(this, delegate
			{
				Uri uri = URL.Value.MigrateLegacyURL(base.Cloud.Platform);
				if (base.Cloud.Assets.IsLegacyDB(uri))
				{
					string signature = base.Cloud.Assets.DBSignature(uri);
					uri = base.Cloud.Assets.GenerateURL(signature);
				}
				URL.Value = uri;
			});
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			URL = new Sync<Uri>();
		}
	}
