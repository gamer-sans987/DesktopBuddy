	public abstract class PeriodicWaveClip : ProceduralAudioClip
	{
		[Range(20f, 4000f, "0.00")]
		public readonly Sync<float> Frequency;

		[Range(0f, 1f, "0.00")]
		public readonly Sync<float> Amplitude;

		private float _frequency;

		private float _amplitude;

		protected virtual float ClipDuration => MathX.Floor(_frequency) / _frequency;

		protected override ChannelConfiguration Channels => ChannelConfiguration.Mono;

		protected override void OnAwake()
		{
			base.OnAwake();
			Frequency.Value = 440f;
			Amplitude.Value = 1f;
		}

		protected override void PrepareAssetUpdateData()
		{
			_frequency = MathX.FilterInvalid(Frequency);
			_amplitude = MathX.FilterInvalid(Amplitude);
			_frequency = MathX.Max(0.1f, MathX.Abs(_frequency)) * ((_frequency < 0f) ? (-1f) : 1f);
		}

		protected override void ClearAudioData()
		{
		}

		protected override void UpdateAudioData(AudioX clip)
		{
			clip.SetDuration(ClipDuration);
			float num = _frequency / (float)clip.SampleRate;
			if (_amplitude > 1f)
			{
				for (int i = 0; i < clip.SampleCount; i++)
				{
					clip.RawSamples[i] = MathX.Clamp01(Generate((float)i * num) * _amplitude);
				}
			}
			else
			{
				for (int j = 0; j < clip.SampleCount; j++)
				{
					clip.RawSamples[j] = Generate((float)j * num) * _amplitude;
				}
			}
		}

		protected abstract float Generate(float position);

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Frequency = new Sync<float>();
			Amplitude = new Sync<float>();
		}
