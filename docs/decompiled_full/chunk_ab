		{
			Random random = new Random(Seed.Value);
			if (Monochrome.Value)
			{
				for (int i = 0; i < tex2D.Size.y; i++)
				{
					for (int j = 0; j < tex2D.Size.x; j++)
					{
						float lerp = (float)random.NextDouble();
						tex2D.SetPixel(j, i, MathX.LerpUnclamped(in _min, in _max, lerp));
					}
				}
			}
			else
