		public Task<bool> Process(Func<MeshX, MeshX> processFunc, IButton button, bool undoable = true)
		{
			return StartGlobalTask(async () => await ProcessAsync(processFunc, button, undoable));
		}

		private async Task<bool> ProcessAsync(Func<MeshX, MeshX> processFunc, IButton button, bool undoable)
		{
			if (Asset?.Data == null)
			{
				return false;
			}
			string _description = button?.LabelText;
			if (button != null)
			{
				button.LabelText = this.GetLocalized("General.Processing");
				button.Enabled = false;
			}
			await default(ToBackground);
			Uri uri;
			try
			{
				MeshX arg = new MeshX(Asset.Data);
				arg = processFunc(arg);
				uri = await base.Engine.LocalDB.SaveAssetAsync(arg).ConfigureAwait(continueOnCapturedContext: false);
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception processing mesh {URL.Value}:\n" + ex);
				await default(ToWorld);
				if (button != null && !button.IsDestroyed)
				{
					button.LabelText = "<color=#f00>Error! Check log.</color>";
				}
				throw;
			}
			await default(ToWorld);
			if (button != null && !button.IsDestroyed)
			{
				button.LabelText = _description;
				button.Enabled = true;
			}
			if (uri == null)
			{
				return false;
			}
			if (undoable)
			{
				base.World.BeginUndoBatch(_description);
				URL.UndoableSet(uri, forceNew: true);
				base.World.EndUndoBatch();
			}
			else
			{
				URL.Value = uri;
			}
			return true;
		}

