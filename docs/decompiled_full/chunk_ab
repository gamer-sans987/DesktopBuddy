	public static class MaterialHelper
	{
		public static bool IsTransparent(this BlendMode blendmode)
		{
			if ((uint)blendmode <= 1u)
			{
				return false;
			}
			return true;
		}

		public static bool GetZWrite(this ZWrite zwrite, BlendMode blendMode, bool opaqueZwrite = true)
		{
			return zwrite.GetZWrite(blendMode.IsTransparent(), opaqueZwrite);
		}

		public static bool GetZWrite(this ZWrite zwrite, bool transparent, bool opaqueZwrite = true)
		{
			switch (zwrite)
			{
			case ZWrite.Auto:
				if (!transparent)
				{
					return opaqueZwrite;
				}
				return !transparent;
			case ZWrite.Off:
				return false;
			case ZWrite.On:
				return true;
			default:
				throw new Exception("Invalid zwrite");
			}
		}

		public static Sidedness ToSidedness(this Culling culling)
		{
			return culling switch
			{
				Culling.Off => Sidedness.Double, 
				Culling.Front => Sidedness.Front, 
				Culling.Back => Sidedness.Back, 
				_ => throw new ArgumentException("Invalid culling: " + culling), 
			};
		}

		public static Culling GetCulling(this Sidedness sidedness, BlendMode blendMode)
		{
			return sidedness.GetCulling(blendMode.IsTransparent());
		}

		public static Culling GetCulling(this Sidedness sidedness, bool transparent)
		{
			switch (sidedness)
			{
			case Sidedness.Auto:
				if (transparent)
				{
					return Culling.Off;
				}
				return Culling.Back;
			case Sidedness.Double:
				return Culling.Off;
			case Sidedness.Front:
				return Culling.Back;
			case Sidedness.Back:
				return Culling.Front;
			default:
				throw new Exception("Invalid sidedness");
			}
		}

