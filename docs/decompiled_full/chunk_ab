		{
			DataTreeDictionary dataTreeDictionary = node as DataTreeDictionary;
			position = dataTreeDictionary.ExtractOrThrow<Elements.Core.float3>("Position");
			rotation = dataTreeDictionary.ExtractOrThrow<Elements.Core.floatQ>("Rotation");
			if (!dataTreeDictionary.TryExtract("Width", ref width))
			{
				width = dataTreeDictionary.ExtractOrThrow<float>("Radius");
			}
		}

