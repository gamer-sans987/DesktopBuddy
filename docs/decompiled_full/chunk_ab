			{
				iPBS_Material2.TextureScale = iPBS_Material.TextureScale;
				iPBS_Material2.TextureOffset = iPBS_Material.TextureOffset;
				iPBS_Material2.AlbedoColor = iPBS_Material.AlbedoColor;
				iPBS_Material2.AlbedoTexture = iPBS_Material.AlbedoTexture;
				iPBS_Material2.EmissiveColor = iPBS_Material.EmissiveColor;
				iPBS_Material2.EmissiveMap = iPBS_Material.EmissiveMap;
				iPBS_Material2.NormalScale = iPBS_Material.NormalScale;
				iPBS_Material2.NormalMap = iPBS_Material.NormalMap;
				iPBS_Material2.OcclusionMap = iPBS_Material.OcclusionMap;
				iPBS_Material2.BlendMode = iPBS_Material.BlendMode;
				iPBS_Material2.AlphaCutoff = iPBS_Material.AlphaCutoff;
				IPBS_Specular iPBS_Specular = iPBS_Material2 as IPBS_Specular;
				IPBS_Specular iPBS_Specular2 = iPBS_Material as IPBS_Specular;
				IPBS_Metallic iPBS_Metallic = iPBS_Material as IPBS_Metallic;
				IPBS_Metallic iPBS_Metallic2 = iPBS_Material2 as IPBS_Metallic;
				if (iPBS_Specular != null && iPBS_Specular2 != null)
				{
					iPBS_Specular.SpecularColor = iPBS_Specular2.SpecularColor;
					iPBS_Specular.Smoothness = iPBS_Specular2.Smoothness;
					iPBS_Specular.SpecularMap = iPBS_Specular2.SpecularMap;
				}
				if (iPBS_Metallic2 != null && iPBS_Metallic != null)
				{
					iPBS_Metallic2.Metallic = iPBS_Metallic.Metallic;
					iPBS_Metallic2.Smoothness = iPBS_Metallic.Smoothness;
					iPBS_Metallic2.MetallicMap = iPBS_Metallic.MetallicMap;
				}
			}
			IStereoMaterial stereoMaterial = from as IStereoMaterial;
			IStereoMaterial stereoMaterial2 = to as IStereoMaterial;
			if (stereoMaterial != null && stereoMaterial2 != null)
			{
				stereoMaterial2.StereoTextureTransform = stereoMaterial.StereoTextureTransform;
				stereoMaterial2.LeftEyeTextureScale = stereoMaterial.LeftEyeTextureScale;
				stereoMaterial2.LeftEyeTextureOffset = stereoMaterial.LeftEyeTextureOffset;
				stereoMaterial2.RightEyeTextureScale = stereoMaterial.RightEyeTextureScale;
				stereoMaterial2.RightEyeTextureOffset = stereoMaterial.RightEyeTextureOffset;
			}
			FlatLitToonMaterial flatLitToonMaterial = from as FlatLitToonMaterial;
			XiexeToonMaterial xiexeToonMaterial = to as XiexeToonMaterial;
			if (flatLitToonMaterial != null && xiexeToonMaterial != null)
			{
				xiexeToonMaterial.EmissionMap.Target = flatLitToonMaterial.EmissionMap.Target;
				xiexeToonMaterial.EmissionColor.Value = flatLitToonMaterial.EmissionColor.Value;
				xiexeToonMaterial.EmissionMapOffset.Value = flatLitToonMaterial.EmissionMapOffset.Value;
				xiexeToonMaterial.EmissionMapScale.Value = flatLitToonMaterial.EmissionMapScale.Value;
				xiexeToonMaterial.AlphaClip.Value = flatLitToonMaterial.AlphaCutoff;
				xiexeToonMaterial.BlendMode.Value = flatLitToonMaterial.BlendMode.Value;
				xiexeToonMaterial.ZWrite.Value = flatLitToonMaterial.ZWrite.Value;
				switch (flatLitToonMaterial.Outline.Value)
				{
				case FlatLitToonMaterial.OutlineStyle.None:
					xiexeToonMaterial.Outline.Value = XiexeToonMaterial.OutlineStyle.None;
