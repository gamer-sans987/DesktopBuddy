					xiexeToonMaterial.Outline.Value = XiexeToonMaterial.OutlineStyle.Emissive;
					xiexeToonMaterial.OutlineAlbedoTint.Value = true;
					break;
				}
				xiexeToonMaterial.OutlineColor.Value = flatLitToonMaterial.OutlineColor;
				xiexeToonMaterial.OutlineWidth.Value = flatLitToonMaterial.OutlineWidth.Value;
				xiexeToonMaterial.OffsetFactor.Value = flatLitToonMaterial.OffsetFactor;
				xiexeToonMaterial.OffsetUnits.Value = flatLitToonMaterial.OffsetUnits;
				xiexeToonMaterial.RenderQueue.Value = flatLitToonMaterial.RenderQueue.Value;
			}
		}

		public static bool UndoableSetMaterial(AssetRef<Material> assetRef, IAssetProvider<Material> material)
		{
			if (assetRef.Target != material)
			{
				assetRef.CreateUndoPoint(forceNew: true);
				assetRef.Target = material;
				return true;
			}
			return false;
		}

		public static int ReplaceAll(Slot root, IAssetProvider<Material> oldMaterial, IAssetProvider<Material> newMaterial, bool respectPolicy, bool undoable)
		{
			return root.World.ForeachWorldElement(root, delegate(AssetRef<Material> syncRef)
			{
				if (syncRef.Target == oldMaterial)
				{
					if (respectPolicy)
					{
						IMaterialApplyPolicy componentInParents = syncRef.FindNearestParent<Slot>().GetComponentInParents((IMaterialApplyPolicy p) => p.Enabled);
						if (componentInParents != null && !componentInParents.CanApplyMaterial)
						{
							return;
						}
					}
					if (undoable)
					{
						UndoableSetMaterial(syncRef, newMaterial);
					}
					else
					{
						syncRef.Target = newMaterial;
					}
				}
			}, (Slot s) => s.GetComponent<UndoManager>() == null);
		}

		public static void UpdateVertexColorInterpolationSpace(this ShaderKeywords keywords, ColorProfile profile)
		{
			if (profile != ColorProfile.Linear)
			{
				if ((uint)(profile - 1) <= 1u)
				{
					keywords.SetKeyword("_VERTEX_LINEAR_COLOR", state: false);
					keywords.SetKeyword("_VERTEX_SRGB_COLOR", state: true);
					keywords.SetKeyword("_VERTEX_HDRSRGB_COLOR", state: false);
					return;
				}
				UniLog.Warning($"Unsupported color profile for vertex coloration: {profile}. Falling back to Linear");
			}
			keywords.SetKeyword("_VERTEX_LINEAR_COLOR", state: true);
			keywords.SetKeyword("_VERTEX_SRGB_COLOR", state: false);
