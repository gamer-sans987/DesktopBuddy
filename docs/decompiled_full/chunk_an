		[SyncMethod(typeof(Delegate), null)]
		private void LoadGroupsPressed(IButton button, ButtonEventData eventData)
		{
			button.Enabled = false;
			StartTask(async delegate
			{
				SetGroupsMessage(this.GetLocalized("Migration.Groups.Fetching"));
				LoginResult result = await EnsureLogin();
				if (result.OtherCloud == null)
				{
					if (result.error != null)
					{
						SetGroupsMessage(this.GetLocalized("Migration.Groups.Fetching.LoginFailed", null, ("error", result.error)));
					}
					button.Enabled = true;
				}
				else
				{
					SkyFrostInterface otherCloud = result.OtherCloud;
					CloudResult<List<Membership>> cloudResult = await otherCloud.Groups.GetUserGroupMemeberships();
					if (!cloudResult.IsOK)
					{
						SetGroupsMessage(this.GetLocalized("Migration.Groups.Fetching.Error", null, ("error", result.error)));
						button.Enabled = true;
					}
					else
					{
						_loadGroupsButton.Target.Slot.Destroy();
						_groupsToMigrate.Clear();
						if (cloudResult.Entity.Count == 0)
						{
							SetGroupsMessage(this.GetLocalized("Migration.Groups.NoGroups", null, ("platform", SourcePlatformName)));
						}
						else
						{
							foreach (Membership item in cloudResult.Entity)
							{
								CloudResult<Group> cloudResult2 = await otherCloud.Groups.GetGroup(item.GroupId);
								if (cloudResult2.IsOK && cloudResult2.Entity.AdminUserId == otherCloud.CurrentUserID)
								{
									_groupsToMigrate.Add(cloudResult2.Entity.GroupId, new GroupForMigration(cloudResult2.Entity.Name, migrate: false));
								}
							}
							if (_groupsToMigrate.Count > 0)
							{
								AddGroupCheckboxes(_groupsToMigrate);
								SetGroupsMessage("");
							}
							else
							{
								SetGroupsMessage(this.GetLocalized("Migration.Groups.NotGroupAdmin", null, ("platform", SourcePlatformName)));
							}
						}
					}
				}
			});
		}

		private void AddGroupCheckboxes(Dictionary<string, GroupForMigration> groups)
		{
			_groupsRoot.Target.DestroyChildren();
			UIBuilder uIBuilder = new UIBuilder(_groupsRoot.Target);
			RadiantUI_Constants.SetupDefaultStyle(uIBuilder);
			uIBuilder.Style.MinHeight = 32f;
			foreach (KeyValuePair<string, GroupForMigration> group in groups)
			{
				Checkbox checkbox = uIBuilder.Checkbox((LocaleString)group.Value.Name, state: false, labelFirst: false);
				checkbox.Slot.Name = group.Key;
				checkbox.Slot.GetComponent<Button>().EnabledField.DriveFrom(_migrateGroups);
				checkbox.IsChecked = group.Value.ShouldMigrate;
			}
		}

