	[Category(new string[] { "Permissions" })]
	public class UserPermissions : PermissionsComponent
	{
		public readonly Sync<bool> AllowEnableEditMode;

		public readonly Sync<bool> AllowRespawn;

		public readonly Sync<bool> AllowSilence;

		public readonly Sync<bool> AllowKick;

		public readonly Sync<bool> AllowBan;

		public readonly Sync<bool> AllowAssignRoles;

		public readonly Sync<bool> AllowSeeOtherRoles;

		public override int Version => 3;

		public bool CanLocalUserSeeOtherRoles
		{
			get
			{
				if (!AllowAssignRoles && !AllowSeeOtherRoles)
				{
					return base.World.IsAuthority;
				}
				return true;
			}
		}

		public override PermissionViolationAction DefaultViolationAction => PermissionViolationAction.TempBanUser;

		public override bool ValidatesType(Type type)
		{
			return typeof(User).IsAssignableFrom(type);
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			AllowEnableEditMode.Value = true;
			AllowSilence.Value = true;
			AllowKick.Value = true;
			AllowBan.Value = false;
			AllowRespawn.Value = true;
			AllowAssignRoles.Value = true;
			AllowSeeOtherRoles.Value = false;
			AllowEnableEditMode.OnValueChange += OnValueChange;
			AllowSilence.OnValueChange += OnValueChange;
			AllowKick.OnValueChange += OnValueChange;
			AllowBan.OnValueChange += OnValueChange;
			AllowRespawn.OnValueChange += OnValueChange;
			AllowAssignRoles.OnValueChange += OnValueChange;
			AllowSeeOtherRoles.OnValueChange += OnValueChange;
		}

		private void OnValueChange(SyncField<bool> syncField)
		{
			if (base.World.State == FrooxEngine.World.WorldState.Running && !base.World.IsInitializingOrLoading && !syncField.IsLoading && base.World != Userspace.UserspaceWorld)
			{
				UniLog.Log($"{syncField.Name} changed to {syncField.Value}. Last Modifying User: {syncField.LastModifyingUser}", stackTrace: true);
			}
		}

		public override void Cleanup(User user, Worker worker)
		{
			User user2 = (User)worker;
			if (!AllowEnableEditMode)
			{
				user2.editMode.Value = false;
			}
			if (!user.IsHost)
			{
				if (user2.silence.WasLastModifiedBy(user) && (!AllowSilence || user2 == user))
				{
					user2.silence.Value = base.Permissions.IsSilenced(user2);
				}
				if (user2.kickRequest.WasLastModifiedBy(user) && !AllowKick)
				{
					user2.kickRequest.Value = User.KickRequestState.None;
				}
				if (user2.banRequest.WasLastModifiedBy(user) && !AllowBan)
				{
					user2.banRequest.Value = false;
				}
			}
			if (base.World.IsAuthority && user2.Role > user.Role)
			{
				user2.Role = user.Role;
			}
		}

		public override bool Validate(User user, Worker worker)
		{
			User user2 = (User)worker;
			if (!user.IsHost)
			{
				if (user2.silence.Value)
				{
					UniLog.Log($"Validating Silence for {user2} by {user}. AllowSilence: {AllowSilence}, LastModifiedBy: {user2.silence.LastModifyingUser}");
					if (user2.silence.WasLastModifiedBy(user) && (!AllowSilence || user2 == user))
					{
						return false;
					}
				}
				if (user2.kickRequest.Value != User.KickRequestState.None)
				{
					UniLog.Log($"Validating KickRequest for {user2} by {user}. AllowKick: {AllowKick}, LastModifiedBy: {user2.kickRequest.LastModifyingUser}");
					if (user2.kickRequest.WasLastModifiedBy(user) && !AllowKick)
					{
						return false;
					}
				}
				if (user2.banRequest.Value)
				{
					UniLog.Log($"Validating BanRequest for {user2} by {user}. AllowBan: {AllowBan}, LastModifiedBy: {user2.banRequest.LastModifyingUser}");
					if (user2.banRequest.WasLastModifiedBy(user) && !AllowBan)
					{
						return false;
					}
				}
			}
			if (!AllowEnableEditMode && user2.editMode.Value)
			{
				return false;
			}
			if (user2.role.WasLastModifiedBy(user) && !user.IsHost)
			{
				if (!AllowAssignRoles)
				{
					return false;
				}
				if (user2 == user)
				{
					return false;
				}
				if (user2.IsHost)
				{
					return false;
				}
				if (user2.Role == null || user2.Role > user.Role)
				{
					return false;
				}
			}
			return true;
		}

