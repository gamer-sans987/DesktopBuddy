	[GloballyRegistered]
	public class SettingManagersManager : Component
	{
		public const string SETTINGS_RECORD_ID = "R-SettingsData";

		public static bool NeverSave;

		public static string RestoreCloudSettings;

		public readonly SyncRef<SettingManager> LocalSettings;

		public readonly SyncRef<SettingManager> CloudSettings;

		private FrooxEngine.Store.Record _localSettingRecord;

		private FrooxEngine.Store.Record _cloudSettingRecord;

		public override bool UserspaceOnly => true;

		protected override void OnAwake()
		{
			base.OnAwake();
			Userspace.RegisterExitTask(SaveAllSettings);
		}

		public async Task SaveAllSettings()
		{
			if (NeverSave)
			{
				UniLog.Log("Setting saving is blocked, skipping");
				return;
			}
			UniLog.Log("Saving all settings");
			Task task = StartTask(SaveCloudSettings);
			Task task2 = StartTask(SaveLocalSettings);
			await Task.WhenAll(task2, task);
		}

		public async Task LoadLocalSettings()
		{
			UniLog.Log("Loading local settings");
			var (target, localSettingRecord) = await LoadSettings(base.Engine.LocalDB.LocalOwnerID);
			LocalSettings.Target = target;
			_localSettingRecord = localSettingRecord;
			await new Updates(2);
			UniLog.Log("Local settings loaded");
			await AutoRegisterSettings();
		}

		private async Task AutoRegisterSettings()
		{
			await default(ToBackground);
			try
			{
				MethodInfo method = typeof(Settings).GetMethod("GetActiveSetting", BindingFlags.Static | BindingFlags.Public);
				foreach (Type item in WorkerInitializer.Workers.Where((Type t) => !t.IsAbstract && typeof(SettingComponent).IsAssignableFrom(t)))
				{
					if (item.GetCustomAttribute<AutoRegisterSetting>(inherit: true, fromInterfaces: false) != null)
					{
						method.MakeGenericMethod(item).Invoke(null, null);
					}
				}
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception auto-registering settings:\n" + ex);
			}
		}

		public async Task LoadCloudSettings()
		{
			UniLog.Log("Loading Cloud Settings for " + base.Cloud.CurrentUserID);
			try
			{
				if (base.Cloud.CurrentUserID == null)
				{
					throw new InvalidOperationException("Trying to load cloud settings when no user is currently logged in");
				}
				(SettingManager, FrooxEngine.Store.Record) obj = await LoadSettings(base.Cloud.CurrentUserID, RestoreCloudSettings);
				SettingManager item = obj.Item1;
				FrooxEngine.Store.Record item2 = obj.Item2;
				RestoreCloudSettings = null;
				if (CloudSettings.Target != null)
				{
					UniLog.Warning("There are existing cloud settings when loading new ones");
					CloudSettings.Target.Slot.Destroy();
				}
				CloudSettings.Target = item;
				_cloudSettingRecord = item2;
				LocalSettings.Target.SupressedBy.Target = item;
				await new Updates(2);
				UniLog.Log("Cloud settings loaded");
				await AutoRegisterSettings();
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception when loading cloud settings:\n" + ex);
			}
		}

		private async Task<(SettingManager, FrooxEngine.Store.Record)> LoadSettings(string ownerId, string restoreFromFile = null)
		{
			string name = ownerId + " Settings";
			Slot settingSlot = base.Slot.AddSlot(name);
			SettingManager settings = null;
			FrooxEngine.Store.Record record = null;
			bool convertLegacySettings = false;
			try
			{
				Uri recordUri = base.Cloud.Platform.GetRecordUri(ownerId, "R-SettingsData");
				CloudResult<FrooxEngine.Store.Record> cloudResult = await base.Engine.RecordManager.FetchRecord(recordUri);
				if (cloudResult.State == HttpStatusCode.NotFound)
				{
					UniLog.Log("Settings not found, scheduling conversion of legacy settings for " + ownerId);
					convertLegacySettings = true;
				}
				if (cloudResult.State == HttpStatusCode.Conflict)
				{
					UniLog.Warning("Conflict when fetching settings. Waiting for any sync tasks to complete first");
					do
					{
						await Task.Delay(TimeSpan.FromSeconds(1L));
					}
					while (base.Engine.RecordManager.SyncingRecordsCount > 0);
					UniLog.Log("Fetching settings again");
					cloudResult = await base.Engine.RecordManager.FetchRecord(recordUri);
				}
				if (cloudResult.IsOK)
				{
					record = cloudResult.Entity;
					Uri uri = new Uri(cloudResult.Entity.AssetURI);
					if (!string.IsNullOrEmpty(restoreFromFile) && File.Exists(restoreFromFile))
					{
						UniLog.Log("Restoring settings from file: " + restoreFromFile);
						uri = await base.Engine.LocalDB.ImportLocalAssetAsync(restoreFromFile, LocalDB.ImportLocation.Copy);
					}
					if (await settingSlot.LoadObjectAsync(uri))
					{
						settings = settingSlot.GetComponent<SettingManager>();
					}
					else
					{
						UniLog.Warning("Failed to load settings for " + ownerId);
					}
				}
				else
				{
					UniLog.Log($"Could not fetch record for settings for {ownerId}: {cloudResult}");
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception when trying to load settings for {ownerId}:\n{value}");
			}
			if (settings == null)
			{
				settingSlot.DestroyChildren();
				UniLog.Log(ownerId + " settings do not exist, creating fresh");
				settings = settingSlot.AttachComponent<SettingManager>();
			}
			settings.Slot.ActiveSelf = true;
			settings.Enabled = true;
			settings.OwnerId.Value = ownerId;
			if (convertLegacySettings)
			{
				StartTask(async delegate
				{
					_ = 1;
					try
					{
						await new Updates(30);
						await LegacySettingsConversion.ConvertSettings(base.World, ownerId);
					}
					catch (Exception value2)
					{
						UniLog.Error($"Exception when converting legacy settings:\n{value2}");
					}
				});
			}
			return (settings, record);
		}

		public async Task SaveLocalSettings()
		{
			if (NeverSave)
			{
				UniLog.Log("Setting saving is blocked, skipping");
				return;
			}
			UniLog.Log("Saving Local Settings");
			_localSettingRecord = await SaveSettings(LocalSettings.Target, _localSettingRecord, base.Engine.LocalDB.LocalOwnerID);
			UniLog.Log("Local Settings Saved");
		}

		public async Task SaveCloudSettings()
		{
			if (CloudSettings.Target != null && base.Cloud.CurrentUserID != null)
			{
				if (NeverSave)
				{
					UniLog.Log("Setting saving is blocked, skipping");
					return;
				}
				UniLog.Log("Saving cloud settings for " + base.Cloud.CurrentUserID);
				_cloudSettingRecord = await SaveSettings(CloudSettings.Target, _cloudSettingRecord, base.Cloud.CurrentUserID);
				UniLog.Log("Cloud settings saved");
			}
		}

		public async Task SaveCloudSettingsAndUnload()
		{
			await SaveCloudSettings();
			CloudSettings.Target.Slot.Destroy();
			LocalSettings.Target.SupressedBy.Target = null;
		}

		private async Task<FrooxEngine.Store.Record> SaveSettings(SettingManager manager, FrooxEngine.Store.Record record, string ownerId)
		{
			SavedGraph data = manager.Slot.SaveObject(DependencyHandling.CollectAssets);
			await default(ToBackground);
			Uri uri = await base.Engine.LocalDB.SaveAssetAsync(data, base.Engine);
			if (record == null)
			{
				record = RecordHelper.CreateForObject<FrooxEngine.Store.Record>(ownerId + " Settings", ownerId, uri.ToString(), null, "R-SettingsData");
			}
			else
			{
				record.AssetURI = uri.ToString();
			}
			await base.Engine.RecordManager.SaveRecord(record, data);
			return record;
		}

