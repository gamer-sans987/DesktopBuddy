		public void Update(Contact contact, ContactData data)
		{
			Contact = contact;
			if (data != null)
			{
				Data = data;
			}
			_statusIndicator.Target.Tint.Value = LegacyUIStyle.GetStatusColor(contact, data, base.Engine);
			if (contact.IsSelfContact)
			{
				_username.Target.LocaleContent = "Contacts.SelfAccount".AsLocaleKey("<i>{0}</i>");
			}
			else
			{
				_username.Target.Content.Value = StringParsingHelper.SanitizeFormatTags(contact.ContactUsername) ?? contact.ContactUserId.Substring(2);
			}
			_rawUsername.Value = contact.ContactUsername ?? contact.ContactUserId.Substring(2);
			if (contact.AlternateUsernames != null)
			{
				_alternateNames.AddRange(contact.AlternateUsernames);
			}
			if (Uri.TryCreate(contact.Profile?.IconUrl, UriKind.Absolute, out Uri result))
			{
				_thumbnailTexture.Target.URL.Value = result;
				_thumbnail.Target.Tint.Value = Elements.Core.colorX.White;
			}
			else
			{
				_thumbnailTexture.Target.URL.Value = OfficialAssets.Graphics.Thumbnails.AnonymousHeadset;
				_thumbnail.Target.Tint.Value = LegacyUIStyle.NameTint(contact.ContactUserId);
			}
			if (contact.IsAccepted && contact.ContactStatus == ContactStatus.Accepted)
			{
				SessionInfo sessionInfo = Data?.CurrentSessionInfo;
				if (sessionInfo != null)
				{
					_joinButton.Target.Label.LocaleContent = "World.Actions.Join".AsLocaleKey();
					_joinButton.Target.Slot.ActiveSelf = sessionInfo != null && sessionInfo.IsCompatible() && sessionInfo.HostUserSessionId != base.Cloud.Status.UserSessionId;
				}
				else if (Data != null && Data.CurrentStatus.OnlineStatus != OnlineStatus.Offline)
				{
					_joinButton.Target.Label.LocaleContent = "Contacts.AskToJoin".AsLocaleKey();
					_joinButton.Target.Slot.ActiveSelf = true;
				}
				else
				{
					_joinButton.Target.Slot.ActiveSelf = false;
				}
				_status.Target.Color.Value = LegacyUIStyle.GetStatusColor(contact, data, base.Engine, text: true);
				if (contact.IsPartiallyMigrated)
				{
					_status.Target.Content.SetLocalized("Contacts.Migrated", "<i>{0}</i>");
				}
				else if (Data == null || Data.CurrentStatus.OnlineStatus == OnlineStatus.Offline)
				{
					_status.Target.Content.SetLocalized("Profile.Status.Offline", "<i>{0}</i>");
				}
				else if (Data.CurrentStatus.SessionType == UserSessionType.Headless)
				{
					_status.Target.Content.SetLocalized("Profile.Status.Headless", "<i>{0}</i>");
				}
				else if (data.CurrentStatus.SessionType == UserSessionType.Bot)
				{
					_status.Target.Content.SetLocalized("Profile.Status.Bot", "<i>{0}</i>", "version", data.CurrentStatus.AppVersion);
				}
				else if (data.CurrentStatus.SessionType == UserSessionType.ChatClient)
				{
					_status.Target.Content.SetLocalized("Profile.Status.ChatClient", "<i>{0}</i>", "version", data.CurrentStatus.AppVersion);
				}
				else if (sessionInfo == null)
				{
					if (contact.ContactUserId == base.Cloud.Platform.AppUserId)
					{
						_status.Target.Content.SetLocalized("Contacts.Bot");
						return;
					}
					switch (Data.CurrentStatus.CurrentSession?.AccessLevel)
					{
					case SessionAccessLevel.RegisteredUsers:
					case SessionAccessLevel.Anyone:
						_status.Target.Content.SetLocalized("Contacts.InHidden");
						break;
					case SessionAccessLevel.ContactsPlus:
						_status.Target.Content.SetLocalized("Contacts.InHiddenContactsPlus");
						break;
					case SessionAccessLevel.Contacts:
						if (Data.CurrentStatus.CurrentSession.SessionHidden)
						{
							_status.Target.Content.SetLocalized("Contacts.InHiddenContactsOnly");
						}
						else
						{
							_status.Target.Content.SetLocalized("Contacts.InContactsOnly");
						}
						break;
					case SessionAccessLevel.LAN:
						_status.Target.Content.SetLocalized("Contacts.InLAN");
						break;
					case null:
						_status.Target.Content.SetLocalized("Contacts.NoSession");
						break;
					default:
						_status.Target.Content.SetLocalized("Contacts.InPrivate");
						break;
					}
				}
				else if (sessionInfo.IsCompatible())
				{
					_status.Target.Content.SetLocalized("Contacts.InSession", null, "name", sessionInfo.Name);
				}
				else
				{
					_status.Target.Content.SetLocalized("Contacts.IncompatibleSession");
				}
				return;
			}
			_joinButton.Target.Slot.ActiveSelf = false;
			switch (contact.ContactStatus)
			{
			case ContactStatus.Accepted:
				if (contact.IsAccepted)
				{
					_status.Target.Content.SetLocalized("Profile.Status.Offline", "<i>{0}</i>");
				}
				else
				{
					_status.Target.Content.SetLocalized("Contacts.RequestSent", "<i>{0}</i>");
				}
				break;
			case ContactStatus.Requested:
				_status.Target.Content.SetLocalized("Contacts.RequestReceived", "<i>{0}</i>");
				break;
			case ContactStatus.Ignored:
				_status.Target.Content.SetLocalized("Contacts.RequestIgnored", "<i>{0}</i>");
				break;
			case ContactStatus.Blocked:
				_status.Target.Content.SetLocalized("Contacts.Blocked", "<i>{0}</i>");
				break;
			case ContactStatus.SearchResult:
				_status.Target.Content.SetLocalized("Contacts.SearchResult", "<i>{0}</i>");
				break;
			}
		}

