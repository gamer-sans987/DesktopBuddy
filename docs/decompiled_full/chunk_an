		[SyncMethod(typeof(Delegate), null)]
		private void StartMigrationPressed(IButton button, ButtonEventData eventData)
		{
			button.Enabled = false;
			string originalText = button.LabelText;
			AccountMigrationConfig config = new AccountMigrationConfig();
			config.ClearAll();
			config.MigrateContacts = _migrateContacts.Value;
			config.MigrateMessageHistory = _migrateMessageHistory.Value;
			config.MigrateCloudVariables = _migrateCloudVariables.Value;
			config.MigrateCloudVariableDefinitions = _migratedCloudVariableDefinitions.Value;
			config.MigrateUserRecords = _migrateRecords.Value;
			config.MigrateGroups = _migrateGroups.Value;
			config.PreserveOldHome = _preserveOldHome.Value;
			if (config.MigrateGroups && _groupsToMigrate.Count > 0)
			{
				HashSet<string> hashSet = new HashSet<string>();
				foreach (KeyValuePair<string, GroupForMigration> item in _groupsToMigrate)
				{
					if (item.Value.ShouldMigrate)
					{
						hashSet.Add(item.Key);
					}
				}
				config.GroupsToMigrate = hashSet;
			}
			if (!config.IsMigratingSomething && !_migrateFavorites.Value)
			{
				button.Enabled = true;
				ShowErrorOnButton(button, this.GetLocalized("Migration.NothingSelected"), originalText);
				return;
			}
			StartTask(async delegate
			{
				LoginResult loginResult = await EnsureLogin();
				if (loginResult.OtherCloud == null)
				{
					button.Enabled = true;
					if (loginResult.error != null)
					{
						UniLog.Warning("Login Error: " + loginResult.error);
						ShowErrorOnButton(button, this.GetLocalized("Migration.Error", null, ("error", loginResult.error)), originalText);
					}
				}
				else
				{
					CloudResult<List<AccountMigrationTask>> cloudResult = await base.Cloud.Migration.CreateMigrationTask(new MigrationInitialization
					{
						SourceSession = loginResult.OtherCloud.Session.CurrentSession,
						Config = config,
						SourceCloudConfig = _otherCloudConfig,
						SourceSecretMachineID = _otherCloud.SecretMachineId,
						SourceUID = _otherCloud.UID
					}, _migrateFavorites.Value, _overwriteFavorites.Value);
					if (cloudResult.IsOK)
					{
						base.Cloud.Migration.ForceMigrationTaskUpdate();
						base.Slot.CloseModalOverlay();
					}
					else
					{
						UniLog.Warning("Migration Creation Error: " + cloudResult.Content);
						button.Enabled = true;
						ShowErrorOnButton(button, this.GetLocalized("Migration.Error", null, ("error", cloudResult.Content)), originalText);
					}
				}
			});
		}

