		protected override void OnAwake()
		{
			base.OnAwake();
			Priority.OnValueChange += PriorityChanged;
			this.FindNearestParent<Component>()?.RunSynchronously(delegate
			{
				ISyncList syncList = this.FindNearestParent<ISyncList>();
				if (syncList.Count != 0 && syncList.GetElement(0) == this)
				{
					UpdateFirstAndLast();
				}
