		private void UpdateSelectedContact()
		{
			_messagesRoot.Target.DestroyChildren();
			UpdateSelectedContactUI();
			if (SelectedContact == null)
			{
				return;
			}
			UserMessages userMessages = base.Engine.Cloud.Messages.GetUserMessages(SelectedContact.ContactUserId);
			string _requestContactId = SelectedContact.ContactUserId;
			messagesUi.Text("General.Loading".AsLocaleKey());
			_lastTimestampMessage = null;
			StartTask(async delegate
			{
				await default(ToBackground);
				await userMessages.EnsureHistory().ConfigureAwait(continueOnCapturedContext: false);
				List<SkyFrost.Base.Message> messages = Pool.BorrowList<SkyFrost.Base.Message>();
				userMessages.GetMessages(messages);
				await default(ToWorld);
				if (!(_requestContactId != SelectedContact?.ContactUserId))
				{
					_messagesRoot.Target.DestroyChildren();
					_messageBackgrounds.Clear();
					foreach (SkyFrost.Base.Message item in messages)
					{
						AddMessage(item);
					}
					Pool.Return(ref messages);
					if (SelectedContact.CanBeInteractedWith)
					{
						_sendMessageButton.Target.Enabled = true;
					}
					_messagesScrollRect.Target.NormalizedPosition.Value = new Elements.Core.float2(0f, 1f);
					await default(ToBackground);
					userMessages.MarkAllRead();
				}
			});
		}

