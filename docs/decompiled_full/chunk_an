	public class WorldLoadProgress : Component
	{
		internal World TargetWorld;

		private Elements.Core.float3 _intermediatePosition;

		private Elements.Core.floatQ _intermediateRotation;

		private float _disappearThreshold;

		protected readonly SyncRef<Slot> _visual;

		protected readonly SyncRef<WorldLoadingProgressInterface> ProgressIndicator;

		private long toDownloadBytes;

		private long downloadedBytes;

		private long bytesPerSecond;

		private bool nameUpdated;

		private bool done;

		/// <summary>
		/// How long after, the world is loaded should the indicator be destroyed.
		/// </summary>
		private float disappearTime = 2f;

		public bool Visible
		{
			get
			{
				return _visual.Target.ActiveSelf;
			}
			set
			{
				_visual.Target.ActiveSelf = value;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			base.Engine.WorldManager.WorldFocused += WorldManager_WorldFocused;
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			_visual.Target = base.Slot.AddSlot("Visual");
			Slot target = _visual.Target;
			target.LocalScale *= 2;
			StartTask(async delegate
			{
				WorldLoadingProgressInterface target2 = await _visual.Target.SpawnEntity<WorldLoadingProgressInterface, LegacySegmentCircleProgress>(FavoriteEntity.WorldLoadingIndicator);
				ProgressIndicator.Target = target2;
			});
			StartTask(DownloadUpdate);
		}

		private async Task DownloadUpdate()
		{
			List<EngineGatherJob> jobs = new List<EngineGatherJob>();
			AssetManager _assetManager = base.Engine.AssetManager;
			await default(ToBackground);
			while (!IsRemoved)
			{
				_assetManager.GetActiveJobs(jobs);
				bytesPerSecond = _assetManager.TotalBytesPerSecond;
				long num = 0L;
				long num2 = 0L;
				foreach (EngineGatherJob item in jobs)
				{
					if (item.TotalBytes > 0)
					{
						num += item.TotalBytes;
						num2 += item.DownloadedBytes;
					}
				}
				toDownloadBytes = num;
				downloadedBytes = num2;
				jobs.Clear();
				await Task.Delay(TimeSpan.FromSeconds(0.20000000298023224));
			}
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			TargetWorld = null;
			base.Engine.WorldManager.WorldFocused -= WorldManager_WorldFocused;
		}

		private void WorldManager_WorldFocused(World obj)
		{
			RunSynchronously(delegate
			{
				Visible = obj == TargetWorld;
			});
		}

		protected override void OnCommonUpdate()
		{
			Elements.Core.float3 v = new Elements.Core.float3(-0.2f, -0.6f, 1.5f);
			Elements.Core.floatQ target = Elements.Core.floatQ.LookRotation(base.Slot.GlobalPosition - base.World.LocalUser.Root.ViewPosition);
			Elements.Core.float3 target2 = base.World.LocalUser.Root.ViewPosition + base.World.LocalUser.Root.ViewRotation * v;
			base.Slot.GlobalPosition = MathX.SmoothLerp(base.Slot.GlobalPosition, target2, ref _intermediatePosition, base.Time.Delta * 3f);
			base.Slot.GlobalRotation = MathX.SmoothSlerp(base.Slot.GlobalRotation, in target, ref _intermediateRotation, base.Time.Delta * 5f);
			if (done || TargetWorld == null)
			{
				return;
			}
			WorldAssetManager assetManager = TargetWorld.AssetManager;
			if (TargetWorld.IsDestroyed)
			{
				if (TargetWorld.State == FrooxEngine.World.WorldState.Failed)
				{
					ProgressIndicator.Target?.Failed(TargetWorld.FailReasonDescription.AsLocaleKey());
					done = true;
					RunInSeconds(5f, base.Slot.Destroy);
					TargetWorld = null;
				}
				else
				{
					base.Slot.Destroy();
				}
				return;
			}
			if (base.Engine.WorldManager.FocusedWorld == TargetWorld && assetManager.InitialAssetsLoaded)
			{
				if (_disappearThreshold == 0f)
				{
					ProgressIndicator.Target?.Loaded("World.Loaded".AsLocaleKey());
				}
				_disappearThreshold += base.Time.Delta;
			}
			else
			{
				_disappearThreshold = 0f;
			}
			if (_disappearThreshold >= disappearTime)
			{
				base.Slot.Destroy();
				return;
			}
			if (TargetWorld.State == FrooxEngine.World.WorldState.Initializing)
			{
				if (!TargetWorld.IsAuthority && TargetWorld.Session.Connections.ConnectionStatusDescription != null)
				{
					ProgressIndicator.Target?.UpdatePhase(TargetWorld.Session.Connections.ConnectionStatusDescription, TargetWorld.Session.Connections.ConnectionStatusDetail);
				}
				return;
			}
			if (assetManager.TotalAssetsToLoad > 0)
			{
				ProgressIndicator.Target?.Update(assetManager, toDownloadBytes, downloadedBytes, bytesPerSecond);
			}
			if (!nameUpdated && TargetWorld.Name != null)
			{
				ProgressIndicator.Target.UpdateName(TargetWorld.Name);
				nameUpdated = true;
			}
		}

		public static Task<WorldLoadProgress> CreateIndicator(LocaleString worldName)
		{
			return CreateIndicator(worldName, "World.Loading".AsLocaleKey(), default(LocaleString));
		}

		public static Task<WorldLoadProgress> CreateIndicator(LocaleString worldName, LocaleString initialMessage, LocaleString initialDetail)
		{
			if (Userspace.UserspaceWorld == null)
			{
				return Task.FromResult<WorldLoadProgress>(null);
			}
			return Userspace.UserspaceWorld.Coroutines.StartTask(async delegate
			{
				await default(ToWorld);
				Slot slot = Userspace.UserspaceWorld.AddSlot("World Load Progress");
				WorldLoadProgress indicator = slot.AttachComponent<WorldLoadProgress>();
				while (indicator.ProgressIndicator.Target == null)
				{
					await default(NextUpdate);
				}
				indicator.ProgressIndicator.Target.UpdateName(worldName);
				indicator.ProgressIndicator.Target.UpdatePhase(initialMessage, initialDetail);
				return indicator;
			});
		}

		public static async Task<WorldLoadProgress> ShowMessage(LocaleString worldName, LocaleString mainMessage, LocaleString detailedInfo, ProgressStage? stage = null, float timeout = 5f)
		{
			WorldLoadProgress indicator = await CreateIndicator(worldName, default(LocaleString), default(LocaleString));
			if (indicator == null)
			{
				return null;
			}
			await indicator.StartTask(async delegate
			{
				await default(ToWorld);
				if (stage == ProgressStage.Completed)
				{
					indicator.ProgressIndicator.Target?.Loaded(mainMessage);
				}
				else if (stage == ProgressStage.Failed)
				{
					indicator.ProgressIndicator.Target?.Failed(mainMessage);
				}
				else
				{
					indicator.ProgressIndicator.Target?.UpdatePhase(mainMessage, detailedInfo);
				}
				await Task.Delay(TimeSpan.FromSeconds(timeout));
				indicator.Slot.Destroy();
			});
			return indicator;
		}

