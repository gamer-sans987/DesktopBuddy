		public static async Task<WorldStartSettings> GenerateStartSettings(this WorldStartupParameters worldStartup, IPlatformProfile profile)
		{
			WorldStartSettings worldStartSettings = new WorldStartSettings();
			if (worldStartup.LoadWorldURL != null)
			{
				if (!Uri.TryCreate(worldStartup.LoadWorldURL, UriKind.Absolute, out Uri result))
				{
					throw new Exception("Invalid World Load URL: " + worldStartup.LoadWorldURL);
				}
				if (!profile.IsValidRecordUri(result))
				{
					throw new Exception($"Incompatible World Load URL: {worldStartup.LoadWorldURL}. Only {profile.RecordScheme}:/// urls are supported.");
				}
				worldStartSettings.URIs = new List<Uri> { result };
			}
			else
			{
				if (worldStartup.LoadWorldPresetName == null)
				{
					throw new Exception("No world start information!");
				}
				WorldPreset worldPreset = WorldPresets.Presets.FirstOrDefault((WorldPreset p) => p.Name?.Equals(worldStartup.LoadWorldPresetName, StringComparison.InvariantCultureIgnoreCase) ?? false);
				if (worldPreset == null)
				{
					throw new Exception($"World preset: {worldPreset} not found!");
				}
				worldStartSettings.InitWorld = worldPreset.Method;
			}
			worldStartSettings.ForcePort = worldStartup.ForcePort.GetValueOrDefault();
			worldStartSettings.ForceSessionId = worldStartup.CustomSessionId;
			worldStartSettings.DefaultAccessLevel = worldStartup.AccessLevel;
			worldStartSettings.HideFromListing = worldStartup.HideFromPublicListing;
			worldStartSettings.GetExisting = false;
			return worldStartSettings;
		}

		public static async Task SetWorldParameters(this WorldStartupParameters info, World world, Func<Task> configSaveCallback = null)
		{
			if (info.SessionName != null)
			{
				world.Name = info.SessionName;
			}
			if (info.Tags != null)
			{
				world.Tags = info.Tags;
			}
			world.AccessLevel = info.AccessLevel;
			if (info.HideFromPublicListing.HasValue)
			{
				world.HideFromListing = info.HideFromPublicListing.Value;
			}
			if (info.UseCustomJoinVerifier)
			{
				world.UseCustomJoinVerifier = true;
			}
			world.MaxUsers = info.MaxUsers;
			world.MobileFriendly = info.MobileFriendly;
			world.Description = info.Description;
			if (info.RoleCloudVariable != null)
			{
				if (!CloudVariableHelper.IsValidPath(info.RoleCloudVariable))
				{
					UniLog.Log("Invalid RoleCloudVariable: " + info.RoleCloudVariable);
				}
				else
				{
					world.Permissions.DefaultRoleCloudVariable = info.RoleCloudVariable;
				}
			}
			if (info.AllowUserCloudVariable != null)
			{
				if (!CloudVariableHelper.IsValidPath(info.AllowUserCloudVariable))
				{
					UniLog.Log("Invalid AllowUserCloudVariable: " + info.AllowUserCloudVariable);
				}
				else
				{
					world.AllowUserCloudVariable = info.AllowUserCloudVariable;
				}
			}
			if (info.DenyUserCloudVariable != null)
			{
				if (!CloudVariableHelper.IsValidPath(info.DenyUserCloudVariable))
				{
					UniLog.Log("Invalid DenyUserCloudVariable: " + info.DenyUserCloudVariable);
				}
				else
				{
					world.DenyUserCloudVariable = info.DenyUserCloudVariable;
				}
			}
			if (info.RequiredUserJoinCloudVariable != null)
			{
				if (!CloudVariableHelper.IsValidPath(info.RequiredUserJoinCloudVariable))
				{
					UniLog.Log("Invalid RequiredUserJoinCloudVariable: " + info.RequiredUserJoinCloudVariable);
				}
				else
				{
					world.RequiredUserJoinCloudVariable = info.RequiredUserJoinCloudVariable;
				}
			}
			if (info.RequiredUserJoinCloudVariableDenyMessage != null)
			{
				world.RequiredUserJoinCloudVariableDenyMessage = info.RequiredUserJoinCloudVariableDenyMessage;
			}
			if (info.OverrideCorrespondingWorldId?.IsValid ?? false)
			{
				world.CorrespondingWorldId = info.OverrideCorrespondingWorldId.ToString();
			}
			if (info.AwayKickMinutes > 0.0)
			{
				world.AwayKickEnabled = true;
				world.AwayKickMinutes = (float)info.AwayKickMinutes;
			}
			await world.Coroutines.StartTask(async delegate
			{
				_ = 4;
				try
				{
					await default(NextUpdate);
					if (info.EnableResoniteLink && world.IsAllowedToRunResoniteLink())
					{
						world.StartResoniteLink(info.ForceResoniteLinkPort);
					}
					if (!info.KeepOriginalRoles)
					{
						world.Permissions.DefaultUserPermissions.Clear();
					}
					if (info.DefaultUserRoles != null)
					{
						foreach (KeyValuePair<string, string> userRole in info.DefaultUserRoles)
						{
							CloudResult<SkyFrost.Base.User> cloudResult = await world.Engine.Cloud.Users.GetUserByName(userRole.Key);
							if (cloudResult.IsError)
							{
								UniLog.Log("User " + userRole.Key + " not found: " + cloudResult.State);
							}
							else
							{
								PermissionSet permissionSet = world.Permissions.FindRoleByName(userRole.Value);
								if (permissionSet == null)
								{
									UniLog.Log("Role " + userRole.Value + " not available for world: " + world.RawName);
								}
								else
								{
									PermissionSet permissionSet2 = world.Permissions.FilterRole(permissionSet);
									if (permissionSet2 != permissionSet)
									{
										UniLog.Warning($"Cannot use default role {permissionSet.RoleName.Value} for {userRole.Key}, because it's higher than the host role {permissionSet2.RoleName.Value} in world {world.RawName}");
									}
									permissionSet = permissionSet2;
									world.Permissions.DefaultUserPermissions.Remove(cloudResult.Entity.Id);
									world.Permissions.DefaultUserPermissions.Add(cloudResult.Entity.Id, permissionSet);
								}
							}
						}
					}
					if (info.AutoInviteUsernames != null && info.AutoInviteUsernames.Count > 0)
					{
						if (world.Engine.Cloud.CurrentUser == null)
						{
							UniLog.Warning("Not logged in, cannot send auto-invites!");
						}
						else
						{
							foreach (string username in info.AutoInviteUsernames)
							{
								Contact contact = world.Engine.Cloud.Contacts.FindContact((Contact c) => c.ContactUsername.Equals(username, StringComparison.InvariantCultureIgnoreCase));
								if (contact == null)
								{
									UniLog.Warning(username + " is not in the contacts list, cannot auto-invite");
								}
								else
								{
									UserMessages messages = world.Engine.Cloud.Messages.GetUserMessages(contact.ContactUserId);
									if (!string.IsNullOrWhiteSpace(info.AutoInviteMessage))
									{
										await messages.SendTextMessage(info.AutoInviteMessage);
									}
									await messages.SendMessage(await messages.CreateInviteMessage(world));
									UniLog.Log(username + " invited.");
								}
							}
						}
					}
					if (info.InviteRequestHandlerUsernames != null && info.InviteRequestHandlerUsernames.Count > 0)
					{
						if (world.Engine.Cloud.CurrentUser != null)
						{
							foreach (string username2 in info.InviteRequestHandlerUsernames)
							{
								Contact contact2 = world.Engine.Cloud.Contacts.FindContact((Contact c) => c.ContactUsername.Equals(username2, StringComparison.InvariantCultureIgnoreCase));
								if (contact2 == null)
								{
									UniLog.Warning(username2 + " is not in the contacts list, cannot setup as invite request handler");
								}
								else
								{
									world.AddInviteRequestHandler(contact2.ContactUserId);
									UniLog.Log(username2 + " (" + contact2.ContactUserId + ") added as invite handler.");
								}
							}
							return;
						}
						UniLog.Warning("Not logged in, cannot forward invite requests!");
					}
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception in world startup:\n" + ex);
				}
			});
			if (info.ParentSessionIds != null)
			{
				for (int num = info.ParentSessionIds.Count - 1; num >= 0; num--)
				{
					string text = info.ParentSessionIds[num];
					if (text.StartsWith("U-"))
					{
						text = "S-" + text;
					}
					if (!SessionInfo.IsValidSessionId(text))
					{
						UniLog.Warning("Parent session ID " + text + " is invalid. Excluding.");
						info.ParentSessionIds.RemoveAt(num);
					}
					else
					{
						UniLog.Log("Parent session ID: " + text);
						info.ParentSessionIds[num] = text;
					}
				}
				world.ParentSessionIds = info.ParentSessionIds;
			}
			if (world.Engine.InputInterface.HeadOutputDevice == HeadOutputDevice.Headless)
			{
				world.ForceFullUpdateCycle = !info.AutoSleep;
			}
			world.SaveOnExit = info.SaveOnExit;
			if (!info.SaveAsOwner.HasValue)
			{
				return;
			}
			string text2 = null;
			switch (info.SaveAsOwner)
			{
			case SaveAsOwner.LocalMachine:
				text2 = "M-" + world.Engine.LocalDB.MachineID;
				break;
			case SaveAsOwner.CloudUser:
				if (world.Engine.Cloud.CurrentUser == null)
				{
					UniLog.Warning("World is set to be saved as under cloud user, but no user is logged in!");
				}
				else
				{
					text2 = world.Engine.Cloud.CurrentUserID;
				}
				break;
			}
			if (text2 != null)
			{
				FrooxEngine.Store.Record record = world.CorrespondingRecord;
				string sourceRootOwnerID = record?.RecordId;
				if (record == null)
				{
					record = world.CreateNewRecord(text2);
					world.CorrespondingRecord = record;
				}
				else
				{
					record.OwnerId = text2;
					record.RecordId = RecordHelper.GenerateRecordID();
				}
				RecordOwnerTransferer transferer = new RecordOwnerTransferer(world.Engine, record.OwnerId, sourceRootOwnerID);
				UniLog.Log($"Saving world as under {info.SaveAsOwner}...");
				FrooxEngine.Store.Record record2 = await Userspace.SaveWorld(world, record, transferer);
				UniLog.Log("Saved successfully, updating config file with URL...");
				info.SaveAsOwner = null;
				info.LoadWorldURL = record2.GetUrl(world.Engine.Cloud.Platform).ToString();
				if (configSaveCallback != null)
				{
					await configSaveCallback();
				}
			}
		}

		public static async Task<WorldStartSettings> GenerateStartSettings(this SessionJoinParameters sessionJoin, Engine engine, int maxLookupAttempts = 5)
		{
			if (sessionJoin.URL != null)
			{
				return new WorldStartSettings(sessionJoin.URL)
				{
					AutoFocus = sessionJoin.AutoFocus,
					GetExisting = true
				};
			}
			if (string.IsNullOrWhiteSpace(sessionJoin.SessionID))
			{
				throw new ArgumentException("When URL isn't specified, SessionID is required. * can be used as wildcard for any");
			}
			List<SessionInfo> sessions = new List<SessionInfo>();
			string normalizedSessionId = sessionJoin.SessionID.ToLowerInvariant();
			for (int attempt = 0; attempt < maxLookupAttempts; attempt++)
			{
				engine.Cloud.Sessions.GetSessions(sessions);
				foreach (SessionInfo item in sessions)
				{
					if (item.IsCompatible() && (!(sessionJoin.SessionID != "*") || !(item.NormalizedSessionId != normalizedSessionId)) && (!sessionJoin.LanOnly || item.IsOnLAN) && (!sessionJoin.HeadlessOnly || item.HeadlessHost) && (string.IsNullOrWhiteSpace(sessionJoin.OnlyUniverseID) || !(item.UniverseId != sessionJoin.OnlyUniverseID)))
					{
						return new WorldStartSettings
						{
							URIs = item.GetSessionURLs(),
							AutoFocus = sessionJoin.AutoFocus,
							GetExisting = true
						};
					}
				}
				sessions.Clear();
				await Task.Delay(TimeSpan.FromSeconds(5L));
			}
			return null;
		}
	}
	[Category(new string[] { "Userspace" })]
	public class AudioDeviceVolume : Component
	{
		public readonly Sync<int> AudioDeviceIndex;

		public readonly Sync<float> Volume;

		public readonly Sync<float> NormalizedVolume;

		[Range(0f, 1f, "0.00")]
		public readonly Sync<float> Smoothing;

		public readonly Sync<float> Power;

		private AudioInput _lastRegisteredDevice;

		private int? _lastIndex;

		private float _volume;

		private float _normalizedVolume;

		public override int Version => 1;

		protected override void OnAwake()
		{
			base.OnAwake();
			AudioDeviceIndex.Value = -1;
			Smoothing.Value = 0.8f;
			Power.Value = 0.5f;
		}

		protected override void OnCommonUpdate()
		{
			if (base.World != Userspace.UserspaceWorld)
			{
				return;
			}
			int num = AudioDeviceIndex.Value;
			if (num < 0)
			{
				num = base.AudioSystem.DefaultAudioInputIndex;
			}
			if (_lastIndex != num)
			{
				UnregisterDevice();
				if (num < base.AudioSystem.AudioInputCount)
				{
					_lastRegisteredDevice = base.AudioSystem.AudioInputs[num];
					_lastRegisteredDevice.NewRawSamples += OnNewRawSamples;
					_lastRegisteredDevice.NewFilteredSamples += OnNewNormalizedSamples;
				}
				_lastIndex = num;
			}
			Volume.Value = _volume;
			NormalizedVolume.Value = _normalizedVolume;
		}

		private void OnNewNormalizedSamples(Span<StereoSample> buffer)
		{
			UpdateVolume(ref _normalizedVolume, buffer);
		}

		private void OnNewRawSamples(Span<StereoSample> buffer)
		{
			UpdateVolume(ref _volume, buffer);
		}

		private void UpdateVolume(ref float target, Span<StereoSample> buffer)
		{
			if (base.Slot.ActiveSelf && base.Enabled)
			{
				float num = 0f;
				for (int i = 0; i < buffer.Length; i += 2)
				{
					num = MathX.Max(num, buffer[i].AbsoluteAmplitude);
				}
				num = MathX.Pow(num, Power.Value);
				target = MathX.Lerp(num, target, Smoothing.Value);
			}
		}

		private void UnregisterDevice()
		{
			if (_lastRegisteredDevice != null)
			{
				_lastRegisteredDevice.NewRawSamples -= OnNewRawSamples;
				_lastRegisteredDevice.NewFilteredSamples -= OnNewNormalizedSamples;
				_lastRegisteredDevice = null;
			}
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			if (control.GetTypeVersion(GetType()) == 0)
			{
				control.OnLoaded(this, delegate
				{
					Smoothing.Value = 1f - (float)Smoothing;
				});
			}
		}

		protected override void OnDispose()
		{
			UnregisterDevice();
			base.OnDispose();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			AudioDeviceIndex = new Sync<int>();
			Volume = new Sync<float>();
			NormalizedVolume = new Sync<float>();
			Smoothing = new Sync<float>();
			Power = new Sync<float>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => AudioDeviceIndex, 
				4 => Volume, 
				5 => NormalizedVolume, 
				6 => Smoothing, 
				7 => Power, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static AudioDeviceVolume __New()
		{
			return new AudioDeviceVolume();
		}
	}
