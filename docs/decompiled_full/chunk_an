		private void UpdateContactItem(ContactData data)
		{
			if (data.Contact.ShouldBeHidden)
			{
				RemoveContactItem(data.Contact);
				return;
			}
			for (int num = _searchResultItems.Count - 1; num >= 0; num--)
			{
				if (_searchResultItems[num].Contact.ContactUserId == data.UserId)
				{
					_searchResultItems[num].Slot.Destroy();
					_searchResultItems.RemoveAt(num);
					break;
				}
			}
			if (!_contactItems.TryGetValue(data.UserId, out ContactItem value))
			{
				value = AddContactItem();
				_contactItems.Add(data.UserId, value);
			}
			value.Update(data.Contact, data);
			value.UpdateUnreadCount(base.Engine.Cloud.Messages.GetUserMessages(data.UserId)?.UnreadCount ?? 0);
			if (data.UserId == SelectedContact?.ContactUserId)
			{
				UpdateSelectedContactUI();
				UpdateSessionItems(data);
			}
			sortList = true;
		}

		private void RemoveContactItem(Contact contact)
		{
			if (_contactItems.TryGetValue(contact.ContactUserId, out ContactItem value))
			{
				value.Slot.Destroy();
				_contactItems.Remove(contact.ContactUserId);
				if (SelectedContact?.ContactUserId == contact.ContactUserId)
				{
					SelectedContact = null;
				}
				sortList = true;
			}
		}

		private void UpdateSessionItems(ContactData status)
		{
			if (status == null)
			{
				foreach (KeyValuePair<string, SessionItem> sessionItem in _sessionItems)
				{
					sessionItem.Value.Slot.Destroy();
				}
				_sessionItems.Clear();
				return;
			}
			HashSet<SessionInfo> hashSet = Pool.BorrowHashSet<SessionInfo>();
			status.DecodeSessions(hashSet);
			HashSet<string> hashSet2 = Pool.BorrowHashSet<string>();
			string currentSessionId = status.CurrentSessionInfo?.SessionId;
			foreach (KeyValuePair<string, SessionItem> sessionItem2 in _sessionItems)
			{
				hashSet2.Add(sessionItem2.Key);
			}
			foreach (SessionInfo item in hashSet)
			{
				if (!_sessionItems.TryGetValue(item.SessionId, out SessionItem value))
				{
					value = AddSessionItem();
					_sessionItems.Add(item.SessionId, value);
				}
				value.Update(item, item.SessionId == currentSessionId);
				hashSet2.Remove(item.SessionId);
			}
			foreach (string item2 in hashSet2)
			{
				_sessionItems[item2].Slot.Destroy();
				_sessionItems.Remove(item2);
			}
			Pool.Return(ref hashSet2);
			_sessionsRoot.Target.SortChildren(delegate(Slot a, Slot b)
			{
				SessionInfo sessionInfo = a.GetComponent<SessionItem>()?.SessionInfo;
				SessionInfo sessionInfo2 = a.GetComponent<SessionItem>()?.SessionInfo;
				if (sessionInfo != null && sessionInfo2 == null)
				{
					return -1;
				}
				if (sessionInfo == null && sessionInfo2 != null)
				{
					return 1;
				}
				if (sessionInfo == null && sessionInfo2 == null)
				{
					return 0;
				}
				if (currentSessionId != null)
				{
					if (sessionInfo.SessionId == currentSessionId)
					{
						return -1;
					}
					if (sessionInfo2.SessionId == currentSessionId)
					{
						return 1;
					}
				}
				return sessionInfo.Name.CompareTo(sessionInfo2.Name);
			});
		}

