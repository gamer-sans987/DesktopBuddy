	public class StreamGroupManager
	{
		private BiDictionary<ushort, string> streamGroupNames;

		private Dictionary<ushort, StreamGroup> streamGroups;

		public User User { get; private set; }

		public Dictionary<ushort, StreamGroup>.ValueCollection Groups => streamGroups.Values;

		public StreamGroup GetGroup(ushort index)
		{
			return streamGroups[index];
		}

		public StreamGroupManager(User user)
		{
			User = user;
			streamGroupNames = new BiDictionary<ushort, string>();
			streamGroups = new Dictionary<ushort, StreamGroup>();
		}

		public ushort GetGroupIndex(string groupName)
		{
			if (streamGroupNames.TryGetFirst(groupName, out var first))
			{
				return first;
			}
			first = (ushort)((streamGroupNames.Count == 0) ? 1 : ((ushort)(streamGroupNames.Max<ValuePair<ushort, string>, ushort>((ValuePair<ushort, string> p) => p.First) + 1)));
			streamGroupNames.Add(first, groupName);
			return first;
		}

		public void AssignToGroup(IStream stream, ushort? oldGroupIndex)
		{
			if (oldGroupIndex.HasValue)
			{
				StreamGroup streamGroup = streamGroups[oldGroupIndex.Value];
				streamGroup.RemoveStream(stream);
				if (streamGroup.StreamCount == 0)
				{
					streamGroups.Remove(oldGroupIndex.Value);
					if (User.IsLocalUser)
					{
						streamGroupNames.RemoveByFirst(oldGroupIndex.Value);
					}
				}
			}
			if (!streamGroups.TryGetValue(stream.GroupIndex, out StreamGroup value))
			{
				value = new StreamGroup(this, stream.GroupIndex);
				streamGroups.Add(stream.GroupIndex, value);
			}
			value.AssignStream(stream);
		}

		public void StreamModified(IStream stream)
		{
			if (User.IsLocalUser)
			{
				streamGroups[stream.GroupIndex].GroupModified();
			}
		}
	}
	public class AssemblyTypeRegistry
	{
		private const BindingFlags BIND_FLAGS = BindingFlags.DeclaredOnly | BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic;

		private List<Type> _types = new List<Type>();

		private HashSet<Type> _dependencyTypes = new HashSet<Type>();

		private HashSet<Assembly> _dependencyAssemblies = new HashSet<Assembly>();

		private Dictionary<Type, int> _typeToIndex = new Dictionary<Type, int>();

		private Dictionary<string, Type> _typesByFullName = new Dictionary<string, Type>();

		private DictionaryList<string, Type> _typesByName = new DictionaryList<string, Type>();

		private Dictionary<string, Type> _movedTypes = new Dictionary<string, Type>();

		private HashSet<AssemblyTypeRegistry> _movedTypeAssemblies = new HashSet<AssemblyTypeRegistry>();

		public DataModelAssemblyType AssemblyType { get; private set; }

		public string AssemblyName { get; private set; }

		public System.Version AssemblyVersion { get; private set; }

		public Assembly Assembly { get; private set; }

		public bool IsDependency => CompatibilityHash == null;

		public string CompatibilityHash { get; private set; }

		public int TypeCount => _types.Count;

		public int TotalTypeCount { get; private set; }

		public IReadOnlyList<Type> Types => _types;

		public IEnumerable<Assembly> DependencyAssemblies => _dependencyAssemblies;

		public IEnumerable<AssemblyTypeRegistry> MovedTypeAssemblies => _movedTypeAssemblies;

		public AssemblyTypeRegistry(string assemblyName)
		{
			AssemblyName = assemblyName;
		}

		private static bool IsMetadataValid(AssemblyTypeRegistryMetadata metadata, Assembly assembly, System.Version version, DateTime lastModification, ref string fileHash)
		{
			if (metadata.SystemCompatibilityVersion != 3)
			{
				return false;
			}
			if (metadata.AssemblyVersion != version.ToString())
			{
				return false;
			}
			if (metadata.FileModificationTime == lastModification)
			{
				fileHash = metadata.FileHash;
				return true;
			}
			EnsureAssemblyHash(assembly, ref fileHash);
			return metadata.FileHash == fileHash;
		}

		private static void EnsureAssemblyHash(Assembly assembly, ref string fileHash)
		{
			if (fileHash == null)
			{
				byte[] inArray = FileUtil.ComputeHash(assembly.Location, FileUtil.FileHash.MD5);
				fileHash = Convert.ToBase64String(inArray);
			}
		}

		public AssemblyTypeRegistry(Assembly assembly, DataModelAssemblyType assemblyType, IEnumerable<Type> assemblyTypes = null, bool scanTypes = true, bool fastCompatibilityHash = false)
		{
			Assembly = assembly;
			AssemblyType = assemblyType;
			AssemblyName name = assembly.GetName();
			AssemblyName = name.Name;
			AssemblyVersion = name.Version;
			if (!scanTypes)
			{
				return;
			}
			AssemblyTypeRegistryMetadata assemblyTypeRegistryMetadata = null;
			string text = null;
			if (GlobalTypeRegistry.MetadataCachePath != null)
			{
				text = Path.Combine(GlobalTypeRegistry.MetadataCachePath, AssemblyName + ".metadata");
			}
			DateTime lastWriteTimeUtc = new FileInfo(assembly.Location).LastWriteTimeUtc;
			string fileHash = null;
			if (File.Exists(text))
			{
				try
				{
					assemblyTypeRegistryMetadata = System.Text.Json.JsonSerializer.Deserialize<AssemblyTypeRegistryMetadata>(File.ReadAllText(text));
				}
				catch (Exception value)
				{
					UniLog.Warning($"Exception when reading metadata for assembly {AssemblyName}:\n{value}");
				}
				if (assemblyTypeRegistryMetadata != null && !IsMetadataValid(assemblyTypeRegistryMetadata, assembly, AssemblyVersion, lastWriteTimeUtc, ref fileHash))
				{
					assemblyTypeRegistryMetadata = null;
				}
			}
			if (assemblyTypes == null)
			{
				assemblyTypes = assembly.GetTypes();
			}
			foreach (Type assemblyType2 in assemblyTypes)
			{
				TotalTypeCount++;
				if (assemblyType2.IsDataModelType())
				{
					AddType(assemblyType2);
				}
			}
			foreach (ExternalDataModelTypeAttribute customAttribute in assembly.GetCustomAttributes<ExternalDataModelTypeAttribute>())
			{
				if (_dependencyTypes.Add(customAttribute.ExternalType))
				{
					_dependencyAssemblies.Add(customAttribute.ExternalType.Assembly);
					GlobalTypeRegistry.RegisterExternalType(customAttribute.ExternalType);
				}
			}
			if (assemblyTypeRegistryMetadata != null)
			{
				CompatibilityHash = assemblyTypeRegistryMetadata.CompatibilityHash;
				return;
			}
			if (fastCompatibilityHash)
			{
				CompatibilityHash = Convert.ToBase64String(RandomX.Bytes(16));
				return;
			}
			ComputeCompatibilityHash();
			if (text != null)
			{
				assemblyTypeRegistryMetadata = new AssemblyTypeRegistryMetadata();
				EnsureAssemblyHash(assembly, ref fileHash);
				assemblyTypeRegistryMetadata.AssemblyName = AssemblyName;
				assemblyTypeRegistryMetadata.SystemCompatibilityVersion = 3;
				assemblyTypeRegistryMetadata.AssemblyVersion = AssemblyVersion.ToString();
				assemblyTypeRegistryMetadata.FileModificationTime = lastWriteTimeUtc;
				assemblyTypeRegistryMetadata.FileHash = fileHash;
				assemblyTypeRegistryMetadata.CompatibilityHash = CompatibilityHash;
				string contents = System.Text.Json.JsonSerializer.Serialize(assemblyTypeRegistryMetadata);
				File.WriteAllText(text, contents);
			}
		}

		internal void RegisterExternalType(Type type)
		{
			if (!IsDependency)
			{
				throw new InvalidOperationException($"Trying to register type: {type} in assembly {AssemblyName}, which isn't marked as dependency assembly!");
			}
			lock (_dependencyTypes)
			{
				if (_dependencyTypes.Add(type))
				{
					TotalTypeCount++;
					AddType(type);
				}
			}
		}

		private static string ProcessOldTypename(Type type, string oldTypename)
		{
			if (!type.IsGenericType)
			{
				return oldTypename;
			}
			if (oldTypename.Contains("`"))
			{
				return oldTypename;
			}
			string fullName = type.FullName;
			int startIndex = fullName.LastIndexOf("`");
			return oldTypename + fullName.Substring(startIndex);
		}

		internal void ProcessMovedTypes()
		{
			foreach (Type type in _types)
			{
				foreach (OldTypeNameAttribute customAttribute in type.GetCustomAttributes<OldTypeNameAttribute>(inherit: false))
				{
					string text = ProcessOldTypename(type, customAttribute.OldTypename);
					if (customAttribute.OldAssembly == null)
					{
						RegisterMovedType(text, type);
					}
					else
					{
						RegisterMovedType(type, text, customAttribute.OldAssembly);
					}
				}
				foreach (OldAssemblyAttribute customAttribute2 in type.GetCustomAttributes<OldAssemblyAttribute>(inherit: false))
				{
					RegisterMovedType(type, type.FullName, customAttribute2.OldAssembly);
				}
				if (type.DeclaringType != null)
				{
					foreach (OldTypeNameAttribute customAttribute3 in type.DeclaringType.GetCustomAttributes<OldTypeNameAttribute>(inherit: false))
					{
						string text2 = type.FullName.Replace(type.DeclaringType.FullName, ProcessOldTypename(type.DeclaringType, customAttribute3.OldTypename));
						if (customAttribute3.OldAssembly == null)
						{
							RegisterMovedType(text2, type);
						}
						else
						{
							RegisterMovedType(type, text2, customAttribute3.OldAssembly);
						}
					}
					foreach (OldAssemblyAttribute customAttribute4 in type.DeclaringType.GetCustomAttributes<OldAssemblyAttribute>(inherit: false))
					{
						RegisterMovedType(type, type.FullName, customAttribute4.OldAssembly);
					}
				}
				foreach (OldTypeHashAttribute customAttribute5 in type.GetCustomAttributes<OldTypeHashAttribute>(inherit: false))
				{
					GlobalTypeRegistry.RegisterOldTypeHash(customAttribute5.Hash, type);
				}
				foreach (OldNonGenericDefaultAttribute customAttribute6 in type.GetCustomAttributes<OldNonGenericDefaultAttribute>(inherit: false))
				{
					string oldFullName = type.FullName.Substring(0, type.FullName.IndexOf("`"));
					RegisterMovedType(oldFullName, customAttribute6.GenericType);
				}
			}
		}

		private void RegisterMovedType(Type type, string oldTypeName, string oldAssembly)
		{
			AssemblyTypeRegistry item = GlobalTypeRegistry.RegisterMovedType(type, oldTypeName, oldAssembly);
			_movedTypeAssemblies.Add(item);
		}

		internal void RegisterMovedType(string oldFullName, Type type)
		{
			_movedTypes.Add(oldFullName, type);
		}

		private void AddType(Type type)
		{
			_typeToIndex.Add(type, _types.Count);
			_typesByFullName.Add(type.FullName, type);
			_typesByName.Add(type.Name, type);
			_types.Add(type);
			if (type.DeclaringType != null && !HasType(type.DeclaringType) && !type.DeclaringType.IsDataModelType())
			{
				AddType(type.DeclaringType);
			}
		}

		public Type GetType(int index)
		{
			if (index < 0 || index >= _types.Count)
			{
				throw new ArgumentOutOfRangeException("index", $"Invalid index on assembly {AssemblyName}: {index}, Max: {TypeCount}");
			}
			return _types[index];
		}

		public int GetTypeIndex(Type type)
		{
			if (_typeToIndex.TryGetValue(type, out var value))
