				2 => EnabledField, 
				3 => TextureSizeRatio, 
				4 => TextureSizeLimit, 
				5 => MinimumTextureSize, 
				6 => DefaultFilterMode, 
				7 => AnisotropicLevel, 
				8 => UseAnisotropicLevel, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

