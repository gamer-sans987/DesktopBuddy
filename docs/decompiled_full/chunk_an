				if (item.SessionId == null || !_sessionIds.Add(item.SessionId) || (item.ActiveUsers == 0 && !item.IsOnLAN && (!ShowHeadless.Value || !item.HeadlessHost)) || (base.World.UserCount > 1 && item.AccessLevel != SessionAccessLevel.Anyone && item.AccessLevel != SessionAccessLevel.RegisteredUsers))
				{
					continue;
				}
				List<Uri> urls = item.GetSessionURLs();
				WorldOrb worldOrb = list2.FirstOrDefault((WorldOrb o) => o.MatchesAnyActiveSessionURL(urls));
				if (list2.Count < MaxOrbs.Value)
				{
					if (worldOrb == null)
					{
						worldOrb = SpawnWorldOrb(list2);
					}
					worldOrb.ActiveSessionURLs = urls;
					worldOrb.ActiveUsers.Value = item.ActiveUsers;
					worldOrb.WorldName = item.Name;
					worldOrb.CreatorName = item.SanitizedHostUsername;
					worldOrb.CreatorTextColor = new Elements.Core.colorX(1f, 0.2f, 1f, 0.4f);
					if (!string.IsNullOrEmpty(item.ThumbnailUrl))
					{
						worldOrb.SetThumbnail(new Uri(item.ThumbnailUrl));
					}
				}
				_activeSessions.Add(worldOrb);
			}
			_sessionIds.Clear();
			foreach (WorldOrb item2 in list2)
			{
				if (!_activeSessions.Contains(item2))
				{
					RemoveWorldOrb(item2);
				}
			}
			_activeSessions.Clear();
			Pool.Return(ref list2);
			Pool.Return(ref list);
		}

