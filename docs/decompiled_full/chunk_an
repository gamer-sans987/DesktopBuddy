		{
			base.OnDispose();
			base.Engine.Cloud.NetworkNodes.AvailableNodesChanged -= OnAvailableNodesChanged;
		}

		private void OnAvailableNodesChanged(INetworkNodeManager manager)
		{
			RunSynchronously(delegate
			{
				Dictionary<string, RelayPriorityEntry> dictionary = Pool.BorrowDictionary<string, RelayPriorityEntry>();
				foreach (RelayPriorityEntry relayPriority in RelayPriorities)
				{
					if (relayPriority.IsAvailable.Value)
					{
						dictionary.Add(relayPriority.EntryID.Value, relayPriority);
					}
				}
				foreach (NetworkNodeInfo node in manager.GetNodes(NetworkNodeType.LNL_Relay, 2, base.Engine.NodePreference, base.Engine.UniverseId))
				{
					if (!string.IsNullOrEmpty(node.NodeName))
					{
						RelayPriorityEntry relayPriorityEntry = RelayPriorities.EnsureEntry(node.NodeName);
						relayPriorityEntry.RelayIP.Value = node.Address;
						relayPriorityEntry.CurrentUsers.Value = node.UserCount;
						relayPriorityEntry.IsAvailable.Value = true;
						dictionary.Remove(node.NodeName);
					}
				}
				foreach (KeyValuePair<string, RelayPriorityEntry> item in dictionary)
				{
					item.Value.IsAvailable.Value = false;
				}
				Pool.Return(ref dictionary);
			});
		}

