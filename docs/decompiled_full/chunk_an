		public static SessionPermissionController Create(Func<ReadOnlyRef<PermissionSet>> getReference, UIBuilder ui, LocaleString text, User associatedUser = null)
		{
			ui.Style.MinHeight = HEIGHT;
			SessionPermissionController sessionPermissionController = ui.Panel().Slot.AttachComponent<SessionPermissionController>();
			sessionPermissionController.GetReference = getReference;
			List<RectTransform> list = ui.SplitHorizontally(0.3f, 0.01f, 0.7f);
			ui.ForceNext = list[0];
			Text text2 = ui.Text(in text, bestFit: true, null, parseRTF: false);
			sessionPermissionController._name.Target = text2;
			if (associatedUser != null && associatedUser.UserID != null)
			{
				Button button = text2.Slot.AttachComponent<Button>();
				InteractionElement.ColorDriver colorDriver = button.ColorDrivers.Add();
				colorDriver.ColorDrive.Target = text2.Color;
				RadiantUI_Constants.SetupLabelDriverColors(colorDriver);
				button.SetupAction(OpenUserProfile, associatedUser.UserID);
			}
			if (associatedUser != null && !associatedUser.IsLocalUser && associatedUser.Role == associatedUser.World.Permissions.LowestRole && associatedUser.DefaultSpectator)
			{
				sessionPermissionController._name.Target.Color.Value = Elements.Core.colorX.Red;
			}
			ui.NestInto(list[2]);
			ui.HorizontalLayout(4f);
			ui.Style.MinWidth = 32f;
