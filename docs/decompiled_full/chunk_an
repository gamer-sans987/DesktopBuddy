				case "FPS":
					FixFacet<FPS_FacetPreset>(componentsInChild);
					break;
				case "FreeformDash":
					FixFacet<FreeformDashFacetPreset>(componentsInChild);
					break;
				case "FullBodyCalibrator":
					FixFacet<FullBodyCalibratorFacetPreset>(componentsInChild);
					break;
				case "CustomNameplateVisibility":
					FixFacet<NameplateStyleFacetPreset>(componentsInChild);
					break;
				case "NameplateVisibility":
					FixFacet<NameplateVisibilityFacetPreset>(componentsInChild);
					break;
				case "NewWorld":
					FixFacet<NewWorldFacetPreset>(componentsInChild);
					break;
				case "OnlineStatus":
					FixFacet<OnlineStatusFacetPreset>(componentsInChild);
					break;
				case "OnlineUserCount":
					FixFacet<OnlineUserCountFacetPreset>(componentsInChild);
					break;
				case "Debug":
					FixFacet<OpenDebugFacetPreset>(componentsInChild);
					break;
				case "OpenHome":
					FixFacet<OpenHomeFacetPreset>(componentsInChild);
					break;
				case "SeatedMode":
					FixFacet<SeatedModeFacetPreset>(componentsInChild);
					break;
				case "ServerStatus":
					FixFacet<ServerStatusFacetPreset>(componentsInChild);
					break;
				case "Setup2FA":
					FixFacet<Setup2FAFacetPreset>(componentsInChild);
					break;
				case "UserProfile":
					FixFacet<SimpleProfileFacetPreset>(componentsInChild);
					break;
				case "StorageIndicator":
					FixFacet<StorageIndicatorFacetPreset>(componentsInChild);
					break;
				case "StreamAudio":
					FixFacet<StreamAudioFacetPreset>(componentsInChild);
					break;
				case "StreamingCamera":
					FixFacet<StreamingCameraFacetPreset>(componentsInChild);
					break;
				case "SyncStatus":
					FixFacet<SyncStatusFacetPreset>(componentsInChild);
					break;
				case "Time":
					FixFacet<TimeFacetPreset>(componentsInChild);
					break;
				case "VersionNumber":
					FixFacet<VersionNumberFacetPreset>(componentsInChild);
					break;
				case "VoiceMode":
					FixFacet<VoiceFacetPreset>(componentsInChild);
					break;
				case "LeaveWorld":
					FixFacet<WorldCloseFacetPreset>(componentsInChild);
					break;
				}
			}
			static void FixFacet<T>(Facet facet) where T : notnull, TemplateFacetPreset, new()
			{
				if (facet.Slot.GetComponent<T>() == null)
				{
					UniLog.Log("Repairing facet template for: " + facet.Slot.Name);
					facet.Slot.AttachComponent<T>();
				}
			}
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			int version = control.GetTypeVersion<UserspaceScreensManager>();
			if (version == Version)
			{
				return;
			}
			control.OnLoaded(this, delegate
			{
				RadiantDash componentInParents = base.Slot.GetComponentInParents<RadiantDash>();
				if (componentInParents == null)
				{
					UniLog.Warning("Dash is missing, skipping screens update:\n" + this);
				}
				else
				{
					if (version < 3)
					{
						AddWorldsScreen(componentInParents);
					}
					if (version < 4)
					{
						componentInParents.GetScreen<ExitScreen>().Slot.Destroy();
						componentInParents.AttachScreen<ExitScreen>();
					}
					if (version < 5)
					{
						componentInParents.AttachScreen<DesktopScreen>();
					}
					if (version < 7)
					{
						AddMigrationScreen(componentInParents);
					}
					if (version < 12)
					{
						componentInParents.GetScreen<LegacyRadiantScreenWrapper<ContactsDialog>>()?.Slot.Destroy();
						componentInParents.GetScreen<LegacyRadiantScreenWrapper<InventoryBrowser>>()?.Slot.Destroy();
						componentInParents.GetScreen<LegacyRadiantScreenWrapper<FileBrowser>>()?.Slot.Destroy();
						AddContactsScreen(componentInParents);
						AddInventoryScreen(componentInParents);
						AddFileBrowserScreen(componentInParents);
					}
					if (version < 13)
					{
						GridContainerScreen screen = componentInParents.GetScreen((GridContainerScreen c) => c.HasPreset(typeof(HomeScreenInitializer)));
						screen.GetGridContainerPreset()?.Destroy();
						screen.Slot.OrderOffset++;
						screen.Label.DriveLocalized("<nobr>Old Home</nobr>");
						screen.Icon.Value = OfficialAssets.Graphics.Icons.Item.Deselect;
						HomeScreenInitializer.CleanupLegacyFacets(screen.GridContainer);
						screen.GridContainer.FacetsRoot.Target.GetComponentsInChildren<FacetPreset>()?.ForEach(delegate(FacetPreset p)
						{
							p.Destroy();
						});
						AddHomeScreen(componentInParents);
					}
					if (version < 14)
					{
						AddSettingsScreen(componentInParents);
					}
					if (version < 15)
					{
						FixBrokenTemplatePresets();
					}
					if (version < 16)
					{
						AddHelpScreen(componentInParents);
					}
					SetupDefaults();
				}
			});
		}

