		public void OnStartStreaming(IButton button, ButtonEventData eventData)
		{
			if (base.World != Userspace.UserspaceWorld)
			{
				return;
			}
			int deviceIndex = base.AudioSystem.FindAudioInputIndex(DeviceID.Value, caseSensitive: false, allowPartialMatch: false);
			World _targetWorld = base.Engine.WorldManager.FocusedWorld;
			_targetWorld.Coroutines.StartTask(async delegate
			{
				await default(ToWorld);
				if (!_targetWorld.CanSpawnObjects())
				{
					NotificationMessage.SpawnTextMessage("Permissions.NotAllowedToSpawn".AsLocaleKey(), Elements.Core.colorX.Red);
				}
				else
				{
					_targetWorld.GetGloballyRegisteredComponents((AudioStreamController c) => c.IsOwnedByLocalUser).ForEach(delegate(AudioStreamController c)
					{
						c.Slot.GetObjectRoot().Destroy();
					});
					int bitrate = MathX.RoundToInt(BitrateKbps.Value * 1000f);
					Slot root = _targetWorld.RootSlot.LocalUserSpace.AddSlot(_targetWorld.LocalUser.UserName + " Audio Stream");
					root.PersistentSelf = false;
					root.AttachComponent<DestroyOnUserLeave>().TargetUser.Target = _targetWorld.LocalUser;
					OpusStream<StereoSample> stream = _targetWorld.LocalUser.AddStream<OpusStream<StereoSample>>();
					stream.ApplicationType.Value = OpusApplicationType.Audio;
					stream.MinimumVolume.Value = 0f;
					stream.MinimumBufferDelay.Value = 0.2f;
					stream.BufferSize.Value = 24000;
					stream.BitRate.Value = bitrate;
					AudioStreamInterface audioStreamInterface = await root.SpawnEntity(FavoriteEntity.AudioStreamController, delegate(Slot s)
					{
						s.AttachComponent<ObjectRoot>();
						s.AttachComponent<DuplicateBlock>();
						AudioStreamInterface audioStreamInterface2 = s.AttachComponent<AudioStreamInterface>();
						LegacyCanvasPanel legacyCanvasPanel = s.AttachComponent<LegacyCanvasPanel>();
						legacyCanvasPanel.Panel.AddCloseButton();
						legacyCanvasPanel.Panel.AddParentButton();
						legacyCanvasPanel.CanvasSize = new Elements.Core.float2(400f, 200f);
						legacyCanvasPanel.PhysicalHeight = 0.3f;
						legacyCanvasPanel.Panel.Color = Elements.Core.colorX.Black;
						AudioStreamController audioStreamController = legacyCanvasPanel.Canvas.Slot.AddSlot("UI").AttachComponent<AudioStreamController>();
						audioStreamController.BuildUI(root);
						s.AttachComponent<ReferenceProxy>().Reference.DriveFrom(audioStreamController.Stream);
						audioStreamInterface2.Source.Target = audioStreamController.Stream;
						audioStreamInterface2.Bitrate.Target = stream.BitRate;
						audioStreamInterface2.Volume.Target = audioStreamController.AudioOutput.Target.Volume;
						audioStreamInterface2.Spatialize.Target = audioStreamController.AudioOutput.Target.Spatialize;
						return audioStreamInterface2;
					});
					root = audioStreamInterface.Slot.GetObjectRoot();
					root.PersistentSelf = false;
					UserAudioStream<StereoSample> userAudioStream = root.AttachComponent<UserAudioStream<StereoSample>>();
					userAudioStream.TargetDeviceIndex = deviceIndex;
					userAudioStream.Stream.Target = stream;
					userAudioStream.UseFilteredData.Value = false;
					root.DestroyWhenDestroyed(stream);
					audioStreamInterface.InitializeEntity(_targetWorld.LocalUser.UserName + " Audio Stream");
					audioStreamInterface.SetAudioStream(stream, bitrate);
					root.PositionInFrontOfUser(Elements.Core.float3.Backward);
				}
			});
			button.Slot.CloseModalOverlay();
		}

