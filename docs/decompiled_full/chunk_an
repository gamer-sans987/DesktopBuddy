				ui.HorizontalLayout(4f, 0f, 0f, 0f, 0f, Alignment.MiddleLeft).ForceExpand = false;
				ui.Panel();
				ui.Text((LocaleString)"┗", bestFit: false, Alignment.MiddleRight).Size.Value = 32f;
