		public static void GenerateBackgroundWorkerDiagnostic(Engine engine, StringBuilder str)
		{
			WorkProcessor workProcessor = engine.WorkProcessor;
			StringBuilder stringBuilder;
			StringBuilder.AppendInterpolatedStringHandler handler;
			foreach (WorkType value in Enum.GetValues(typeof(WorkType)))
			{
				stringBuilder = str;
