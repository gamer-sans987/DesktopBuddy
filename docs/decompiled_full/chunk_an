		{
			base.InitializeSyncMembers();
			TextureSizeRatio = new Sync<TextureSizeRatio>();
			TextureSizeLimit = new Sync<TextureSizeLimit>();
			MinimumTextureSize = new Sync<int>();
			DefaultFilterMode = new Sync<TextureFilterMode>();
