		private void AddNotification(string userId, string message, Uri thumbnail, Elements.Core.colorX color, NotificationType type, string mainMessage = "N/A", Uri overrideProfile = null, IAssetProvider<AudioClip> clip = null)
		{
			if (base.Engine.Cloud.Status.OnlineStatus == OnlineStatus.Busy || type == NotificationType.None)
			{
				return;
			}
			Elements.Core.colorX colorX = color;
			Elements.Core.colorX lIGHT = RadiantUI_Constants.Neutrals.LIGHT;
			if (base.Engine.Cloud.Status.OnlineStatus == OnlineStatus.Away)
			{
				delayedNotifications.Enqueue(delegate
				{
					AddNotification(userId, message, thumbnail, color, type, mainMessage, overrideProfile, clip);
				});
				if (delayedNotifications.Count > 5)
				{
					delayedNotifications.Dequeue();
				}
				return;
			}
			if (clip != null && (type == NotificationType.AudioOnly || type == NotificationType.Full) && base.Time.WorldTime - lastSoundEffect >= 0.10000000149011612)
			{
				base.Slot.PlayOneShot(clip, 1f, base.InputInterface.VR_Active, null, RandomX.Range(0.95f, 1.05f), parent: true, AudioDistanceSpace.Global).SetupAsUI();
				lastSoundEffect = base.Time.WorldTime;
			}
			if (type == NotificationType.ToastOnly || type == NotificationType.Full)
			{
				uiBuilder.Style.TextColor = lIGHT;
				NotificationItem notificationItem = new NotificationItem();
				notificationItem.userId = userId;
				notificationItem.addTime = DateTime.UtcNow;
				Contact contact = (string.IsNullOrWhiteSpace(userId) ? null : base.Engine.Cloud.Contacts.GetContact(userId));
				Mask mask = uiBuilder.Mask(colorX.SetA(0.95f), showMaskGraphic: true, zwrite: true);
				FrooxEngine.UIX.Image component = mask.Slot.GetComponent<FrooxEngine.UIX.Image>();
				component.Sprite.Target = uiBuilder.Style.ButtonSprite;
				component.NineSliceSizing.Value = uiBuilder.Style.NineSliceSizing;
				notificationItem.root = uiBuilder.Current;
				notificationItem.element = uiBuilder.Current.GetComponentOrAttach<LayoutElement>();
				notificationItem.element.UseZeroMetrics.Value = true;
				notificationItem.element.MinHeight.Value = 0f;
				notificationItem.root.OrderOffset = _orderOffset--;
				FrooxEngine.UIX.Image component2 = uiBuilder.Current.GetComponent<FrooxEngine.UIX.Image>();
				Button button = uiBuilder.Current.AttachComponent<Button>();
				button.ColorDrivers[0].ColorDrive.Target = component2.Tint;
				if (userId != null)
				{
					button.SetupAction(OnNotificationPressed, userId);
				}
				_ = uiBuilder.CurrentRect;
				uiBuilder.Nest();
				uiBuilder.Panel();
				uiBuilder.SetFixedHeight(32f);
				uiBuilder.VerticalHeader(32f, out RectTransform header, out RectTransform content);
				uiBuilder.NestInto(content);
				uiBuilder.VerticalFooter(48f, out RectTransform footer, out RectTransform content2);
				uiBuilder.NestInto(content2);
				uiBuilder.SplitVertically(0.6f, out RectTransform top, out RectTransform bottom);
				uiBuilder.ForceNext = bottom;
				uiBuilder.Text((LocaleString)message, bestFit: true, Alignment.MiddleLeft);
				uiBuilder.ForceNext = top;
				uiBuilder.Text((LocaleString)("<b>" + (contact?.ContactUsername ?? mainMessage) + "</b>"), bestFit: true, Alignment.MiddleLeft);
				uiBuilder.NestOutFrom(content);
				uiBuilder.NestInto(header);
				uiBuilder.SpriteMask(uiBuilder.CircleSprite);
				uiBuilder.SetPadding(2f);
				uiBuilder.Nest();
				Uri result = overrideProfile;
				if (result == null)
				{
					Uri.TryCreate(contact?.Profile?.IconUrl, UriKind.Absolute, out result);
				}
				if (result != null)
				{
					uiBuilder.Image(result);
					uiBuilder.CurrentRect.AnchorMin.Value = new Elements.Core.float2(-1f);
					uiBuilder.CurrentRect.AnchorMax.Value = new Elements.Core.float2(2f, 1f);
				}
				uiBuilder.NestOut();
