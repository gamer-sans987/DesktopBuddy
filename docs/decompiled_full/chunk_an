		public static async Task UploadAssets(AssetUploadConfig config, Engine engine)
		{
			UniLog.Log("Starting standard asset upload");
			while (engine.RecordManager.SyncingRecordsCount > 0)
			{
				await Task.Delay(TimeSpan.FromSeconds(15L));
				DefaultInterpolatedStringHandler defaultInterpolatedStringHandler = new DefaultInterpolatedStringHandler(32, 3);
				defaultInterpolatedStringHandler.AppendLiteral("Syncing ");
				defaultInterpolatedStringHandler.AppendFormatted(engine.RecordManager.SyncingRecordsCount);
				defaultInterpolatedStringHandler.AppendLiteral(" records. Current: ");
				EngineRecordUploadTask currentUploadTask = engine.RecordManager.CurrentUploadTask;
				defaultInterpolatedStringHandler.AppendFormatted((currentUploadTask != null) ? new float?(currentUploadTask.Progress * 100f) : ((float?)null), "F2");
				defaultInterpolatedStringHandler.AppendLiteral(" % - ");
				defaultInterpolatedStringHandler.AppendFormatted(engine.RecordManager.CurrentUploadTask?.StageDescription);
				UniLog.Log(defaultInterpolatedStringHandler.ToStringAndClear());
			}
			if (string.IsNullOrEmpty(config.Owner))
			{
				config.Owner = engine.Cloud.CurrentUserID;
			}
			if (string.IsNullOrEmpty(config.ClassName))
			{
				config.ClassName = "Assets";
			}
			Dictionary<string, StdAssetRecord> records = new Dictionary<string, StdAssetRecord>();
			if (File.Exists(config.RecordsCache))
			{
				string[] array = File.ReadAllLines(config.RecordsCache);
				for (int i = 0; i < array.Length; i++)
				{
					string[] array2 = array[i].Split('|');
					StdAssetRecord stdAssetRecord = new StdAssetRecord();
					stdAssetRecord.uri = array2[1].Trim();
					stdAssetRecord.recordId = array2[2].Trim();
					stdAssetRecord.timestamp = DateTime.FromBinary(long.Parse(array2[3]));
					stdAssetRecord.md5 = array2[4];
					records.Add(array2[0].Trim(), stdAssetRecord);
				}
			}
			StringBuilder src = new StringBuilder();
			src.AppendLine("using System;");
			src.AppendLine();
			src.AppendLine("// Autogenerated do not edit, see FrooxEngine/Utility/StandardAssetUploader.cs");
			StringBuilder stringBuilder = src;
			StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(22, 1, stringBuilder);
			handler.AppendLiteral("public static class ");
			handler.AppendFormatted(config.ClassName);
			handler.AppendLiteral("\n{");
			stringBuilder.AppendLine(ref handler);
			await ProcessFolder(config.Path, config, src, records, engine, config.ClassName).ConfigureAwait(continueOnCapturedContext: false);
			foreach (Func<Task> completionTask in config.CompletionTasks)
			{
				await completionTask().ConfigureAwait(continueOnCapturedContext: false);
			}
			src.AppendLine("}");
			if (!string.IsNullOrEmpty(config.CodeFile))
			{
				File.WriteAllText(config.CodeFile, src.ToString());
			}
			StringBuilder stringBuilder2 = new StringBuilder();
			foreach (KeyValuePair<string, StdAssetRecord> item in records)
			{
				stringBuilder2.AppendLine(item.Key + "|" + item.Value.uri + "|" + item.Value.recordId + "|" + item.Value.timestamp.ToBinary() + "|" + item.Value.md5);
			}
			if (!string.IsNullOrEmpty(config.RecordsCache))
			{
				File.WriteAllText(config.RecordsCache, stringBuilder2.ToString());
			}
			UniLog.Log("Finished Standard Asset Upload");
		}

		private static async Task ProcessFolder(string path, AssetUploadConfig config, StringBuilder src, Dictionary<string, StdAssetRecord> records, Engine engine, string rootDirName, bool runAlphaBleed = false)
		{
			HashSet<string> names = new HashSet<string>();
			string[] files = Directory.GetFiles(path);
			foreach (string f in files)
			{
				if (!IsSupported(f))
				{
					continue;
				}
				string text = Path.GetExtension(f)?.ToLower();
				if (runAlphaBleed && AssetHelper.IdentifyClass(f) == AssetClass.Texture && text != ".jpg" && text != ".jpeg")
				{
					UniLog.Log("Processing ColorToAlphaBleed to " + f);
					Bitmap2D bitmap2D = Bitmap2D.Load(f, false);
					bitmap2D.BleedColorToAlpha();
					bitmap2D.Save(f);
				}
				string relativePath = f.Remove(0, config.Path.Length);
				DateTime timestamp = File.GetLastWriteTimeUtc(f);
				string fname = Path.GetFileNameWithoutExtension(f);
				bool upload = false;
				FrooxEngine.Store.Record record = null;
				if (records.TryGetValue(relativePath, out StdAssetRecord localRecord))
				{
					if (timestamp != localRecord.timestamp && Convert.ToBase64String(FileUtil.ComputeHash(f, FileUtil.FileHash.MD5)) != localRecord.md5)
					{
						UniLog.Log("Uploading Modified: ");
						records.Remove(relativePath);
						upload = true;
						record = (await engine.Cloud.Records.GetRecord<FrooxEngine.Store.Record>(config.Owner, localRecord.recordId)).Entity;
					}
				}
				else
				{
					localRecord = new StdAssetRecord();
					UniLog.Log("Uploading New: ");
					upload = true;
					record = new FrooxEngine.Store.Record();
					record.OwnerId = config.Owner;
					record.RecordId = RecordHelper.GenerateRecordID();
				}
				if (upload)
				{
					UniLog.Log(relativePath);
					AssetClass assetClass = AssetHelper.IdentifyClass(f);
					if (assetClass == AssetClass.Model)
					{
						UniLog.Log("Importing: " + f);
						World w = Userspace.UserspaceWorld;
						Coroutine importCoroutine = default(Coroutine);
						Slot importSlot = null;
						w.RunSynchronously(delegate
						{
							importSlot = w.AddSlot("Import");
							importCoroutine = w.Coroutines.StartCoroutine(ModelImporter.ImportModel(f, importSlot, ModelImportSettings.PBS()));
						});
						while (importCoroutine.IsNull || !importCoroutine.IsDone)
						{
							await default(NextUpdate);
						}
						UniLog.Log("Import finished, saving...");
						SavedGraph graph = null;
						w.RunSynchronously(delegate
						{
							graph = importSlot.SaveObject(DependencyHandling.CollectAssets);
							importSlot.Destroy();
						});
						while (graph == null)
						{
							await default(NextUpdate);
						}
						Uri uri = await engine.LocalDB.SaveAssetAsync(graph, engine);
						record.AssetURI = uri.ToString();
						record.RecordType = "object";
					}
					else
					{
						Uri uri2 = await engine.LocalDB.ImportLocalAssetAsync(f, LocalDB.ImportLocation.Original);
						record.AssetURI = uri2.ToString();
						record.RecordType = assetClass.ToString().ToLower();
					}
					record.Name = fname;
					record.IsPublic = true;
					if (!string.IsNullOrEmpty(config.InventoryPath))
					{
						record.Path = Path.Combine(config.InventoryPath, Path.GetDirectoryName(relativePath.Substring(1)));
					}
					RecordManager.RecordSaveResult saveResult = await engine.RecordManager.SaveRecord(record);
					saveResult.task.ForceConflictSync = true;
					config.CompletionTasks.Add(async delegate
					{
						_ = 4;
						try
						{
							await saveResult.task.Task;
							while (engine.RecordManager.SyncingRecordsCount > 0)
							{
								await default(NextUpdate);
							}
							int attempts = 0;
							do
							{
								await default(NextUpdate);
								FrooxEngine.Store.Record record2 = await engine.LocalDB.TryFetchRecordAsync(config.Owner, record.RecordId).ConfigureAwait(continueOnCapturedContext: false);
								record = record2;
								if (engine.RecordManager.SyncingRecordsCount == 0)
								{
									attempts++;
								}
							}
							while (!engine.Cloud.Assets.IsValidDBUri(record.AssetURI) && attempts < 256);
							UniLog.Log("DONE, record:\n" + JsonConvert.SerializeObject(record));
							localRecord.uri = record.AssetURI;
							localRecord.recordId = record.RecordId;
							localRecord.timestamp = timestamp;
							localRecord.md5 = Convert.ToBase64String(FileUtil.ComputeHash(f, FileUtil.FileHash.MD5));
							records.Add(relativePath, localRecord);
							if (assetClass == AssetClass.Shader && engine.Cloud.Assets.IsValidDBUri(localRecord.uri))
							{
								await engine.Cloud.Assets.GetAssetMetadata(AssetVariantType.Shader, engine.Cloud.Assets.DBSignature(new Uri(localRecord.uri)));
							}
						}
						catch (Exception ex)
						{
							UniLog.Error("Exception when finalizing task for " + record.Name + ":\n" + ex);
						}
					});
				}
				if (fname == rootDirName)
				{
					fname += "_";
				}
				string membername = FilterName(fname, names);
				string backingMemberName = "__uri_" + membername;
				config.CompletionTasks.Add(async delegate
				{
					StringBuilder stringBuilder = src;
					StringBuilder stringBuilder2 = stringBuilder;
					StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(12, 1, stringBuilder);
					handler.AppendLiteral("static Uri ");
					handler.AppendFormatted(backingMemberName);
					handler.AppendLiteral(";");
					stringBuilder2.AppendLine(ref handler);
					stringBuilder = src;
					StringBuilder stringBuilder3 = stringBuilder;
					handler = new StringBuilder.AppendInterpolatedStringHandler(67, 5, stringBuilder);
					handler.AppendLiteral("public static Uri ");
					handler.AppendFormatted(membername);
					handler.AppendLiteral(" { get {");
					handler.AppendLiteral("if(");
					handler.AppendFormatted(backingMemberName);
					handler.AppendLiteral(" == null) ");
					handler.AppendLiteral("  ");
					handler.AppendFormatted(backingMemberName);
					handler.AppendLiteral(" = new Uri(\"");
					handler.AppendFormatted(localRecord.uri);
					handler.AppendLiteral("\");");
					handler.AppendLiteral("return ");
					handler.AppendFormatted(backingMemberName);
					handler.AppendLiteral(";");
					handler.AppendLiteral("} }");
					stringBuilder3.AppendLine(ref handler);
				});
			}
			files = Directory.GetDirectories(path);
			foreach (string path2 in files)
			{
				string dirName = Path.GetFileName(path2);
				if (!dirName.StartsWith("."))
				{
					dirName = FilterName(dirName, names);
					config.CompletionTasks.Add(async delegate
					{
						src.AppendLine("public static class " + dirName);
						src.AppendLine("{");
					});
					await ProcessFolder(path2, config, src, records, engine, dirName, runAlphaBleed || dirName == "Graphics");
					config.CompletionTasks.Add(async delegate
					{
						src.AppendLine("}");
					});
				}
			}
		}

		private static string FilterName(string name, HashSet<string> names)
		{
			name = name.Trim();
			if (char.IsDigit(name[0]))
			{
				name = "_" + name;
			}
			name = name.Replace(" ", "_");
			name = name.Replace("-", "_");
			name = name.Replace(".", "_");
			name = name.Replace(",", "_");
			string text = name;
			int num = 1;
			if (CSharpKeywords.Contains(text))
			{
				text = "@" + text;
			}
			while (names.Contains(text))
			{
				text = name + "_" + num++;
			}
			names.Add(text);
			return text;
		}

		private static bool IsSupported(string filename)
		{
			switch (AssetHelper.IdentifyClass(filename))
			{
			case AssetClass.Text:
			case AssetClass.Texture:
			case AssetClass.Volume:
			case AssetClass.Model:
			case AssetClass.Audio:
			case AssetClass.Video:
			case AssetClass.Shader:
			case AssetClass.Font:
				return true;
			default:
				UniLog.Log("Unsupported standard asset type: " + filename);
				return false;
			}
		}
	}
