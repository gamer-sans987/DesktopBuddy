		private bool ShouldAddTimestamp(SkyFrost.Base.Message message)
		{
			if (_lastTimestampMessage == null)
			{
				return true;
			}
			if ((message.SendTime - _lastTimestampMessage.SendTime).TotalSeconds >= 30.0)
			{
				return true;
			}
			return false;
		}

		private FrooxEngine.UIX.Image AddMessage(SkyFrost.Base.Message message)
		{
			string content = message.Content;
			messagesUi.PushStyle();
			RectTransform rectTransform = messagesUi.Panel();
			messagesUi.LayoutTarget = rectTransform.Slot;
			OverlappingLayout overlappingLayout = messagesUi.OverlappingLayout(2f);
			UIBuilder uIBuilder = messagesUi;
			Elements.Core.colorX tint;
			if (message.IsSent)
			{
				Elements.Core.colorX colorX = ((!message.IsRead || base.Cloud.DoNotSendReadStatus) ? (message.SendStatus switch
				{
					SendStatus.Sending => SENDING_MESSAGE_COLOR, 
					SendStatus.Sent => SENT_MESSAGE_COLOR, 
					SendStatus.Failed => ERROR_SENT_COLOR, 
					_ => ERROR_SENT_COLOR, 
				}) : READ_MESSAGE_COLOR);
				tint = colorX;
			}
			else
			{
				tint = RECEIVED_MESSAGE_COLOR;
			}
			FrooxEngine.UIX.Image image = uIBuilder.Panel(in tint);
			image.Sprite.Target = messagesUi.Style.ButtonSprite;
			image.NineSliceSizing.Value = messagesUi.Style.NineSliceSizing;
			HoverArea hoverArea = image.Slot.AttachComponent<HoverArea>();
			messagesUi.Style.MinHeight = -1f;
			messagesUi.LayoutTarget = image.Slot;
			messagesUi.VerticalLayout(0f, 2f);
			bool flag;
			switch (message.MessageType)
			{
			case SkyFrost.Base.MessageType.Text:
			case SkyFrost.Base.MessageType.Object:
				flag = ShouldAddTimestamp(message);
				break;
			case SkyFrost.Base.MessageType.Sound:
			case SkyFrost.Base.MessageType.SessionInvite:
			case SkyFrost.Base.MessageType.InviteRequest:
				flag = true;
				break;
			default:
				flag = false;
				break;
			}
			DateTime dateTime = message.SendTime.ToLocalTime();
			if (flag)
			{
				FrooxEngine.UIX.Image image2 = messagesUi.Panel(in RadiantUI_Constants.Neutrals.MID);
				image2.Sprite.Target = messagesUi.Style.ButtonSprite;
				image2.NineSliceSizing.Value = messagesUi.Style.NineSliceSizing;
				messagesUi.LayoutTarget = messagesUi.Root;
				messagesUi.OverlappingLayout(2f);
				messagesUi.Text((LocaleString)(dateTime.ToLongTimeString() + " " + dateTime.ToLongDateString()), bestFit: false).Size.Value = 12f;
				messagesUi.NestOut();
			}
			if (message.IsSent && !message.IsRead)
			{
				_messageBackgrounds.Add(message.Id, image);
			}
			if (message.IsSent)
			{
				overlappingLayout.PaddingLeft.Value = 32f;
			}
			else
			{
				overlappingLayout.PaddingRight.Value = 32f;
			}
			try
			{
				SkyFrost.Base.Record record;
				switch (message.MessageType)
				{
				case SkyFrost.Base.MessageType.Text:
				{
					Text text3 = messagesUi.Text((LocaleString)content, bestFit: false, message.IsSent ? Alignment.MiddleRight : Alignment.MiddleLeft);
					text3.Size.Value = 20f;
					Slot slot2 = text3.Slot.AddSlot("Copy");
					messagesUi.NestInto(slot2);
					Button button2 = messagesUi.Button(OfficialAssets.Graphics.Icons.Inspector.Duplicate);
					button2.LocalPressed += [SyncMethod(typeof(Delegate), null)] (IButton b, ButtonEventData e) =>
					{
						OnCopyMessage(b, e, message);
					};
					if (message.IsSent)
					{
						button2.RectTransform.SetFixedRect(new Elements.Core.Rect(new Elements.Core.float2(2f), Elements.Core.float2.One * 24), new Elements.Core.float2(0f, 0f));
					}
					else
					{
						button2.RectTransform.SetFixedRect(new Elements.Core.Rect(new Elements.Core.float2(-26f), Elements.Core.float2.One * 24), new Elements.Core.float2(1f));
					}
					slot2.ActiveSelf_Field.DriveFrom(hoverArea.IsHovering);
					break;
				}
				case SkyFrost.Base.MessageType.Sound:
				{
					record = message.ExtractContent<SkyFrost.Base.Record>();
					messagesUi.Style.MinHeight = 32f;
					Slot slot = messagesUi.Panel().Slot;
					StaticAudioClip staticAudioClip = slot.AttachComponent<StaticAudioClip>();
					staticAudioClip.URL.Value = new Uri(record.AssetURI);
					AudioClipPlayer audioClipPlayer = slot.AttachComponent<AudioClipPlayer>();
					audioClipPlayer.Clip.Target = staticAudioClip;
					AudioOutput audioOutput = slot.AttachComponent<AudioOutput>();
					audioOutput.Source.Target = audioClipPlayer;
					audioOutput.SpatialBlend.Value = 0f;
					audioOutput.Spatialize.Value = false;
					audioOutput.AudioTypeGroup.Value = AudioTypeGroup.Voice;
					audioOutput.IgnoreAudioEffects.Value = true;
					AudioWaveformTexture audioWaveformTexture = slot.AttachComponent<AudioWaveformTexture>();
					audioWaveformTexture.Clip.Target = staticAudioClip;
					audioWaveformTexture.Size.Value = new Elements.Core.int2(128, 32);
					audioWaveformTexture.FilterMode.Value = TextureFilterMode.Point;
					audioWaveformTexture.ForegroundColor.Value = (message.IsSent ? RadiantUI_Constants.Hero.GREEN : RadiantUI_Constants.Hero.CYAN);
					audioWaveformTexture.BackgroundColor.Value = (message.IsSent ? RadiantUI_Constants.Dark.GREEN : RadiantUI_Constants.Dark.CYAN);
					messagesUi.VerticalHeader(32f, out RectTransform header, out RectTransform content2);
					messagesUi.ForceNext = header;
					Button button = messagesUi.Button();
					button.Slot.AttachComponent<ButtonPlaybackAction>().Playback.Target = audioClipPlayer;
					button.RequireLockInToPress.Value = true;
					messagesUi.Nest();
					FrooxEngine.UIX.Image image3 = messagesUi.Image(OfficialAssets.Common.Icons.Play);
					FrooxEngine.UIX.Image image4 = messagesUi.Image(OfficialAssets.Common.Icons.Pause);
					image3.RectTransform.AddFixedPadding(4f);
					image4.RectTransform.AddFixedPadding(4f);
					PlaybackStateDriver playbackStateDriver = slot.AttachComponent<PlaybackStateDriver>();
					playbackStateDriver.Source.Target = audioClipPlayer;
					playbackStateDriver.IsPlaying.Target = image4.Slot.ActiveSelf_Field;
					playbackStateDriver.IsNotPlaying.Target = image3.Slot.ActiveSelf_Field;
					PlaybackStateDriver playbackStateDriver2 = slot.AttachComponent<PlaybackStateDriver>();
					playbackStateDriver2.Source.Target = audioClipPlayer;
					playbackStateDriver2.IsPlaying.Target = audioOutput.EnabledField;
					messagesUi.NestOut();
					messagesUi.NestInto(content2);
					RawImage rawImage = messagesUi.RawImage(audioWaveformTexture);
					FrooxEngine.UIX.Image image5 = messagesUi.Image(LegacyAudioPlayer.PLAYBACK_COLOR.SetA(0.25f));
					ProgressBar progressBar = image5.Slot.AttachComponent<ProgressBar>();
					PlaybackPositionDriver playbackPositionDriver = image5.Slot.AttachComponent<PlaybackPositionDriver>();
					playbackPositionDriver.Source.Target = audioClipPlayer;
					playbackPositionDriver.Target.Target = progressBar.Progress;
					progressBar.SetTarget(image5.RectTransform);
					image5.InteractionTarget.Value = false;
					rawImage.Slot.AttachComponent<Button>();
					rawImage.Slot.AttachComponent<ButtonPlaybackSeeker>().Playback.Target = audioClipPlayer;
					messagesUi.NestOut();
					messagesUi.NestOut();
					break;
				}
				case SkyFrost.Base.MessageType.Object:
					record = message.ExtractContent<SkyFrost.Base.Record>();
					messagesUi.Style.MinHeight = 64f;
					messagesUi.Button(new Uri(record.ThumbnailURI), (Elements.Core.colorX?)null, Elements.Core.colorX.White).SetupLocalAction([SyncMethod(typeof(Delegate), null)] (IButton button3, ButtonEventData data) =>
					{
						SpawnMessageItem(button3, data, record);
					}, 0.35f).RequireLockInToPress.Value = true;
					break;
				case SkyFrost.Base.MessageType.SessionInvite:
				{
					SessionInfo sessionInfo = message.ExtractContent<SessionInfo>();
					sessionInfo = base.Cloud.Sessions.TryGetInfo(sessionInfo.SessionId) ?? sessionInfo;
					messagesUi.Style.MinHeight = 64f;
					messagesUi.Panel();
					SessionItem sessionItem = messagesUi.Root.AttachComponent<SessionItem>();
					sessionItem.BuildUI(messagesUi);
					messagesUi.NestOut();
					sessionItem.Update(sessionInfo, isCurrent: true);
					break;
				}
				case SkyFrost.Base.MessageType.InviteRequest:
				{
					InviteRequest inviteRequest = message.ExtractContent<InviteRequest>();
					if (message.IsSent || inviteRequest.IsGranted)
					{
						LocaleString text = ((inviteRequest.UserIdToInvite == base.Cloud.CurrentUserID) ? "Contacts.InviteRequest.SentRequest".AsLocaleKey() : ((!inviteRequest.IsGranted) ? "Contacts.InviteRequest.ForwardedRequest".AsLocaleKey(null, ("username", inviteRequest.UsernameToInvite), ("sessionName", inviteRequest.ForSessionName)) : "Contacts.InviteRequest.GrantedRequest".AsLocaleKey(null, ("username", inviteRequest.UsernameToInvite), ("sessionName", inviteRequest.ForSessionName))));
						messagesUi.Text(in text).Size.Value = 20f;
					}
					else
					{
						InviteRequestItem inviteRequestItem = messagesUi.Root.AttachComponent<InviteRequestItem>();
						inviteRequestItem.Request = inviteRequest;
						inviteRequestItem.ContactDialog.Target = this;
						Text text2 = messagesUi.Text((LocaleString)"");
						text2.Size.Value = 20f;
						inviteRequestItem.HeaderText.Target = text2;
						messagesUi.Style.MinHeight = 32f;
						inviteRequestItem.InviteButton.Target = messagesUi.Button((LocaleString)"Invite");
						inviteRequestItem.AddContactButton.Target = messagesUi.Button((LocaleString)"Contact");
						inviteRequestItem.InviteButton.Target.RequireLockInToPress.Value = true;
						inviteRequestItem.AddContactButton.Target.RequireLockInToPress.Value = true;
					}
					break;
				}
				}
			}
			catch (Exception ex)
			{
				base.Debug.Error("Exception generating message content:\n" + ex);
			}
			messagesUi.NestOutFrom(rectTransform);
			messagesUi.PopStyle();
			_messagesScrollRect.Target.NormalizedPosition.Value = new Elements.Core.float2(0f, 1f);
			_lastTimestampMessage = message;
			return image;
		}

		private void SpawnMessageItem(IButton button, ButtonEventData eventData, SkyFrost.Base.Record record)
		{
			World w = base.Engine.WorldManager.FocusedWorld;
			w.RunSynchronously(delegate
			{
				if (w.CanSpawnObjects())
				{
					Slot s = w.AddSlot("Spawn");
					s.StartTask(async delegate
					{
						await s.LoadObjectAsync(record);
						List<Slot> list = Pool.BorrowList<Slot>();
						s.PositionInFrontOfUser(Elements.Core.float3.Backward);
						s = s.GetComponent<InventoryItem>()?.Unpack(keepExistingPosition: false, list) ?? s;
						s.World.BeginUndoBatch("Undo.Spawn".AsLocaleKey(("name", s.Name_Field)));
						foreach (Slot item in list)
						{
							item.CreateSpawnUndoPoint();
						}
						s.World.EndUndoBatch();
						Pool.Return(ref list);
					});
				}
			});
		}

