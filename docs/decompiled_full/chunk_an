		{
			base.InitializeSyncMembers();
			PasteOnGrab = new Sync<bool>();
			_indicatorMaterial = new SyncRef<FresnelMaterial>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => PasteOnGrab, 
				4 => _indicatorMaterial, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static TransferGrabbable __New()
		{
			return new TransferGrabbable();
		}
	}
