		[SyncMethod(typeof(Delegate), null)]
		private void SearchTextChanged(TextEditor editor)
		{
			string searchTerm = editor.TargetString?.Trim().ToLower();
			foreach (ContactItem searchResultItem in _searchResultItems)
			{
				searchResultItem.Slot.Destroy();
			}
			_searchResultItems.Clear();
			bool flag = string.IsNullOrWhiteSpace(searchTerm);
			foreach (KeyValuePair<string, ContactItem> contactItem in _contactItems)
			{
				if (flag)
				{
					contactItem.Value.Slot.ActiveSelf = true;
					continue;
				}
				contactItem.Value.Slot.ActiveSelf = contactItem.Value.Username.StartsWith(searchTerm, StringComparison.InvariantCultureIgnoreCase) || contactItem.Value.AlternateNames.Any((string n) => n.StartsWith(searchTerm, StringComparison.InvariantCulture));
			}
			globalSearchTimer = 0.5;
		}

