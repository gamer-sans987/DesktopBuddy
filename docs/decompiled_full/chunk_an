		protected override void OnCommonUpdate()
		{
			base.InputInterface.AppDashOpened = Open;
			Dash.ScreenProjection.Value = !base.InputInterface.VR_Active;
			DashBlocked = BlockOpenClose.Value;
			_editModeToggleLerp = MathX.Progress01(_editModeToggleLerp, base.Time.Delta * 4f, Userspace.UserInterfaceEditMode);
			Slot target = _uiEditModeToggle.Target;
			target.LocalScale = new Elements.Core.float3(MathX.SmootherStep(_editModeToggleLerp), 1f, 1f) * 0.0007f;
			target.ActiveSelf = _editModeToggleLerp > 0f;
			if (base.InputInterface.GetKeyDown(Key.I) && base.InputInterface.GetKey(Key.LeftControl))
			{
				ToggleLegacyInventory();
			}
			_lookat.Target.MaxSwing.Value = (Freeform.Value ? 360f : 0f);
			if (!_lastOpen && Dash.Open.Value)
			{
				_positioner.Target.TeleportAtTarget();
				ResetHorizontalOffset();
			}
			_lastOpen = Dash.Open.Value;
			UpdateModalOverlaySpawnRoot();
			bool flag = false;
			if (base.InputInterface.ScreenActive && Open)
			{
				flag = true;
				base.InputInterface.RegisterGlobalBlock(KeyboardBlock.GLOBAL_BLOCK);
				base.InputInterface.RegisterGlobalBlock(MouseBlock.GLOBAL_BLOCK);
			}
			if (flag != _lastCursorUnlockRegistered)
			{
				if (flag)
				{
					base.Input.RegisterCursorUnlock(this);
				}
				else
				{
					base.Input.UnregisterCursorUnlock(this);
				}
				_lastCursorUnlockRegistered = flag;
			}
		}

