				handler = new StringBuilder.AppendInterpolatedStringHandler(44, 4, stringBuilder);
				handler.AppendFormatted(value);
				handler.AppendLiteral(" workers active: ");
				handler.AppendFormatted(workProcessor.ActiveWorkerCount(value));
				handler.AppendLiteral(" of ");
				handler.AppendFormatted(workProcessor.GetWorkerCount(value));
				handler.AppendLiteral(". Last processed jobs: ");
				handler.AppendFormatted(workProcessor.LastProcessedJobs(value));
				stringBuilder2.AppendLine(ref handler);
			}
			ThreadPool.GetAvailableThreads(out var workerThreads, out var completionPortThreads);
			stringBuilder = str;
			StringBuilder stringBuilder3 = stringBuilder;
			handler = new StringBuilder.AppendInterpolatedStringHandler(74, 3, stringBuilder);
			handler.AppendLiteral("ThreadPool WorkerThreads, ");
			handler.AppendFormatted(workerThreads);
			handler.AppendLiteral(", CompletionPortThreads: ");
			handler.AppendFormatted(completionPortThreads);
			handler.AppendLiteral(", MaxConcurrencyLevel: ");
			handler.AppendFormatted(TaskScheduler.Default.MaximumConcurrencyLevel);
			stringBuilder3.AppendLine(ref handler);
			str.AppendLine("--------");
			List<string> list = Pool.BorrowList<string>();
			List<int> list2 = Pool.BorrowList<int>();
			foreach (WorkType value2 in Enum.GetValues(typeof(WorkType)))
			{
				stringBuilder = str;
				StringBuilder stringBuilder4 = stringBuilder;
				handler = new StringBuilder.AppendInterpolatedStringHandler(7, 1, stringBuilder);
				handler.AppendLiteral("<b>");
				handler.AppendFormatted(value2);
				handler.AppendLiteral("</b>");
				stringBuilder4.AppendLine(ref handler);
				workProcessor.GetActiveJobs(value2, list);
				workProcessor.GetLastProcessedJobs(value2, list2);
				for (int i = 0; i < list.Count; i++)
				{
					str.AppendLine($"#{i} ({list2[i]}): " + list[i]);
				}
				list.Clear();
				list2.Clear();
			}
			Pool.Return(ref list);
			Pool.Return(ref list2);
		}

