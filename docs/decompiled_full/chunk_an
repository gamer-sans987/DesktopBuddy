			_minInvalidIndex = MathX.Min(index, _minInvalidIndex);
			_maxInvalidIndex = MathX.Max(index + length, _maxInvalidIndex);
		}

		public void DataShortened(int origLength, int newLength)
		{
			DataWritten(newLength, origLength - newLength);
		}

		public void InvalidateWhole()
		{
			_minInvalidIndex = 0;
			_maxInvalidIndex = int.MaxValue;
		}

		public void TrackArray<T>(SyncArray<T> syncarray) where T : IEquatable<T>
		{
			syncarray.DataWritten += delegate(SyncArray<T> sender, int index, int length)
			{
				DataWritten(index, length);
			};
			syncarray.DataShortened += delegate(SyncArray<T> sender, int origLength, int newLength)
			{
				DataShortened(origLength, newLength);
			};
		}

		public void AddWholeInvalidator(IChangeable changeable)
		{
			changeable.Changed += delegate
			{
				InvalidateWhole();
			};
		}
	}
	public class SlotComponentTracker<T> where T : class
	{
		public readonly Slot Slot;

		public readonly Worker RootWorker;

		public readonly HashSet<T> Components = new HashSet<T>();

		public bool IsTracking { get; private set; }

		public SlotComponentTracker(Worker rootWorker)
		{
			RootWorker = rootWorker;
			Slot = rootWorker.FindNearestParent<Slot>();
			Slot.ForeachComponent((T c) => Components.Add(c));
			Slot.ComponentAdded += Slot_ComponentAdded;
			Slot.ComponentRemoved += Slot_ComponentRemoved;
			RootWorker.Disposing += RootWorker_Disposing;
			IsTracking = true;
		}

		private void RootWorker_Disposing(Worker obj)
		{
			Dispose();
		}

		private void Slot_ComponentRemoved(Component component)
		{
			if (component is T item)
			{
				Components.Remove(item);
			}
		}

		private void Slot_ComponentAdded(Component component)
		{
			if (component is T item)
			{
				Components.Add(item);
			}
		}

		public void Dispose()
		{
			if (IsTracking)
			{
				Slot.ComponentAdded -= Slot_ComponentAdded;
				Slot.ComponentRemoved -= Slot_ComponentRemoved;
				IsTracking = false;
				Components.Clear();
			}
		}
	}
