			stringBuilder2.Append(ref handler);
			bool flag = false;
			if (element is SyncElement syncElement)
			{
				builder.Append(", Name: " + syncElement.Name + ", Disposed: " + syncElement.IsDisposed);
				flag = true;
			}
			if (element is Component component)
			{
				stringBuilder = builder;
				StringBuilder stringBuilder3 = stringBuilder;
				handler = new StringBuilder.AppendInterpolatedStringHandler(40, 3, stringBuilder);
				handler.AppendLiteral(", IsDestroyed: ");
				handler.AppendFormatted(component.IsDestroyed);
				handler.AppendLiteral(", IsDisposed: ");
				handler.AppendFormatted(component.IsDisposed);
				handler.AppendLiteral(", Enabled: ");
				handler.AppendFormatted(component.Enabled);
				stringBuilder3.Append(ref handler);
				flag = true;
			}
			if (element is Slot slot)
			{
				builder.Append(", " + slot.ToString());
				flag = true;
			}
			if (!flag && element is ISyncMember syncMember)
			{
				stringBuilder = builder;
				StringBuilder stringBuilder4 = stringBuilder;
				handler = new StringBuilder.AppendInterpolatedStringHandler(8, 1, stringBuilder);
				handler.AppendLiteral(", Name: ");
				handler.AppendFormatted(syncMember.Name);
				stringBuilder4.Append(ref handler);
			}
			if (element is ConflictingSyncElement conflictingSyncElement)
			{
				stringBuilder = builder;
				StringBuilder stringBuilder5 = stringBuilder;
				handler = new StringBuilder.AppendInterpolatedStringHandler(76, 4, stringBuilder);
				handler.AppendLiteral(", LastVersion: ");
				handler.AppendFormatted(conflictingSyncElement.LastVersion);
				handler.AppendLiteral(", LastConfirmedTime: ");
				handler.AppendFormatted(conflictingSyncElement.LastConfirmedTime);
				handler.AppendLiteral(", LastHostVersion: ");
				handler.AppendFormatted(conflictingSyncElement.LastHostVersion);
				handler.AppendLiteral(", ");
				handler.AppendLiteral("LastModifyingUser: ");
				handler.AppendFormatted(conflictingSyncElement.LastModifyingUser);
				stringBuilder5.Append(ref handler);
			}
			builder.AppendLine();
