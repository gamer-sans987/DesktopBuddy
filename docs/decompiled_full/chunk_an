		[SyncMethod(typeof(Delegate), null)]
		private void DoRegister(IButton button, ButtonEventData eventData)
		{
			string username = _username.Target.TargetString;
			string email = _email.Target.TargetString?.Trim();
			string text = _emailRepeat.Target.TargetString?.Trim();
			string password = _password.Target.TargetString;
			string targetString = _passwordRepeat.Target.TargetString;
			bool rememberMe = _rememberLogin.Target.IsChecked;
			int value = _birthMonth.Target.ParsedValue.Value;
			int value2 = _birthDay.Target.ParsedValue.Value;
			int value3 = _birthYear.Target.ParsedValue.Value;
			if (string.IsNullOrWhiteSpace(username))
			{
				FlashError((TextField)_username);
				return;
			}
			if (string.IsNullOrWhiteSpace(email))
			{
				FlashError((TextField)_email);
				return;
			}
			if (email != text)
			{
				SetHeaderMessage("Account.ErrorEmailMismatch".AsLocaleKey(), Elements.Core.colorX.Red);
				FlashError((TextField)_email);
				FlashError((TextField)_emailRepeat);
				return;
			}
			if (password != targetString)
			{
				SetHeaderMessage("Account.ErrorPasswordMismatch".AsLocaleKey(), Elements.Core.colorX.Red);
				FlashError((TextField)_password);
				FlashError((TextField)_passwordRepeat);
				return;
			}
			DateTimeOffset dateOfBirth;
			try
			{
				dateOfBirth = new DateTime(value3, value, value2);
			}
			catch (Exception)
			{
				SetHeaderMessage((LocaleString)"Account.InvalidDateOfBirth", Elements.Core.colorX.Red);
				FlashError(_birthDay);
				FlashError(_birthMonth);
				FlashError(_birthYear);
				return;
			}
			if (!_policies.Target.IsChecked)
			{
				FlashError((Checkbox)_policies);
				return;
			}
			SetInteraction(enabled: false);
			SetHeaderMessage("Account.Registering".AsLocaleKey(), Elements.Core.colorX.Cyan);
			StartTask(async delegate
			{
				UniLog.Log("Registering user...");
				CloudResult<RegistrationStatus> cloudResult = await base.Engine.Cloud.Users.Register(username, email, password, dateOfBirth);
				if (cloudResult.IsError)
				{
					UniLog.Error($"Error in registration: {cloudResult}");
					if (string.IsNullOrEmpty(cloudResult.Content))
					{
						ShowError("Register.UnknownError".AsLocaleKey());
					}
					else
					{
						ShowError(cloudResult.Content.AsLocaleKey());
					}
					SetInteraction(enabled: true);
				}
				else
				{
					string userId = cloudResult.Entity.Id;
					string token = cloudResult.Entity.Token;
					if (!(await WaitForRegistration(userId, token)))
					{
						SetInteraction(enabled: true);
					}
					else
					{
						CloudResult<UserSessionResult<SkyFrost.Base.User>> cloudResult2 = await base.Engine.Cloud.Users.GetRegisteredSession(userId, token);
						if (cloudResult2.IsError)
						{
							ShowError("Register.ManualLoginRequired".AsLocaleKey());
							SetInteraction(enabled: true);
						}
						else
						{
							BuildUI(State.Message, SlideSwapRegion.Slide.Left, this.GetLocalized("Account.RegistrationSuccess", null, ("email", $"<color={RadiantUI_Constants.LABEL_HEX}>{email}</color>"), ("appEmail", base.Cloud.Platform.Email), ("appCommunity", base.Cloud.Platform.DiscordInviteUrl)), "General.Cancel".AsLocaleKey());
							await AutoLoginWhenVerified(cloudResult2.Entity.Entity, email, new PasswordLogin(password), rememberMe);
						}
					}
				}
			});
		}

		/// <summary>
		/// Waits for a user's registration to complete, displaying any errors encountered
		/// </summary>
		/// <param name="id"></param>
		/// <param name="token"></param>
		/// <returns>Whether the registration was completed successfully</returns>
		private async Task<bool> WaitForRegistration(string id, string token)
		{
			ArgumentException.ThrowIfNullOrWhiteSpace(id, "id");
			ArgumentException.ThrowIfNullOrWhiteSpace(token, "token");
			UniLog.Log("Waiting for registration " + id + " to be processed...");
			int statusCheckErrors = 0;
			while (true)
			{
				await DelaySeconds(5f);
				CloudResult<RegistrationStatus> cloudResult = await base.Cloud.Users.GetRegistrationStatus(id, token);
				if (cloudResult.IsError)
				{
					UniLog.Error($"Error checking registration status: {cloudResult}");
					int num = statusCheckErrors + 1;
					statusCheckErrors = num;
					if (num >= 3)
					{
						ShowError("Register.StatusCheckError".AsLocaleKey());
						return false;
					}
					continue;
				}
				if (cloudResult.Entity.State == RegistrationState.Failed)
				{
					UniLog.Error("Error registering user " + id + ": " + cloudResult.Entity.Error);
					ShowError(cloudResult.Entity.Error.AsLocaleKey());
					return false;
				}
				if (cloudResult.Entity.State == RegistrationState.Done)
				{
					break;
				}
				UniLog.Log($"Registration {id} state: {cloudResult.Entity.State}");
			}
			UniLog.Log("Registration " + id + " succeeded");
			return true;
		}

		private async Task AutoLoginWhenVerified(SkyFrost.Base.User user, string email, LoginAuthentication authentication, bool rememberLogin)
		{
			if (user == null)
			{
				throw new ArgumentNullException("user");
			}
			CloudResult<SkyFrost.Base.User> cloudResult;
			do
			{
				await DelaySeconds(5f);
				cloudResult = await base.Cloud.Users.GetUser(user.Id);
			}
			while (!cloudResult.IsOK || !cloudResult.Entity.IsVerified);
			await Login(email, authentication, rememberLogin);
		}

