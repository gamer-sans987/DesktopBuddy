		private async Task Login(string credential, LoginAuthentication authentication, bool rememberLogin, string totpCode = null)
		{
			SetInteraction(enabled: false);
			SetHeaderMessage("Account.LoggingIn".AsLocaleKey(), Elements.Core.colorX.Cyan);
			CloudResult<UserSessionResult<UserSession>> cloudResult = await base.Engine.Cloud.Session.Login(credential, authentication, base.Engine.LocalDB.SecretMachineID, rememberLogin, totpCode);
			if (cloudResult.IsOK)
			{
				Close();
				return;
			}
			if (cloudResult.Content == "TOTP")
			{
				string text = await base.Slot.OpenModalOverlay(new Elements.Core.float2(0.25f, 0.25f)).Slot.AttachComponent<TwoFactorCodeDialog>().Task;
				if (string.IsNullOrWhiteSpace(text))
				{
					SetInteraction(enabled: true);
				}
				else
				{
					await Login(credential, authentication, rememberLogin, text);
				}
				return;
			}
			UniLog.Log("Login Error: " + cloudResult.State.ToString() + ", " + cloudResult.Content);
			SetInteraction(enabled: true);
			if (string.IsNullOrEmpty(cloudResult.Content))
			{
				ShowError("Login.UnknownError".AsLocaleKey());
			}
			else
			{
				ShowError(cloudResult.Content.AsLocaleKey());
			}
		}

