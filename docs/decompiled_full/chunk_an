		private static void InitializeGridContainer(Slot root, Elements.Core.int2 cellCount, Action<UIBuilder> preprocess, float scaleRatio = 1f, bool priority = true)
		{
			Slot slot = root.AddSlot("Container");
			Slot target = root.AddSlot("Facets");
			slot.LocalScale = Elements.Core.float3.One * 0.0002f * scaleRatio;
			Canvas canvas = slot.AttachComponent<Canvas>();
			if (priority)
			{
				slot.AttachComponent<UserspaceLaserPriority>();
			}
			canvas.StartingOffset.Value = -10000;
			canvas.Size.Value = cellCount * 32f;
			UIBuilder uIBuilder = new UIBuilder(canvas);
			preprocess(uIBuilder);
			uIBuilder.Next("GridContainer");
			GridContainer gridContainer = uIBuilder.Current.AttachComponent<GridContainer>();
			gridContainer.CellSize.Value = null;
			gridContainer.CellCount.Value = cellCount;
			gridContainer.FacetsRoot.Target = target;
			GridContainerAnimatedEditVisual.Setup(gridContainer, gridContainer.BackgroundRoot.Slot);
			ValueCopyExtensions.DriveFrom(source: gridContainer.Slot.AttachComponent<UserInterfaceEditModeSync>().EditModeActive, field: gridContainer.EditMode);
		}

		private async Task InstrumentAnchors()
		{
			if (base.Cloud.CurrentUserID == null)
			{
				return;
			}
			UniLog.Log("Instrumenting facet anchors with components. Waiting for all workspaces to load...");
			while (Anchors.Any((Data a) => a.Workspace.Target.IsLoadingWorkspace || a.Workspace.Target.CurrentWorkspaceOwnerId != base.Cloud.CurrentUserID))
			{
				await default(NextUpdate);
			}
			foreach (Data anchor in Anchors)
			{
				if (anchor.Root.Target.GetComponentInChildren<UserspaceFacetAnchor>() == null)
				{
					UserspaceFacetAnchor userspaceFacetAnchor = anchor.Root.Target.AttachComponent<UserspaceFacetAnchor>();
					userspaceFacetAnchor.Point.Value = anchor.Point.Value;
					UI_UnlitMaterial material = anchor.Root.Target.GetComponentInChildren<UI_UnlitMaterial>();
					FrooxEngine.UIX.Image componentInChildren = anchor.Root.Target.GetComponentInChildren((FrooxEngine.UIX.Image i) => i.Material.Target == material);
					userspaceFacetAnchor.BackgroundMaterial.Target = material;
					userspaceFacetAnchor.BackgroundImage.Target = componentInChildren;
					if (anchor.Point.Value.IsView())
					{
						anchor.Root.Target.GetComponentInChildren<UserspaceLaserPriority>()?.Destroy();
					}
					userspaceFacetAnchor.FixViewPadding();
					UniLog.Log($"Injecting facet anchor info {anchor.Point.Value}. Found BG: {componentInChildren != null}, Found BG Mat: {material != null}");
				}
			}
		}

