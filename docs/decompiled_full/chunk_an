		protected async Task<LoginResult> EnsureLogin()
		{
			if (_otherCloud.CurrentUser != null)
			{
				return new LoginResult(_otherCloud);
			}
			if (CurrentState.Value == State.Account)
			{
				_username = _usernameField.Target.TargetString;
				_password = _passwordField.Target.TargetString;
			}
			CloudResult<UserSessionResult<UserSession>> cloudResult = await _otherCloud.Session.Login(_username, new PasswordLogin(_password), _otherCloud.SecretMachineId, rememberMe: true, null);
			while (cloudResult.Content == "TOTP")
			{
				string text = await base.Slot.OpenModalOverlay(new Elements.Core.float2(0.25f, 0.25f)).Slot.AttachComponent<TwoFactorCodeDialog>().Task;
				if (string.IsNullOrEmpty(text))
				{
					return default(LoginResult);
				}
				cloudResult = await _otherCloud.Session.Login(_username, new PasswordLogin(_password), _otherCloud.SecretMachineId, rememberMe: true, text);
			}
			if (!cloudResult.IsOK)
			{
				return new LoginResult(cloudResult.Content);
			}
			return new LoginResult(_otherCloud);
		}

		[SyncMethod(typeof(Delegate), null)]
		public void CheckLoginAndNext(IButton button, ButtonEventData eventData, State next)
		{
			button.Enabled = false;
			StartTask(async delegate
			{
				button.LabelText = this.GetLocalized("General.Loading");
				LoginResult loginResult = await EnsureLogin();
				if (loginResult.OtherCloud == null)
				{
					if (loginResult.error != null)
					{
						ShowErrorOnButton(button, this.GetLocalized("Migration.Error", null, ("error", loginResult.error)), this.GetLocalized("General.Next"));
					}
					button.Enabled = true;
				}
				else
				{
					ChangeStep(button, eventData, next);
				}
			});
		}

