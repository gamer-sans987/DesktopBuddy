		/// <summary>
		/// Checks if any of the URIs in this are valid for a given platform
		/// </summary>
		/// <param name="platform">Platform to use when checking</param>
		/// <param name="manager"></param>
		/// <returns><see langword="true" /> if there are valid URIs. <see langword="false" /> otherwise.</returns>
		public bool HasValidUri(IPlatformProfile platform, INetworkManagerManager manager)
		{
			return URIs.Any((Uri uri) => platform.IsValidRecordUri(uri) || platform.IsValidSessionUri(uri) || manager.IsSupportedSessionScheme(uri.Scheme));
		}

		/// <summary>
		/// Checks if this worldstartsettings can "start" a world.
		/// </summary>
		/// <param name="platform">Platform the world should run on.</param>
		/// <param name="manager"></param>
		/// <returns><see langword="true" /> if this can be used to start a world. <see langword="false" /> otherwise.</returns>
		/// <remarks>
		/// This is a quick check, that doesn't rely on anything external to the WorldStartSettings except for the platform.
		/// </remarks>
		public bool CanStart(IPlatformProfile platform, INetworkManagerManager manager)
		{
			if (HasValidUri(platform, manager))
			{
				return true;
			}
			if (Link != null)
			{
				return true;
			}
			if (InitWorld != null)
			{
				return true;
			}
			if (SessionID != null || Record != null)
			{
				return true;
			}
			return false;
		}

		public override string ToString()
		{
			return $"World Start Settings. URIs: {string.Join(", ", URIs)}, InitFunc: {InitWorld}, SessionID: {SessionID}, GetExisting: {GetExisting}";
		}
