	public abstract class SettingActionProxyBase<S, D> : Component where S : SettingComponent<S>, new() where D : Delegate
	{
		public readonly Sync<string> ActionName;

		public readonly Sync<string> SubsettingGetter;

		public readonly Sync<string> SubsettingKey;

		private string _mappedActionName;

		private string _mappedSubsettingGetter;

		private string _mappedSubsettingKey;

		protected S _cachedComponent { get; private set; }

		protected D _cachedMethod { get; private set; }

		protected bool CanTrigger
		{
			get
			{
				if (!base.World.IsUserspace() && !base.World.UnsafeMode)
				{
					return false;
				}
				if (string.IsNullOrEmpty(ActionName.Value))
				{
					return false;
				}
				if (_cachedComponent == null || _cachedMethod == null)
				{
					return false;
				}
				return true;
			}
		}

		protected override void OnStart()
		{
			base.OnStart();
			if (base.World.IsUserspace())
			{
				Settings.RegisterComponentChanges<S>(OnComponentChanged);
			}
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (_cachedComponent != null && (ActionName.Value != _mappedActionName || SubsettingGetter.Value != _mappedSubsettingGetter || SubsettingKey.Value != _mappedSubsettingKey))
			{
				BindMethod();
			}
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			if (base.World.IsUserspace())
			{
				Settings.UnregisterComponentChanges<S>(OnComponentChanged);
			}
		}

		private void OnComponentChanged(S setting)
		{
			_cachedComponent = setting;
			BindMethod();
		}

		private void BindMethod()
		{
			if (_cachedComponent == null)
			{
				return;
			}
			_mappedActionName = ActionName.Value;
			_mappedSubsettingGetter = SubsettingGetter.Value;
			_mappedSubsettingKey = SubsettingKey.Value;
			Worker worker = _cachedComponent.GetSettingContainer(_mappedSubsettingGetter, _mappedSubsettingKey);
			if (worker != null)
			{
				string[] array = _mappedActionName.Split('.');
				string name = array.Last();
				for (int i = 0; i < array.Length - 1; i++)
				{
					worker = worker?.GetSyncMember(array[i]) as Worker;
				}
				_cachedMethod = worker.GetSyncMethod(name) as D;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			ActionName = new Sync<string>();
			SubsettingGetter = new Sync<string>();
			SubsettingKey = new Sync<string>();
		}
	}
