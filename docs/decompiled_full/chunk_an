		public void ToggleLegacyInventory(bool position = true)
		{
			if (_legacyInventoryPanel.Target == null)
			{
				foreach (InventoryBrowser globallyRegisteredComponent in base.World.GetGloballyRegisteredComponents<InventoryBrowser>())
				{
					LegacyCanvasPanel componentInParents = globallyRegisteredComponent.Slot.GetComponentInParents<LegacyCanvasPanel>();
					if (componentInParents != null)
					{
						_legacyInventory.Target = globallyRegisteredComponent;
						_legacyInventoryPanel.Target = componentInParents;
						break;
					}
				}
			}
			if (_legacyInventoryPanel.Target == null)
			{
				LegacyCanvasPanel legacyCanvasPanel = base.World.AddSlot("Legacy Inventory").AttachComponent<LegacyCanvasPanel>();
				InventoryBrowser inventoryBrowser = legacyCanvasPanel.Canvas.Slot.AddSlot().AttachComponent<RectTransform>().Slot.AttachComponent<InventoryBrowser>();
				inventoryBrowser.OpenDefault();
				legacyCanvasPanel.CanvasSize = new Elements.Core.float2(700f, 700f);
				legacyCanvasPanel.Panel.AddCloseButton();
				legacyCanvasPanel.Panel.AddUserspaceTransferButton(delegate(Slot slot)
				{
					InventoryBrowser componentInChildren = slot.GetComponentInChildren<InventoryBrowser>();
					if (componentInChildren != null)
					{
						string path = componentInChildren.CurrentPath;
						string ownerId = componentInChildren.CurrentOwnerId;
						Elements.Core.float3 pos = WorldManager.TransferPoint(slot.GlobalPosition, slot.World, Userspace.UserspaceWorld);
						Elements.Core.floatQ rot = WorldManager.TransferRotation(slot.GlobalRotation, slot.World, Userspace.UserspaceWorld);
						Elements.Core.float3 scl = WorldManager.TransferScale(slot.GlobalScale, slot.World, Userspace.UserspaceWorld);
						RunSynchronously(delegate
						{
							ToggleLegacyInventory(position: false);
							_legacyInventory.Target.Slot.ActiveSelf = true;
							_legacyInventory.Target._changePath = path;
							_legacyInventory.Target._changeOwnerId = ownerId;
							Slot slot2 = _legacyInventory.Target.Slot.GetComponentInParents<LegacyPanel>().Slot;
							slot2.GlobalPosition = pos;
							slot2.GlobalRotation = rot;
							slot2.GlobalScale = MathX.AvgComponent(in scl) * Elements.Core.float3.One;
						});
					}
				}, delegate(Slot slot)
				{
					InventoryBrowser componentInChildren = slot.GetComponentInChildren<InventoryBrowser>();
					if (componentInChildren != null)
					{
						componentInChildren.SafeUser = slot.LocalUser;
					}
				});
				legacyCanvasPanel.Panel.AddParentButton();
				legacyCanvasPanel.Panel.Title = "Inventory (legacy)";
				legacyCanvasPanel.Panel.CloseOverride.Target = OnHide;
				legacyCanvasPanel.Panel.IndicatePrivate = true;
				if (position)
				{
					legacyCanvasPanel.Slot.PositionInFrontOfUser(Elements.Core.float3.Backward, Elements.Core.float3.Up * 0.2f);
				}
				_legacyInventoryPanel.Target = legacyCanvasPanel;
				_legacyInventory.Target = inventoryBrowser;
			}
			else
			{
				_legacyInventoryPanel.Target.Slot.ActiveSelf = !_legacyInventoryPanel.Target.Slot.ActiveSelf;
				if (position)
				{
					_legacyInventoryPanel.Target.Slot.PositionInFrontOfUser(Elements.Core.float3.Backward, Elements.Core.float3.Up * 0.2f);
				}
			}
		}

