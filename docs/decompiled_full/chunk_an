		private void UpdateState(string ownerId, bool isMemberQuota, long usedBytes, long quotaBytes)
		{
			OwnerType ownerType = IdUtil.GetOwnerType(ownerId);
			if (_ownerLabel.Target != null)
			{
				switch (ownerType)
				{
				case OwnerType.User:
					_ownerLabel.Target.Text.Value = "Cloud space:";
					break;
				case OwnerType.Group:
				{
					Group obj = base.Engine.Cloud.Groups.TryGetCurrentUserGroupInfo(ownerId);
					if (isMemberQuota)
					{
						_ownerLabel.Target.Text.Value = "Your <b>" + obj?.Name + "</b>\ngroup quota:";
					}
					else
					{
						_ownerLabel.Target.Text.Value = "<b>" + obj?.Name + "</b> group\nshared space:";
					}
					break;
				}
				default:
					_ownerLabel.Target.Text.Value = "???";
					break;
				}
			}
			float num = ((quotaBytes >= 0) ? ((float)((double)usedBytes / (double)quotaBytes)) : 0f);
			float num2 = 1f - num;
			if (quotaBytes < 0)
			{
				if (_usageLabel.Target != null)
				{
					_usageLabel.Target.Text.Value = "---";
				}
				if (_percentLabel.Target != null)
				{
					_percentLabel.Target.Text.Value = "---";
				}
			}
			else
			{
				if (_usageLabel.Target != null)
				{
					_usageLabel.Target.Text.Value = "Using " + UnitFormatting.FormatBytes(usedBytes) + " of " + UnitFormatting.FormatBytes(quotaBytes);
				}
				if (_percentLabel.Target != null)
				{
					_percentLabel.Target.Text.Value = MathX.RoundToInt(num * 100f) + " %";
				}
			}
			if (_progressBar.Target != null)
			{
				_progressBar.Target.Progress = num;
				_progressBar.Target.ContainerColor = ContainerColor.Value;
				if (num2 > LowSpaceThreshold.Value)
				{
					_progressBar.Target.BarColor = UsedColor.Value;
				}
				else if (num2 > CriticalSpaceThreshold.Value)
				{
					_progressBar.Target.BarColor = LowSpaceColor.Value;
				}
				else
				{
					_progressBar.Target.BarColor = CriticalSpaceColor.Value;
				}
			}
		}

