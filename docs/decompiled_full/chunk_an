		private const int CHANGES_SAVED_WAIT_FRAMES = 5;

		public bool Initialized;

		public readonly Sync<EndMode> Mode;

		public readonly Sync<bool> ChangesSaved;

		private bool endInitiated;

		private int changedSavedFrames;

		protected readonly SyncRef<TextRenderer> _text;

		protected readonly FieldDrive<Elements.Core.colorX> _textColor;

		protected readonly FieldDrive<Elements.Core.colorX> _outlineColor;

		private int _exitPressCount;

		protected override void OnAttach()
		{
			Slot slot = base.World.AddSlot("Label");
			slot.GlobalPosition = Elements.Core.float3.Up * 1.7f + Elements.Core.float3.Forward * 2f;
			TextRenderer textRenderer = slot.AttachComponent<TextRenderer>();
			textRenderer.Size.Value = 1f;
			TextUnlitMaterial textUnlitMaterial = slot.AttachComponent<TextUnlitMaterial>();
			textRenderer.Material.Target = textUnlitMaterial;
			textUnlitMaterial.OutlineThickness.Value = 0.3f;
			textUnlitMaterial.FaceDilate.Value = 0.3f;
			textUnlitMaterial.FaceSoftness.Value = 0.5f;
			_text.Target = textRenderer;
			_outlineColor.Target = textUnlitMaterial.OutlineColor;
			_textColor.Target = textRenderer.Color;
		}

		public override void OnFocusChanged(World.WorldFocus focus)
		{
			if (!Initialized || focus == FrooxEngine.World.WorldFocus.Focused)
			{
				return;
			}
			base.Engine.GlobalCoroutineManager.RunInUpdates(1, delegate
			{
				if (!base.World.IsDestroyed)
				{
					base.Engine.WorldManager.FocusWorld(base.World);
				}
			});
		}

		protected override void OnCommonUpdate()
		{
			if (!Initialized)
			{
				return;
			}
			if (base.InputInterface.GetKeyDown(Key.Escape))
			{
				_exitPressCount++;
			}
			float h = (float)base.Time.WorldTime * 0.1f;
			_textColor.Target.Value = new ColorHSV(h, 0.05f, 0.05f).ToRGB(ColorProfile.sRGB);
			_outlineColor.Target.Value = new ColorHSV(h, 0.2f, 2f).ToRGB(ColorProfile.sRGB);
			if (Userspace.ActiveSaveTaskCount > 0)
			{
				_text.Target.Text.Value = this.GetLocalized("Exiting.SavingItems", null, "n", Userspace.ActiveSaveTaskCount);
			}
			else if (!ChangesSaved)
			{
				_text.Target.Text.Value = this.GetLocalized("Exiting.SavingChanges");
			}
			else if (base.Engine.RecordManager.SyncingRecordsCount > 0)
			{
				string value = ((base.Engine.RecordManager.CurrentUploadTask?.Progress ?? 0f) * 100f).ToString("F1");
				_text.Target.Text.Value = this.GetLocalized("Indicator.Sync.SyncingItems", null, new Dictionary<string, object>
				{
					{
						"item_count",
						base.Engine.RecordManager.SyncingRecordsCount
					},
					{ "item_percent", value }
				});
			}
			else
			{
				_text.Target.Text.Value = (((EndMode)Mode == EndMode.Exit) ? this.GetLocalized("Exiting.Exiting") : this.GetLocalized("Exiting.LoggingOut"));
			}
			if ((bool)ChangesSaved)
			{
				changedSavedFrames++;
			}
			bool flag = _exitPressCount >= 10;
			if (Userspace.ActiveSaveTaskCount != 0 || changedSavedFrames <= 5 || (!flag && base.Engine.RecordManager.SyncingRecordsCount != 0) || endInitiated)
			{
				return;
			}
			endInitiated = true;
			switch (Mode.Value)
			{
			case EndMode.Exit:
				base.Engine.RequestShutdown();
				break;
			case EndMode.Logout:
				Task.Run(async delegate
				{
					try
					{
						UniLog.Log("Logging out...");
						await base.Engine.Cloud.Session.Logout(isManual: true);
					}
					catch (Exception ex)
					{
						UniLog.Error("Exception when running log-out:\n" + ex);
					}
					UniLog.Log("Log out complete, existing log out world");
					await Userspace.ExitWorld(base.World);
					Userspace.IsLoggingOut = false;
				});
				break;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Mode = new Sync<EndMode>();
			ChangesSaved = new Sync<bool>();
			_text = new SyncRef<TextRenderer>();
			_textColor = new FieldDrive<Elements.Core.colorX>();
			_outlineColor = new FieldDrive<Elements.Core.colorX>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Mode, 
				4 => ChangesSaved, 
				5 => _text, 
				6 => _textColor, 
				7 => _outlineColor, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static AppEnder __New()
		{
			return new AppEnder();
		}
	}
	public class ColorWheelTriangleMesh : ProceduralMesh
	{
		public enum SelectionMode
		{
			Invalid,
			Hue,
			ValueSaturation
		}

		public readonly Sync<float> Hue;

		public readonly Sync<float> OuterRadius;

		public readonly Sync<float> InnerRadius;

		public readonly Sync<int> RingSegments;

		public readonly Sync<Elements.Core.float3> CursorPosition;

		public readonly Sync<int> CursorSegments;

		public readonly Sync<Elements.Core.colorX> CursorColor;

		public readonly Sync<float> CursorOuterRadius;

		public readonly Sync<float> CursorInnerRadius;

		public readonly Sync<float> CursorZOffset;

		private Ring _ring;

		private Ring _cursorRing;

		private Elements.Assets.Triangle _triangle;

		private Elements.Assets.Vertex _vHue;

		private Elements.Assets.Vertex _vWhite;

		private Elements.Assets.Vertex _vBlack;

		private float _hue;

		private float _inner;

		private float _outer;

		private int _segments;

		private Elements.Core.float3 _cursorCoord;

		private int _cursorSegments;

		private float _cursorInner;

		private float _cursorOuter;

		private Elements.Core.colorX _cursorColor;

		private float _cursorZoff;

		protected override void OnAwake()
		{
			RingSegments.Value = 64;
			OuterRadius.Value = 0.5f;
			InnerRadius.Value = 0.4f;
			CursorSegments.Value = 16;
			CursorColor.Value = Elements.Core.colorX.Black;
			CursorOuterRadius.Value = 0.05f;
			CursorInnerRadius.Value = 0.03f;
			CursorZOffset.Value = -0.01f;
			CursorPosition.Value = new Elements.Core.float3(1f);
		}

		public void BeginSelection(Elements.Core.float2 localPoint, out SelectionMode mode)
		{
			float magnitude = localPoint.Magnitude;
			if (magnitude > OuterRadius.Value)
			{
				mode = SelectionMode.Invalid;
			}
			else if (magnitude > InnerRadius.Value)
			{
				mode = SelectionMode.Hue;
				UpdateSelection(localPoint, mode);
			}
			else if (MathX.MinComponent(GetBarycentricCoord(localPoint)) < 0f)
			{
				mode = SelectionMode.Invalid;
			}
			else
			{
				mode = SelectionMode.ValueSaturation;
				UpdateSelection(localPoint, mode);
			}
		}

		public void UpdateSelection(Elements.Core.float2 localPoint, SelectionMode mode)
		{
			switch (mode)
			{
			case SelectionMode.Hue:
			{
				float num2 = 0f - MathX.Atan2(in localPoint) + MathF.PI;
				Hue.Value = MathX.Repeat(num2 / (MathF.PI * 2f), 1f);
				break;
			}
			case SelectionMode.ValueSaturation:
			{
				Elements.Core.float3 v = MathX.Clamp01(GetBarycentricCoord(localPoint));
				float num = v.x + v.y + v.z;
				v /= num;
				CursorPosition.Value = v;
				break;
			}
			}
		}

		public Elements.Core.float3 GetBarycentricCoord(Elements.Core.float2 localPoint)
		{
			float num = Hue.Value * (MathF.PI * 2f);
			return MathX.BarycentricCoord(in localPoint, TrianglePoint(num, InnerRadius.Value), TrianglePoint(num + MathF.PI * 2f / 3f, InnerRadius.Value), TrianglePoint(num + 4.1887903f, InnerRadius.Value));
		}

		public ColorHSV ComputeHSV()
		{
			float y = CursorPosition.Value.y;
			float z = CursorPosition.Value.z;
			float num = MathX.Clamp01(1f - z);
			return new ColorHSV(s: (num != 0f) ? (1f - MathX.Clamp01(y / num)) : 0f, h: Hue.Value, v: num);
		}

		public Elements.Core.colorX ComputeColor()
		{
			Elements.Core.colorX a = new ColorHSV(Hue.Value, 1f, 1f).ToRGB(ColorProfile.Linear);
			Elements.Core.float3 value = CursorPosition.Value;
			return a * value.x + Elements.Core.colorX.White * value.y;
		}

		public void SetColor(Elements.Core.colorX c)
		{
			SetHSV(new ColorHSV(in c));
		}

		public void SetHSV(ColorHSV hsv)
		{
			SetHSV(hsv.h, hsv.s, hsv.v);
		}

		public void SetHSV(float h, float s, float v)
		{
			Hue.Value = h;
			float num = 1f - v;
			float num2 = (1f - s) * v;
			CursorPosition.Value = new Elements.Core.float3(1f - (num2 + num), num2, num);
		}

		protected override void PrepareAssetUpdateData()
		{
			_hue = MathX.Repeat(Hue.Value, 1f);
			_inner = InnerRadius.Value;
			_outer = OuterRadius.Value;
			_segments = MathX.Max(RingSegments.Value, 3);
			_cursorCoord = CursorPosition.Value;
			_cursorSegments = MathX.Max(CursorSegments.Value, 3);
			_cursorInner = CursorInnerRadius.Value;
			_cursorOuter = CursorOuterRadius.Value;
			_cursorColor = CursorColor.Value;
			_cursorZoff = CursorZOffset.Value;
		}

		protected override void ClearMeshData()
		{
			_triangle = default(Elements.Assets.Triangle);
			_ring = null;
			_cursorRing = null;
		}

		protected override void UpdateMeshData(MeshX meshx)
		{
			bool value = false;
			meshx.TrackRemovals = true;
			if (_triangle.Mesh == null)
			{
				_vHue = meshx.AddVertex();
				_vWhite = meshx.AddVertex();
				_vBlack = meshx.AddVertex();
				_triangle = meshx.AddTriangle(_vHue, _vWhite, _vBlack);
				_vWhite.Color = Elements.Core.color.White;
				_vBlack.Color = Elements.Core.color.Black;
				value = true;
			}
			if (_ring == null || _ring.Segments != _segments)
			{
				_ring?.Remove();
				_ring = new Ring(meshx, _segments);
				for (int i = 0; i < _segments; i++)
				{
					ColorHSV colorHSV = new ColorHSV((float)i / (float)_segments, 1f, 1f);
					_ring.InnerRingVertex(i).SetColor((Elements.Core.color)colorHSV);
					_ring.OuterRingVertex(i).SetColor((Elements.Core.color)colorHSV);
				}
				value = true;
			}
			if (_cursorRing == null || _cursorRing.Segments != _cursorSegments)
			{
				_cursorRing?.Remove();
				_cursorRing = new Ring(meshx, _cursorSegments);
				value = true;
			}
			_ring.OuterRadius = _outer;
			_ring.InnerRadius = _inner;
			_cursorRing.OuterRadius = _cursorOuter;
			_cursorRing.InnerRadius = _cursorInner;
			foreach (Elements.Assets.Vertex allVertex in _cursorRing.AllVertices)
			{
				allVertex.SetColor(_cursorColor.LinearColor);
			}
			_triangle.Vertex0.SetColor((Elements.Core.color)new ColorHSV(_hue, 1f, 1f));
			float num = _hue * (MathF.PI * 2f);
			_vHue.Position = TrianglePoint(num, _inner);
			_vWhite.Position = TrianglePoint(num + MathF.PI * 2f / 3f, _inner);
			_vBlack.Position = TrianglePoint(num + 4.1887903f, _inner);
			_cursorRing.Position = new Elements.Core.float3(MathX.BarycentricToCartesian(in _cursorCoord, _vHue.Position.xy, _vWhite.Position.xy, (Elements.Core.float3)_vBlack.Position.xy), _cursorZoff);
			_ring.Update();
			_cursorRing.Update();
			uploadHint[MeshUploadHint.Flag.Geometry] = value;
		}

		private Elements.Core.float2 TrianglePoint(float angle, float radius)
		{
			return new Elements.Core.float2(0f - MathX.Cos(angle), MathX.Sin(angle)) * radius;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Hue = new Sync<float>();
			OuterRadius = new Sync<float>();
			InnerRadius = new Sync<float>();
			RingSegments = new Sync<int>();
			CursorPosition = new Sync<Elements.Core.float3>();
			CursorSegments = new Sync<int>();
			CursorColor = new Sync<Elements.Core.colorX>();
			CursorOuterRadius = new Sync<float>();
			CursorInnerRadius = new Sync<float>();
			CursorZOffset = new Sync<float>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => HighPriorityIntegration, 
				4 => OverrideBoundingBox, 
				5 => OverridenBoundingBox, 
				6 => Profile, 
				7 => Hue, 
				8 => OuterRadius, 
				9 => InnerRadius, 
				10 => RingSegments, 
				11 => CursorPosition, 
				12 => CursorSegments, 
				13 => CursorColor, 
				14 => CursorOuterRadius, 
				15 => CursorInnerRadius, 
				16 => CursorZOffset, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static ColorWheelTriangleMesh __New()
		{
			return new ColorWheelTriangleMesh();
		}
	}
