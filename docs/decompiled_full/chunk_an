			_indicatorMaterial.Target.FarColor.Value = c;
		}

		public IGrabbable Grab(Grabber grabber, Slot holdSlot, bool supressEvents = false)
		{
			World focusedWorld = base.Engine.WorldManager.FocusedWorld;
			object linkingKey = grabber.LinkingKey;
			Grabber targetGrabber = null;
			if (linkingKey != null)
			{
				targetGrabber = Userspace.TryGetWorldGrabber(focusedWorld, linkingKey);
			}
			if ((bool)PasteOnGrab && targetGrabber != null)
			{
				Userspace.Paste(Saved, Source, base.Slot.GlobalPosition, base.Slot.GlobalRotation, base.Slot.GlobalScale).OnResultDone += delegate(Slot slot)
				{
					IGrabbable componentInChildren = slot.GetComponentInChildren<IGrabbable>();
					targetGrabber.Grab(componentInChildren);
				};
				base.Slot.Destroy();
				return null;
			}
			if (CanGrab(grabber))
			{
				base.Slot.Parent = holdSlot;
				return this;
			}
			return null;
		}

		public void Release(Grabber grabber, bool supressEvents = false)
		{
			Userspace.Paste(Saved, Source, base.Slot.GlobalPosition, base.Slot.GlobalRotation, base.Slot.GlobalScale);
			base.Slot.Destroy();
		}

		protected override void OnCommonUpdate()
		{
			bool flag = base.Engine.WorldManager.FocusedWorld.CanSpawnObjects();
			if (_lastIsActive == flag)
			{
				return;
			}
			if (flag)
			{
				RestoreOriginalMaterials(base.Slot);
			}
			else
			{
				if (_originalMaterials == null)
				{
					SaveOriginalMaterials(base.Slot);
				}
				ReplaceMaterials(base.Slot, _indicatorMaterial.Target);
				SetIndicatorColor(Elements.Core.colorX.Red);
			}
			_lastIsActive = flag;
		}

		private void SaveOriginalMaterials(Slot root)
		{
			_originalMaterials = new Dictionary<MeshRenderer, List<IAssetProvider<Material>>>();
			foreach (MeshRenderer componentsInChild in root.GetComponentsInChildren<MeshRenderer>())
			{
				List<IAssetProvider<Material>> list = new List<IAssetProvider<Material>>();
				foreach (IAssetProvider<Material> material in componentsInChild.Materials)
				{
					list.Add(material);
				}
				_originalMaterials.Add(componentsInChild, list);
			}
		}

		private void RestoreOriginalMaterials(Slot root)
		{
			foreach (MeshRenderer componentsInChild in root.GetComponentsInChildren<MeshRenderer>())
			{
				if (_originalMaterials.TryGetValue(componentsInChild, out List<IAssetProvider<Material>> value))
				{
					for (int i = 0; i < value.Count; i++)
					{
						componentsInChild.Materials[i] = value[i];
					}
				}
			}
		}

		private void ReplaceMaterials(Slot root, IAssetProvider<Material> material)
		{
			foreach (MeshRenderer componentsInChild in root.GetComponentsInChildren<MeshRenderer>())
			{
				for (int i = 0; i < componentsInChild.Materials.Count; i++)
				{
					componentsInChild.Materials[i] = material;
				}
			}
		}

