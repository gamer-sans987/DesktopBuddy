			if (_actions.ToggleDash.Pressed)
			{
				_dash.Target.ToggleOpen();
			}
			if ((bool)_actions.ToggleDash)
			{
				_actions.SubmitBlocksToGlobal = true;
			}
			if (_actions.ToggleMute.Pressed)
			{
				base.AudioSystem.IsMuted = !base.AudioSystem.IsMuted;
