		protected override void OnChanges()
		{
			if (!CanInteract(base.World.LocalUser) || !CanOperate)
			{
				return;
			}
			if (CurrentPath.LastModifyingUser != null && CurrentPath.LastModifyingUser != base.LocalUser)
			{
				UniLog.Warning("CurrentPath was modified by a different user, self-destructing.");
				base.Slot.Destroy();
				return;
			}
			_createNewButton.Target.Enabled = Path.IsPathRooted(CurrentPath);
			_importButton.Target.Enabled = SelectedFileItem != null;
			if (_lastPath != CurrentPath.Value)
			{
				int num = CurrentPath.Value?.Length ?? 0;
				int num2 = _lastPath.Value?.Length ?? 0;
				SlideSwapRegion.Slide slide;
				if (num == num2)
				{
					slide = SlideSwapRegion.Slide.None;
				}
				else if (num > num2)
				{
					slide = SlideSwapRegion.Slide.Left;
				}
				else
				{
					slide = SlideSwapRegion.Slide.Right;
				}
				StartTask(async delegate
				{
					await Refresh(slide);
				});
			}
			base.OnChanges();
		}

		protected override string GetSelectedText()
		{
			string text = SelectedFileItem?.Name.Value;
			if (text != null)
			{
				string value = "";
				AssetClass value2 = AssetHelper.IdentifyClass(text);
				if (SelectedFileItem.Type.Value == FileSystemItem.EntryType.Directory)
				{
					value2 = AssetClass.Folder;
				}
				else
				{
					try
					{
						string text2 = Path.Combine(SelectedFileItem.BasePath, SelectedFileItem.Name);
						if (File.Exists(text2))
						{
							FileInfo fileInfo = new FileInfo(text2);
							value = " (" + UnitFormatting.FormatBytes(fileInfo.Length) + ") ";
						}
					}
					catch
					{
					}
				}
				return $"{text}{value}<color=#0008> ({value2})</color>";
			}
			return "---";
		}

		protected override void GoUp(int levels = 1)
		{
			if (!Disable)
			{
				for (int i = 0; i < levels; i++)
				{
					CurrentPath.Value = PathUtility.GetDirectoryName(CurrentPath.Value);
				}
			}
		}

		private async Task Refresh(SlideSwapRegion.Slide slide)
		{
			if (Disable)
			{
				return;
			}
			if (!IsValidPath(CurrentPath.Value))
			{
				CurrentPath.Value = _lastPath.Value;
			}
			if (!IsValidPath(CurrentPath.Value))
			{
				AppConfig config = FrooxEngine.Engine.Config;
				if (config != null && config.PathWhitelist.Count == 0)
				{
					return;
				}
				CurrentPath.Value = FrooxEngine.Engine.Config.PathWhitelist[0];
			}
			_lastPath.Value = CurrentPath.Value;
			string fetchedPath = _lastPath.Value;
			List<string> pathChain = FileUtil.GetPathDirectories(_lastPath);
			pathChain.Insert(0, "Computer");
			SetPath(pathChain);
			await default(ToBackground);
			string[] files;
			string[] directories;
			if (string.IsNullOrWhiteSpace(_lastPath))
			{
				files = new string[0];
				directories = Directory.GetLogicalDrives();
			}
			else if (Directory.Exists(_lastPath))
			{
				try
				{
					files = Directory.GetFiles(_lastPath);
					directories = Directory.GetDirectories(_lastPath);
				}
				catch (Exception exception)
				{
					UniLog.Warning($"Exception accessing directories and folders at {_lastPath}:\n{DebugManager.PreprocessException(exception)}");
					files = new string[0];
					directories = new string[0];
				}
			}
			else
			{
				files = new string[0];
				directories = new string[0];
			}
			await default(ToWorld);
			if (fetchedPath != CurrentPath.Value)
			{
				return;
			}
			GridLayout folder;
			GridLayout items;
			UIBuilder uIBuilder = GenerateContent(slide, out folder, out items);
			uIBuilder.Style.ButtonTextAlignment = Alignment.MiddleLeft;
			uIBuilder.Style.ButtonTextPadding = 2f;
			uIBuilder.NestInto(folder.Slot);
			if (pathChain.Count > 1)
			{
				GenerateBackButton(uIBuilder, "General.Back".AsLocaleKey());
			}
			string[] array = directories;
			foreach (string text in array)
			{
				string text2 = Path.GetFileName(text);
				if (string.IsNullOrEmpty(text2))
				{
					text2 = text;
				}
				FileSystemItem fileSystemItem = GenerateItem<FileSystemItem>(uIBuilder, text2, null, RadiantUI_Constants.Sub.YELLOW, SELECTED_COLOR);
				fileSystemItem.NormalText.Value = RadiantUI_Constants.Hero.YELLOW;
				fileSystemItem.SelectedText.Value = RadiantUI_Constants.Hero.GREEN;
				fileSystemItem.SetTarget(text2, FileSystemItem.EntryType.Directory);
			}
			array = files;
			for (int i = 0; i < array.Length; i++)
			{
				string fileName = Path.GetFileName(array[i]);
				FileSystemItem fileSystemItem2 = GenerateItem<FileSystemItem>(uIBuilder, fileName, null, RadiantUI_Constants.Sub.CYAN, SELECTED_COLOR);
				fileSystemItem2.NormalText.Value = RadiantUI_Constants.Hero.CYAN;
				fileSystemItem2.SelectedText.Value = RadiantUI_Constants.Hero.GREEN;
				fileSystemItem2.SetTarget(fileName, FileSystemItem.EntryType.File);
			}
		}

		[SyncMethod(typeof(BrowserCreateDirectoryDialog.CreateHandler), new string[] { })]
		private bool CreateDirectory(string name, out string error)
		{
			if (Disable)
			{
				error = "Disabled";
				return false;
			}
			if (!CanInteract(base.LocalUser) || !base.World.IsUserspace())
			{
				error = "Not allowed";
				return false;
			}
			try
			{
				string path = Path.Combine(CurrentPath, name);
				if (Directory.Exists(path))
				{
					error = "Directory with this name already exists:";
					return false;
				}
				Directory.CreateDirectory(path);
				StartTask(async delegate
				{
					await Refresh(SlideSwapRegion.Slide.None);
				});
				error = null;
				return true;
			}
