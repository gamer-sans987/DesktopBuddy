		public static string ChildHierarchyToString(this ISyncMember member)
		{
			if (member == null)
			{
				return "Null Element";
			}
			StringBuilder stringBuilder = Pool.BorrowStringBuilder();
			member.BuildChildHierarchyString(stringBuilder, 0);
			string result = stringBuilder.ToString();
			Pool.Return(ref stringBuilder);
			return result;
		}

		private static void BuildChildHierarchyString(this ISyncMember member, StringBuilder builder, int level, string prefix = null)
		{
			for (int i = 0; i < level; i++)
			{
				builder.Append(" ");
			}
			builder.Append("- ");
			if (prefix != null)
			{
				builder.Append(prefix);
			}
			string text = "";
			if (member is SyncVar)
			{
				SyncVar syncVar = (SyncVar)member;
				if (syncVar.ElementType == null)
				{
					builder.AppendLine("[null]");
					return;
				}
				text = $" [{syncVar.ElementType}]";
				member = syncVar.Element;
			}
			if (member is IField)
			{
				builder.AppendLine(((IField)member).BoxedValue.ToString() + text);
				return;
			}
			if (member is ISyncList)
			{
				ISyncList syncList = (ISyncList)member;
				builder.AppendLine("List" + (text ?? $"({member.GetType()})"));
				for (int j = 0; j < syncList.Count; j++)
				{
					syncList.GetElement(j).BuildChildHierarchyString(builder, level + 1);
				}
				return;
			}
			if (member is ISyncDictionary)
			{
				ISyncDictionary obj = (ISyncDictionary)member;
				builder.AppendLine("Dictionary" + (text ?? $"({member.GetType()})"));
				{
					foreach (KeyValuePair<object, ISyncMember> boxedEntry in obj.BoxedEntries)
					{
						boxedEntry.Value.BuildChildHierarchyString(builder, level + 1, boxedEntry.Key.ToString() + " : ");
					}
					return;
				}
			}
			if (!(member is ISyncArray))
			{
				return;
			}
			ISyncArray syncArray = (ISyncArray)member;
			builder.AppendLine("Array" + (text ?? $"({member.GetType()})"));
			for (int k = 0; k < syncArray.Count; k++)
			{
				for (int l = 0; l < level + 1; l++)
				{
					builder.Append(" ");
				}
				builder.AppendLine("- " + syncArray.GetElement(k));
			}
		}
	}
