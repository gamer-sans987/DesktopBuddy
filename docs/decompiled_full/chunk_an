		private void BuildStep(State targetState, SlideSwapRegion.Slide slide = SlideSwapRegion.Slide.Left)
		{
			if (targetState == State.ChooseOverwrite && !_migrateFavorites.Value)
			{
				State state = (CurrentState.Value = State.ConfirmStart);
				targetState = state;
			}
			else if (CurrentState.Value == State.Account && targetState != State.Account)
			{
				if (!string.IsNullOrEmpty(_passwordField.Target.TargetString))
				{
					_password = _passwordField.Target.TargetString;
				}
				CurrentState.Value = targetState;
			}
			else
			{
				CurrentState.Value = targetState;
			}
			UIBuilder ui = _swapRegion.Target.Swap(slide);
			RadiantUI_Constants.SetupDefaultStyle(ui);
			ui.Style.MinHeight = 32f;
			ui.Style.MinWidth = 32f;
			base.Slot.SetContainerTitle("Migration.Dialog.Title".AsLocaleKey());
			ui.Style.TextAlignment = Alignment.MiddleLeft;
			ui.Style.ForceExpandHeight = false;
			ui.VerticalLayout(4f, 4f);
			switch (targetState)
			{
			case State.Source:
				ui.Text("Migration.Dialog.Source".AsLocaleKey());
				ui.VerticalLayout(4f, 4f);
				foreach (string item in Directory.EnumerateFiles(Path.Combine(base.Engine.AppPath, "Migrations"), "*.json", SearchOption.AllDirectories))
				{
					try
					{
						SkyFrostConfig skyFrostConfig = System.Text.Json.JsonSerializer.Deserialize<SkyFrostConfig>(File.ReadAllText(item));
						ui.Button((LocaleString)skyFrostConfig.Platform.Name, OnSourceSelected, item);
					}
					catch (Exception value)
					{
						UniLog.Warning($"Exception parsing configuration {item}:\n{value}");
					}
				}
				ui.NestOut();
				ui.Button("General.Cancel".AsLocaleKey(), CancelPressed);
				break;
			case State.Account:
				ui.Text("Migration.Dialog.AccountDescription".AsLocaleKey(null, ("platform", SourcePlatformName)));
				ui.Style.ForceExpandHeight = true;
				ui.VerticalLayout(4f, 4f);
				ui.Style.MinHeight = 50f;
				_usernameField.Target = ui.HorizontalElementWithLabel("Migration.SourceUsername".AsLocaleKey(null, ("platform", SourcePlatformName)), 0.2f, () => ui.TextField());
