		public static void SetWorldControllerData(Chirality node, bool toolInUse, Elements.Core.float3 offset, Elements.Core.float3 forward, float distance)
		{
			ControllerData controllerData = GetControllerData(node);
			offset = MathX.Clamp(MathX.FilterInvalid(offset), -Elements.Core.float3.One, Elements.Core.float3.One);
			forward = MathX.FilterInvalid(forward.Normalized, Elements.Core.float3.Forward);
			if (forward.Magnitude <= 0f)
			{
				forward = Elements.Core.float3.Forward;
			}
			distance = MathX.Clamp(MathX.FilterInvalid(distance), 0f, 100000f);
			controllerData.toolInUse = toolInUse;
			controllerData.distance = distance;
			if (!ContextMenuOpened)
			{
				controllerData.pointOffset = offset;
				controllerData.forward = forward;
			}
		}

