	public static class ItemHelper
	{
		public class SavedItem
		{
			public string Name;

			public Uri Asset;

			public Uri Thumbnail;

			public HashSet<string> Tags;
		}

		public class ItemUploadTask
		{
			public FrooxEngine.Store.Record Record;

			public EngineRecordUploadTask UploadTask;
		}

		public static Elements.Core.int2 THUMBNAIL_SIZE => Elements.Core.int2.One * 512;

		public static string THUMBNAIL_FORMAT => "webp";

		public static int THUMBNAIL_QUALITY => 85;

		public static async Task<ItemUploadTask> SaveItemAndSync(Slot root, bool saveRoot = true, Action<FrooxEngine.Store.Record> recordPostprocess = null)
		{
			SavedItem savedItem = await SaveItem(root, saveRoot).ConfigureAwait(continueOnCapturedContext: false);
			if (savedItem == null)
			{
				return null;
			}
			Engine engine = root.Engine;
			FrooxEngine.Store.Record record = RecordHelper.CreateForObject<FrooxEngine.Store.Record>(ownerId: engine.Cloud.CurrentUserID, name: savedItem.Name, assetUrl: savedItem.Asset.ToString(), thumbnailUrl: savedItem.Thumbnail.ToString());
			record.Tags = savedItem.Tags;
			recordPostprocess?.Invoke(record);
			RecordManager.RecordSaveResult recordSaveResult = await engine.RecordManager.SaveRecord(record).ConfigureAwait(continueOnCapturedContext: false);
			return new ItemUploadTask
			{
				Record = record,
				UploadTask = recordSaveResult.task
			};
		}

		public static Task<SavedItem> SaveItem(Slot root, bool saveRoot = true)
		{
			return root.StartTask(async () => await SaveItemInternal(root, saveRoot).ConfigureAwait(continueOnCapturedContext: false));
		}

		public static bool CanSave(Slot root)
		{
			if (!root.ForeachComponent((IItemPermissions p) => p.CanSave))
			{
				return false;
			}
			foreach (Slot child in root.Children)
			{
				if (child.ActiveUserRoot?.Slot != child && !CanSave(child))
				{
					return false;
				}
			}
			return true;
		}

		private static async Task<SavedItem> SaveItemInternal(Slot itemSlot, bool saveRoot)
		{
			await default(ToWorld);
			SavedItem item = new SavedItem();
			SaveProxy componentInChildren = itemSlot.GetComponentInChildren<SaveProxy>();
			if (componentInChildren != null)
			{
				itemSlot = componentInChildren.Target.Target;
				saveRoot = true;
			}
			if (!CanSave(itemSlot))
			{
				return null;
			}
			Slot slot = ((!saveRoot && itemSlot.ChildrenCount != 0) ? itemSlot[0] : itemSlot);
			InventoryItem inventoryItem = null;
			if (!saveRoot)
			{
				inventoryItem = itemSlot.AttachComponent<InventoryItem>();
				if (itemSlot.ActiveUserRoot != null)
				{
					inventoryItem.RelativeToUserRoot.Value = true;
					Slot slot2 = itemSlot.ActiveUserRoot.Slot;
					inventoryItem.SavedRotation.Value = slot2.SpaceRotationToLocal(itemSlot.LocalRotation, itemSlot.Parent);
					inventoryItem.SavedScale.Value = slot2.SpaceScaleToLocal(itemSlot.LocalScale, itemSlot.Parent);
				}
				else
				{
					inventoryItem.RelativeToUserRoot.Value = false;
					inventoryItem.SavedRotation.Value = itemSlot.GlobalRotation;
					inventoryItem.SavedScale.Value = itemSlot.GlobalScale;
				}
			}
			item.Name = slot.Name;
			item.Tags = new HashSet<string>();
			itemSlot.GenerateTags(item.Tags);
			if (itemSlot.GetComponentInChildren<IAvatarObject>() != null)
			{
				item.Tags.Add(RecordTags.CommonAvatar);
			}
			foreach (IItemMetadataSource componentsInChild in itemSlot.GetComponentsInChildren((IItemMetadataSource c) => c.Slot.PersistentSelf && c.Slot.IsActive, excludeDisabled: true))
			{
				if (componentsInChild.Slot == slot)
				{
					string itemName = componentsInChild.ItemName;
					if (itemName != null)
					{
						item.Name = itemName;
					}
				}
				foreach (string itemTag in componentsInChild.ItemTags)
				{
					item.Tags.Add(itemTag);
				}
			}
			SavedGraph graph = itemSlot.SaveObject(DependencyHandling.CollectAssets);
			inventoryItem?.Destroy();
			List<IItemThumbnailSource> componentsInChildren = itemSlot.GetComponentsInChildren((IItemThumbnailSource s) => s.HasThumbnail && s.Slot.IsActive, excludeDisabled: true);
			SavedItem savedItem;
			if (componentsInChildren.Count == 1 && componentsInChildren[0].Slot == slot)
			{
				Bitmap2D texture = await componentsInChildren[0].GetThumbnail(THUMBNAIL_SIZE.x).ConfigureAwait(continueOnCapturedContext: false);
				savedItem = item;
				savedItem.Thumbnail = await itemSlot.Engine.LocalDB.SaveAssetAsync(texture, THUMBNAIL_FORMAT, THUMBNAIL_QUALITY);
			}
			else
			{
				List<Slot> list = new List<Slot>();
				GetExcludeRoots(slot, list);
				if (list.Count == 0)
				{
					list = null;
				}
				try
				{
					savedItem = item;
					savedItem.Thumbnail = await itemSlot.RenderToAsset(THUMBNAIL_SIZE, itemSlot.World.LocalUser.Root.HeadPosition, 60f, THUMBNAIL_FORMAT, THUMBNAIL_QUALITY, list).ConfigureAwait(continueOnCapturedContext: false);
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception rendering thumbnail: " + ex);
				}
			}
			await default(ToBackground);
			savedItem = item;
			savedItem.Asset = await itemSlot.Engine.LocalDB.SaveAssetAsync(graph, itemSlot.Engine).ConfigureAwait(continueOnCapturedContext: false);
			while (item.Thumbnail == null)
			{
				await Task.Delay(20).ConfigureAwait(continueOnCapturedContext: false);
			}
			return item;
		}

		private static void GetExcludeRoots(Slot root, List<Slot> exclude, bool isRoot = true)
		{
			if (!isRoot && (!root.PersistentSelf || root.GetComponent<UserRoot>() != null))
			{
				return;
			}
			if (root.GetComponent<ChildrenSaveBlocker>() != null)
			{
				foreach (Slot child in root.Children)
				{
					exclude.Add(child);
				}
				return;
			}
			foreach (Slot child2 in root.Children)
			{
				GetExcludeRoots(child2, exclude, isRoot: false);
			}
		}
	}
	[OldTypeName("FrooxEngine.TextureThumbnailSource", null)]
	public class ItemTextureThumbnailSource : Component, IItemThumbnailSource, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable, ICustomInspector
	{
		public readonly AssetRef<Texture2D> Texture;

		public readonly Sync<Elements.Core.Rect?> Crop;

		public bool HasThumbnail
		{
			get
			{
				if (Texture.Asset != null)
				{
					return HasValidSize;
				}
				return false;
			}
		}

		public bool HasValidSize
		{
			get
			{
				if (!Crop.Value.HasValue)
				{
					return true;
				}
				if ((Crop.Value.Value.size <= 0f).Any())
				{
					return false;
				}
				return true;
			}
		}

		public async Task<Bitmap2D> GetThumbnail(int maxSize)
		{
			if (!HasThumbnail)
			{
				throw new InvalidOperationException("Source doesn't have thumbnail. Please check HasThumbnail first");
			}
			Texture2D texture = Texture.Asset;
			object _lock = new object();
			await texture.RequestReadLock(_lock).ConfigureAwait(continueOnCapturedContext: false);
			try
			{
				await default(ToBackground);
				Bitmap2D bitmap2D = await texture.GetOriginalTextureData().ConfigureAwait(continueOnCapturedContext: false);
				if (bitmap2D.BitsPerPixel > 32.0)
				{
					bitmap2D = bitmap2D.ConvertTo(TextureFormat.ARGB32);
				}
				if (Crop.Value.HasValue)
				{
					bitmap2D = bitmap2D.Crop(Crop.Value.Value);
				}
				return bitmap2D.GetRescaled(maxSize, false);
			}
			finally
			{
				texture.ReleaseReadLock(_lock);
			}
		}

