	public class WorldValueSync<T> : Component
	{
		public readonly RelayRef<IField<T>> LocalValue;

		private IField<T> _targetWorldValue;

		private bool _targetValueRead;

		public IField<T> TargetWorldValue
		{
			get
			{
				return _targetWorldValue;
			}
			set
			{
				if (_targetWorldValue != null)
				{
					_targetWorldValue.Changed -= TargetWorldValueChanged;
				}
				_targetWorldValue = value;
				_targetValueRead = false;
				if (value != null)
				{
					value.Changed += TargetWorldValueChanged;
					TargetWorldValueChanged(value);
				}
			}
		}

		private void TargetWorldValueChanged(IChangeable obj)
		{
			T value = TargetWorldValue.Value;
			RunSynchronously(delegate
			{
				if (LocalValue.Target != null)
				{
					LocalValue.Target.Value = value;
					_targetValueRead = true;
				}
			});
		}

		protected override void OnChanges()
		{
			if (_targetValueRead && TargetWorldValue != null && LocalValue.Target != null)
			{
				T value = LocalValue.Target.Value;
				TargetWorldValue.World.RunSynchronously(delegate
				{
					TargetWorldValue.Value = value;
				});
