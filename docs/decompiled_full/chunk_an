	public static class DataModelTypeHelper
	{
		public static bool IsDataModelType(this Type type)
		{
			if (type.IsBaseEnginePrimitive())
			{
				return true;
			}
			if (typeof(IWorldElement).IsAssignableFrom(type))
			{
				return true;
			}
			if (type.GetCustomAttribute<DataModelTypeAttribute>(inherit: true, fromInterfaces: true) != null)
			{
				return true;
			}
			if ((type.IsEnum || typeof(Delegate).IsAssignableFrom(type)) && type.DeclaringType != null && type.DeclaringType.IsDataModelType())
			{
				return true;
			}
			if (ReflectionExtensions.IsNullable(type))
			{
				return Nullable.GetUnderlyingType(type).IsDataModelType();
			}
			Type[] interfaces = type.GetInterfaces();
			for (int i = 0; i < interfaces.Length; i++)
			{
				if (interfaces[i].IsDataModelType())
				{
					return true;
				}
			}
			return false;
		}
	}
