		public void Submit(WorldOrb orb)
		{
			StartTask(async delegate
			{
				await RunSubmission(orb);
			});
		}

		private async Task RunSubmission(WorldOrb orb)
		{
			Uri url = orb.URL;
			base.Cloud.Records.ExtractRecordID(url, out var ownerId, out var recordId);
			if (recordId == "R-Home")
			{
				string oldName = orb.WorldName;
				orb.WorldName = "Can't submit your home!";
				await DelaySeconds(5f);
				orb.WorldName = oldName;
				return;
			}
			orb.WorldName = "Submitting...";
			await default(ToBackground);
			if (IdUtil.GetOwnerType(ownerId) == OwnerType.Machine)
			{
				RecordOwnerTransferer transferer = new RecordOwnerTransferer(base.Engine, base.Engine.Cloud.CurrentUserID, ownerId);
				Task task = transferer.TransferOwner(url);
				RunSynchronously(delegate
				{
					orb.WorldName = "Uploading...";
				});
				await task;
				url = transferer.GetTransferedRecordURL(url);
				base.Cloud.Records.ExtractRecordID(url, out ownerId, out recordId);
			}
			CloudResult<FrooxEngine.Store.Record> cloudResult = await base.Engine.Cloud.Records.GetRecord<FrooxEngine.Store.Record>(ownerId, recordId);
			if (cloudResult.IsError)
			{
				UniLog.Log("Error fetching record: " + cloudResult.State.ToString() + "\n" + cloudResult.Content);
				RunSynchronously(delegate
				{
					orb.WorldName = "Error!";
				});
				return;
			}
			FrooxEngine.Store.Record record = cloudResult.Entity;
			if (!record.IsPublic || !record.IsListed)
			{
				RunSynchronously(delegate
				{
					orb.WorldName = "Publishing...";
				});
				record.IsPublic = true;
				record.IsListed = true;
				RecordManager.RecordSaveResult obj = await base.Engine.RecordManager.SaveRecord(record);
				Task.Run(async delegate
				{
					await RecordPublisher.UpdateReferencedRecords(base.Engine, record);
				});
				await obj.task.Task;
			}
			Task<CloudResult<Submission>> task2 = base.Engine.Cloud.Groups.UpsertSubmission(GroupId.Value, ownerId, recordId);
			RunSynchronously(delegate
			{
				orb.WorldName = "Submitting...";
			});
			CloudResult<Submission> submitResult = await task2;
			if (submitResult.IsError)
			{
				UniLog.Log("Error submitting record: " + submitResult.State.ToString() + "\n" + submitResult.Content);
				RunSynchronously(delegate
				{
					if (submitResult.State == HttpStatusCode.Conflict)
					{
						orb.WorldName = "Already submitted";
					}
					else
					{
						orb.WorldName = $"<color=#f00>Error!</color>\n<size=25%>{submitResult.State}</size>";
					}
				});
			}
			else
			{
				RunSynchronously(delegate
				{
					orb.WorldName = "Submitted!";
					orb.Slot.Position_Field.TweenTo(orb.Slot.LocalPosition + Elements.Core.float3.Up * 0.5f, 1f, CurvePreset.Smoother);
				});
				RunInSeconds(5f, delegate
				{
					orb.RefreshInfo();
				});
			}
		}

