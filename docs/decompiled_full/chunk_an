	public class LocalModeVariableProxy<T> : IDisposable
	{
		private readonly string path;

		private readonly T defaultValue;

		private T currentScreenValue;

		private T currentVRValue;

		private Engine engine;

		private bool IsVRActive => engine.InputInterface.VR_Active;

		public T Value
		{
			get
			{
				if (!IsVRActive)
				{
					return currentScreenValue;
				}
				return currentVRValue;
			}
			set
			{
				Task.Run(async delegate
				{
					await db.WriteVariableAsync(path + (IsVRActive ? ".VR" : ".Screen"), value);
				});
			}
		}

		public string Path => path;

		protected LocalDB db => engine.LocalDB;

		public event Action<LocalModeVariableProxy<T>> OnChanged;

		public LocalModeVariableProxy(Engine engine, string path, T defaultValue, bool convertOldVariable = true)
		{
			LocalModeVariableProxy<T> localModeVariableProxy = this;
			this.engine = engine;
			this.path = path;
			this.defaultValue = defaultValue;
			Task.Run(async delegate
			{
				if (convertOldVariable)
				{
					LocalDB.VariableResult<T> variableResult = await localModeVariableProxy.db.TryReadVariableAsync<T>(path).ConfigureAwait(continueOnCapturedContext: false);
					if (variableResult.hasValue)
					{
						await localModeVariableProxy.db.WriteVariableAsync(path + ".VR", variableResult.value).ConfigureAwait(continueOnCapturedContext: false);
						await localModeVariableProxy.db.DeleteVariableAsync(path).ConfigureAwait(continueOnCapturedContext: false);
					}
				}
				localModeVariableProxy.db.RegisterVariableListener(path + ".Screen", localModeVariableProxy.OnScreenVariableChanged);
				localModeVariableProxy.db.RegisterVariableListener(path + ".VR", localModeVariableProxy.OnVRVariableChanged);
				engine.InputInterface.VRActiveChanged += localModeVariableProxy.InputInterface_VRActiveChanged;
				localModeVariableProxy.OnScreenVariableChanged();
				localModeVariableProxy.OnVRVariableChanged();
			});
		}

		private void InputInterface_VRActiveChanged(bool obj)
		{
			if (!EqualityComparer<T>.Default.Equals(currentScreenValue, currentVRValue))
			{
				this.OnChanged?.Invoke(this);
			}
		}

		private void OnScreenVariableChanged()
		{
			Task.Run(async delegate
			{
				currentScreenValue = await db.ReadVariableAsync(path + ".Screen", defaultValue).ConfigureAwait(continueOnCapturedContext: false);
				if (!IsVRActive)
				{
					this.OnChanged?.Invoke(this);
				}
			});
		}

		private void OnVRVariableChanged()
		{
			Task.Run(async delegate
			{
				currentVRValue = await db.ReadVariableAsync(path + ".VR", defaultValue).ConfigureAwait(continueOnCapturedContext: false);
				if (IsVRActive)
				{
					this.OnChanged?.Invoke(this);
				}
			});
		}

		public void Dispose()
		{
			db.UnregisterVariableListener(path + ".Screen", OnScreenVariableChanged);
			db.UnregisterVariableListener(path + ".VR", OnVRVariableChanged);
			engine = null;
		}

		public static implicit operator T(LocalModeVariableProxy<T> proxy)
		{
			return proxy.Value;
		}
	}
