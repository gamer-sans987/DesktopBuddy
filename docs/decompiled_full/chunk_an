				if (!string.IsNullOrEmpty(_username))
				{
					_usernameField.Target.TargetString = _username;
				}
				else
				{
					_usernameField.Target.TargetString = DefaultMigrationUsername;
				}
				if (!string.IsNullOrEmpty(_password))
				{
					_passwordField.Target.TargetString = _password;
				}
				ui.NestOut();
				ui.Style.MinHeight = 50f;
				ui.Button("General.Next".AsLocaleKey(), CheckLoginAndNext, State.MigrationType);
