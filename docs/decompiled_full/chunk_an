		private static void BuildHierarchyToString(IWorldElement element, StringBuilder builder)
		{
			StringBuilder stringBuilder = builder;
			StringBuilder stringBuilder2 = stringBuilder;
			StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(39, 4, stringBuilder);
			handler.AppendLiteral("Element: ");
