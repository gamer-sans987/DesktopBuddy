		}

		private void ComputeCompatibilityHash()
		{
			if (CompatibilityHash != null)
			{
				throw new InvalidOperationException("Compatibility hash has already been computed");
			}
			using ContinuousHasher<MD5CryptoServiceProvider> continuousHasher = new ContinuousHasher<MD5CryptoServiceProvider>();
			BinaryWriter binaryWriter = new BinaryWriter(continuousHasher);
			binaryWriter.Write(AssemblyName);
			foreach (Type type in _types)
			{
				HashType(type, binaryWriter);
			}
			foreach (Type dependencyType in _dependencyTypes)
			{
				HashType(dependencyType, binaryWriter);
			}
			binaryWriter.Flush();
			byte[] inArray = continuousHasher.FinalizeHash();
			CompatibilityHash = Convert.ToBase64String(inArray);
		}

		private void HashType(Type type, BinaryWriter hasher)
		{
			hasher.Write(type.GetNiceFullName());
			if (typeof(Worker).IsAssignableFrom(type))
			{
				HashWorker(type, hasher);
			}
			else if (typeof(Delegate).IsAssignableFrom(type))
			{
				HashDelegate(type, hasher);
			}
		}

		private void HashWorker(Type type, BinaryWriter hasher)
		{
			FieldInfo[] fields = type.GetFields(BindingFlags.DeclaredOnly | BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
			foreach (FieldInfo fieldInfo in fields)
			{
				if (fieldInfo.IsInitOnly)
				{
					hasher.Write(fieldInfo.FieldType.GetNiceFullName());
				}
			}
			MethodInfo[] methods = type.GetMethods(BindingFlags.DeclaredOnly | BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
			Array.Sort(methods, (MethodInfo a, MethodInfo b) => string.CompareOrdinal(a.Name, b.Name));
			MethodInfo[] array = methods;
			foreach (MethodInfo methodInfo in array)
			{
				if (methodInfo.GetCustomAttribute<SyncMethod>() != null)
				{
					hasher.Write(methodInfo.Name);
					HashMethodSignature(methodInfo, hasher);
				}
			}
		}

		private void HashDelegate(Type type, BinaryWriter hasher)
		{
			MethodInfo method = type.GetMethod("Invoke");
			if (method == null)
			{
				throw new ArgumentException("Type: " + type.FullName + " is not a delegate derived type!");
			}
			HashMethodSignature(method, hasher);
		}

		private void HashMethodSignature(MethodInfo info, BinaryWriter hasher)
		{
			hasher.Write(info.ReturnType.GetNiceFullName());
			ParameterInfo[] parameters = info.GetParameters();
			foreach (ParameterInfo parameterInfo in parameters)
			{
				hasher.Write(parameterInfo.ParameterType.GetNiceFullName());
				hasher.Write((int)parameterInfo.Attributes);
			}
		}

		public void ValidateTypes(HashSet<Type> invalidTypes, IEngineInitProgress progress = null)
		{
			foreach (Type type2 in _types)
			{
				progress?.SetSubphase("Validating " + type2.GetNiceFullName(), alwaysShow: true);
				Type baseType = type2.BaseType;
				while (baseType != null && baseType.IsDataModelType())
				{
					if (baseType.IsGenericType)
					{
						Type[] genericArguments = baseType.GetGenericArguments();
						foreach (Type type in genericArguments)
						{
							if (!type.IsGenericParameter && !GlobalTypeRegistry.IsSupportedType(type) && invalidTypes.Add(type))
							{
								UniLog.Warning("Unsupported type " + type.GetNiceName() + " used as generic argument on base class of " + type2.GetNiceName());
							}
						}
					}
					baseType = baseType.BaseType;
				}
				if (typeof(Worker).IsAssignableFrom(type2))
				{
					ValidateWorker(type2, invalidTypes);
				}
			}
		}

		private void ValidateWorker(Type type, HashSet<Type> invalidTypes)
		{
			FieldInfo[] fields = type.GetFields(BindingFlags.DeclaredOnly | BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
			foreach (FieldInfo fieldInfo in fields)
			{
				if (!fieldInfo.IsInitOnly || !fieldInfo.FieldType.IsGenericType)
				{
					continue;
				}
				Type genericTypeDefinition = fieldInfo.FieldType.GetGenericTypeDefinition();
				if (genericTypeDefinition == typeof(Sync<>) || genericTypeDefinition == typeof(SyncRef<>) || genericTypeDefinition == typeof(SyncDelegate<>) || genericTypeDefinition == typeof(SyncFieldList<>) || genericTypeDefinition == typeof(SyncRefList<>) || genericTypeDefinition == typeof(SyncDelegateList<>) || genericTypeDefinition == typeof(SyncArray<>) || genericTypeDefinition == typeof(Sync2DArray<>) || genericTypeDefinition == typeof(SyncLinear<>) || genericTypeDefinition == typeof(SyncCurve<>) || genericTypeDefinition == typeof(RawOutput<>))
				{
					Type type2 = fieldInfo.FieldType.GenericTypeArguments[0];
					if (!type2.IsGenericParameter && !GlobalTypeRegistry.IsSupportedType(type2) && invalidTypes.Add(type2))
					{
						UniLog.Warning($"Unsupported {genericTypeDefinition.GetNiceName()} type {type2}. IsDataModelType: {type2.IsDataModelType()}. On:{type.FullName}");
					}
				}
			}
		}
	}
