		public T FocusScreenOrAttach<T>(Action<T> initialize = null, Predicate<T> filter = null) where T : RadiantDashScreen, new()
		{
			T component;
			foreach (Slot child in Dash.ScreensContainer.Children)
			{
				component = child.GetComponent<T>();
				if (component != null && (filter == null || filter(component)))
				{
					Dash.CurrentScreen.Target = component;
					return component;
				}
			}
			component = Dash.AttachScreen<T>();
			initialize?.Invoke(component);
			Dash.CurrentScreen.Target = component;
			return component;
		}

