			ui.NestOut();
			ui.NestOut();
			ui.NestOut();
			return sessionPermissionController;
		}

		protected override void OnCommonUpdate()
		{
			ReadOnlyRef<PermissionSet> readOnlyRef = GetReference?.Invoke();
			World world = readOnlyRef?.World;
			if (world == null)
			{
				return;
			}
			if (_lastRolesVersion != world.Permissions.RolesVersion)
			{
				_rolesUI.NestInto(_rolesRoot);
				_rolesUI.Root.DestroyChildren();
				_rolesButtons.Clear();
				for (int i = 0; i < world.Permissions.Roles.Count; i++)
				{
					PermissionSet permissionSet = world.Permissions.Roles[i];
					Button target = _rolesUI.Button((LocaleString)permissionSet.RoleName.Value, new Elements.Core.colorX?(RadiantUI_Constants.TAB_INACTIVE_BACKGROUND_COLOR), SetRole, i);
					_rolesButtons.Add(target);
				}
				_rolesUI.NestOut();
				_lastRolesVersion = world.Permissions.RolesVersion;
			}
			bool flag = CanSetRole();
			bool flag2 = world.LocalUser.CanSeeOtherRoles();
			if (AssociatedUser != null && AssociatedUser.IsLocalUser)
			{
				flag2 = true;
			}
			for (int j = 0; j < _rolesButtons.Count; j++)
			{
				bool flag3 = world.Permissions.Roles[j] == readOnlyRef.Target && flag2;
				bool flag4 = flag;
				if (flag4 && !CanSetRoleTo(world.Permissions.Roles[j]))
				{
					flag4 = false;
				}
				_rolesButtons[j].Enabled = flag4 || flag3;
				_rolesButtons[j].SetColors(flag3 ? RadiantUI_Constants.TAB_ACTIVE_BACKGROUND_COLOR : RadiantUI_Constants.TAB_INACTIVE_BACKGROUND_COLOR);
			}
		}

		private bool CanSetRole()
		{
			ReadOnlyRef<PermissionSet> readOnlyRef = GetReference?.Invoke();
			World world = readOnlyRef?.World;
			if (world == null)
			{
				return false;
			}
			bool result = true;
			if (AssociatedUser != null && (AssociatedUser.IsHost || AssociatedUser.IsLocalUser))
			{
				result = false;
			}
			if (!world.LocalUser.CanAssignRoles())
			{
				result = false;
			}
			if (world.LocalUser.Role != null && readOnlyRef.Target != null && readOnlyRef.Target > world.LocalUser.Role)
			{
				result = false;
			}
			return result;
		}

		private bool CanSetRoleTo(PermissionSet targetRole)
		{
			World world = (GetReference?.Invoke())?.World;
			if (world == null)
			{
				return false;
			}
			if (world.LocalUser.Role != null && targetRole > world.LocalUser.Role)
			{
				return false;
			}
			return true;
		}

		[SyncMethod(typeof(Delegate), null)]
		private void SetRole(IButton button, ButtonEventData eventData, int roleIndex)
		{
			if (base.World != Userspace.UserspaceWorld)
			{
				return;
			}
			ReadOnlyRef<PermissionSet> reference = GetReference?.Invoke();
			World world = reference?.World;
			if (world == null)
			{
				return;
			}
			world.RunSynchronously(delegate
			{
				PermissionSet permissionSet = world.Permissions.Roles[roleIndex];
				if (CanSetRole() && CanSetRoleTo(permissionSet))
				{
					reference.ForceWrite(permissionSet);
					if (AssociatedUser?.UserID != null)
					{
						world.Permissions.AssignDefaultRole(AssociatedUser, reference.Target);
					}
				}
			});
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			_name = new SyncRef<Text>();
			_rolesButtons = new SyncRefList<Button>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => _name, 
				4 => _rolesButtons, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

