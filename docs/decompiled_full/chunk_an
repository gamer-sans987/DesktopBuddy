		private async Task<WorldOrb> SaveAsync(string ownerId, World parentWorld)
		{
			if (TargetWorld == null)
			{
				throw new Exception("TargetWorld hasn't been assigned!");
			}
			Orb.Target.WorldName = this.GetLocalized("World.Actions.Saving");
			saving.Value = true;
			interactive.Value = false;
			if (parentWorld != null)
			{
				TargetWorld.Parent = parentWorld;
			}
			string sourceRootOwnerID = null;
			FrooxEngine.Store.Record record = TargetWorld.CorrespondingRecord;
			if (record != null)
			{
				if (SaveType == SaveType.SaveCopy)
				{
					record = record.Clone<FrooxEngine.Store.Record>();
				}
				sourceRootOwnerID = record.OwnerId;
				record.OwnerId = ownerId ?? TargetWorld.GetCorrespondingOwnerId();
				record.RecordId = RecordHelper.GenerateRecordID();
				record.ClearRecordSpecificMetadata();
			}
			else
			{
				record = TargetWorld.CreateNewRecord(ownerId);
				if (SaveType == SaveType.SaveAs)
				{
					TargetWorld.CorrespondingRecord = record;
				}
			}
			if (ThumbnailUri != null)
			{
				record.ThumbnailURI = ThumbnailUri.ToString();
			}
			RecordOwnerTransferer transferer = new RecordOwnerTransferer(base.Engine, record.OwnerId, sourceRootOwnerID);
			FrooxEngine.Store.Record savedRecord = await Userspace.SaveWorld(TargetWorld, record, transferer);
			World worldOrbWorld = parentWorld ?? base.World;
			Elements.Core.float3 point = WorldManager.TransferPoint(base.Slot.GlobalPosition, base.World, worldOrbWorld);
			TaskCompletionSource<WorldOrb> worldOrbTask = new TaskCompletionSource<WorldOrb>();
			worldOrbWorld.RunSynchronously(delegate
			{
				Slot slot = worldOrbWorld.AddSlot("World Orb");
				slot.GlobalPosition = point;
				WorldOrb worldOrb = slot.AttachComponent<WorldOrb>();
				worldOrb.URL = savedRecord.GetUrl(worldOrbWorld.Engine.PlatformProfile);
				if (SaveType == SaveType.SaveAs)
				{
					TargetWorld.SourceLink = worldOrb;
				}
				worldOrbTask.TrySetResult(worldOrb);
			});
			base.Slot.Destroy();
			if (CloseOnSave)
			{
				Userspace.ExitWorld(TargetWorld);
			}
			return await worldOrbTask.Task;
		}

