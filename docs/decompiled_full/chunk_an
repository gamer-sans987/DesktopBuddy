		public bool IsCommitedResolutionValid => IsResolutionValid(CurrentCommitedResolution);

		public Elements.Core.int2 CurrentCommitedResolution
		{
			get
			{
				if (!Fullscreen.Value)
				{
					return CommitedWindowResolution.Value;
				}
				return CommitedFullscreenResolution.Value;
			}
			set
			{
				if (Fullscreen.Value)
				{
