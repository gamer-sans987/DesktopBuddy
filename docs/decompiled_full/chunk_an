			{
				return true;
			}
			return false;
		}

		public static FacetAnchorPoint GetSide(this FacetAnchorPoint point, Chirality side)
		{
			bool flag = side == Chirality.Left;
			switch (point)
			{
			case FacetAnchorPoint.LeftHandTop:
			case FacetAnchorPoint.RightHandTop:
				if (!flag)
				{
					return FacetAnchorPoint.RightHandTop;
				}
				return FacetAnchorPoint.LeftHandTop;
			case FacetAnchorPoint.LeftHandBottom:
			case FacetAnchorPoint.RightHandBottom:
				if (!flag)
				{
					return FacetAnchorPoint.RightHandBottom;
				}
				return FacetAnchorPoint.LeftHandBottom;
			case FacetAnchorPoint.LeftForearmTop:
			case FacetAnchorPoint.RightForearmTop:
				if (!flag)
				{
					return FacetAnchorPoint.RightForearmTop;
				}
				return FacetAnchorPoint.LeftForearmTop;
			case FacetAnchorPoint.LeftForearmBottom:
			case FacetAnchorPoint.RightForearmBottom:
				if (!flag)
				{
					return FacetAnchorPoint.RightForearmBottom;
				}
				return FacetAnchorPoint.LeftForearmBottom;
			default:
				throw new InvalidOperationException("Cannot get the side for anchor point: " + point);
			}
		}
