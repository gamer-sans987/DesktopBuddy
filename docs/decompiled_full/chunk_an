		protected override void OnAwake()
		{
			if (!base.World.IsAuthority)
			{
				return;
			}
			base.Engine.WorldManager.WorldAdded += OnWorldAdded;
			base.Engine.WorldManager.WorldRemoved += OnWorldRemoved;
			base.Engine.WorldManager.WorldFocused += OnWorldFocused;
			foreach (World world in base.Engine.WorldManager.Worlds)
			{
				if (world.Focus != FrooxEngine.World.WorldFocus.Overlay && world.Focus != FrooxEngine.World.WorldFocus.PrivateOverlay)
				{
					OnWorldAdded(world);
				}
			}
			StartCoroutine(Update());
		}

		protected override void OnCommonUpdate()
		{
			if (!base.World.IsAuthority)
			{
				return;
			}
			_showLerp = MathX.Progress01(_showLerp, base.Time.Delta * 2f, Show);
			base.Slot.LocalScale = MathX.Lerp(Elements.Core.float3.One * 0.001f, Elements.Core.float3.One, MathX.SmootherStep(_showLerp));
			_visualRoot.Target.ActiveSelf = _showLerp > 0f;
			if (_showLerp == 0f)
			{
				if (_slider.Target.IsGrabbed)
				{
					_slider.Target.Release(_slider.Target.Grabber);
				}
				return;
			}
			MultiSegmentMesh target = _linesMesh.Target;
			target.Sides.Value = 6;
			target.HighPriorityIntegration.Value = true;
			target.Segments.EnsureExactCount(_orbs.Count);
			int num = 0;
			foreach (KeyValuePair<World, OrbInfo> orb2 in _orbs)
			{
				WorldOrb orb = orb2.Value.orb;
				World key = orb2.Key;
				MultiSegmentMesh.SegmentInfo segmentInfo = target.Segments[num++];
				if (orb.IsDestroyed)
				{
					continue;
				}
				float num2 = 0.018333334f;
				Elements.Core.float3 a = _visualRoot.Target.GlobalPointToLocal(orb2.Value.root.GlobalPosition);
				Elements.Core.float3 a2;
				float num3;
				if (key.Parent != null && _orbs.TryGetValue(key.Parent, out OrbInfo value))
				{
					a2 = _visualRoot.Target.GlobalPointToLocal(value.root.GlobalPosition);
					num3 = num2;
				}
				else
				{
					a2 = Elements.Core.float3.Zero;
					num3 = 0.027500002f;
				}
				segmentInfo.PointA.Value = a + (a2 - a).Normalized * num2;
				segmentInfo.PointB.Value = a2 + (a - a2).Normalized * num3;
				segmentInfo.Radius.Value = 0.0025f;
				orb2.Value.root.GlobalRotation = Elements.Core.floatQ.Identity;
				if (key.Parent != orb2.Value.lastParent)
				{
					if (key.Parent == null)
					{
						orb2.Value.root.Parent = _visualRoot.Target;
						orb2.Value.lastParent = null;
					}
					else if (_orbs.TryGetValue(key.Parent, out value))
					{
						orb2.Value.root.Parent = value.root;
						orb2.Value.lastParent = key.Parent;
					}
				}
			}
		}

		private IEnumerator<Context> Update()
		{
			while (true)
			{
				yield return Context.WaitForSeconds(2.0);
				if (!base.Slot.IsActive)
				{
					yield return Context.WaitForNextUpdate();
				}
				foreach (KeyValuePair<World, OrbInfo> orb2 in _orbs)
				{
					WorldOrb orb = orb2.Value.orb;
					World key = orb2.Key;
					if (!orb.IsDestroyed)
					{
						orb.WorldName = ((key.State == FrooxEngine.World.WorldState.Initializing) ? "Loading..." : key.Name);
						orb.ActiveUsers.Value = key.UserCount;
						orb.SetThumbnail(Userspace.GetThumbnailData(key)?.LocalThumbnail);
					}
				}
			}
		}

		private void OnWorldAdded(World world)
		{
			RunSynchronously(delegate
			{
				OrbInfo value;
				Slot slot = ((world.Parent == null || !_orbs.TryGetValue(world.Parent, out value)) ? _visualRoot.Target : value.root);
				Slot slot2 = slot.AddSlot("Item");
				Slot slot3 = slot2.AddSlot("Orb");
				slot3.PersistentSelf = false;
				WorldOrb worldOrb = slot3.AttachComponent<WorldOrb>();
				slot3.GetComponent<Grabbable>().Destroy();
				slot3.Scale_Field.TweenTo(Elements.Core.float3.One * (1f / 3f), 0.5f);
				worldOrb.ActiveUsers.Value = 1;
				worldOrb.WorldName = world.Name;
				worldOrb.LocalOpenedWorld = world;
				RepulsionTreeItem repulsionTreeItem = slot2.AttachComponent<RepulsionTreeItem>();
				repulsionTreeItem.Force.Value = 0.05f;
				repulsionTreeItem.Radius.Value = 0.075f;
				worldOrb.Touched.Target = WorldOrbTouched;
				if (world != Userspace.LocalHome)
				{
					worldOrb.LongPressTriggered.Target = WorldOrbLongPressed;
				}
				worldOrb.LongPressIndicatorColor.Value = new Elements.Core.colorX(2f, 0.3f, 0.3f);
				worldOrb.LongPressTime.Value = 2f;
				_orbs.Add(world, new OrbInfo
				{
					orb = worldOrb,
					root = slot2,
					lastParent = world.Parent
				});
			});
		}

		private void OnWorldRemoved(World world)
		{
			RunSynchronously(delegate
			{
				RemoveWorldOrb(world);
			});
		}

		private void RemoveWorldOrb(World world)
		{
			if (!_orbs.TryGetValue(world, out OrbInfo value))
			{
				return;
			}
			for (int i = 0; i < value.root.ChildrenCount; i++)
			{
				Slot slot = value.root[i];
				if (slot.GetComponent<RepulsionTreeItem>() != null)
				{
					slot.Parent = _visualRoot.Target;
				}
			}
			_orbs.Remove(world);
			if (!value.orb.IsDestroyed)
			{
				value.orb.Slot.Scale_Field.TweenTo(Elements.Core.float3.Zero, 0.25f, CurvePreset.Sine, value.root.Destroy);
