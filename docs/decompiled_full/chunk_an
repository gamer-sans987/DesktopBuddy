		[SyncMethod(typeof(Delegate), null)]
		private void CreateNew(IButton button, ButtonEventData eventData)
		{
			if (Disable || !CanInteract(base.LocalUser))
			{
				return;
			}
			Grabber grabber = base.World.GetLocalUserGrabberWithItems(eventData.source.Slot);
			if (grabber != null)
			{
				Elements.Core.float3 point = WorldManager.TransferPoint(base.Slot.GlobalPosition + base.Slot.Backward * 0.1f, base.World, grabber.World);
				Elements.Core.floatQ orientation = WorldManager.TransferRotation(base.Slot.GlobalRotation, base.World, grabber.World);
				grabber.World.RunSynchronously(delegate
				{
					if (grabber.HolderSlot.ChildrenCount == 1)
					{
						Slot slot2 = grabber.World.AddSlot("Export Dialog");
						slot2.GlobalPosition = point;
						slot2.GlobalRotation = orientation;
						Slot slot3 = grabber.HolderSlot[0];
						ReferenceProxy componentInChildren = slot3.GetComponentInChildren((ReferenceProxy r) => r.Reference.Target is Slot);
						if (componentInChildren != null)
						{
							slot3 = (Slot)componentInChildren.Reference.Target;
						}
						if (slot3.ForeachComponentInChildren((IItemPermissions p) => p.CanSave) && grabber.World.CanSaveItems())
						{
							ExportDialog exportDialog = slot2.AttachComponent<ExportDialog>();
							exportDialog.ExportFinished = delegate
							{
								StartTask(async delegate
								{
									await default(ToWorld);
									await Refresh(SlideSwapRegion.Slide.None);
								});
							};
							List<IExportable> componentsInChildren = slot3.GetComponentsInChildren<IExportable>();
							if (componentsInChildren.Count == 0)
							{
								ModelExportable modelExportable = slot2.AttachComponent<ModelExportable>();
								modelExportable.Root.Target = slot3;
								componentsInChildren.Add(modelExportable);
							}
							else
							{
								for (int num = 0; num < componentsInChildren.Count; num++)
								{
									componentsInChildren[num] = (IExportable)slot2.DuplicateComponent((Component)componentsInChildren[num]);
								}
							}
							if (!componentsInChildren.Any((IExportable e) => e is PackageExportable))
							{
								PackageExportable packageExportable = slot2.AttachComponent<PackageExportable>();
								packageExportable.Root.Target = slot3;
								componentsInChildren.Insert(0, packageExportable);
							}
							KeyCounter<Type> keyCounter = new KeyCounter<Type>();
							foreach (IExportable item in componentsInChildren)
							{
								_ = item;
								keyCounter.Increment(exportDialog.GetType());
							}
							foreach (KeyValuePair<Type, int> group in keyCounter)
							{
								if (group.Value > 1)
								{
									componentsInChildren.RemoveAll((IExportable e) => e.GetType() == group.Key);
								}
							}
							exportDialog.Setup(CurrentPath, componentsInChildren.ToArray());
						}
					}
				}, immediatellyIfPossible: true);
			}
			else
			{
				Slot slot = base.LocalUserSpace.AddSlot("Directory Create Dialog");
				BrowserCreateDirectoryDialog browserCreateDirectoryDialog = slot.AttachComponent<BrowserCreateDirectoryDialog>();
				slot.PositionInFrontOfUser(Elements.Core.float3.Backward, null, 0.6f);
				browserCreateDirectoryDialog.Setup(this, CreateDirectory);
			}
		}

