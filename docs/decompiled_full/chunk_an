		private void SetCloudData(SkyFrost.Base.User data)
		{
			CloudData = data;
			if (data.Tags != null)
			{
				if (data.Tags.Contains(UserTags.Team))
				{
					AddBadge("team");
				}
				if (data.Tags.Contains(UserTags.Moderator))
				{
					AddBadge("moderator");
				}
				if (data.Tags.Contains(UserTags.Mentor))
				{
					AddBadge("mentor");
				}
				if (data.Tags.Contains(UserTags.Translator))
				{
					AddBadge("translator");
				}
				if (data.Tags.Contains(UserTags.HearingImpaired))
				{
					AddBadge("hearing_impaired");
				}
				if (data.Tags.Contains(UserTags.VisuallyImpaired))
				{
					AddBadge("visually_impaired");
				}
				if (data.Tags.Contains(UserTags.ColorBlind))
				{
					AddBadge("color_vision_deficiency");
				}
				if (data.Tags.Contains(UserTags.Mute))
				{
					AddBadge("speech_impaired");
				}
				foreach (string tag in data.Tags)
				{
					bool pointFiltering;
					string customBadge = UserTags.GetCustomBadge(tag, out pointFiltering);
					if (customBadge != null)
					{
						AddBadge(base.Cloud.Assets.GenerateURL(customBadge), "custom_" + tag, pointFiltering);
					}
				}
			}
			if (data != null)
			{
				DateTime dateTime = data.RegistrationDate.ToLocalTime();
				DateTime now = DateTime.Now;
				if (dateTime.Year != now.Year && dateTime.Day == now.Day && dateTime.Month == now.Month)
				{
					AddBadge("baguette");
				}
			}
			if (data != null && data.HasSupported)
			{
				AddBadge("supporter");
			}
			UpdateName();
		}

		private void AddBadge(string spriteName)
		{
			_cachedUserName = _cachedUserName + "<sprite name=\"" + spriteName + "\">";
		}

		private void AddBadge(Uri badge, string key, bool pointFiltering = false)
		{
			DynamicSpriteFont dynamicSpriteFont = GetBadgeFontCollection().FontSets[1] as DynamicSpriteFont;
			if (!dynamicSpriteFont.HasSprite(key))
			{
				dynamicSpriteFont.AddSprite(key, badge, 1.25f);
			}
			_cachedUserName = _cachedUserName + "<sprite name=\"" + key + "\">";
		}

		private void UpdateName()
		{
			string text = "<noparse>" + _cachedUserName + "</noparse>";
			if (TargetUser.IsHost)
			{
				text = "<b>" + text + "</b>";
			}
			if (!TargetUser.IsPresentInWorld)
			{
				text = "<i>" + text + "</i>";
			}
			_name.Target.Content.Value = text;
			_name.Target.Font.Target = GetBadgeFontCollection();
			_lastIsPresent = TargetUser.IsPresentInWorld;
		}

		protected override void OnCommonUpdate()
		{
			if (TargetUser.IsPresentInWorld != _lastIsPresent)
			{
				UpdateName();
			}
			float localVolume = TargetUser.LocalVolume;
			if (localVolume != _lastUserVolume)
			{
				_slider.Target.Value.Value = localVolume;
				_lastUserVolume = localVolume;
			}
			else if (_slider.Target.Value.Value != localVolume)
			{
				TargetUser.LocalVolume = _slider.Target.Value.Value;
				_lastUserVolume = _slider.Target.Value.Value;
			}
			User targetUser = TargetUser;
			bool valueOrDefault = targetUser.World.LocalUser.Root?.GetRegisteredComponent<LocomotionController>()?.IsSupressed == true;
			_mute.Target.Enabled = !targetUser.IsLocalUser;
			_jump.Target.Enabled = !targetUser.IsLocalUser && !valueOrDefault && targetUser.CanJumpToUser();
			_respawn.Target.Enabled = targetUser.IsLocalUser || targetUser.CanRespawn();
			_kick.Target.Enabled = !targetUser.IsHost && targetUser.World.LocalUser.CanKick();
			_silence.Target.Enabled = !targetUser.IsHost && targetUser.World.LocalUser.CanSilence() && !targetUser.IsLocalUser;
			_ban.Target.Enabled = !targetUser.IsHost && targetUser.World.LocalUser.CanBan() && !targetUser.IsLocalUser;
			if (!targetUser.IsHost && targetUser.World.LocalUser.CanSilence() && !targetUser.IsLocalUser)
			{
				_silence.Target.SetColors(targetUser.IsSilenced ? RadiantUI_Constants.HIGHLIGHT_COLOR : RadiantUI_Constants.BUTTON_COLOR);
			}
		}

