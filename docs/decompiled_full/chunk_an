		protected override void OnCommonUpdate()
		{
			World focusedWorld = base.Engine.WorldManager.FocusedWorld;
			if (_inviteButton.Target != null && focusedWorld != null)
			{
				_inviteButton.Target.Enabled = !focusedWorld.UnsafeMode && (focusedWorld.IsAuthority || (focusedWorld.Configuration.AccessLevel.Value != SessionAccessLevel.Private && focusedWorld.Configuration.AccessLevel.Value != SessionAccessLevel.LAN));
				bool flag = focusedWorld.IsAuthority && focusedWorld.IsUserAllowed(SelectedContactId);
				_inviteButton.Target.Label.LocaleContent = (flag ? "Contacts.RevokeInvite".AsLocaleKey() : "Contacts.Invite".AsLocaleKey());
			}
			if (!_searchBar.Target.Editor.Target.IsEditing && string.IsNullOrWhiteSpace(_searchBar.Target.TargetString))
			{
				_searchBar.Target.TargetString = null;
			}
			if (!_sendMessageTextField.Target.Editor.Target.IsEditing && string.IsNullOrWhiteSpace(_sendMessageTextField.Target.TargetString))
			{
				_sendMessageTextField.Target.TargetString = null;
			}
			UpdateBanButtons();
			if (globalSearchTimer > 0.0)
			{
				globalSearchTimer -= base.Time.Delta;
				if (globalSearchTimer <= 0.0)
				{
					string searchTerm = _searchBar.Target.Editor.Target.TargetString;
					if (!string.IsNullOrWhiteSpace(searchTerm))
					{
						searchTerm = searchTerm.Trim().ToLower();
						int searchRequestId = ++_lastSearchRequestId;
						StartTask(async delegate
						{
							CloudResult<List<SkyFrost.Base.User>> cloudResult = await base.Engine.Cloud.Users.GetUsers(searchTerm);
							string text = _searchBar.Target.Editor.Target.TargetString.Trim().ToLower();
							if (cloudResult.IsOK && text == searchTerm && _lastSearchRequestId == searchRequestId)
							{
								SetSearchResults(cloudResult.Entity);
							}
						});
					}
				}
			}
			if (!sortList)
			{
				return;
			}
			_listRoot.Target.SortChildren(delegate(Slot a, Slot b)
			{
				ContactItem component = a.GetComponent<ContactItem>();
				ContactItem component2 = b.GetComponent<ContactItem>();
				Contact contact = component?.Contact;
				Contact contact2 = component2?.Contact;
				if (contact != null && contact2 == null)
				{
					return -1;
				}
				if (contact == null && contact2 != null)
				{
					return 1;
				}
				if (contact == null && contact2 == null)
				{
					return 0;
				}
				int num = -component.HasMessages.CompareTo(component2.HasMessages);
				if (num != 0)
				{
					return num;
				}
				int orderNumber = GetOrderNumber(component);
				int orderNumber2 = GetOrderNumber(component2);
				if (orderNumber != orderNumber2)
				{
					return orderNumber.CompareTo(orderNumber2);
				}
				int num2 = -contact.LatestMessageTime.CompareTo(contact2.LatestMessageTime);
				return (num2 != 0) ? num2 : contact.ContactUsername.CompareTo(contact2.ContactUsername);
			});
			sortList = false;
		}

		private static int GetOrderNumber(ContactItem item)
		{
			if (item.Contact.IsPartiallyMigrated)
			{
				return 10;
			}
			if (item.Contact.ContactStatus == ContactStatus.Requested)
			{
				return 2;
			}
			return (item.Data?.CurrentStatus.OnlineStatus).GetValueOrDefault() switch
			{
				OnlineStatus.Sociable => 0, 
				OnlineStatus.Online => 1, 
				OnlineStatus.Away => 3, 
				OnlineStatus.Busy => 4, 
				_ => 5, 
			};
		}

