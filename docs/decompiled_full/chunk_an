		public readonly Sync<TextureFilterMode> DefaultFilterMode;

		[SettingProperty(null, null, null, false, 0L, null, "UseAnisotropicLevel", false)]
		[Range(0f, 16f, "F0")]
		public readonly Sync<int> AnisotropicLevel;

		[NonPersistent]
		public readonly Sync<bool> UseAnisotropicLevel;

		/// <remarks>Used via Reflection, See: <see cref="M:FrooxEngine.SettingManager.RecomputeSettings" /></remarks>
		public static List<SettingSwitchValue> GetDefaultSettingSwitches(World world)
		{
			DeviceIDSettingSwitchSource deviceIDSettingSwitchSource = SettingSwitchSource.EnsureSettingSwitchSource<DeviceIDSettingSwitchSource>(world);
			return new List<SettingSwitchValue> { deviceIDSettingSwitchSource.CurrentValue };
		}

		internal override bool IsValidSetOfSwitches(List<SettingSwitchValue> switches)
		{
			return switches.Any((SettingSwitchValue s) => s.source is DeviceIDSettingSwitchSource);
		}

		public int? GetMaxSize(int textureSize)
		{
			if (TextureSizeRatio.Value == FrooxEngine.TextureSizeRatio.FullSize && TextureSizeLimit.Value == FrooxEngine.TextureSizeLimit.Unlimited)
			{
				return null;
			}
			if (textureSize < MinimumTextureSize.Value)
			{
				return null;
			}
			switch (TextureSizeRatio.Value)
			{
			case FrooxEngine.TextureSizeRatio.HalfSize:
				textureSize >>= 1;
				break;
			case FrooxEngine.TextureSizeRatio.QuarterSize:
				textureSize >>= 2;
				break;
			case FrooxEngine.TextureSizeRatio.EightSize:
				textureSize >>= 4;
				break;
			default:
				throw new ArgumentException("Invalid texture size ratio: " + TextureSizeRatio.Value);
			case FrooxEngine.TextureSizeRatio.FullSize:
				break;
			}
			switch (TextureSizeLimit.Value)
			{
			case FrooxEngine.TextureSizeLimit.Tex8K:
				textureSize = MathX.Min(textureSize, 8192);
				break;
			case FrooxEngine.TextureSizeLimit.Tex4K:
				textureSize = MathX.Min(textureSize, 4096);
				break;
			case FrooxEngine.TextureSizeLimit.Tex2K:
				textureSize = MathX.Min(textureSize, 2048);
				break;
			case FrooxEngine.TextureSizeLimit.Tex1K:
				textureSize = MathX.Min(textureSize, 1024);
				break;
			case FrooxEngine.TextureSizeLimit.Tex512:
				textureSize = MathX.Min(textureSize, 512);
				break;
			case FrooxEngine.TextureSizeLimit.Tex256:
				textureSize = MathX.Min(textureSize, 256);
				break;
			case FrooxEngine.TextureSizeLimit.Tex128:
				textureSize = MathX.Min(textureSize, 128);
				break;
			}
			textureSize = MathX.Max(textureSize, 128);
			return textureSize;
		}

		[SettingProperty(null, null, null, false, 0L, null, null, false)]
		[SyncMethod(typeof(Action), new string[] { })]
		public void ReloadAllTextures()
		{
			base.Engine.AssetManager.ForceUpdateAllTextures();
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			ResetToDefault();
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			double num = (double)base.Engine.SystemInfo.VRAMBytes / 1073741824.0;
			if (num <= 2.0)
			{
				TextureSizeRatio.Value = FrooxEngine.TextureSizeRatio.QuarterSize;
				TextureSizeLimit.Value = FrooxEngine.TextureSizeLimit.Tex2K;
			}
			else if (num <= 4.0)
			{
				TextureSizeRatio.Value = FrooxEngine.TextureSizeRatio.HalfSize;
				TextureSizeLimit.Value = FrooxEngine.TextureSizeLimit.Tex2K;
				MinimumTextureSize.Value = 256;
			}
			else if (num <= 6.0)
			{
				TextureSizeRatio.Value = FrooxEngine.TextureSizeRatio.HalfSize;
				TextureSizeLimit.Value = FrooxEngine.TextureSizeLimit.Tex4K;
				MinimumTextureSize.Value = 512;
			}
		}

		public override void ResetToDefault()
		{
			TextureSizeRatio.Value = FrooxEngine.TextureSizeRatio.FullSize;
			TextureSizeLimit.Value = FrooxEngine.TextureSizeLimit.Unlimited;
			DefaultFilterMode.Value = TextureFilterMode.Anisotropic;
			AnisotropicLevel.Value = 16;
			MinimumTextureSize.Value = 0;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			UseAnisotropicLevel.Value = DefaultFilterMode.Value == TextureFilterMode.Anisotropic;
		}

