				UserMessages messages = base.Engine.Cloud.Messages.GetUserMessages(SelectedContact.ContactUserId);
				if (grabber.LocalExternallyHeldItem != null)
				{
					StartTask(async delegate
					{
						await SendObjectMessage(messages, grabber.LocalExternallyHeldItem, saveRoot: true);
					});
				}
				else
				{
					StartTask(async delegate
					{
						await SendObjectMessage(messages, grabber.HolderSlot, saveRoot: false);
					});
				}
			}
			else
			{
				TrySendMessage();
			}
		}

