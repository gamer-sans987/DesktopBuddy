	public class SessionThumbnailData
	{
		private static int[] CAPTURE_INTERVALS_SECONDS = new int[5] { 5, 15, 30, 60, 120 };

		private static int[] HEADLESS_INTERVAL_SECONDS = new int[3] { 15, 60, 120 };

		private string _lastUpload;

		private bool _isUploading;

		private bool _uploadPublic;

		private int _captureIntervalIndex;

		private CancellationTokenSource _uploadCancellation;

		public Engine Engine { get; private set; }

		public World World { get; private set; }

		public Uri LocalThumbnail { get; private set; }

		public string LocalThumbnailPath { get; private set; }

		public SkyFrost.Base.ThumbnailInfo PublicThumbnail { get; private set; }

		public Uri PublicThumbnailUrl { get; private set; }

		public DateTime CaptureTime { get; private set; }

		public DateTime UploadTime { get; private set; }

		public DateTime LastExtendRequestTime { get; private set; }

		public bool UploadPublic
		{
			get
			{
				if (_uploadPublic)
				{
					return !string.IsNullOrEmpty(LocalThumbnailPath);
				}
				return false;
			}
			set
			{
				if (_uploadPublic != value)
				{
					_uploadPublic = value;
					if (_uploadPublic && !string.IsNullOrEmpty(LocalThumbnailPath) && LocalThumbnailPath != _lastUpload && !_isUploading)
					{
						StartUpload();
					}
				}
			}
		}

		private int[] CaptureIntervals
		{
			get
			{
				if (Engine.InputInterface.HeadOutputDevice != HeadOutputDevice.Headless)
				{
					return CAPTURE_INTERVALS_SECONDS;
				}
				return HEADLESS_INTERVAL_SECONDS;
			}
		}

		public int CurrentCaptureInterval => CaptureIntervals[_captureIntervalIndex];

		public event Action<SessionThumbnailData> ThumbnailUpdated;

		public SessionThumbnailData(World world)
		{
			Engine = world.Engine;
			World = world;
			CaptureTime = DateTime.UtcNow;
		}

		public bool ShouldCapture()
		{
			if (_isUploading)
			{
				return false;
			}
			return (DateTime.UtcNow - CaptureTime).TotalSeconds >= (double)CurrentCaptureInterval;
		}

		public void UpdateCaptureTime()
		{
			CaptureTime = DateTime.UtcNow;
		}

		public void InvalidateThumbnail()
		{
			LocalThumbnail = null;
			LocalThumbnailPath = null;
			PublicThumbnailUrl = null;
			PublicThumbnail = null;
			CaptureTime = default(DateTime);
			_uploadCancellation?.Cancel();
			_uploadCancellation = null;
		}

		public void UpdateLocalThumbnail(Uri url, string filePath)
		{
			LocalThumbnail = url;
			LocalThumbnailPath = filePath;
			CaptureTime = DateTime.UtcNow;
			this.ThumbnailUpdated?.Invoke(this);
			if (_captureIntervalIndex < CaptureIntervals.Length - 1)
			{
				_captureIntervalIndex++;
			}
			if (UploadPublic && File.Exists(filePath))
			{
				StartUpload();
			}
			else if (url != null && (url.Scheme == "http" || url.Scheme == "https"))
			{
				UpdatePublicThumbnailURL(url);
			}
		}

		private void StartUpload()
		{
			if (_isUploading)
			{
				throw new InvalidOperationException("Cannot start thumbnail upload when already uploading!");
			}
			if (_captureIntervalIndex != 1)
			{
				_isUploading = true;
				_uploadCancellation = new CancellationTokenSource();
				CancellationToken token = _uploadCancellation.Token;
				Task.Run(async delegate
				{
					await Upload(token);
				});
			}
		}

		private async Task Upload(CancellationToken cancellationToken)
		{
			_ = 2;
			try
			{
				int uploadAttempts = 0;
				CloudResult<SkyFrost.Base.ThumbnailInfo> result;
				do
				{
					if (uploadAttempts > 0)
					{
						await Task.Delay(TimeSpan.FromSeconds(10L), cancellationToken).ConfigureAwait(continueOnCapturedContext: false);
					}
					if (cancellationToken.IsCancellationRequested)
					{
						return;
					}
					_lastUpload = LocalThumbnailPath;
					result = await Engine.Cloud.Assets.UploadThumbnail(LocalThumbnailPath, World?.SessionId ?? "unknown").ConfigureAwait(continueOnCapturedContext: false);
				}
				while (!result.IsOK && uploadAttempts++ < 3);
				if (cancellationToken.IsCancellationRequested)
				{
					return;
				}
				if (result.IsOK)
				{
					Uri thumbnailUrl = Engine.Cloud.Assets.ThumbnailToHttp(result.Entity);
					await Engine.LocalDB.StoreCacheRecordAsync(thumbnailUrl, LocalThumbnailPath).ConfigureAwait(continueOnCapturedContext: false);
					if (!cancellationToken.IsCancellationRequested)
					{
						UploadTime = DateTime.UtcNow;
						PublicThumbnail = result.Entity;
						UpdatePublicThumbnailURL(thumbnailUrl);
					}
				}
				else
				{
					UniLog.Warning("Error uploading thumbnail " + LocalThumbnailPath + ": " + result.State.ToString() + " - " + result.Content);
				}
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception uploading thumbnail:\n" + ex);
			}
			finally
			{
				if (!cancellationToken.IsCancellationRequested)
				{
					_isUploading = false;
					_uploadCancellation?.Dispose();
					_uploadCancellation = null;
				}
			}
		}

