		private bool TrySendMessage()
		{
			string targetString = _sendMessageTextField.Target.TargetString;
			bool result = false;
			if (!string.IsNullOrWhiteSpace(targetString))
			{
				UserMessages userMessages = base.Engine.Cloud.Messages.GetUserMessages(SelectedContact.ContactUserId);
				SkyFrost.Base.Message textMessage = userMessages.CreateTextMessage(targetString);
				StartTask(async delegate
				{
					await SendMessage(userMessages, textMessage);
				});
				result = true;
			}
			_sendMessageTextField.Target.TargetString = "";
			return result;
		}

		private async Task SendObjectMessage(UserMessages userMessages, Slot root, bool saveRoot)
		{
			if (!root.World.CanSaveItems())
			{
				NotificationMessage.SpawnTextMessage("You're not allowed to save items in this world.", Elements.Core.colorX.Red);
				return;
			}
			ObjectMessageData messageData = await userMessages.CreateObjectMessage(root, saveRoot);
			if (messageData != null)
			{
				FrooxEngine.UIX.Image bg = AddSendingMessage(messageData.message);
				await messageData.uploadTask;
				UpdateSentMessage(bg, await userMessages.SendMessage(messageData.message));
			}
		}

		private async Task SendVoiceMessage(UserMessages userMessages, AudioX clip)
		{
			ObjectMessageData messageData = await userMessages.CreateSoundMessage(base.Engine, clip);
			if (messageData != null)
			{
				FrooxEngine.UIX.Image bg = AddSendingMessage(messageData.message);
				await messageData.uploadTask;
				UpdateSentMessage(bg, await userMessages.SendMessage(messageData.message));
			}
		}

		private async Task SendMessage(UserMessages userMessages, SkyFrost.Base.Message message)
		{
			FrooxEngine.UIX.Image bg = AddSendingMessage(message);
