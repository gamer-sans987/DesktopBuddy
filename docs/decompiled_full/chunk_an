		public Entry FindMatchingEntry(UserFingerprint fingerprint)
		{
			lock (_quickAccessLock)
			{
				if (fingerprint.HasUserId && _byUserId.TryGetValue(fingerprint.UserId, out Entry value))
				{
					return value;
				}
				Entry entry = null;
				foreach (Entry item in EnumerateAlternateEntries(fingerprint))
				{
					entry = GetBestEntry(entry, item, fingerprint.HasUserId);
				}
				return entry;
			}
		}

		public bool HasMatch(UserFingerprint fingerprint, Predicate<Entry> check)
		{
			lock (_quickAccessLock)
			{
				if (fingerprint.HasUserId && _byUserId.TryGetValue(fingerprint.UserId, out Entry value) && check(value))
				{
					return true;
				}
				foreach (Entry item in EnumerateAlternateEntries(fingerprint))
				{
					if (check(item))
					{
						return true;
					}
				}
				return false;
			}
		}

		private IEnumerable<Entry> EnumerateAlternateEntries(UserFingerprint fingerprint)
		{
			if (fingerprint.HasExtraIds)
			{
				foreach (KeyValuePair<string, string> extraId in fingerprint.ExtraIds)
				{
					if (!_byExtraId.TryGetValue(extraId.Key, out DictionaryList<string, Entry> value))
					{
						continue;
					}
					List<Entry> list = value.TryGetList(extraId.Value);
					if (list == null)
					{
						continue;
					}
					foreach (Entry item in list)
					{
						yield return item;
					}
				}
			}
			if (string.IsNullOrEmpty(fingerprint.MachineId))
			{
				yield break;
			}
			List<Entry> list2 = _byMachineId.TryGetList(fingerprint.MachineId);
			if (list2 == null)
			{
				yield break;
			}
			foreach (Entry item2 in list2)
			{
				yield return item2;
			}
		}

		private static Entry GetBestEntry(Entry current, Entry candidate, bool preferWithoutUserID)
		{
			if (current == null)
			{
				return candidate;
			}
			if (preferWithoutUserID)
			{
				if (string.IsNullOrEmpty(candidate.UserId.Value) && !string.IsNullOrEmpty(current.UserId.Value))
				{
					return candidate;
				}
				if (!string.IsNullOrEmpty(candidate.UserId.Value))
				{
					return current;
				}
			}
			int num = current.MachineIDs.Count + current.ExtraIds.Count;
			if (candidate.MachineIDs.Count + candidate.ExtraIds.Count > num)
			{
				return candidate;
			}
			return current;
		}

