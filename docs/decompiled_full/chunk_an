				});
			}
			else
			{
				justAddedStreams.Add(stream);
			}
			try
			{
				this.StreamAdded?.Invoke(stream);
			}
			catch (Exception exception)
			{
				base.Debug.Error("Exception running StreamAdded: " + DebugManager.PreprocessException(exception));
			}
		}

