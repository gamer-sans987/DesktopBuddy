		public void InviteContact(string contactId)
		{
			World targetWorld = base.Engine.WorldManager.FocusedWorld;
			if (targetWorld.IsAuthority && targetWorld.IsUserAllowed(contactId))
			{
				targetWorld.RemoveAllowedUser(contactId);
				return;
			}
			UserMessages messages = base.Engine.Cloud.Messages.GetUserMessages(contactId);
			StartTask(async delegate
			{
				SkyFrost.Base.Message message = await messages.CreateInviteMessage(targetWorld);
				await SendMessage(messages, message);
			});
		}

