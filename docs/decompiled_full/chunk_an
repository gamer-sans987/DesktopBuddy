		private static Elements.Core.colorX MixColor(Elements.Core.colorX color)
		{
			return MathX.Lerp(in color, Elements.Core.colorX.White, 0.5f);
		}

		private bool IsValidPath(string path)
		{
			if (FrooxEngine.Engine.Config?.PathWhitelist == null)
			{
				return true;
			}
			path = path ?? "";
			foreach (string item in FrooxEngine.Engine.Config.PathWhitelist)
			{
				if (path.StartsWith(item))
				{
					return true;
				}
			}
			return false;
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			_user.Target = base.World.LocalUser;
			if (base.Engine.Platform == Platform.Android)
			{
				CurrentPath.Value = "/mnt/sdcard";
			}
			UIBuilder uIBuilder = BeginGenerateToolPanel();
			RadiantUI_Constants.SetupDefaultStyle(uIBuilder);
			uIBuilder.Style.ButtonColor = Elements.Core.colorX.White;
			_importButton.Target = uIBuilder.Button(OfficialAssets.Common.Icons.External, new Elements.Core.colorX?(MixColor(Elements.Core.colorX.Cyan)), Elements.Core.colorX.Black, RunImport);
			_rawImportButton.Target = uIBuilder.Button(OfficialAssets.Common.Icons.File, new Elements.Core.colorX?(MixColor(Elements.Core.colorX.Orange)), Elements.Core.colorX.Black, RunRawImport);
			_createNewButton.Target = uIBuilder.Button(OfficialAssets.Common.Icons.Plus, new Elements.Core.colorX?(MixColor(Elements.Core.colorX.Green)), Elements.Core.colorX.Black, CreateNew);
			_reloadButton.Target = uIBuilder.Button(OfficialAssets.Common.Icons.Reload, new Elements.Core.colorX?(MixColor(Elements.Core.colorX.Blue)), Elements.Core.colorX.Black, Reload);
			_rawImportButton.Target.EnabledField.DriveFrom(_importButton.Target.EnabledField);
			StartTask(async delegate
			{
				await Refresh(SlideSwapRegion.Slide.None);
			});
