		public Type TryGetType(string name, bool checkMovedTypes = true)
		{
			if (_typesByFullName.TryGetValue(name, out Type value))
			{
				return value;
			}
			if (checkMovedTypes && _movedTypes.TryGetValue(name, out value))
			{
				return value;
			}
			return null;
		}

