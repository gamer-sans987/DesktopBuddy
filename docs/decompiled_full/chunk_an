	public static class ProtocolRegistration
	{
		public const int INVALID_PROTOCOL_VERSION = -1;

		public static async Task<bool> Register(string appPath, IPlatformProfile platform)
		{
			string text = platform.Name + "ProtocolHandler";
			string text2 = Path.Combine(appPath, "Tools", text);
			string text3 = Path.Combine(text2, text + ".exe");
			if (!File.Exists(text3))
			{
				UniLog.Log("Unable to locate operating system protocol registration program. Directory Checked: " + text3);
				return false;
			}
			ProcessStartInfo startInfo = new ProcessStartInfo(text3)
			{
				UseShellExecute = true,
				WindowStyle = ProcessWindowStyle.Hidden,
				WorkingDirectory = text2,
				Arguments = "setup"
			};
			try
			{
				using Process process = Process.Start(startInfo);
				if (process == null)
				{
					LogRegistrationFailure();
					return false;
				}
				process.WaitForExit();
				return process.ExitCode == 0;
			}
			catch (Exception obj)
			{
				UniLog.Log(obj);
				LogRegistrationFailure();
				return false;
			}
		}

		private static void LogRegistrationFailure()
		{
			UniLog.Log("Failed to register operating system protocols.");
		}

		public static bool ShouldRegister(AppConfig config, Platform platform, IPlatformProfile profile)
		{
			if (platform != Platform.Windows)
			{
				return false;
			}
			if (config.DisableProtocolRegistration)
			{
				return false;
			}
			return !IsRegistered(profile, 1);
		}

		public static bool IsRegistered(IPlatformProfile platform, int version = 0)
		{
			try
			{
				RegistryKey registryKey = Registry.ClassesRoot.OpenSubKey(platform.AppScheme);
				if (registryKey == null)
				{
					return false;
				}
				int? num = (int?)registryKey.GetValue("ProtocolVersion", -1);
				if (num == -1)
				{
					return true;
				}
				return registryKey.SubKeyCount > 0 && num == version;
			}
			catch (Exception ex)
			{
				UniLog.Log("Failed to check " + platform.Name + " Operating System Protocol registration due to: " + ex);
				return false;
			}
		}
	}
