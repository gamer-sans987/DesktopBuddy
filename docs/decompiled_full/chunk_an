		public static string GeneratePhotoPath(string path, World world, DateTime timeTaken, string locationName, string appVersion)
		{
			DateTime localSessionBeginTime = world.Time.LocalSessionBeginTime;
			path = path.Replace("%day%", timeTaken.Day.ToString()).Replace("%month%", timeTaken.Month.ToString()).Replace("%year%", timeTaken.Year.ToString())
				.Replace("%second%", timeTaken.Second.ToString())
				.Replace("%minute%", timeTaken.Minute.ToString())
				.Replace("%hour%", timeTaken.Hour.ToString())
				.Replace("%day_name%", timeTaken.ToString("dddd"))
				.Replace("%month_name%", timeTaken.ToString("MMMMM"))
				.Replace("%day_name_en%", timeTaken.ToString("dddd", CultureInfo.InvariantCulture))
				.Replace("%month_name_en%", timeTaken.ToString("MMMMM", CultureInfo.InvariantCulture))
				.Replace("%session_day%", localSessionBeginTime.Day.ToString())
				.Replace("%session_month%", localSessionBeginTime.Month.ToString())
				.Replace("%session_year%", localSessionBeginTime.Year.ToString())
				.Replace("%session_second%", localSessionBeginTime.Second.ToString())
				.Replace("%session_minute%", localSessionBeginTime.Minute.ToString())
				.Replace("%session_hour%", localSessionBeginTime.Hour.ToString())
				.Replace("%session_day_name%", localSessionBeginTime.ToString("dddd"))
				.Replace("%session_month_name%", localSessionBeginTime.ToString("MMMMM"))
				.Replace("%session_day_name_en%", localSessionBeginTime.ToString("dddd", CultureInfo.InvariantCulture))
				.Replace("%session_month_name_en%", localSessionBeginTime.ToString("MMMMM", CultureInfo.InvariantCulture))
				.Replace("%location_name%", FilterName(locationName, "(unnamed location)"))
				.Replace("%app_version%", FilterName(appVersion, world.Engine.VersionString));
			path = "Inventory\\" + path;
			path = path.Replace("/", "\\");
			while (path.Contains("\\\\"))
			{
				path = path.Replace("\\\\", "\\");
			}
			return path;
		}

		private static string FilterName(string name, string defaultName)
		{
			if (string.IsNullOrWhiteSpace(name))
			{
				return defaultName;
			}
			return name.Trim().Replace("/", "").Replace("\\", "");
		}

