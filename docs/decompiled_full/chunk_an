		public readonly Sync<bool> UseImperialUnits;

		private string _activeCultureCode;

		public static string SystemLocale => CultureInfo.InstalledUICulture.IetfLanguageTag;

		public string ActiveLocaleCode { get; private set; }

		public CultureInfo ActiveCulture { get; private set; }

		[SettingSubcategoryEnumerator(null, null, null, -2L)]
		public async IAsyncEnumerable<DataFeedItem> AvailableLocales()
		{
			DataFeedGrid grid = new DataFeedGrid();
			grid.InitBase("Locales", null, null, "Settings." + GetType().Name + ".AvailableLocales");
			yield return grid;
			string[] grouping = new string[1] { grid.ItemKey };
			foreach (string item in base.Engine.AvailableLocales.Concat(new SingleItemEnumerable<string>(null)))
			{
				LocaleString label;
				if (item != null)
				{
					string text;
					string text2;
					try
					{
						CultureInfo cultureInfo = new CultureInfo(item);
						text = cultureInfo.NativeName;
						text2 = cultureInfo.EnglishName;
					}
					catch
					{
						text = base.Engine.GetLocaleNativeName(item);
						text2 = base.Engine.GetLocaleEnglishName(item);
					}
					label = ((!(text == text2)) ? ((LocaleString)(text + " <size=50%>(" + text2 + ")</size>")) : ((LocaleString)text));
				}
				else
				{
					label = "Settings.LocaleSettings.AvailableLocales.SystemLocale".AsLocaleKey();
				}
				DataFeedValueAction<string> dataFeedValueAction = new DataFeedValueAction<string>();
				string _localeCode = item;
				dataFeedValueAction.InitBase(item, null, grouping, label);
				dataFeedValueAction.InitAction(delegate(SyncDelegate<Action<string>> d)
				{
					d.ProxySettingAction<LocaleSettings, string>("SetCurrentLocale");
				}, _localeCode);
				dataFeedValueAction.InitHighlight(delegate(IField<bool> h)
				{
					LocaleActiveDriver localeActiveDriver = h.FindNearestParent<Slot>().AttachComponent<LocaleActiveDriver>();
					localeActiveDriver.MatchMainLanguage.Value = false;
					localeActiveDriver.LocaleCode.Value = _localeCode;
					localeActiveDriver.Target.Target = h;
				});
				yield return dataFeedValueAction;
			}
		}

		[SyncMethod(typeof(Action<string>), new string[] { })]
		public void SetCurrentLocale(string localeCode)
		{
			PrimaryInterfaceLocaleCode.Value = localeCode;
		}

		protected override void OnChanges()
		{
			string text = PrimaryInterfaceLocaleCode.Value;
			if (string.IsNullOrEmpty(text))
			{
				text = SystemLocale;
			}
			if (string.IsNullOrEmpty(text))
			{
				text = "en";
			}
			ActiveLocaleCode = text;
			string text2 = CultureLocaleCode.Value;
			if (string.IsNullOrEmpty(text2))
			{
				text2 = text;
			}
			if (_activeCultureCode != text2)
			{
				try
				{
					if (text == SystemLocale)
					{
						ActiveCulture = CultureInfo.CurrentCulture;
					}
					else
					{
						ActiveCulture = CultureInfo.CreateSpecificCulture(text2);
					}
				}
				catch (CultureNotFoundException ex)
				{
					UniLog.Log($"Culture not found: {text}, for reason: {ex.Message}, defaulting to system locale");
					ActiveCulture = CultureInfo.CurrentCulture;
				}
				_activeCultureCode = text2;
			}
			base.OnChanges();
		}

