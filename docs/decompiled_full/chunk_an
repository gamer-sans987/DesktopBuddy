		{
			base.OnAwake();
			UseClosestAvailableRelay.Value = true;
			base.Engine.Cloud.NetworkNodes.AvailableNodesChanged += OnAvailableNodesChanged;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			RelayPrioritiesEnabled.Value = !UseClosestAvailableRelay.Value;
		}

		protected override void OnStart()
		{
			base.OnStart();
			OnAvailableNodesChanged(base.Cloud.NetworkNodes);
		}

