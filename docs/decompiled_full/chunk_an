	[Category(new string[] { "Utility" })]
	public class SettingValueSync<T, S> : Component where S : SettingComponent<S>, new()
	{
		public readonly UserRef SyncingUser;

		public readonly Sync<string> SettingName;

		public readonly FieldDrive<T> TargetField;

		public readonly Sync<string> SubsettingGetter;

		public readonly Sync<string> SubsettingKey;

		private S _mappedSetting;

		private string _mappedSettingName;

		private IField<T> _mappedField;

		private bool _allowWrite;

		private string _mappedSubsettingGetter;

		private string _mappedSubsettingKey;

		private bool _eventRegistered;

		public static bool IsValidGenericType => Coder<T>.IsEnginePrimitive;

		public bool ShouldSync
		{
			get
			{
				if (!base.World.IsUserspace())
				{
					return SyncingUser.Target == base.LocalUser;
				}
				return true;
			}
		}

		private void UpdateRegistration()
		{
			if (ShouldSync != _eventRegistered)
			{
				if (ShouldSync)
				{
					Settings.RegisterComponentChanges<S>(OnSettingComponentChanged);
					Settings.RegisterValueChanges<S>(OnSettingValueChanged);
					_eventRegistered = true;
				}
				else
				{
					Unregister();
				}
			}
			if (_mappedSettingName != SettingName.Value || _mappedSubsettingGetter != SubsettingGetter.Value || _mappedSubsettingKey != SubsettingKey.Value)
			{
				MapField();
			}
			UpdateValue();
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			TargetField.SetupValueSetHook(delegate(IField<T> field, T value)
			{
				if (_mappedField != null && _allowWrite)
				{
					TargetField.Target.Value = value;
					_mappedField.FindNearestParent<Component>()?.RunSynchronously(delegate
					{
						_mappedField.Value = value;
					});
				}
			});
		}

		protected override void OnStart()
		{
			base.OnStart();
			UpdateRegistration();
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			UpdateRegistration();
		}

		protected override void OnDispose()
		{
			Unregister();
			base.OnDispose();
		}

		private void Unregister()
		{
			if (_eventRegistered)
			{
				Settings.UnregisterComponentChanges<S>(OnSettingComponentChanged);
				Settings.UnregisterValueChanges<S>(OnSettingValueChanged);
				_eventRegistered = false;
			}
		}

		private void MapField()
		{
			_mappedField = null;
			if (_mappedSetting == null)
			{
				return;
			}
			_mappedSettingName = SettingName.Value ?? "";
			_mappedSubsettingGetter = SubsettingGetter.Value;
			_mappedSubsettingKey = SubsettingKey.Value;
			Worker worker = _mappedSetting.GetSettingContainer(_mappedSubsettingGetter, _mappedSubsettingKey);
			if (worker == null)
			{
				return;
			}
			string[] array = _mappedSettingName.Split('.');
			string name = array.Last();
			for (int i = 0; i < array.Length - 1; i++)
			{
				worker = worker?.GetSyncMember(array[i]) as Worker;
			}
			if (!base.World.IsUserspace() && !base.World.UnsafeMode)
			{
				WorldspaceSettingAttribute worldspaceSettingAttribute = worker.GetSyncMemberFieldInfo(name)?.GetCustomAttribute<WorldspaceSettingAttribute>();
				if (worldspaceSettingAttribute == null)
				{
					_mappedField = null;
					return;
				}
				_allowWrite = worldspaceSettingAttribute.AllowWrite;
			}
			else
			{
				_allowWrite = true;
			}
			_mappedField = worker?.GetSyncMember(name) as IField<T>;
		}

		private void OnSettingComponentChanged(S setting)
		{
			_mappedSetting = setting;
			MapField();
		}

		private void OnSettingValueChanged(S setting)
		{
			if (_mappedField != null)
			{
				RunSynchronously(UpdateValue);
			}
		}

		private void UpdateValue()
		{
			if (_mappedField != null && TargetField.IsLinkValid)
			{
				TargetField.Target.Value = _mappedField.Value;
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			SyncingUser = new UserRef();
			SettingName = new Sync<string>();
			TargetField = new FieldDrive<T>();
			SubsettingGetter = new Sync<string>();
			SubsettingKey = new Sync<string>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => SyncingUser, 
				4 => SettingName, 
				5 => TargetField, 
				6 => SubsettingGetter, 
				7 => SubsettingKey, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static SettingValueSync<T, S> __New()
		{
			return new SettingValueSync<T, S>();
		}
	}
