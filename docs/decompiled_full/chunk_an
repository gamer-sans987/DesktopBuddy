		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			base.InputInterface.AppFacetsOpened = Open.Value && base.InputInterface.VR_Active;
			foreach (FacetAnchorPoint value in EnumsNET.Enums.GetValues<FacetAnchorPoint>())
			{
				Userspace.AnchorData anchorData = Userspace.GetAnchorData(value);
				Slot root = GetRoot(value);
				bool increase = anchorData.overrideState ?? ((bool)Open);
				ref float reference = ref _openLerp[(int)value];
				reference = MathX.FilterInvalid(reference);
				reference = MathX.Progress01(reference, base.Time.Delta * (float)AnimSpeed, increase);
				float num = ((!value.IsView()) ? reference : (1f - (Dash.Target?.OpenLerp ?? 0f)));
				bool activeSelf = base.InputInterface.VR_Active && num > 0f;
				num = MathX.SmootherStep(num);
				root.ActiveSelf = activeSelf;
				if (anchorData.HasPose)
				{
					root.LocalScale = anchorData.scale * Elements.Core.float3.One * num;
					root.LocalRotation = anchorData.orientation;
					root.LocalPosition = anchorData.position - base.InputInterface.GlobalTrackingOffset;
				}
				else
				{
					ApplyDefaultPose(root, value, num);
				}
			}
		}

		private void ApplyDefaultPose(Slot root, FacetAnchorPoint point, float scale)
		{
			root.LocalScale = Elements.Core.float3.One * scale;
			switch (point)
			{
			case FacetAnchorPoint.LeftHandTop:
				root.GlobalRotation = base.LocalUserRoot.LeftHandSlot.GlobalRotation * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.LeftHandSlot.LocalPointToGlobal(Elements.Core.float3.Up * 0.05f + HAND_FORWARD_OFFSET);
				break;
			case FacetAnchorPoint.LeftHandBottom:
				root.GlobalRotation = base.LocalUserRoot.LeftHandSlot.GlobalRotation * BOTTOM_OFFSET * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.LeftHandSlot.LocalPointToGlobal(Elements.Core.float3.Down * 0.075f + HAND_FORWARD_OFFSET);
				break;
			case FacetAnchorPoint.RightHandTop:
				root.GlobalRotation = base.LocalUserRoot.RightHandSlot.GlobalRotation * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.RightHandSlot.LocalPointToGlobal(Elements.Core.float3.Up * 0.05f + HAND_FORWARD_OFFSET);
				break;
			case FacetAnchorPoint.RightHandBottom:
				root.GlobalRotation = base.LocalUserRoot.RightHandSlot.GlobalRotation * BOTTOM_OFFSET * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.RightHandSlot.LocalPointToGlobal(Elements.Core.float3.Down * 0.075f + HAND_FORWARD_OFFSET);
				break;
			case FacetAnchorPoint.LeftForearmTop:
				root.GlobalRotation = base.LocalUserRoot.LeftHandSlot.GlobalRotation * FOREARM_ROTATE_LEFT * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.LeftHandSlot.LocalPointToGlobal(Elements.Core.float3.Up * 0.075f + FOREARM_BACKWARD_OFFSET);
				break;
			case FacetAnchorPoint.LeftForearmBottom:
				root.GlobalRotation = base.LocalUserRoot.LeftHandSlot.GlobalRotation * BOTTOM_OFFSET * FOREARM_ROTATE_LEFT * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.LeftHandSlot.LocalPointToGlobal(Elements.Core.float3.Down * 0.075f + FOREARM_BACKWARD_OFFSET);
				break;
			case FacetAnchorPoint.RightForearmTop:
				root.GlobalRotation = base.LocalUserRoot.RightHandSlot.GlobalRotation * FOREARM_ROTATE_RIGHT * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.RightHandSlot.LocalPointToGlobal(Elements.Core.float3.Up * 0.075f + FOREARM_BACKWARD_OFFSET);
				break;
			case FacetAnchorPoint.RightForearmBottom:
				root.GlobalRotation = base.LocalUserRoot.RightHandSlot.GlobalRotation * BOTTOM_OFFSET * FOREARM_ROTATE_RIGHT * CANVAS_OFFSET;
				root.GlobalPosition = base.LocalUserRoot.RightHandSlot.LocalPointToGlobal(Elements.Core.float3.Down * 0.075f + FOREARM_BACKWARD_OFFSET);
				break;
			case FacetAnchorPoint.ViewFront:
				root.GlobalRotation = base.LocalUserRoot.HeadRotation;
				root.GlobalPosition = base.LocalUserRoot.HeadSlot.LocalPointToGlobal(Elements.Core.float3.Forward * 1f);
				break;
			case FacetAnchorPoint.ViewBottom:
			{
				Elements.Core.floatQ b = Elements.Core.floatQ.AxisAngle(Elements.Core.float3.Right, 45f);
				root.GlobalRotation = base.LocalUserRoot.HeadRotation * b;
				root.GlobalPosition = base.LocalUserRoot.HeadSlot.LocalPointToGlobal(b * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Forward * 0.7f) + Elements.Core.float3.Forward * 0.4f + Elements.Core.float3.Up * 0.035f);
				break;
			}
			}
			static ref readonly T ILSpyHelper_AsRefReadOnly<T>(in T temp)
			{
				//ILSpy generated this function to help ensure overload resolution can pick the overload using 'in'
				return ref temp;
			}
		}

