		public static async Task RecordPerfMetrics(Engine engine, CancellationToken cancellationToken)
		{
			Directory.CreateDirectory("Bench");
			FileStream stream = File.OpenWrite("Bench\\" + DateTime.Now.ToString("yyyy-MM-dd HH_mm_ss") + ".csv");
			StreamWriter writer = new StreamWriter(stream);
			List<string> parameters = new List<string> { "FPS" };
			string[] updateStageNames = FrooxEngine.Engine.UpdateStageNames;
			foreach (string item in updateStageNames)
			{
				parameters.Add(item);
			}
			parameters.Add("Audio Reads");
			parameters.Add("Empty Audio Reads");
			parameters.Add("Asset Uploads");
			parameters.Add("Texture");
			parameters.Add("Slices");
			parameters.Add("Mesh");
			parameters.Add("Material");
			parameters.Add("Camera Renders");
			parameters.Add("Mirror Portal Renders");
			parameters.Add("Blit Renders");
			foreach (object value in Enum.GetValues(typeof(World.RefreshStage)))
			{
				parameters.Add(value.ToString());
			}
			parameters.Add("Coroutines");
			parameters.Add("Updates");
			parameters.Add("Changes");
			parameters.Add("Moved Slots");
			parameters.Add("Total Slots");
			parameters.Add("Audio Update Time");
			parameters.Add("Audio Stream Buffer Underruns");
			writer.WriteLine(string.Join(",", parameters));
			parameters.Clear();
			while (!cancellationToken.IsCancellationRequested)
			{
				await default(NextUpdate);
				World focusedWorld = engine.WorldManager.FocusedWorld;
				if (focusedWorld == null)
				{
					continue;
				}
				parameters.Add(engine.PerfStats.FPS.ToString(CultureInfo.InvariantCulture));
				double[] updateStageTimes = engine.UpdateStageTimes;
				foreach (double num in updateStageTimes)
				{
					parameters.Add(num.ToString(CultureInfo.InvariantCulture));
				}
				parameters.Add(engine.AudioReads.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.EmptyAudioReads.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.AssetUpdates.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.TextureUpdates.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.TextureSliceUpdates.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.MeshUpdates.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.MaterialUpdates.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.CameraRenders.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.PortalRenders.ToString(CultureInfo.InvariantCulture));
				parameters.Add(engine.BlitRenders.ToString(CultureInfo.InvariantCulture));
				foreach (World.RefreshStage value2 in Enum.GetValues(typeof(World.RefreshStage)))
				{
					parameters.Add(focusedWorld.StageUpdateTime[(int)value2].ToString(CultureInfo.InvariantCulture));
				}
				parameters.Add(focusedWorld.LastCoroutines.ToString(CultureInfo.InvariantCulture));
				parameters.Add(focusedWorld.LastCommonUpdates.ToString(CultureInfo.InvariantCulture));
				parameters.Add(focusedWorld.LastChanges.ToString(CultureInfo.InvariantCulture));
				parameters.Add(focusedWorld.LastMovedSlots.ToString(CultureInfo.InvariantCulture));
				parameters.Add(focusedWorld.LastTotalSlots.ToString(CultureInfo.InvariantCulture));
				parameters.Add(focusedWorld.AudioUpdateTime.ToString(CultureInfo.InvariantCulture));
				parameters.Add(focusedWorld.LastAudioStreamUnderruns.ToString(CultureInfo.InvariantCulture));
				writer.WriteLine(string.Join(",", parameters));
				parameters.Clear();
			}
			writer.Close();
		}

