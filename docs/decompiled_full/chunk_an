		private DataFeedItem EntryToItem(ISyncMember item)
		{
			RelayPriorityEntry entry = (RelayPriorityEntry)item;
			DataFeedOrderedItem<int> feedItem = new DataFeedOrderedItem<int>();
			feedItem.InitBase(entry.EntryID.Value, (IReadOnlyList<string>)null, (IReadOnlyList<string>)null, (LocaleString)(entry.EntryID.Value + " <size=75%>(" + entry.RelayIP.Value + ")</size>"), (Uri?)null, (Action<IField<bool>>?)null, (Action<IField<bool>>?)delegate(IField<bool> f)
			{
				f.SyncWithSetting<bool, RelaySettings>("IsAvailable", "GetEntry", feedItem.ItemKey);
			}, (IReadOnlyList<DataFeedItem>?)null, (object?)null);
			feedItem.InitSorting(() => -(int)entry.Priority);
			entry.InitSetup<RelaySettings>(feedItem, "GetEntry", includeMakeFirst: true, includeMakeLast: true);
			return feedItem;
		}

