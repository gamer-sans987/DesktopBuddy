		private void ContactStatusUpdated(ContactData contact)
		{
			if (contact.Contact.ContactStatus != ContactStatus.Accepted || contact.Contact.IsSelfContact || (DateTime.UtcNow - base.Cloud.Session.InitialSessionActivationTime).TotalSeconds < 15.0)
			{
				return;
			}
			OnlineStatus valueOrDefault = contact.PreviousStatus.OnlineStatus.GetValueOrDefault();
			OnlineStatus valueOrDefault2 = contact.CurrentStatus.OnlineStatus.GetValueOrDefault();
			if (valueOrDefault == valueOrDefault2)
			{
				return;
			}
			bool sociableNotification = false;
			if (_settings.UserSociable.Value == NotificationType.None)
			{
				if (valueOrDefault == OnlineStatus.Online || valueOrDefault == OnlineStatus.Sociable || (valueOrDefault2 != OnlineStatus.Online && valueOrDefault2 != OnlineStatus.Sociable))
				{
					return;
				}
			}
			else
			{
				if (valueOrDefault == OnlineStatus.Sociable || (valueOrDefault2 != OnlineStatus.Sociable && valueOrDefault2 != OnlineStatus.Online))
				{
					return;
				}
				if (valueOrDefault2 == OnlineStatus.Sociable)
				{
					sociableNotification = true;
				}
			}
			if (sociableNotification)
			{
				if (_lastSociableUpdate.TryGetValue(contact.UserId, out var value) && DateTime.UtcNow - value < SociableStatusCooldown)
				{
					return;
				}
				_lastSociableUpdate[contact.UserId] = DateTime.UtcNow;
			}
			else
			{
				if (_lastOnlineUpdate.TryGetValue(contact.UserId, out var value2) && DateTime.UtcNow - value2 < OnlineStatusCooldown)
				{
					return;
				}
				_lastOnlineUpdate[contact.UserId] = DateTime.UtcNow;
			}
			RunSynchronously(delegate
			{
				if (sociableNotification)
				{
					AddNotification(contact.UserId, this.GetLocalized("Notifications.IsSociable"), null, RadiantUI_Constants.Dark.CYAN, _settings.UserSociable.Value, "N/A", null, _sociableClip.Target);
				}
				else
				{
					NotificationPanel notificationPanel = this;
					string userId = contact.UserId;
					string localized = this.GetLocalized("Notifications.IsOnline");
					Elements.Core.colorX gREEN = RadiantUI_Constants.Dark.GREEN;
					NotificationSettings settings = _settings;
					notificationPanel.AddNotification(userId, localized, null, gREEN, (settings != null && settings.UserOnline.Value) ? NotificationType.Full : NotificationType.None);
				}
			});
		}

		protected override void OnCommonUpdate()
		{
			if (delayedNotifications.Count > 0 && base.Engine.Cloud.Status.OnlineStatus != OnlineStatus.Away)
			{
				notificationDelay += base.Time.Delta;
				if (notificationDelay > ONLINE_NOTIFICATION_DELAY)
				{
					try
					{
						foreach (Action delayedNotification in delayedNotifications)
						{
							delayedNotification();
						}
					}
					catch
					{
					}
					delayedNotifications.Clear();
				}
			}
			else
			{
				notificationDelay = 0f;
			}
			int num = 0;
			string openUserId = OpenUserId;
			for (int i = 0; i < _items.Count; i++)
			{
				NotificationItem notificationItem = _items[i];
				notificationItem.show = (DateTime.UtcNow - notificationItem.addTime).TotalSeconds < (double)(float)DisplayDuration;
				if (openUserId != null && openUserId == notificationItem.userId)
				{
					notificationItem.show = false;
				}
				if (notificationItem.show)
				{
					num++;
				}
				if (num > 5)
				{
					notificationItem.show = false;
				}
				notificationItem.showLerp = MathX.Progress01(notificationItem.showLerp, base.Time.Delta * 5f, notificationItem.show);
				if (!notificationItem.show && notificationItem.showLerp == 0f)
				{
					notificationItem.root.Destroy();
					_items.RemoveAt(i);
				}
				else
				{
					float value = MathX.SmootherStep(notificationItem.showLerp) * 36f;
					notificationItem.element.MinHeight.Value = value;
				}
			}
			_canvas.Target.Collider.Target.Enabled = num > 0;
			float x = 720f * base.InputInterface.WindowAspectRatio;
			Elements.Core.float2 @float = new Elements.Core.float2(x, 720f);
			float x2 = MathX.SmootherStep(MathX.Clamp01((Dash.Target.Dash.LocalShowLerp - 0.5f) / 0.5f)) * CANVAS_SIZE.x * 0.0013888889f;
			_canvas.Target.Size.Value = (base.InputInterface.VR_Active ? CANVAS_SIZE : @float);
			base.Slot.LocalScale = Elements.Core.float3.One * (base.InputInterface.VR_Active ? VR_SCALE : 0.0013888889f);
			base.Slot.LocalPosition = (base.InputInterface.VR_Active ? Elements.Core.float3.Zero : new Elements.Core.float3(x2, 0f, -0.1f));
		}

		public void Messages_OnMessageReceived(SkyFrost.Base.Message message)
		{
			if (message.IsSent || message.IsRead || message.IsPreFetched || OpenUserId == message.SenderId)
			{
				return;
			}
			RunSynchronously(delegate
			{
				Uri result;
				switch (message.MessageType)
				{
				case SkyFrost.Base.MessageType.Text:
					AddNotification(message.SenderId, message.Content, null, _settings?.Message.Value ?? NotificationType.None, _notificationClip.Target);
					break;
				case SkyFrost.Base.MessageType.SessionInvite:
				{
					SessionInfo sessionInfo = message.ExtractContent<SessionInfo>();
					Uri.TryCreate(sessionInfo.ThumbnailUrl, UriKind.Absolute, out result);
					AddNotification(message.SenderId, this.GetLocalized("Notifications.ReceivedInvite", "<b>{0}</b>") + " " + sessionInfo.Name, result, RadiantUI_Constants.Dark.YELLOW, _settings?.Invite.Value ?? NotificationType.None, "N/A", null, _inviteClip.Target);
					break;
				}
				case SkyFrost.Base.MessageType.InviteRequest:
				{
					InviteRequest inviteRequest = message.ExtractContent<InviteRequest>();
					if (!inviteRequest.IsGranted)
					{
						string message2 = ((!(inviteRequest.RequestingFromUserId == base.Cloud.CurrentUserID)) ? (this.GetLocalized("Notifications.ReceivedInviteRequestForwarded", "<b>{0}</b>") + " " + inviteRequest.UsernameToInvite) : this.GetLocalized("Notifications.ReceivedInviteRequestDirect".AsLocaleKey()));
						AddNotification(message.SenderId, message2, null, RadiantUI_Constants.Dark.PURPLE, _settings?.InviteRequest.Value ?? NotificationType.None, "N/A", null, _inviteRequestClip.Target);
					}
					break;
				}
				case SkyFrost.Base.MessageType.Object:
				{
					SkyFrost.Base.Record record = message.ExtractContent<SkyFrost.Base.Record>();
					Uri.TryCreate(record.ThumbnailURI, UriKind.Absolute, out result);
