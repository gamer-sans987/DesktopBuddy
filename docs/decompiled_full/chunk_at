		public static void EnableTimeout(this Button button, int timeout = 5)
		{
			button.StartTask(async delegate
			{
				await EnableTimeout(button, button.EnabledField, button.Label?.Content, timeout).ConfigureAwait(continueOnCapturedContext: false);
			});
		}

		private static async Task EnableTimeout(Component component, IField<bool> enabled, IField<string> label, int timeout)
		{
			enabled.Value = false;
			LocaleStringDriver localeStringDriver = label.ActiveLink?.FindNearestParent<Component>() as LocaleStringDriver;
			if (localeStringDriver != null)
			{
				label = localeStringDriver.Format;
			}
			string origLabel = label.Value;
			string baseLabel = origLabel;
			if (localeStringDriver != null)
			{
				baseLabel = "{0}";
			}
			for (int i = timeout; i > 0; i--)
			{
				if (label != null)
				{
					label.Value = baseLabel + $" ({i})";
				}
				await component.DelaySeconds(1f);
			}
			label.Value = origLabel;
			enabled.Value = true;
		}

