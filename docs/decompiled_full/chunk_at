		public void ChunkHierarchyToString(StringBuilder str, int indent = 0)
		{
			SelfInfoToString(str, indent);
			indent++;
			foreach (GraphicsChunk childrenChunk in ChildrenChunks)
			{
				childrenChunk.SelfInfoToString(str, indent);
			}
		}

		public void SelfInfoToString(StringBuilder str, int indent = 0)
		{
			for (int i = 0; i < indent * 2; i++)
			{
				str.Append('-');
			}
			StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(107, 8, str);
			handler.AppendLiteral("Chunk: ");
			handler.AppendFormatted(GetHashCode());
			handler.AppendLiteral(", IsEnabled: ");
			handler.AppendFormatted(IsEnabled);
			handler.AppendLiteral(", Root.Removed: ");
			handler.AppendFormatted(Root?.IsRemoved);
			handler.AppendLiteral(", IsRectDisabled: ");
			handler.AppendFormatted(Root?.IsRectDisabled);
			handler.AppendLiteral(", Children: ");
			handler.AppendFormatted(ChildrenChunks.Count);
			handler.AppendLiteral(", IsMask: ");
			handler.AppendFormatted(IsMask);
			handler.AppendLiteral(", Content Render Data: ");
			handler.AppendFormatted(_usedContentRenderDataCount);
			handler.AppendLiteral(", Root:\n");
			handler.AppendFormatted(Root);
			str.AppendLine(ref handler);
		}
