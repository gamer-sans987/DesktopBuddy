		protected override void OnSaving(SaveControl control)
		{
			base.OnSaving(control);
			Slot _target = Target.Target;
			if (_target != null)
			{
				Slot parent = _target.Parent;
				control.OnBeforeSaveStart(delegate
				{
					_target.SetParent(_originalParent.Target, keepGlobalTransform: false);
				});
				control.OnSaved(delegate
				{
					_target.SetParent(parent, keepGlobalTransform: false);
				});
			}
		}

