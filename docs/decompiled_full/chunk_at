		public Task ComputeGraphics()
		{
			if (World == null)
			{
				throw new InvalidOperationException("The World is null, cannot compute!");
			}
			if (Root == null)
			{
				throw new InvalidOperationException("The Root is null, cannot compute!");
			}
			if (_graphicsComputationTask != null)
			{
				throw new InvalidOperationException("Another computation task is already running!");
			}
			_graphicsComputationTask = new TaskCompletionSource<bool>();
			Task<bool> task = _graphicsComputationTask.Task;
			World.RunInBackground(_computeGraphicsTask);
			return task;
		}

		private void ComputeGraphicsTask()
		{
			if (IsMask)
			{
				MaskRenderData.PrepareCompute(0);
				_currentRenderData = MaskRenderData;
				Root.ComputeGraphics(this, 0, computingMask: true);
			}
			_currentRenderData = null;
			_usedContentRenderDataCount = 0;
			_currentChildrenChunkCount = 0;
			if (!IsDebug)
			{
				Root.ComputeGraphics(this, 0, computingMask: false);
			}
			else
			{
				Root.ComputeDebugGraphics(this, Elements.Core.float2.Zero);
			}
			TaskCompletionSource<bool> graphicsComputationTask = _graphicsComputationTask;
			_graphicsComputationTask = null;
			graphicsComputationTask.SetResult(result: true);
		}

		public void SubmitChanges(ref int renderOffset, Elements.Core.Rect maskRect, int depth = 0, int maskDepth = 0)
		{
			if (!IsEnabled)
			{
				if (ChunkSlot != null)
				{
					ChunkSlot.ActiveSelf = false;
				}
			}
			else
			{
				if (ChunkSlot != null && ChunkSlot.IsRemoved)
				{
					return;
				}
				Slot parentSlot = ParentSlot;
				if (ChunkSlot == null)
				{
					ChunkSlot = parentSlot.AddLocalSlot("Chunk");
					MaskRenderData?.SetupComponents();
					MaskClearRenderData?.SetupComponents();
				}
				if (_usedContentRenderDataCount > _lastUsedContentRenderDataCount)
				{
					for (int i = _lastUsedContentRenderDataCount; i < _usedContentRenderDataCount; i++)
					{
						_contentRenderData[i].SetupComponents();
					}
				}
				_lastUsedContentRenderDataCount = _usedContentRenderDataCount;
				while (_contentRenderData.Count > _usedContentRenderDataCount)
				{
					int index = _contentRenderData.Count - 1;
					_contentRenderData[index].DestroyComponents();
					_contentRenderData.RemoveAt(index);
				}
				ChunkSlot.ActiveSelf = true;
				Root.Controller?.OnPreSubmitChanges();
				if (ChunkSlot.Parent != parentSlot)
				{
					ChunkSlot.Parent = parentSlot;
				}
				ChunkSlot.LocalPosition = ComputeOffset;
				ref Elements.Core.float2 position = ref maskRect.position;
				position -= ComputeOffset;
				if (IsMask)
				{
					maskDepth++;
					Elements.Core.float2 size = Root.LocalComputeRect.size;
					maskRect = maskRect.Clip(new Elements.Core.Rect(Elements.Core.float2.Zero, in size));
				}
				MaskRenderData?.SubmitChanges(renderOffset++, maskDepth, in maskRect);
				int j = 0;
				for (int k = 0; k < _contentRenderData.Count; k++)
				{
					RenderData renderData = _contentRenderData[k];
					while (j < renderData.PrecedingChildrenChunkCount && ChildrenChunks.Count > j)
					{
						ChildrenChunks[j++].SubmitChanges(ref renderOffset, maskRect, depth + 1, maskDepth);
					}
					renderData.SubmitChanges(renderOffset++, maskDepth, in maskRect);
					Root.Controller?.OnMainSubmitChanges(k, ref renderOffset, ref maskDepth, ref maskRect);
				}
				if (_contentRenderData.Count == 0)
				{
					Root.Controller?.OnMainSubmitChanges(0, ref renderOffset, ref maskDepth, ref maskRect);
				}
				for (; j < ChildrenChunks.Count; j++)
				{
					ChildrenChunks[j].SubmitChanges(ref renderOffset, maskRect, depth + 1, maskDepth);
				}
				MaskClearRenderData?.SubmitChanges(renderOffset++, maskDepth, in maskRect);
				if (IsMask)
				{
					maskDepth--;
				}
			}
		}

		public void UploadMesh(bool highPriority)
		{
			MaskRenderData?.UploadMesh(highPriority);
			for (int i = 0; i < _usedContentRenderDataCount; i++)
			{
				_contentRenderData[i].UploadMesh(highPriority);
			}
		}

