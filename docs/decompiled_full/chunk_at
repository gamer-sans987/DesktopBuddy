		public void SetProportionalRect(Elements.Core.float2 size, Alignment alignment)
		{
			LayoutHorizontalAlignment horizontalLayout = alignment.GetHorizontalLayout();
			LayoutVerticalAlignment verticalLayout = alignment.GetVerticalLayout();
			float x;
			float x2;
			switch (horizontalLayout)
			{
			case LayoutHorizontalAlignment.Left:
				x = 0f;
				x2 = size.x;
				break;
			case LayoutHorizontalAlignment.Right:
				x = 1f - size.x;
				x2 = 1f;
				break;
			default:
			{
				float num = size.x * 0.5f;
				x = 0.5f - num;
				x2 = 0.5f + num;
				break;
			}
			}
			float y;
			float y2;
			switch (verticalLayout)
			{
			case LayoutVerticalAlignment.Top:
				y = 1f;
				y2 = 1f - size.y;
				break;
			case LayoutVerticalAlignment.Bottom:
				y = size.y;
				y2 = 0f;
				break;
			default:
			{
				float num2 = size.y * 0.5f;
				y = 0.5f + num2;
				y2 = 0.5f - num2;
				break;
			}
			}
			AnchorMin.Value = new Elements.Core.float2(x, y2);
			AnchorMax.Value = new Elements.Core.float2(x2, y);
		}

