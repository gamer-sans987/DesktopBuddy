		private GraphicsChunk FindParentChunk()
		{
			if (Root.IsRectDisabled)
			{
				return null;
			}
			for (RectTransform rectParent = Root.RectParent; rectParent != null; rectParent = rectParent.RectParent)
			{
				if (rectParent.IsRectDisabled)
				{
					return null;
				}
				if (rectParent.GraphicsChunk != null)
