		{
			base.OnChanges();
			if (Target.Target != _lastTarget.Target)
			{
				if (_lastTarget.Target != null && _originalParent.Target != null)
				{
					_lastTarget.Target.SetParent(_originalParent.Target, keepGlobalTransform: false);
				}
				Slot target = Target.Target;
				_lastTarget.Target = target;
				_originalParent.Target = target?.Parent;
				_position.Target = target?.Position_Field;
				_rotation.Target = target?.Rotation_Field;
				_scale.Target = target?.Scale_Field;
			}
