	public class GraphicsChunk
	{
		public enum RenderType
		{
			MaskWrite,
			Content,
			MaskClear,
			Debug
		}

		public class RenderData
		{
			private Dictionary<MaterialKey, List<Elements.Assets.TriangleSubmesh>> requestedMaterials;

			private Dictionary<MaterialKey, AssignedMaterial> assignedMaterials;

			internal Action<int> MaterialCountSet;

			internal Action<MaterialKey, RawValueList<int>> MaterialAssigned;

			internal Action<MaterialKey> MaterialRemoved;

			private int currentMaskDepth;

			private bool? currentMaskVisible;

			private Elements.Core.Rect currentRect;

			private bool materialSetupDirty;

			private RenderData meshData;

			private Task _runningMeshUploadTask;

			private int _submeshCount;

			public GraphicsChunk Chunk { get; private set; }

			public MeshX Mesh { get; private set; }

			public RenderType RenderType { get; private set; }

			public LocalMeshProvider MeshProvider { get; private set; }

			public MeshRenderer MeshRenderer { get; private set; }

			public int PrecedingChildrenChunkCount { get; private set; }

			public int CurrentMaxSubmeshIndex { get; private set; }

			public int MinimumSubmeshIndex { get; private set; }

			public Task WaitForLastUpload()
			{
				return _runningMeshUploadTask ?? Task.CompletedTask;
			}

			public RenderData(GraphicsChunk chunk, RenderType renderType, RenderData meshData = null)
			{
				Chunk = chunk;
				RenderType = renderType;
				if (meshData == null)
				{
					Mesh = new MeshX();
					Mesh.Profile = ColorProfile.Linear;
					Mesh.HasUV0s = true;
					Mesh.HasColors = true;
					requestedMaterials = new Dictionary<MaterialKey, List<Elements.Assets.TriangleSubmesh>>();
				}
				else
				{
					this.meshData = meshData;
					meshData.MaterialCountSet = OnMaterialCountSet;
					meshData.MaterialAssigned = OnMaterialAssigned;
					meshData.MaterialRemoved = OnMaterialRemoved;
				}
				assignedMaterials = new Dictionary<MaterialKey, AssignedMaterial>();
			}

			internal void PrepareCompute(int precedingChildrenChunkCount)
			{
				PrecedingChildrenChunkCount = precedingChildrenChunkCount;
				Mesh.ClearVerticesAndIndicies();
				_submeshCount = 0;
				foreach (KeyValuePair<MaterialKey, List<Elements.Assets.TriangleSubmesh>> requestedMaterial in requestedMaterials)
				{
					List<Elements.Assets.TriangleSubmesh> list = requestedMaterial.Value;
					Pool.Return(ref list);
				}
				requestedMaterials.Clear();
			}

			internal void SetupComponents()
			{
				if (Mesh != null)
				{
					MeshProvider = Chunk.ChunkSlot.AttachComponent<LocalMeshProvider>();
				}
				MeshRenderer = Chunk.ChunkSlot.AttachComponent<MeshRenderer>();
				MeshRenderer.Mesh.Target = MeshProvider ?? meshData.MeshProvider;
			}

			internal void DestroyComponents()
			{
				MeshProvider?.Destroy();
				MeshRenderer?.Destroy();
				MeshProvider = null;
				MeshRenderer = null;
			}

			internal void SubmitChanges(int renderOffset, int maskDepth, in Elements.Core.Rect maskRect)
			{
				MeshRenderer.SortingOrder.Value = renderOffset;
				bool flag = maskDepth > 0;
				bool flag2 = currentMaskDepth > 0;
				bool flag3 = maskDepth != currentMaskDepth;
				bool flag4 = Chunk.Root.IsMaskVisible != currentMaskVisible;
				currentMaskDepth = maskDepth;
				currentMaskVisible = Chunk.Root.IsMaskVisible;
				if (meshData == null)
				{
					MeshRenderer.Materials.EnsureExactCount(_submeshCount);
					MaterialCountSet?.Invoke(MeshRenderer.Materials.Count);
					MeshRenderer.Enabled = _submeshCount > 0;
					if (flag != flag2)
					{
						foreach (KeyValuePair<MaterialKey, AssignedMaterial> assignedMaterial in assignedMaterials)
						{
							AssignedMaterial value = assignedMaterial.Value;
							RemoveMaterial(in value.map);
							MaterialRemoved?.Invoke(assignedMaterial.Key);
						}
						assignedMaterials.Clear();
					}
					UpdateMaterials();
				}
				if (maskDepth > 0 && (flag3 || (flag && flag4) || materialSetupDirty))
				{
					foreach (KeyValuePair<MaterialKey, AssignedMaterial> assignedMaterial2 in assignedMaterials)
					{
						UpdateMaterialMasking(assignedMaterial2.Value.map.material, maskDepth);
					}
				}
				if (RenderType == RenderType.Content && flag)
				{
					if (maskRect != currentRect || materialSetupDirty)
					{
						foreach (KeyValuePair<MaterialKey, AssignedMaterial> assignedMaterial3 in assignedMaterials)
						{
							UpdateMaterialRectClip(assignedMaterial3.Value.map.material, maskRect);
						}
					}
					currentRect = maskRect;
				}
				materialSetupDirty = false;
			}

			private void UpdateMaterialRectClip(IAssetProvider<Material> material, Elements.Core.Rect rect)
			{
				if (material is IUIX_Material iUIX_Material)
				{
					iUIX_Material.Rect.Value = rect;
				}
			}

			private void UpdateMaterialMasking(IAssetProvider<Material> material, int maskDepth)
			{
				if (material is IUIX_Material iUIX_Material)
				{
					byte mask = GetMask(maskDepth);
					iUIX_Material.RenderQueue.Value = 3000;
					switch (RenderType)
					{
					case RenderType.MaskWrite:
						iUIX_Material.ColorMask.Value = (Chunk.Root.IsMaskVisible ? ColorMask.RGBA : ColorMask.None);
						iUIX_Material.StencilComparison.Value = ((maskDepth == 1) ? StencilComparison.Always : StencilComparison.Equal);
						iUIX_Material.StencilOperation.Value = StencilOperation.Replace;
						iUIX_Material.StencilID.Value = mask;
						iUIX_Material.StencilReadMask.Value = GetMask(maskDepth - 1);
						iUIX_Material.StencilWriteMask.Value = mask;
						iUIX_Material.RectClip.Value = false;
						break;
					case RenderType.Content:
					case RenderType.Debug:
						iUIX_Material.ColorMask.Value = ColorMask.RGBA;
						iUIX_Material.StencilComparison.Value = StencilComparison.Equal;
						iUIX_Material.StencilOperation.Value = StencilOperation.Keep;
						iUIX_Material.StencilID.Value = mask;
						iUIX_Material.StencilReadMask.Value = mask;
						iUIX_Material.StencilWriteMask.Value = 0;
						iUIX_Material.RectClip.Value = true;
						break;
					case RenderType.MaskClear:
						iUIX_Material.ColorMask.Value = ColorMask.None;
						iUIX_Material.StencilOperation.Value = StencilOperation.Zero;
						iUIX_Material.StencilComparison.Value = StencilComparison.Equal;
						iUIX_Material.StencilID.Value = mask;
						iUIX_Material.StencilReadMask.Value = mask;
						iUIX_Material.StencilWriteMask.Value = (byte)(1 << maskDepth - 1);
						iUIX_Material.RectClip.Value = false;
						break;
					}
				}
			}

			private static byte GetMask(int depth)
			{
				return (byte)(255u >> 8 - depth);
			}

			internal void UploadMesh(bool highPriority)
			{
				if (_runningMeshUploadTask != null && !_runningMeshUploadTask.IsCompleted)
				{
					throw new Exception("Last mesh upload is still running, cannot submit new!");
				}
				if (Mesh.VertexCount != 0)
				{
					if (MeshProvider == null)
					{
						throw new Exception($"MeshProvider is null! RenderType: {RenderType}, Mesh: {Mesh}Mesh Renderer:\n{MeshRenderer}");
					}
					while (Mesh.SubmeshCount > _submeshCount)
					{
						Mesh.RemoveSubmesh(Mesh.SubmeshCount - 1);
					}
					MeshProvider.HighPriorityIntegration.Value = highPriority;
					MeshProvider.Mesh = Mesh;
					MeshProvider.LocalManualUpdate = true;
					_runningMeshUploadTask = MeshProvider.Update();
				}
			}

			private void UpdateMaterials()
			{
				int num = 0;
				RawValueList<int> list = Pool.BorrowRawValueList<int>();
				foreach (KeyValuePair<MaterialKey, List<Elements.Assets.TriangleSubmesh>> requestedMaterial in requestedMaterials)
				{
					list.Clear();
					foreach (Elements.Assets.TriangleSubmesh item in requestedMaterial.Value)
					{
						list.Add(item.Index);
					}
					UpdateMaterial(requestedMaterial.Key, list, out var changed, out var usedExisting);
					if (usedExisting)
					{
						num++;
					}
					if (changed)
					{
						MaterialAssigned?.Invoke(requestedMaterial.Key, list);
					}
				}
				Pool.Return(ref list);
				if (num == assignedMaterials.Count)
				{
					return;
				}
				List<MaterialKey> list2 = Pool.BorrowList<MaterialKey>();
				foreach (KeyValuePair<MaterialKey, AssignedMaterial> assignedMaterial in assignedMaterials)
				{
					if (!requestedMaterials.ContainsKey(assignedMaterial.Key))
					{
						list2.Add(assignedMaterial.Key);
						AssignedMaterial value = assignedMaterial.Value;
						RemoveMaterial(in value.map);
						MaterialRemoved?.Invoke(assignedMaterial.Key);
						RawValueList<int> list3 = assignedMaterial.Value.indexes;
						Pool.Return(ref list3);
					}
				}
				foreach (MaterialKey item2 in list2)
				{
					assignedMaterials.Remove(item2);
				}
				Pool.Return(ref list2);
			}

			private void UpdateMaterial(in MaterialKey key, RawValueList<int> indexes, out bool changed, out bool usedExisting)
			{
				if (assignedMaterials.TryGetValue(key, out var value))
				{
					usedExisting = true;
					changed = false;
					if (value.indexes.Count > indexes.Count)
					{
						value.indexes.Count = indexes.Count;
					}
					else
					{
						while (value.indexes.Count < indexes.Count)
						{
							value.indexes.Add(-1);
						}
					}
					for (int i = 0; i < indexes.Count; i++)
					{
						int num = indexes[i];
						if (num != value.indexes[i])
						{
							changed = true;
							value.indexes[i] = num;
							MeshRenderer.Materials[num] = value.map.FilteredMaterial;
							if (value.map.FilteredPropertyBlock != null || MeshRenderer.MaterialPropertyBlocks.Count > 0)
							{
								MeshRenderer.MaterialPropertyBlocks.EnsureExactCount(MeshRenderer.Materials.Count);
								MeshRenderer.MaterialPropertyBlocks[num] = value.map.FilteredPropertyBlock;
							}
						}
					}
					return;
				}
				changed = true;
				usedExisting = false;
				MaterialMap map = GetMaterialMap(in key);
				RawValueList<int> rawValueList = Pool.BorrowRawValueList<int>();
				if (rawValueList.Capacity < indexes.Count)
				{
					rawValueList.Capacity = indexes.Count;
				}
				rawValueList.Count = indexes.Count;
				Array.Copy(indexes.Elements, 0, rawValueList.Elements, 0, indexes.Count);
				for (int j = 0; j < indexes.Count; j++)
				{
					int index = indexes[j];
					MeshRenderer.Materials[index] = map.FilteredMaterial;
					if (map.FilteredPropertyBlock != null || MeshRenderer.MaterialPropertyBlocks.Count > 0)
					{
						MeshRenderer.MaterialPropertyBlocks.EnsureExactCount(MeshRenderer.Materials.Count);
						MeshRenderer.MaterialPropertyBlocks[index] = map.FilteredPropertyBlock;
					}
				}
				assignedMaterials.Add(key, new AssignedMaterial(rawValueList, in map));
			}

			private void RemoveMaterial(in MaterialMap map)
			{
				Remove(map.material?.Slot);
			}

			private void Remove(Slot slot)
			{
				if (slot != null && slot.Parent == Chunk.ChunkSlot)
				{
					slot.Destroy();
				}
			}

			private MaterialMap GetMaterialMap(in MaterialKey key)
			{
				MaterialMap result = GetBaseMaterial(in key);
				if ((currentMaskDepth > 0 || Chunk.IsMask) && result.FilteredMaterial is IUIX_Material uixMaterial)
				{
					result = new MaterialMap(CloneMaterial(uixMaterial), result.propertyBlock);
				}
				return result;
			}

			public UI_UnlitMaterial GetDefaultUIMaterial()
			{
				return Chunk.Canvas.DefaultCulling.Value switch
				{
					Culling.Front => Chunk.Canvas.World.GetLocalRegisteredComponent("UI_DefaultMaterial_Back", delegate(UI_UnlitMaterial m)
					{
