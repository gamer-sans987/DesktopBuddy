		private void MetricsChanged(LayoutMetric metrics, int index)
		{
			if (!AnyMetricsValid)
			{
				return;
			}
			if (_layoutElements.Count > 0)
			{
				if (index < _layoutElements.Count)
				{
					int priority = _layoutElements[index].Priority;
					do
					{
						index--;
					}
					while (index >= 0 && _layoutElements[index].Priority == priority);
				}
				else
				{
					index--;
				}
				int? num = null;
				LayoutMetric layoutMetric = (LayoutMetric)0;
				while (index >= 0)
				{
					ILayoutElement layoutElement = _layoutElements[index];
					layoutMetric |= layoutElement.FilterChangedMetrics(metrics);
					if (layoutElement.Priority != num || index == 0)
					{
						metrics = layoutMetric;
						layoutMetric = (LayoutMetric)0;
						num = layoutElement.Priority;
					}
					index--;
				}
			}
			if (metrics != 0)
			{
				if ((metrics & LayoutMetric.ALL_Width) != 0)
				{
					InvalidateMetrics(LayoutDirection.Horizontal);
				}
				if ((metrics & LayoutMetric.ALL_Height) != 0)
				{
					InvalidateMetrics(LayoutDirection.Vertical);
				}
				if (IsRectDriven)
				{
					RectParent?.MetricsChanged(metrics);
				}
			}
		}

