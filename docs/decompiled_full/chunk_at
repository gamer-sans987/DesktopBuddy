	[Category(new string[] { "Assets/Procedural Cubemaps" })]
	public class DebugDirectionCubemap : ProceduralCubemap
	{
		public readonly Sync<Elements.Core.bool3> RGB_Mask;

		protected override void OnAwake()
		{
			base.OnAwake();
			RGB_Mask.Value = Elements.Core.bool3.True;
		}

		protected override void UpdateTextureData(BitmapCube texCube)
		{
			texCube.ForeachPixelDirection(delegate(Elements.Core.float3 dir)
			{
				dir *= 0.5f;
				dir += 0.5f;
				return new Elements.Core.color(dir.Mask(RGB_Mask));
			});
		}

		protected override void ClearTextureData()
		{
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			RGB_Mask = new Sync<Elements.Core.bool3>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => HighPriorityIntegration, 
				4 => FilterMode, 
				5 => AnisotropicLevel, 
				6 => MipmapBias, 
				7 => Profile, 
				8 => Size, 
				9 => Mipmaps, 
				10 => Format, 
				11 => RGB_Mask, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static DebugDirectionCubemap __New()
		{
			return new DebugDirectionCubemap();
		}
	}
