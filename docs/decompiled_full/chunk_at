		public static LayoutHorizontalAlignment GetHorizontalLayout(this Alignment align)
		{
			switch (align)
			{
			case Alignment.TopLeft:
			case Alignment.MiddleLeft:
			case Alignment.BottomLeft:
				return LayoutHorizontalAlignment.Left;
			case Alignment.TopCenter:
			case Alignment.MiddleCenter:
			case Alignment.BottomCenter:
				return LayoutHorizontalAlignment.Center;
			case Alignment.TopRight:
			case Alignment.MiddleRight:
			case Alignment.BottomRight:
				return LayoutHorizontalAlignment.Right;
			default:
				throw new Exception("Invalid Alignment: " + align);
			}
		}

		public static LayoutVerticalAlignment GetVerticalLayout(this Alignment align)
		{
			switch (align)
			{
			case Alignment.BottomLeft:
			case Alignment.BottomCenter:
			case Alignment.BottomRight:
				return LayoutVerticalAlignment.Bottom;
			case Alignment.MiddleLeft:
			case Alignment.MiddleCenter:
			case Alignment.MiddleRight:
				return LayoutVerticalAlignment.Middle;
			case Alignment.TopLeft:
			case Alignment.TopCenter:
			case Alignment.TopRight:
				return LayoutVerticalAlignment.Top;
			default:
				throw new Exception("Invalid Alignment: " + align);
			}
		}
