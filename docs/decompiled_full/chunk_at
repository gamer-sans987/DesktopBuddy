			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => _current, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static SlideSwapRegion __New()
		{
			return new SlideSwapRegion();
		}
	}
