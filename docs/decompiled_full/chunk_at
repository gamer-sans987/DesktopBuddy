				Elements.Assets.TriangleSubmesh triangleSubmesh;
				for (int i = 0; i < value.Count; i++)
				{
					triangleSubmesh = value[i];
					if (triangleSubmesh.Index >= MinimumSubmeshIndex)
					{
						CurrentMaxSubmeshIndex = MathX.Max(triangleSubmesh.Index, CurrentMaxSubmeshIndex);
