			Elements.Core.float3 spacePoint = GetCanvasPoint().xy_;
			Elements.Core.floatQ spaceRotation = Elements.Core.floatQ.Identity;
			Elements.Core.float3 spaceScale = base.Slot.LocalScaleToSpace(1f, canvas.Slot) * Elements.Core.float3.One;
			ICanvasPointProjector componentInParents = base.Slot.GetComponentInParents<ICanvasPointProjector>();
			if (componentInParents != null)
			{
				Slot slot = componentInParents.ProjectTransform(canvas, ref spacePoint, ref spaceRotation, ref spaceScale);
				if (slot != null)
				{
					target.ActiveSelf = true;
					if (target.Parent != slot)
					{
						target.SetParent(slot, keepGlobalTransform: false);
					}
					target.LocalPosition = spacePoint;
					target.LocalRotation = spaceRotation;
					target.LocalScale = spaceScale;
				}
				else
				{
					target.ActiveSelf = false;
				}
			}
			else
			{
				Slot parent = target.Parent;
				target.ActiveSelf = true;
				if (parent != _originalParent.Target)
				{
					target.SetParent(_originalParent.Target, keepGlobalTransform: false);
				}
				target.LocalPosition = parent.SpacePointToLocal(in spacePoint, canvas.Slot);
				target.LocalRotation = parent.SpaceRotationToLocal(in spaceRotation, canvas.Slot);
				target.LocalScale = parent.SpaceScaleToLocal(in spaceScale, canvas.Slot);
			}
		}

