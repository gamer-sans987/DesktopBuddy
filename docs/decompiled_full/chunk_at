		public readonly Sync<string> Closed;

		public readonly Sync<string> Opened;

		public readonly Sync<string> Empty;

		public readonly SyncDelegate<Func<bool>> CustomEmptyCheck;

		private Slot _setupSectionRoot;

		private Slot _setupChildrenRoot;

		protected override void OnInit()
		{
			Closed.Value = "▶";
			Opened.Value = "▼";
			Empty.Value = "●";
		}

		protected override void OnChanges()
		{
			if (!Text.IsLinkValid || SectionRoot.Target == null || ChildrenRoot.Target == null)
			{
				return;
			}
			if (_setupSectionRoot != SectionRoot.Target)
			{
				if (_setupSectionRoot != null)
				{
					_setupSectionRoot.ActiveChanged -= ActiveChanged;
				}
				_setupSectionRoot = SectionRoot.Target;
				_setupSectionRoot.ActiveChanged += ActiveChanged;
			}
			if (_setupChildrenRoot != ChildrenRoot.Target)
			{
				if (_setupChildrenRoot != null)
