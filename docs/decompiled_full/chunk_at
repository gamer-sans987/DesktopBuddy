					_setupChildrenRoot.ChildRemoved -= ChildrenChanged;
				}
				_setupChildrenRoot = ChildrenRoot.Target;
				_setupChildrenRoot.ChildAdded += ChildrenChanged;
				_setupChildrenRoot.ChildRemoved += ChildrenChanged;
			}
			if (CustomEmptyCheck.Target?.Invoke() ?? (ChildrenRoot.Target.ChildrenCount == 0))
			{
