	public static class LayoutHelper
	{
		public struct Element
		{
			public float size;

			public float offset;

			public float min;

			public float grow;

			public float flexible;

			public Element(LayoutMetrics metrics)
			{
				size = 0f;
				offset = 0f;
				min = metrics.min;
				grow = MathX.Max(0f, metrics.preferred - min);
				flexible = MathX.Max(0f, metrics.flexible);
			}
		}

		public enum ElementAlign
		{
			Start,
			Middle,
			End,
			Justify
		}

		public enum MetricsMode
		{
			Total,
			Largest
		}

		public static void ComputeCombinedMetrics(MetricsMode mode, LayoutDirection direction, RectTransform rootRect, float padding, float spacing, ref float minSize, ref float prefSize, ref float flexibleSize)
		{
			minSize = 0f;
			prefSize = 0f;
			flexibleSize = 0f;
			int num = 0;
			foreach (RectTransform layoutChild in rootRect.LayoutChildren)
			{
				LayoutMetrics metrics = layoutChild.GetMetrics(direction);
				switch (mode)
				{
				case MetricsMode.Total:
					minSize += metrics.min;
					prefSize += metrics.preferred;
					flexibleSize += metrics.flexible;
					break;
				case MetricsMode.Largest:
					minSize = MathX.Max(minSize, metrics.min);
					prefSize = MathX.Max(prefSize, metrics.preferred);
					flexibleSize += metrics.flexible;
					break;
				}
				num++;
			}
			if (mode == MetricsMode.Largest && num >= 0)
			{
				flexibleSize /= num;
			}
			float num2 = padding + spacing * (float)MathX.Max(0, num - 1);
			minSize += num2;
			prefSize += num2;
		}

		public static void DistributeElements(float totalSize, float spacing, float offset, ElementAlign align, RawValueList<Element> elements, bool forceExpand)
		{
			float num = totalSize;
			num -= spacing * (float)MathX.Max(elements.Count - 1, 0);
			for (int i = 0; i < elements.Count; i++)
			{
				ref Element reference = ref elements.Elements[i];
				reference.size = reference.min;
				num -= reference.min;
			}
			if (num > 0f)
			{
				float num2 = 0f;
				for (int j = 0; j < elements.Count; j++)
				{
					num2 += elements.Elements[j].grow;
				}
				if (num2 > 0f)
				{
					float num3 = MathX.Min(1f, num / num2);
					for (int k = 0; k < elements.Count; k++)
					{
						ref Element reference2 = ref elements.Elements[k];
						reference2.size += reference2.grow * num3;
					}
					num -= num2 * num3;
				}
			}
			if (num > 0f)
			{
				float num4 = 0f;
				for (int l = 0; l < elements.Count; l++)
				{
					num4 += elements.Elements[l].flexible;
				}
				if (num4 > 0f)
				{
					float num5 = 1f / num4;
					for (int m = 0; m < elements.Count; m++)
					{
						ref Element reference3 = ref elements.Elements[m];
						reference3.size += num * num5 * reference3.flexible;
					}
					num = 0f;
				}
			}
			if (num > 0f && forceExpand && elements.Count > 0)
			{
				float num6 = num / (float)elements.Count;
				for (int n = 0; n < elements.Count; n++)
				{
					elements.Elements[n].size += num6;
				}
				num = 0f;
			}
			float num7 = offset;
			switch (align)
			{
			case ElementAlign.Middle:
				num7 += num * 0.5f;
				break;
			case ElementAlign.End:
				num7 += num;
				break;
			case ElementAlign.Justify:
				if (elements.Count >= 2)
				{
					spacing += num / (float)(elements.Count - 1);
				}
				break;
			}
			for (int num8 = 0; num8 < elements.Count; num8++)
			{
				ref Element reference4 = ref elements.Elements[num8];
				reference4.offset = num7;
				num7 += reference4.size + spacing;
			}
		}

		public static void ComputeOverlappingHorizontalLayout(this EnumerableWrapper<RectTransform, RectTransform.LayoutChildEnumerator> children, float x, float availableWidth, bool forceExpand, LayoutHorizontalAlignment align)
		{
			if (forceExpand)
			{
				foreach (RectTransform item in children)
				{
					item.SetHorizontalLayoutRect(x, availableWidth);
				}
				return;
			}
			foreach (RectTransform item2 in children)
			{
				LayoutMetrics metrics = item2.GetMetrics(LayoutDirection.Horizontal);
				float num = x;
				float num2 = ((!(metrics.flexible > 0f)) ? MathX.Max(metrics.min, MathX.Min(metrics.preferred, availableWidth)) : availableWidth);
				float num3 = availableWidth - num2;
				switch (align)
				{
				case LayoutHorizontalAlignment.Center:
				case LayoutHorizontalAlignment.Justify:
					num += num3 * 0.5f;
					break;
				case LayoutHorizontalAlignment.Right:
					num += num3;
					break;
				}
				item2.SetHorizontalLayoutRect(num, num2);
			}
		}

		public static void ComputeOverlappingVerticalLayout(this EnumerableWrapper<RectTransform, RectTransform.LayoutChildEnumerator> children, float y, float availableHeight, bool forceExpand, LayoutVerticalAlignment align)
