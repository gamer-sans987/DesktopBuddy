			foreach (float num2 in proportions)
			{
				RectTransform component = Empty("Split").GetComponent<RectTransform>();
				component.AnchorMin.Value = new Elements.Core.float2(num);
				component.AnchorMax.Value = new Elements.Core.float2(num + num2, 1f);
