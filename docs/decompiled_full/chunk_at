		public DistanceResult<T> FindNearest<T>(Elements.Core.float2 point, Predicate<T> filter = null) where T : class
		{
			point = ParentPointToLocal(point);
			T component = base.Slot.GetComponent(filter);
			DistanceResult<T> result = new DistanceResult<T>(null, float.MaxValue);
			if (component != null)
			{
				float distance = _commitedRect.Distance(in point);
				result = new DistanceResult<T>(component, distance);
			}
			for (int i = 0; i < _children.Count; i++)
			{
				DistanceResult<T> distanceResult = _children[i].FindNearest(point, filter);
				if (distanceResult.distance < result.distance)
				{
					result = distanceResult;
				}
			}
			return result;
		}

