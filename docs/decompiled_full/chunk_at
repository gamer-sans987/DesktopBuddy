			List<RectTransform> list = new List<RectTransform>();
			float num = 1f;
			foreach (float num2 in proportions)
			{
				RectTransform component = Empty("Split").GetComponent<RectTransform>();
				component.AnchorMin.Value = new Elements.Core.float2(0f, num - num2);
				component.AnchorMax.Value = new Elements.Core.float2(1f, num);
				num -= num2;
				list.Add(component);
			}
			return list;
		}

