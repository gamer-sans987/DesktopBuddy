		public static ValueOptionDescriptionDriver<T> EnsureOptionDescriptionDriver<T>(this Button button, IField<T> target, bool setupLabel = true, bool setupSprite = false, Elements.Core.colorX? overrideTintBase = null, bool setupColor = true)
		{
			bool attached;
			ValueOptionDescriptionDriver<T> componentOrAttach = button.Slot.GetComponentOrAttach<ValueOptionDescriptionDriver<T>>(out attached);
			componentOrAttach.Value.Target = target;
			if (attached)
			{
				if (setupLabel && button.Label != null)
				{
					if (button.Label.Content.ActiveLink?.FindNearestParent<Component>() is LocaleStringDriver localeStringDriver)
					{
						componentOrAttach.Label.Target = localeStringDriver.Format;
					}
					else
					{
						componentOrAttach.Label.Target = button.Label?.Content;
					}
				}
				if (setupColor)
				{
					componentOrAttach.Color.Target = button.BaseColor;
				}
				Image icon = button.Icon;
				if (icon != null)
				{
					componentOrAttach.SpriteTintBase.Value = overrideTintBase ?? ((Elements.Core.colorX)icon.Tint);
					componentOrAttach.SpriteTint.InsertLink(icon.Tint, componentOrAttach.SpriteTintBase);
					if (setupSprite)
					{
						if ((icon.Sprite.Target as SpriteProvider)?.Texture.Target is StaticTexture2D staticTexture2D && staticTexture2D.Slot == icon.Slot)
						{
							componentOrAttach.SpriteURL.Target = staticTexture2D.URL;
						}
						else
						{
							componentOrAttach.Sprite.Target = icon.Sprite;
						}
					}
				}
			}
			return componentOrAttach;
		}

