		private void RunLayoutPass(LayoutDirection direction, int depth, int pass)
		{
			if (_layoutController == null)
			{
				return;
			}
			if (NeedsToComputeLayout(direction))
			{
				MarkLayoutValid(direction);
				_layoutController.ComputeLayout(direction, depth, pass);
				if (!_layoutController.DeferChildLayouts)
				{
					foreach (RectTransform layoutChild in LayoutChildren)
					{
						layoutChild.RunLayoutPass(direction, depth + 1, pass);
					}
				}
			}
			else
			{
				float rectOffset = GetRectOffset(_lastLayoutRect, direction);
				float num = GetRectOffset(_rect, direction) - rectOffset;
				if (!MathX.Approximately(num, 0f))
				{
					TranslateLayout(num, direction);
				}
			}
			switch (direction)
			{
			case LayoutDirection.Horizontal:
				_lastLayoutRect.x = _rect.x;
				_lastLayoutRect.width = _rect.width;
				break;
			case LayoutDirection.Vertical:
				_lastLayoutRect.y = _rect.y;
				_lastLayoutRect.height = _rect.height;
				break;
			}
		}

