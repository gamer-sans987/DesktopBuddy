			Elements.Core.colorX b = ColorDrivers[0].NormalColor.Value * BaseColor.Value;
			BaseColor.Value = b;
			foreach (ColorDriver colorDriver in ColorDrivers)
			{
				if (colorDriver.TintColorMode.Value != ColorMode.Direct)
				{
					colorDriver.TintColorMode.Value = ColorMode.Additive;
					Sync<Elements.Core.colorX> normalColor = colorDriver.NormalColor;
					normalColor.Value -= b;
					Sync<Elements.Core.colorX> highlightColor = colorDriver.HighlightColor;
					highlightColor.Value -= b;
					Sync<Elements.Core.colorX> pressColor = colorDriver.PressColor;
					pressColor.Value -= b;
