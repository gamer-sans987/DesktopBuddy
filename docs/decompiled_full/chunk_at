		public LayoutMetrics ComputeMetrics(LayoutDirection direction, int? underPriorityLevel)
		{
			int i = 0;
			if (underPriorityLevel.HasValue)
			{
				for (; i < _layoutElements.Count && _layoutElements[i].Priority >= underPriorityLevel.Value; i++)
				{
				}
			}
			float? mainValue = null;
			float? mainValue2 = null;
			float? mainValue3 = null;
			int? currentPriority = null;
			int? currentPriority2 = null;
			int? currentPriority3 = null;
			int? num = null;
			for (; i < _layoutElements.Count; i++)
			{
				ILayoutElement layoutElement = _layoutElements[i];
				int priority = layoutElement.Priority;
				if (mainValue.HasValue && mainValue2.HasValue && mainValue3.HasValue && priority != num)
				{
					break;
				}
				layoutElement.EnsureValidMetrics(direction);
				float? newValue;
				float? newValue2;
				float? newValue3;
				switch (direction)
				{
				case LayoutDirection.Horizontal:
					newValue = layoutElement.MinWidth;
					newValue2 = layoutElement.PreferredWidth;
					newValue3 = layoutElement.FlexibleWidth;
					break;
				case LayoutDirection.Vertical:
					newValue = layoutElement.MinHeight;
					newValue2 = layoutElement.PreferredHeight;
					newValue3 = layoutElement.FlexibleHeight;
					break;
				default:
					throw new ArgumentOutOfRangeException("direction", "Direction: " + direction);
				}
				UpdateMetric(ref mainValue, newValue, ref currentPriority, priority);
				UpdateMetric(ref mainValue2, newValue2, ref currentPriority2, priority);
				UpdateMetric(ref mainValue3, newValue3, ref currentPriority3, priority);
				num = priority;
			}
			float rawRectTransformSize = GetRawRectTransformSize(direction);
			LayoutMetrics result = default(LayoutMetrics);
			result.min = mainValue ?? rawRectTransformSize;
			result.preferred = MathX.Max(result.min, mainValue2 ?? rawRectTransformSize);
			result.flexible = mainValue3.GetValueOrDefault();
			return result;
		}

		private static void UpdateMetric(ref float? mainValue, float? newValue, ref int? currentPriority, int priority)
		{
			if (!newValue.HasValue || !newValue.Value.IsValid() || currentPriority > priority)
			{
				return;
			}
			if (!mainValue.HasValue)
			{
				if (newValue.HasValue)
				{
					mainValue = newValue;
					currentPriority = priority;
				}
			}
			else if (newValue.HasValue)
			{
				mainValue = MathX.Max(mainValue.Value, newValue.Value);
			}
		}

