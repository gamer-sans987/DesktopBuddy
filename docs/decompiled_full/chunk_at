	public class AxisMultiViewportPanner : Component
	{
		public enum AlignDirection
		{
			LeftToRight,
			RightToLeft,
			TopToBottom,
			BottomToTop
		}

		public class Viewport : SyncObject
		{
			public readonly FieldDrive<Elements.Core.float2> AnchorMin;

			public readonly FieldDrive<Elements.Core.float2> AnchorMax;

			public readonly FieldDrive<bool> Active;

			protected override void InitializeSyncMembers()
			{
				base.InitializeSyncMembers();
				AnchorMin = new FieldDrive<Elements.Core.float2>();
				AnchorMax = new FieldDrive<Elements.Core.float2>();
				Active = new FieldDrive<bool>();
			}

			public override ISyncMember GetSyncMember(int index)
			{
				return index switch
				{
					0 => AnchorMin, 
					1 => AnchorMax, 
					2 => Active, 
					_ => throw new ArgumentOutOfRangeException(), 
				};
			}

			public static Viewport __New()
			{
				return new Viewport();
			}
		}

		public readonly Sync<int> ViewportIndex;

		public readonly Sync<float> AnimationTime;

		public readonly Sync<AlignDirection> Direction;

		public readonly SyncList<Viewport> Viewports;

		private float _position = -1f;

		public void AddViewport(RectTransform rect)
		{
			Viewport viewport = Viewports.Add();
			viewport.AnchorMin.Target = rect.AnchorMin;
			viewport.AnchorMax.Target = rect.AnchorMax;
			viewport.Active.Target = rect.Slot.ActiveSelf_Field;
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			AnimationTime.Value = 0.25f;
			Direction.Value = AlignDirection.LeftToRight;
		}

		protected override void OnStart()
		{
			base.OnStart();
			_position = ViewportIndex.Value;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			if (Viewports.Count == 0)
			{
				return;
			}
			int num = MathX.Clamp(ViewportIndex, 0, Viewports.Count);
			float position = _position;
			_position = MathX.ConstantLerp(_position, num, base.Time.Delta / AnimationTime.Value);
			if (position != _position)
			{
				MarkChangeDirty();
			}
			for (int i = 0; i < Viewports.Count; i++)
			{
				Viewport viewport = Viewports[i];
				float num2 = (float)i - _position;
				bool flag = !(num2 <= -1f) && !(num2 >= 1f);
				if (!flag && viewport.Active.IsLinkValid)
				{
					viewport.Active.Target.Value = false;
					continue;
				}
				if (viewport.Active.IsLinkValid)
				{
					viewport.Active.Target.Value = true;
				}
				Elements.Core.float2 value = Elements.Core.float2.Zero;
				Elements.Core.float2 value2 = Elements.Core.float2.One;
				if (flag)
				{
					num2 = MathX.SmootherStep(MathX.Abs(num2)) * (float)MathX.Sign(num2);
				}
				switch (Direction.Value)
				{
				case AlignDirection.LeftToRight:
					value = new Elements.Core.float2(num2);
					value2 = new Elements.Core.float2(num2 + 1f, 1f);
					break;
				case AlignDirection.RightToLeft:
					value = new Elements.Core.float2(0f - num2);
					value2 = new Elements.Core.float2(1f - num2, 1f);
					break;
				case AlignDirection.TopToBottom:
					value = new Elements.Core.float2(0f, num2);
					value2 = new Elements.Core.float2(1f, num2 + 1f);
					break;
				case AlignDirection.BottomToTop:
					value = new Elements.Core.float2(0f, 0f - num2);
					value2 = new Elements.Core.float2(1f, 1f - num2);
					break;
				}
				if (viewport.AnchorMin.IsLinkValid)
				{
					viewport.AnchorMin.Target.Value = value;
				}
				if (viewport.AnchorMax.IsLinkValid)
				{
					viewport.AnchorMax.Target.Value = value2;
				}
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			ViewportIndex = new Sync<int>();
			AnimationTime = new Sync<float>();
			Direction = new Sync<AlignDirection>();
			Viewports = new SyncList<Viewport>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => ViewportIndex, 
				4 => AnimationTime, 
				5 => Direction, 
				6 => Viewports, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

