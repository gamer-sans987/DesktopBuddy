			public readonly Sync<Elements.Core.colorX> HighlightColor;

			public readonly Sync<Elements.Core.colorX> PressColor;

			public readonly Sync<Elements.Core.colorX> DisabledColor;

			protected override void OnAwake()
			{
				base.OnAwake();
				NormalColor.Value = Elements.Core.colorX.White;
				HighlightColor.Value = MathX.Lerp(Elements.Core.colorX.White, Elements.Core.colorX.Yellow, 0.2f);
				PressColor.Value = MathX.Lerp(Elements.Core.colorX.White, new Elements.Core.colorX(1f, 0.75f, 0f), 0.4f);
				DisabledColor.Value = new Elements.Core.colorX(0.65f);
				ColorDrive.SetupValueSetHook(delegate(IField<Elements.Core.colorX> f, Elements.Core.colorX c)
				{
					SetColors(in c);
				});
			}

			public Elements.Core.colorX GetColor(in Elements.Core.colorX color, in Elements.Core.colorX baseColor)
			{
				return TintColorMode.Value switch
				{
					ColorMode.Additive => baseColor + color, 
					ColorMode.Multiply => NormalColor.Value * color * baseColor, 
					ColorMode.Direct => color, 
					_ => color * baseColor, 
				};
			}

			public void UpdateColor(in Elements.Core.colorX baseColor, bool enabled, bool hovering, bool pressed)
			{
				if (!ColorDrive.IsLinkValid)
				{
					return;
				}
				if (!enabled)
				{
					ColorDrive.Target.Value = DisabledColor.Value;
					return;
				}
				if (pressed)
				{
					ColorDrive.Target.Value = GetColor(PressColor.Value, in baseColor);
					return;
				}
				if (hovering)
				{
					ColorDrive.Target.Value = GetColor(HighlightColor.Value, in baseColor);
					return;
				}
				switch (TintColorMode.Value)
				{
				case ColorMode.Direct:
					ColorDrive.Target.Value = NormalColor.Value;
					break;
				case ColorMode.Multiply:
					ColorDrive.Target.Value = NormalColor.Value * baseColor;
					break;
				default:
					ColorDrive.Target.Value = GetColor((Elements.Core.colorX)NormalColor, in baseColor);
					break;
				}
			}

			public void SetColors(in Elements.Core.colorX c)
			{
				NormalColor.Value = c;
				ColorHSV colorHSV = new ColorHSV(in c);
				bool flag = colorHSV.s >= 0.1f;
				if (colorHSV.v < 0.5f)
				{
					HighlightColor.Value = new ColorHSV(colorHSV.h, colorHSV.s, colorHSV.v + 0.25f).ToRGB(c.profile);
					PressColor.Value = new ColorHSV(colorHSV.h, flag ? MathX.Clamp01(colorHSV.s + 0.2f) : colorHSV.s, colorHSV.v + 0.5f).ToRGB(c.profile);
					DisabledColor.Value = new Elements.Core.colorX(0.45f);
				}
				else
				{
					HighlightColor.Value = new ColorHSV(colorHSV.h, colorHSV.s, colorHSV.v - 0.25f).ToRGB(c.profile);
					PressColor.Value = new ColorHSV(colorHSV.h, flag ? MathX.Clamp01(colorHSV.s + 0.2f) : colorHSV.s, colorHSV.v - 0.5f).ToRGB(c.profile);
					DisabledColor.Value = new Elements.Core.colorX(0.65f);
				}
			}

