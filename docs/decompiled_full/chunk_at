	public class TiledRawImage : Graphic
	{
		public enum TileSizeBasis
		{
			Absolute,
			RectWidth,
			RectHeight
		}

		public readonly AssetRef<ITexture2D> Texture;

		public readonly AssetRef<Material> Material;

		public readonly Sync<Elements.Core.colorX> Tint;

