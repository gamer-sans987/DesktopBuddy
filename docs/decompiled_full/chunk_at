		public bool ProcessEvent(Canvas.InteractionData eventData)
		{
			Image component = base.Slot.GetComponent<Image>();
			if (component == null)
			{
				return false;
			}
			Elements.Core.colorX value = component.Tint.Value.SetB(0f).SetA(1f);
			switch (eventData.hover)
			{
			case EventState.Begin:
				value = value.SetR(1f);
				break;
			case EventState.Stay:
				value = value.SetR(0.5f);
				break;
			case EventState.End:
				value = value.SetR(0f);
				break;
			}
			switch (eventData.touch)
			{
			case EventState.Begin:
				value = value.SetG(1f);
				break;
			case EventState.Stay:
				value = value.SetG(0.5f);
				break;
			case EventState.End:
				value = value.SetG(0f);
				break;
			}
			component.Tint.Value = value;
			return true;
		}

