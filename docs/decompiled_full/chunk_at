				LayoutMetrics metrics = item2.GetMetrics(LayoutDirection.Vertical);
				float num = y;
				float num2 = ((!(metrics.flexible > 0f)) ? MathX.Max(metrics.min, MathX.Min(metrics.preferred, availableHeight)) : availableHeight);
				float num3 = availableHeight - num2;
				switch (align)
				{
				case LayoutVerticalAlignment.Middle:
				case LayoutVerticalAlignment.Justify:
					num += num3 * 0.5f;
					break;
				case LayoutVerticalAlignment.Top:
					num += num3;
					break;
				}
				item2.SetVerticalLayoutRect(num, num2);
			}
		}
