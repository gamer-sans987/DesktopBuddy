			private IAssetProvider<Material> CloneMaterial(IUIX_Material uixMaterial)
			{
				materialSetupDirty = true;
				Slot slot = Chunk.ChunkSlot.AddSlot("UIX_Material");
				MaterialProvider materialProvider = (MaterialProvider)uixMaterial;
				MaterialProvider materialProvider2 = slot.DuplicateComponent(materialProvider);
				for (int i = 0; i < materialProvider2.SyncMemberCount; i++)
				{
					ISyncMember syncMember = materialProvider2.GetSyncMember(i);
					ISyncMember syncMember2 = materialProvider.GetSyncMember(i);
					if (syncMember is AssetRef<Shader> assetRef)
					{
						assetRef.Target = null;
					}
					else
					{
						if (!syncMember.IsDrivable || syncMember2 == uixMaterial.StencilComparison || syncMember2 == uixMaterial.StencilOperation || syncMember2 == uixMaterial.StencilID || syncMember2 == uixMaterial.StencilWriteMask || syncMember2 == uixMaterial.StencilReadMask || syncMember2 == uixMaterial.ColorMask || syncMember2 == uixMaterial.Rect || syncMember2 == uixMaterial.RectClip || syncMember2 == uixMaterial.RenderQueue)
						{
							continue;
						}
						if (!(syncMember is ISyncRef reference))
						{
							if (syncMember is IField field)
							{
								IField source = syncMember2 as IField;
								field.DriveFrom(source, writeBack: false, keepOriginalValue: false, searchForDuplicate: false);
							}
						}
						else
						{
							ISyncRef source2 = syncMember2 as ISyncRef;
							reference.DriveFromRef(source2, writeBack: false, keepOriginalValue: false, searchForDuplicate: false);
						}
					}
				}
				return materialProvider2;
			}

