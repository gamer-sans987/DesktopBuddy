	public class SlideSwapRegion : Component
	{
		public enum Slide
		{
			None,
			Left,
			Right
		}

		protected readonly SyncRef<RectTransform> _current;

		protected override void OnAttach()
		{
			base.OnAttach();
			base.Slot.AttachComponent<Mask>();
			base.Slot.AttachComponent<Image>();
		}

		public UIBuilder Swap(Slide slide, float duration = 0.5f)
		{
			RectTransform rectTransform = base.Slot.AddSlot("Content").AttachComponent<RectTransform>();
			RectTransform target = _current.Target;
			rectTransform.Slot.AttachComponent<GraphicChunkRoot>();
			switch (slide)
			{
			case Slide.Left:
				rectTransform.AnchorMin.TweenFrom(new Elements.Core.float2(1f), duration);
				rectTransform.AnchorMax.TweenFrom(new Elements.Core.float2(2f, 1f), duration);
				if (target != null)
				{
					target.AnchorMin.TweenTo(new Elements.Core.float2(-1f), duration);
					target.AnchorMax.TweenTo(new Elements.Core.float2(0f, 1f), duration, CurvePreset.Sine, target.Slot.Destroy);
				}
				break;
			case Slide.Right:
				rectTransform.AnchorMin.TweenFrom(new Elements.Core.float2(-1f), duration);
				rectTransform.AnchorMax.TweenFrom(new Elements.Core.float2(0f, 1f), duration);
				if (target != null)
				{
					target.AnchorMin.TweenTo(new Elements.Core.float2(1f), duration);
					target.AnchorMax.TweenTo(new Elements.Core.float2(2f, 1f), duration, CurvePreset.Sine, target.Slot.Destroy);
				}
				break;
			case Slide.None:
				target?.Slot?.Destroy();
				break;
			}
			_current.Target = rectTransform;
			return new UIBuilder(rectTransform);
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			_current = new SyncRef<RectTransform>();
		}

