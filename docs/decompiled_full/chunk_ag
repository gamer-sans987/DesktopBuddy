		{
			if (_scaleReference.Target != null)
			{
				if (_scaleReference.Target.GrabbedObjects.Count == 0)
				{
					_scaleReference.Target = null;
					return;
				}
				float num = MathX.Distance(HolderSlot.GlobalPosition, _scaleReference.Target.HolderSlot.GlobalPosition) / _baseDistance.Value;
				_scaleReference.Target.HolderSlot.LocalScale = _baseScale.Value * num;
			}
		}

		public bool Grab(Elements.Core.float3 point, float radius)
		{
			List<ICollider> list = Pool.BorrowList<ICollider>();
			base.World.Physics.SphereOverlap(in point, radius, list);
			bool result = Grab(list);
			Pool.Return(ref list);
			return result;
		}

		public bool Grab(List<ICollider> colliders, Predicate<IGrabbable> filter = null, bool includeDynamic = true, bool singleItem = false)
		{
			List<IGrabbable> list = Pool.BorrowList<IGrabbable>();
			HashSet<IGrabbable> hashSet = Pool.BorrowHashSet<IGrabbable>();
			foreach (ICollider collider in colliders)
			{
				IGrabbable grabbable = FindGrabbableInParents(collider.Slot, filter);
				if (grabbable != null && hashSet.Add(grabbable))
				{
					list.Add(grabbable);
				}
			}
			if (includeDynamic)
			{
				foreach (IGrabbable dynamicGrabbable in base.World.GetDynamicGrabbables())
				{
					if ((filter == null || filter(dynamicGrabbable)) && hashSet.Add(dynamicGrabbable))
					{
						list.Add(dynamicGrabbable);
					}
				}
			}
			Pool.Return(ref hashSet);
			bool result = Grab(list, singleItem);
			Pool.Return(ref list);
			return result;
		}

		public bool Grab(List<IGrabbable> grabbables, bool singleItem)
		{
			bool flag = false;
			grabbables.RemoveAll((IGrabbable g) => !g.IsGrabbed && !g.CanGrab(this));
			if (grabbables.Count == 0)
			{
				return false;
			}
			base.World.BeginUndoBatch("Undo.GrabObjects".AsLocaleKey());
			if (!singleItem)
			{
				grabbables.Sort(delegate(IGrabbable a, IGrabbable b)
				{
					bool flag2 = a.CanGrab(this);
					bool flag3 = b.CanGrab(this);
					if (flag2 == flag3)
					{
						return -a.GrabPriority.CompareTo(b.GrabPriority);
					}
					return (!flag2) ? 1 : (-1);
				});
			}
			int? num = null;
			foreach (IGrabbable grabbable2 in grabbables)
			{
				if (num.HasValue && grabbable2.GrabPriority != num.Value)
				{
					break;
				}
				if (!ShouldGrab(grabbable2, singleItem ? null : grabbables))
				{
					continue;
				}
				IGrabbable grabbable = grabbable2.Grab(this, HolderSlot);
				if (grabbable != null)
				{
					_grabbedObjects.Add(grabbable);
					flag = true;
				}
				else if (_scaleReference.Target == null)
				{
					Grabber grabber = grabbable2.Grabber;
					if (grabber != null && grabber != this && grabber.Slot.ActiveUserRoot?.ActiveUser == base.World.LocalUser && grabber.CanScaleHeldObjects)
					{
						_scaleReference.Target = grabber;
						_baseScale.Value = grabber.HolderSlot.LocalScale;
						_baseDistance.Value = MathX.Distance(HolderSlot.GlobalPosition, _scaleReference.Target.HolderSlot.GlobalPosition);
						flag = true;
					}
				}
				if (flag)
				{
					num = grabbable2.GrabPriority;
					if (singleItem)
					{
						break;
					}
				}
			}
			base.World.EndUndoBatch();
			return flag;
		}

		public bool Grab(IGrabbable grabbable)
		{
			if (!ShouldGrab(grabbable, null))
			{
				return false;
			}
			IGrabbable grabbable2 = grabbable.Grab(this, HolderSlot);
			if (grabbable2 != null)
			{
				_grabbedObjects.Add(grabbable2);
				return true;
			}
			return false;
		}

		public bool ShouldGrab(IGrabbable grabbable, List<IGrabbable> grabbables)
		{
			if (grabbable.Slot.IsChildOf(base.Slot))
			{
				return false;
			}
			if (grabbables != null)
			{
				foreach (IGrabbable grabbable2 in grabbables)
				{
					if (grabbable2.CanGrab(this) && grabbable.GrabPriority == grabbable2.GrabPriority && grabbable.Slot.IsChildOf(grabbable2.Slot))
					{
						return false;
					}
				}
			}
			return true;
		}

		public void Release(bool supressEvents = false)
		{
			Slot holderSlot = HolderSlot;
			CleanupGrabbed();
			if (_grabbedObjects.Count > 0)
			{
				Elements.Core.BoundingSphere boundingSphere = Elements.Core.BoundingSphere.FromBoundingBox(holderSlot?.ComputeBoundingBox() ?? Elements.Core.BoundingBox.Empty());
				foreach (IGrabbable grabbedObject in _grabbedObjects)
				{
					if (grabbedObject != null && !grabbedObject.IsRemoved)
					{
						grabbedObject.Release(this, supressEvents);
					}
				}
				_grabbedObjects.RemoveAll((IGrabbable g) => !g.Receivable);
				if (boundingSphere.IsValid && _grabbedObjects.Count > 0)
				{
					Elements.Core.float3 point = boundingSphere.center;
					float radius = boundingSphere.radius * (float)ReleaseCheckRadius;
					if (!supressEvents)
					{
						InformOfReleasedObjects(_grabbedObjects, base.World, point, radius);
					}
					if (_grabbedObjects.Count > 0 && base.World != Userspace.UserspaceWorld && Userspace.UserspaceWorld != null)
					{
						List<IGrabbable> list = Pool.BorrowList<IGrabbable>();
						list.AddRange(_grabbedObjects);
						point = WorldManager.TransferPoint(point, base.World, Userspace.UserspaceWorld);
						radius = WorldManager.TransferScale(radius, base.World, Userspace.UserspaceWorld);
						if (!supressEvents)
						{
							Userspace.UserspaceWorld.RunSynchronously(delegate
							{
								InformOfReleasedObjects(list, Userspace.UserspaceWorld, point, radius);
								Pool.Return(ref list);
							});
						}
					}
				}
				_grabbedObjects.Clear();
			}
			if (holderSlot != null)
			{
				holderSlot.LocalScale = Elements.Core.float3.One;
			}
			_scaleReference.Target = null;
		}

		public void Release(IGrabbable grabbable, bool supressEvents = false)
		{
			grabbable.Release(this, supressEvents);
			_grabbedObjects.Remove(grabbable);
		}

		private void InformOfReleasedObjects(List<IGrabbable> objects, World world, Elements.Core.float3 point, float radius)
		{
			HashSet<IGrabbableReceiver> hashSet = Pool.BorrowHashSet<IGrabbableReceiver>();
			List<ICollider> list = Pool.BorrowList<ICollider>();
			if (!float.IsNaN(radius) && !float.IsInfinity(radius) && !point.IsInfinity && !point.IsNaN && radius < 100000f)
			{
				world.Physics.SphereOverlap(in point, radius, list);
			}
			foreach (ICollider item in list)
			{
				IGrabbableReceiver componentInParents = item.Slot.GetComponentInParents<IGrabbableReceiver>();
				if (componentInParents != null && componentInParents.Enabled && componentInParents.Slot.IsActive)
				{
					hashSet.Add(componentInParents);
				}
			}
			Pool.Return(ref list);
			if (hashSet.Count > 0)
			{
				HashSet<IGrabbable> received = Pool.BorrowHashSet<IGrabbable>();
				foreach (IGrabbable @object in objects)
				{
					float num = float.MaxValue;
					IGrabbableReceiver grabbableReceiver = null;
					foreach (IGrabbableReceiver item2 in hashSet)
					{
						float? receiveDistance = item2.GetReceiveDistance(@object, this);
						if (receiveDistance.HasValue && receiveDistance.Value < num)
						{
							num = receiveDistance.Value;
							grabbableReceiver = item2;
						}
					}
					if (grabbableReceiver != null)
					{
						grabbableReceiver.Receive(@object, this);
						received.Add(@object);
					}
				}
				objects.RemoveAll((IGrabbable g) => received.Contains(g));
				Pool.Return(ref received);
			}
			Pool.Return(ref hashSet);
		}

		public void DestroyGrabbed(bool preserveAssets = true)
		{
			CleanupGrabbed();
			base.World.BeginUndoBatch("Undo.DestroyGrabbed".AsLocaleKey());
			List<IGrabbable> list = Pool.BorrowList<IGrabbable>();
			try
			{
				foreach (IGrabbable grabbedObject in _grabbedObjects)
				{
					if (ItemHasInteractionBlock<IDestroyBlock>(grabbedObject.Slot))
					{
						list.Add(grabbedObject);
						continue;
					}
					grabbedObject.Release(this);
					Slot slot = GrabbableGetDestroyRoot(grabbedObject.Slot);
					IObjectRoot objectRoot = GrabbableGetComponentInParents<IObjectRoot>(grabbedObject.Slot);
					if (objectRoot != null && objectRoot.Slot.IsChildOf(slot))
					{
						slot = objectRoot.Slot;
					}
					if (preserveAssets)
					{
						slot.UndoableDestroyPreservingAssets();
					}
					else
					{
						slot.UndoableDestroy();
					}
				}
				_grabbedObjects.Clear();
				foreach (IGrabbable item in list)
				{
					_grabbedObjects.Add(item);
				}
			}
			catch (Exception ex)
			{
				base.Debug.Error("Exception destroying grabbed objects:\n" + ex);
			}
			Pool.Return(ref list);
			base.World.EndUndoBatch();
		}

		private Slot GrabbableGetDestroyRoot(Slot root)
		{
			return GrabbableGetComponentInParents(root, (IDestroyRoot r) => r.Enabled)?.Slot ?? root;
		}

		public T? GrabbableGetComponentInParents<T>(Slot root, Predicate<T>? filter = null, bool excludeDisabled = false) where T : class
		{
			if (root.ActiveUserRoot != null && root.GetComponent<Grabber>() != null)
			{
				return null;
			}
			T component = root.GetComponent(filter, excludeDisabled);
			if (component != null)
			{
				return component;
			}
			if (!root.Parent.IsRootSlot)
			{
				return GrabbableGetComponentInParents(root.Parent, filter, excludeDisabled);
			}
			return null;
		}

		/// <summary>
		/// Returns true if the grabber is holding ANY item that has a <typeparamref name="T" />
		/// </summary>
		/// <typeparam name="T">The type of action to check, must inherit from <see cref="T:FrooxEngine.IInteractionBlock" /></typeparam>
		/// <param name="excludeDisabled">True, if disabled copies of <typeparamref name="T" /> should be excluded</param>
		/// <returns>true if the action block was found, false otherwise.</returns>
		public bool IsHoldingInteractionBlock<T>(bool excludeDisabled = true) where T : class, IInteractionBlock
		{
			foreach (IGrabbable grabbedObject in GrabbedObjects)
			{
				if (ItemHasInteractionBlock<T>(grabbedObject.Slot, excludeDisabled))
				{
					return true;
				}
			}
			return false;
		}

		/// <summary>
		/// Checks if a Grabbed Item has a <typeparamref name="T" />
		/// </summary>
		/// <param name="itemRoot">Root Slot of the item</param>
		/// <inheritdoc cref="M:FrooxEngine.Grabber.IsHoldingInteractionBlock``1(System.Boolean)" />
		public bool ItemHasInteractionBlock<T>(Slot itemRoot, bool excludeDisabled = true) where T : class, IInteractionBlock
		{
			return GrabbableGetComponentInParents<T>(itemRoot, null, excludeDisabled) != null;
		}

		public IGrabbable? FindGrabbableInParents(Slot slot, Predicate<IGrabbable> filter)
		{
			if (slot.IsRootSlot)
			{
				return null;
			}
			if (slot.GetComponent<IGrabBlock>(null, excludeDisabled: true) != null)
			{
				return null;
			}
			IGrabbable component = slot.GetComponent((IGrabbable g) => (g.CanGrab(this) || g.Scalable) && (filter?.Invoke(g) ?? true), excludeDisabled: true);
			if (component != null)
			{
				return component;
			}
			if (slot.Parent.IsRootSlot || slot.GetComponent<SearchBlock>(null, excludeDisabled: true) != null)
			{
				return null;
			}
			return FindGrabbableInParents(slot.Parent, filter);
		}

