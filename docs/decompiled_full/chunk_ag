		{
			if (!base.World.CanTransferObjectsOut())
			{
				return;
			}
			BeforeUserspaceTransfer?.Invoke();
			CleanupGrabbed();
			if (focus != FrooxEngine.World.WorldFocus.Background || !IsHoldingObjects)
			{
				return;
			}
			foreach (IGrabbable grabbedObject in _grabbedObjects)
			{
				if (grabbedObject.Slot.GetComponentInChildren((IItemPermissions p) => !p.CanSave) != null)
				{
					return;
				}
			}
			if (HolderSlot.LocalPosition != Elements.Core.float3.Zero)
			{
				Elements.Core.float3 b = HolderSlot.LocalPosition;
				HolderSlot.LocalPosition = Elements.Core.float3.Zero;
				foreach (Slot child in HolderSlot.Children)
				{
					child.LocalPosition += b;
				}
			}
			bool flag = false;
			foreach (IGrabbable grabbedObject2 in _grabbedObjects)
			{
				if (Userspace.TryTransferToUserspaceGrabber(grabbedObject2.Slot, LinkingKey))
				{
					flag = true;
				}
			}
			if (flag)
			{
				DestroyGrabbed();
			}
		}

