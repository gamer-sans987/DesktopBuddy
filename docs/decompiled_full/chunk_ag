	public class FontDataManager : Component
	{
		private Dictionary<GlyphAtlasManager, Dictionary<MaterialProvider, MaterialProvider>> _materials = new Dictionary<GlyphAtlasManager, Dictionary<MaterialProvider, MaterialProvider>>();

		private Dictionary<GlyphAtlasManager, FontAtlasTexture> _textures = new Dictionary<GlyphAtlasManager, FontAtlasTexture>();

		protected override void OnAttach()
		{
			base.OnAttach();
		}

		public MaterialProvider GetMaterial(MaterialProvider template, GlyphAtlasManager atlas)
		{
			if (template == null)
			{
				return null;
			}
			if (!_materials.TryGetValue(atlas, out Dictionary<MaterialProvider, MaterialProvider> value))
			{
				atlas.Unloaded += AtlasUnloaded;
				value = new Dictionary<MaterialProvider, MaterialProvider>();
				_materials.Add(atlas, value);
			}
			if (value.TryGetValue(template, out var value2))
			{
				return value2;
			}
			value2 = base.Slot.AddSlot(null).DuplicateComponent(template);
			template.Destroyed += MaterialTemplateDestroyed;
			FontAtlasTexture texture = GetTexture(atlas);
			ITextMaterial textMaterial = value2 as ITextMaterial;
			if (textMaterial != null)
			{
				textMaterial.GlyphRenderMethod.Value = atlas.Atlas.RenderMethod;
				textMaterial.PixelRange.Value = atlas.Atlas.PixelRange;
				textMaterial.FontAtlas.Target = texture;
			}
			else if (value2 is ICommonMaterial commonMaterial)
			{
				commonMaterial.MainTexture = texture;
			}
			for (int i = 0; i < value2.SyncMemberCount; i++)
			{
				ISyncMember syncMember = value2.GetSyncMember(i);
				ISyncMember syncMember2 = template.GetSyncMember(i);
				if (syncMember is AssetRef<Shader> assetRef)
				{
					assetRef.Target = null;
				}
				else
				{
					if (!syncMember.IsDrivable)
					{
						continue;
					}
					if (!(syncMember is ISyncRef syncRef))
					{
						if (syncMember is IField field)
						{
							IField source = syncMember2 as IField;
							if (textMaterial == null || (textMaterial.PixelRange != field && textMaterial.GlyphRenderMethod != field))
							{
								field.DriveFrom(source, writeBack: false, keepOriginalValue: false, searchForDuplicate: false);
							}
						}
					}
					else if (syncRef.Target != texture && syncRef != textMaterial?.FontAtlas)
					{
						ISyncRef source2 = syncMember2 as ISyncRef;
						syncRef.DriveFromRef(source2, writeBack: false, keepOriginalValue: false, searchForDuplicate: false);
					}
				}
			}
			value.Add(template, value2);
			return value2;
		}

		public FontAtlasTexture GetTexture(GlyphAtlasManager atlas)
		{
			if (_textures.TryGetValue(atlas, out FontAtlasTexture value))
			{
				return value;
			}
			value = base.Slot.AttachComponent<FontAtlasTexture>();
			value.GlyphAtlas = atlas;
			_textures.Add(atlas, value);
			return value;
		}

		private void MaterialTemplateDestroyed(IDestroyable changeable)
		{
			RunSynchronously(delegate
			{
				MaterialProvider key = (MaterialProvider)changeable;
				foreach (KeyValuePair<GlyphAtlasManager, Dictionary<MaterialProvider, MaterialProvider>> material in _materials)
				{
					if (material.Value.TryGetValue(key, out var value))
					{
						value?.Slot?.Destroy();
						material.Value.Remove(key);
					}
				}
			});
		}

		protected override void OnDispose()
		{
			foreach (KeyValuePair<GlyphAtlasManager, Dictionary<MaterialProvider, MaterialProvider>> material in _materials)
			{
				material.Key.Unloaded -= AtlasUnloaded;
			}
			base.OnDispose();
		}

		private void AtlasUnloaded(GlyphAtlasManager atlas)
		{
			RunSynchronously(delegate
			{
				RemoveAtlas(atlas);
			});
		}

		public void RemoveAtlas(GlyphAtlasManager atlas)
		{
			if (_materials.TryGetValue(atlas, out Dictionary<MaterialProvider, MaterialProvider> value))
			{
				foreach (KeyValuePair<MaterialProvider, MaterialProvider> item in value)
				{
					item.Value?.Destroy();
				}
				_materials.Remove(atlas);
			}
			if (_textures.TryGetValue(atlas, out FontAtlasTexture value2))
			{
				value2.Destroy();
				_textures.Remove(atlas);
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static FontDataManager __New()
		{
			return new FontDataManager();
		}
	}
