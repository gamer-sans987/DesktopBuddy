		private async Task CameraUpdateTask()
		{
			while (!base.IsDestroyed)
			{
				World focusedWorld = base.Engine.WorldManager.FocusedWorld;
				lock (worldCameras)
				{
					if (!worldCameras.TryGetValue(focusedWorld, out _lastCamera) || (_lastCamera != null && _lastCamera.IsDestroyed))
					{
						InteractiveCamera last = _lastCamera;
						last?.RunSynchronously(delegate
						{
							last.Slot.Destroy();
						});
						_lastCamera = null;
						worldCameras.Remove(focusedWorld);
						worldCameras.Add(focusedWorld, null);
						SpawnCameraInWorld(focusedWorld);
					}
					else if (_lastCamera != null)
					{
						_renderTextureProxy.Target.SourceProvider = _lastCamera.PreviewTexture.Target;
					}
				}
				await default(NextUpdate);
			}
		}

		private void SpawnCameraInWorld(World targetWorld)
		{
			targetWorld.Coroutines.StartTask(async delegate
			{
				await default(ToWorld);
				Slot s = targetWorld.AddSlot("Interactive Camera");
				s.PersistentSelf = false;
				Uri uri = base.Cloud.Platform.GetSpawnObjectUri("Camera");
				if (targetWorld.CanSpawnObjects())
				{
					uri = base.Cloud.Profile?.GetCurrentFavorite(FavoriteEntity.Camera) ?? uri;
				}
				await s.LoadObjectAsync(uri);
				s = s.UnpackInventoryItem();
				InteractiveCamera componentInChildren = s.GetComponentInChildren<InteractiveCamera>();
				componentInChildren.Control = this;
				componentInChildren.Slot.PersistentSelf = false;
				lock (worldCameras)
				{
					if (worldCameras.TryGetValue(targetWorld, out InteractiveCamera value))
					{
						if (componentInChildren != value)
						{
							value?.Slot.Destroy();
						}
						worldCameras[targetWorld] = componentInChildren;
					}
					else
					{
						componentInChildren.Slot.Destroy();
					}
				}
			});
		}

