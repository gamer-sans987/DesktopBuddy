		public void SetUserGroupMode(User user, GroupMode mode)
		{
			string value = user.UserID ?? user.MachineID;
			GroupExcludeUsers.RemoveAll(value);
			GroupIncludeUsers.RemoveAll(value);
			switch (mode)
			{
			case GroupMode.Exclude:
				GroupExcludeUsers.Add(value);
				break;
			case GroupMode.Include:
				GroupIncludeUsers.Add(value);
				break;
			}
		}

