		{
			StartTask(PickColor);
		}

		private async Task PickColor()
		{
			RenderTask renderTask = new RenderTask(base.Tip, Elements.Core.floatQ.LookRotation(base.Slot.Forward));
			renderTask.parameters.fov = 1f;
			renderTask.parameters.resolution = Elements.Core.int2.One * 4;
			renderTask.parameters.postProcessing = false;
			renderTask.parameters.nearClip = 0.01f;
			renderTask.parameters.farClip = 2000f;
			renderTask.parameters.clearMode = CameraClearMode.Skybox;
			renderTask.excludeObjects = new List<Slot>();
			Slot slot = base.ActiveHandler?.Laser.Slot;
			if (slot != null)
			{
				renderTask.excludeObjects.Add(slot);
			}
			Bitmap2D bitmap2D = await base.World.Render.RenderToBitmap(renderTask).ConfigureAwait(continueOnCapturedContext: false);
			Elements.Core.colorX sum = Elements.Core.colorX.Clear;
			for (int i = 0; i < bitmap2D.Size.y; i++)
			{
				for (int j = 0; j < bitmap2D.Size.x; j++)
				{
					sum += new Elements.Core.colorX(bitmap2D[j, i]);
				}
			}
			sum *= 1f / (float)bitmap2D.MipmapTotalPixels(0);
			await default(ToWorld);
			Color.Value = sum.SetA(1f);
		}

