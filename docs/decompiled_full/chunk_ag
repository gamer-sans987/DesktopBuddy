		private static void GenerateDebugVisualIntern(BoneNode node, IAssetProvider<Material> material, float radius)
		{
			Slot slot = node.bone.AddSlot("DebugBonePoint");
			slot.PersistentSelf = false;
			slot.Tag = "RIG_DEBUG";
			float num = node.bone.GlobalScaleToLocal(radius);
			slot.AttachSphere(num * 1.5f, material, collider: false);
			foreach (BoneNode child in node.children)
			{
				float magnitude;
				Elements.Core.float3 forward = node.bone.GlobalPointToLocal(child.bone.GlobalPosition).GetNormalized(out magnitude);
				Slot slot2 = node.bone.AddSlot("DebugBoneLine");
				slot2.PersistentSelf = false;
				slot2.Tag = "RIG_DEBUG";
				slot2.LocalRotation = Elements.Core.floatQ.LookRotation(in forward) * Elements.Core.floatQ.FromToRotation(Elements.Core.float3.Forward, Elements.Core.float3.Up);
				slot2.LocalPosition = forward * magnitude * 0.5f;
				slot2.AttachCylinder(num, magnitude, material, collider: false);
				GenerateDebugVisualIntern(child, material, radius);
			}
		}

