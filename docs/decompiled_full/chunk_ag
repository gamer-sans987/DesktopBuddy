		private void PostProcessRenderSettings(RenderTask settings)
		{
			if (settings.excludeObjects == null)
			{
				settings.excludeObjects = new List<Slot>();
			}
			if (HideLasersOnCapture.Value)
			{
				InteractionHandler.GetLaserRoots(base.World.AllUsers, settings.excludeObjects);
			}
			foreach (User allUser in base.World.AllUsers)
			{
				if (allUser.HideInScreenshots && allUser.Root != null)
				{
					settings.excludeObjects.Add(allUser.Root.Slot);
				}
			}
		}

		public bool Capture(Mode mode, Elements.Core.int2 resolution, bool spawnInFrontOfUser = false)
		{
			RenderTask renderSettings;
			switch (mode)
			{
			case Mode.Camera2D:
				renderSettings = MainCamera.Target.GetRenderSettings(resolution);
				PostProcessRenderSettings(renderSettings);
				StartTask(async delegate
				{
					Uri texture = await base.World.Render.RenderToAsset(renderSettings, GetFormatExt(), GetQualitySetting());
					SpawnPhoto(texture, Mode.Camera2D, MainCamera.Target.FieldOfView, spawnInFrontOfUser);
				});
				return true;
			case Mode.Camera360:
				renderSettings = MainCamera.Target.GetRenderSettings(resolution);
				PostProcessRenderSettings(renderSettings);
				renderSettings.parameters.fov = 360f;
				renderSettings.position = (PanoramaIndicator.Target ?? base.Slot).GlobalPosition;
				renderSettings.rotation = Elements.Core.floatQ.Identity;
				renderSettings.excludeObjects = new List<Slot> { base.Slot };
				StartTask(async delegate
				{
					Uri texture = await base.World.Render.RenderToAsset(renderSettings, GetFormatExt(), GetQualitySetting());
					SpawnPhoto(texture, Mode.Camera360, 360f, spawnInFrontOfUser);
				});
				return true;
			case Mode.CameraObject:
			{
				Slot renderObject = RaycastRenderObject();
				if (renderObject != null)
				{
					renderSettings = MainCamera.Target.GetRenderSettings(resolution);
					PostProcessRenderSettings(renderSettings);
					if (ObjectAutoPose.Value)
					{
						renderObject.GetRenderPoint(out renderSettings.position, out renderSettings.rotation, resolution, MainCamera.Target.Slot.GlobalPosition, renderSettings.parameters.fov);
					}
					StartTask(async delegate
					{
						Uri texture = await renderObject.RenderToAsset(renderSettings, GetFormatExt(), GetQualitySetting());
						SpawnPhoto(texture, Mode.CameraObject, MainCamera.Target.FieldOfView, spawnInFrontOfUser);
					});
					return true;
				}
				break;
			}
			case Mode.CameraStereo:
				StartTask(async delegate
				{
					await RenderStereo(GetFormatExt(), GetQualitySetting());
				});
				return true;
			}
			return false;
		}

		private async Task RenderStereo(string formatExt, int quality, bool spawnInFrontOfUser = false)
		{
			Elements.Core.int2 resolution = GetSingleRenderResolution();
			RenderTask renderSettings = MainCamera.Target.GetRenderSettings(resolution);
			RenderTask renderSettings2 = SecondaryCamera.Target.GetRenderSettings(resolution);
			PostProcessRenderSettings(renderSettings);
			PostProcessRenderSettings(renderSettings2);
			Task<Bitmap2D> task = base.World.Render.RenderToBitmap(renderSettings);
			Task<Bitmap2D> rightTask = base.World.Render.RenderToBitmap(renderSettings2);
			Bitmap2D leftTex = await task.ConfigureAwait(continueOnCapturedContext: false);
			Bitmap2D source = await rightTask.ConfigureAwait(continueOnCapturedContext: false);
			Bitmap2D bitmap2D = new Bitmap2D(resolution.x * 2, resolution.y, leftTex.Format, mipmaps: false, ColorProfile.sRGB);
			bitmap2D.CopyFrom(leftTex, 0, 0, 0, 0, resolution.x, resolution.y);
			bitmap2D.CopyFrom(source, 0, 0, resolution.x, 0, resolution.x, resolution.y);
			Uri uri = await base.Engine.LocalDB.SaveAssetAsync(bitmap2D, formatExt, quality).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToWorld);
			SpawnPhoto(uri, Mode.CameraStereo, MainCamera.Target.FieldOfView, spawnInFrontOfUser);
		}

		private void SpawnPhoto(Uri texture, Mode mode, float fov, bool spawnInFrontOfUser = false)
		{
			bool canSpawn = SpawnPhotoInWorld.Value && base.World.CanSpawnObjects();
			Slot s;
			if (canSpawn)
			{
				s = base.LocalUserSpace.AddSlot("Image");
			}
			else
			{
				s = base.LocalUserRoot.Slot.AddLocalSlot("Image", persistent: true);
				s.LocalPosition = new Elements.Core.float3(0f, -10000f);
			}
			StaticTexture2D staticTexture2D = s.AttachTexture(texture, getExisting: true, uncompressed: false, directLoad: false, evenNull: false, (mode != Mode.Camera360) ? Renderite.Shared.TextureWrapMode.Clamp : Renderite.Shared.TextureWrapMode.Repeat);
			ImageImporter.SetupTextureProxyComponents(s, staticTexture2D, (mode == Mode.CameraStereo) ? StereoLayout.Horizontal_LR : StereoLayout.None, (mode == Mode.Camera360) ? ImageProjection.Equirectangular360 : ImageProjection.Perspective, setupPhotoMetadata: true);
			PhotoMetadata metadata = s.GetComponentInChildren<PhotoMetadata>();
			metadata.CameraManufacturer.Value = base.Engine.Cloud.Platform.Name;
			metadata.CameraModel.Value = CameraModelOverride.Value ?? "InteractiveCamera.cs";
			metadata.CameraFOV.Value = fov;
			s.AttachComponent<Grabbable>().Scalable.Value = true;
			if (mode == Mode.Camera360)
			{
				AttachedModel<IcoSphereMesh, Projection360Material> attachedModel = s.AttachMesh<IcoSphereMesh, Projection360Material>();
				attachedModel.material.Texture.Target = staticTexture2D;
				attachedModel.material.Projection.Value = Projection360Material.Mode.Normal;
				attachedModel.mesh.Subdivisions.Value = 2;
				s.AttachComponent<MeshCollider>().Mesh.Target = attachedModel.mesh;
				s.GlobalPosition = base.Slot.GlobalPosition;
			}
			else
			{
				AttachedModel<QuadMesh, UnlitMaterial> attachedModel2 = s.AttachMesh<QuadMesh, UnlitMaterial>();
				attachedModel2.material.Texture.Target = staticTexture2D;
				attachedModel2.material.Sidedness.Value = Sidedness.Double;
				TextureSizeDriver textureSizeDriver = s.AttachComponent<TextureSizeDriver>();
				textureSizeDriver.Texture.Target = staticTexture2D;
				textureSizeDriver.DriveMode.Value = TextureSizeDriver.Mode.Normalized;
				textureSizeDriver.Target.Target = attachedModel2.mesh.Size;
				if (canSpawn)
				{
					if (spawnInFrontOfUser)
					{
						s.Parent = base.LocalUserSpace;
						Slot slot = s;
						slot.LocalScale *= 0.35f;
						s.PositionInFrontOfUser(Elements.Core.float3.Backward);
					}
					else
					{
						Slot slot2 = PhotoSpawnPoint.Target ?? base.Slot;
						s.GlobalPosition = slot2.GlobalPosition + slot2.LocalVectorToGlobal(Elements.Core.float3.Backward * 0.005f * slot2.ChildrenCount);
						s.GlobalRotation = slot2.GlobalRotation;
						s.LocalScale = slot2.LocalScaleToGlobal(PhotoSpawnSize.Value) * Elements.Core.float3.One;
						s.Parent = slot2;
					}
				}
				BoxCollider boxCollider = s.AttachComponent<BoxCollider>();
				boxCollider.Size.DriveFromXY(attachedModel2.mesh.Size);
				boxCollider.Type.Value = ColliderType.NoCollision;
				if (mode == Mode.CameraStereo)
				{
					SetupStereoMaterial(attachedModel2.material);
					textureSizeDriver.Premultiply.Value = new Elements.Core.float2(0.5f, 1f);
				}
				if (mode == Mode.CameraObject)
				{
					attachedModel2.material.BlendMode.Value = BlendMode.Alpha;
				}
			}
			StartTask(async delegate
			{
				await metadata.NotifyOfScreenshot();
				if (!canSpawn)
				{
					s.Destroy();
				}
			});
		}

		private void SetupMonoMaterial(IStereoMaterial material)
		{
			material.StereoTextureTransform = false;
			material.LeftEyeTextureOffset = Elements.Core.float2.Zero;
