	public class InteractiveCameraOBS : LegacySwapCanvasPanel
	{
		private OBSWebsocket obs;

		private volatile OBSWebsocketDotNet.Types.OutputState _streamingState = OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED;

		private volatile OBSWebsocketDotNet.Types.OutputState _recordingState = OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED;

		private volatile OutputStatus? _streamingStatus;

		private volatile RecordingStatus? _recordingStatus;

		private volatile ObsStats _obsStats;

		private Task? _updateTask;

		private CancellationTokenSource? _updateCancellation;

		public readonly SyncRef<InteractiveCameraControl> CameraControl;

		protected readonly SyncRef<TextField> _connectAddress;

		protected readonly SyncRef<TextField> _connectPassword;

		protected readonly SyncRef<Text> _status;

		protected readonly Sync<bool> _active;

		protected readonly SyncRef<Text> _streamTime;

		protected readonly SyncRef<Text> _bytesPerSec;

		protected readonly SyncRef<Text> _fps;

		protected readonly SyncRef<Text> _droppedFrames;

		protected readonly SyncRef<Button> _streamButton;

		protected readonly SyncRef<Button> _recordButton;

		protected readonly SyncTime _recordingStarted;

		protected readonly SyncRef<Button> _launchOBSbutton;

		protected readonly SyncRef<Checkbox> _autoMirror;

		private string obsExecutable;

		private bool? obsRunning;

		private DateTime lastOBSrunningCheck;

		private bool _connected;

		public bool IsStreaming => _streamingState != OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED;

		public bool IsRecording => _recordingState != OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED;

		public bool IsConnected => _connected;

		protected override void OnAwake()
		{
			base.OnAwake();
			obs = new OBSWebsocket();
			obs.WSTimeout = TimeSpan.FromSeconds(5L);
			obs.Connected += Obs_Connected;
			obs.Disconnected += Obs_Disconnected;
			obs.StreamStateChanged += Obs_StreamingStateChanged;
			obs.RecordStateChanged += Obs_RecordingStateChanged;
			RunInBackground(delegate
			{
				string path = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ProgramFilesX86), "obs-studio\\bin\\64bit\\obs64.exe");
				if (File.Exists(path))
				{
					obsExecutable = path;
				}
				else
				{
					path = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ProgramFiles), "obs-studio\\bin\\64bit\\obs64.exe");
					if (File.Exists(path))
					{
						obsExecutable = path;
					}
				}
			});
		}

		private void Obs_RecordingStateChanged(object sender, RecordStateChangedEventArgs args)
		{
			if (_recordingState == OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED && args.OutputState.IsActive)
			{
				RunSynchronously(delegate
				{
					_recordingStarted.SetNow();
				});
			}
			_recordingState = args.OutputState.State;
		}

		private void Obs_StreamingStateChanged(object sender, StreamStateChangedEventArgs args)
		{
			_streamingState = args.OutputState.State;
		}

		private void Obs_Disconnected(object sender, ObsDisconnectionInfo e)
		{
			RunSynchronously(delegate
			{
				_connected = false;
				_active.Value = false;
				_streamingStatus = null;
				_recordingStatus = null;
				_recordingState = (_streamingState = OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED);
				_updateCancellation?.Cancel();
				_updateTask = null;
				if (e.ObsCloseCode == ObsCloseCodes.AuthenticationFailed)
				{
					OpenErrorPage(this.GetLocalized("CameraControl.OBS.AuthFailure"));
				}
				else
				{
					OpenErrorPage(this.GetLocalized("CameraControl.OBS.DisconnectedPage"));
				}
			});
		}

		private void Obs_Connected(object sender, EventArgs e)
		{
			_connected = true;
			_streamingState = (obs.GetStreamStatus().IsActive ? OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STARTED : OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED);
			_recordingState = (obs.GetRecordStatus().IsRecording ? OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STARTED : OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED);
		}

