			{
				Elements.Core.floatQ a = Elements.Core.floatQ.Euler(in rotation);
				if (Grabber.HolderSlot.ChildrenCount > 0)
				{
					Elements.Core.floatQ a2 = base.World.LocalUserViewRotation;
					Elements.Core.floatQ a3 = a2.Inverted;
					foreach (Slot child in Grabber.HolderSlot.Children)
					{
						Elements.Core.floatQ globalRotation = a2 * (a * (a3 * Grabber.HolderSlot.LocalRotationToGlobal(child.LocalRotation)));
						child.LocalRotation = Grabber.HolderSlot.GlobalRotationToLocal(in globalRotation);
					}
				}
				else
				{
					_holderRotationOffset.Value = a * _holderRotationOffset.Value;
				}
