		private static Chain GetChain(BodyNode node, out int indexInChain)
		{
			foreach (Chain boneChain in BoneChains)
			{
				indexInChain = boneChain.bodyNodes.IndexOf(node);
				if (indexInChain >= 0)
				{
					return boneChain;
				}
			}
			indexInChain = -1;
			return null;
		}

		/// <summary>
		/// Corrects ambiguous matches within chains(such as legs and arms) by examining the parent bone's type.
		/// </summary>
		/// <param name="childNode">A child that you're trying to fix</param>
		/// <param name="parentNode">The immediate parent of that child node</param>
		/// <returns>A fixed BodyNode if a match could be found</returns>
		/// <example>
		/// Given a child LeftUpperArm, whose parent is also LeftUpperArm, we know that the child should actually be LeftLowerArm
		/// <code>
		/// BodyNode child = BodyNode.LeftUpperArm;
		/// BodyNode parent = BodyNode.LeftUpperArm;
		/// BodyNode fixed = BipedRig.FixChain(child, parent); // Will be LeftLowerArm
		/// </code>
		/// </example>
		public static BodyNode FixChain(BodyNode childNode, BodyNode parentNode)
		{
			int indexInChain;
			Chain chain = GetChain(childNode, out indexInChain);
			if (chain != null)
			{
				int num = chain.bodyNodes.IndexOf(parentNode);
				if (num < 0)
				{
					return chain.bodyNodes[chain.canSkipFirst ? 1 : 0];
				}
				if (indexInChain <= num)
				{
					indexInChain = num + 1;
				}
				if (indexInChain >= chain.bodyNodes.Count)
				{
					return BodyNode.NONE;
				}
				return chain.bodyNodes[indexInChain];
			}
			return childNode;
		}

		private static void ClassifyBiped(BoneNode node, BipedRig rig)
		{
			bool ambiguous;
			bool potentiallyInvalid;
			BodyNode bodyNode = NameToBoneType(node.bone.Name, out ambiguous, out potentiallyInvalid);
			if (node.parent != null)
			{
				if (potentiallyInvalid && node.parent.children.Count > 1)
				{
					bodyNode = BodyNode.NONE;
				}
				if (ambiguous)
				{
					bodyNode = FixChain(bodyNode, node.parent.boneType);
					if (node.HasParent(bodyNode))
					{
						bodyNode = BodyNode.NONE;
					}
				}
			}
			node.boneType = bodyNode;
			foreach (BoneNode child in node.children)
			{
				ClassifyBiped(child, rig);
			}
			if (node.boneType == BodyNode.NONE)
			{
				return;
			}
			if (ambiguous && node.HasChild(node.boneType))
			{
				node.boneType = BodyNode.NONE;
				return;
			}
			int indexInChain;
			Chain chain = GetChain(node.boneType, out indexInChain);
			if (chain == null)
			{
				return;
			}
			for (int i = indexInChain + 1; i < chain.bodyNodes.Count; i++)
			{
				if (IsRequiredBone(chain.bodyNodes[i]) && !node.HasChild(chain.bodyNodes[i]))
				{
					node.boneType = BodyNode.NONE;
					return;
				}
			}
			for (int num = indexInChain - 1; num >= 0; num--)
			{
				if (IsRequiredBone(chain.bodyNodes[num]) && !node.HasParent(chain.bodyNodes[num]))
				{
					node.boneType = BodyNode.NONE;
					break;
				}
			}
		}

		private void AssignBones(BoneNode root, bool ignoreDuplicates)
		{
			if (root.boneType != BodyNode.NONE)
			{
				if (!Bones.ContainsKey(root.boneType))
				{
					Bones.Add(root.boneType, root.bone);
				}
				else if (!ignoreDuplicates)
				{
					UniLog.Log($"Duplicate Bone type {root.boneType}, on: {root.bone}");
				}
			}
			foreach (BoneNode child in root.children)
			{
				AssignBones(child, ignoreDuplicates);
			}
		}

