		public override void Update(float primaryStrength, Elements.Core.float2 secondaryAxis, Digital primary, Digital secondary)
		{
			if ((bool)PickColors || (bool)PickMaterials)
			{
				List<RaycastHit> list = Pool.BorrowList<RaycastHit>();
				Elements.Core.float3 v = TipForward;
				float num = base.Slot.LocalScaleToGlobal(1f);
				base.Physics.RaycastAll(base.Tip - v * num * 0.02f, TipForward, num * 0.03f, list);
				bool flag = false;
				bool flag2 = false;
				foreach (RaycastHit item in list)
				{
					if ((bool)PickMaterials && !flag)
					{
						AssetProxy<Material> componentInParents = item.Collider.Slot.GetComponentInParents<AssetProxy<Material>>();
						IAssetProvider<Material> assetProvider = componentInParents?.AssetReference.Target;
						if (assetProvider != null && assetProvider != lastPickedMaterial && AcceptMaterial(assetProvider))
						{
							CurrentMaterial.Target = componentInParents.AssetReference.Target;
							OnMaterialPicked();
						}
						lastPickedMaterial = assetProvider;
						flag = true;
					}
					if ((bool)PickColors && !flag2)
					{
						IValueSource<Elements.Core.colorX> componentInParents2 = item.Collider.Slot.GetComponentInParents<IValueSource<Elements.Core.colorX>>();
						if (componentInParents2 != null && componentInParents2 != _colorPicker.Target)
						{
							TryChangeCurrentMaterialColor(componentInParents2.Value);
						}
						flag2 = true;
					}
				}
				Pool.Return(ref list);
			}
			if (!_lastPickedColor.HasValue)
			{
				_lastPickedColor = _pickedColor.Value;
			}
			if ((bool)PickColors)
			{
				Elements.Core.colorX a = _pickedColor.Value;
				Elements.Core.colorX? lastPickedColor = _lastPickedColor;
				if (!lastPickedColor.HasValue || a != lastPickedColor.GetValueOrDefault())
				{
					TryChangeCurrentMaterialColor(_pickedColor.Value);
				}
			}
			Pressure.Value = MathX.Lerp(Pressure.Value, primaryStrength, base.Time.Delta / (float)PressureSmoothing);
			Position.Value = MathX.Lerp(Position.Value, ProcessedTip, base.Time.Delta / (float)PositionSmoothing);
			Rotation.Value = MathX.Slerp(Rotation.Value, TipRotation, MathX.Clamp01(base.Time.Delta / (float)RotationSmoothing));
			PostProcessPosition();
			bool forceStroke = ForceStroke;
			forceStroke = ((!IsStrokeActive) ? (forceStroke | (Pressure.Value >= (float)ActivationThreshold)) : (forceStroke | (Pressure.Value >= (float)ActivationThreshold * (float)DeactivationThresholdRatio)));
			if (!IsStrokeActive)
			{
				if (forceStroke)
				{
					if (!IsGroupActive)
					{
						_currentStrokeGroup = BeginStrokeGroup();
						_isFirstStroke = true;
						if (GenerateParticleEmitter)
						{
							switch (ParticleTemplateHandling.Value)
							{
							case TemplateHandling.CloneComponent:
							{
								_currentParticleSystem = _currentStrokeGroup.DuplicateComponent(ParticleSystem.Target);
								ParticleStyle particleStyle = _currentStrokeGroup.DuplicateComponent(_currentParticleSystem.Style.Target);
								_currentParticleSystem.Style.Target = particleStyle;
								particleStyle.Renderer.Target = (IParticleRenderer)_currentStrokeGroup.DuplicateComponent((Component)particleStyle.Renderer.Target);
								for (int i = 0; i < particleStyle.Modules.Count; i++)
								{
									if (particleStyle.Modules[i] != null)
									{
										particleStyle.Modules[i] = (IParticleSystemSubsystem)_currentStrokeGroup.DuplicateComponent((Component)particleStyle.Modules[i]);
									}
								}
								break;
							}
							case TemplateHandling.CloneSlot:
								_currentParticleSystem = ParticleSystem.Target.Slot.Duplicate(_currentStrokeGroup, keepGlobalTransform: false).GetComponent<FrooxEngine.PhotonDust.ParticleSystem>();
								break;
							case TemplateHandling.Share:
								_currentParticleSystem = ParticleSystem.Target;
								break;
							}
						}
						base.Slot.ForeachComponent(delegate(IBrushEventReceiver r)
						{
							r.OnBeginStrokeGroup(this);
						});
						StrokeGroupIndex.Value = -1;
						IsGroupActive = true;
					}
					_lastUsedMaterial.Target = CurrentMaterial.Target;
					StrokeGroupIndex.Value++;
					Position.Value = ProcessedTip;
					Slot slot = BeginStroke();
					if (_isFirstStroke && _currentStrokeGroup != null)
					{
						base.World.BeginUndoBatch("Undo.BrushStroke".AsLocaleKey());
						_currentStrokeGroup.CreateSpawnUndoPoint("Brush Stroke");
					}
					slot?.CreateSpawnUndoPoint("Brush Stroke");
					if (_isFirstStroke && _currentStrokeGroup != null)
					{
						base.World.EndUndoBatch();
					}
					_isFirstStroke = false;
					base.Slot.ForeachComponent(delegate(IBrushEventReceiver r)
					{
						r.OnBeginStroke(this);
					});
					IsStrokeActive = true;
					SetOnStrokeVisibility(visible: false);
					pointCount = 0;
					RunCreateNewPoint();
				}
				else if (IsGroupActive && base.Time.WorldTime - lastStrokeTime >= (double)(float)StrokeGroupFinishWaitTime)
				{
					FinishStrokeGroup();
				}
			}
			else if (forceStroke)
			{
				if ((MathX.Distance(PreviousPoint, Position.Value) >= MinimumPointDistance) | (pointCount == 1))
				{
					RunCreateNewPoint();
				}
				else
				{
					RunUpdatePoint();
				}
			}
			else
			{
				EndStroke();
				base.Slot.ForeachComponent(delegate(IBrushEventReceiver r)
				{
					r.OnEndStroke(this);
				});
				IsStrokeActive = false;
				lastStrokeTime = base.Time.WorldTime;
				_currentMeshEmitter = null;
				SetOnStrokeVisibility(visible: true);
			}
			StrokeGroupActive.Value = IsGroupActive;
		}

