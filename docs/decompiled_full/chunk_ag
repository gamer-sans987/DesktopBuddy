		[SyncMethod(typeof(Delegate), null)]
		private void OnCreateCameraAnchor(IButton button, ButtonEventData eventData)
		{
			if (_lastCamera != null)
			{
				_lastCamera.StartTask(async delegate
				{
					await default(ToWorld);
					Slot slot = _lastCamera.MainCamera.Target.Slot;
					Elements.Core.float3 pos = slot.GlobalPosition;
					Elements.Core.floatQ rot = slot.GlobalRotation;
					float fov = _lastCamera.MainCamera.Target.FieldOfView.Value;
					Slot s = _lastCamera.LocalUserSpace.AddSlot("Camera Anchor");
					await s.LoadObjectAsync(base.Cloud.Platform.GetSpawnObjectUri("Camera Anchor"));
					s.GlobalPosition = pos;
					s.GlobalRotation = rot;
					s.GetComponentInChildren<InteractiveCameraAnchor>().FieldOfView.Value = fov;
				});
			}
		}

