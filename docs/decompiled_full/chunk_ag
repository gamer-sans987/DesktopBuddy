		private void RunCapture(Action<InteractiveCamera> captureMethod)
		{
			InteractiveCamera cam = _lastCamera;
			cam?.RunSynchronously(delegate
			{
				if (cam.TimerEnabled.Value)
				{
					cam.LocalCaptureOverride = delegate
					{
						captureMethod(cam);
						cam.LocalCaptureOverride = null;
					};
					cam.Trigger();
				}
				else
				{
					captureMethod(cam);
					cam.PlayCaptureSound();
				}
			});
		}

