		private void RunCreateNewPoint()
		{
			float? num = null;
			if (pointCount == 0)
			{
				accumulatedStrokeLength = 0f;
				Elements.Core.float3 @float = (PrevPreviousPoint = Position.Value);
				Elements.Core.float3 currentPosition = (PreviousPoint = @float);
				CurrentPosition = currentPosition;
				currentPosition = (PrevPreviousPosition = Position.Value);
				PreviousPosition = currentPosition;
				RawStrokeLength.Value = 0f;
				num = Pressure.Value;
				Pressure.Value = 0f;
			}
			else
			{
				PrevPreviousPoint = PreviousPoint;
				PreviousPoint = Position.Value;
				if (pointCount > 1)
				{
					accumulatedStrokeLength += MathX.Distance(CurrentPosition, PreviousPoint);
				}
			}
			pointCount++;
			UpdateStrokeParameters();
			AddNewPoint();
			base.Slot.ForeachComponent(delegate(IBrushEventReceiver r)
			{
				r.OnAddNewPoint(this);
			});
			UpdatePoint();
			base.Slot.ForeachComponent(delegate(IBrushEventReceiver r)
			{
				r.OnUpdatePoint(this);
			});
			if (num.HasValue)
			{
				Pressure.Value = num.Value;
			}
		}

		private void RunUpdatePoint()
		{
			UpdateStrokeParameters();
			UpdatePoint();
			base.Slot.ForeachComponent(delegate(IBrushEventReceiver r)
			{
				r.OnUpdatePoint(this);
			});
		}

		private void UpdateStrokeParameters()
		{
			RawDelta.Value = Position.Value - CurrentPosition;
			Velocity.Value = RawDelta.Value * base.Time.InvertedDelta;
			LastPointDelta.Value = Position.Value - PreviousPoint;
			RawStrokeLength.Value += RawDelta.Value.Magnitude;
			StrokeLength.Value = accumulatedStrokeLength + MathX.Distance(Position.Value, PreviousPoint);
			NormalizedStrokeLength.Value = StrokeLength.Value / MaxStrokeLength.Value;
			StrokeFadeMultiplier.Value = MathX.Clamp01(MathX.Min(MathX.InverseLerp(0f, StrokeFadeInLength.Value, StrokeLength.Value), MathX.InverseLerp((float)MaxStrokeLength - (float)StrokeFadeOutLength, MaxStrokeLength, StrokeLength.Value)));
			PrevPreviousPosition = PreviousPoint;
			PreviousPosition = CurrentPosition;
			CurrentPosition = Position.Value;
			if (_currentMeshEmitter != null && EmissionRatePerUnitLength.Value.HasValue)
			{
				_currentMeshEmitter.Rate.Value = StrokeLength.Value * EmissionRatePerUnitLength.Value.Value;
			}
		}

