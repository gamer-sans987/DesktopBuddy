		public void CaptureFrom(IFingerPoseSource source)
		{
			Bones.Clear();
			if (source.AreFingersTracking(Chirality.Left))
			{
				CaptureFrom(source, Chirality.Left);
			}
			if (source.AreFingersTracking(Chirality.Right))
			{
				CaptureFrom(source, Chirality.Right);
			}
		}

		public void CaptureFrom(IFingerPoseSource source, Chirality side)
		{
			if (!source.AreFingersTracking(side))
			{
				return;
			}
			Slot slot = EnsureNodeSlot(BodyNode.LeftHand.GetSide(side), base.Slot);
			foreach (FingerType value in EnumsNET.Enums.GetValues<FingerType>())
			{
				Slot slot2 = null;
				foreach (FingerSegmentType value2 in EnumsNET.Enums.GetValues<FingerSegmentType>())
				{
					if ((value != FingerType.Thumb || value2 != FingerSegmentType.Intermediate) && (value2 != FingerSegmentType.Metacarpal || source.TracksMetacarpals))
					{
						Slot root = slot2 ?? slot;
						BodyNode node = value.ComposeFinger(value2, side);
						Slot slot3 = EnsureNodeSlot(node, root);
						source.GetFingerData(node, out var position, out var rotation);
						slot3.LocalRotation = slot.LocalRotationToSpace(in rotation, slot3.Parent);
						slot3.LocalPosition = slot.LocalPointToSpace(in position, slot3.Parent);
						slot2 = slot3;
					}
				}
			}
		}

		private Slot EnsureNodeSlot(BodyNode node, Slot root)
		{
			if (!Bones.TryGetTarget(node, out Slot target) || target == null)
			{
				target = root.AddSlot($"{node}");
				Bones[node] = target;
			}
			return target;
		}

