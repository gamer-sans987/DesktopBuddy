			float num = MathX.Clamp(boundingBox.Size.y, 0.02f, 0.1f);
			_editIconScale.Target.Value = Elements.Core.float3.One * num;
			_editIconPosition.Target.Value = boundingBox.max.xy_ + Elements.Core.float3.Right * num * 0.7f + Elements.Core.float3.Down * num * 0.5f;
		}

