		public static BoneNode SlotHierarchyToBoneHiearchy(this Slot slot, Func<Slot, bool> filter = null)
		{
			BoneNode boneNode = new BoneNode(slot);
			foreach (Slot child in slot.Children)
			{
				child.SlotHierarchyToBoneHiearchy(boneNode, filter);
			}
			return boneNode;
		}

		private static void SlotHierarchyToBoneHiearchy(this Slot slot, BoneNode parentNode, Func<Slot, bool> filter = null)
		{
			if (filter == null || filter(slot))
			{
				BoneNode boneNode = new BoneNode(slot);
				boneNode.parent = parentNode;
				parentNode.children.Add(boneNode);
				parentNode = boneNode;
			}
			foreach (Slot child in slot.Children)
			{
				child.SlotHierarchyToBoneHiearchy(parentNode, filter);
			}
		}

		public static Slot GetBone(this Slot slot)
		{
			Rig componentInParents = slot.GetComponentInParents<Rig>();
			if (componentInParents == null)
			{
				return null;
			}
			Slot slot2 = slot;
			while (!slot2.IsRootSlot)
			{
				if (componentInParents.IsBone(slot2))
				{
					return slot2;
				}
				slot2 = slot2.Parent;
			}
			return null;
		}
	}
	public static class RigHelper
	{
		public static void TransferRig(Rig source, Rig target)
		{
			Slot slot = source.Slot;
			Slot slot2 = target.Slot;
			List<SkinnedMeshRenderer> componentsInChildren = slot.GetComponentsInChildren<SkinnedMeshRenderer>();
			List<SkinnedMeshRenderer> componentsInChildren2 = slot2.GetComponentsInChildren<SkinnedMeshRenderer>();
			Dictionary<string, Slot> dictionary = new Dictionary<string, Slot>();
			foreach (Slot bone in target.Bones)
			{
				if (bone != null && bone.Name != null)
				{
					if (!dictionary.ContainsKey(bone.Name))
					{
						dictionary.Add(bone.Name, bone);
					}
					else
					{
						UniLog.Warning("Duplicate bone name on target rig during rig transfer: " + bone);
					}
				}
			}
			Dictionary<Slot, Slot> dictionary2 = new Dictionary<Slot, Slot>();
			HashSet<Slot> hashSet = new HashSet<Slot>();
			foreach (Slot bone2 in source.Bones)
			{
				if (bone2 != null && bone2.Name != null)
				{
					if (dictionary.TryGetValue(bone2.Name, out var value))
					{
						dictionary2.Add(bone2, value);
					}
					else
					{
						hashSet.Add(bone2);
					}
				}
			}
			VRIK componentInParentsOrChildren = source.Slot.GetComponentInParentsOrChildren<VRIK>();
			VRIK componentInParentsOrChildren2 = target.Slot.GetComponentInParentsOrChildren<VRIK>();
			if (componentInParentsOrChildren != null && componentInParentsOrChildren2 != null)
			{
				for (int i = 0; i < componentInParentsOrChildren.Solver.BoneReferences.ReferenceCount; i++)
				{
					Slot slot3 = componentInParentsOrChildren.Solver.BoneReferences[i];
					if (slot3 != null && !dictionary2.ContainsKey(slot3))
					{
						Slot slot4 = componentInParentsOrChildren2.Solver.BoneReferences[i];
						if (slot4 != null)
						{
							dictionary2.Add(slot3, slot4);
							hashSet.Remove(slot3);
						}
					}
				}
			}
			foreach (Slot item in hashSet)
			{
				Slot slot5 = TransplantSlot(item, source.Slot, dictionary2);
				if (slot5 == null)
				{
					UniLog.Warning("Could not transplant source bone: " + item);
				}
				dictionary2.Add(item, slot5);
			}
			foreach (SkinnedMeshRenderer item2 in componentsInChildren2)
			{
				SkinnedMeshRenderer skinnedMeshRenderer = FindClosestRenderer(item2, componentsInChildren, componentsInChildren2);
				if (skinnedMeshRenderer == null)
				{
					continue;
				}
				Dictionary<string, int> dictionary3 = new Dictionary<string, int>();
				for (int j = 0; j < skinnedMeshRenderer.BlendShapeWeights.Count; j++)
				{
					dictionary3.Add(skinnedMeshRenderer.BlendShapeName(j), j);
				}
				for (int k = 0; k < item2.BlendShapeWeights.Count; k++)
				{
					string key = item2.BlendShapeName(k);
					if (dictionary3.TryGetValue(key, out var value2))
					{
						if (value2 > k)
						{
							item2.BlendShapeWeights.Insert(k);
						}
					}
					else
					{
						item2.BlendShapeWeights.RemoveAt(k);
					}
				}
				while (item2.BlendShapeWeights.Count < skinnedMeshRenderer.BlendShapeWeights.Count)
				{
					item2.BlendShapeWeights.Add();
				}
				item2.Mesh.Target = skinnedMeshRenderer.Mesh.Target;
				item2.Bones.Clear();
				foreach (Slot bone3 in skinnedMeshRenderer.Bones)
				{
					item2.Bones.Add(dictionary2[bone3]);
				}
			}
			VRIKAvatar componentInParentsOrChildren3 = target.Slot.GetComponentInParentsOrChildren<VRIKAvatar>();
			if (componentInParentsOrChildren3 != null && componentInParentsOrChildren3.Slot.GetComponentInChildren<VisemeAnalyzer>() == null)
			{
				AvatarCreator.TrySetupVisemes(componentInParentsOrChildren3.Slot);
			}
			target.Bones.Clear();
			target.Bones.AddRange(dictionary2.Values);
		}

		private static SkinnedMeshRenderer FindClosestRenderer(SkinnedMeshRenderer target, List<SkinnedMeshRenderer> sources, List<SkinnedMeshRenderer> targets)
		{
			foreach (SkinnedMeshRenderer source in sources)
			{
				if (source.Slot.Name == target.Slot.Name)
				{
					return source;
				}
			}
			if (target.Mesh.Asset == null)
			{
				return null;
			}
			int vertexCount = target.Mesh.Asset.Data.VertexCount;
			int num = int.MaxValue;
			SkinnedMeshRenderer result = null;
			foreach (SkinnedMeshRenderer source2 in sources)
			{
				if (source2.Mesh.Asset != null)
				{
					int num2 = MathX.Abs(source2.Mesh.Asset.Data.VertexCount - vertexCount);
					if (num2 < num)
					{
						num = num2;
						result = source2;
					}
				}
			}
			return result;
		}

		private static Slot TransplantSlot(Slot sourceSlot, Slot root, Dictionary<Slot, Slot> translatedBones)
		{
			if (translatedBones.TryGetValue(sourceSlot, out Slot value))
			{
				return value;
			}
			if (sourceSlot.Parent == root)
			{
				return null;
			}
			Slot slot = TransplantSlot(sourceSlot.Parent, root, translatedBones);
			if (slot == null)
			{
				return null;
			}
			value = slot.FindChild(sourceSlot.Name);
			if (value == null)
			{
				value = slot.FindChild((Slot s) => s.Name == sourceSlot.Name);
			}
			if (value != null)
			{
				return value;
			}
			value = sourceSlot.Duplicate(slot);
			value.LocalPosition = sourceSlot.LocalPosition;
			value.LocalRotation = sourceSlot.LocalRotation;
			value.LocalScale = sourceSlot.LocalScale;
			return value;
		}
	}
