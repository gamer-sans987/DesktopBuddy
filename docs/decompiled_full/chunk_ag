			HashSet<StaticGaussianSplat> processed = new HashSet<StaticGaussianSplat>();
			Elements.Core.float3 progressOffset = Elements.Core.float3.Zero;
			if (_activeBox.Target != null)
			{
				Elements.Core.float3 v = _activeBox.Target.Size.Target.Value * 0.5f;
				Elements.Core.floatQ q = _activeBox.Target.Slot.GlobalRotation;
				Elements.Core.float3 a = _activeBox.Target.Slot.LocalPointToGlobal(-v);
				Elements.Core.float3 a2 = _activeBox.Target.Slot.LocalPointToGlobal(in v);
				Elements.Core.float3 b = _activeBox.Target.Slot.GlobalPosition;
				Elements.Core.float3 v2 = a - b;
				Elements.Core.float3 v3 = a2 - b;
				Elements.Core.float3 globalDirection = q * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Forward);
				Elements.Core.float3 globalDirection2 = q * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Up);
				Elements.Core.float3 size = Elements.Core.BoundingBox.FromPoints(q.Inverted * v2, q.Inverted * v3).Size;
