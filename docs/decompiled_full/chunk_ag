				if (chain.Count == 0)
				{
					Fill(handRoot, fingerRoot, ignoreRig: true);
				}
			}

			public void ComputeDistanceToThumb(PotentialFinger thumb)
			{
				distanceToThumb = MathX.Distance(thumb.proximal.GlobalPosition, chain[0].slot.GlobalPosition);
				Elements.Core.float3 b = chain[0].slot.GlobalPointToLocal(chain[1].slot.GlobalPosition).Normalized;
				Elements.Core.float3 a = chain[0].slot.GlobalPointToLocal(thumb.closestSegment.GlobalPosition);
				Elements.Core.float3 a2 = chain[0].slot.GlobalPointToLocal(thumb.furthestSegment.GlobalPosition);
				a = MathX.Project(in a, in b);
				a2 = MathX.Project(in a2, in b);
				alignedDistanceToThumbStart = a.Magnitude;
				alignedDistanceToThumbEnd = a2.Magnitude;
			}

			public void DetermineSegments()
			{
				if (!type.HasValue)
				{
					throw new Exception("Need to compute finger type first!");
				}
				if (type == FingerType.Thumb)
				{
					int num = 0;
					if (num < chain.Count)
					{
						metacarpal = chain[num++].slot;
					}
					if (num < chain.Count)
					{
						proximal = chain[num++].slot;
					}
					if (num < chain.Count)
					{
						distal = chain[num++].slot;
					}
					if (num < chain.Count)
					{
						tip = chain[num].slot;
					}
					return;
				}
				int num2 = 0;
				if ((chain.Count(delegate(Segment s)
				{
					if (s.segment == FingerSegmentType.Tip)
					{
						return false;
					}
					return (!s.names.Contains("tip") && !s.names.Contains("end")) ? true : false;
				}) >= 4 && chain.Count >= 5 && !chain[num2].segment.HasValue) || chain[num2].segment == FingerSegmentType.Metacarpal)
				{
					metacarpal = chain[num2++].slot;
				}
				if (num2 < chain.Count)
				{
					proximal = chain[num2++].slot;
				}
				if (num2 < chain.Count)
				{
					intermediate = chain[num2++].slot;
				}
				if (num2 < chain.Count)
				{
					distal = chain[num2++].slot;
				}
				if (num2 < chain.Count)
				{
					tip = chain[num2++].slot;
				}
			}

			public void ExtractFingers(BipedRig rig, Chirality chirality)
			{
				ExtractFinger(metacarpal, FingerSegmentType.Metacarpal, chirality, rig);
				ExtractFinger(proximal, FingerSegmentType.Proximal, chirality, rig);
				ExtractFinger(intermediate, FingerSegmentType.Intermediate, chirality, rig);
				ExtractFinger(distal, FingerSegmentType.Distal, chirality, rig);
				ExtractFinger(tip, FingerSegmentType.Tip, chirality, rig);
			}

			private void ExtractFinger(Slot finger, FingerSegmentType segmentType, Chirality chirality, BipedRig rig)
			{
				if (finger != null)
				{
					BodyNode key = type.Value.ComposeFinger(segmentType, chirality);
					rig.Bones.Add(key, finger);
				}
			}

			private void Fill(Slot handRoot, Slot fingerRoot, bool ignoreRig)
			{
				Slot slot = handRoot;
				Slot slot2 = fingerRoot;
				length = 0f;
				do
				{
					float num = MathX.Distance(slot.GlobalPosition, slot2.GlobalPosition);
					if ((double)num > 1E-05 && (ignoreRig || rig == null || rig.Bones.Contains(slot2)))
					{
						Segment segment = new Segment(slot2);
						segment.length = num;
						chain.Add(segment);
						length += num;
						slot = slot2;
					}
					slot2 = GetNextChainSegment(slot2);
				}
				while (slot2 != null);
			}

			public override string ToString()
			{
				return $"Finger length: {length}, type: {type}, Chain: " + string.Join(", ", chain.Select((Segment s) => s.slot.Name)) + $", Distance to thumb start: {alignedDistanceToThumbStart}, thumb end: {alignedDistanceToThumbEnd}";
			}
		}

