		public static List<string> SplitName(string name)
		{
			StringBuilder stringBuilder = new StringBuilder();
			List<string> list = new List<string>();
			foreach (char c in name)
			{
				if (char.IsLetter(c))
				{
					stringBuilder.Append(c);
				}
				else
				{
					AppendNameSegment(list, stringBuilder);
				}
			}
			AppendNameSegment(list, stringBuilder);
			foreach (char c2 in name)
			{
				if (char.IsLetter(c2))
				{
					if (char.IsUpper(c2))
					{
						AppendNameSegment(list, stringBuilder);
					}
					stringBuilder.Append(c2);
				}
				else
				{
					AppendNameSegment(list, stringBuilder);
				}
			}
			AppendNameSegment(list, stringBuilder);
			bool flag = false;
			bool flag2 = false;
			foreach (string item in list)
			{
				if (item.Contains("left") && item != "left")
				{
					flag = true;
				}
				if (item.Contains("right") && item != "right")
				{
					flag2 = true;
				}
			}
			list.RemoveAll(delegate(string n)
			{
				if (n.Contains("left") && n != "left")
				{
					return true;
				}
				return (n.Contains("right") && n != "right") ? true : false;
			});
			if (flag)
			{
				list.AddUnique("left");
			}
			if (flag2)
			{
				list.AddUnique("right");
			}
			return list;
		}

		private static void AppendNameSegment(List<string> names, StringBuilder str)
		{
			if (str.Length > 0)
			{
				string text = str.ToString();
				names.AddUnique(text.ToLowerInvariant());
			}
			str.Clear();
		}

		public static Chirality? NameToBoneChirality(string wholeName, List<string> names)
		{
			bool flag = false;
			bool flag2 = false;
			if (names.Contains("left") || names.Contains("l"))
			{
				flag = true;
			}
			if (names.Contains("right") || names.Contains("r"))
			{
				flag2 = true;
			}
			if ((flag ^ flag2) && (flag || flag2))
			{
				if (flag)
				{
					return Chirality.Left;
				}
				return Chirality.Right;
			}
			flag = false;
			flag2 = false;
			if (ContainsIsolatedLetter(wholeName, 'R'))
			{
				flag2 = true;
			}
			if (ContainsIsolatedLetter(wholeName, 'L'))
			{
				flag = true;
			}
			if ((flag ^ flag2) && (flag || flag2))
			{
				if (flag)
				{
					return Chirality.Left;
				}
				return Chirality.Right;
			}
			if (wholeName.StartsWith("r", StringComparison.InvariantCultureIgnoreCase))
			{
				return Chirality.Right;
			}
			if (wholeName.StartsWith("l", StringComparison.InvariantCultureIgnoreCase))
			{
				return Chirality.Left;
			}
			return null;
		}

		public static bool ContainsIsolatedLetter(string name, char ch)
		{
			for (int i = 0; i < name.Length; i++)
			{
				if (name[i] == ch && (i <= 0 || !char.IsLetterOrDigit(name[i - 1]) || !char.IsUpper(name[i - 1])) && !IsPartOfCommonName(ch, i, name))
				{
					return true;
				}
			}
			return false;
		}

		public static bool IsPartOfCommonName(char ch, int index, string name)
		{
			char value = char.ToLowerInvariant(ch);
			foreach (string commonName in _commonNames)
			{
				int num = 0;
				while (num < commonName.Length)
				{
					int num2 = commonName.IndexOf(value, num);
					if (num2 < 0)
					{
						break;
					}
					int num3 = index - num2;
					int num4 = num3 + commonName.Length;
					if (num3 > 0 && num4 <= name.Length && string.Compare(name, num3, commonName, 0, commonName.Length, StringComparison.InvariantCultureIgnoreCase) == 0)
					{
						return true;
					}
					num = num2 + 1;
				}
			}
			return false;
		}
	}
