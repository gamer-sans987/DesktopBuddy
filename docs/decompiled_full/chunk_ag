	public static class InteractionHandlerExtensions
	{
		public static ITool GetActiveTool(this User user)
		{
			object obj = user?.GetInteractionHandler(Chirality.Left)?.ActiveTool;
			if (obj == null)
			{
				if (user == null)
				{
					return null;
				}
				InteractionHandler interactionHandler = user.GetInteractionHandler(Chirality.Right);
				if (interactionHandler == null)
				{
					return null;
				}
				obj = interactionHandler.ActiveTool;
			}
			return (ITool)obj;
		}

		public static IEnumerable<ITool> GetActiveTools(this User user)
		{
			foreach (ITool activeTool in user.GetActiveTools(Chirality.Left))
			{
				yield return activeTool;
			}
			foreach (ITool activeTool2 in user.GetActiveTools(Chirality.Right))
			{
				yield return activeTool2;
			}
		}

		public static IEnumerable<ITool> GetActiveTools(this User user, Chirality chirality)
		{
			ITool tooltip = (user?.GetInteractionHandler(chirality))?.ActiveTool;
			if (tooltip != null)
			{
				do
				{
					yield return tooltip;
					tooltip = ((!(tooltip is ToolMultiplexer toolMultiplexer)) ? null : toolMultiplexer.ActiveTool);
				}
				while (tooltip != null);
			}
		}

		public static InteractionHandler GetInteractionHandler(this User user, Chirality side)
		{
			return user?.Root?.GetRegisteredComponent((InteractionHandler tool) => tool.Side.Value == side);
		}

		public static bool IsCurrentlyTouching(this User user)
		{
			return user?.Root?.GetRegisteredComponent(delegate(InteractionHandler tool)
			{
				InteractionLaser laser = tool.Laser;
				return laser != null && laser.TouchSource?.IsTouchEventRunning == true;
			}) != null;
		}

		public static bool IsDirectlyInteracting(this User user)
		{
			if (user.IsCurrentlyTouching())
			{
				return true;
			}
			if (user.GetActiveFocus() is TextEditor { EditEventRunning: not false })
			{
				return true;
			}
			return false;
		}

		public static InteractionHandler FindInteractionHandler(this Component source)
		{
			if (source is InteractionHandler result)
			{
				return result;
			}
			InteractionHandler interactionHandler = source.Slot.FindInteractionHandler();
			if (interactionHandler != null)
			{
				return interactionHandler;
			}
			if (source.InputInterface.ScreenActive)
			{
				return source.LocalUserRoot.GetRegisteredComponent((InteractionHandler t) => t.Side.Value == source.InputInterface.PrimaryHand);
			}
			return null;
		}

		public static InteractionHandler FindInteractionHandler(this Slot source)
		{
			InteractionHandler interactionHandler = source.GetComponentInParentsOrChildren<InteractionHandler>();
			if (interactionHandler == null)
			{
				InteractionHandlerRelay componentInParents = source.GetComponentInParents<InteractionHandlerRelay>();
				if (componentInParents == null)
				{
					return null;
				}
				interactionHandler = componentInParents.CommonTool.Target;
			}
			return interactionHandler;
		}
	}
