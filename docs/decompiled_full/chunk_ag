	public class SlicingVolumeVisualizer : Component
	{
		public readonly RelayRef<VolumeUnlitMaterial> Material;

		public readonly Sync<bool> AutoScale;

		protected readonly SyncRef<MeshRenderer> _renderer;

		protected readonly SyncRef<BoxMesh> _mesh;

		protected readonly SyncRef<BoxCollider> _collider;

		protected readonly FieldDrive<Elements.Core.float3> _scale;

		public readonly SyncRelayList<VolumePlaneSlicer> Slicers;

		protected readonly DriveRef<SyncList<VolumeUnlitMaterial.SlicePlane>> _slicePlanes;

		protected readonly DriveRef<SyncList<VolumeUnlitMaterial.Highlight>> _highlights;

		protected override void OnAwake()
		{
			base.OnAwake();
			base.Slot.WorldTransformChanged += Slot_WorldTransformChanged;
		}

		private void Slot_WorldTransformChanged(Slot slot)
		{
			MarkChangeDirty();
		}

		protected override void OnAttach()
		{
			Slot slot = base.Slot.AddSlot("Visual");
			_scale.Target = slot.Scale_Field;
			_renderer.Target = slot.AttachComponent<MeshRenderer>();
			_mesh.Target = slot.AttachComponent<BoxMesh>();
			_collider.Target = slot.AttachComponent<BoxCollider>();
			_renderer.Target.Mesh.Target = _mesh.Target;
		}

		protected override void OnChanges()
		{
			VolumeUnlitMaterial target = Material.Target;
			_renderer.Target.Material.Target = target;
			if (AutoScale.Value)
			{
				Elements.Core.int3 a = target?.Volume.Target?.Asset?.Size ?? Elements.Core.int3.Zero;
				Elements.Core.float3 value = Elements.Core.float3.Zero;
				if (a != Elements.Core.int3.Zero)
				{
					value = a / (float)MathX.MaxComponent(in a);
				}
				_scale.Target.Value = value;
			}
			else
			{
				_scale.Target.Value = Elements.Core.float3.One;
			}
			_slicePlanes.Target = target?.Slices;
			_highlights.Target = target?.Highlights;
			if (target == null)
			{
				return;
			}
			int num = 0;
			int num2 = 0;
			Slicers.RemoveAll((RelayRef<VolumePlaneSlicer> t) => t.Target == null);
			foreach (VolumePlaneSlicer slicer in Slicers)
			{
				if (slicer.Mode.Value == VolumePlaneMode.Off)
				{
					continue;
				}
				VolumeUnlitMaterial.SlicePlane slicePlane;
				if (slicer.Mode.Value == VolumePlaneMode.Highlight)
				{
					if (num2 == 4)
					{
						continue;
					}
					target.Highlights.EnsureMinimumCount(num2 + 1);
					VolumeUnlitMaterial.Highlight highlight = target.Highlights[num2];
					num2++;
					highlight.Color.Value = slicer.HighlightColor;
					highlight.Range.Value = slicer.HighlightRange;
					slicePlane = highlight;
				}
				else
				{
					if (num == 4)
					{
						continue;
					}
					target.Slices.EnsureMinimumCount(num + 1);
					slicePlane = target.Slices[num];
					num++;
				}
				Elements.Core.float3 a2 = _renderer.Target.Slot.GlobalDirectionToLocal(slicer.Slot.Up);
				Elements.Core.float3 b = _renderer.Target.Slot.GlobalPointToLocal(slicer.Slot.GlobalPosition);
				slicePlane.Normal.Value = a2;
				slicePlane.Offset.Value = 0f - MathX.Dot(in a2, in b);
			}
			target.Highlights.EnsureExactCount(num2);
			target.Slices.EnsureExactCount(num);
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Material = new RelayRef<VolumeUnlitMaterial>();
			AutoScale = new Sync<bool>();
			_renderer = new SyncRef<MeshRenderer>();
			_mesh = new SyncRef<BoxMesh>();
			_collider = new SyncRef<BoxCollider>();
			_scale = new FieldDrive<Elements.Core.float3>();
			Slicers = new SyncRelayList<VolumePlaneSlicer>();
			_slicePlanes = new DriveRef<SyncList<VolumeUnlitMaterial.SlicePlane>>();
			_highlights = new DriveRef<SyncList<VolumeUnlitMaterial.Highlight>>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => Material, 
				4 => AutoScale, 
				5 => _renderer, 
				6 => _mesh, 
				7 => _collider, 
				8 => _scale, 
				9 => Slicers, 
				10 => _slicePlanes, 
				11 => _highlights, 
				_ => throw new ArgumentOutOfRangeException(), 
