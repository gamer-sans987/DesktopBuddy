		public static FingerType? NameToFingerType(List<string> names)
		{
			if (names.Contains("thumb") || names.Contains("th") || names.Contains("thm") || names.Contains("thmb"))
			{
				return FingerType.Thumb;
			}
			if (names.Contains("index") || names.Contains("point") || names.Contains("in") || names.Contains("ind"))
			{
				return FingerType.Index;
			}
			if (names.Contains("middle") || names.Contains("mid") || names.Contains("mi"))
			{
				return FingerType.Middle;
			}
			if (names.Contains("ring") || names.Contains("ri") || names.Contains("rin"))
			{
				return FingerType.Ring;
			}
			if (names.Contains("pinky") || names.Contains("little") || names.Contains("pi") || names.Contains("pin") || names.Contains("pnk"))
			{
				return FingerType.Pinky;
			}
			return null;
		}

		public static BodyNode NameToBoneType(string name, out bool ambiguous, out bool potentiallyInvalid)
		{
			List<string> list = NameHeuristicsHelper.SplitName(name);
			string text = name.ToLower();
			text = text.Replace("armature", "");
			potentiallyInvalid = list.Contains("twist");
			if (text.Contains("hips") || text.Contains("pelvis") || text.Contains("root"))
			{
				ambiguous = false;
				return BodyNode.Hips;
			}
			if (text.Contains("spine") || text.Contains("chest") || text.Contains("ribcage") || text.Contains("torso"))
			{
				ambiguous = true;
				return BodyNode.Hips;
			}
			if (text.Contains("neck") && !text.Contains("necklace"))
			{
				ambiguous = false;
				return BodyNode.Neck;
			}
			if (text.Contains("head"))
			{
				ambiguous = false;
				return BodyNode.Head;
			}
			Chirality? chirality = NameHeuristicsHelper.NameToBoneChirality(name, list);
			if (chirality.HasValue)
			{
				BodyNode bodyNode;
				if (text.Contains("shoulder") || text.Contains("clavicle") || text.Contains("collar"))
				{
					bodyNode = BodyNode.LeftShoulder;
					ambiguous = false;
				}
				else if (text.Contains("upperarm") || text.Contains("uparm") || text.Contains("uarm") || text.Contains("bicep"))
				{
					bodyNode = BodyNode.LeftUpperArm;
					ambiguous = false;
				}
				else if (text.Contains("forearm") || text.Contains("lowarm") || list.Contains("lowerarm") || list.Contains("elbow"))
				{
					bodyNode = BodyNode.LeftLowerArm;
					ambiguous = false;
				}
				else
				{
					if (text.Contains("finger") || text.Contains("digit") || text.Contains("thumb"))
					{
						FingerType? fingerType = NameToFingerType(list);
						if (!fingerType.HasValue)
						{
							ambiguous = true;
							return BodyNode.NONE;
						}
						return GetFingerNode(fingerType.Value, list, out ambiguous);
					}
					if (text.Contains("arm"))
					{
						bodyNode = BodyNode.LeftUpperArm;
						ambiguous = true;
					}
					else if (text.Contains("hand") || text.Contains("wrist") || text.Contains("palm"))
					{
						bodyNode = BodyNode.LeftHand;
						ambiguous = false;
					}
					else if (text.Contains("thigh") || text.Contains("upleg") || text.Contains("uleg") || text.Contains("upperleg") || (text.Contains("hip") && !text.Contains("hips")))
					{
						bodyNode = BodyNode.LeftUpperLeg;
						ambiguous = false;
					}
					else if (text.Contains("calf") || text.Contains("knee") || text.Contains("lowleg"))
					{
						bodyNode = BodyNode.LeftLowerLeg;
						ambiguous = false;
					}
					else if (text.Contains("shin"))
					{
						bodyNode = BodyNode.LeftLowerLeg;
						ambiguous = false;
					}
					else if (text.Contains("leg"))
					{
						bodyNode = BodyNode.LeftUpperLeg;
						ambiguous = true;
					}
					else if (text.Contains("foot") || text.Contains("ankle") || list.Contains("feet"))
					{
						bodyNode = BodyNode.LeftFoot;
						ambiguous = false;
					}
					else if (text.Contains("toe") || (text.Contains("ball") && !text.Contains("eye")))
					{
						bodyNode = BodyNode.LeftToes;
						ambiguous = false;
					}
					else
					{
						if ((!text.Contains("eye") && !list.Contains("eye")) || text.Contains("eyebrow") || text.Contains("blink") || text.Contains("eyelid") || list.Contains("brow") || list.Contains("eyebrow") || list.Contains("lid") || list.Contains("blink") || list.Contains("under"))
						{
							if (list.Contains("b") || list.Contains("m") || list.Contains("t"))
							{
								FingerType? fingerType2 = NameToFingerType(list);
								if (!fingerType2.HasValue)
								{
									ambiguous = true;
									return BodyNode.NONE;
								}
								BodyNode fingerNode = GetFingerNode(fingerType2.Value, list, out ambiguous);
								if (!ambiguous)
								{
									return fingerNode;
								}
								if (list.Contains("m"))
								{
									return fingerType2.Value.ComposeFinger(FingerSegmentType.Intermediate, Chirality.Left);
								}
								if (list.Contains("t"))
								{
									return fingerType2.Value.ComposeFinger(FingerSegmentType.Distal, Chirality.Left);
								}
								return fingerType2.Value.ComposeFinger(FingerSegmentType.Proximal, Chirality.Left);
							}
							ambiguous = false;
							return BodyNode.NONE;
						}
						bodyNode = BodyNode.LeftEye;
						ambiguous = false;
					}
				}
				if (chirality == Chirality.Right)
				{
					return bodyNode.GetRightSide();
				}
				return bodyNode;
			}
			ambiguous = false;
			return BodyNode.NONE;
		}

		public static bool DetectHandRig(BipedRig rig, Slot root, Chirality chirality)
		{
			Rig componentInChildren = rig.Slot.GetObjectRoot().GetComponentInChildren<Rig>();
			BodyNode side = BodyNode.LeftThumb_Metacarpal.GetSide(chirality);
			BodyNode side2 = BodyNode.LeftPinky_Tip.GetSide(chirality);
			for (BodyNode bodyNode = side; bodyNode <= side2; bodyNode++)
			{
				rig.Bones.Remove(bodyNode);
			}
			List<PotentialFinger> list = new List<PotentialFinger>();
			List<Slot> fingerRoots = GetFingerRoots(root);
			if (fingerRoots != null)
			{
				foreach (Slot item in fingerRoots)
				{
					list.Add(new PotentialFinger(root, item, null, componentInChildren));
				}
				PotentialFinger potentialFinger = null;
				foreach (PotentialFinger item2 in list)
				{
					if (item2.chain.Any((Segment s) => s.type == FingerType.Thumb))
					{
						potentialFinger = item2;
						break;
					}
				}
				if (potentialFinger == null)
				{
					float num = float.MaxValue;
					foreach (PotentialFinger item3 in list)
					{
						if (item3.length < num)
						{
							num = item3.length;
							potentialFinger = item3;
						}
					}
				}
				potentialFinger.type = FingerType.Thumb;
				potentialFinger.DetermineSegments();
				foreach (PotentialFinger item4 in list)
				{
					if (item4 != potentialFinger)
					{
						item4.ComputeDistanceToThumb(potentialFinger);
					}
				}
				list.Sort((PotentialFinger a, PotentialFinger b) => a.distanceToThumb.CompareTo(b.distanceToThumb));
				for (FingerType fingerType = FingerType.Thumb; fingerType <= FingerType.Pinky; fingerType++)
				{
					list[(int)fingerType].type = fingerType;
				}
				foreach (PotentialFinger item5 in list)
				{
					if (item5.type != FingerType.Thumb)
					{
						item5.DetermineSegments();
					}
				}
			}
			else
			{
				UniLog.Log("Couldn't find finger roots geometrically, falling back to naming convention");
				Slot slot = FindFingerRoot(root, FingerType.Thumb);
				if (slot == null)
				{
					return false;
				}
				Slot slot2 = FindFingerRoot(root, FingerType.Index);
				Slot slot3 = FindFingerRoot(root, FingerType.Middle);
				Slot slot4 = FindFingerRoot(root, FingerType.Ring);
				Slot slot5 = FindFingerRoot(root, FingerType.Pinky);
				list.Add(new PotentialFinger(root, slot, FingerType.Thumb, componentInChildren));
				if (slot2 != null)
				{
					list.Add(new PotentialFinger(root, slot2, FingerType.Index, componentInChildren));
				}
				if (slot3 != null)
				{
					list.Add(new PotentialFinger(root, slot3, FingerType.Middle, componentInChildren));
				}
				if (slot4 != null)
				{
					list.Add(new PotentialFinger(root, slot4, FingerType.Ring, componentInChildren));
				}
				if (slot5 != null)
				{
					list.Add(new PotentialFinger(root, slot5, FingerType.Pinky, componentInChildren));
				}
				if (list.Count < 3)
				{
					return false;
				}
				foreach (PotentialFinger item6 in list)
				{
					item6.DetermineSegments();
				}
			}
			foreach (PotentialFinger item7 in list)
			{
				item7.ExtractFingers(rig, chirality);
			}
			return true;
		}

		private static Slot FindFingerRoot(Slot root, FingerType type)
		{
			Slot slot = root.FindChild((Slot s) => NameToFingerType(NameHeuristicsHelper.SplitName(s.Name)) == type);
			if (slot == null)
			{
				return null;
			}
			if (MathX.Distance(root.GlobalPosition, slot.GlobalPosition) > 1E-05f && slot.Parent.Name.ToLower().Contains("palm") && IsSingleChildChain(slot.Parent, 2))
			{
				slot = slot.Parent;
			}
			return slot;
		}

		private static List<Slot> GetFingerRoots(Slot root)
		{
			if (root.ChildrenCount >= 5)
			{
				List<Slot> list = new List<Slot>();
				foreach (Slot child in root.Children)
				{
					if (IsSingleChildChain(child, 2))
					{
						list.Add(child);
					}
				}
				if (list.Count == 5)
				{
					return list;
				}
			}
			foreach (Slot child2 in root.Children)
			{
				List<Slot> fingerRoots = GetFingerRoots(child2);
				if (fingerRoots != null)
				{
					return fingerRoots;
				}
			}
			return null;
		}

		private static bool IsSingleChildChain(Slot root, int depth)
		{
			if (depth > 0)
			{
				Slot nextChainSegment = GetNextChainSegment(root);
				if (nextChainSegment == null)
				{
					return false;
				}
				return IsSingleChildChain(nextChainSegment, depth - 1);
			}
			return true;
		}

		public static Slot GetNextChainSegment(Slot root)
		{
			List<Slot> list = root.Children.Where((Slot s) => (s.GetComponent<CapsuleCollider>() == null || s.ChildrenCount != 0) ? true : false).ToList();
			if (list.Count == 0 && root.ChildrenCount == 1)
			{
				return root[0];
			}
			if (list.Count == 1)
			{
				return list[0];
			}
			return null;
		}

