			{
				if (_streamingState != OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED)
				{
					RecordOrStreamStarted();
				}
				obs.ToggleStream();
			}
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnRecord(IButton button, ButtonEventData eventData)
