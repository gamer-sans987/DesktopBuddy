		public bool HasMinimalHand(Chirality chirality)
		{
			if (FingerSegmentCount(FingerType.Thumb, chirality, excludeMetacarpal: false) < 2)
			{
				return false;
			}
			int num = 0;
			for (FingerType fingerType = FingerType.Index; fingerType <= FingerType.Pinky; fingerType++)
			{
				if (FingerSegmentCount(fingerType, chirality, excludeMetacarpal: true) >= 2)
				{
					num++;
				}
			}
			return num >= 2;
		}

		public int FingerSegmentCount(FingerType finger, Chirality chirality, bool excludeMetacarpal)
		{
			return Bones.Count<KeyValuePair<BodyNode, SyncRef<Slot>>>(delegate(KeyValuePair<BodyNode, SyncRef<Slot>> e)
			{
				if (!e.Key.IsFinger() || e.Key.GetChirality() != chirality)
				{
					return false;
				}
				return (!excludeMetacarpal || e.Key.GetFingerSegmentType() != FingerSegmentType.Metacarpal) && e.Key.GetFingerType() == finger;
			});
		}

