		protected override void OnCommonUpdate()
		{
			if (Control != null)
			{
				if (Control.IsDestroyed)
				{
					base.Slot.Destroy();
					return;
				}
				if (!_originalScale.HasValue && base.LocalUser.Root?.Slot != null)
				{
					_originalScale = base.LocalUser.Root.Slot.GlobalScaleToLocal(base.Slot.GlobalScale.x);
				}
				DestroyOnUserLeave.Target = base.LocalUser;
				MainCamera.Target.RenderPrivateUI = Control.RenderPrivateUI;
				SecondaryCamera.Target.RenderPrivateUI = Control.RenderPrivateUI;
				MainCamera.Target.MotionBlur.Value = Control.MotionBlur;
				SecondaryCamera.Target.MotionBlur.Value = Control.MotionBlur;
				MainCamera.Target.ScreenSpaceReflections.Value = Control.ScreenSpaceReflections;
				SecondaryCamera.Target.ScreenSpaceReflections.Value = Control.ScreenSpaceReflections;
				float num = base.LocalUserRoot?.GlobalScale ?? 1f;
				if (Control.Mode.Value == CameraPositioningMode.SmoothFirstPerson)
				{
					MainCamera.Target.NearClipping.Value = (base.LocalUserRoot?.RenderSettings.Target?.NearClip ?? ((float)DefaultNearClip)) * num;
					MainCamera.Target.FarClipping.Value = base.LocalUserRoot?.RenderSettings.Target?.FarClip ?? ((float)DefaultFarClip);
				}
				else
				{
					MainCamera.Target.NearClipping.Value = MathX.Max((float)DefaultNearClip * num, 1E-05f);
					MainCamera.Target.FarClipping.Value = DefaultFarClip;
				}
				if ((bool)Control.RenderForEveryone)
				{
					RenderOnlyForUsers.EnsureExactCount(0);
				}
				else
				{
					RenderOnlyForUsers.EnsureExactCount(1);
					RenderOnlyForUsers[0].Target = base.LocalUser;
				}
				if ((bool)Control.AnyoneCanInteract)
				{
					ExclusiveOperators.EnsureExactCount(0);
				}
				else if (_lastControlOperatorsVersion != Control.OperatorsVersion)
				{
					ExclusiveOperators.EnsureExactCount(1 + Control.CameraOperators.Count);
					ExclusiveOperators[0].Target = base.LocalUser;
					for (int i = 0; i < Control.CameraOperators.Count; i++)
					{
						ExclusiveOperators[i + 1].SetFromIdAuto(Control.CameraOperators[i]);
					}
				}
				SpawnPhotoInWorld.Value = Control.SpawnPhotoInWorld.Value;
				if ((bool)Control.InterpolateBetweenAnchors)
				{
					AnchorInterpolationSpeed.Value = Control.AnchorInterpolationSpeed;
					AnchorLinearInterpolation.Value = Control.AnchorLinearInterpolation;
				}
				else
				{
					AnchorInterpolationSpeed.Value = 0f;
				}
				List<InteractiveCameraAnchor> list = Pool.BorrowList<InteractiveCameraAnchor>();
				base.World.GetGloballyRegisteredComponents(list);
				foreach (InteractiveCameraAnchor item in list)
				{
					if (base.Slot.IsChildOf(item.Slot))
					{
						if (_excludedAnchors.Contains(item))
						{
							MainCamera.Target.ExcludeRender.Remove(item.Slot);
							_excludedAnchors.Remove(item);
						}
					}
					else if (!_excludedAnchors.Contains(item))
					{
						MainCamera.Target.ExcludeRender.Add(item.Slot);
						_excludedAnchors.Add(item);
					}
				}
				_excludedAnchors.RemoveWhere((InteractiveCameraAnchor a) => a.IsDestroyed);
				Pool.Return(ref list);
				MainCamera.Target.ExcludeRender.RemoveAll(null);
				Slot slot = base.LocalUserRoot?.GetRegisteredComponent<AvatarManager>()?.AutomaticLiveBadge;
				if (slot != null && _excludedLocalLiveBadge != slot)
				{
					MainCamera.Target.ExcludeRender.AddUnique(slot);
					_excludedLocalLiveBadge = slot;
				}
				if (Control.HideBadge)
				{
					List<User> list2 = Pool.BorrowList<User>();
					base.World.GetUsers(list2);
					AvatarManager.CollectAllBadgeRoots(list2, delegate(Slot root)
					{
						MainCamera.Target.ExcludeRender.AddUnique(root);
						_excludedBadges.Add(root);
					});
					Pool.Return(ref list2);
				}
				else
				{
					foreach (Slot excludedBadge in _excludedBadges)
					{
						MainCamera.Target.ExcludeRender.Remove(excludedBadge);
					}
					_excludedBadges.Clear();
				}
				if (FrustumVisual.Target != null)
				{
					FrustumVisual.Target.Slot.ActiveSelf = Control.ShowFrustum;
				}
				if (Control.HideLasers != _lastHideLasers)
				{
					_lastHideLasers = Control.HideLasers;
					List<Slot> list3 = Pool.BorrowList<Slot>();
					InteractionHandler.GetLaserRoots(base.LocalUser, list3);
					foreach (Slot item2 in list3)
					{
						if (_lastHideLasers.Value)
						{
							MainCamera.Target.ExcludeRender.AddUnique(item2);
						}
						else
						{
							MainCamera.Target.ExcludeRender.Remove(item2);
						}
					}
					Pool.Return(ref list3);
				}
				MainCamera.Target.ExcludeRender.RemoveAll((AutoSyncRef<Slot> r) => r.Target == null);
				if (Control.ForceEyesOnCamera)
				{
					ForceEyeAttentionUsers.EnsureExactCount(1);
					ForceEyeAttentionUsers[0].Target = base.LocalUser;
				}
				else
				{
					ForceEyeAttentionUsers.Clear();
				}
				if (base.LocalUserRoot != null)
				{
					if (Control.AudioFromCameraViewpoint)
					{
						if (_cameraListener == null)
						{
							Slot slot2 = base.LocalUserRoot.PrimaryListener.Target.Slot.Duplicate(base.Slot, keepGlobalTransform: false);
							_cameraListener = slot2.GetComponent<AudioListener>();
						}
						if (base.AudioSystem.StreamingOutput.Device != null)
						{
							_cameraListener.TargetOutput.Value = AudioListener.ListenerTarget.StreamingCamera;
							base.LocalUserRoot.PrimaryListener.Target.Enabled = true;
						}
						else
						{
							_cameraListener.TargetOutput.Value = AudioListener.ListenerTarget.Default;
							base.LocalUserRoot.PrimaryListener.Target.Enabled = false;
						}
					}
					else
					{
						RestoreListener();
					}
				}
				ForceVisualsOff.Value = Control.HideCamera;
				AvoidOcclusion.Value = Control.AvoidOcclusion;
				GroupIncludeRadius.Value = Control.GroupDetectionRadius.Value;
				GroupExcludeRadius.Value = GroupIncludeRadius.Value + Control.GroupLeaveBoundary.Value;
				PositionSmoothSpeed.Value = Control.PositionSmoothSpeed;
				AnglePositionSmoothSpeed.Value = Control.AngleSmoothSpeed;
				FramingSmoothSpeed.Value = Control.FramingSmoothSpeed;
				if (_lastControlGroupVersion != Control.GroupModeVersion)
				{
					ForceGroupExclude.Clear();
					ForceGroupInclude.Clear();
					foreach (string groupExcludeUser in Control.GroupExcludeUsers)
					{
						ForceGroupExclude.Add().SetFromIdAuto(groupExcludeUser);
					}
