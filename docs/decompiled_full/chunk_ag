		private void BuildExcludeList(Slot root, List<Slot> list)
		{
			if (!root.PersistentSelf || root.Tag == "Developer" || root.ActiveUserRoot != null || root.GetComponent<IDeveloperInterface>() != null || root.GetComponent<IComponentGizmo>() != null)
			{
				list.Add(root);
				return;
			}
			if (root.GetComponent<ReflectionProbe>() != null)
			{
				foreach (Slot child in root.Children)
				{
					list.Add(child);
				}
				return;
			}
			foreach (Slot child2 in root.Children)
			{
				BuildExcludeList(child2, list);
			}
		}

		public static List<ReflectionProbe> GetBakedReflectionProbes(Slot root, bool includeInactive = false, string tag = null)
		{
			return root.GetComponentsInChildren((ReflectionProbe p) => p.ProbeType.Value == ReflectionProbeType.Baked && (includeInactive || (p.Enabled && p.Slot.IsActive)) && (string.IsNullOrWhiteSpace(tag) || p.Slot.Tag == tag));
		}

		public static async Task BakeReflectionProbes(List<ReflectionProbe> probes, float delayBeforeBake, Func<int, ReflectionProbe, Task> beforeBake = null, Func<int, ReflectionProbe, Task> onBaked = null)
		{
			for (int i = 0; i < probes.Count; i++)
			{
				ReflectionProbe probe = probes[i];
				if (!probe.IsDestroyed)
				{
					if (beforeBake != null)
					{
						await beforeBake(i, probe);
					}
					await Task.Delay(TimeSpan.FromSeconds(delayBeforeBake));
					await probe.BakeAsync();
					if (onBaked != null)
					{
						await onBaked(i, probe);
					}
				}
			}
		}

