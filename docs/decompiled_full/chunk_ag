		public static IFingerPoseSourceComponent MapToComponent(this IFingerPoseSource source, Slot slot)
		{
			if (source is IFingerPoseSourceComponent result)
			{
				return result;
			}
			if (source == FingerPosePresets.Idle)
			{
				return GetSharedPreset(slot, FingerPosePreset.Preset.Idle);
			}
			if (source == FingerPosePresets.Fist)
			{
				return GetSharedPreset(slot, FingerPosePreset.Preset.Fist);
			}
			if (source == FingerPosePresets.Point)
			{
				return GetSharedPreset(slot, FingerPosePreset.Preset.Point);
			}
			UniLog.Warning($"Unable to map finger pose source to data model: {source}");
			return null;
		}

		public static FingerPosePreset GetSharedPreset(Slot slot, FingerPosePreset.Preset preset)
		{
			FingerPosePreset component = slot.GetComponent((FingerPosePreset p) => p.PresetPose.Value == preset);
			if (component != null)
			{
				return component;
			}
			component = slot.AttachComponent<FingerPosePreset>();
			component.PresetPose.Value = preset;
			return component;
		}
