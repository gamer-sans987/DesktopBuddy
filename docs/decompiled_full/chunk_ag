		public static void GenerateDebugVisual(BoneNode node, IAssetProvider<Material> material = null, float radius = 0.01f)
		{
			if (material == null)
			{
				OverlayFresnelMaterial overlayFresnelMaterial = node.bone.World.AssetsSlot.AddSlot("RigDebugMaterial").AttachComponent<OverlayFresnelMaterial>();
				overlayFresnelMaterial.Slot.PersistentSelf = false;
				overlayFresnelMaterial.BlendMode.Value = BlendMode.Alpha;
				Elements.Core.colorX a = RandomX.Hue;
				overlayFresnelMaterial.FrontNearColor.Value = a * 0.5f;
				overlayFresnelMaterial.FrontFarColor.Value = a;
				overlayFresnelMaterial.SetBehindColorFromFront((Elements.Core.colorX c) => c.SetA(0.73f));
				material = overlayFresnelMaterial;
			}
			GenerateDebugVisualIntern(node, material, radius);
