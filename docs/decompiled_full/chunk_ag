			Slot slot2 = slot.AddSlot("MeshPreview");
			slot2.AttachComponent<Spinner>().Speed = new Elements.Core.float3(0f, 90f);
			Slot slot3 = slot2.AddSlot("Holder");
			slot3.AttachMesh(mesh, sharedComponentOrCreate3);
			Elements.Core.BoundingSphere boundingSphere = Elements.Core.BoundingSphere.FromBoundingBox(mesh.Asset.Bounds);
			float num = 1f / boundingSphere.radius * 0.05f;
			slot3.LocalScale = Elements.Core.float3.One * num;
			slot3.LocalPosition = -boundingSphere.center * num;
			slot.AttachComponent<AssetProxy<Mesh>>().AssetReference.Target = mesh;
			slot.AttachComponent<ReferenceProxy>().Reference.Target = mesh;
			slot.AttachComponent<Grabbable>().ReparentOnRelease.Value = false;
			slot.AttachComponent<Snapper>();
			slot.AttachComponent<SphereCollider>().Radius.Value = 0.05f;
		}

