		[SyncMethod(typeof(Delegate), null)]
		private void RunConversion(DevCreateNewForm form, Slot newMaterialRoot)
		{
			IAssetProvider<Material> componentInChildren = newMaterialRoot.GetComponentInChildren<IAssetProvider<Material>>();
			Slot slot = form.Slot.GetComponent((ReferenceProxy p) => p.Reference.Target is Slot)?.Reference.Target as Slot;
			IAssetProvider<Material> assetProvider = ((slot == null) ? GetMaterial() : null);
			if (componentInChildren == null || (assetProvider == null && slot == null))
			{
				return;
			}
			if (slot != null)
			{
				List<Slot> list = new List<Slot>();
				base.World.BeginUndoBatch("Undo.BatchConvertMaterials".AsLocaleKey());
				foreach (IAssetProvider<Material> item in MaterialOrb.ExtractAllMaterials(slot))
				{
					Slot slot2 = newMaterialRoot.Duplicate();
					IAssetProvider<Material> componentInChildren2 = slot2.GetComponentInChildren<IAssetProvider<Material>>();
					MaterialHelper.CopyMaterialProperties(item, componentInChildren2);
					MaterialHelper.ReplaceAll(slot, item, componentInChildren2, respectPolicy: true, undoable: true);
					slot2.Name = item.Slot.Name;
					list.Add(slot2);
				}
				newMaterialRoot.Destroy();
				SlotPositioning.ArrangeInGrid(list, base.Tip, base.World.LocalUserViewRotation, 0.112500004f);
				base.World.EndUndoBatch();
			}
			else
			{
				base.World.BeginUndoBatch("Undo.BatchConvertMaterials".AsLocaleKey());
				MaterialHelper.CopyMaterialProperties(assetProvider, componentInChildren);
				MaterialHelper.ReplaceAll(base.World.RootSlot, assetProvider, componentInChildren, respectPolicy: true, undoable: true);
				base.World.EndUndoBatch();
				newMaterialRoot.Name = assetProvider.Slot.Name;
			}
		}

