		{
			_setupMesh = null;
			foreach (Slot markedBone in _markedBones)
			{
				markedBone.DecrementRenderable();
			}
			_markedBones = null;
			base.Slot.ActiveUserRootChanged -= Slot_ActiveUserRootChanged;
			base.OnDispose();
