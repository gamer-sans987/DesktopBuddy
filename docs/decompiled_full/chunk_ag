	public abstract class FingerPoseProcessor : Component, IFingerPoseSourceComponent, IFingerPoseSource, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		protected bool _isTrackingLeft;

		protected bool _isTrackingRight;

		protected bool _metacarpals;

		private List<Elements.Core.float3> _positionsLeft = new List<Elements.Core.float3>();

		private List<Elements.Core.floatQ> _rotationsLeft = new List<Elements.Core.floatQ>();

		private List<Elements.Core.float3> _positionsRight = new List<Elements.Core.float3>();

		private List<Elements.Core.floatQ> _rotationsRight = new List<Elements.Core.floatQ>();

		private int _lastUpdate;

		public bool TracksMetacarpals => _metacarpals;

		private void EnsureUpdatedData()
		{
			if (_lastUpdate == base.Time.LocalUpdateIndex)
			{
				return;
			}
			_lastUpdate = base.Time.LocalUpdateIndex;
			try
			{
				UpdatePoses();
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception updating poses on {this}\n\n{value}");
				base.Enabled = false;
			}
		}

		public bool AreFingersTracking(Chirality chirality)
		{
			if (!base.Enabled)
			{
				return false;
			}
			EnsureUpdatedData();
			if (chirality != Chirality.Left)
			{
				return _isTrackingRight;
			}
			return _isTrackingLeft;
		}

		protected void GetData(Chirality side, out List<Elements.Core.float3> positions, out List<Elements.Core.floatQ> rotations)
		{
			if (side == Chirality.Left)
			{
				positions = _positionsLeft;
				rotations = _rotationsLeft;
			}
			else
			{
				positions = _positionsRight;
				rotations = _rotationsRight;
			}
		}

		public void GetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			if (!TryGetFingerData(node, out position, out rotation))
			{
				throw new Exception($"Unable to get finger data for {node}");
			}
		}

		public void GetFingerData(List<BodyNode> nodes, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			EnsureUpdatedData();
			foreach (BodyNode node in nodes)
			{
				GetFingerData(node, out var position, out var rotation);
				positions?.Add(position);
				rotations?.Add(rotation);
			}
		}

		public void GetFingerData(Chirality chirality, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			EnsureUpdatedData();
			GetData(chirality, out List<Elements.Core.float3> positions2, out List<Elements.Core.floatQ> rotations2);
			if ((positions2.Count != 24 && positions2.Count != 0) || rotations2.Count != 24)
			{
				throw new Exception($"Finger data has invalid number of elements for {chirality}. Positions: {positions2.Count}, Rotations: {rotations2.Count}, Expected: {24}\nLeftTracking: {_isTrackingLeft}, RightTracking: {_isTrackingRight}, Metacarpals: {_metacarpals}, LastUpdate: {_lastUpdate} (current: {base.Time.LocalUpdateIndex})\nPositionsLeft: {_positionsLeft.Count}, RotationsLeft: {_rotationsLeft.Count}, PositionsRight: {_positionsRight.Count}, RotationsRight: {_rotationsRight.Count}\nOn: {this}");
			}
			if (positions != null)
			{
				if (positions2.Count == 0)
				{
					positions.Clear();
				}
				else
				{
					positions.AddRange(positions2);
				}
			}
			rotations?.AddRange(rotations2);
		}

		public bool TryGetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			EnsureUpdatedData();
			Chirality chirality = node.GetChirality();
			if (!AreFingersTracking(chirality))
			{
				position = default(Elements.Core.float3);
				rotation = Elements.Core.floatQ.Identity;
				return false;
			}
			int fingerSegmentIndex = node.GetFingerSegmentIndex();
			GetData(chirality, out List<Elements.Core.float3> positions, out List<Elements.Core.floatQ> rotations);
			position = positions[fingerSegmentIndex];
			rotation = rotations[fingerSegmentIndex];
			return true;
		}

		protected abstract void UpdatePoses();

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
		}
	}
