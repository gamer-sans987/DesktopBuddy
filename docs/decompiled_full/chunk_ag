				screen = base.LocalUserRoot.GetRegisteredComponent<ScreenController>();
			}
			while (menu.CurrentSummoner == summoner && (menu.MenuState == FrooxEngine.ContextMenu.State.Opening || screen?.ActiveTargetting.Target?.IsViewTransitioning == true))
			{
				if (base.InputInterface.VR_Active)
				{
					Elements.Core.float3 to = (menu.Slot.GlobalPosition - base.LocalUserRoot.HeadPosition).Normalized;
					Elements.Core.float3 from = CurrentTip + CurrentTipForward * base.Slot.LocalScaleToGlobal(0.075f);
					Elements.Core.floatQ a = Elements.Core.floatQ.LookRotation(MathX.Lerp(CurrentTipForward, in to, 0.5f), base.LocalUserRoot?.Slot.Up ?? Elements.Core.float3.Up);
					float num = MathX.Pow(menu.Lerp, 6f);
					menu.Slot.GlobalPosition = MathX.Lerp(in from, menu.Slot.GlobalPosition, num);
					menu.Slot.GlobalRotation = MathX.Slerp(in a, menu.Slot.GlobalRotation, num);
					menu.Slot.LocalScale = Elements.Core.float3.One;
				}
				else
				{
					Elements.Core.float3 a2 = base.World.LocalUserViewPosition;
					Elements.Core.floatQ q = base.World.LocalUserViewRotation;
					Elements.Core.float3? @float = base.World.GetScreen()?.GetWorldPoint(Laser.LastOrigin, Laser.LastDirection, null);
					if (@float.HasValue)
					{
						menu.Slot.GlobalPosition = @float.Value;
					}
					else
					{
						float num2 = MathX.Distance(in a2, base.LocalUserRoot.HeadPosition);
						menu.Slot.GlobalPosition = a2 + q * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Forward) * (0.5f * base.LocalUserRoot.GlobalScale + num2);
					}
					menu.Slot.GlobalRotation = q;
					menu.Slot.GlobalScale = Elements.Core.float3.One * MathX.Distance(menu.Slot.GlobalPosition, in a2) * 1.5f;
				}
				await default(NextUpdate);
			}
			static ref readonly T ILSpyHelper_AsRefReadOnly<T>(in T temp)
