		private void PinTwitchDialog(TwitchChatDialog dialog)
		{
			Slot slot = dialog.Slot;
			slot.Parent = base.Slot;
			slot.CopyTransform(base.Slot);
			dialog.CanvasSize = new Elements.Core.float2(800f, 1080f) * 0.4f;
			dialog.PhysicalHeight = base.Slot.LocalScaleToGlobal(0.3f);
			slot.LocalPosition += Elements.Core.float3.Right * 0.415f;
