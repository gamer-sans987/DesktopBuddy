		public float TwistAngle
		{
			get
			{
				Slot slot = base.LocalUserRoot?.Slot;
				if (slot == null)
				{
					return 0f;
				}
				Elements.Core.float3 from = slot.GlobalDirectionToLocal(CurrentTipForward);
				Elements.Core.float3 v = slot.GlobalDirectionToLocal(CurrentTipUp);
				Elements.Core.float3 to = from.x_z.Normalized;
				v = Elements.Core.floatQ.FromToRotation(in from, in to) * v;
				return (0f - MathX.Atan2((Elements.Core.floatQ.FromToRotation(in to, Elements.Core.float3.Forward) * v).xy)) * 57.29578f;
			}
		}

