	public static class InteractiveCameraExtensions
	{
		public static InteractiveCamera GetActiveInteractiveCamera(this World world)
		{
			return world.GetGloballyRegisteredComponents<InteractiveCamera>().FirstOrDefault(delegate(InteractiveCamera c)
			{
				if (c.ExclusiveOperators.Any((UserRef u) => u.Target == world.LocalUser))
				{
					return true;
				}
				if (c.ExclusiveOperators.Count > 0)
				{
					return false;
				}
				if (c.SimulatingUser.Target == world.LocalUser)
				{
					return true;
				}
				return c.Control != null;
			});
		}
	}
