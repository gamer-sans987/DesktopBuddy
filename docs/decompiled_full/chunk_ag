		[SyncMethod(typeof(Delegate), null)]
		private void OnLaunchOBS(IButton button, ButtonEventData eventData)
		{
			button.Enabled = false;
			button.LabelText = this.GetLocalized("CameraControl.OBS.Launching");
			StartTask(async delegate
			{
				obsRunning = true;
				await default(ToBackground);
				Process process = new Process();
				process.StartInfo.UseShellExecute = true;
				process.StartInfo.WorkingDirectory = PathUtility.GetDirectoryName(obsExecutable);
				process.StartInfo.FileName = obsExecutable;
				process.Start();
				await default(ToWorld);
				if (!button.IsDestroyed)
				{
					button.LabelText = this.GetLocalized("CameraControl.OBS.Launched");
				}
			});
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnConnect(IButton button, ButtonEventData eventData)
		{
			button.LabelText = this.GetLocalized("CameraControl.OBS.Connecting");
			button.Enabled = false;
			try
			{
				obs.ConnectAsync(_connectAddress.Target.TargetString, _connectPassword.Target.TargetString);
				RunSynchronously(OpenConnectedPanel);
			}
			catch (Exception ex)
			{
				Exception e = ex;
				RunSynchronously(delegate
				{
					OpenErrorPage(this.GetLocalized("CameraControl.OBS.UnexpectedConnectionError") + "\n" + e.Message);
				});
			}
		}

		[SyncMethod(typeof(Delegate), null)]
		private void OnStream(IButton button, ButtonEventData eventData)
		{
