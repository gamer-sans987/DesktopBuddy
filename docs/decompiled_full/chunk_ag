		public class FingerSegment : SyncObject
		{
			public readonly Sync<Elements.Core.floatQ> CoordinateCompensation;

			public readonly SyncRef<Slot> Root;

			public readonly Sync<Elements.Core.floatQ> OriginalRotation;

			public readonly FieldDrive<Elements.Core.floatQ> RotationDrive;

			public void Assign(Slot slot)
			{
				Root.Target = slot;
				OriginalRotation.Value = slot?.LocalRotation ?? Elements.Core.floatQ.Identity;
				RotationDrive.Target = slot?.Rotation_Field;
			}

			public void ComputeCoordinateCompensation(Slot handRoot, Elements.Core.float3 handForward, Elements.Core.float3 handUp, Elements.Core.float3 handRight, bool isThumb, bool isLeft)
			{
				if (Root.Target == null)
				{
					return;
				}
				Slot target = Root.Target;
				Elements.Core.float3 a = Elements.Core.float3.Zero;
				bool flag = false;
				Slot neighborSegment = GetNeighborSegment(upwards: false);
				if (neighborSegment != null)
				{
					string text = neighborSegment.Name.ToLower();
					if (text.Contains("end") || text.Contains("tip"))
					{
						flag = true;
					}
				}
				if (neighborSegment != null)
				{
					a = neighborSegment.GlobalPosition - target.GlobalPosition;
				}
				Slot neighborSegment2 = GetNeighborSegment(upwards: true);
				Elements.Core.float3 a2 = target.GlobalPosition - neighborSegment2.GlobalPosition;
				if (a == Elements.Core.float3.Zero || (flag && MathX.Dot(in a2, in a) < 0.5f))
				{
					UniLog.Log("Using alternate selfForward detection");
					a = a2;
				}
				a = target.GlobalDirectionToLocal(in a).Normalized;
				Elements.Core.float3 from = target.SpaceDirectionToLocal(in handForward, handRoot);
				Elements.Core.float3 v = target.SpaceDirectionToLocal(in handUp, handRoot);
				Elements.Core.float3 v2 = target.SpaceDirectionToLocal(in handRight, handRoot);
				Elements.Core.floatQ q = Elements.Core.floatQ.FromToRotation(in from, in a);
				from = q * from;
				v = q * v;
				v2 = q * v2;
				if (isThumb)
				{
					CoordinateCompensation.Value = Elements.Core.floatQ.LookRotation(in from, isLeft ? v2 : (-v2)).Inverted;
				}
				else
				{
					CoordinateCompensation.Value = Elements.Core.floatQ.LookRotation(in from, in v).Inverted;
				}
			}

			private Slot GetNeighborSegment(bool upwards)
			{
				if (Root.Target == null)
				{
					return null;
				}
				Slot slot = Root.Target;
				_ = Root.Target;
				do
				{
					if (slot == null)
					{
						return null;
					}
					slot = ((!upwards) ? BipedRig.GetNextChainSegment(slot) : slot.Parent);
				}
				while (!IsValidSegment(slot));
				if (!IsValidSegment(slot))
				{
					return null;
				}
				return slot;
			}

			private bool IsValidSegment(Slot current)
			{
				if (current == null)
				{
					return false;
				}
				if (current.LocalPosition.SqrMagnitude <= 1E-05f)
				{
					return false;
				}
				if (current.GetComponent<CapsuleCollider>() != null)
				{
					return false;
				}
				return true;
			}

