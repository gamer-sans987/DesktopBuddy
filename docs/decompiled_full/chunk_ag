						blendModeMaterial.BlendMode = BlendMode.Transparent;
					}
				}
				else if (blendModeMaterial.IsBlendModeSupported(BlendMode.Opaque))
				{
					blendModeMaterial.BlendMode = BlendMode.Opaque;
				}
			}
			switch (CameraMode.Value)
			{
			case Mode.Camera2D:
				MainCamera.Target.Clear.Value = CameraClearMode.Skybox;
				SetStereo(stereo: false);
				break;
			case Mode.Camera360:
				MainCamera.Target.Clear.Value = CameraClearMode.Skybox;
				SetStereo(stereo: false);
				break;
			case Mode.CameraObject:
				MainCamera.Target.Clear.Value = CameraClearMode.Color;
				MainCamera.Target.ClearColor.Value = Elements.Core.colorX.Clear;
				SetStereo(stereo: false);
				break;
			case Mode.CameraStereo:
			{
				MainCamera.Target.Clear.Value = CameraClearMode.Skybox;
				SetStereo(stereo: true);
				SecondaryCamera.Target.ExcludeRender.EnsureExactCount(MainCamera.Target.ExcludeRender.Count);
				for (int i = 0; i < MainCamera.Target.ExcludeRender.Count; i++)
				{
					SecondaryCamera.Target.ExcludeRender[i] = MainCamera.Target.ExcludeRender[i];
				}
				break;
			}
			}
		}

		private void SetStereo(bool stereo)
		{
			if (stereo)
			{
				PreviewScale.Value = new Elements.Core.float2(0.5f, 1f);
				Camera target = MainCamera.Target;
				Camera target2 = SecondaryCamera.Target;
				target2.FieldOfView.Value = target.FieldOfView;
				target2.NearClipping.Value = target.NearClipping;
				target2.FarClipping.Value = target.FarClipping;
				target2.Clear.Value = target.Clear;
				target2.ClearColor.Value = target.ClearColor;
				target2.Projection.Value = target.Projection;
				target2.OrthographicSize.Value = target.OrthographicSize;
				target2.RenderTexture.Target = target.RenderTexture.Target;
				target2.Depth.Value = target.Depth;
				target2.DoubleBuffered.Value = target.DoubleBuffered;
				target2.Postprocessing.Value = target.Postprocessing;
				target2.ScreenSpaceReflections.Value = target.ScreenSpaceReflections;
				MainCamera.Target.Viewport.Value = new Elements.Core.Rect(0f, 0f, 0.5f, 1f);
				SecondaryCamera.Target.Viewport.Value = new Elements.Core.Rect(0.5f, 0f, 0.5f, 1f);
				if (DisplayMaterial.Target != null)
				{
					SetupStereoMaterial(DisplayMaterial.Target);
				}
				SetSeparation(MainCamera.Target.Slot.GlobalScaleToLocal(StereoSeparation));
			}
			else
			{
				PreviewScale.Value = new Elements.Core.float2(1f, 1f);
				MainCamera.Target.Viewport.Value = new Elements.Core.Rect(0f, 0f, 1f, 1f);
				if (DisplayMaterial.Target != null)
				{
					SetupMonoMaterial(DisplayMaterial.Target);
				}
				SetSeparation(0f);
			}
		}

		private Elements.Core.int2 GetFinalPreviewResolution()
		{
			if (CameraMode.Value == Mode.CameraStereo)
			{
				return new Elements.Core.int2((int)PreviewWidth * 2, PreviewHeight);
			}
			return new Elements.Core.int2(PreviewWidth, PreviewHeight);
		}

		private Elements.Core.int2 GetSingleRenderResolution()
		{
			int y = MathX.RoundToInt((float)(int)PreviewHeight / (float)(int)PreviewWidth * (float)(int)RenderWidth);
			return new Elements.Core.int2(RenderWidth, y);
		}

		private Elements.Core.int2 GetFinalRenderResolution()
		{
			Elements.Core.int2 singleRenderResolution = GetSingleRenderResolution();
			if (CameraMode.Value == Mode.CameraStereo)
			{
				return new Elements.Core.int2(singleRenderResolution.x * 2, singleRenderResolution.y);
			}
			if (CameraMode.Value == Mode.Camera360)
			{
				return new Elements.Core.int2(singleRenderResolution.x, singleRenderResolution.x / 2);
			}
			return singleRenderResolution;
		}

		private void SetSeparation(float separation)
		{
