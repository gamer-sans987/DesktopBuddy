	public static class SharedComponents
	{
		public static T GetSharedComponentOrCreate<T>(this World world, string sharedKey, Action<T> onCreate, int version = 0, bool replaceExisting = false, bool updateExisting = false, Func<Slot> getRoot = null) where T : Component, new()
		{
			Component component = world.KeyOwner(sharedKey);
			if (component != null)
			{
				if (component is T val)
				{
					if (version > 0 && world.KeyVersion(sharedKey) < version)
					{
						updateExisting = true;
						world.RequestKey(val, sharedKey, version, onlyFree: false);
					}
					if (updateExisting)
					{
						onCreate(val);
					}
					return val;
				}
				if (!replaceExisting)
				{
					throw new Exception("An incompatible component is stored under the key " + sharedKey + $"\nExisting: {component}");
				}
			}
			T val2 = (getRoot?.Invoke() ?? world.RootSlot).AttachComponent<T>();
			onCreate(val2);
			world.RequestKey(val2, sharedKey, version, onlyFree: false);
			return val2;
		}
	}
