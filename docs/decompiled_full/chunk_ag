		private IAssetProvider<Material> GetMaterial(MeshRenderer renderer, int index)
		{
			if (EnsureUniqueMaterial.Value)
			{
				renderer.Materials.GetElement(index).CreateUndoPoint();
				return renderer.GetUniqueMaterial(index);
			}
			return renderer.Materials[index];
		}

		public override void OnPrimaryPress()
		{
			RaycastHit? hit = GetHit();
			if (!hit.HasValue)
			{
				return;
			}
			RaycastHit value = hit.Value;
			MeshRenderer componentInParents = value.Collider.Slot.GetComponentInParents<MeshRenderer>();
			if ((_colorDialog.Target != null && componentInParents != null && componentInParents.Slot.IsChildOf(_colorDialog.Target.Slot)) || componentInParents == null)
			{
				return;
			}
			int num = -1;
			if (value.IsMeshCollider)
			{
				num = value.GetTriangle().SubmeshIndex;
			}
			base.World.BeginUndoBatch("Undo.ChangeColor".AsLocaleKey());
			if (num == -1 || num >= componentInParents.Materials.Count)
			{
				for (int i = 0; i < componentInParents.Materials.Count; i++)
				{
					if (componentInParents.Materials[i] != null)
					{
						SetColor(GetMaterial(componentInParents, i));
					}
				}
			}
			else if (componentInParents.Materials[num] != null)
			{
				SetColor(GetMaterial(componentInParents, num));
			}
			base.World.EndUndoBatch();
		}

		public void SetColor(IAssetProvider<Material> material)
		{
			Worker obj = (Worker)material;
			ColorHSV colorHSV = new ColorHSV((Elements.Core.colorX)Color);
			foreach (ISyncMember syncMember in obj.SyncMembers)
			{
				if (syncMember is IField<Elements.Core.colorX> { Value: var cRGB } field)
				{
					ColorHSV colorHSV2 = new ColorHSV(in cRGB);
					if (colorHSV2.v != 0f)
					{
						field.CreateUndoPoint();
						field.Value = new ColorHSV(colorHSV.h, colorHSV.s, (colorHSV2.v + colorHSV.v) * 0.5f).ToRGB(field.Value.profile);
					}
				}
			}
		}

