	[Category(new string[] { "Tools" })]
	[OldTypeName("FrooxEngine.MaterialTip", null)]
	public class MaterialTool : OrbCartridgeTool
	{
		private struct Target
		{
			public IMaterialTarget target;

			public MeshRenderer renderer;

			public int materialIndex;
		}

		public readonly Sync<AssetToolReplacementMode> ReplacementMode;

		public readonly Sync<float> AreaRadius;

		protected readonly SyncRef<Slot> _areaIndicator;

		protected readonly FieldDrive<float> _areaIndicatorRadius;

		protected readonly FieldDrive<Elements.Core.float3> _areaIndicatorOffset;

		protected readonly FieldDrive<bool> _areaIndicatorActive;

		protected readonly FieldDrive<bool> _knobControlActive;

		private BatchAction _activeUndoBatch;

		public override bool UsesLaser => ReplacementMode.Value != AssetToolReplacementMode.Area;

		public override string PrimaryDescription => this.GetLocalized("Tutorial.Tooltip.MaterialPrimary");

		public override string SecondaryDescription => this.GetLocalized("Tutorial.Tooltip.MaterialSecondary");

		protected override Elements.Core.colorX DefaultVisualColor => Elements.Core.colorX.White;

		protected override bool SnapFilter(Snapper snapper, SnapTarget target)
		{
			return snapper.Slot.GetComponent<AssetProxy<Material>>() != null;
		}

		public override void OnPrimaryPress()
		{
			_activeUndoBatch = base.World.BeginUndoBatch("Undo.ApplyMaterial".AsLocaleKey());
			ApplyMaterial();
			base.World.EndUndoBatch();
		}

		public override void OnPrimaryHold()
		{
			if (ReplacementMode.Value == AssetToolReplacementMode.Area)
			{
				if (_activeUndoBatch == null || _activeUndoBatch.IsDestroyed)
				{
					_activeUndoBatch = base.World.BeginUndoBatch("Undo.ApplyMaterial".AsLocaleKey());
				}
				else
				{
					base.World.SetActiveUndoBatch(_activeUndoBatch);
				}
				ApplyMaterial();
				base.World.EndUndoBatch();
			}
		}

		public IAssetProvider<Material> GetMaterial()
		{
			return base.OrbSlot?.GetComponentInChildren<AssetProxy<Material>>()?.AssetReference.Target;
		}

		public T GetHeldReference<T>() where T : class
		{
			InteractionHandler activeHandler = base.ActiveHandler;
			if (activeHandler != null && activeHandler.Grabber.IsHoldingObjects)
			{
				return base.ActiveHandler.Grabber.HolderSlot.GetComponentInChildren<ReferenceProxy>()?.Reference.Target as T;
			}
			return null;
		}

		private void ApplyMaterial()
		{
			IAssetProvider<Material> material = GetMaterial();
			if (material == null)
			{
				return;
			}
			List<Target> list = Pool.BorrowList<Target>();
			RaycastTargets(list);
			if (list.Count > 0)
			{
				foreach (Target item in list)
				{
					Slot slot = item.target?.Slot ?? item.renderer.Slot;
					Slot slot2 = slot;
					switch (ReplacementMode.Value)
					{
					case AssetToolReplacementMode.Ray:
					case AssetToolReplacementMode.Area:
					{
						IMaterialApplyPolicy componentInParents = slot.GetComponentInParents((IMaterialApplyPolicy p) => p.Enabled);
						if (componentInParents != null && !componentInParents.CanApplyMaterial)
						{
							break;
						}
						if (item.target != null)
						{
							item.target.Assign(material);
						}
						else if (item.materialIndex < 0)
						{
							foreach (AssetRef<Material> element in item.renderer.Materials.Elements)
							{
								MaterialHelper.UndoableSetMaterial(element, material);
							}
						}
						else
						{
							MaterialHelper.UndoableSetMaterial(item.renderer.Materials.GetElement(item.materialIndex), material);
						}
						break;
					}
					case AssetToolReplacementMode.ObjectGlobal:
					case AssetToolReplacementMode.SceneGlobal:
					{
						slot2 = ((ReplacementMode.Value != AssetToolReplacementMode.SceneGlobal) ? slot2.GetObjectRoot() : base.World.RootSlot);
						IAssetProvider<Material> assetProvider = null;
						if (item.target != null)
						{
							assetProvider = item.target?.Slot?.GetComponent<IMaterialSource>()?.Material;
						}
						else if (item.materialIndex >= 0)
						{
							assetProvider = item.renderer.Materials[item.materialIndex];
						}
						else
						{
							foreach (IAssetProvider<Material> material2 in item.renderer.Materials)
							{
								if (material2 != null)
								{
									MaterialHelper.ReplaceAll(slot2, material2, material, respectPolicy: true, undoable: true);
								}
							}
						}
						if (assetProvider != null)
						{
							MaterialHelper.ReplaceAll(slot2, assetProvider, material, respectPolicy: true, undoable: true);
						}
						break;
					}
					}
				}
			}
			else if (UsesLaser)
			{
				ISkyboxMaterial skyboxMaterial = material as ISkyboxMaterial;
				if (skyboxMaterial != null)
				{
					Skybox skybox = base.World.KeyOwner(Skybox.ACTIVE_SKYBOX_KEY) as Skybox;
					if (skybox == null)
					{
						skybox = base.World.RootSlot.GetComponentInChildren<Skybox>();
						if (skybox != null)
						{
							skybox.ActiveSkybox = true;
						}
					}
					if (skybox == null)
					{
						skybox = base.World.RootSlot.AddSlot("Skybox").AttachComponent<Skybox>();
					}
					IMaterialApplyPolicy component = skybox.Slot.GetComponent((IMaterialApplyPolicy p) => p.Enabled);
					if (component != null && !component.CanApplyMaterial)
					{
						return;
					}
					if (!skyboxMaterial.IsSetupForSkybox)
					{
						skyboxMaterial = (ISkyboxMaterial)skybox.Slot.AddSlot("Material").CopyComponent((Component)skyboxMaterial);
						skyboxMaterial.SetupForSkybox();
					}
					MaterialHelper.UndoableSetMaterial(skybox.Material, skyboxMaterial);
				}
			}
			Pool.Return(ref list);
		}

		public override void OnSecondaryPress()
		{
			Slot heldReference = GetHeldReference<Slot>();
			if (heldReference != null)
			{
				ExtractAllMaterials(heldReference);
			}
			else
			{
				if (base.HasOrb)
				{
					return;
				}
				IAssetProvider<Material> assetProvider = null;
				assetProvider = GetHeldReference<IAssetProvider<Material>>();
				bool hitSomething = false;
				if (UsesLaser)
				{
					if (assetProvider == null)
					{
						assetProvider = RaycastMaterial(out hitSomething);
					}
					if (assetProvider == null && !hitSomething)
					{
						assetProvider = base.World.RootSlot.GetComponentInChildren<Skybox>().Material.Target;
					}
				}
				if (assetProvider != null)
				{
					Slot slot = base.World.AddSlot(assetProvider.Slot.Name);
					MaterialOrb.ConstructMaterialOrb(assetProvider, slot);
					base.SnapTarget.TrySnap(slot, ignorePosition: true);
				}
			}
		}

		private void ExtractAllMaterials(Slot slot)
		{
			if (!slot.IsAvatarProtected() && !ToolSimulator.IsSimulating)
			{
				MaterialOrb.ExtractAllMaterials(slot, base.Tip, base.World.LocalUserViewRotation);
			}
		}

		private void RaycastTargets(List<Target> targets)
		{
			if (ReplacementMode.Value == AssetToolReplacementMode.Area)
			{
				List<ICollider> list = Pool.BorrowList<ICollider>();
				base.Physics.SphereOverlap(_areaIndicator.Target.GlobalPosition, _areaIndicator.Target.LocalScaleToGlobal(_areaIndicatorRadius.Target.Value), list);
				foreach (ICollider item2 in list)
				{
					if (item2.Slot.ActiveUserRoot == base.Slot.ActiveUserRoot)
					{
						continue;
					}
					IMaterialTarget componentInParents = item2.Slot.GetComponentInParents((IMaterialTarget t) => t.IsValidMaterialTarget);
					if (componentInParents != null)
					{
						targets.Add(new Target
						{
							target = componentInParents
						});
						continue;
					}
					MeshRenderer componentInParents2 = item2.Slot.GetComponentInParents<MeshRenderer>();
					if (componentInParents2 != null)
					{
						targets.Add(new Target
						{
							renderer = componentInParents2,
							materialIndex = -1
						});
					}
				}
				Pool.Return(ref list);
				return;
			}
			RaycastHit? hit = GetHit();
			if (!hit.HasValue)
			{
				return;
			}
			RaycastHit value = hit.Value;
			Target item = new Target
			{
				materialIndex = -1,
				target = value.Collider.Slot.GetComponentInParentsUntilBlock((IMaterialTarget t) => t.IsValidMaterialTarget)
			};
			if (item.target != null)
			{
				targets.Add(item);
				return;
			}
			item.renderer = value.Collider.Slot.GetComponentInParents<MeshRenderer>();
			if (item.renderer != null)
			{
				if (value.IsMeshCollider)
				{
					item.materialIndex = value.GetTriangle().SubmeshIndex;
				}
				else if (item.renderer.Materials.Count == 1)
				{
					item.materialIndex = 0;
				}
				targets.Add(item);
			}
		}

		private IAssetProvider<Material> RaycastMaterial(out bool hitSomething)
		{
			RaycastHit? hit = GetHit();
			if (hit.HasValue)
			{
				RaycastHit value = hit.Value;
				hitSomething = true;
				if (value.Collider.Slot.IsAvatarProtected() || ToolSimulator.IsSimulating)
				{
					return null;
				}
				IMaterialSource componentInParentsUntilBlock = value.Collider.Slot.GetComponentInParentsUntilBlock((IMaterialSource s) => s.IsValidMaterialSource);
				if (componentInParentsUntilBlock != null)
				{
					return componentInParentsUntilBlock.Material;
				}
				MeshRenderer componentInParents = value.Collider.Slot.GetComponentInParents<MeshRenderer>();
				if (componentInParents != null)
				{
					if (value.IsMeshCollider)
					{
						return componentInParents.Materials[value.GetTriangle().SubmeshIndex];
					}
					return componentInParents.Material.Target;
				}
			}
			else
			{
				hitSomething = false;
			}
			return null;
		}

