		{
			Slot slot = RaycastObject();
			if (slot == null || slot.ActiveUserRoot != null)
			{
				return;
			}
			List<Collider> list = ((!ApplyToObjectRoot) ? slot.GetComponents<Collider>() : slot.GetComponentsInChildren<Collider>());
			if (list.Count <= 0)
			{
				return;
			}
			List<IHighlightable> list2 = Pool.BorrowList<IHighlightable>();
			foreach (Collider item in list)
			{
				bool flag = false;
				if (item.CharacterCollider.Value != enable)
				{
					item.CharacterCollider.Value = enable;
					if (item is MeshCollider)
					{
						if (enable && item.Type.Value == ColliderType.NoCollision)
						{
							item.SetStatic();
						}
						if (!enable && item.Type.Value == ColliderType.Static)
						{
							item.SetNoCollision();
						}
					}
					flag = true;
				}
				if (enable)
				{
					LocomotionGrip component = item.Slot.GetComponent<LocomotionGrip>();
					if (component != null != MarkGrippable.Value)
					{
						if (MarkGrippable.Value)
						{
							item.Slot.AttachComponent<LocomotionGrip>();
						}
						else
						{
							component.Destroy();
						}
						flag = true;
					}
				}
				if (flag && item is IHighlightable)
				{
					list2.Add((IHighlightable)item);
				}
			}
			if (list2.Count > 0)
			{
				HighlightHelper.FlashHighlight(list2, new Elements.Core.colorX(0.2f, 1f, 0.2f));
				base.Slot.TryVibrateLong();
