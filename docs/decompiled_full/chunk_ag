		public void ComputeCoordinateCompensation()
		{
			Finger leftMostFinger = LeftMostFinger;
			Finger rightMostFinger = RightMostFinger;
			if (leftMostFinger == null)
			{
				throw new Exception("Hand has no fingers!");
			}
			if (leftMostFinger == rightMostFinger)
			{
				throw new Exception("The hand has only one finger (excluding thumb)!");
			}
			Slot currentHandRoot = CurrentHandRoot;
			Elements.Core.float3 a = Elements.Core.float3.Zero;
			for (FingerType fingerType = FingerType.Index; fingerType <= FingerType.Pinky; fingerType++)
			{
				Finger finger = this[fingerType];
				if (finger.IsValidFinger)
				{
					a += finger.Proximal.Root.Target.GlobalPosition - currentHandRoot.GlobalPosition;
				}
			}
			a = a.Normalized;
			Slot target = leftMostFinger.Proximal.Root.Target;
			Elements.Core.float3 b = (rightMostFinger.Proximal.Root.Target.GlobalPosition - target.GlobalPosition).Normalized;
			Elements.Core.float3 globalDirection = MathX.Cross(in a, in b);
			a = currentHandRoot.GlobalDirectionToLocal(in a);
			globalDirection = currentHandRoot.GlobalDirectionToLocal(in globalDirection);
			b = currentHandRoot.GlobalDirectionToLocal(in b);
			HandForward.Value = a;
			HandUp.Value = globalDirection;
			HandRight.Value = b;
			bool flag = Side.Value == Chirality.Left;
			Thumb.ComputeCoordinateCompensation(currentHandRoot, a, globalDirection, b, isThumb: true, flag);
			Index.ComputeCoordinateCompensation(currentHandRoot, a, globalDirection, b, isThumb: false, flag);
			Middle.ComputeCoordinateCompensation(currentHandRoot, a, globalDirection, b, isThumb: false, flag);
			Ring.ComputeCoordinateCompensation(currentHandRoot, a, globalDirection, b, isThumb: false, flag);
			Pinky.ComputeCoordinateCompensation(currentHandRoot, a, globalDirection, b, isThumb: false, flag);
			int num = 0;
			float num2 = 0f;
			for (FingerType fingerType2 = FingerType.Index; fingerType2 <= FingerType.Pinky; fingerType2++)
			{
				Slot target2 = this[fingerType2].Metacarpal.Root.Target;
				if (target2 != null)
				{
					num2 += MathX.Distance(currentHandRoot.GlobalPosition, target2.GlobalPosition);
					num++;
				}
			}
			if (num <= 0)
			{
				return;
			}
			num2 /= (float)num;
			Finger finger2 = (flag ? rightMostFinger : leftMostFinger);
			Slot slot = null;
			Slot slot2 = null;
			for (FingerSegmentType fingerSegmentType = FingerSegmentType.Proximal; fingerSegmentType <= FingerSegmentType.Distal; fingerSegmentType++)
			{
				FingerSegment fingerSegment = finger2[fingerSegmentType];
				if (fingerSegment.Root.Target != null)
				{
					if (slot != null)
					{
						slot2 = fingerSegment.Root.Target;
						break;
					}
					slot = fingerSegment.Root.Target;
				}
			}
			float num3 = MathX.Distance(slot.GlobalPosition, slot2.GlobalPosition);
			PoseMetacarpals.Value = num2 >= num3 * 1f;
		}

		private void DebugCoordinateCompensation(Finger finger)
		{
			for (int i = 0; i < 5; i++)
			{
				FingerSegment fingerSegment = finger[(FingerSegmentType)i];
				if (fingerSegment?.Root.Target != null)
				{
					Slot target = fingerSegment.Root.Target;
					Elements.Core.floatQ b = fingerSegment.CoordinateCompensation.Value;
					b = MathX.Lerp(Elements.Core.floatQ.Identity, in b, MathX.Sin((float)base.Time.WorldTime).Pack());
					base.Debug.Vector(target.GlobalPosition, target.LocalDirectionToGlobal(b * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Forward)) * 0.05f, Elements.Core.colorX.Cyan);
					base.Debug.Vector(target.GlobalPosition, target.LocalDirectionToGlobal(b * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Right)) * 0.05f, Elements.Core.colorX.Red);
					base.Debug.Vector(target.GlobalPosition, target.LocalDirectionToGlobal(b * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Up)) * 0.05f, Elements.Core.colorX.Green);
				}
			}
			static ref readonly T ILSpyHelper_AsRefReadOnly<T>(in T temp)
			{
				//ILSpy generated this function to help ensure overload resolution can pick the overload using 'in'
				return ref temp;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			PoseMetacarpals.Value = true;
		}

		protected override void OnCommonUpdate()
		{
			if (DebugFingers.Value && base.World.IsAuthority)
			{
				DebugCoordinateCompensation(Thumb);
				DebugCoordinateCompensation(Index);
				DebugCoordinateCompensation(Middle);
				DebugCoordinateCompensation(Ring);
				DebugCoordinateCompensation(Pinky);
			}
			BodyNode side = BodyNode.LeftThumb_Metacarpal.GetSide(Side);
			BodyNode side2 = BodyNode.LeftPinky_Tip.GetSide(Side);
			if (PoseSource.Target == null || !PoseSource.Target.AreFingersTracking(Side))
			{
				if (handReset)
				{
					return;
				}
				for (BodyNode bodyNode = side; bodyNode <= side2; bodyNode++)
				{
					FingerSegment fingerSegment = this[bodyNode.GetFingerType()][bodyNode.GetFingerSegmentType()];
					if (fingerSegment?.Root.Target != null)
					{
						fingerSegment.Root.Target.LocalRotation = fingerSegment.OriginalRotation.Value;
					}
				}
				handReset = true;
				return;
			}
			List<Elements.Core.floatQ> list = Pool.BorrowList<Elements.Core.floatQ>();
			PoseSource.Target.GetFingerData(Side, null, list);
			Slot slot = HandRoot.Target ?? base.Slot;
			handReset = false;
			Elements.Core.floatQ a = Elements.Core.floatQ.LookRotation((Elements.Core.float3)HandForward, (Elements.Core.float3)HandUp);
			for (int i = 0; i < list.Count; i++)
			{
				list[i] = a * list[i];
			}
			for (BodyNode bodyNode2 = side; bodyNode2 <= side2; bodyNode2++)
			{
				int index = bodyNode2 - side;
				FingerType fingerType = bodyNode2.GetFingerType();
				FingerSegmentType fingerSegmentType = bodyNode2.GetFingerSegmentType();
				FingerSegment fingerSegment2 = this[fingerType][fingerSegmentType];
				if (fingerSegment2 != null && fingerSegment2.RotationDrive.IsLinkValid)
				{
					if ((!PoseMetacarpals.Value || !PoseSource.Target.TracksMetacarpals) && fingerSegmentType == FingerSegmentType.Metacarpal && fingerType != FingerType.Thumb)
					{
						fingerSegment2.RotationDrive.Target.Value = fingerSegment2.OriginalRotation.Value;
						continue;
					}
					Slot slot2 = fingerSegment2.Root.Target?.Parent ?? slot;
					fingerSegment2.RotationDrive.Target.Value = slot2.SpaceRotationToLocal(list[index], slot) * fingerSegment2.CoordinateCompensation.Value;
				}
			}
			Pool.Return(ref list);
		}

