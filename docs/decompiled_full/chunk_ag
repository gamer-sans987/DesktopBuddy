		protected override void OnAwake()
		{
			base.OnAwake();
			DefaultProperties();
			SpawnPhotoInWorld.Value = true;
			MotionBlur.Value = true;
			Mode.Value = CameraPositioningMode.ThirdPerson;
			GroupExcludeUsers.Changed += delegate
			{
				GroupModeVersion++;
			};
			GroupIncludeUsers.Changed += delegate
			{
				GroupModeVersion++;
			};
			CameraOperators.Changed += delegate
			{
				OperatorsVersion++;
			};
			base.World.Coroutines.StartTask(CameraUpdateTask);
		}

