		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			control.OnLoaded(this, delegate
			{
				LastCaptureTime.CurrentTime = -1000.0;
			});
			int typeVersion = control.GetTypeVersion<InteractiveCamera>();
			if (typeVersion == 0)
			{
				RunSynchronously(delegate
				{
					Format.Value = EncodeFormat.WebP;
				});
			}
			if (typeVersion < 2)
			{
				RunSynchronously(SpawnFrustumVisual);
			}
			if (typeVersion < 3)
			{
				RunSynchronously(ReadDefaultClipping);
			}
			if (typeVersion < 4)
			{
				RunSynchronously(delegate
				{
					PhotoSpawnSize.Value *= 5f;
					if (Format.Value == EncodeFormat.WebP)
					{
						Quality.Value = 200f;
					}
				});
			}
			if (typeVersion < 5)
			{
				RunSynchronously(delegate
				{
					MissingComponent componentInChildren = base.Slot.GetComponentInChildren((MissingComponent m) => m.Type.Value == "FrooxEngine.TouchMethodNameTrigger");
					if (componentInChildren != null)
					{
						Slot slot = componentInChildren.Slot;
						ButtonActionTrigger buttonActionTrigger = slot.AttachComponent<ButtonActionTrigger>();
						slot.AttachComponent<PhysicalButton>().PressDepth.Value *= 0.25f;
						buttonActionTrigger.OnPressed.Target = Trigger;
						componentInChildren.Destroy();
					}
				});
			}
			if (typeVersion < 6)
			{
				RunSynchronously(delegate
				{
					TimerCountdownSlowOutput.Target?.SetupAsUI();
					TimerCountdownFastOutput.Target?.SetupAsUI();
				});
			}
		}

