		[Range(-25f, 40f, "0.00")]
		public readonly Sync<float> LeftSplayMagnitude;

		[Range(-25f, 40f, "0.00")]
		public readonly Sync<float> RightSplayMagnitude;

		protected override void UpdatePoses()
		{
			IFingerPoseSourceComponent target = Source.Target;
			if (target == null)
			{
				_isTrackingLeft = false;
				_isTrackingRight = false;
				_metacarpals = false;
			}
			else
			{
				_isTrackingLeft = target.AreFingersTracking(Chirality.Left);
				_isTrackingRight = target.AreFingersTracking(Chirality.Right);
				_metacarpals = target.TracksMetacarpals;
			}
			if (_isTrackingLeft)
			{
				ComputeData(Chirality.Left, LeftSplayMagnitude, target);
			}
			if (_isTrackingRight)
			{
				ComputeData(Chirality.Right, RightSplayMagnitude, target);
			}
