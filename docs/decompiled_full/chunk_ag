	public class FingerPoseLerp : FingerPoseProcessor
	{
		public readonly SyncRef<IFingerPoseSourceComponent> A;

		public readonly SyncRef<IFingerPoseSourceComponent> B;

		[Range(0f, 1f, "0.00")]
		public readonly Sync<float> Lerp;

		protected override void UpdatePoses()
		{
			_isTrackingLeft = false;
			_isTrackingRight = false;
			_metacarpals = false;
			IFingerPoseSourceComponent target = A.Target;
			IFingerPoseSourceComponent target2 = B.Target;
			if (target != null && target2 != null)
			{
				_metacarpals = target.TracksMetacarpals && target2.TracksMetacarpals;
				_isTrackingLeft = target.AreFingersTracking(Chirality.Left) && target2.AreFingersTracking(Chirality.Left);
				_isTrackingRight = target.AreFingersTracking(Chirality.Right) && target2.AreFingersTracking(Chirality.Right);
				List<Elements.Core.float3> list = Pool.BorrowList<Elements.Core.float3>();
				List<Elements.Core.floatQ> list2 = Pool.BorrowList<Elements.Core.floatQ>();
				List<Elements.Core.float3> list3 = Pool.BorrowList<Elements.Core.float3>();
				List<Elements.Core.floatQ> list4 = Pool.BorrowList<Elements.Core.floatQ>();
				if (_isTrackingLeft)
				{
					ComputeData(Chirality.Left, target, target2, list, list2, list3, list4);
				}
				if (_isTrackingRight)
				{
					ComputeData(Chirality.Right, target, target2, list, list2, list3, list4);
				}
				Pool.Return(ref list);
				Pool.Return(ref list2);
				Pool.Return(ref list3);
				Pool.Return(ref list4);
			}
		}

		private void ComputeData(Chirality side, IFingerPoseSource a, IFingerPoseSource b, List<Elements.Core.float3> aPositions, List<Elements.Core.floatQ> aRotations, List<Elements.Core.float3> bPositions, List<Elements.Core.floatQ> bRotations)
		{
			a.GetFingerData(side, aPositions, aRotations);
			b.GetFingerData(side, bPositions, bRotations);
			bool flag = aPositions.Count > 0 && aPositions.Count == bPositions.Count;
			GetData(side, out List<Elements.Core.float3> positions, out List<Elements.Core.floatQ> rotations);
			positions.EnsureExactCount(flag ? aPositions.Count : 0);
			rotations.EnsureExactCount(aRotations.Count);
			FingerPoseHelper.TransformPosesToHierarchy(aPositions, aRotations);
			FingerPoseHelper.TransformPosesToHierarchy(bPositions, bRotations);
			FingerPoseHelper.InterpolatePoses(aPositions, aRotations, bPositions, bRotations, Lerp, positions, rotations);
			FingerPoseHelper.TransformPosesToFlat(positions, rotations);
			aPositions.Clear();
			aRotations.Clear();
			bPositions.Clear();
			bRotations.Clear();
		}

