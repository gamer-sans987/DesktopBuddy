	public class FingerReferencePoseSource : Component, IFingerPoseSourceComponent, IFingerPoseSource, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable, ICustomInspector
	{
		public readonly SyncRefDictionary<BodyNode, Slot> Bones;

		private bool _leftTracking;

		private bool _rightTracking;

		private bool _metacarpals;

		public bool TracksMetacarpals => _metacarpals;

		protected override void OnChanges()
		{
			base.OnChanges();
			_leftTracking = CheckTracking(Chirality.Left, out var hasMetacarpals);
			_rightTracking = CheckTracking(Chirality.Right, out var hasMetacarpals2);
			_metacarpals = true;
			if (_leftTracking)
			{
				_metacarpals &= hasMetacarpals;
			}
			if (_rightTracking)
			{
				_metacarpals &= hasMetacarpals2;
			}
		}

		private bool CheckTracking(Chirality side, out bool hasMetacarpals)
		{
			hasMetacarpals = false;
			if (!HasBone(BodyNode.LeftHand, side))
			{
				return false;
			}
			hasMetacarpals = HasBone(BodyNode.LeftThumb_Metacarpal, side) && HasBone(BodyNode.LeftIndexFinger_Metacarpal, side) && HasBone(BodyNode.LeftMiddleFinger_Metacarpal, side) && HasBone(BodyNode.LeftRingFinger_Metacarpal, side) && HasBone(BodyNode.LeftPinky_Metacarpal, side);
			if (HasFinger(FingerType.Thumb, side) && HasFinger(FingerType.Index, side) && HasFinger(FingerType.Middle, side) && HasFinger(FingerType.Ring, side))
			{
				return HasFinger(FingerType.Pinky, side);
			}
			return false;
		}

		private bool HasFinger(FingerType finger, Chirality side)
		{
			if (HasBone(finger.ComposeFinger(FingerSegmentType.Proximal, side)) && (finger == FingerType.Thumb || HasBone(finger.ComposeFinger(FingerSegmentType.Intermediate, side))) && HasBone(finger.ComposeFinger(FingerSegmentType.Distal, side)))
			{
				return HasBone(finger.ComposeFinger(FingerSegmentType.Tip, side));
			}
			return false;
		}

		private bool HasBone(BodyNode node, Chirality side)
		{
			return HasBone(node.GetSide(side));
		}

		private bool HasBone(BodyNode node)
		{
			if (!Bones.TryGetTarget(node, out Slot target))
			{
				return false;
			}
			return target != null;
		}

		public bool AreFingersTracking(Chirality chirality)
		{
			return chirality switch
			{
				Chirality.Left => _leftTracking, 
				Chirality.Right => _rightTracking, 
				_ => false, 
			};
		}

		public void GetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			if (!TryGetFingerData(node, out position, out rotation))
			{
				throw new Exception($"Unable to get finger data for: {node}");
			}
		}

		public void GetFingerData(List<BodyNode> nodes, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			foreach (BodyNode node in nodes)
			{
				GetFingerData(node, out var position, out var rotation);
				positions?.Add(position);
				rotations?.Add(rotation);
			}
		}

		public void GetFingerData(Chirality chirality, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			Slot space = GetSpace(chirality);
			if (space == null)
			{
				throw new Exception($"Unable to get finger data for side: {chirality}");
			}
			for (BodyNode bodyNode = BodyNode.LeftThumb_Metacarpal.GetSide(chirality); bodyNode <= BodyNode.LeftPinky_Tip.GetSide(chirality); bodyNode++)
			{
				if (bodyNode.GetFingerSegmentType() == FingerSegmentType.Metacarpal && !TracksMetacarpals)
				{
					positions?.Add(default(Elements.Core.float3));
					rotations?.Add(Elements.Core.floatQ.Identity);
					continue;
				}
				if (!TryGetFingerData(bodyNode, out var position, out var rotation, space))
				{
					throw new Exception($"Unable to get finger data for: {bodyNode}");
				}
				positions?.Add(position);
				rotations?.Add(rotation);
			}
		}

		public bool TryGetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			Slot space = GetSpace(node.GetHandChirality());
			if (space == null)
			{
				position = default(Elements.Core.float3);
				rotation = Elements.Core.floatQ.Identity;
				return false;
			}
			return TryGetFingerData(node, out position, out rotation, space);
		}

		private Slot GetSpace(Chirality chirality)
		{
			if (!Bones.TryGetTarget(BodyNode.LeftHand.GetSide(chirality), out Slot target))
			{
				return null;
			}
			return target;
		}

		private bool TryGetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation, Slot space)
		{
			if (!Bones.TryGetTarget(node, out Slot target))
			{
				position = default(Elements.Core.float3);
				rotation = Elements.Core.floatQ.Identity;
				return false;
			}
			position = target.Parent.LocalPointToSpace(target.LocalPosition, space);
			rotation = target.Parent.LocalRotationToSpace(target.LocalRotation, space);
			return true;
		}

