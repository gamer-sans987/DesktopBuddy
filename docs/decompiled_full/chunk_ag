			v = MathX.Abs(_activeBox.Target.Slot.LocalRotation.Inverted * v);
			Elements.Core.float3 localPosition = MathX.Average(in a, in _selectionStartPoint);
			_activeBox.Target.Size.Target.Value = v;
			_activeBox.Target.Slot.LocalPosition = localPosition;
		}

		private void UpdateSphere()
		{
			Elements.Core.float3 b = base.LocalUserSpace.GlobalPointToLocal(base.Tip);
			float value = MathX.Distance(in _selectionStartPoint, in b);
			_activeSphere.Target.Radius.Target.Value = value;
		}

		private void UpdateCylinder()
		{
			Elements.Core.float3 @float = base.LocalUserSpace.GlobalPointToLocal(base.Tip);
			float value = MathX.Distance(_selectionStartPoint.xz, @float.xz);
			float value2 = MathX.Distance(_selectionStartPoint.y, @float.y) * 2f;
			_activeCylinder.Target.Radius.Target.Value = value;
			_activeCylinder.Target.Height.Target.Value = value2;
		}

