	public class StaticFingerPose : IFingerPoseSource
	{
		private Dictionary<BodyNode, Transform> _poses = new Dictionary<BodyNode, Transform>();

		private bool _metadataComputed;

		private bool _hasMetacarpals;

		private bool _hasLeft;

		private bool _hasRight;

		public bool TracksMetacarpals
		{
			get
			{
				EnsureMetadata();
				return _hasMetacarpals;
			}
		}

		private void InvalidateMetadata()
		{
			_metadataComputed = false;
		}

		private void EnsureMetadata()
		{
			if (!_metadataComputed)
			{
				ComputeMetadata();
			}
		}

		private void ComputeMetadata()
		{
			_hasMetacarpals = true;
			_hasLeft = ComputeHasSide(Chirality.Left, ref _hasMetacarpals);
			_hasRight = ComputeHasSide(Chirality.Right, ref _hasMetacarpals);
			_metadataComputed = true;
		}

		private bool ComputeHasSide(Chirality side, ref bool metacarpals)
		{
			for (BodyNode bodyNode = BodyNode.LeftThumb_Metacarpal.GetSide(side); bodyNode <= BodyNode.LeftPinky_Tip.GetSide(side); bodyNode++)
			{
				if (!_poses.ContainsKey(bodyNode))
				{
					if (bodyNode.GetFingerSegmentType() != FingerSegmentType.Metacarpal)
					{
						return false;
					}
					metacarpals = false;
				}
			}
			return true;
		}

		public bool AreFingersTracking(Chirality chirality)
		{
			EnsureMetadata();
			if (chirality != Chirality.Left)
			{
				return _hasRight;
			}
			return _hasLeft;
		}

		public void GetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			Transform transform = _poses[node];
			position = transform.position;
			rotation = transform.rotation;
		}

		public void GetFingerData(List<BodyNode> nodes, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			foreach (BodyNode node in nodes)
			{
				GetFingerData(node, out var position, out var rotation);
				positions?.Add(position);
				rotations?.Add(rotation);
			}
		}

		public void GetFingerData(Chirality chirality, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			for (BodyNode bodyNode = BodyNode.LeftThumb_Metacarpal.GetSide(chirality); bodyNode <= BodyNode.LeftPinky_Tip.GetSide(chirality); bodyNode++)
			{
				if (bodyNode.GetFingerSegmentType() == FingerSegmentType.Metacarpal && !TracksMetacarpals)
				{
					positions?.Add(default(Elements.Core.float3));
					rotations?.Add(Elements.Core.floatQ.Identity);
					continue;
				}
				if (!TryGetFingerData(bodyNode, out var position, out var rotation))
				{
					throw new Exception($"Unable to get finger data for: {bodyNode}");
				}
				positions?.Add(position);
				rotations?.Add(rotation);
			}
		}

		public bool TryGetFingerData(BodyNode node, out Elements.Core.float3 position, out Elements.Core.floatQ rotation)
		{
			if (_poses.TryGetValue(node, out var value))
			{
				position = value.position;
				rotation = value.rotation;
				return true;
			}
			position = default(Elements.Core.float3);
			rotation = Elements.Core.floatQ.Identity;
			return false;
		}

		public void SetPose(BodyNode node, in Elements.Core.float3 position, in Elements.Core.floatQ rotation)
		{
			_poses[node] = new Transform(in position, in rotation, Elements.Core.float3.One);
			InvalidateMetadata();
		}
