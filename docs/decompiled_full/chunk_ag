		public static Elements.Core.BoundingBox ComputeBoundingBox(this Slot slot, bool includeInactive = false, Slot space = null, Predicate<IBounded> filter = null, Predicate<Slot> searchBlock = null)
		{
			List<IBounded> list = Pool.BorrowList<IBounded>();
			Elements.Core.BoundingBox bounds = Elements.Core.BoundingBox.Empty();
			EncapsulateBoundingBox(slot, ref bounds, includeInactive, space, filter, searchBlock, list);
			Pool.Return(ref list);
			return bounds;
		}

		public static async Task<Elements.Core.BoundingBox> ComputeExactBounds(this Slot slot, bool includeInactive = false, Slot space = null, Predicate<IBounded> filter = null)
		{
			Elements.Core.BoundingBox bounds = Elements.Core.BoundingBox.Empty();
			List<IBounded> bounded = slot.GetComponentsInChildren(delegate(IBounded b)
			{
				if (!b.IsBoundingBoxAvailable)
				{
					return false;
				}
				if (!includeInactive && (!b.Slot.IsActive || !b.Enabled))
				{
					return false;
				}
				return (filter == null || filter(b)) ? true : false;
			});
			await default(ToBackground);
			foreach (IBounded item in bounded)
			{
				Elements.Core.BoundingBox box = await item.ComputeExactBounds(space).ConfigureAwait(continueOnCapturedContext: false);
				if (box.IsValid)
				{
					bounds.Encapsulate(box);
				}
			}
			return bounds;
		}

		public static async Task ForeachExactBoundedPoint(this Slot slot, Action<Elements.Core.float3> point, bool includeInactive = false, Slot space = null, Predicate<IBounded> filter = null)
		{
			List<IBounded> bounded = slot.GetComponentsInChildren(delegate(IBounded b)
			{
				if (!b.IsBoundingBoxAvailable)
				{
					return false;
				}
				if (!includeInactive && !b.Slot.IsActive)
				{
					return false;
				}
				return (filter == null || filter(b)) ? true : false;
			});
			await default(ToBackground);
			foreach (IBounded item in bounded)
			{
				await item.ForeachExactBoundedPoint(space, point);
			}
		}

		private static void EncapsulateBoundingBox(Slot slot, ref Elements.Core.BoundingBox bounds, bool includeInactive, Slot space, Predicate<IBounded> filter, Predicate<Slot> searchBlock, List<IBounded> buffer)
		{
			if ((!includeInactive && !slot.IsActive) || (searchBlock != null && !searchBlock(slot)))
			{
				return;
			}
			slot.GetComponents(buffer, filter);
			if (buffer.Count > 0)
			{
				foreach (IBounded item in buffer)
				{
					if (item.IsBoundingBoxAvailable)
					{
						Elements.Core.BoundingBox box = ((space != null) ? item.GetBoundingBoxInSpace(space) : item.GlobalBoundingBox);
						if (box.IsValid)
						{
							bounds.Encapsulate(box);
						}
					}
				}
				buffer.Clear();
			}
			foreach (Slot child in slot.Children)
			{
				EncapsulateBoundingBox(child, ref bounds, includeInactive, space, filter, searchBlock, buffer);
			}
		}

		public static bool AreBoundingBoxesAvailable(this Slot slot, bool includeInactive = false)
		{
			return slot.ForeachComponentInChildren(delegate(IBounded bounded)
			{
				if (!includeInactive && !bounded.Slot.IsActive)
				{
					return true;
				}
				return bounded.IsBoundingBoxAvailable ? true : false;
			});
		}
