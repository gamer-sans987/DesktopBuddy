			{
				mat.Transparent.Value = true;
				mat.RimColor.Value = Elements.Core.colorX.Green;
				mat.AlbedoColor.Value = new Elements.Core.colorX(0.2f, 0.2f);
				mat.Metallic.Value = 0.1f;
				mat.Smoothness.Value = 0.8f;
			});
			WireframeMaterial sharedComponentOrCreate3 = world.GetSharedComponentOrCreate("MeshOrb_Wireframe", delegate(WireframeMaterial mat)
			{
				mat.ScreenSpace.Value = true;
				mat.UseFresnel.Value = true;
				mat.Thickness.Value = 2f;
				mat.FillColor.Value = Elements.Core.colorX.Black;
				mat.FillFarColor.Value = new Elements.Core.colorX(0f, 0.1f, 0f);
				mat.LineColor.Value = new Elements.Core.colorX(0.5f, 1f, 0.5f);
				mat.LineFarColor.Value = new Elements.Core.colorX(0.1f, 0.8f, 0.1f);
