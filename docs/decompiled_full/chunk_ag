			colorDriver.HighlightColor.Value = Elements.Core.colorX.Blue;
			colorDriver.PressColor.Value = Elements.Core.colorX.Blue;
			text.Slot.AttachComponent<DelegateProxySource<T>>().Delegate.Target = target;
		}

