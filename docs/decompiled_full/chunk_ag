		public static BipedRig ClassifyBiped(Slot slot, BoneNode root, bool keepInvalid = false, List<BodyNode> missingBones = null)
		{
			BipedRig bipedRig = slot.AttachComponent<BipedRig>();
			ClassifyBiped(root, bipedRig);
			bipedRig.AssignBones(root, ignoreDuplicates: false);
			bipedRig.DetectHandRigs();
			if (!keepInvalid && !bipedRig.IsBiped)
			{
				if (missingBones != null)
				{
					bipedRig.GetMissingBipedBones(missingBones);
				}
				bipedRig.Destroy();
				bipedRig = null;
			}
			bipedRig?.GuessForwardFlipped();
			return bipedRig;
		}

