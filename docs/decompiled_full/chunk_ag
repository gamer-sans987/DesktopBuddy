		public void MakeTPose()
		{
			bool flag = MathX.Dot(Elements.Core.float3.Forward, ForwardAxis.Value ?? Elements.Core.float3.Forward) < 0f;
			foreach (KeyValuePair<BodyNode, SyncRef<Slot>> bone in Bones)
			{
				BodyNode key = bone.Key;
				Elements.Core.float3 localDirection;
				if (key <= BodyNode.LeftHand)
				{
					if ((uint)(key - 6) > 3u)
					{
						if ((uint)(key - 15) > 2u)
						{
							continue;
						}
						localDirection = (flag ? Elements.Core.float3.Right : Elements.Core.float3.Left);
					}
					else
					{
						localDirection = Elements.Core.float3.Up;
					}
				}
				else if ((uint)(key - 44) > 2u)
				{
					if ((uint)(key - 72) > 1u && (uint)(key - 76) > 1u)
					{
						continue;
					}
					localDirection = Elements.Core.float3.Down;
				}
				else
				{
					localDirection = (flag ? Elements.Core.float3.Left : Elements.Core.float3.Right);
				}
				Slot target = bone.Value.Target;
				target.GlobalRotation = Elements.Core.floatQ.FromToRotation(target.Up, base.Slot.LocalDirectionToGlobal(in localDirection)) * target.GlobalRotation;
			}
		}

