		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			if (_launchOBSbutton.Target != null)
			{
				if ((DateTime.Now - lastOBSrunningCheck).TotalSeconds > 5.0)
				{
					lastOBSrunningCheck = DateTime.Now;
					RunInBackground(delegate
					{
						Process[] processesByName = Process.GetProcessesByName("obs64");
						obsRunning = processesByName.Length != 0;
					});
				}
				_launchOBSbutton.Target.Enabled = obsExecutable != null && obsRunning.HasValue && !obsRunning.Value;
				if (_launchOBSbutton.Target.Enabled)
				{
					_launchOBSbutton.Target.LabelText = this.GetLocalized("CameraControl.OBS.Launch");
				}
			}
			if (_status.Target != null)
			{
				_status.Target.Content.Value = "<b>OBS: " + this.GetLocalized("CameraControl.OBS." + (_active.Value ? "Connected" : "Disconnected")) + "</b>";
			}
			if (!_active.Value)
			{
				return;
			}
			if (IsConnected && (_updateTask == null || _updateTask.IsCompleted))
			{
				if (_updateCancellation == null || _updateCancellation.IsCancellationRequested)
				{
					_updateCancellation = new CancellationTokenSource();
				}
				_updateTask = StartTask(UpdateStatuses, _updateCancellation.Token);
			}
			long milliseconds = 0L;
			string localized = this.GetLocalized("CameraControl.OBS.Idle");
			if (IsStreaming)
			{
				milliseconds = _streamingStatus?.Duration ?? 0;
				localized = this.GetLocalized("CameraControl.OBS.Live");
			}
			else if (IsRecording)
			{
				milliseconds = _recordingStatus?.RecordingDuration ?? 0;
				localized = this.GetLocalized("CameraControl.OBS.Recording");
			}
			_streamTime.Target.Content.Value = localized + ": " + TimeSpan.FromMilliseconds(milliseconds).ToString("g", CultureInfo.CurrentCulture);
			_bytesPerSec.Target.Content.Value = this.GetLocalized("CameraControl.OBS.Bitrate", null, "n", CalculateAverageBytesPerSecond(_streamingStatus));
			_fps.Target.Content.Value = this.GetLocalized("CameraControl.OBS.FPS", null, "n", (_obsStats?.FPS ?? 0.0).ToString("F2", CultureInfo.CurrentCulture));
			_droppedFrames.Target.Content.Value = this.GetLocalized("CameraControl.OBS.DroppedFrames", null, "n", _streamingStatus?.SkippedFrames ?? 0);
			UpdateButton(_streamButton, _streamingState, "Streaming");
			UpdateButton(_recordButton, _recordingState, "Recording");
		}

		private async Task UpdateStatuses(CancellationToken token)
		{
			if (token.IsCancellationRequested || !IsConnected)
			{
				return;
			}
			await default(ToBackground);
			ObsStats stats = obs.GetStats();
			if (!token.IsCancellationRequested)
			{
				RecordingStatus recordingStatus = obs.GetRecordStatus();
				if (!token.IsCancellationRequested)
				{
					OutputStatus streamStatus = obs.GetStreamStatus();
					await default(ToWorld);
					_obsStats = stats;
					_recordingStatus = recordingStatus;
					_streamingStatus = streamStatus;
				}
			}
		}

		private string CalculateAverageBytesPerSecond(OutputStatus? status)
		{
			if (status == null || status.BytesSent == 0L || status.Duration == 0L)
			{
				return "---";
			}
			long num = status.Duration / 1000;
			if (num == 0L)
			{
				return "---";
			}
			return UnitFormatting.FormatBytes(status.BytesSent / num);
		}

		private void UpdateButton(Button button, OBSWebsocketDotNet.Types.OutputState state, string label)
		{
			Elements.Core.colorX a = default(Elements.Core.colorX);
			string key = null;
			switch (state)
			{
			case OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPED:
				a = Elements.Core.colorX.Red;
				key = "CameraControl.OBS." + label + ".Start";
				break;
			case OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STARTING:
				a = Elements.Core.colorX.Yellow;
				key = "CameraControl.OBS." + label + ".Starting";
				break;
			case OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STARTED:
			case OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_RESUMED:
				a = Elements.Core.colorX.Green;
				key = "CameraControl.OBS." + label + ".Stop";
				break;
			case OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_STOPPING:
				a = Elements.Core.colorX.Orange;
				key = "CameraControl.OBS." + label + ".Stopping";
				break;
			case OBSWebsocketDotNet.Types.OutputState.OBS_WEBSOCKET_OUTPUT_PAUSED:
				a = Elements.Core.colorX.Orange;
				key = "CameraControl.OBS." + label + ".Start";
				break;
			}
			button.SetColors(MathX.Lerp(in a, Elements.Core.colorX.White, 0.5f));
			button.LabelText = this.GetLocalized(key);
		}

		protected override void OnDestroy()
		{
			base.OnDestroy();
			if (!IsConnected)
			{
				obs = null;
				return;
			}
			RunInBackground(delegate
			{
				try
				{
					_connected = false;
					_updateCancellation.Cancel();
					obs.Disconnect();
				}
				catch (Exception exception)
				{
					UniLog.Error("Exception disconnecting OBS:\n" + DebugManager.PreprocessException(exception));
				}
				obs = null;
