		[SyncMethod(typeof(Delegate), null)]
		private void OnPreviewImagePress(IButton button, ButtonEventData eventData)
		{
			CameraPositioningMode value = Mode.Value;
			if (value != CameraPositioningMode.SmoothFirstPerson && value != CameraPositioningMode.Manual)
			{
				Elements.Core.float2 normalizedPressPoint = eventData.normalizedPressPoint;
				normalizedPressPoint = new Elements.Core.float2(normalizedPressPoint.x, 1f - normalizedPressPoint.y);
				if (!(normalizedPressPoint.x <= 0.1f) && !(normalizedPressPoint.x >= 0.9f) && !(normalizedPressPoint.y <= 0.1f) && !(normalizedPressPoint.y >= 0.9f))
				{
					FramingViewportPosition.Value = normalizedPressPoint;
				}
			}
		}

