		public void EnsureUnusedMaterial()
		{
			Component component = CurrentMaterial.Target as Component;
			bool flag = component == _lastCreatedMaterial.Target && _lastCreatedMaterial.Target != null;
			if (_lastUsedMaterial.Target == CurrentMaterial.Target || _lastCreatedMaterial.Target != CurrentMaterial.Target)
			{
				Slot slot = base.World.AssetsSlot.FindChildOrAdd("BrushMaterials");
				CurrentMaterial.Target = (IAssetProvider<Material>)slot.CopyComponent((Component)CurrentMaterial.Target);
				_lastCreatedMaterial.Target = CurrentMaterial.Target;
			}
			if (ColorMappings.Count != 0 && ColorMappings[0].Field.Target.FindNearestParent<IAssetProvider<Material>>() == CurrentMaterial.Target)
			{
				return;
			}
			Component component2 = (Component)CurrentMaterial.Target;
			if (ColorMappings.Count > 0 && component?.GetType() == component2.GetType() && flag)
			{
				for (int i = 0; i < component.SyncMemberCount; i++)
				{
					IField<Elements.Core.colorX> prevField = component.GetSyncMember(i) as IField<Elements.Core.colorX>;
					if (prevField != null)
					{
						int num = ColorMappings.FindIndex((ColorMapping m) => m.Field.Target == prevField);
						if (num >= 0)
						{
							ColorMappings[num].Field.Target = (IField<Elements.Core.colorX>)component2.GetSyncMember(i);
						}
					}
				}
				return;
			}
			IEnumerable<IField<Elements.Core.colorX>> source = component2.SyncMembers.OfType<IField<Elements.Core.colorX>>();
			ColorMappings.Clear();
			List<IField<Elements.Core.colorX>> list = source.Where((IField<Elements.Core.colorX> f) => f.Value.rgb != Elements.Core.float3.One && f.Value.rgb != Elements.Core.float3.Zero).ToList();
			if (list.Count == 0)
			{
				list = source.Where((IField<Elements.Core.colorX> f) => f.Value.rgb == Elements.Core.float3.One).ToList();
			}
			if (list.Count == 0)
			{
				list.Add(source.FirstOrDefault());
			}
			list.RemoveAll((IField<Elements.Core.colorX> f) => f.Name.ToLower().Contains("specular"));
			if (list.Count <= 0)
			{
				return;
			}
			ColorHSV colorHSV = new ColorHSV(0f, 0f, 0f);
			for (int num2 = 0; num2 < list.Count; num2++)
			{
				ColorHSV colorHSV2 = new ColorHSV(list[num2].Value);
				if (colorHSV2.s > colorHSV.s)
				{
					colorHSV = colorHSV2;
				}
			}
			for (int num3 = 0; num3 < list.Count; num3++)
			{
				ColorHSV colorHSV3 = new ColorHSV(list[num3].Value);
				ColorMapping colorMapping = ColorMappings.Add();
				colorMapping.Field.Target = list[num3];
				colorMapping.HueOffset.Value = colorHSV3.h - colorHSV.h;
				colorMapping.ValueOffset.Value = colorHSV3.v - colorHSV.v;
				colorMapping.SaturationOffset.Value = colorHSV3.s - colorHSV.s;
				colorMapping.AlphaMultiplier.Value = colorHSV3.a;
			}
		}

		public void TryChangeCurrentMaterialColor(Elements.Core.colorX color)
		{
			_pickedColor.Value = color;
			_lastPickedColor = color;
			EnsureUnusedMaterial();
			ColorHSV colorHSV = new ColorHSV(in color);
			foreach (ColorMapping colorMapping in ColorMappings)
			{
				ColorHSV colorHSV2 = new ColorHSV(MathX.Repeat01(colorHSV.h + (float)colorMapping.HueOffset), colorHSV.s + (float)colorMapping.SaturationOffset, colorHSV.v + (float)colorMapping.ValueOffset, colorHSV.a * (float)colorMapping.AlphaMultiplier);
				colorMapping.Field.Target.Value = colorHSV2.ToRGB(color.profile);
			}
			OnColorPicked(color);
		}

