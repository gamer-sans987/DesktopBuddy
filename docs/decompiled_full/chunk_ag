		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			if (control.GetTypeVersion(GetType()) == 0)
			{
				control.OnLoaded(this, SetupAmbientLight);
			}
			if (control.GetFeatureFlag("NetCore").HasValue)
			{
				return;
			}
			control.OnLoaded(this, delegate
			{
				if (Material.Target == null)
				{
					UniLog.Log($"Skybox material is null! Injecting fake material for compatibility. On:\n{this}");
					UnlitMaterial unlitMaterial = base.Slot.AttachComponent<UnlitMaterial>();
					unlitMaterial.BlendMode.Value = BlendMode.Alpha;
					unlitMaterial.TintColor.Value = Elements.Core.colorX.Clear;
					Material.Target = unlitMaterial;
				}
			});
		}

		public void SetupAmbientLight()
		{
			AmbientLightSH2 ambientLightSH = base.Slot.AttachComponent<AmbientLightSH2>();
			ReflectionProbeSH2 reflectionProbeSH = base.Slot.AttachComponent<ReflectionProbeSH2>();
			ReflectionProbe reflectionProbe = base.Slot.AttachComponent<ReflectionProbe>();
			reflectionProbe.ProbeType.Value = ReflectionProbeType.OnChanges;
			reflectionProbe.SkyboxOnly.Value = true;
