			TextRenderer target = _target.Target;
			Slot slot = target.Slot;
			base.Slot.GlobalPosition = slot.GlobalPosition;
			base.Slot.GlobalRotation = slot.GlobalRotation;
			Elements.Core.BoundingBox boundingBox = target.GetBoundingBoxInSpace(base.Slot);
			if (!boundingBox.IsValid)
			{
				boundingBox = new Elements.Core.BoundingBox(Elements.Core.float3.Zero);
