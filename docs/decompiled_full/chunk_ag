	/// <summary>
	/// Renders a skybox in the world using a material asset
	/// </summary>
	[Category(new string[] { "Rendering" })]
	public class Skybox : Component, ICustomInspector, IWorker, IWorldElement
	{
		/// <summary>
		/// Reference to the material asset to be used for skybox rendering
		/// </summary>
		public readonly AssetRef<Material> Material;

		/// <summary>
		/// A read-only bool which shows if this instance of the component is the currently active one
		/// </summary>
		public readonly RawOutput<bool> IsActive;

		public override int Version => 1;

		public static string ACTIVE_SKYBOX_KEY => "Skybox";

		/// <summary>
		/// Determines whether the component is currently rendering skybox in the world
		/// </summary>
		public bool ActiveSkybox
		{
			get
			{
				return HasKey(ACTIVE_SKYBOX_KEY);
			}
			set
			{
				if (!ActiveSkybox && value)
				{
					AssignKey(ACTIVE_SKYBOX_KEY);
				}
				if (ActiveSkybox && !value)
				{
					RemoveKey(ACTIVE_SKYBOX_KEY);
				}
			}
		}

		private void CheckActiveSkyboxes()
		{
			if (!base.World.IsKeyInUse(ACTIVE_SKYBOX_KEY))
			{
				ActiveSkybox = true;
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			Material.ListenToAssetUpdates = true;
		}

		protected override void OnStart()
		{
			CheckActiveSkyboxes();
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			IsActive.Value = ActiveSkybox;
		}

		public override void OnFocusChanged(World.WorldFocus focus)
		{
			CheckActiveSkyboxes();
			MarkChangeDirty();
			RunInSeconds(1f, base.MarkChangeDirty);
		}

