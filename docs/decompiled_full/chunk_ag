	{
		public const float RADIUS = 0.05f;

		public static MAT CreateMaterialOrb<MAT>(this Slot slot, Action<MAT> init = null) where MAT : Component, IAssetProvider<Material>, new()
		{
			MAT val = slot.AttachComponent<MAT>();
			init?.Invoke(val);
			ConstructMaterialOrb(val, slot);
			return val;
		}

		public static Slot ConstructMaterialOrb(IAssetProvider<Material> material, float horizontalScale = 1f)
		{
			Slot slot = material.World.AddSlot("MaterialOrb");
			ConstructMaterialOrb(material, slot, horizontalScale);
			return slot;
		}

		public static void ConstructMaterialOrb(IAssetProvider<Material> material, Slot slot, float horizontalScale = 1f)
		{
			SphereMesh sphereMesh = slot.AttachMesh<SphereMesh>(material);
			sphereMesh.UVScale.Value = new Elements.Core.float2(horizontalScale, 1f);
			SphereCollider sphereCollider = slot.AttachComponent<SphereCollider>();
			sphereMesh.Radius.Value = 0.05f;
			sphereCollider.Radius.Value = 0.05f;
			slot.AttachComponent<Grabbable>().ReparentOnRelease.Value = false;
			slot.AttachComponent<Snapper>();
			slot.AttachComponent<AssetProxy<Material>>().AssetReference.Target = material;
			slot.AttachComponent<ReferenceProxy>().Reference.Target = material;
			slot.DisallowMaterialChange();
		}

		public static HashSet<IAssetProvider<Material>> ExtractAllMaterials(Slot slot)
		{
			HashSet<IAssetProvider<Material>> hashSet = new HashSet<IAssetProvider<Material>>();
			foreach (MeshRenderer componentsInChild in slot.GetComponentsInChildren<MeshRenderer>())
			{
				foreach (IAssetProvider<Material> material in componentsInChild.Materials)
				{
					if (material != null)
					{
						hashSet.Add(material);
					}
				}
			}
			return hashSet;
		}

		public static void ExtractAllMaterials(Slot slot, Elements.Core.float3 point, Elements.Core.floatQ orientation)
		{
			HashSet<IAssetProvider<Material>> hashSet = ExtractAllMaterials(slot);
			if (hashSet.Count == 0)
			{
				return;
			}
			slot.World.BeginUndoBatch("Undo.ExtractMaterialsFromHierarchy".AsLocaleKey());
			List<Slot> list = new List<Slot>();
			foreach (IAssetProvider<Material> item in hashSet)
			{
				Slot slot2 = ConstructMaterialOrb(item);
				slot2.SetParent(slot.LocalUserSpace, keepGlobalTransform: false);
				slot2.CreateSpawnUndoPoint();
				list.Add(slot2);
			}
			slot.World.EndUndoBatch();
			SlotPositioning.ArrangeInGrid(list, point, orientation, 0.112500004f);
		}
	}
