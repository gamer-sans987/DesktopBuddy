	public class MinecraftEngineData
	{
		private const int RENDER_DISTANCE = 512;

		private const int SEA_LEVEL = 62;

		private Dictionary<Elements.Core.int2, long> _chunkTimestamps = new Dictionary<Elements.Core.int2, long>();

		private Dictionary<Elements.Core.int2, long> _newTimestamps = new Dictionary<Elements.Core.int2, long>();

		private DateTime _importStart;

		private int _processedChunks;

		public World World { get; private set; }

		public Slot MapRoot { get; private set; }

		public Slot GroupsRoot { get; private set; }

		public Slot MaterialsRoot { get; private set; }

		public Slot TimestampRoot { get; private set; }

		public int GroupSize { get; private set; }

		public TimeSpan Elapsed => DateTime.UtcNow - _importStart;

		public int TotalChunkCount => _processedChunks;

		public int UpdatedChunkCount => _newTimestamps.Count;

		public MinecraftEngineData(World world, int groupSize)
		{
			World = world;
			_importStart = DateTime.UtcNow;
			MapRoot = world.RootSlot.FindChildOrAdd("Minecraft Map");
			MapRoot.LocalPosition = Elements.Core.float3.One * -0.5f + Elements.Core.float3.Down * 62;
			GroupsRoot = MapRoot.FindChildOrAdd("Chunk Groups");
			MaterialsRoot = MapRoot.FindChildOrAdd("Materials");
			GroupSize = groupSize;
			foreach (Slot child in GroupsRoot.Children)
			{
				Slot slot = child.FindChild("Timestamps");
				if (slot == null)
				{
					continue;
				}
				foreach (Slot child2 in slot.Children)
				{
					if (Elements.Core.int2.TryParse(child2.Name, out var val))
					{
						ValueField<long> component = child2.GetComponent<ValueField<long>>();
						if (component != null)
						{
							_chunkTimestamps.Add(val, component.Value);
						}
					}
				}
			}
		}

		public Elements.Core.int2 ChunkCoordinateToGroup(Elements.Core.int2 globalChunkCoordinate)
		{
			Elements.Core.int2 a = globalChunkCoordinate;
			return (a - (Elements.Core.int2.One * GroupSize - 1).Mask(a < 0)) / GroupSize;
		}

		public bool ShouldUpdateChunk(Elements.Core.int2 globalChunkCoordinate, long timestamp)
		{
			_processedChunks++;
			if (_chunkTimestamps.TryGetValue(globalChunkCoordinate, out var value) && value == timestamp)
			{
				return false;
			}
			_newTimestamps.Add(globalChunkCoordinate, timestamp);
			return true;
		}

		public void WriteNewTimestamps()
		{
			foreach (KeyValuePair<Elements.Core.int2, long> newTimestamp in _newTimestamps)
			{
				Elements.Core.int2 coordinate = ChunkCoordinateToGroup(newTimestamp.Key);
				GetGroupRoot(coordinate).FindChildOrAdd("Timestamps").FindChildOrAdd(newTimestamp.Key.ToString()).GetComponentOrAttach<ValueField<long>>()
					.Value.Value = newTimestamp.Value;
			}
		}

		public void FinishImport()
		{
			WriteNewTimestamps();
		}

		public Slot GetGroupRoot(Elements.Core.int2 coordinate)
		{
			string name = coordinate.ToString();
			Slot slot = GroupsRoot.FindChild(name);
			if (slot != null)
			{
				return slot;
			}
			slot = GroupsRoot.AddSlot(name);
			slot.LocalPosition = coordinate.x_y * GroupSize * new Elements.Core.int3(1, 1, -1);
			return slot;
		}

		public async Task SetupGroup(Slot root, MinecraftGroupData groupData)
		{
			Slot modelRoot = root.FindChild((Slot s) => s.Name.EndsWith(".obj"));
			WorldOptimizer.CleanupEmptySlots(modelRoot);
			DictionaryList<MinecraftMaterialGroup, Slot> materialGroups = new DictionaryList<MinecraftMaterialGroup, Slot>();
			await ProcessChildren(modelRoot);
			while (!modelRoot.ForeachComponentInChildren((MeshRenderer m) => m.Mesh.IsAssetAvailable))
			{
				await default(NextUpdate);
			}
			Slot geometryRoot = root.AddSlot("Geometry");
			Slot assetsRoot = root.AddSlot("Assets");
			foreach (KeyValuePair<MinecraftMaterialGroup, List<Slot>> group in materialGroups)
			{
				Slot slot = geometryRoot.AddSlot(group.Key.ToString());
				foreach (Slot item in group.Value)
				{
					item.Parent = slot;
				}
				Slot slot2 = await slot.BakeMeshes(destroyOriginal: true, undoable: false, includeInactive: false, skinnedMeshMode: false, ComponentHandling.NeverAdd, group.Key.collision ? ComponentHandling.AlwaysAdd : ComponentHandling.NeverAdd, assetsRoot);
				if (group.Key.collision)
				{
					slot2.GetComponentInChildren<MeshCollider>().SetCharacterCollider();
				}
			}
			if (groupData.lightSources.Count > 0)
			{
				Slot slot3 = geometryRoot.AddSlot("Lights");
				foreach (Elements.Core.int3 lightSource in groupData.lightSources)
				{
					Slot slot4 = slot3.AddSlot("Light");
					Light light = slot4.AttachComponent<Light>();
					light.Range.Value = 6f;
					light.Intensity.Value = 1f;
					light.Color.Value = new Elements.Core.colorX(1f, 0.9f, 0.5f);
					slot4.LocalPosition = (Elements.Core.float3)new Elements.Core.int3(GroupSize - lightSource.x - 1, lightSource.yz) - new Elements.Core.float3((float)GroupSize * 0.5f, 0f, (float)GroupSize * 0.5f) + Elements.Core.float3.One * 0.5f;
				}
				slot3.ActiveSelf = false;
				DynamicValueVariableDriver<bool> dynamicValueVariableDriver = geometryRoot.AttachComponent<DynamicValueVariableDriver<bool>>();
				dynamicValueVariableDriver.VariableName.Value = "World/Minecraft.Lights";
				dynamicValueVariableDriver.DefaultValue.Value = false;
				dynamicValueVariableDriver.Target.Target = slot3.ActiveSelf_Field;
			}
			modelRoot.Destroy();
			Slot slot5 = root.AddSlot("Culling");
			SphereCollider sphereCollider = slot5.AttachComponent<SphereCollider>();
			sphereCollider.Type.Value = ColliderType.StaticTrigger;
			sphereCollider.Radius.Value = 512f;
			sphereCollider.Offset.Value = Elements.Core.float3.Up * 128;
			ColliderUserTracker colliderUserTracker = slot5.AttachComponent<ColliderUserTracker>();
			geometryRoot.ActiveSelf_Field.DriveFrom(colliderUserTracker.IsLocalUserInside);
			foreach (MeshRenderer componentsInChild in geometryRoot.GetComponentsInChildren<MeshRenderer>())
			{
				BooleanReferenceDriver<IAssetProvider<Mesh>> booleanReferenceDriver = componentsInChild.Slot.AttachComponent<BooleanReferenceDriver<IAssetProvider<Mesh>>>();
				booleanReferenceDriver.TrueTarget.Target = componentsInChild.Mesh.Target;
				booleanReferenceDriver.TargetReference.Target = componentsInChild.Mesh;
				booleanReferenceDriver.State.DriveFrom(colliderUserTracker.IsLocalUserInside);
			}
			foreach (MeshCollider componentsInChild2 in geometryRoot.GetComponentsInChildren<MeshCollider>())
			{
				BooleanReferenceDriver<IAssetProvider<Mesh>> booleanReferenceDriver2 = componentsInChild2.Slot.AttachComponent<BooleanReferenceDriver<IAssetProvider<Mesh>>>();
				booleanReferenceDriver2.TrueTarget.Target = componentsInChild2.Mesh.Target;
				booleanReferenceDriver2.TargetReference.Target = componentsInChild2.Mesh;
				booleanReferenceDriver2.State.DriveFrom(colliderUserTracker.IsLocalUserInside);
			}
			async Task ProcessChildren(Slot slot6)
			{
				foreach (Slot child in slot6.Children)
				{
					MinecraftMaterialGroup minecraftMaterialGroup = MinecraftMaterialClassifier.Classify(child.Name);
					MeshRenderer componentInChildren = child.GetComponentInChildren<MeshRenderer>();
					if (minecraftMaterialGroup.split)
					{
						UniLog.Log("Splitting " + child.Name);
						Slot rendererRoot = componentInChildren.Slot;
						await componentInChildren.SplitSubmeshesAsync((string matName, int index) => matName.Replace("Material: ", "").Trim());
						await ProcessChildren(rendererRoot);
					}
					else
					{
						UniLog.Log($"Classification {child.Name} - {minecraftMaterialGroup}");
						materialGroups.Add(minecraftMaterialGroup, child);
						await SetupMaterials(componentInChildren, child.Name, minecraftMaterialGroup);
					}
				}
			}
		}

		public async Task SetupMaterials(MeshRenderer renderer, string groupName, MinecraftMaterialGroup group)
		{
			for (int i = 0; i < renderer.Materials.Count; i++)
			{
				MaterialProvider materialProvider = (MaterialProvider)renderer.Materials[i];
				string name = materialProvider.Slot.Name;
				List<string> list = NameHeuristicsHelper.SplitName(name);
				MaterialProvider materialProvider2 = MaterialsRoot.FindChild(name)?.GetComponent<MaterialProvider>();
				if (materialProvider2 == null)
				{
					materialProvider2 = MaterialsRoot.AddSlot(name).DuplicateComponent(materialProvider);
					if (list.Contains("water"))
					{
						materialProvider2 = SetupWater(list, materialProvider2);
					}
					else if (list.Contains("grass") && !list.Contains("block") && !list.Contains("double") && !list.Contains("tall") && !list.Contains("path"))
					{
						materialProvider2 = SetupGrass(materialProvider2);
					}
					else if (group.alphaHandling != AlphaHandling.Opaque)
					{
						materialProvider2 = SetupDualsided(materialProvider2);
					}
					if (materialProvider2 is IPBS_Material iPBS_Material)
					{
						if (iPBS_Material is IPBS_Metallic iPBS_Metallic)
						{
							iPBS_Metallic.Metallic = 0f;
							iPBS_Metallic.Smoothness = 0f;
						}
						if (iPBS_Material is IPBS_Specular iPBS_Specular)
						{
							iPBS_Specular.SpecularColor = Elements.Core.colorX.Clear;
						}
						switch (group.alphaHandling)
						{
						case AlphaHandling.AlphaBlend:
							iPBS_Material.BlendMode = BlendMode.Alpha;
							break;
						case AlphaHandling.AlphaClip:
							iPBS_Material.BlendMode = BlendMode.Cutout;
							break;
						}
					}
				}
				renderer.Materials[i] = materialProvider2;
			}
		}

		public MaterialProvider SetupDualsided(MaterialProvider material)
		{
			if (material is PBS_Specular pBS_Specular)
			{
				PBS_DualSidedSpecular pBS_DualSidedSpecular = material.Slot.AttachComponent<PBS_DualSidedSpecular>();
				MaterialHelper.CopyMaterialProperties(pBS_Specular, pBS_DualSidedSpecular);
				pBS_DualSidedSpecular.Culling.Value = Culling.Off;
				pBS_Specular.Destroy();
				return pBS_DualSidedSpecular;
			}
			return material;
		}

		public MaterialProvider SetupGrass(MaterialProvider material)
		{
			if (material is PBS_Specular pBS_Specular)
			{
				PBS_DisplaceSpecular pBS_DisplaceSpecular = material.Slot.AttachComponent<PBS_DisplaceSpecular>();
				pBS_DisplaceSpecular.Culling.Value = Culling.Off;
				MaterialHelper.CopyMaterialProperties(pBS_Specular, pBS_DisplaceSpecular);
				GradientStripTexture gradientStripTexture = material.Slot.AttachComponent<GradientStripTexture>();
				gradientStripTexture.SetupGradientFromTo(Elements.Core.colorX.White, Elements.Core.colorX.Black);
				gradientStripTexture.Orientation = GradientStripTexture.StripOrientation.Vertical;
				pBS_DisplaceSpecular.VertexDisplaceMap.Target = gradientStripTexture;
				TimeSineDriver timeSineDriver = material.Slot.AttachComponent<TimeSineDriver>();
				timeSineDriver.Min.Value = -0.1f;
				timeSineDriver.Max.Value = 0.1f;
				timeSineDriver.Target.Target = pBS_DisplaceSpecular.VertexDisplaceMagnitude;
				pBS_Specular.Destroy();
				return pBS_DisplaceSpecular;
			}
			return material;
		}

		public MaterialProvider SetupWater(List<string> names, MaterialProvider material)
		{
			if (material is PBS_Specular pBS_Specular)
			{
				PBS_DualSidedSpecular pBS_DualSidedSpecular = pBS_Specular.Slot.AttachComponent<PBS_DualSidedSpecular>();
				MaterialHelper.CopyMaterialProperties(pBS_Specular, pBS_DualSidedSpecular);
				pBS_DualSidedSpecular.Culling.Value = Culling.Off;
				pBS_DualSidedSpecular.OffsetFactor.Value = 1f;
				pBS_DualSidedSpecular.OffsetUnits.Value = 1f;
				if (names.Contains("flow"))
				{
					Panner2D panner2D = material.Slot.AttachComponent<Panner2D>();
					panner2D.Target = pBS_DualSidedSpecular.TextureOffset;
					panner2D.Speed = new Elements.Core.float2(0f, 1f);
				}
				pBS_Specular.Destroy();
				return pBS_DualSidedSpecular;
			}
			return material;
		}
	}
