		private static async Task ImportImageSlicesAsVolume(Slot root, string path, bool grayscale)
		{
			ProgressBarInterface progress = await root.World.AddSlot("Import indicator").SpawnEntity<ProgressBarInterface, LegacySegmentCircleProgress>(FavoriteEntity.ProgressBar);
			progress.Initialize(canBeHidden: false);
			progress.UpdateProgress(-1f, "Waiting", "");
			await default(ToBackground);
			progress.UpdateProgress(0f, "Collecting files", "");
			List<string> list = new List<string>();
			foreach (string item in Directory.EnumerateFiles(path))
			{
				if (AssetHelper.IdentifyClass(item) == AssetClass.Texture)
				{
					list.Add(item);
				}
			}
			if (list.Count < 2)
			{
				progress.ProgressFail("At least 2 image files are required");
				return;
			}
			progress.UpdateProgress(0f, "Generating 3D Texture", list.Count + " Slices");
			Stopwatch stopwatch = Stopwatch.StartNew();
			Bitmap3D texture = Bitmap3D.CreateFromSlices(list, grayscale ? TextureFormat.Alpha8 : TextureFormat.RGB24, TextureSize.NearestPOT);
			UniLog.Log("3D Texture Generated in: " + stopwatch.Elapsed);
			progress.UpdateProgress(99f, "Encoding...", "");
			Uri uri = await root.Engine.LocalDB.SaveAssetAsync(texture).ConfigureAwait(continueOnCapturedContext: false);
			await default(ToWorld);
			UniversalImporter.SpawnVolume(root, uri, root.LocalUserRoot.GlobalScale * Elements.Core.float3.One, grayscale);
			progress.ProgressDone("Imported");
		}
	}
