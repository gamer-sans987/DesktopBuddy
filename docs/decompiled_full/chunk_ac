	public class Shader : RendererAsset<Shader, ShaderVariantDescriptor>, IAssetRequester
	{
		private static string[] AndroidBlockedShaders = new string[14]
		{
			"Blur", "Blur_PerObject", "GetDepth", "Gamma", "Grayscale", "HSV", "ChannelMatrix", "Invert", "Pixelate", "Pixelate_PerObject",
			"Posterize", "Refract", "Refract_PerObject", "Threshold"
		};

		private TaskCompletionSource<bool> onAssetUpdated;

		private KeyCounter<uint> variantRequestCount;

		private DictionaryList<uint, ShaderVariantHandler> variantAvailableCallbacks;

		private Dictionary<uint, Shader> variants;

		public ShaderMetadata Metadata => base.VariantManager?.Metadata as ShaderMetadata;

		public bool IsMetadataVariant => Metadata != null;

		public uint? VariantIndex { get; private set; }

		protected override RenderAssetManager<Shader> Manager => base.RenderSystem.Shaders;

		private string ShaderName => base.AssetURL.LocalPath.Substring(1);

		private ShaderTargetPlatform ShaderPlatform => base.Engine.Platform switch
		{
			Platform.Windows => ShaderTargetPlatform.WindowsDX11, 
			Platform.Linux => ShaderTargetPlatform.WindowsDX11, 
			Platform.Android => ShaderTargetPlatform.AndroidOpenGL, 
			_ => throw new NotSupportedException("Unsupported engine platform: " + base.Engine.Platform), 
		};

		public int UniqueVariantRequestCount => variantRequestCount?.KeyCount ?? (-1);

		public int VariantCallbackCount => variantAvailableCallbacks?.Count ?? (-1);

		public int VariantCount => variants?.Count ?? (-1);

		protected override async Task LoadTargetVariant(ShaderVariantDescriptor variant)
		{
			if (variant.VariantManager)
			{
				if (Metadata == null)
				{
					FailLoad("Could not load metadata");
					return;
				}
				if (base.AssetURL.Scheme != base.Engine.Cloud.Assets.DBScheme)
				{
					FailLoad("Invalid protocol");
					return;
				}
				string signature = base.Engine.Cloud.Assets.DBSignature(base.AssetURL);
				if (!(await base.Engine.LocalDB.ReadVariableAsync(signature, def: false)))
				{
					if (!(await base.Engine.Cloud.Assets.IsValidShader(signature)))
					{
						FailLoad("Invalid shader");
						return;
					}
					await base.Engine.LocalDB.WriteVariableAsync(signature, value: true);
				}
				variantRequestCount = new KeyCounter<uint>();
				variantAvailableCallbacks = new DictionaryList<uint, ShaderVariantHandler>();
				variants = new Dictionary<uint, Shader>();
				return;
			}
			VariantIndex = variant.VariantIndex;
			string text = await base.AssetManager.RequestVariant(base.AssetURL, variant.VariantIdentifier, variant, generateVariant: false, waitForCloud: true).ConfigureAwait(continueOnCapturedContext: false);
			if (text == null)
			{
				FailLoad("Could not gather asset file");
				return;
			}
			bool flag = false;
			if (base.Engine.Platform == Platform.Android)
			{
				string fileName = Metadata.SourceFile.FileName;
				string[] androidBlockedShaders = AndroidBlockedShaders;
				foreach (string value in androidBlockedShaders)
				{
					if (fileName.IndexOf(value, StringComparison.InvariantCultureIgnoreCase) >= 0)
					{
						flag = true;
						break;
					}
				}
			}
			if (!flag && Manager != null)
			{
				TaskCompletionSource<bool> taskCompletionSource = (onAssetUpdated = new TaskCompletionSource<bool>());
				ShaderUpload shaderUpload = new ShaderUpload();
				shaderUpload.assetId = base.AssetId;
				shaderUpload.file = text;
				base.RenderSystem.SendAssetUpdate(shaderUpload);
				await taskCompletionSource.Task.ConfigureAwait(continueOnCapturedContext: false);
			}
		}

		public void RequestVariant(uint variant, ShaderVariantHandler callback)
		{
			CheckMetadataVariant();
			lock (base.VariantManager.VariantLock)
			{
				if (variantRequestCount.Increment(variant) == 1)
				{
					base.VariantManager.RequestAsset(this, new ShaderVariantDescriptor(variant, ShaderPlatform));
				}
				if (variants.TryGetValue(variant, out Shader value) && value.LoadState == AssetLoadState.FullyLoaded)
				{
					callback(this, variant, value);
				}
				else
				{
					variantAvailableCallbacks.Add(variant, callback);
				}
			}
		}

		public void FreeVariant(uint variant)
		{
			CheckMetadataVariant();
			lock (base.VariantManager.VariantLock)
			{
				if (variantRequestCount.Decrement(variant) == 0)
				{
					variants[variant].RemoveRequest(this);
					variants.Remove(variant);
					variantAvailableCallbacks.RemoveList(variant);
				}
			}
		}

		public void HandleResult(ShaderUploadResult result)
		{
			Interlocked.Exchange(ref onAssetUpdated, null)?.SetResult(result.instanceChanged);
		}

		private void CheckMetadataVariant()
		{
			if (!IsMetadataVariant)
			{
				throw new Exception("Given shader isn't a metadata variant");
			}
		}

		public void AssignAsset(Asset asset)
		{
			Shader shader = (Shader)asset;
			variants.Add(shader.TargetVariant.VariantIndex, shader);
		}

		public void AssetLoadStateUpdated(Asset asset)
		{
			Shader value = (Shader)asset;
			if (value.LoadState != AssetLoadState.FullyLoaded)
			{
				return;
			}
			lock (base.VariantManager.VariantLock)
			{
				uint variantIndex = value.TargetVariant.VariantIndex;
				if (!variants.TryGetValue(variantIndex, out value))
				{
					return;
				}
				List<ShaderVariantHandler> list = variantAvailableCallbacks.TryGetList(variantIndex);
				if (list != null)
				{
					foreach (ShaderVariantHandler item in list)
					{
						item(this, variantIndex, value);
					}
				}
				variantAvailableCallbacks.RemoveList(variantIndex);
			}
		}

		public override void Unload()
		{
			CancelTasks();
			if (Manager != null)
			{
				ShaderUnload shaderUnload = new ShaderUnload();
				shaderUnload.assetId = base.AssetId;
				base.RenderSystem.SendAssetUpdate(shaderUnload);
			}
			base.Unload();
		}

		private void CancelTasks()
		{
			Interlocked.Exchange(ref onAssetUpdated, null)?.TrySetCanceled();
		}
	}
