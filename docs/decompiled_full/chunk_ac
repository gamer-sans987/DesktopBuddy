				{
					FailLoad("Could not gather asset file");
					return;
				}
				string text2 = Path.GetExtension(base.AssetURL.LocalPath).Replace(".", "").ToLower();
				if (string.IsNullOrWhiteSpace(text2))
				{
					text2 = new FileInfo(text).GetFileType()?.Extension;
				}
				try
				{
					Data = FontX.Load(text, text2);
				}
				catch (Exception ex)
				{
					FailLoad("Failed to load font file from " + text + ":\n" + ex);
					return;
				}
				currentDynamicAtlas = new DynamicAtlas(this);
				_dataLoaded = true;
				GlyphEmSize = variant.GlyphEmSize;
				PixelRange = variant.PixelRange;
				Padding = variant.Padding;
				MipMaps = variant.MipMaps;
				MipMapFiltering = variant.MipMapFiltering;
			}
			else
			{
				await currentDynamicAtlas.UpdateTextureProperties().ConfigureAwait(continueOnCapturedContext: false);
			}
		}

		public async ValueTask<bool> PinGlyphs(StringRenderTree renderTree, Action invalidateCallback, List<GlyphAtlasManager> pinnedAtlases)
		{
			HashSet<uint> hashSet = null;
			int currentAtlasVersion = _atlasVersion;
			foreach (StringRenderGlyphSegmentNode item in renderTree)
			{
				Elements.Assets.FontSet fontSet = item.GetFontSet();
				if (fontSet == null || !fontSet.Fonts.Contains(Data))
				{
					continue;
				}
				for (int i = 0; i < item.GlyphSegmentLength; i++)
				{
					RenderGlyph renderGlyph = item.GetRenderGlyph(i);
					if (renderGlyph.font == Data && !(renderGlyph.rect.size == Elements.Core.float2.Zero))
					{
						if (hashSet == null)
						{
							hashSet = Pool.BorrowHashSet<uint>();
						}
						hashSet.Add(renderGlyph.glyphId);
					}
				}
			}
			if (hashSet != null)
			{
				GlyphPin pin = new GlyphPin(hashSet, invalidateCallback);
				bool pinned = false;
				DynamicAtlas dynamicAtlas;
				do
				{
					dynamicAtlas = currentDynamicAtlas;
					if (dynamicAtlas == null)
					{
						await Task.Delay(10).ConfigureAwait(continueOnCapturedContext: false);
					}
					else
					{
						pinned = await dynamicAtlas.AddPin(renderTree, pin).ConfigureAwait(continueOnCapturedContext: false);
					}
				}
				while (!pinned);
				for (int j = 0; j < dynamicAtlas.AtlasCount; j++)
				{
					pinnedAtlases.Add(dynamicAtlas.GetAtlas(j));
				}
			}
			return _atlasVersion != currentAtlasVersion;
		}

		public void RemovePin(StringRenderTree renderTree)
		{
			if (currentDynamicAtlas == null)
			{
				return;
			}
			currentDynamicAtlas.RemovePin(renderTree);
			bool flag = false;
			foreach (KeyValuePair<DynamicAtlas, bool> invalidatedAtlase in _invalidatedAtlases)
			{
				flag |= invalidatedAtlase.Key.RemovePin(renderTree);
			}
			if (flag)
			{
				ScheduleGlyphRender();
			}
		}

		internal void ScheduleGlyphRender()
		{
			lock (_lock)
			{
				if (!_renderScheduled)
				{
					_renderScheduled = true;
					if (!_renderRunning)
					{
						RunRenderGlyphs();
					}
				}
			}
		}

		private void RunRenderGlyphs()
		{
			base.Engine.GlobalCoroutineManager.StartTask(async delegate
			{
				_ = 2;
				try
				{
					await Task.Delay(16).ConfigureAwait(continueOnCapturedContext: false);
					await default(ToBackground);
					await RenderGlyphs().ConfigureAwait(continueOnCapturedContext: false);
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception in running RenderGlyphs():\n" + ex);
				}
			});
		}

		private Elements.Core.float2 ComputeGlyphSize(GlyphMetrics metrics, in Elements.Core.int2 defaultGlyphResolution)
		{
			if ((defaultGlyphResolution > 0).All())
			{
				float num = (float)MaxFixedSize / (float)MathX.MaxComponent(in defaultGlyphResolution);
				if (num < 1f)
				{
					return MathX.Max(4, MathX.RoundToInt(defaultGlyphResolution * num));
				}
				return defaultGlyphResolution;
			}
			return new Elements.Core.float2(metrics.width, metrics.height) * GlyphEmSize;
		}

		private async Task RenderGlyphs()
		{
			lock (_lock)
			{
				_renderScheduled = false;
				_renderRunning = true;
			}
			List<GlyphPackData> list = Pool.BorrowList<GlyphPackData>();
			List<TaskCompletionSource<bool>> tasks = Pool.BorrowList<TaskCompletionSource<bool>>();
			HashSet<uint> hashSet = Pool.BorrowHashSet<uint>();
			DynamicAtlas dynamicAtlas = currentDynamicAtlas;
			RenderTask result;
			while (dynamicAtlas.GlyphsToRender.TryDequeue(out result))
			{
				foreach (uint glyph in result.glyphs)
				{
					if (!hashSet.Add(glyph))
					{
						continue;
					}
					bool flag = false;
					for (int i = 0; i < dynamicAtlas.AtlasCount; i++)
					{
						if (dynamicAtlas.GetAtlas(i).Atlas.HasGlyphData(glyph))
						{
							flag = true;
							break;
						}
					}
					if (!flag)
					{
						GlyphMetrics glyphMetrics = Data.GetGlyphMetrics(glyph);
						if (glyphMetrics.width != 0f || glyphMetrics.height != 0f)
						{
							list.Add(new GlyphPackData(glyph, ComputeGlyphSize(glyphMetrics, Data.GetDefaultGlyphResolution(glyph))));
						}
					}
				}
				tasks.Add(result.finishedTask);
			}
			bool invalidated = false;
			if (!PackGlyphs(dynamicAtlas, list))
			{
				list.Clear();
				hashSet.Clear();
				foreach (KeyValuePair<StringRenderTree, GlyphPin> pin in dynamicAtlas.Pins)
				{
					foreach (uint glyph2 in pin.Value.Glyphs)
					{
						if (hashSet.Add(glyph2))
						{
							GlyphMetrics glyphMetrics2 = Data.GetGlyphMetrics(glyph2);
							list.Add(new GlyphPackData(glyph2, ComputeGlyphSize(glyphMetrics2, Data.GetDefaultGlyphResolution(glyph2))));
						}
					}
				}
				DynamicAtlas dynamicAtlas2 = new DynamicAtlas(this);
				if (!PackGlyphs(dynamicAtlas2, list))
				{
					throw new Exception("Failed to re-pack all glyphs into a new dynamic atlas!");
				}
				DynamicAtlas dynamicAtlas3 = currentDynamicAtlas;
				currentDynamicAtlas = dynamicAtlas2;
				dynamicAtlas3.Invalidate();
				_invalidatedAtlases.TryAdd(dynamicAtlas3, value: true);
				invalidated = true;
			}
			Pool.Return(ref hashSet);
			for (int j = 0; j < currentDynamicAtlas.AtlasCount; j++)
			{
				GlyphAtlasManager atlas = currentDynamicAtlas.GetAtlas(j);
				if (!atlas.Atlas.BitmapAllocated)
				{
					invalidated = true;
					atlas.Atlas.AllocateBitmap(MipMaps);
				}
			}
			if (list.Count > 0)
			{
				ActionBlock<uint> actionBlock = new ActionBlock<uint>((Action<uint>)RenderGlyph, new ExecutionDataflowBlockOptions
				{
					MaxDegreeOfParallelism = MathX.Max(1, base.Engine.ProcessorCount - 1),
					EnsureOrdered = false
				});
				foreach (GlyphPackData item in list)
				{
					actionBlock.Post(item.glyphId);
				}
				actionBlock.Complete();
				await actionBlock.Completion.ConfigureAwait(continueOnCapturedContext: false);
			}
			List<ValueTask> updateTasks = Pool.BorrowList<ValueTask>();
			for (int k = 0; k < currentDynamicAtlas.AtlasCount; k++)
			{
				updateTasks.Add(currentDynamicAtlas.GetAtlas(k).UpdateTexture(LODBias));
			}
			foreach (ValueTask item2 in updateTasks)
			{
				await item2.ConfigureAwait(continueOnCapturedContext: false);
			}
			Pool.Return(ref updateTasks);
			if (invalidated)
			{
				_atlasVersion++;
			}
			foreach (TaskCompletionSource<bool> item3 in tasks)
			{
				item3.SetResult(!invalidated);
			}
			Pool.Return(ref tasks);
			if (invalidated)
			{
				this.OnAtlasesUpdated?.Invoke();
			}
			foreach (KeyValuePair<DynamicAtlas, bool> invalidatedAtlase in _invalidatedAtlases)
			{
				if (invalidatedAtlase.Key.Pins.Count == 0)
				{
					invalidatedAtlase.Key.Unload();
					_invalidatedAtlases.TryRemove(invalidatedAtlase.Key, out var _);
				}
			}
			bool flag2 = false;
			lock (_lock)
			{
				_renderRunning = false;
				if (_renderScheduled)
				{
					flag2 = true;
				}
			}
			if (flag2)
			{
				RunRenderGlyphs();
			}
		}

		private static Elements.Core.IntRect ComputeRegion(Elements.Core.Rect rect)
		{
			Elements.Core.IntRect result = rect.RoundToIntConservative();
			if ((result.x & 1) == 1)
			{
				result.x--;
				result.width++;
			}
			if ((result.y & 1) == 1)
			{
				result.y--;
				result.height++;
			}
			if ((result.width & 1) == 1)
			{
				result.width++;
			}
			if ((result.height & 1) == 1)
			{
				result.height++;
			}
			return result;
		}

		private void RenderGlyph(uint glyphId)
		{
			try
			{
				for (int i = 0; i < currentDynamicAtlas.AtlasCount; i++)
				{
					GlyphAtlasManager atlas = currentDynamicAtlas.GetAtlas(i);
					GlyphAtlasData glyphData = atlas.Atlas.GetGlyphData(glyphId);
					if (glyphData == null)
					{
						continue;
					}
					atlas.MarkDirty();
					foreach (KeyValuePair<DynamicAtlas, bool> invalidatedAtlase in _invalidatedAtlases)
					{
						for (int j = 0; j < invalidatedAtlase.Key.AtlasCount; j++)
						{
							GlyphAtlasManager atlas2 = invalidatedAtlase.Key.GetAtlas(j);
							GlyphAtlasData glyphData2 = atlas2.Atlas.GetGlyphData(glyphId);
							if (glyphData2 != null)
							{
								atlas.Atlas.CopyGlyphBitmapFrom(glyphData, atlas2.Atlas, glyphData2);
								if (atlas.Atlas.Atlas.HasMipMaps)
								{
									atlas.Atlas.Atlas.GenerateMipMapForRegion(ComputeRegion(glyphData.region), MipMapFiltering);
								}
								return;
							}
						}
					}
					switch (RenderMethod)
					{
					case GlyphRenderMethod.MSDF:
						Data.RenderGlyphMSDF(glyphId, atlas.Atlas.Atlas, glyphData.region, PixelRange, glyphData.rotated);
						if (atlas.Atlas.Atlas.HasMipMaps)
						{
							atlas.Atlas.Atlas.GenerateMipMapForRegion(ComputeRegion(glyphData.region), MipMapFiltering);
						}
						break;
					case GlyphRenderMethod.Raster:
						Data.RenderGlyphRaster(glyphId, atlas.Atlas.Atlas, glyphData.region, glyphData.rotated);
						if (atlas.Atlas.Atlas.HasMipMaps)
						{
							atlas.Atlas.Atlas.GenerateMipMapForRegion(ComputeRegion(glyphData.region), MipMapFiltering);
						}
						break;
					default:
						throw new NotSupportedException("Unsupported render method: " + RenderMethod);
					}
					break;
				}
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception rendering glyph {glyphId} for {Data?.Name}\n" + ex);
			}
		}

		private bool PackGlyphs(DynamicAtlas dynamicAtlas, List<GlyphPackData> packData)
		{
			int num = 0;
			int num2 = 0;
			while (num < packData.Count)
			{
				if (dynamicAtlas.AtlasCount == num2)
				{
					RenderSystem renderSystem = base.Engine.RenderSystem;
					object obj;
					if (!renderSystem.HasRenderer)
					{
						obj = null;
					}
					else
					{
						IBackingBufferAllocator backingBufferAllocator = renderSystem;
						obj = backingBufferAllocator;
					}
					IBackingBufferAllocator allocator = (IBackingBufferAllocator)obj;
					GlyphAtlas atlas = new GlyphAtlas(Data, RenderMethod, allocator, Padding, PixelRange, MathX.Max(512, GlyphEmSize), 4096);
					dynamicAtlas.AddAtlas(new GlyphAtlasManager(this, atlas));
				}
				GlyphAtlasManager atlas2 = dynamicAtlas.GetAtlas(num2);
				bool flag = IsFullSize(atlas2.Atlas) || !atlas2.Atlas.BitmapAllocated;
				num = atlas2.Atlas.Pack(packData, num, flag);
				if (num < packData.Count)
				{
					if (!flag)
					{
						return false;
					}
					num2++;
