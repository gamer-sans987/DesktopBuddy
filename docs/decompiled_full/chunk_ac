		public static float operator -(LegacyReverb left, LegacyReverb right)
		{
			float[] array = GetArray(left);
			float[] array2 = GetArray(right);
			Normalize(array);
			Normalize(array2);
			float num = 0f;
			for (int i = 0; i < array.Length; i++)
			{
				num += MathX.Pow(array[i] - array2[i], 2f);
