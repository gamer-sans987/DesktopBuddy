		public bool CanModify(IRecord recordId)
		{
			return CanModify(recordId.OwnerId);
		}

		public bool CanModify(string ownerId)
		{
			EngineSkyFrostInterface cloud = Engine.Cloud;
			OwnerType ownerType = IdUtil.GetOwnerType(ownerId);
			switch (ownerType)
			{
			case OwnerType.Machine:
				return true;
			case OwnerType.User:
				if (ownerId == cloud.Session.CurrentUserID)
				{
					return true;
				}
				break;
			}
			if (ownerType == OwnerType.Group && cloud.Groups.TryGetCurrentUserGroupMemberInfo(ownerId) != null)
			{
				return true;
			}
			return false;
		}
	}
	public class SessionData
	{
		private BroadcastTarget lastBroadcastTarget;

		private bool lastBroadcastOnLAN;

		private DateTime lastLANbroadcast;

		private DateTime lastWANannounce;

		private bool lastPublicAnnounced;

		private DateTime lastPublicAnnoucement;

		private bool schedulePublicAnnouncement;

		private DateTime lastMetadataAnnoucement;

		private bool metadataAnnoucementDirty = true;

		private bool metadataAnnoucementRunning;

		private DateTime? forceUpdateOnTime;

		public static TimeSpan AnnounceInterval => TimeSpan.FromSeconds(15L);

		public EngineSkyFrostInterface Cloud => Engine.Cloud;

		public Engine Engine => Announcer.Engine;

		public SessionAnnouncer Announcer { get; private set; }

		public World World { get; private set; }

		public SessionInfo Info { get; private set; }

		public SessionData(SessionAnnouncer announcer, World world)
		{
			Announcer = announcer;
			World = world;
			Info = new SessionInfo();
		}

		internal void SendInfoToUser(string userId)
		{
			SendInfoToTarget(new BroadcastTarget(BroadcastGroup.SpecificContacts, userId));
		}

		internal void SendInfoToConnectionId(string connectionId)
		{
			SendInfoToTarget(new BroadcastTarget(BroadcastGroup.ConnectionIds, connectionId));
		}

		internal void SendInfoToTarget(BroadcastTarget target)
		{
			if (Info?.SessionId != null && !Info.HideFromListing && Info.AccessLevel >= SessionAccessLevel.Contacts && (Info.AccessLevel == SessionAccessLevel.ContactsPlus || World.IsAuthority))
			{
				Task.Run(async delegate
				{
					await Cloud.HubClient.BroadcastSession(Info, target).ConfigureAwait(continueOnCapturedContext: false);
				});
			}
		}

		private void CheckScheduledPublicAnnoucement()
		{
			if (schedulePublicAnnouncement && DateTime.UtcNow - lastPublicAnnoucement > AnnounceInterval)
			{
				Announcer.SchedulePublicAnnoucement(Info);
				lastPublicAnnoucement = DateTime.UtcNow;
				schedulePublicAnnouncement = false;
			}
		}

		internal void Update()
		{
			bool announceOnWAN = World.AnnounceOnWAN;
			if (World.IsAuthority && announceOnWAN && DateTime.UtcNow - lastWANannounce >= AnnounceInterval)
			{
				IReadOnlyList<IListener> readOnlyList = World.Session?.Connections?.Listener.Listeners;
				if (readOnlyList != null)
				{
					foreach (IListener item in readOnlyList)
					{
						item.GlobalAnnounceRefresh();
					}
				}
				lastWANannounce = DateTime.UtcNow;
			}
			bool flag = false;
			try
			{
				flag = World.UpdateSessionInfo(Info);
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception updating session info: " + ex);
			}
			if (flag)
			{
				metadataAnnoucementDirty = true;
			}
			if (Info.SessionId == null)
			{
				return;
			}
			if (World.IsAuthority)
			{
				CheckScheduledPublicAnnoucement();
			}
			bool flag2 = false;
			if (forceUpdateOnTime >= DateTime.UtcNow)
			{
				flag2 = true;
				forceUpdateOnTime = null;
			}
			if (announceOnWAN && World.IsAuthority)
			{
				TimeSpan timeSpan = DateTime.UtcNow - lastMetadataAnnoucement;
				if ((timeSpan >= UserStatus.StatusHeartbeat || (metadataAnnoucementDirty && timeSpan >= AnnounceInterval)) && !metadataAnnoucementRunning)
				{
					Task.Run(async delegate
					{
						try
						{
							metadataAnnoucementRunning = true;
							await Cloud.Sessions.UpdateSessionMetadata(Info.GetMetadata()).ConfigureAwait(continueOnCapturedContext: false);
						}
						catch (Exception ex2)
						{
							UniLog.Log("Exception in updating session metadata:\n" + ex2);
						}
						finally
						{
							metadataAnnoucementRunning = false;
						}
					});
					metadataAnnoucementDirty = false;
					lastMetadataAnnoucement = DateTime.UtcNow;
				}
			}
			if (!flag)
			{
				if (lastBroadcastOnLAN && DateTime.UtcNow - lastLANbroadcast > LAN_SessionAnnouncer.BroadcastInterval)
				{
					BroadcastOnLAN();
				}
				if (!flag2)
				{
					return;
				}
			}
			Cloud.Sessions.UpdateSessionInfo(Info, localUpdate: true);
			BroadcastTarget target = null;
			bool flag3 = false;
			bool flag4 = false;
			if (!Info.HideFromListing)
			{
				switch (Info.AccessLevel)
				{
				case SessionAccessLevel.Private:
					if (World.IsAuthority)
					{
						List<string> allowedUserList = World.GetAllowedUserList();
						if (allowedUserList.Count > 0)
						{
							allowedUserList.Sort();
							target = new BroadcastTarget(BroadcastGroup.SpecificContacts, allowedUserList);
						}
					}
					break;
				case SessionAccessLevel.LAN:
					flag3 = true;
					break;
				case SessionAccessLevel.Contacts:
					if (World.IsAuthority)
					{
						target = BroadcastTarget.ALL_CONTACTS;
					}
					break;
				case SessionAccessLevel.ContactsPlus:
				{
					Sync<string> broadcastKey = World.Configuration.BroadcastKey;
					if (World.IsAuthority && !string.IsNullOrEmpty(broadcastKey))
					{
						target = new BroadcastTarget(BroadcastGroup.BroadcastKey, broadcastKey);
					}
					break;
				}
				case SessionAccessLevel.RegisteredUsers:
				case SessionAccessLevel.Anyone:
					if (World.IsAuthority)
					{
						target = BroadcastTarget.PUBLIC;
						flag3 = true;
						flag4 = true;
					}
					break;
				}
			}
			if (target != null || lastBroadcastTarget != null)
			{
				Task.Run(async delegate
				{
					_ = 1;
					try
					{
						if (Cloud.HubClient == null)
						{
							UniLog.Warning("HubClient is null when trying to broadcast session info");
						}
						else
						{
							if (target != null)
							{
								await Cloud.HubClient.BroadcastSession(Info, target);
							}
							if (target != lastBroadcastTarget && lastBroadcastTarget != null)
							{
								await Cloud.HubClient.BroadcastSessionEnded(Info.SessionId, Info.LastUpdate, lastBroadcastTarget);
							}
							lastBroadcastTarget = target;
						}
					}
					catch (Exception ex2)
					{
						UniLog.Error("Exception broadcasting session info: " + ex2);
					}
				});
			}
			if (flag3)
			{
				BroadcastOnLAN();
			}
			else if (lastBroadcastOnLAN)
			{
				Announcer.LAN_Announcer.AnnounceSessionEnded(Info.SessionId, Info.LastUpdate);
			}
			lastBroadcastOnLAN = flag3;
			if (flag4)
			{
				if (!lastPublicAnnounced)
				{
					Announcer.SchedulePublicAnnoucement(Info);
					lastPublicAnnoucement = DateTime.UtcNow;
					lastPublicAnnounced = true;
					forceUpdateOnTime = DateTime.UtcNow.AddSeconds(15.0);
				}
				else
				{
					schedulePublicAnnouncement = true;
				}
			}
			else
			{
				schedulePublicAnnouncement = false;
				if (lastPublicAnnounced)
				{
					Announcer.SchedulePublicAnnoucementRemoval(Info.SessionId);
					lastPublicAnnounced = false;
				}
			}
		}

		private void BroadcastOnLAN()
		{
			lastLANbroadcast = DateTime.UtcNow;
			Announcer.LAN_Announcer.AnnounceSession(Info);
		}

		internal async Task Remove()
		{
			if (Info.SessionId == null)
			{
				return;
			}
			Info.LastUpdate = DateTime.UtcNow;
			Cloud.Sessions.RemoveSession(Info.SessionId, DateTime.MaxValue, isLocalRemoval: true);
			if (lastBroadcastOnLAN)
			{
				Announcer.LAN_Announcer.AnnounceSessionEnded(Info.SessionId, Info.LastUpdate);
			}
			if (lastPublicAnnounced)
			{
				Announcer.SchedulePublicAnnoucementRemoval(Info.SessionId);
				lastPublicAnnounced = false;
			}
			if (lastBroadcastTarget != null)
			{
				await Task.Run(async delegate
				{
					await Cloud.HubClient.BroadcastSessionEnded(Info.SessionId, Info.LastUpdate, lastBroadcastTarget).ConfigureAwait(continueOnCapturedContext: false);
				}).ConfigureAwait(continueOnCapturedContext: false);
			}
		}
	}
	public class SessionAnnouncer
	{
		private Dictionary<World, SessionData> worldData = new Dictionary<World, SessionData>();

		private List<SessionInfo> sessionsToPublicAnnounce = new List<SessionInfo>();

		private List<string> sessionsToPublicRemove = new List<string>();

		public Engine Engine { get; private set; }

		public EngineSkyFrostInterface Cloud => Engine.Cloud;

		internal LAN_SessionAnnouncer LAN_Announcer { get; private set; }

		public SessionAnnouncer(Engine engine)
		{
			Engine = engine;
			LAN_Announcer = new LAN_SessionAnnouncer(this);
			engine.Cloud.HubStatusController.OnUserStatusRequested += UserStatusRequested;
			engine.Cloud.HubStatusController.OnKeyListenerAdded += OnKeyListenerAdded;
			engine.OnShutdown += OnEngineShutdown;
		}

		private void OnKeyListenerAdded(string broadcastKey, string connectionId)
		{
			foreach (KeyValuePair<World, SessionData> worldDatum in worldData)
			{
				if (worldDatum.Value?.Info?.BroadcastKey == broadcastKey)
				{
					UniLog.Log("Sending info matching broadcast key " + broadcastKey + " to " + connectionId);
					worldDatum.Value.SendInfoToConnectionId(connectionId);
					break;
				}
			}
		}

		private void OnEngineShutdown()
		{
			Engine.RegisterShutdownTask(Exit());
		}

		private void UserStatusRequested(string userId)
		{
			foreach (KeyValuePair<World, SessionData> worldDatum in worldData)
			{
				worldDatum.Value.SendInfoToUser(userId);
			}
		}

		public SessionInfo GetSessionInfo(World world)
		{
			if (worldData.TryGetValue(world, out SessionData value))
			{
				return value.Info;
			}
			return null;
		}

		internal void Update()
		{
			List<World> list = Pool.BorrowList<World>();
			HashSet<World> hashSet = Pool.BorrowHashSet<World>();
			foreach (KeyValuePair<World, SessionData> worldDatum in worldData)
			{
				hashSet.Add(worldDatum.Key);
			}
			Engine.WorldManager.GetWorlds(list);
			foreach (World item in list)
			{
				if (!item.IsDestroyed && !item.IsDisposed && item.State == World.WorldState.Running)
				{
					hashSet.Remove(item);
					if (!worldData.TryGetValue(item, out SessionData value))
					{
						value = new SessionData(this, item);
						worldData.Add(item, value);
					}
					value.Update();
				}
			}
			Pool.Return(ref list);
			foreach (World item2 in hashSet)
			{
				worldData[item2].Remove();
				worldData.Remove(item2);
			}
			Pool.Return(ref hashSet);
			ProcessPublicAnnoucements();
		}

		private async Task ProcessPublicAnnoucements()
		{
			if (sessionsToPublicAnnounce.Count <= 0 && sessionsToPublicRemove.Count <= 0)
			{
				return;
			}
			foreach (string removedId in sessionsToPublicRemove)
			{
				sessionsToPublicAnnounce.RemoveAll((SessionInfo s) => s.SessionId == removedId);
			}
			SessionUpdate update = new SessionUpdate();
			update.HostedSessions = new List<SessionInfo>(sessionsToPublicAnnounce);
			update.RemovedSessions = new List<string>(sessionsToPublicRemove);
			sessionsToPublicAnnounce.Clear();
			sessionsToPublicRemove.Clear();
			await Task.Run(async delegate
			{
				try
				{
					await Cloud.Sessions.UpdateSessions(update).ConfigureAwait(continueOnCapturedContext: false);
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception updating cloud sessions:\n" + ex);
				}
			}).ConfigureAwait(continueOnCapturedContext: false);
		}

		internal async Task Exit()
		{
			List<Task> list = new List<Task>();
			foreach (KeyValuePair<World, SessionData> worldDatum in worldData)
			{
				list.Add(worldDatum.Value.Remove());
			}
			list.Add(ProcessPublicAnnoucements());
			await Task.WhenAll(list).ConfigureAwait(continueOnCapturedContext: false);
		}

		internal void SchedulePublicAnnoucement(SessionInfo info)
		{
			sessionsToPublicAnnounce.Add(info);
		}

		internal void SchedulePublicAnnoucementRemoval(string sessionId)
		{
			sessionsToPublicRemove.Add(sessionId);
		}

		internal void Dispose()
		{
			LAN_Announcer.Dispose();
		}
	}
	public class VisitTracker
	{
		private object lockobj = new object();

		private Dictionary<World, Visit> trackedWorlds = new Dictionary<World, Visit>();

		private Visit currentVisit;

		private DateTime currentFocusTime;

		public Engine Engine { get; private set; }

		public EngineSkyFrostInterface Cloud => Engine.Cloud;

		public LocalDB DB => Engine.LocalDB;

		public VisitTracker(Engine engine)
		{
			Engine = engine;
			engine.WorldManager.WorldFocused += WorldManager_WorldFocused;
			engine.WorldManager.WorldRemoved += WorldManager_WorldRemoved;
			engine.OnShutdown += Engine_OnShutdown;
		}

		private void Engine_OnShutdown()
		{
			lock (lockobj)
			{
				EndCurrentFocus();
				foreach (KeyValuePair<World, Visit> trackedWorld in trackedWorlds)
				{
					Engine.RegisterShutdownTask(EndVisit(trackedWorld.Value));
				}
				trackedWorlds.Clear();
			}
		}

		private void WorldManager_WorldFocused(World world)
		{
			lock (lockobj)
			{
				EndCurrentFocus();
				if (!ShouldTrack(world))
				{
					return;
				}
				if (!trackedWorlds.TryGetValue(world, out Visit visit))
				{
					visit = new Visit();
					visit.URL = world.RecordURL.ToString();
					visit.UserId = Cloud.Session.CurrentUserID ?? Engine.LocalDB.MachineID;
					visit.RecordVersion = world.CorrespondingRecord.Version.GlobalVersion;
					visit.Start = DateTime.UtcNow;
					Task.Run(async delegate
					{
						try
						{
							await DB.LogVisitAsync(visit.URL, visit.RecordVersion).ConfigureAwait(continueOnCapturedContext: false);
						}
						catch (Exception value)
						{
							UniLog.Error($"Exception logging visit {visit.URL}:\n{value}", stackTrace: false);
						}
					});
					trackedWorlds.Add(world, visit);
				}
				currentFocusTime = DateTime.Now;
				currentVisit = visit;
			}
		}

		private void WorldManager_WorldRemoved(World world)
		{
			lock (lockobj)
			{
				if (trackedWorlds.TryGetValue(world, out Visit visit))
				{
					if (visit == currentVisit)
					{
						EndCurrentFocus();
					}
					Task.Run(async () => await EndVisit(visit));
					trackedWorlds.Remove(world);
				}
			}
		}

		private bool ShouldTrack(World world)
		{
			if (world?.CorrespondingRecord == null)
			{
				return false;
			}
			OwnerType ownerType = IdUtil.GetOwnerType(world.CorrespondingRecord.OwnerId);
			if (ownerType != OwnerType.User)
			{
				return ownerType == OwnerType.Group;
			}
			return true;
		}

		private Task<CloudResult> EndVisit(Visit visit)
		{
			visit.End = DateTime.UtcNow;
			return Cloud.Visits.LogVisit(visit);
		}

		private void EndCurrentFocus()
		{
			if (currentVisit != null)
			{
				currentVisit.Duration += (long)(DateTime.Now - currentFocusTime).TotalSeconds;
				currentVisit = null;
			}
		}
	}
