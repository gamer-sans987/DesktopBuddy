				while (!cancellationToken.IsCancellationRequested);
				Func<Task> val;
				while (!cancellationToken.IsCancellationRequested && recordsToSync.Count == 0 && variantsToSync.TryDequeue(out val))
				{
					uploadingVariant = true;
					await val();
					uploadingVariant = false;
				}
				await Task.Delay(TimeSpan.FromSeconds(1L), cancellationToken);
			}
		}

		internal void ScheduleVariantUpload(Func<Task> task)
		{
			variantsToSync.Enqueue(task);
		}

		private bool ShouldSync(FrooxEngine.Store.Record record)
		{
			if (!(record.OwnerId == Cloud.Session.CurrentUserID))
			{
				return record.Version.LastModifyingUserId == Cloud.Session.CurrentUserID;
			}
			return true;
		}

		private void Cloud_SessionChanged(UserSession session)
		{
			if (!(session?.UserId != lastUserId))
			{
				return;
			}
			if (currentCancelationToken != null)
			{
				currentCancelationToken.Cancel();
				_currentUploadTasks.Clear();
				currentCancelationToken = null;
				recordsToSync.Clear();
			}
			currentCancelationToken = new CancellationTokenSource();
			loadedGroupRecords.Clear();
			if (session != null)
			{
				LoadUnsyncedRecords(session.UserId);
				Engine.GlobalCoroutineManager.StartTask(async delegate
				{
					await SyncRecords(currentCancelationToken.Token).ConfigureAwait(continueOnCapturedContext: false);
				});
			}
			lastUserId = session?.UserId;
		}

		private void Cloud_GroupUpdated(Group obj)
		{
			if (obj != null && !loadedGroupRecords.Contains(obj.GroupId))
			{
				loadedGroupRecords.Add(obj.GroupId);
				LoadUnsyncedRecords(obj.GroupId);
			}
		}

		private void LoadUnsyncedRecords(string ownerId)
		{
			Task.Run(async delegate
			{
				foreach (FrooxEngine.Store.Record record in await DB.FetchRecordsAsync((FrooxEngine.Store.Record r) => r.OwnerId == ownerId && !r.IsSynced))
				{
					if (!recordsToSync.Any((EngineRecordUploadTask task) => task.Record.IsSameRecord(record)))
					{
						UniLog.Log("Loaded unsynced record:\n" + JsonConvert.SerializeObject(record));
						EngineRecordUploadTask val = new EngineRecordUploadTask(Engine, record)
						{
							ForceConflictSync = ForceConflictSync
						};
						recordsToSync.Enqueue(val);
					}
				}
			});
		}

		public async Task<CloudResult<FrooxEngine.Store.Record>> FetchRecord(Uri linkUrl, TimeSpan? maxCachedAge = null)
		{
			if (!Cloud.Records.ExtractRecordID(linkUrl, out var ownerId, out var recordId))
			{
				if (!Cloud.Records.ExtractRecordPath(linkUrl, out ownerId, out var recordPath))
				{
					throw new ArgumentException("Not a valid record URL: " + linkUrl);
				}
				if (!recordPathTranslationCache.TryGetValue(linkUrl, out RecordId value))
				{
					CloudResult<FrooxEngine.Store.Record> cloudResult = await Cloud.Records.GetRecordAtPath<FrooxEngine.Store.Record>(ownerId, recordPath).ConfigureAwait(continueOnCapturedContext: false);
					UniLog.Log($"Fetched record at path {linkUrl}: {cloudResult?.Entity}");
					if (!cloudResult.IsOK)
					{
						return cloudResult;
					}
					value = new RecordId(cloudResult.Entity.OwnerId, cloudResult.Entity.RecordId);
					recordPathTranslationCache.TryAdd(linkUrl, value);
				}
				else
				{
					UniLog.Log($"Fetched cached recordId at path {linkUrl}: {value}");
				}
				ownerId = value.OwnerId;
				recordId = value.Id;
			}
			return await FetchRecord(ownerId, recordId, maxCachedAge).ConfigureAwait(continueOnCapturedContext: false);
		}

		public Task<CloudResult<FrooxEngine.Store.Record>> FetchRecord(string ownerId, string recordId, TimeSpan? maxCachedAge = null)
		{
			return Task.Run(async () => await FetchRecordIntern(ownerId, recordId, maxCachedAge).ConfigureAwait(continueOnCapturedContext: false));
		}

		private async Task<CloudResult<FrooxEngine.Store.Record>> FetchRecordIntern(string ownerId, string recordId, TimeSpan? maxCachedAge = null)
		{
			FrooxEngine.Store.Record localRecord = await DB.TryFetchRecordAsync(ownerId, recordId).ConfigureAwait(continueOnCapturedContext: false);
			bool flag = IdUtil.GetOwnerType(ownerId) != OwnerType.Machine;
			if (localRecord != null && flag && maxCachedAge.HasValue)
			{
				flag = DateTime.UtcNow - localRecord.FetchedOn > maxCachedAge.Value;
			}
			if (flag)
			{
				CloudResult<FrooxEngine.Store.Record> cloudResult = await Cloud.Records.GetRecord<FrooxEngine.Store.Record>(ownerId, recordId).ConfigureAwait(continueOnCapturedContext: false);
				if (!cloudResult.IsOK && cloudResult.State != HttpStatusCode.NotFound)
				{
					return cloudResult;
				}
				FrooxEngine.Store.Record entity = cloudResult.Entity;
				if (entity != null)
				{
					entity.FetchedOn = DateTime.UtcNow;
					entity.IsSynced = true;
				}
				if (localRecord != null && !localRecord.IsSynced)
				{
					if (entity != null && entity.Version.GlobalVersion != localRecord.Version.GlobalVersion)
					{
						UniLog.Log($"Conflicting cloud record version! Local: {localRecord.Version.GlobalVersion}, Global: {entity.Version.GlobalVersion}");
						localRecord.ConflictingCloudVersion = entity;
						return new CloudResult<FrooxEngine.Store.Record>(localRecord, HttpStatusCode.Conflict, null, 1, "Conflicting cloud version");
					}
					localRecord.FetchedOn = DateTime.UtcNow;
					if (!(await DB.StoreRecordAsync(localRecord).ConfigureAwait(continueOnCapturedContext: false)))
					{
						UniLog.Log("Couldn't store local record with updated fetch time");
					}
					return new CloudResult<FrooxEngine.Store.Record>(localRecord, HttpStatusCode.OK, null, 1);
				}
				if (entity != null && !(await DB.StoreRecordAsync(entity, (FrooxEngine.Store.Record r) => r.IsSynced).ConfigureAwait(continueOnCapturedContext: false)))
				{
					UniLog.Log("Couldn't store new cloud record");
				}
				return cloudResult;
			}
			return new CloudResult<FrooxEngine.Store.Record>(localRecord, (localRecord == null) ? HttpStatusCode.NotFound : HttpStatusCode.OK, null, 0);
		}

		public async Task<RecordSaveResult> SaveRecord(FrooxEngine.Store.Record record, SavedGraph loadedGraph = null)
		{
			if (!record.IsValidOwnerId)
			{
				throw new Exception("Invalid OwnerId");
			}
			if (!record.IsValidRecordId)
			{
				throw new Exception("Invalid RecordId");
			}
			record.IsSynced = false;
			record.IncrementLocalVersion(Engine.LocalDB.MachineID, Cloud.Session.CurrentUserID);
			if (!record.CreationTime.HasValue)
			{
				record.CreationTime = DateTime.UtcNow;
			}
			record.LastModificationTime = DateTime.UtcNow;
			bool flag = await DB.StoreRecordAsync(record, delegate(FrooxEngine.Store.Record oldRec)
			{
				bool num = record.CanOverwrite(oldRec);
				if (!num)
				{
					UniLog.Warning($"Conflict. Old Record:\n\n{JsonConvert.SerializeObject(oldRec)}\n\nNew Record:\n\n{JsonConvert.SerializeObject(record)}");
				}
				return num;
			}).ConfigureAwait(continueOnCapturedContext: false);
			EngineRecordUploadTask engineRecordUploadTask = null;
			if (flag)
			{
				OwnerType ownerType = IdUtil.GetOwnerType(record.OwnerId);
				if (ownerType == OwnerType.User || ownerType == OwnerType.Group)
				{
					engineRecordUploadTask = new EngineRecordUploadTask(Engine, record, loadedGraph);
					recordsToSync.Enqueue(engineRecordUploadTask);
				}
				World world = Engine.WorldManager.GetWorld(record);
				if (world != null)
				{
					world.CorrespondingRecord = record;
				}
				try
				{
					this.RecordSaved?.Invoke(record);
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception running RecordSaved event\n{value}");
				}
			}
			return new RecordSaveResult(flag, engineRecordUploadTask);
		}

		public async Task ModifyRecord(Uri url, Func<FrooxEngine.Store.Record, bool> modifyFunc)
		{
			Cloud.Records.ExtractRecordID(url, out var ownerId, out var recId);
			World world = Engine.WorldManager.Worlds.FirstOrDefault((World w) => w.CorrespondingRecord != null && w.CorrespondingRecord.OwnerId == ownerId && w.CorrespondingRecord.RecordId == recId);
			if (world != null)
			{
				if (modifyFunc(world.CorrespondingRecord))
				{
					SaveRecord(world.CorrespondingRecord);
				}
				return;
			}
			CloudResult<FrooxEngine.Store.Record> cloudResult = await FetchRecord(ownerId, recId).ConfigureAwait(continueOnCapturedContext: false);
			if (cloudResult.IsOK && modifyFunc(cloudResult.Entity))
			{
				SaveRecord(cloudResult.Entity);
			}
		}

		public void DeleteRecord(Uri recordUri)
		{
			if (Cloud.Records.ExtractRecordID(recordUri, out var ownerId, out var recordId))
