	public class PriorityQueue<T> : IEnumerable<T>, IEnumerable where T : class, IPriorityItem
	{
		private List<T> queue = new List<T>();

		public int Count => queue.Count;

		public event Action OnNewElements;

		public void Enqeue(T item)
		{
			queue.Add(item);
			this.OnNewElements?.Invoke();
		}

		public IEnumerator<T> GetEnumerator()
		{
			return queue.GetEnumerator();
		}

		IEnumerator IEnumerable.GetEnumerator()
		{
			return queue.GetEnumerator();
		}

		public T Dequeue()
		{
			T val = null;
			foreach (T item in queue)
			{
				if (val == null)
				{
					val = item;
				}
				else if (val.Priority < item.Priority)
				{
					val = item;
				}
			}
			if (val != null)
			{
				queue.Remove(val);
			}
			return val;
		}
	}
	public class PriorityStack<T> : IEnumerable<T>, IEnumerable where T : class, IPriorityItem
	{
		private List<T> stack = new List<T>();

		public int Count => stack.Count;

		public event Action OnNewElements;

		public void Push(T item)
		{
			stack.Add(item);
			this.OnNewElements?.Invoke();
		}

		public T Pop()
		{
			T val = null;
			for (int num = stack.Count - 1; num >= 0; num--)
			{
				T val2 = stack[num];
				if (val == null)
				{
					val = val2;
				}
				else if (val.Priority < val2.Priority)
				{
					val = val2;
				}
			}
			if (val != null)
			{
				stack.Remove(val);
			}
			return val;
		}

		public IEnumerator<T> GetEnumerator()
		{
			return stack.GetEnumerator();
		}

