		[SyncMethod(typeof(Delegate), null)]
		private void ExportPressed(IButton button, ButtonEventData eventData)
		{
			if (_safeUser != base.LocalUser || !ValidOptionSelected)
			{
				return;
			}
			string targetString = ExportName.Target.TargetString;
			if (!ValidName(targetString))
			{
				return;
			}
			ExportOption option = SelectedOption;
			IExportable target = option.Exportable.Target;
			if (!base.World.CanSaveItems())
			{
				return;
			}
			foreach (Slot exportRoot in target.ExportRoots)
			{
				if (!exportRoot.ForeachComponentInChildren((IItemPermissions p) => p.CanSave))
				{
					return;
				}
			}
			EditEnabled.Value = false;
			_cancel.Target.Enabled = false;
			_export.Target.Enabled = false;
			_export.Target.LabelText = this.GetLocalized("Exporter.Exporting");
			StartTask(async delegate
			{
				bool error = false;
				try
				{
					if (!(await option.Exportable.Target.Export(_targetFolder, ExportName.Target.TargetString.Trim(), option.ExportType)))
					{
						error = true;
					}
				}
				catch (Exception exception)
				{
					UniLog.Error("Exception when exporting:\n" + DebugManager.PreprocessException(exception));
					error = true;
				}
				ExportFinished?.Invoke(this);
				_export.Target.LabelText = (error ? "Error! Check log." : "Done!");
				_export.Target.BaseColor.Value = (error ? Elements.Core.colorX.Red : Elements.Core.colorX.Green);
				await Task.Delay(TimeSpan.FromSeconds(error ? 10 : 2));
				await default(ToWorld);
				base.Slot.Destroy();
			});
		}

