		public void ConnectionClosed(IConnection connection)
		{
			lock (transferManagerLock)
			{
				List<JobID> list = new List<JobID>();
				foreach (KeyValuePair<JobID, FileTransmitJob> transmitJob in transmitJobs)
				{
					if (transmitJob.Value.Target == connection)
					{
						transmitJob.Value.Cancel();
						list.Add(transmitJob.Key);
					}
				}
				foreach (JobID item in list)
				{
					transmitJobs.Remove(item);
				}
				list.Clear();
				foreach (KeyValuePair<JobID, FileReceiveJob> receiveJob in receiveJobs)
				{
					if (receiveJob.Value.Source == connection)
					{
						receiveJob.Value.Cancel();
						list.Add(receiveJob.Key);
						assetRequests[receiveJob.Value.AssetURL].onGathered(receiveJob.Value.AssetURL, null, "Connection Closed");
						assetRequests.Remove(receiveJob.Value.AssetURL);
					}
				}
				foreach (JobID item2 in list)
				{
					receiveJobs.Remove(item2);
				}
				transmitJobsToInitialize.RemoveAll((FileTransmitJob job) => job.Target == connection);
				connectionIndexes.Remove(connection);
				RefreshJobs();
			}
		}

