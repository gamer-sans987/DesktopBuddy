		private async Task TestProxy(ProxyConfig config, WebProxy proxy)
		{
			if (config.Required)
			{
				config.Test = true;
			}
			if (!config.Test)
			{
				return;
			}
			UniLog.Log($"Testing HTTP Proxy for SkyFrost: {config.Address}...");
			bool flag;
			try
			{
				flag = await WebProxyUtility.TestProxy(proxy, base.Platform);
			}
			catch (Exception ex)
			{
				UniLog.Error("SkyFrost proxy test failed due to: " + ex, stackTrace: false);
				flag = false;
			}
			if (flag)
			{
				UniLog.Log("SkyFrost Proxy test success!");
				return;
			}
			UniLog.Warning("SkyFrost proxy test failed.");
			if (!config.Required)
			{
				return;
			}
			throw new FrooxEngineInitializationException("The SkyFrost proxy test failed and the proxy is marked as required.", "Proxy_Support#SkyFrost_WebProxy_test_failed");
		}

		private async Task Intialize(SkyFrostConfig config)
		{
			if (Initialized)
