			public Dictionary<string, Slot> TryGetBoneMapping(StaticMesh mesh)
			{
				if (boneMappings.TryGetValue(mesh, out Dictionary<string, Slot> value))
				{
					return value;
				}
				if (rawBoneMappings.TryGetValue(mesh, out Dictionary<string, Assimp.Node> value2))
				{
					value = new Dictionary<string, Slot>();
					foreach (KeyValuePair<string, Assimp.Node> item in value2)
					{
						value.Add(item.Key, nodeMappings[item.Value]);
					}
					boneMappings.Add(mesh, value);
				}
				return value;
			}

			public IAssetProvider<Material> GetVertexColorVariant(IAssetProvider<Material> material)
			{
				if (vertexColorVariants.TryGetValue(material, out IAssetProvider<Material> value))
				{
					return value;
				}
				if (material is PBS_Metallic)
				{
					value = material.Slot.AttachComponent<PBS_VertexColorMetallic>();
					((Component)value).CopyProperties((Component)material);
				}
				else if (material is PBS_Specular)
				{
					value = material.Slot.AttachComponent<PBS_VertexColorSpecular>();
					((Component)value).CopyProperties((Component)material);
				}
				else if (material is UnlitMaterial)
				{
					((UnlitMaterial)material).UseVertexColors.Value = true;
					value = material;
				}
				else
				{
					UniLog.Warning("Cannot convert material into VertexColored: " + material.GetType());
					value = material;
				}
				vertexColorVariants.Add(material, value);
				return value;
			}

