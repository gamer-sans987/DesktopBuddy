			Viseme.E => E, 
			Viseme.ih => ih, 
			Viseme.oh => oh, 
			Viseme.ou => ou, 
			Viseme.Laughter => LaughterProbability, 
			_ => null, 
		};

		protected override void OnAwake()
		{
			base.OnAwake();
			analysis = new float[16];
			Smoothing.Value = 0.7f;
			_onAnalyzed = OnAnalyzed;
		}

		protected override void OnDispose()
		{
			DisposeAnalysisEngine();
			_currentAudioStream = null;
			base.OnDispose();
		}

		private void DisposeAnalysisEngine()
		{
			ovrContext?.Dispose();
			ovrContext = null;
			openLipSyncContext?.Dispose();
			openLipSyncContext = null;
			currentEngine = null;
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			IAudioStream audioStream = Source.Target as IAudioStream;
			if (_currentAudioStream != audioStream)
			{
				if (audioStream == null)
				{
					RemoteSource.Target = null;
				}
				else if (audioStream.IsOwnedByLocalUser)
				{
					RemoteSource.Target = base.LocalUser.GetStreamOrAdd($"Visemes.{audioStream.ReferenceID}", delegate(MultiValueStream<float> s)
					{
						s.SetUpdatePeriod(0u, 0u);
						s.Encoding = ValueEncoding.Quantized;
						s.FullFrameBits = 6;
						s.FullFrameMin = 0f;
						s.FullFrameMax = 1f;
						s.Count = 16;
					});
				}
				_currentAudioStream = audioStream;
			}
			_hasRemoteSource = !(RemoteSource.Target?.IsOwnedByLocalUser ?? true);
		}

		protected override void OnCommonUpdate()
		{
			MultiValueStream<float> target = RemoteSource.Target;
			if (target != null)
			{
				if (!target.IsOwnedByLocalUser)
				{
					if (target.HasValidData)
					{
						for (int i = 0; i < 16; i++)
						{
							this[(Viseme)i].Value = target[i];
						}
					}
					return;
				}
				for (int j = 0; j < 16; j++)
				{
					target[j] = analysis[j];
				}
			}
			for (int k = 0; k < analysis.Length; k++)
			{
				this[(Viseme)k].Value = analysis[k];
			}
		}

		protected override void OnAudioUpdate()
		{
			if (!base.Enabled)
			{
				Array.Clear(analysis, 0, analysis.Length);
			}
			else
			{
				if (_hasRemoteSource || _analysisRunning)
				{
					return;
				}
				_analysisRunning = true;
				IWorldAudioDataSource target = Source.Target;
				if (target != null)
				{
					int simulationFrameSize = base.Engine.AudioSystem.SimulationFrameSize;
					buffer = buffer.EnsureExactSize(simulationFrameSize);
					target.Read(buffer.AsMonoBuffer(), base.Audio.Simulator);
					VisemeAnalyzerEngine visemeAnalyzerEngine = PreferredAnalyzer.Value;
					if (visemeAnalyzerEngine == VisemeAnalyzerEngine.OVRLipSync && !base.AudioSystem.OVRLipSync.IsInitialized)
					{
						visemeAnalyzerEngine = VisemeAnalyzerEngine.OpenLipSync;
					}
					if (visemeAnalyzerEngine != currentEngine)
					{
						DisposeAnalysisEngine();
						currentEngine = visemeAnalyzerEngine;
						switch (visemeAnalyzerEngine)
						{
						case VisemeAnalyzerEngine.OVRLipSync:
							ovrContext = new OVRLipSyncContext(base.AudioSystem.OVRLipSync);
							break;
						case VisemeAnalyzerEngine.OpenLipSync:
							openLipSyncContext = new OpenLipSyncContext(base.AudioSystem.SampleRate, base.AudioSystem.SimulationFrameSize);
							break;
						}
					}
					switch (currentEngine)
					{
					case VisemeAnalyzerEngine.OVRLipSync:
						ovrContext.Update(Smoothing);
						ovrContext.Analyze(buffer, analysis, _onAnalyzed);
						break;
					case VisemeAnalyzerEngine.OpenLipSync:
						openLipSyncContext.Update(Smoothing);
						openLipSyncContext.Analyze(buffer, analysis);
						_onAnalyzed();
						break;
					default:
						Array.Clear(analysis, 0, analysis.Length);
						OnAnalyzed();
						break;
					}
				}
				else
				{
					Array.Clear(analysis, 0, analysis.Length);
					_analysisRunning = false;
				}
			}
		}

		private void OnAnalyzed()
		{
			MultiValueStream<float> target = RemoteSource.Target;
			if (target != null && target.IsOwnedByLocalUser)
			{
				target.ForceUpdate();
			}
			_analysisRunning = false;
		}

