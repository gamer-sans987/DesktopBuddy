	public static class ModelExporter
	{
		private struct MeshMatPair
		{
			public readonly IAssetProvider<Mesh> mesh;

			public readonly IAssetProvider<Material> material;

			public MeshMatPair(IAssetProvider<Mesh> mesh, IAssetProvider<Material> material)
			{
				this.mesh = mesh;
				this.material = material;
			}
		}

		private class ExportData
		{
			public readonly Scene scene;

			public readonly Slot root;

			public readonly Predicate<Component> filter;

			public readonly string exportPath;

			private List<MeshMatPair> meshes = new List<MeshMatPair>();

			private List<IAssetProvider<Material>> materials = new List<IAssetProvider<Material>>();

			private Dictionary<IAssetProvider<ITexture2D>, string> textures = new Dictionary<IAssetProvider<ITexture2D>, string>();

			private HashSet<string> filePaths = new HashSet<string>();

			private List<Task> processingTasks = new List<Task>();

			private Engine Engine => root.Engine;

			private Task EnqueueAssetJob<T>(T asset, Action<T> action) where T : class, IAsset
			{
				Task task = Task.Run(async delegate
				{
					object _lock = new object();
					await asset.RequestReadLock(_lock);
					action(asset);
					asset.ReleaseReadLock(_lock);
				});
				processingTasks.Add(task);
				return task;
			}

			public ExportData(Scene scene, Slot root, string exportPath, Predicate<Component> filter)
			{
				this.scene = scene;
				this.root = root;
				this.exportPath = exportPath;
				this.filter = filter;
				Directory.CreateDirectory(Path.Combine(exportPath, "textures"));
			}

			public int GenerateMeshIndex(IAssetProvider<Mesh> mesh, IAssetProvider<Material> material, int materialIndex)
			{
				MeshMatPair item = new MeshMatPair(mesh, material);
				int num = meshes.IndexOf(item);
				if (num < 0)
				{
					meshes.Add(item);
					num = meshes.Count - 1;
					Assimp.Mesh assimpMesh = new Assimp.Mesh();
					assimpMesh.MaterialIndex = GenerateMaterialIndex(material);
					EnqueueAssetJob(mesh.Asset, delegate
					{
						ProcessMesh(assimpMesh, mesh.Asset, materialIndex);
					});
					scene.Meshes.Add(assimpMesh);
				}
				return num;
			}

			private int GenerateMaterialIndex(IAssetProvider<Material> material)
			{
				int num = materials.IndexOf(material);
				if (num < 0)
				{
					materials.Add(material);
					num = materials.Count - 1;
					Assimp.Material item = ProcessMaterial(material, this);
					scene.Materials.Add(item);
				}
				return num;
			}

			public string GenerateTexturePath(IAssetProvider<ITexture2D> tex2D, string name)
			{
				if (!textures.TryGetValue(tex2D, out string path))
				{
					StaticTexture2D staticTex = tex2D as StaticTexture2D;
					if (staticTex != null)
					{
						if (staticTex.URL.Value != null)
						{
							path = GetUniqueFilePath("textures", tex2D.Slot.Name + "_" + name, ".png");
							processingTasks.Add(Task.Run(async delegate
							{
								TextureEncoder.ConvertToPNG(await Engine.AssetManager.GatherAssetFile(staticTex.URL.Value, 100f), Path.Combine(exportPath, path));
							}));
						}
						else
						{
							path = null;
						}
					}
					else
					{
						Texture2D texture2D = tex2D.Asset as Texture2D;
						Bitmap2D bitmap2D = texture2D?.Data;
						if (bitmap2D == null)
						{
							path = null;
						}
						else
						{
							path = GetUniqueFilePath("textures", tex2D.Slot.Name, ".png");
							EnqueueAssetJob(texture2D, delegate
							{
								bitmap2D.Save(Path.Combine(exportPath, path));
							});
						}
					}
					textures.Add(tex2D, path);
				}
				return path;
			}

			public string GetUniqueFilePath(string path, string baseName, string extension)
			{
				char[] invalidFileNameChars = Path.GetInvalidFileNameChars();
				foreach (char value in invalidFileNameChars)
				{
					if (baseName.Contains(value))
					{
						baseName = "texture";
						break;
					}
				}
				string fileNameWithoutExtension = Path.GetFileNameWithoutExtension(baseName);
				int num = 0;
				string text2;
				do
				{
					string text = fileNameWithoutExtension;
					if (num > 0)
					{
						text = text + "_" + num.ToString("D4");
					}
					text += extension;
					text2 = Path.Combine(path, text);
					num++;
				}
				while (filePaths.Contains(text2));
				filePaths.Add(text2);
				return text2;
			}

			public Elements.Core.float3 GlobalPositionInScene(Slot slot)
			{
				return root.GlobalPointToLocal(slot.GlobalPosition);
			}

			public Elements.Core.floatQ GlobalRotationInScene(Slot slot)
			{
				return root.GlobalRotationToLocal(slot.GlobalRotation);
			}

			public async Task AwaitAll()
			{
				await Task.WhenAll(processingTasks);
			}
		}

		private static string GetFormatId(string extension)
		{
			return extension switch
			{
				"dae" => "collada", 
				"obj" => "obj", 
				"x" => "x", 
				"stl" => "stlb", 
				"ply" => "ply", 
				"glb" => "glb", 
				"3ds" => "3ds", 
				"assbin" => "assbin", 
				"assxml" => "assxml", 
				"fbx" => "fbx", 
				"gltf" => "gltf2", 
				_ => null, 
			};
		}

		public static async Task<bool> ExportModel(Slot slot, string targetFile, Predicate<Component> filter = null)
		{
			string text = Path.GetExtension(targetFile).Substring(1).ToLower();
			using AssimpContext context = new AssimpContext();
			string formatId = GetFormatId(text);
			if (formatId == null)
			{
				StringBuilder stringBuilder = new StringBuilder();
				ExportFormatDescription[] supportedExportFormats = context.GetSupportedExportFormats();
				foreach (ExportFormatDescription exportFormatDescription in supportedExportFormats)
				{
					StringBuilder stringBuilder2 = stringBuilder;
					StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(18, 3, stringBuilder2);
					handler.AppendLiteral("\tID: ");
					handler.AppendFormatted(exportFormatDescription.FormatId);
					handler.AppendLiteral("\tExt: ");
					handler.AppendFormatted(exportFormatDescription.FileExtension);
					handler.AppendLiteral("\tInfo: ");
					handler.AppendFormatted(exportFormatDescription.Description);
					stringBuilder2.AppendLine(ref handler);
				}
				UniLog.Error("Unsupported export format: " + text + ", supported formats: \n" + stringBuilder);
				return false;
			}
			UniLog.Log("Starting export in format: " + formatId);
			string directoryName = Path.GetDirectoryName(targetFile);
			Directory.CreateDirectory(directoryName);
			Scene scene = new Scene();
			ExportData exportData = new ExportData(scene, slot, directoryName, filter);
			scene.RootNode = GenerateNode(slot, exportData);
			UniLog.Log("Graph processed, waiting for mesh and texture tasks to finish");
			await exportData.AwaitAll();
			await default(ToBackground);
			UniLog.Log("Textures and meshes processing finished, saving scene");
			bool result = context.ExportFile(scene, targetFile, formatId, PostProcessSteps.MakeLeftHanded | PostProcessSteps.ValidateDataStructure | PostProcessSteps.FlipWindingOrder);
			UniLog.Log("Finished export, success: " + result);
			return result;
		}

		private static Assimp.Node GenerateNode(Slot slot, ExportData data)
		{
			Assimp.Node node = new Assimp.Node(slot.Name);
			node.Transform = slot.TRS.ToAssimp();
			foreach (Component component in slot.Components)
			{
				if (component.Enabled)
				{
					if (component is MeshRenderer)
					{
						ProcessMeshRenderer((MeshRenderer)component, node, data);
					}
					if (component is Light)
					{
						ProcessLight((Light)component, slot, node, data);
					}
				}
			}
			foreach (Slot child in slot.Children)
			{
				if (child.IsActive)
				{
					node.Children.Add(GenerateNode(child, data));
				}
			}
			return node;
		}

		private static void ProcessMeshRenderer(MeshRenderer meshRenderer, Assimp.Node node, ExportData data)
		{
			if (data.filter != null && !data.filter(meshRenderer))
			{
				return;
			}
			int num = 0;
			foreach (IAssetProvider<Material> material2 in meshRenderer.Materials)
			{
				IAssetProvider<Mesh> target = meshRenderer.Mesh.Target;
				IAssetProvider<Material> material = material2;
				if (target?.Asset?.Data != null)
				{
					node.MeshIndices.Add(data.GenerateMeshIndex(target, material, num));
					num++;
				}
			}
		}

		private static Assimp.Material ProcessMaterial(IAssetProvider<Material> material, ExportData data)
		{
			Assimp.Material material2 = ((material is IPBS_Material pbs) ? ProcessPBS_Material(pbs, data) : ((material is UnlitMaterial unlit) ? ProcessUnlitMaterial(unlit, data) : ((!(material is ICommonMaterial common)) ? new Assimp.Material() : ProcessCommonMaterial(common, data))));
			material2.Name = material?.Slot.Name ?? "(null)";
			return material2;
		}

		private static Assimp.Material ProcessPBS_Material(IPBS_Material pbs, ExportData data)
		{
			Assimp.Material material = new Assimp.Material();
			material.ColorDiffuse = pbs.AlbedoColor.ToAssimp();
			material.ColorEmissive = pbs.EmissiveColor.ToAssimp();
			ProcessTexture(pbs.AlbedoTexture, material, Assimp.TextureType.Diffuse, data, "Albedo");
			ProcessTexture(pbs.EmissiveMap, material, Assimp.TextureType.Emissive, data, "Emissive");
			ProcessTexture(pbs.NormalMap, material, Assimp.TextureType.Normals, data, "Normal");
			ProcessTexture(pbs.OcclusionMap, material, Assimp.TextureType.Ambient, data, "AO");
			if (pbs is PBS_Material pBS_Material)
			{
				ProcessTexture(pBS_Material.HeightMap.Target, material, Assimp.TextureType.Height, data, "Height");
			}
			if (pbs is IPBS_Specular iPBS_Specular)
			{
				material.ColorSpecular = iPBS_Specular.SpecularColor.ToAssimp();
				ProcessTexture(iPBS_Specular.SpecularMap, material, Assimp.TextureType.Specular, data, "SpecularSmoothness");
			}
			if (pbs is IPBS_Metallic iPBS_Metallic)
			{
				material.Shininess = iPBS_Metallic.Metallic;
				ProcessTexture(iPBS_Metallic.MetallicMap, material, Assimp.TextureType.Shininess, data, "MetallicSmoothness");
			}
			return material;
		}

		private static Assimp.Material ProcessUnlitMaterial(UnlitMaterial unlit, ExportData data)
		{
			Assimp.Material material = new Assimp.Material();
			material.ColorDiffuse = Elements.Core.colorX.Black.ToAssimp();
			material.ColorEmissive = unlit.TintColor.Value.ToAssimp();
			ProcessTexture(unlit.Texture.Target, material, Assimp.TextureType.Emissive, data, "Color");
			if (unlit.BlendMode.Value == BlendMode.Additive)
			{
				material.BlendMode = Assimp.BlendMode.Additive;
			}
			return material;
		}

		private static Assimp.Material ProcessCommonMaterial(ICommonMaterial common, ExportData data)
		{
			Assimp.Material material = new Assimp.Material();
			material.ColorDiffuse = common.Color.ToAssimp();
			ProcessTexture(common.MainTexture, material, Assimp.TextureType.Diffuse, data, "Color");
			ProcessTexture(common.NormalMap, material, Assimp.TextureType.Normals, data, "Normal");
			if (common is IBlendModeMaterial { BlendMode: BlendMode.Additive })
			{
				material.BlendMode = Assimp.BlendMode.Additive;
			}
			return material;
		}

		private static void ProcessTexture(IAssetProvider<ITexture2D> textureProvider, Assimp.Material material, Assimp.TextureType type, ExportData data, string name)
		{
			if (textureProvider != null)
			{
				TextureSlot texture = new TextureSlot
				{
					FilePath = data.GenerateTexturePath(textureProvider, name)
				};
				if (texture.FilePath != null)
				{
					texture.TextureType = type;
					texture.Mapping = Assimp.TextureMapping.FromUV;
					texture.WrapModeU = Assimp.TextureWrapMode.Wrap;
					texture.WrapModeV = Assimp.TextureWrapMode.Wrap;
					material.AddMaterialTexture(in texture);
				}
			}
		}

		private static void ProcessMesh(Assimp.Mesh assimpMesh, Mesh engineMesh, int materialIndex)
		{
			MeshX data = engineMesh.Data;
			for (int i = 0; i < MathX.Min(data.UV_ChannelCount, assimpMesh.UVComponentCount.Length); i++)
			{
				assimpMesh.UVComponentCount[i] = data.GetUV_Dimension(i);
			}
			for (int j = 0; j < data.VertexCount; j++)
			{
				Elements.Assets.Vertex vertex = data.GetVertex(j);
				assimpMesh.Vertices.Add(Filter(vertex.Position).ToAssimp());
				if (data.HasNormals)
				{
					assimpMesh.Normals.Add(Filter(vertex.Normal).ToAssimp());
				}
				if (data.HasTangents)
				{
					assimpMesh.Tangents.Add(Filter(vertex.Tangent).ToAssimp());
				}
				if (data.HasColors)
				{
					assimpMesh.VertexColorChannels[0].Add(vertex.Color.ToAssimp());
				}
				for (int k = 0; k < data.UV_ChannelCount; k++)
				{
					if (data.GetUV_Dimension(k) != 0)
					{
						assimpMesh.TextureCoordinateChannels[k].Add(Filter(vertex.GetUV_Auto(k)).xyz.ToAssimp());
					}
				}
			}
			if (data.SubmeshCount <= 0 || materialIndex >= data.SubmeshCount)
			{
				return;
			}
			Elements.Assets.Submesh submesh = data.GetSubmesh(materialIndex);
			Elements.Assets.TriangleSubmesh triangleSubmesh = submesh as Elements.Assets.TriangleSubmesh;
			Elements.Assets.PointSubmesh pointSubmesh = submesh as Elements.Assets.PointSubmesh;
			if (triangleSubmesh != null)
			{
				for (int l = 0; l < triangleSubmesh.Count; l++)
				{
					Elements.Assets.Triangle triangle = triangleSubmesh.GetTriangle(l);
					Face face = new Face();
					face.Indices.Add(triangle.Vertex0Index);
					face.Indices.Add(triangle.Vertex1Index);
					face.Indices.Add(triangle.Vertex2Index);
					assimpMesh.Faces.Add(face);
				}
			}
			else if (pointSubmesh != null)
			{
				for (int m = 0; m < pointSubmesh.Count; m++)
				{
					Point point = pointSubmesh.GetPoint(m);
					Face face2 = new Face();
					face2.Indices.Add(point.VertexIndex);
					assimpMesh.Faces.Add(face2);
				}
			}
		}

		private static void ProcessLight(Light light, Slot slot, Assimp.Node node, ExportData data)
		{
			string name = "Light-" + light.ReferenceID;
			Assimp.Node item = new Assimp.Node(name);
			node.Children.Add(item);
			Assimp.Light light2 = new Assimp.Light();
			light2.Name = name;
			light2.Position = data.GlobalPositionInScene(slot).ToAssimp();
			light2.Direction = Elements.Core.float3.Forward.ToAssimp();
			light2.ColorDiffuse = light.Color.Value.ToAssimpRGB();
			light2.ColorSpecular = light.Color.Value.ToAssimpRGB();
			light2.AttenuationConstant = Filter(1f / light.Intensity.Value);
			light2.AttenuationLinear = 0f;
			light2.AttenuationQuadratic = Filter(1f / light.Range.Value);
			switch (light.LightType.Value)
			{
			case LightType.Point:
				light2.LightType = LightSourceType.Point;
				light2.AngleInnerCone = MathF.PI * 2f;
				light2.AngleOuterCone = MathF.PI * 2f;
				break;
			case LightType.Spot:
				light2.LightType = LightSourceType.Spot;
				light2.AngleInnerCone = 0f;
				light2.AngleOuterCone = light.SpotAngle.Value * (MathF.PI / 180f);
				break;
			case LightType.Directional:
				light2.LightType = LightSourceType.Directional;
				break;
			}
			data.scene.Lights.Add(light2);
		}

		private static float Filter(float val)
		{
			if (float.IsNaN(val) || float.IsInfinity(val))
			{
				return 0f;
			}
			return val;
		}

		private static Elements.Core.float2 Filter(Elements.Core.float2 val)
		{
			return new Elements.Core.float2(Filter(val.x), Filter(val.y));
		}

		private static Elements.Core.float3 Filter(Elements.Core.float3 val)
		{
			return new Elements.Core.float3(Filter(val.x), Filter(val.y), Filter(val.z));
		}

		private static Elements.Core.float4 Filter(Elements.Core.float4 val)
		{
			return new Elements.Core.float4(Filter(val.x), Filter(val.y), Filter(val.z), Filter(val.w));
		}
	}
