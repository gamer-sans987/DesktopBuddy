			Elements.Core.BoundingBox boundingBox = overrideBounds ?? Bounds;
			if (boundingBox.Size.IsInfinity || boundingBox.Size.IsNaN)
			{
				if (!_invalidBoundsWarned)
				{
					_invalidBoundsWarned = true;
					string[] obj = new string[8] { "Invalid bounds: ", null, null, null, null, null, null, null };
					Elements.Core.BoundingBox boundingBox2 = boundingBox;
					obj[1] = boundingBox2.ToString();
					obj[2] = ", owner: ";
					obj[3] = base.Owner?.ToString();
					obj[4] = ", URL: ";
					obj[5] = base.AssetURL?.ToString();
					obj[6] = "\n";
					obj[7] = (base.Owner as Worker)?.MembersToString();
					UniLog.Warning(string.Concat(obj));
				}
				boundingBox = new Elements.Core.BoundingBox(Elements.Core.float3.Zero);
			}
			if (Manager != null)
			{
				GaussianSplatUploadRaw gaussianSplatUploadRaw = new GaussianSplatUploadRaw();
