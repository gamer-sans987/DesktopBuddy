		private static async Task<AudioTypeGroup> DetectAudioTypeGroup(IAssetProvider<AudioClip> audioClip)
		{
			while (!audioClip.IsAssetAvailable && !audioClip.IsRemoved)
			{
				await default(NextUpdate);
			}
			if (audioClip.IsRemoved)
			{
				return (AudioTypeGroup)(-1);
			}
			if (audioClip.Asset.Data.Duration >= 10.0)
			{
				return AudioTypeGroup.Multimedia;
			}
			return AudioTypeGroup.SoundEffect;
		}

