	{
		public readonly RawOutput<int> CurrentChannels;

		public readonly SyncList<RawOutput<float>> ChannelVolumes;

		public readonly Sync<bool> DoNotRemoveExcessFields;

		private float[] _lastVolumes;

		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			float[] lastVolumes = _lastVolumes;
			int num = ((lastVolumes != null) ? lastVolumes.Length : 0);
			if (DoNotRemoveExcessFields.Value)
			{
				ChannelVolumes.EnsureMinimumCount(num);
			}
			else
			{
				ChannelVolumes.EnsureExactCount(num);
			}
			for (int i = 0; i < ChannelVolumes.Count; i++)
			{
				ChannelVolumes[i].Value = ((i < num) ? _lastVolumes[i] : 0f);
			}
		}

		protected override void StoreVolume(Span<float> volumes)
		{
			if (_lastVolumes?.Length != volumes.Length)
			{
				_lastVolumes = new float[volumes.Length];
			}
			for (int i = 0; i < volumes.Length; i++)
			{
				_lastVolumes[i] = MathX.LerpUnclamped(volumes[i], _lastVolumes[i], Smoothing.Value);
			}
		}

		protected override void ClearVolume()
		{
			if (_lastVolumes != null)
			{
				Array.Clear(_lastVolumes, 0, _lastVolumes.Length);
			}
		}

