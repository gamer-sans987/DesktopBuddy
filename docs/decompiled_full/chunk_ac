	public static class EngineSkyFrostExtensions
	{
		private static ConcurrentDictionary<string, bool> _globalCompatibilityHashes = new ConcurrentDictionary<string, bool>();

		public static bool IsCompatible(this SessionInfo sessionInfo)
		{
			if (sessionInfo.SystemCompatibilityHash != GlobalTypeRegistry.SystemCompatibilityHash)
			{
				return false;
			}
			if (sessionInfo.DataModelAssemblies == null)
			{
				return false;
			}
			if (_globalCompatibilityHashes.TryGetValue(sessionInfo.CompatibilityHash, out var value))
			{
				return value;
			}
			value = true;
			foreach (AssemblyInfo dataModelAssembly in sessionInfo.DataModelAssemblies)
			{
				AssemblyTypeRegistry assemblyTypeRegistry = GlobalTypeRegistry.TryGetTypeRegistry(dataModelAssembly.Name);
				if (assemblyTypeRegistry == null)
				{
					value = false;
					break;
				}
				if (assemblyTypeRegistry.CompatibilityHash != dataModelAssembly.CompatibilityHash)
				{
					value = false;
					break;
				}
			}
			_globalCompatibilityHashes.TryAdd(sessionInfo.CompatibilityHash, value);
			return value;
		}

