				}
				return Texture.Target.Slot.Name;
			}
		}

		public int ExportTypeCount
		{
			get
			{
				if (!Texture.IsAssetAvailable)
				{
					return 0;
				}
				return formats.Length;
			}
		}

		public IEnumerable<Slot> ExportRoots
		{
			get
			{
				if (Texture.Target != null)
				{
					yield return Texture.Target.Slot;
				}
			}
		}

		public string SingleItemKey => "CopyImage";

		public bool KeepFirstSingleItem => false;

		public async Task<bool> Export(string folder, string name, int exportType)
		{
			if (exportType < 0 || exportType >= formats.Length)
			{
				throw new ArgumentOutOfRangeException("exportType");
			}
			string targetFile = Path.Combine(folder, name + "." + formats[exportType].ToLower());
			if (Texture.Target is StaticTexture2D staticTexture2D)
			{
				Uri url = staticTexture2D.URL.Value;
				await default(ToBackground);
				string text = await base.Engine.AssetManager.GatherAssetFile(url, 100f).ConfigureAwait(continueOnCapturedContext: false);
				string text2 = Path.GetExtension(text).Replace(".", "").ToUpper();
				UniLog.Log("Export type: " + formats[exportType] + ", source: " + text2);
				if (text2 == formats[exportType])
				{
					File.Copy(text, targetFile, overwrite: true);
				}
				else
				{
					UniLog.Log("Converting to: " + formats[exportType]);
					switch (formats[exportType])
					{
					case "PNG":
						TextureEncoder.ConvertToPNG(text, targetFile);
						break;
					case "JPG":
						TextureEncoder.ConvertToJPG(text, targetFile);
						break;
					case "EXR":
						TextureEncoder.ConvertToEXR(text, targetFile);
						break;
					case "LUT":
					{
						Bitmap2D bitmap2D = Bitmap2D.Load(text, false);
						Elements.Core.int2 size = MathX.RoundToInt(1024f / (float)bitmap2D.Size.x * bitmap2D.Size);
						bitmap2D = bitmap2D.GetRescaled(size);
						Bitmap2D bitmap2D2 = new Bitmap2D(size.x, size.y + 32, bitmap2D.Format, mipmaps: false, bitmap2D.Profile);
						bitmap2D2.CopyFrom(bitmap2D, 0, 0, 0, 32, bitmap2D.Size.x, bitmap2D.Size.y);
						float num = 1f / 31f;
						for (int i = 0; i < 32; i++)
						{
							for (int j = 0; j < 1024; j++)
							{
								int num2 = j % 32;
								int num3 = j / 32;
								bitmap2D2.SetPixel(j, i, new Elements.Core.color((float)num2 * num, (float)i * num, (float)num3 * num));
							}
						}
						bitmap2D2.Save(targetFile + ".png");
						break;
					}
					default:
						throw new Exception("Unsupported export format: " + formats[exportType]);
					}
				}
			}
			else
			{
				Bitmap2D tex = Texture.Asset.Data;
				await default(ToBackground);
				tex.Save(targetFile);
			}
			return true;
		}

