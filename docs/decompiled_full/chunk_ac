	public static class BatchFolderImporter
	{
		[FolderImporter("Importer.Folder.Individual", "Importer.Folder.Individual.Description")]
		public static void IndividualImport(Slot root, string path)
		{
			int num = 0;
			foreach (string item in Directory.EnumerateFiles(path))
			{
				if (AssetHelper.IdentifyClass(item) != AssetClass.Unknown)
				{
					UniversalImporter.Import(item, root.World, root.GlobalPosition + root.Right * 0.5f * num, root.GlobalRotation);
				}
				num++;
			}
			root.Destroy();
		}

		[FolderImporter("Importer.Folder.Batch", "Importer.Folder.Batch.Description")]
		public static void BatchImport(Slot root, string path)
		{
			BatchImport(root, Directory.EnumerateFiles(path));
		}

		public static void BatchImport(Slot root, IEnumerable<string> files, bool forceUnknown = false)
		{
			Dictionary<AssetClass, List<string>> dictionary = new Dictionary<AssetClass, List<string>>();
			foreach (string file in files)
			{
				AssetClass key = ((!forceUnknown) ? AssetHelper.IdentifyClass(file) : AssetClass.Unknown);
				if (!dictionary.TryGetValue(key, out var value))
				{
					value = new List<string>();
					dictionary.Add(key, value);
				}
				value.Add(file);
			}
			Elements.Core.float3 b = Elements.Core.float3.Zero;
			foreach (KeyValuePair<AssetClass, List<string>> item in dictionary)
			{
				UniversalImporter.Import(item.Key, item.Value, root.World, root.GlobalPosition + b, root.GlobalRotation);
				b += root.Forward * 0.5f;
			}
			root.Destroy();
		}
	}
