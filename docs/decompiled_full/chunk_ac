	public class AssetVariantManager<A> : AssetVariantManager where A : Asset, new()
	{
		private List<A> variants = new List<A>();

		public override int VariantCount => variants.Count;

		public override Type AssetType => typeof(A);

		public AssetVariantManager(Uri assetUrl, AssetManager manager, IAssetMetadata metadata)
			: base(assetUrl, manager, metadata)
		{
		}

		public void ForEachVariant(Action<A> action)
		{
			lock (VariantLock)
			{
				foreach (A variant in variants)
				{
					action(variant);
				}
			}
		}

		public override void RequestAsset(IAssetRequester requester, IEngineAssetVariantDescriptor variantDescriptor)
		{
			lock (VariantLock)
			{
				foreach (A variant in variants)
				{
					if (variant.ActiveRequestCount > 0 && variant.TryAddRequest(requester, variantDescriptor))
					{
						return;
					}
				}
				foreach (A variant2 in variants)
				{
					if (variant2.ActiveRequestCount == 0 && variant2.TryAddRequest(requester, variantDescriptor))
					{
						return;
					}
				}
				A val = new A();
				val.InitializeStatic(AssetURL, this);
				variants.Add(val);
				if (!val.TryAddRequest(requester, variantDescriptor))
				{
					throw new Exception("Failed adding request to new variant");
				}
			}
		}

		internal override void VariantRemoved(Asset asset)
		{
			variants.Remove((A)asset);
			if (variants.Count == 0)
			{
				AssetManager.ScheduleVariantManagerRemoval(new AssetID(AssetURL, typeof(A)));
			}
		}

		internal override void VariantLoaded(Asset asset)
		{
			lock (VariantLock)
			{
				for (int num = variants.Count - 1; num >= 0; num--)
				{
					if (variants[num] != asset)
					{
						variants[num].VariantLoaded(asset);
					}
				}
			}
		}

		internal override Asset ForceLoad(Asset requestingAsset, IEngineAssetVariantDescriptor descriptor)
		{
			A val = new A();
			val.InitializeStatic(AssetURL, this);
			val.ForceLoad(requestingAsset, descriptor);
			variants.Add(val);
			return val;
		}
	}
