				base.RenderSystem.SendAssetUpdate(unloadTexture3D);
			}
			Data = null;
			base.Unload();
		}

		private static void AssignUploadLayout(Bitmap3D bitmap, SetTexture3DData data)
		{
			SharedMemoryBlockLease<byte> sharedMemoryBlockLease = (SharedMemoryBlockLease<byte>)bitmap.Buffer;
			data.data = sharedMemoryBlockLease.Descriptor;
		}
