	{
		public AudioX Data { get; private set; }

		public double BaseRate { get; private set; }

		public async Task<AudioX> GetOriginalAudioData()
		{
			if (base.AssetURL != null)
			{
				await default(ToBackground);
				string file = await base.AssetManager.GatherAssetFile(base.AssetURL, 0f).ConfigureAwait(continueOnCapturedContext: false);
				await default(ToBackground);
				if (file == null)
				{
					return null;
				}
				return new AudioX(file);
			}
			if (Data != null)
			{
				return Data;
			}
			return null;
