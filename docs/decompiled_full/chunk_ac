			SharedMemoryBlockLease<byte> DecodeBuffer(string path, int num)
			{
				SharedMemoryBlockLease<byte> sharedMemoryBlockLease = allocator.AllocateBlock<byte>(MathX.AlignToNextMultiple(num, 4), frameBound: false, this);
				Span<byte> rawData = sharedMemoryBlockLease.RawData;
				MemoryUsage += sharedMemoryBlockLease.SizeBytes;
				using FileStream innerStream = File.OpenRead(path);
				using LZ4Stream lZ4Stream = new LZ4Stream(innerStream, CompressionMode.Decompress);
				int num2 = num;
				while (num2 > 0)
				{
					int num3 = lZ4Stream.Read(readBuffer, 0, MathX.Min(num2, readBuffer.Length));
					if (num3 == 0)
					{
						throw new EndOfStreamException("Unexpected end of LZ4 stream");
					}
					readBuffer.AsSpan(0, num3).CopyTo(rawData.Slice(num - num2, num3));
					num2 -= num3;
				}
				return sharedMemoryBlockLease;
			}
		}

