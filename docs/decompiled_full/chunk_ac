		}

		public static SphereConstantReferenceSpatialVariable<AudioDSP_Effect> SetupReverbZone(AudioZitaReverb reverb)
		{
			Slot slot = reverb.Slot;
			Slot slot2 = slot.AddSlot("ReverbEffect");
			AudioFilterBlendWrapper audioFilterBlendWrapper = slot2.AttachComponent<AudioFilterBlendWrapper>();
			audioFilterBlendWrapper.NestedFilter.Target = reverb;
			slot2.AttachComponent<SpatialVariableBlendDriver>().BlendWeight.Target = audioFilterBlendWrapper.BlendWeight;
			SphereConstantReferenceSpatialVariable<AudioDSP_Effect> sphereConstantReferenceSpatialVariable = slot.AttachComponent<SphereConstantReferenceSpatialVariable<AudioDSP_Effect>>();
			sphereConstantReferenceSpatialVariable.VariableName.Value = "Resonite.Audio.Filters";
			sphereConstantReferenceSpatialVariable.Reference.Target = audioFilterBlendWrapper;
			sphereConstantReferenceSpatialVariable.BlendDistanceMode.Value = SpatialVariableBlendDistanceMode.Absolute;
			return sphereConstantReferenceSpatialVariable;
		}

