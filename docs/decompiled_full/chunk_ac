	[Category(new string[] { "Media" })]
	public class ChildParentAudioClipPlayer : RandomAudioClipPlayerBase
	{
		public enum PointMode
		{
			ParentOrigin,
			ChildOrigin,
			ParentBoundsCenter,
			ChildBoundsCenter
		}

		public readonly Sync<PointMode> PlayPointMode;

		public readonly Sync<int> ChildLimit;

		public readonly Sync<string> FilterTag;

		public readonly SyncList<ClipData> ParentedClips;

		public readonly SyncList<ClipData> UnparentedClips;

		protected override void OnAwake()
		{
			base.OnAwake();
			base.Slot.ChildAdded += Slot_ChildAdded;
			base.Slot.ChildRemoved += Slot_ChildRemoved;
		}

		private void Slot_ChildAdded(Slot slot, Slot child)
		{
			PlayClip(child, ParentedClips, removed: false);
		}

		private void Slot_ChildRemoved(Slot slot, Slot child)
		{
			PlayClip(child, UnparentedClips, removed: true);
		}

		private void PlayClip(Slot child, SyncList<ClipData> clips, bool removed)
		{
			if (base.World.CanMakeSynchronousChanges)
			{
				int num = base.Slot.ChildrenCount;
				if (removed)
				{
					num++;
				}
				if ((ChildLimit.Value <= 0 || num <= ChildLimit.Value) && (string.IsNullOrWhiteSpace(FilterTag.Value) || !(child.Tag != FilterTag.Value)))
				{
					PlayAtPoint(clips, PlayPointMode.Value switch
					{
						PointMode.ParentOrigin => base.Slot.GlobalPosition, 
						PointMode.ChildOrigin => child.GlobalPosition, 
						PointMode.ParentBoundsCenter => GetBoundsPoint(base.Slot), 
						PointMode.ChildBoundsCenter => GetBoundsPoint(child), 
						_ => base.Slot.GlobalPosition, 
					});
				}
			}
		}

		private static Elements.Core.float3 GetBoundsPoint(Slot slot)
		{
			Elements.Core.BoundingBox boundingBox = slot.ComputeBoundingBox();
			if (!boundingBox.IsValid)
			{
				return slot.GlobalPosition;
			}
			return boundingBox.Center;
		}

		protected override void OnDispose()
		{
			base.Slot.ChildAdded -= Slot_ChildAdded;
			base.Slot.ChildRemoved -= Slot_ChildRemoved;
			base.OnDispose();
		}

		protected override void InitializeSyncMembers()
