		public async void OnlineStatusChanged(OnlineStatus status)
		{
			if (LoadingOnlineStatus || Cloud.CurrentUserID == null)
			{
				return;
			}
			await Task.Run(async delegate
			{
				try
				{
					await Cloud.Variables.WriteOwners(Cloud.Platform.VariablePath(SettingsCloudVariables.LAST_ONLINE_STATUS.subpath), status, SettingsCloudVariables.LAST_ONLINE_STATUS.type);
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception writing last online status:\n" + ex);
				}
			});
		}

		public void SignIn()
		{
			if (Status.ForceInvisible)
			{
				LoadingOnlineStatus = false;
				return;
			}
			LoadingOnlineStatus = true;
			Task.Run(async delegate
			{
				_ = 2;
				try
				{
					CloudResult<TimestampedCloudVariable<OnlineStatus>> result = await Cloud.Variables.ReadOwnersWithTimestamp<OnlineStatus>(Cloud.Platform.VariablePath(SettingsCloudVariables.LAST_ONLINE_STATUS.subpath), SettingsCloudVariables.LAST_ONLINE_STATUS.type);
					if (result.IsOK)
					{
						OnlineStatusSettings onlineStatusSettings;
						do
						{
							await Task.Delay(100);
							onlineStatusSettings = await Settings.GetActiveSettingAsync<OnlineStatusSettings>();
						}
						while (onlineStatusSettings.SettingOwnerId != Cloud.CurrentUserID);
						if (onlineStatusSettings.UseLastStatus(result.Entity.value, result.Entity.timestamp))
						{
							Status.OnlineStatus = result.Entity.value;
						}
						else
						{
							Status.OnlineStatus = onlineStatusSettings.DefaultStatus.Value;
						}
					}
					else
					{
						UniLog.Warning($"Failed to read the last online status:\n{result}");
					}
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception trying to load last online status:\n" + ex);
				}
				finally
				{
					LoadingOnlineStatus = false;
				}
			});
		}

