			Size = bitmap.Size;
			MipMapCount = overrideMips ?? bitmap.MipMapLevels;
			base.Format = bitmap.Format;
			base.Profile = variant?.Profile ?? bitmap.Profile;
			return (byte)num != 0;
		}

