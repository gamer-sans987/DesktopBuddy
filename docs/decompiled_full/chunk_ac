		public static async Task<ObjectMessageData> CreateObjectMessage(this UserMessages userMessages, Slot objectRoot, bool saveRoot)
		{
			string messageId = SkyFrost.Base.Message.GenerateId();
			ItemHelper.ItemUploadTask syncTask = await ItemHelper.SaveItemAndSync(objectRoot, saveRoot, delegate(FrooxEngine.Store.Record r)
			{
				if (r.Tags == null)
				{
					r.Tags = new HashSet<string>();
				}
				r.Tags.Add(RecordTags.MessageItem);
				r.Tags.Add(RecordTags.CorrespondingMessageId(messageId));
			}).ConfigureAwait(continueOnCapturedContext: false);
			if (syncTask == null)
			{
				return null;
			}
			ObjectMessageData objectMessageData = new ObjectMessageData();
			SkyFrost.Base.Message message = new SkyFrost.Base.Message();
			message.Id = messageId;
			message.MessageType = SkyFrost.Base.MessageType.Object;
			message.SendTime = DateTime.UtcNow;
			message.SetContent(syncTask.Record);
			objectMessageData.message = message;
			objectMessageData.uploadTask = Task.Run(async delegate
			{
				await syncTask.UploadTask.Task.ConfigureAwait(continueOnCapturedContext: false);
				FrooxEngine.Store.Record record = syncTask.UploadTask.Record.Clone<FrooxEngine.Store.Record>();
				record.Manifest = null;
				record.AssetManifest = null;
				message.SetContent(record);
			});
			return objectMessageData;
		}

		public static async Task<ObjectMessageData> CreateSoundMessage(this UserMessages userMessages, Engine engine, AudioX sound)
		{
			string messageId = SkyFrost.Base.Message.GenerateId();
			await default(ToBackground);
			Uri uri = await engine.LocalDB.SaveAssetAsync(sound).ConfigureAwait(continueOnCapturedContext: false);
			FrooxEngine.Store.Record record = RecordHelper.CreateForAudioClip<FrooxEngine.Store.Record>("Voice Message", engine.Cloud.Session.CurrentUserID, uri.ToString());
			if (record.Tags == null)
			{
				record.Tags = new HashSet<string>();
			}
			record.Tags.Add(RecordTags.MessageItem);
			record.Tags.Add(RecordTags.CorrespondingMessageId(messageId));
			RecordManager.RecordSaveResult saveResult = await engine.RecordManager.SaveRecord(record);
			if (!saveResult.saved)
			{
				return null;
			}
			ObjectMessageData objectMessageData = new ObjectMessageData();
			SkyFrost.Base.Message message = new SkyFrost.Base.Message();
			message.Id = messageId;
			message.MessageType = SkyFrost.Base.MessageType.Sound;
			message.SendTime = DateTime.UtcNow;
			message.SetContent(record);
			objectMessageData.message = message;
			objectMessageData.uploadTask = Task.Run(async delegate
			{
				await saveResult.task.Task;
				message.SetContent(saveResult.task.Record);
			});
			return objectMessageData;
		}
	}
