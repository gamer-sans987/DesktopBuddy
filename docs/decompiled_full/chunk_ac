	public class InviteRequestManager : SkyFrostModule
	{
		private class InviteRequestForwardState
		{
			public readonly HashSet<string> ForwardedToUserIds = new HashSet<string>();

			private string _handledByUserId;

			public string HandledByUserId { get; private set; }

			public bool HasBeenForwardedTo(string userId)
			{
				return ForwardedToUserIds.Contains(userId);
			}

			public bool TryHandle(string byUserId)
			{
				if (Interlocked.CompareExchange(ref _handledByUserId, byUserId, null) != null)
				{
					return false;
				}
				return true;
			}
		}

		private Dictionary<string, InviteRequestForwardState> _forwardedInviteRequests = new Dictionary<string, InviteRequestForwardState>();

		public Engine Engine { get; private set; }

		public InviteRequestManager(EngineSkyFrostInterface cloud)
			: base(cloud)
		{
			Engine = cloud.Engine;
			base.Cloud.Messages.OnMessageReceived += OnMessageReceived;
		}

		private void OnMessageReceived(SkyFrost.Base.Message message)
		{
			if (message.MessageType != SkyFrost.Base.MessageType.InviteRequest)
			{
				return;
			}
			InviteRequest inviteRequest = message.ExtractContent<InviteRequest>();
			if (inviteRequest.IsGranted || Engine.InputInterface.HeadOutputDevice == HeadOutputDevice.Headless)
			{
				if (inviteRequest.IsGranted)
				{
					ProcessGrantedInviteRequest(message, inviteRequest);
				}
				else
				{
					ForwardToAdmins(message, inviteRequest);
				}
			}
		}

		private void ProcessGrantedInviteRequest(SkyFrost.Base.Message incomingMessage, InviteRequest request)
		{
			if (!_forwardedInviteRequests.TryGetValue(request.InviteRequestId, out InviteRequestForwardState state))
			{
				UniLog.Warning("Received granted invite request that has not been forwarded in this session: " + request);
			}
			else if (!state.HasBeenForwardedTo(incomingMessage.SenderId))
			{
				UniLog.Warning("Got invite request response from user who it wasn't forwarded to (" + incomingMessage.SenderId + "): " + request);
			}
			else if (request.Response == InviteRequestResponse.SendInvite && !state.TryHandle(incomingMessage.SenderId))
			{
				Task.Run(async delegate
				{
					await base.Cloud.Messages.GetUserMessages(incomingMessage.SenderId).SendTextMessage("This user was already invited by " + base.Cloud.Contacts.GetContact(state.HandledByUserId)?.ContactUsername + ". Your action was ignored.");
				});
			}
			else if (request.RequestingFromUserId == base.Cloud.CurrentUserID)
			{
				Task.Run(async delegate
				{
					await base.Cloud.Messages.GetUserMessages(request.UserIdToInvite).SendInviteMessage(request.Invite).ConfigureAwait(continueOnCapturedContext: false);
				});
			}
			else if (Engine.InputInterface.HeadOutputDevice == HeadOutputDevice.Headless)
			{
				if (!request.Response.HasValue)
				{
					UniLog.Warning("Received invite request with response being null from " + incomingMessage.SenderId + ":\n" + request);
					return;
				}
				Task.Run(async delegate
				{
					UserMessages senderMessages = base.Cloud.Messages.GetUserMessages(incomingMessage.SenderId);
					InviteRequestResponse? response = request.Response;
					if (response.HasValue)
					{
						switch (response.GetValueOrDefault())
						{
						case InviteRequestResponse.AddAsContact:
							if (base.Cloud.Contacts.IsContact(request.UserIdToInvite))
							{
								await senderMessages.SendTextMessage("User " + request.UsernameToInvite + " is already a contact!");
							}
							else if (await base.Cloud.Contacts.AddContact(request.UserIdToInvite, request.UsernameToInvite).ConfigureAwait(continueOnCapturedContext: false))
							{
								await senderMessages.SendTextMessage("User " + request.UsernameToInvite + " was added as a contact!");
							}
							else
							{
								await senderMessages.SendTextMessage("FAILED to add user " + request.UsernameToInvite + " as a contact!");
							}
							break;
						case InviteRequestResponse.SendInvite:
						{
							World correspondingHostedWorld = GetCorrespondingHostedWorld(request);
							if (correspondingHostedWorld == null)
							{
								await senderMessages.SendTextMessage("Session associated with the invite request does not exist anymore, could not invite the user to it.");
							}
							else
							{
								await SendInvite(request, correspondingHostedWorld).ConfigureAwait(continueOnCapturedContext: false);
							}
							break;
						}
						}
					}
				});
			}
			else
			{
				UniLog.Warning($"Unknown situation when processing granted invite request.\nIncoming message: {incomingMessage}\nRequest: {request}");
			}
		}

		private void ForwardToAdmins(SkyFrost.Base.Message incomingMessage, InviteRequest request)
		{
			UserMessages senderMessages = base.Cloud.Messages.GetUserMessages(incomingMessage.SenderId);
			World world = GetCorrespondingHostedWorld(request);
			if (world == null)
			{
				UniLog.Warning($"Couldn't find hosted world for invite request: {request}");
				Task.Run(async () => await senderMessages.SendTextMessage("Could not find corresponding world for this invite request."));
				return;
			}
			Task.Run(async delegate
			{
				HashSet<string> inviteHandlerUsers = world.GetInviteHandlerUsers();
				inviteHandlerUsers.RemoveWhere(delegate(string u)
				{
					if (base.Cloud.Contacts.IsContact(u))
					{
						return false;
					}
					UniLog.Warning($"User {u} is admin of the session {world.Name}, but is not contact with the host. Cannot forward  invite request.");
					return true;
				});
				if (inviteHandlerUsers.Count == 0)
				{
					await senderMessages.SendTextMessage("There are currently no admins available to handle this invite request.");
				}
				else
				{
					bool isContactOfHost = base.Cloud.Contacts.IsContact(request.UserIdToInvite);
					await ForwardInviteRequest(request, isContactOfHost, inviteHandlerUsers.ToArray());
				}
			});
		}

		/// <summary>
		/// This forwards invite request to given contacts and registers it as forwarded.
		/// </summary>
		/// <param name="request">The invite request to forward</param>
		/// <param name="forSessionId">Which session is this invite request for</param>
		/// <param name="forSessionName">The corresponding name of the session</param>
		/// <param name="contactIds">List of contacts to forward it to. Typically host or admins</param>
		/// <returns></returns>
		/// <exception cref="T:System.InvalidOperationException"></exception>
		public Task ForwardInviteRequest(InviteRequest request, string forSessionId, string forSessionName, params string[] contactIds)
		{
			if (string.IsNullOrEmpty(forSessionId))
			{
				throw new ArgumentException("forSessionId must not be empty");
			}
			return ForwardInviteRequest(request, (InviteRequest r, UserMessages m) => m.CreateForwardedInviteRequest(r, forSessionId, forSessionName), contactIds);
		}

		/// <summary>
		/// This forwards invite request to given contacts and registers it as forwarded.
		/// </summary>
		/// <param name="request">The invite request to forward</param>
		/// <param name="isContactOfHost">Indicates of the user who wants invite is contact of the host</param>
		/// <param name="contactIds">List of contacts to forward it to. Typically host or admins</param>
		/// <returns></returns>
		/// <exception cref="T:System.InvalidOperationException"></exception>
		public Task ForwardInviteRequest(InviteRequest request, bool isContactOfHost, params string[] contactIds)
		{
			return ForwardInviteRequest(request, (InviteRequest r, UserMessages m) => m.CreateHeadlessForwardedInviteRequest(r, isContactOfHost), contactIds);
		}

		/// <summary>
		/// This forwards invite request to given contacts and registers it as forwarded.
		/// </summary>
		/// <param name="request">The invite request to forward</param>
		/// <param name="convertor">Method that converts the invite request into a forwarded message</param>
		/// <param name="contactIds">List of contacts to forward it to. Typically host or admins</param>
		/// <returns></returns>
		/// <exception cref="T:System.InvalidOperationException"></exception>
		private async Task ForwardInviteRequest(InviteRequest request, Func<InviteRequest, UserMessages, SkyFrost.Base.Message> convertor, params string[] contactIds)
		{
			if (_forwardedInviteRequests.ContainsKey(request.InviteRequestId))
			{
				throw new InvalidOperationException("This invite request has already been forwarded");
			}
			InviteRequestForwardState state = new InviteRequestForwardState();
			_forwardedInviteRequests.Add(request.InviteRequestId, state);
			foreach (string text in contactIds)
			{
				UserMessages userMessages = base.Cloud.Messages.GetUserMessages(text);
				if (userMessages == null)
				{
					throw new InvalidOperationException("User isn't contact: " + text);
				}
				state.ForwardedToUserIds.Add(text);
				SkyFrost.Base.Message message = convertor(request, userMessages);
				await userMessages.SendMessage(message);
			}
		}

		public async Task SendInvite(InviteRequest request, World world)
		{
			world.RunSynchronously(delegate
			{
				world.AllowUserToJoin(request.UserIdToInvite);
			});
			SessionInfo invite = world.GenerateSessionInfo();
			UserMessages userMessages = base.Cloud.Messages.GetUserMessages(request.RequestingFromUserId);
			SkyFrost.Base.Message message = userMessages.CreateGrantedInviteRequest(request, invite);
			await userMessages.SendMessage(message).ConfigureAwait(continueOnCapturedContext: false);
		}

		public async Task SendResponse(InviteRequest request, InviteRequestResponse response, string toContactId)
		{
			UserMessages userMessages = base.Cloud.Messages.GetUserMessages(toContactId);
			SkyFrost.Base.Message message = userMessages.CreateInviteRequestResponse(request, response);
			await userMessages.SendMessage(message).ConfigureAwait(continueOnCapturedContext: false);
		}

		public World GetCorrespondingHostedWorld(InviteRequest request)
		{
			return Engine.WorldManager.GetWorld((World w) => w.IsAuthority && w.SessionId == request.ForSessionId);
		}
	}
	public class LAN_SessionAnnouncer : IDisposable
	{
		private enum AnnouncementType
		{
			SessionInfo,
			SessionEnded
		}

		public const byte VERSION = 1;

		public const ushort ANNOUNCE_PORT = 12101;

		public const int ANNOUNCE_INTERVAL = 1;

		private UdpClient listener;

		private IPEndPoint announceEndpoint;

		private IPEndPoint resoniteLinkAnnounceEndpoint;

		private List<UdpClient> announcers = new List<UdpClient>();

		private List<IPAddress> localAddresses = new List<IPAddress>();

		private CancellationTokenSource cancellationTokenSource;

		private byte[] _selfId;

		private byte[] _idBuffer;

		public static TimeSpan BroadcastInterval => TimeSpan.FromSeconds(5L);

		public bool IsDisposed { get; private set; }

		public Engine Engine => Announcer?.Engine;

		public SessionAnnouncer Announcer { get; private set; }

		public SkyFrostInterface Cloud => Announcer.Cloud;

		public string Header => Cloud.Platform.ShortNamePrefix;

		public LAN_SessionAnnouncer(SessionAnnouncer sessionAnnouncer)
		{
			Announcer = sessionAnnouncer;
			_selfId = Guid.NewGuid().ToByteArray();
			_idBuffer = new byte[_selfId.Length];
			cancellationTokenSource = new CancellationTokenSource();
			foreach (IPAddress localIP in NetUtils.GetLocalIPs())
			{
				try
				{
					UdpClient item = new UdpClient(new IPEndPoint(localIP, 0))
					{
						EnableBroadcast = true
					};
					localAddresses.Add(localIP);
					announcers.Add(item);
				}
				catch (SocketException)
				{
				}
			}
			announceEndpoint = new IPEndPoint(IPAddress.Broadcast, 12101);
			resoniteLinkAnnounceEndpoint = new IPEndPoint(IPAddress.Broadcast, 12512);
			listener = new UdpClient();
			listener.Client.SetSocketOption(SocketOptionLevel.Socket, SocketOptionName.ReuseAddress, optionValue: true);
			listener.Client.Bind(new IPEndPoint(IPAddress.Any, 12101));
			Task.Run(async delegate
			{
				await ReceiveAnnoucements(cancellationTokenSource.Token).ConfigureAwait(continueOnCapturedContext: false);
			});
		}

		private async Task ReceiveAnnoucements(CancellationToken cancellation)
		{
			new IPEndPoint(IPAddress.Any, 0);
			while (!cancellation.IsCancellationRequested)
			{
				try
				{
					UdpReceiveResult udpReceiveResult = await listener.ReceiveAsync().WithCancellation(cancellation).ConfigureAwait(continueOnCapturedContext: false);
					if (udpReceiveResult.Buffer != null)
					{
						Decode(udpReceiveResult.RemoteEndPoint, udpReceiveResult.Buffer);
					}
				}
				catch (OperationCanceledException)
				{
				}
				catch (Exception value)
				{
					UniLog.Log($"Exception when receiving announcements:\n{value}");
				}
			}
		}

		private void Decode(IPEndPoint endpoint, byte[] data)
		{
			string header = Header;
			if (data.Length < header.Length)
			{
				return;
			}
			MemoryStream memoryStream = new MemoryStream(data);
			BinaryReaderX reader = Pool.BorrowBinaryReader(memoryStream);
			try
			{
				for (int i = 0; i < header.Length; i++)
				{
					if ((byte)header[i] != reader.ReadByte())
					{
						return;
					}
				}
				if (reader.ReadByte() != 1)
				{
					return;
				}
				lock (_idBuffer)
				{
					if (memoryStream.Read(_idBuffer, 0, _idBuffer.Length) != _idBuffer.Length)
					{
						return;
					}
					bool flag = true;
					for (int j = 0; j < _selfId.Length; j++)
					{
						if (_selfId[j] != _idBuffer[j])
						{
							flag = false;
							break;
						}
					}
					if (flag)
					{
						return;
					}
				}
				switch (reader.ReadEnumBinary<AnnouncementType>())
				{
				case AnnouncementType.SessionInfo:
				{
					ushort value = reader.ReadUInt16();
					using LZ4Stream targetStream = new LZ4Stream(memoryStream, CompressionMode.Decompress);
					reader.TargetStream = targetStream;
					SessionInfo sessionInfo = System.Text.Json.JsonSerializer.Deserialize<SessionInfo>(reader.ReadString());
					sessionInfo.LAN_URL = $"lnl://{endpoint.Address}:{value}";
					if (sessionInfo.SessionURLs == null)
					{
						sessionInfo.SessionURLs = new List<string>();
					}
					sessionInfo.SessionURLs.Add(sessionInfo.LAN_URL);
					Cloud.Sessions.UpdateSessionInfo(sessionInfo);
					break;
				}
				case AnnouncementType.SessionEnded:
				{
					string sessionId = reader.ReadString();
					DateTime timestamp = reader.ReadDateTime();
					Cloud.Sessions.RemoveSession(sessionId, timestamp);
					break;
				}
				}
			}
			finally
			{
				Pool.Return(ref reader);
			}
		}

		internal void AnnounceResoniteLink(string sessionId, string sessionName, int linkPort)
		{
			ResoniteLinkSession resoniteLinkSession = new ResoniteLinkSession();
			resoniteLinkSession.SessionId = sessionId;
			resoniteLinkSession.SessionName = sessionName;
			resoniteLinkSession.LinkPort = linkPort;
			using MemoryStream memoryStream = new MemoryStream();
			System.Text.Json.JsonSerializer.Serialize(memoryStream, resoniteLinkSession);
			Broadcast(memoryStream, resoniteLink: true);
		}

		internal void AnnounceResoniteLinkEnded(string sessionId)
		{
			AnnounceResoniteLink(sessionId, "", -1);
		}

		internal void AnnounceSession(SessionInfo info)
		{
			if (FrooxEngine.Engine.Config.DisableAnnounceOnLAN || NetworkManager.DisableLAN || !info.LAN_Port.HasValue)
			{
				return;
			}
			using MemoryStream memoryStream = SyncMessage.StreamManager.GetStream();
			BinaryWriterX writer = Pool.BorrowBinaryWriter(memoryStream);
			WriteHeader(writer, AnnouncementType.SessionInfo);
			writer.Write(info.LAN_Port.Value);
			using (LZ4Stream targetStream = new LZ4Stream(memoryStream, CompressionMode.Compress, LZ4StreamFlags.HighCompression))
			{
				writer.TargetStream = targetStream;
				string value = System.Text.Json.JsonSerializer.Serialize(info);
				writer.Write(value);
				writer.Flush();
				Broadcast(memoryStream, resoniteLink: false);
			}
			Pool.Return(ref writer);
		}

		internal void AnnounceSessionEnded(string sessionId, DateTime timestamp)
		{
			if (NetworkManager.DisableLAN)
			{
				return;
			}
			using MemoryStream stream = SyncMessage.StreamManager.GetStream();
			BinaryWriterX writer = Pool.BorrowBinaryWriter(stream);
			WriteHeader(writer, AnnouncementType.SessionEnded);
			writer.Write(sessionId);
			writer.Write(timestamp);
			writer.Flush();
			Broadcast(stream, resoniteLink: false);
			Pool.Return(ref writer);
		}

		private void Broadcast(MemoryStream stream, bool resoniteLink)
		{
			byte[] buffer = stream.GetBuffer();
			List<UdpClient> invalidAnnouncers = null;
			foreach (UdpClient announcer in announcers)
			{
				try
				{
					announcer.Send(buffer, (int)stream.Length, resoniteLink ? resoniteLinkAnnounceEndpoint : announceEndpoint);
				}
				catch (Exception)
				{
					if (invalidAnnouncers == null)
					{
						invalidAnnouncers = new List<UdpClient>();
					}
					invalidAnnouncers.Add(announcer);
				}
			}
			if (invalidAnnouncers != null)
			{
				announcers.RemoveAll((UdpClient a) => invalidAnnouncers.Contains(a));
			}
		}

		private void WriteHeader(BinaryWriter writer, AnnouncementType type)
		{
			string header = Header;
			foreach (char c in header)
			{
				writer.Write((byte)c);
			}
			writer.Write((byte)1);
			writer.Write(_selfId);
			writer.WriteEnumBinary(type);
			writer.Flush();
		}

		public void Dispose()
		{
			cancellationTokenSource.Cancel();
			foreach (UdpClient announcer in announcers)
			{
				announcer.Close();
			}
			listener.Close();
			IsDisposed = true;
		}
	}
