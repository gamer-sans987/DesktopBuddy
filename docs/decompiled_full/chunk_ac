								float gain;
								Elements.Core.colorX value2 = light2.ColorDiffuse.ToEngine().NormalizeHDR(out gain);
								light.Color.Value = value2;
								light.Intensity.Value = gain;
								if (light.LightType.Value == LightType.Directional)
