		private static void GenerateRigBones(BoneNode node, ModelImportData data, Slot root, BipedRig bipedRig, Elements.Core.float3? parentBone = null)
		{
			List<BoneNode> children = node.children;
			for (int i = 0; i < MathX.Max(1, children.Count); i++)
			{
				Elements.Core.float3 v = Elements.Core.float3.Zero;
				if (children.Count > 0)
				{
					v = node.bone.GlobalPointToLocal(children[i].bone.GlobalPosition);
				}
				else
				{
					bool flag = false;
					foreach (Slot child in node.bone.Children)
					{
						v = node.bone.GlobalPointToLocal(child.GlobalPosition);
						if (v.Magnitude > 0.1f)
						{
							flag = true;
							break;
						}
					}
					if (!flag)
					{
						if (!parentBone.HasValue)
						{
							break;
						}
						float num = 0.8f;
						float max = float.MaxValue;
						float min = 0f;
						if (bipedRig?.TryGetBone(BodyNode.Head) == node.bone)
						{
							num = 3f;
							max = 0.2f;
							min = 0.1f;
						}
						if (bipedRig?.TryGetBone(BodyNode.LeftHand) == node.bone || bipedRig?.TryGetBone(BodyNode.RightHand) == node.bone)
						{
							num = 1f;
							min = 0.15f;
						}
						v = new Elements.Core.float3(0f, MathX.Clamp(parentBone.Value.Magnitude * num, min, max));
					}
				}
				float num2 = 0.125f;
				float num3 = float.MaxValue;
				bool flag2 = true;
				BodyNode bodyNode = bipedRig?.GetBoneType(node.bone) ?? BodyNode.NONE;
				if (bipedRig != null)
				{
					switch (bodyNode)
					{
					case BodyNode.Spine:
					case BodyNode.Chest:
					case BodyNode.UpperChest:
						num2 = 0.3f;
						num3 = 0.035f;
						break;
					case BodyNode.Head:
						num2 = 0.4f;
						break;
					case BodyNode.Neck:
						num2 = 0.25f;
						break;
					case BodyNode.LeftShoulder:
					case BodyNode.RightShoulder:
						if (bodyNode == BodyNode.RightShoulder)
						{
						}
						break;
					case BodyNode.LeftUpperArm:
					case BodyNode.RightUpperArm:
						if (bodyNode == BodyNode.RightUpperArm)
						{
						}
						break;
					case BodyNode.LeftLowerArm:
					case BodyNode.RightLowerArm:
						if (bodyNode == BodyNode.RightLowerArm)
						{
						}
						break;
					case BodyNode.LeftHand:
					case BodyNode.RightHand:
						if (bodyNode == BodyNode.RightHand)
						{
						}
						break;
					case BodyNode.NONE:
						flag2 = false;
						break;
					}
				}
				if (num3 < float.MaxValue)
				{
					num3 = MathX.Abs(node.bone.GlobalScaleToLocal(num3));
				}
				if (flag2)
				{
					float magnitude = v.Magnitude;
					float value = MathX.Min(magnitude * num2, num3);
					Elements.Core.float3 localPosition = v * 0.5f;
					if (data.settings.GenerateColliders)
					{
						Slot slot = node.bone.AddSlot(((bodyNode == BodyNode.NONE) ? node.bone.Name : bodyNode.ToString()) + " Collider");
						slot.LocalPosition = localPosition;
						slot.LocalRotation = Elements.Core.floatQ.LookRotation(in v) * Elements.Core.floatQ.FromToRotation(Elements.Core.float3.Up, Elements.Core.float3.Forward);
						if (data.settings.GenerateSkeletonBoneVisuals)
						{
							AttachedModel<CylinderMesh, FresnelMaterial> attachedModel = slot.AttachMesh<CylinderMesh, FresnelMaterial>();
							attachedModel.material.BlendMode.Value = BlendMode.Alpha;
							Elements.Core.color color = new ColorHSV((float)i / 10f, 1f, 1f).ToRGB();
							attachedModel.material.NearColor.Value = new Elements.Core.colorX(color.rgb, 0.2f);
							attachedModel.material.FarColor.Value = new Elements.Core.colorX(color.rgb);
							attachedModel.mesh.Radius.Value = value;
							attachedModel.mesh.Height.Value = magnitude;
						}
						CapsuleCollider capsuleCollider = slot.AttachComponent<CapsuleCollider>();
						capsuleCollider.Radius.Value = value;
						capsuleCollider.Height.Value = magnitude;
					}
					if (children.Count > 0)
					{
						GenerateRigBones(children[i], data, root, bipedRig, v);
					}
				}
				else if (children.Count > 0)
				{
					GenerateRigBones(children[i], data, root, bipedRig, parentBone);
				}
			}
		}

