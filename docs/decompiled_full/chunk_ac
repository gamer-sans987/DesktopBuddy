	public static class ImageImporter
	{
		public static void SetupStereoLayout(IStereoMaterial stereoMaterial, StereoLayout stereoLayout)
		{
			switch (stereoLayout)
			{
			case StereoLayout.None:
				stereoMaterial.StereoTextureTransform = false;
				stereoMaterial.LeftEyeTextureScale = new Elements.Core.float2(1f, 1f);
				stereoMaterial.LeftEyeTextureOffset = new Elements.Core.float2(0f, 0f);
				stereoMaterial.RightEyeTextureScale = new Elements.Core.float2(1f, 1f);
				stereoMaterial.RightEyeTextureOffset = new Elements.Core.float2(0f, 0f);
				break;
			case StereoLayout.Horizontal_LR:
				stereoMaterial.StereoTextureTransform = true;
				stereoMaterial.LeftEyeTextureScale = new Elements.Core.float2(0.5f, 1f);
				stereoMaterial.LeftEyeTextureOffset = new Elements.Core.float2(0f, 0f);
				stereoMaterial.RightEyeTextureScale = new Elements.Core.float2(0.5f, 1f);
				stereoMaterial.RightEyeTextureOffset = new Elements.Core.float2(0.5f);
				break;
			case StereoLayout.Horizontal_RL:
				stereoMaterial.StereoTextureTransform = true;
				stereoMaterial.LeftEyeTextureScale = new Elements.Core.float2(0.5f, 1f);
				stereoMaterial.LeftEyeTextureOffset = new Elements.Core.float2(0.5f);
				stereoMaterial.RightEyeTextureScale = new Elements.Core.float2(0.5f, 1f);
				stereoMaterial.RightEyeTextureOffset = new Elements.Core.float2(0f, 0f);
				break;
			case StereoLayout.Vertical_LR:
				stereoMaterial.StereoTextureTransform = true;
				stereoMaterial.LeftEyeTextureScale = new Elements.Core.float2(1f, 0.5f);
				stereoMaterial.LeftEyeTextureOffset = new Elements.Core.float2(0f, 0.5f);
				stereoMaterial.RightEyeTextureScale = new Elements.Core.float2(1f, 0.5f);
				stereoMaterial.RightEyeTextureOffset = new Elements.Core.float2(0f, 0f);
				break;
			case StereoLayout.Vertical_RL:
				stereoMaterial.StereoTextureTransform = true;
				stereoMaterial.LeftEyeTextureScale = new Elements.Core.float2(1f, 0.5f);
				stereoMaterial.LeftEyeTextureOffset = new Elements.Core.float2(0f, 0f);
				stereoMaterial.RightEyeTextureScale = new Elements.Core.float2(1f, 0.5f);
				stereoMaterial.RightEyeTextureOffset = new Elements.Core.float2(0f, 0.5f);
				break;
			}
		}

		public static void SetupTextureProxyComponents(Slot targetSlot, IAssetProvider<Texture2D> texture, StereoLayout stereoLayout, ImageProjection projection, bool setupPhotoMetadata)
		{
			targetSlot.AttachComponent<TextureExportable>().Texture.Target = texture;
			if (projection == ImageProjection.Perspective)
			{
				ItemTextureThumbnailSource itemTextureThumbnailSource = targetSlot.AttachComponent<ItemTextureThumbnailSource>();
				itemTextureThumbnailSource.Texture.Target = texture;
				switch (stereoLayout)
				{
				case StereoLayout.Horizontal_LR:
				case StereoLayout.Horizontal_RL:
					itemTextureThumbnailSource.Crop.Value = new Elements.Core.Rect(0f, 0f, 0.5f, 1f);
					break;
				case StereoLayout.Vertical_LR:
				case StereoLayout.Vertical_RL:
					itemTextureThumbnailSource.Crop.Value = new Elements.Core.Rect(0f, 0f, 1f, 0.5f);
					break;
				}
				targetSlot.AttachComponent<SnapPlane>();
			}
			targetSlot.AttachComponent<ReferenceProxy>().Reference.Target = texture;
			targetSlot.AttachComponent<AssetProxy<Texture2D>>().AssetReference.Target = texture;
			if (setupPhotoMetadata)
			{
				PhotoMetadata photoMetadata = targetSlot.AttachComponent<PhotoMetadata>();
				photoMetadata.SetFromCurrentWorld();
				photoMetadata.CameraFOV.Value = targetSlot.World.LocalUserDesktopFOV;
				photoMetadata.Is360.Value = projection == ImageProjection.Equirectangular360;
				photoMetadata.StereoLayout.Value = stereoLayout;
			}
		}

		public static void Create360Sphere(Slot slot, ITexture2DProvider texture, StereoLayout layout = StereoLayout.None, ImageProjection projection = ImageProjection.Equirectangular360, bool addCollider = true)
		{
			Projection360Material projection360Material = slot.AttachComponent<Projection360Material>();
			SphereMesh target = slot.AttachComponent<SphereMesh>();
			MeshRenderer meshRenderer = slot.AttachComponent<MeshRenderer>();
			meshRenderer.Mesh.Target = target;
			meshRenderer.Material.Target = projection360Material;
			projection360Material.Texture.Target = texture;
			SetupStereoLayout(projection360Material, layout);
			if (addCollider)
			{
				slot.AttachComponent<MeshCollider>().Mesh.Target = target;
			}
			switch (projection)
			{
			case ImageProjection.Equirectangular180:
				projection360Material.FieldOfView.Value = new Elements.Core.float2(180f, 180f);
				break;
			case ImageProjection.Equirectangular360:
				projection360Material.FieldOfView.Value = new Elements.Core.float2(360f, 180f);
				break;
			default:
				throw new Exception("Invalid projection: " + projection);
			}
		}

		public static void CreateQuad(Slot slot, IAssetProvider<ITexture2D> texture, StereoLayout layout = StereoLayout.None, bool addCollider = true)
		{
			UnlitMaterial mat = slot.AttachComponent<UnlitMaterial>();
			QuadMesh quadMesh = slot.AttachComponent<QuadMesh>();
			MeshRenderer meshRenderer = slot.AttachComponent<MeshRenderer>();
			meshRenderer.Mesh.Target = quadMesh;
			meshRenderer.Material.Target = mat;
			mat.Texture.Target = texture;
			mat.Sidedness.Value = Sidedness.Double;
			SetupStereoLayout(mat, layout);
			mat.BlendMode.Value = BlendMode.Alpha;
			StaticTexture2D obj = texture as StaticTexture2D;
			if (obj != null && obj.IsNormalMap.Value)
			{
				mat.DecodeAsNormalMap.Value = true;
			}
			TextureSizeDriver textureSizeDriver = slot.AttachComponent<TextureSizeDriver>();
			textureSizeDriver.Texture.Target = texture;
			textureSizeDriver.DriveMode.Value = TextureSizeDriver.Mode.Normalized;
			textureSizeDriver.Target.Target = quadMesh.Size;
			switch (layout)
			{
			case StereoLayout.Horizontal_LR:
			case StereoLayout.Horizontal_RL:
				textureSizeDriver.Ratio.Value = new Elements.Core.float2(0.5f, 1f);
				break;
			case StereoLayout.Vertical_LR:
			case StereoLayout.Vertical_RL:
				textureSizeDriver.Ratio.Value = new Elements.Core.float2(1f, 0.5f);
				break;
			}
			if (addCollider)
			{
				BoxCollider boxCollider = slot.AttachComponent<BoxCollider>();
				boxCollider.Size.DriveFromXY(quadMesh.Size);
				boxCollider.Type.Value = ColliderType.NoCollision;
			}
			Texture2D tex2D = texture.Asset as Texture2D;
			if (tex2D == null)
			{
				return;
			}
			slot.World.Coroutines.StartBackgroundTask(async delegate
			{
				if (!(await tex2D.GetOriginalTextureData().ConfigureAwait(continueOnCapturedContext: false)).HasTransparentPixels())
				{
					mat.RunSynchronously(delegate
					{
						mat.BlendMode.Value = BlendMode.Opaque;
					});
				}
			});
		}

		public static async Task<Elements.Core.Result> ImportLUT(ImportItem item, Slot targetSlot)
		{
			Uri uri;
			if (item.inMemoryAsset != null)
			{
				object inMemoryAsset = item.inMemoryAsset;
				if (!(inMemoryAsset is Bitmap2D bitmap2D))
				{
					if (!(inMemoryAsset is Bitmap3D bitmap3D))
					{
						if (!(inMemoryAsset is BitmapCube bitmapCube))
						{
							throw new NotImplementedException("Unsupported in memory asset type: " + item.inMemoryAsset.GetType());
						}
						await default(ToBackground);
						uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(bitmapCube).ConfigureAwait(continueOnCapturedContext: false);
						await default(ToWorld);
					}
					else
					{
						await default(ToBackground);
						uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(bitmap3D).ConfigureAwait(continueOnCapturedContext: false);
						await default(ToWorld);
					}
				}
				else
				{
					await default(ToBackground);
					uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(bitmap2D).ConfigureAwait(continueOnCapturedContext: false);
					await default(ToWorld);
				}
			}
			else if (item.assetUri != null)
			{
				uri = item.assetUri;
			}
			else
			{
				await default(ToBackground);
				Bitmap2D bitmap2D2 = Bitmap2D.Load(item.filePath, false);
				if (bitmap2D2.Size.x != 1024 || bitmap2D2.Size.y < 32)
				{
					return Elements.Core.Result.Failure("LUT is Incompatible size");
				}
				Bitmap3D bitmap3D2 = new Bitmap3D(32, 32, 32, TextureFormat.RGBA32, mipmaps: false, bitmap2D2.Profile);
				for (int i = 0; i < 32; i++)
				{
					for (int j = 0; j < 1024; j++)
					{
						int x = j % 32;
						int z = j / 32;
						bitmap3D2.SetPixel(x, i, z, bitmap2D2.GetPixel(j, i));
					}
				}
				uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(bitmap3D2).ConfigureAwait(continueOnCapturedContext: false);
				await default(ToWorld);
			}
			UniversalImporter.SpawnVolume(targetSlot, uri, Elements.Core.float3.One * 0.2f);
			return Elements.Core.Result.Success();
		}

		public static async Task<Elements.Core.Result> ImportImage(ImportItem item, Slot targetSlot, bool addCollider = true, ImageProjection projection = ImageProjection.Perspective, StereoLayout stereoLayout = StereoLayout.None, Elements.Core.float3? forward = null, TextureConversion convert = TextureConversion.Auto, bool setupScreenshotMetadata = false, bool pointFiltering = false, bool uncompressed = false, bool alphaBleed = false, bool stripMetadata = false)
		{
			Uri uri;
			if (item.inMemoryAsset != null)
			{
				object inMemoryAsset = item.inMemoryAsset;
				if (!(inMemoryAsset is Bitmap2D bitmap2D))
				{
					if (!(inMemoryAsset is Bitmap3D bitmap3D))
					{
						if (!(inMemoryAsset is BitmapCube bitmapCube))
						{
							return Elements.Core.Result.Failure("Unsupported in memory asset type: " + item.inMemoryAsset.GetType());
						}
						await default(ToBackground);
						uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(bitmapCube).ConfigureAwait(continueOnCapturedContext: false);
						await default(ToWorld);
					}
					else
					{
						await default(ToBackground);
						uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(bitmap3D).ConfigureAwait(continueOnCapturedContext: false);
						await default(ToWorld);
					}
				}
				else
				{
					await default(ToBackground);
					uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(bitmap2D).ConfigureAwait(continueOnCapturedContext: false);
					await default(ToWorld);
				}
			}
			else if (item.assetUri != null)
			{
				uri = item.assetUri;
			}
			else
			{
				uri = new Uri(item.filePath);
				if (!uri.IsWellFormedOriginalString())
				{
					await default(ToBackground);
					LocalDB localDB = targetSlot.World.Engine.LocalDB;
					LocalDB.ImportLocation location = LocalDB.ImportLocation.Copy;
					string text = item.filePath;
					if (stripMetadata)
					{
						string tempFilePath = localDB.GetTempFilePath(item.extension);
						if (!TextureEncoder.ClearMetadata(text, tempFilePath))
						{
							return Elements.Core.Result.Failure("Unable to strip meta-data.");
						}
						location = LocalDB.ImportLocation.Move;
						text = tempFilePath;
					}
					if (convert != TextureConversion.Auto)
					{
						string text2 = ConvertImage(text, convert, localDB);
						if (text2 != text)
						{
							text = text2;
							location = LocalDB.ImportLocation.Move;
						}
					}
					uri = await localDB.ImportLocalAssetAsync(text, location).ConfigureAwait(continueOnCapturedContext: false);
					await default(ToWorld);
				}
			}
			targetSlot.Name = item.itemName;
			if (forward.HasValue)
			{
				targetSlot.LocalRotation = Elements.Core.floatQ.FromToRotation(forward.Value, Elements.Core.float3.Forward);
			}
			StaticTexture2D tex = targetSlot.AttachComponent<StaticTexture2D>();
			tex.URL.Value = uri;
			if (pointFiltering)
			{
				tex.FilterMode.Value = TextureFilterMode.Point;
			}
			if (uncompressed)
			{
				tex.Uncompressed.Value = true;
				tex.PowerOfTwoAlignThreshold.Value = 0f;
			}
			if (alphaBleed)
			{
				await tex.BleedColorToAlpha();
			}
			SetupTextureProxyComponents(targetSlot, tex, stereoLayout, projection, setupScreenshotMetadata);
			if (projection != ImageProjection.Perspective)
			{
				Create360Sphere(targetSlot, tex, stereoLayout, projection, addCollider);
			}
			else
			{
				while (!tex.IsAssetAvailable)
				{
					await default(NextUpdate);
				}
				CreateQuad(targetSlot, tex, stereoLayout, addCollider);
			}
			if (setupScreenshotMetadata)
			{
				targetSlot.GetComponentInChildren<PhotoMetadata>()?.NotifyOfScreenshot();
			}
			return Elements.Core.Result.Success();
		}

		private static string ConvertImage(string path, TextureConversion conversion, LocalDB db)
		{
			switch (conversion)
			{
			case TextureConversion.PNG:
			{
				string tempFilePath = db.GetTempFilePath("png");
				TextureEncoder.ConvertToPNG(path, tempFilePath);
				return tempFilePath;
			}
			case TextureConversion.JPEG:
			{
				string tempFilePath = db.GetTempFilePath("jpg");
				TextureEncoder.ConvertToJPG(path, tempFilePath);
				return tempFilePath;
			}
			case TextureConversion.WEBP:
			{
				string tempFilePath = db.GetTempFilePath("webp");
				TextureEncoder.ConvertToWEBP(path, tempFilePath);
				return tempFilePath;
			}
			default:
				return path;
			}
		}
	}
