				gaussianSplatUploadRaw.positionsBuffer = GetDescriptor(cloud.PositionsBuffer, cloud.Positions);
				gaussianSplatUploadRaw.rotationsBuffer = GetDescriptor(cloud.RotationsBuffer, cloud.Rotations);
				gaussianSplatUploadRaw.scalesBuffer = GetDescriptor(cloud.ScalesBuffer, cloud.Scales);
				gaussianSplatUploadRaw.colorsBuffer = GetDescriptor(cloud.ColorDataBuffer, cloud.RawColorData);
				gaussianSplatUploadRaw.alphasBuffer = GetDescriptor(cloud.AlphasBuffer, cloud.Alphas);
