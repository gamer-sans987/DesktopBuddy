		public LocomotionBipedFeet SetupTwoFeet(float separation, float backwardsOffset)
		{
			LocomotionFoot locomotionFoot = new LocomotionFoot(this, "Left");
			LocomotionFoot locomotionFoot2 = new LocomotionFoot(this, "Right");
			locomotionFoot.SetOpposingFoot(locomotionFoot2);
			locomotionFoot2.SetOpposingFoot(locomotionFoot);
			_feet.Add(locomotionFoot);
			_feet.Add(locomotionFoot2);
			LocomotionBipedFeet result = new LocomotionBipedFeet(locomotionFoot, locomotionFoot2);
			result.SetRestingPosition(separation, backwardsOffset);
			locomotionFoot.Initialize();
			locomotionFoot2.Initialize();
			return result;
		}

		public LocomotionBipedHands SetupTwoHands(float shoulderSeparation, float shoulderHeight, float shoulderOffset, float armLength, float handOffset)
		{
			LocomotionHand locomotionHand = new LocomotionHand(this, _feet.FirstOrDefault((LocomotionFoot f) => f.Name == "Right"), Chirality.Left, "Left");
			LocomotionHand locomotionHand2 = new LocomotionHand(this, _feet.FirstOrDefault((LocomotionFoot f) => f.Name == "Left"), Chirality.Right, "Right");
			_hands.Add(locomotionHand);
			_hands.Add(locomotionHand2);
			LocomotionBipedHands result = new LocomotionBipedHands(locomotionHand, locomotionHand2);
			result.SetRestingPosition(shoulderSeparation, shoulderHeight, shoulderOffset, armLength, handOffset);
			locomotionHand.Initialize();
			locomotionHand2.Initialize();
			return result;
		}

		private void ComputeActualParameters()
		{
			if (_parameters.Count == 0)
			{
				return;
			}
			if (_parameters.Count == 1)
			{
				CurrentParameters = _parameters[0];
				ReadBaseFingerPose(CurrentParameters.FingerBasePose);
				return;
			}
			int num = 0;
			for (int i = 0; i < _parameters.Count && !(_parameters[i].ReferenceSpeed > SmoothVelocity); i++)
			{
				num = i;
			}
			if (num == _parameters.Count - 1)
			{
				CurrentParameters = _parameters[_parameters.Count - 1];
				ReadBaseFingerPose(CurrentParameters.FingerBasePose);
				return;
			}
			LocomotionGaitParameters locomotionGaitParameters = _parameters[num];
			LocomotionGaitParameters to = _parameters[num + 1];
			float value = MathX.InverseLerp(locomotionGaitParameters.ReferenceSpeed, to.ReferenceSpeed, SmoothVelocity);
			value = MathX.FilterInvalid(value);
			CurrentParameters = LocomotionGaitParameters.Lerp(locomotionGaitParameters, to, value);
			ComputeBaseFingerPoses(locomotionGaitParameters.FingerBasePose, to.FingerBasePose, value);
		}

		private void ClearFingerPoses()
		{
			TracksMetacarpals = false;
			_leftBasePositions.Clear();
			_leftBaseRotations.Clear();
			_rightBasePositions.Clear();
			_rightBaseRotations.Clear();
		}

		private void ReadBaseFingerPose(IFingerPoseSource source)
		{
			if (source == null)
			{
				ClearFingerPoses();
				return;
			}
			TracksMetacarpals = source.TracksMetacarpals;
			ReadBaseFingerPose(Chirality.Left, source, _leftBasePositions, _leftBaseRotations);
			ReadBaseFingerPose(Chirality.Right, source, _rightBasePositions, _rightBaseRotations);
			BlendAdditionalPoses();
		}

		private void ReadBaseFingerPose(Chirality side, IFingerPoseSource source, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			positions.Clear();
			rotations.Clear();
			if (source.AreFingersTracking(side))
			{
				source.GetFingerData(side, positions, rotations);
				FingerPoseHelper.TransformPosesToHierarchy(positions, rotations);
			}
		}

		private void ComputeBaseFingerPoses(IFingerPoseSource from, IFingerPoseSource to, float lerp)
		{
			if (from != null && to != null)
			{
				TracksMetacarpals = from.TracksMetacarpals && to.TracksMetacarpals;
				LerpFingerPoses(Chirality.Left, _leftBasePositions, _leftBaseRotations, from, to, lerp);
				LerpFingerPoses(Chirality.Right, _rightBasePositions, _rightBaseRotations, from, to, lerp);
				BlendAdditionalPoses();
			}
			else
			{
				ClearFingerPoses();
			}
		}

		private void BlendAdditionalPoses()
		{
			if (AirLerp > 0f && InAirFingerBasePose != null)
			{
				if (LeftFingersTracking)
				{
					BlendAdditionalPoses(Chirality.Left, _leftBasePositions, _leftBaseRotations, InAirFingerBasePose, AirLerp);
				}
				if (RightFingersTracking)
				{
					BlendAdditionalPoses(Chirality.Right, _rightBasePositions, _rightBaseRotations, InAirFingerBasePose, AirLerp);
				}
			}
			if (FloatingLerp > 0f && FloatingFingerBasePose != null)
			{
				if (LeftFingersTracking)
				{
					BlendAdditionalPoses(Chirality.Left, _leftBasePositions, _leftBaseRotations, FloatingFingerBasePose, FloatingLerp);
				}
				if (RightFingersTracking)
				{
					BlendAdditionalPoses(Chirality.Right, _rightBasePositions, _rightBaseRotations, FloatingFingerBasePose, FloatingLerp);
				}
			}
		}

		internal void GetBaseFingerData(Chirality side, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations)
		{
			if (side == Chirality.Left)
			{
				positions.AddRange(_leftBasePositions);
				rotations.AddRange(_leftBaseRotations);
			}
			else
			{
				positions.AddRange(_rightBasePositions);
				rotations.AddRange(_rightBaseRotations);
			}
		}

		private void LerpFingerPoses(Chirality side, List<Elements.Core.float3> positions, List<Elements.Core.floatQ> rotations, IFingerPoseSource from, IFingerPoseSource to, float lerp)
		{
			if (!from.AreFingersTracking(side) || !to.AreFingersTracking(side))
			{
				positions.Clear();
				rotations.Clear();
				return;
			}
			lerp = MathX.Clamp01(lerp);
			List<Elements.Core.float3> list = Pool.BorrowList<Elements.Core.float3>();
			List<Elements.Core.floatQ> list2 = Pool.BorrowList<Elements.Core.floatQ>();
			List<Elements.Core.float3> list3 = Pool.BorrowList<Elements.Core.float3>();
			List<Elements.Core.floatQ> list4 = Pool.BorrowList<Elements.Core.floatQ>();
			from.GetFingerData(side, list, list2);
			to.GetFingerData(side, list3, list4);
			FingerPoseHelper.TransformPosesToHierarchy(list, list2);
			FingerPoseHelper.TransformPosesToHierarchy(list3, list4);
			FingerPoseHelper.InterpolatePoses(list, list2, list3, list4, lerp, positions, rotations);
			Pool.Return(ref list);
			Pool.Return(ref list2);
			Pool.Return(ref list3);
			Pool.Return(ref list4);
		}

		private void BlendAdditionalPoses(Chirality side, List<Elements.Core.float3> basePositions, List<Elements.Core.floatQ> baseRotations, IFingerPoseSource to, float lerp)
		{
			if (to != null && to.AreFingersTracking(side))
			{
				List<Elements.Core.float3> list = Pool.BorrowList<Elements.Core.float3>();
				List<Elements.Core.floatQ> list2 = Pool.BorrowList<Elements.Core.floatQ>();
				to.GetFingerData(side, list, list2);
				FingerPoseHelper.TransformPosesToHierarchy(list, list2);
				FingerPoseHelper.InterpolatePoses(basePositions, baseRotations, list, list2, lerp, basePositions, baseRotations);
				Pool.Return(ref list);
				Pool.Return(ref list2);
			}
		}

		public void Update(Elements.Core.float3 positionDelta, Elements.Core.floatQ rotationDelta, float deltaTime, LocomotionState state, float headCrouchOffset)
		{
			float num = 1f / deltaTime;
			_ = positionDelta.Magnitude;
			MoveData data = new MoveData(positionDelta, rotationDelta, deltaTime);
			if (State == LocomotionState.InAir && state == LocomotionState.OnGround)
			{
				LastLandingVelocity = CurrentPositionVelocity;
			}
			State = state;
			HeadCrouchOffset = headCrouchOffset;
			CrouchLerp = MathX.Clamp01(headCrouchOffset / (Height * 0.5f));
			AirLerp = MathX.Progress01(AirLerp, deltaTime * 10f, State == LocomotionState.InAir);
			FloatingLerp = MathX.Progress01(FloatingLerp, deltaTime * 10f, State == LocomotionState.Floating);
			MaxFootStepHeight = Height * 0.5f;
			MaxFootStepHeight -= headCrouchOffset;
			MaxFootStepHeight = MathX.Max(0.1f, MaxFootStepHeight);
			CurrentPositionVelocity = positionDelta * num;
			CurrentAngularVelocity = MathX.Pow(in rotationDelta, num);
			CurrentVelocity = CurrentPositionVelocity.x_z.Magnitude;
			CurrentAngularVelocityMagnitude = MathX.Angle(Elements.Core.floatQ.Identity, CurrentAngularVelocity);
			float val = GaitParameters[GaitParameters.Count - 1].ReferenceSpeed * 2f;
			float val2 = ((CurrentVelocity > SmoothVelocity) ? CurrentParameters.VelocityIncreaseSmoothTime : CurrentParameters.VelocityDecreaseSmoothTime);
			SmoothVelocity = MathX.SmoothDamp(SmoothVelocity, MathX.Min(CurrentVelocity, val), ref _intermediateVelocity, MathX.Max(1f, val2), 25f, deltaTime);
			SmoothVerticalVelocity = MathX.SmoothDamp(SmoothVerticalVelocity, CurrentPositionVelocity.y, ref _intermediateVerticalVelocity, 50f, 25f, deltaTime);
			IsStandingStill = SmoothVelocity < StillVelocityThreshold;
			if (State != LocomotionState.OnGround)
			{
				AirReferenceLerp = MathX.Clamp(CurrentPositionVelocity.y / MaxVerticalReferenceSpeed, -1f, 1f);
			}
			else
			{
				AirReferenceLerp = 0f;
			}
			ComputeActualParameters();
			SidewaysLerp = MathX.Abs(MathX.Dot(Elements.Core.float3.Right, in data.positionDir));
			ForwardsLerp = MathX.Max(0f, MathX.Dot(Elements.Core.float3.Forward, in data.positionDir));
			BackwardsLerp = MathX.Max(0f, MathX.Dot(Elements.Core.float3.Backward, in data.positionDir));
			DirectionTravelRatio = MathX.LerpUnclamped(MathX.LerpUnclamped(1f, CurrentParameters.FootBackwardsDistanceRatio, BackwardsLerp), CurrentParameters.FootSidewaysDistanceRatio, SidewaysLerp);
			DirectionFootTravelDistance = CurrentParameters.FootTravelDistance * DirectionTravelRatio;
			MinVelocityLerp = MathX.Clamp01((SmoothVelocity - StillVelocityThreshold) / MinFullTravelDistanceSpeed);
			ActualFootTravelDistance = DirectionFootTravelDistance * MinVelocityLerp;
			float num2 = MathX.Angle(Elements.Core.floatQ.Identity, MathX.Pow(CurrentAngularVelocity, ActualFootTravelDistance));
			if (num2 > CurrentParameters.FootMaxAngle)
			{
				TravelDistanceRatio = MathX.Clamp01(CurrentParameters.FootMaxAngle / num2);
				ActualFootTravelDistance *= TravelDistanceRatio;
			}
			else
			{
				TravelDistanceRatio = 1f;
			}
			Elements.Core.float3 v = Elements.Core.float3.Zero;
			Elements.Core.float3 v2 = Elements.Core.float3.Zero;
			foreach (LocomotionFoot foot in _feet)
			{
				foot.UpdateGround(in data);
				v += foot.BasePosition;
				v2 += foot.RestingPosition;
			}
			if (_feet.Count > 0)
			{
				v /= _feet.Count;
				v2 /= _feet.Count;
			}
			CurrentCenter = v;
			RestingCenter = v2;
			if (data.positionDir == Elements.Core.float3.Zero)
			{
				CenterOffset = Elements.Core.float3.Zero;
			}
			else
			{
				Elements.Core.floatQ q = Elements.Core.floatQ.FromToRotation(Elements.Core.float3.Forward, in data.positionDir);
				LocomotionGaitParameters currentParameters = CurrentParameters;
				CenterOffset = q * currentParameters.Offset * DirectionTravelRatio;
			}
			foreach (LocomotionHand hand in _hands)
			{
				hand.UpdateGround(in data);
			}
			foreach (LocomotionFoot foot2 in _feet)
			{
				if (foot2.WantsToMove)
				{
					_feetToMove.Add(foot2);
				}
			}
			_feetToMove.Sort((LocomotionFoot a, LocomotionFoot b) => -a.MovePriority.CompareTo(b.MovePriority));
			foreach (LocomotionFoot item in _feetToMove)
			{
				if (!item.WantsToMove)
				{
					continue;
				}
				if (item.OpposingFoot != null)
				{
					if (item.OpposingFoot.CurrentState == LocomotionFoot.State.HasFooting || (item.OpposingFoot.CurrentState == LocomotionFoot.State.IsTravelling && item.OpposingFoot.TravelProgress >= CurrentParameters.MinOpposingProgress))
					{
						item.StartTravelling(in data);
					}
					continue;
				}
				bool flag = false;
				foreach (LocomotionFoot foot3 in _feet)
