	public class AssetMetadataManager
	{
		private ActionBlock<Func<Task>> processor;

		private Dictionary<Uri, Task<IAssetMetadata>> metadataComputationTasks = new Dictionary<Uri, Task<IAssetMetadata>>();

		public AssetManager AssetManager { get; private set; }

		public Engine Engine => AssetManager.Engine;

		public EngineSkyFrostInterface Cloud => Engine.Cloud;

		public AssetMetadataManager(AssetManager manager, int maxDegreeOfParallelism)
		{
			AssetManager = manager;
			processor = new ActionBlock<Func<Task>>(async delegate(Func<Task> t)
			{
				await t().ConfigureAwait(continueOnCapturedContext: false);
			}, new ExecutionDataflowBlockOptions
			{
				EnsureOrdered = true,
				MaxDegreeOfParallelism = maxDegreeOfParallelism
			});
		}

		public Task<T> FetchCloudMetadata<T>(string hash) where T : class, IAssetMetadata, new()
		{
			return Cloud.MetadataBatch<T>().Request(hash);
		}

		public async Task<T> ComputeMetadata<T>(Uri uri) where T : class, IAssetMetadata, new()
		{
			Task<IAssetMetadata> value;
			lock (metadataComputationTasks)
			{
				if (!metadataComputationTasks.TryGetValue(uri, out value))
				{
					TaskCompletionSource<IAssetMetadata> completionSource = new TaskCompletionSource<IAssetMetadata>();
					DateTime computationStart = DateTime.UtcNow;
					processor.Post(async delegate
					{
						_ = 1;
						try
						{
							if ((DateTime.UtcNow - computationStart).TotalSeconds > 10.0 && uri.Scheme == Cloud.Assets.DBScheme)
							{
								T val = await AssetManager.Cloud.MetadataBatch<T>().Request(Cloud.Assets.DBSignature(uri));
								if (val != null)
								{
									completionSource.SetResult(val);
									return;
								}
							}
							IAssetMetadata result2 = await ComputeMetadataIntern<T>(uri).ConfigureAwait(continueOnCapturedContext: false);
							completionSource.SetResult(result2);
						}
						catch (Exception exception)
						{
							completionSource.SetException(exception);
						}
					});
					value = completionSource.Task;
					metadataComputationTasks.Add(uri, value);
				}
			}
			T result = (await value.ConfigureAwait(continueOnCapturedContext: false)) as T;
			if (result != null)
			{
				await Engine.LocalDB.SaveAssetMetadataAsync(result).ConfigureAwait(continueOnCapturedContext: false);
			}
			Task.Run(async delegate
			{
				await Task.Delay(TimeSpan.FromMinutes(1L)).ConfigureAwait(continueOnCapturedContext: false);
				lock (metadataComputationTasks)
				{
					metadataComputationTasks.Remove(uri);
				}
			});
			return result;
		}

		private async Task<IAssetMetadata> ComputeMetadataIntern<T>(Uri assetURL) where T : class, IAssetMetadata, new()
		{
			string asset = await Engine.AssetManager.GatherAssetFile(assetURL, 0f).ConfigureAwait(continueOnCapturedContext: false);
			if (asset == null || !File.Exists(asset))
			{
				UniLog.Warning($"Failed to gather {assetURL}, cannot compute metadata!");
				return null;
			}
			await default(ToBackground);
			T val = AssetMetadataHelper.ComputeMetadata<T>(asset);
			if (assetURL.Scheme == Cloud.Assets.DBScheme)
			{
				val.AssetIdentifier = Cloud.Assets.DBSignature(assetURL);
			}
			else
			{
				val.AssetIdentifier = assetURL.ToString();
			}
			return val;
		}
	}
	public class AssetVariantGenerator
	{
		private class ComputeTask
		{
			public readonly string key;

			public readonly Uri assetUrl;

			public readonly string baseFile;

			public readonly IAssetVariantDescriptor variantDescriptor;

			public readonly DateTime CreationTime;

			private bool finished;

			private Dictionary<string, TaskCompletionSource<string>> variantResults = new Dictionary<string, TaskCompletionSource<string>>();

			public float AgeSeconds => (float)(DateTime.UtcNow - CreationTime).TotalSeconds;

			public ComputeTask(string key, Uri assetUrl, string baseFile, IAssetVariantDescriptor variantDescriptor)
			{
				this.key = key;
				this.assetUrl = assetUrl;
				this.baseFile = baseFile;
				this.variantDescriptor = variantDescriptor;
				CreationTime = DateTime.UtcNow;
			}

			internal Task<string> GetVariant(string variant)
			{
				TaskCompletionSource<string> value;
				lock (variantResults)
				{
					if (finished)
					{
						value = new TaskCompletionSource<string>();
						value.SetResult(null);
						return value.Task;
					}
					if (!variantResults.TryGetValue(variant, out value))
					{
						value = new TaskCompletionSource<string>();
						variantResults.Add(variant, value);
					}
				}
				return value.Task;
			}

			internal void SetVariant(string variant, string file)
			{
				TaskCompletionSource<string> value;
				lock (variantResults)
				{
					if (!variantResults.TryGetValue(variant, out value))
					{
						value = new TaskCompletionSource<string>();
						variantResults.Add(variant, value);
					}
				}
				value.SetResult(file);
			}

			internal void Finish()
			{
				lock (variantResults)
				{
					finished = true;
					foreach (KeyValuePair<string, TaskCompletionSource<string>> variantResult in variantResults)
					{
						if (!variantResult.Value.Task.IsCompleted)
						{
							variantResult.Value.TrySetResult(null);
						}
					}
				}
			}
		}

		private Dictionary<string, ComputeTask> computeTasks = new Dictionary<string, ComputeTask>();

		private ActionBlock<ComputeTask> processor;

		private readonly int maxThreads;

		public AssetManager AssetManager { get; private set; }

		public Engine Engine => AssetManager.Engine;

		public EngineSkyFrostInterface Cloud => Engine.Cloud;

		public LocalDB LocalDB => Engine.LocalDB;

		public AssetVariantGenerator(AssetManager manager, int maxThreads, int maxDegreeOfParallelism)
		{
			this.maxThreads = maxThreads;
			AssetManager = manager;
			processor = new ActionBlock<ComputeTask>((Func<ComputeTask, Task>)ComputeVariant, new ExecutionDataflowBlockOptions
			{
				EnsureOrdered = true,
				MaxDegreeOfParallelism = maxDegreeOfParallelism
			});
		}

		private async Task ComputeVariant(ComputeTask computeTask)
		{
			try
			{
				if (!File.Exists(computeTask.baseFile))
				{
					UniLog.Log("BaseFile doesn't exist: " + computeTask.baseFile);
					return;
				}
				if (computeTask.assetUrl.Scheme == Cloud.Assets.DBScheme && computeTask.AgeSeconds > 10f)
				{
					List<IAssetVariantDescriptor> list = computeTask.variantDescriptor.GenerateCloudChainNonGeneric();
					bool gotAll = true;
					foreach (IAssetVariantDescriptor item2 in list)
					{
						string variantIdentifier = item2.VariantIdentifier;
						string text = await Engine.AssetManager.GatherAssetFile(new Uri(computeTask.assetUrl, "?" + item2.VariantIdentifier), 100f).ConfigureAwait(continueOnCapturedContext: false);
						if (text != null)
						{
							computeTask.SetVariant(variantIdentifier, text);
							if (gotAll)
							{
								return;
							}
							continue;
						}
						break;
					}
				}
				await default(ToBackground);
				List<Task> finishTasks = Pool.BorrowList<Task>();
				AssetVariantHelper.GenerateVariants(computeTask.baseFile, computeTask.variantDescriptor, maxThreads, delegate(ComputedVariantResult generatedVariant)
				{
					Task item = Task.Run(async delegate
					{
						string file = null;
						string identifier = generatedVariant.identifier;
						if (generatedVariant.file != null)
						{
							file = await LocalDB.StoreCacheRecordAsync(new Uri(computeTask.assetUrl, "?" + identifier), generatedVariant.file);
						}
						else
						{
							UniLog.Warning("Could not generate: " + identifier);
						}
						computeTask.SetVariant(identifier, file);
					});
					finishTasks.Add(item);
				});
				await Task.WhenAll(finishTasks).ConfigureAwait(continueOnCapturedContext: false);
				Pool.Return(ref finishTasks);
			}
			catch (ThreadAbortException)
			{
			}
			catch (Exception ex2)
			{
				UniLog.Error($"Exception when computing variants for {computeTask.assetUrl}. Variant: {computeTask.variantDescriptor.VariantIdentifier}:\n" + ex2);
			}
			finally
			{
				computeTask.Finish();
				Task.Run(async delegate
				{
					await Task.Delay(TimeSpan.FromMinutes(1L)).ConfigureAwait(continueOnCapturedContext: false);
					lock (computeTasks)
					{
						computeTasks.Remove(computeTask.key);
					}
				});
			}
		}

		public async Task<string> ComputeVariant(Uri assetUrl, string baseFile, string variant, IAssetVariantDescriptor variantDescriptor)
		{
			string key = baseFile + "-" + variantDescriptor.VariantIdentifier;
			ComputeTask value = null;
			lock (computeTasks)
			{
				if (!computeTasks.TryGetValue(key, out value))
				{
					value = new ComputeTask(key, assetUrl, baseFile, variantDescriptor);
					computeTasks.Add(key, value);
					processor.Post(value);
				}
			}
			return await value.GetVariant(variant).ConfigureAwait(continueOnCapturedContext: false);
		}
	}
