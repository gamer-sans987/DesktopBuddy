	public static class MinecraftImporter
	{
		public static string MinewaysPath = "C:\\Program Files\\mineways\\mineways.exe";

		public static string WorkingDirectory = null;

		[FolderImporter("Importer.Folder.Minecraft", "Importer.Folder.Minecraft.Description")]
		public static void ImportMinecraftFolder(Slot root, string path)
		{
			root.World.Coroutines.StartTask(async delegate
			{
				root.PersistentSelf = false;
				ProgressBarInterface progress = await root.SpawnEntity<ProgressBarInterface, LegacySegmentCircleProgress>(FavoriteEntity.ProgressBar);
				progress.Initialize(canBeHidden: false);
				progress.UpdateProgress(-1f, "Waiting", "");
				try
				{
					await SyncMinecraftWorld(root.World, path, 64, progress.WrapSynchronously(root.World));
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception importing Minecraft world:\n" + ex);
					progress.ProgressFail("Failed!");
				}
			});
		}

		public static async Task SyncMinecraftWorld(World world, string minecraftWorldPath, int groupSize = 64, IProgressIndicator progress = null)
		{
			progress?.UpdateProgress(-1f, "Searching for Mineways...", "");
			string minewaysExecutable = MinewaysPath;
			if (!File.Exists(minewaysExecutable))
			{
				minewaysExecutable = Path.Combine(world.Engine.AppPath, "Tools\\Mineways\\mineways.exe");
			}
			if (!File.Exists(minewaysExecutable))
			{
				throw new Exception("Mineways.exe not found!");
			}
			MinecraftEngineData data = new MinecraftEngineData(world, groupSize);
			await default(ToBackground);
			string text = WorkingDirectory;
			if (string.IsNullOrWhiteSpace(text))
			{
				text = Path.Combine(world.Engine.CachePath, "MinecraftStaging");
			}
			text = Path.Combine(text, Guid.NewGuid().ToString());
			if (Directory.Exists(text))
			{
				Directory.Delete(text, recursive: true);
			}
			Directory.CreateDirectory(text);
			new BufferBlock<MinecraftGroupData>();
			BufferBlock<MinecraftGroupData> groups = await ExportGroups(data, minewaysExecutable, minecraftWorldPath, text, groupSize, progress);
			if (groups != null)
			{
				await default(ToWorld);
				progress?.UpdateProgress(-1f, "Importing chunks", "");
				ModelImportSettings importSettings = ModelImportSettings.PBS(generateColliders: false, importBones: false, importAnimations: false, pbsUnlit: false, mapExternalTextures: false, preferSpecular: true);
				importSettings.Center = false;
				importSettings.CalculateTextureAlpha = false;
				importSettings.ForceNoMipmaps = true;
				importSettings.ForcePointFiltering = true;
				importSettings.ForceCompression = TextureCompression.RawRGBA;
				int count = 0;
				while (await groups.OutputAvailableAsync())
				{
					MinecraftGroupData group = await groups.ReceiveAsync();
					progress?.UpdateProgress((float)count / (float)groups.Count, $"Generating group {group.chunkPosition}", "Importing geometry");
					Slot groupRoot = data.GetGroupRoot(group.chunkPosition);
					groupRoot.DestroyChildren();
					Slot originalAssets = groupRoot.AddSlot("Import Assets");
					await ModelImporter.ImportModelAsync(group.file, groupRoot, importSettings, originalAssets);
					progress?.UpdateProgress((float)count / (float)groups.Count, $"Generating group {group.chunkPosition}", "Setting up group");
					await data.SetupGroup(groupRoot, group);
					originalAssets.DestroyPreservingAssets();
					count++;
				}
				data.FinishImport();
				UniLog.Log($"Minecraft Map Import Finished! Processed chunks: {data.TotalChunkCount}, New/Updated chunks: {data.UpdatedChunkCount}, Elapsed: {data.Elapsed}");
				progress?.ProgressDone("Map imported!");
			}
		}

		private static async Task<BufferBlock<MinecraftGroupData>> ExportGroups(MinecraftEngineData data, string minewaysExe, string minecraftWorldPath, string workingDir, int groupSize, IProgressIndicator progress)
		{
			string text = Path.Combine(workingDir, "Groups");
			string text2 = Path.Combine(workingDir, "Script.mwscript");
			Directory.CreateDirectory(text);
			StringBuilder stringBuilder = new StringBuilder();
			StringBuilder stringBuilder2 = stringBuilder;
			StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(17, 1, stringBuilder2);
			handler.AppendLiteral("Minecraft world: ");
			handler.AppendFormatted(minecraftWorldPath);
			stringBuilder2.AppendLine(ref handler);
			stringBuilder.AppendLine("Set render type: Wavefront OBJ absolute indices");
			stringBuilder.AppendLine("File type: Export tiles for textures to directory texture");
			stringBuilder.AppendLine("Create block faces at the borders: no");
			stringBuilder.AppendLine("Center model: YES");
			progress?.UpdateProgress(-1f, "Analyzing Minecraft Data", "");
			NbtWorld nbtWorld = NbtWorld.Open(minecraftWorldPath);
			if (nbtWorld == null)
			{
				progress?.ProgressFail("Failed to decode Minecraft world");
				return null;
			}
			IChunkManager chunkManager = nbtWorld.GetChunkManager();
			Dictionary<Elements.Core.int2, MinecraftGroupData> dictionary = new Dictionary<Elements.Core.int2, MinecraftGroupData>();
			Dictionary<string, MinecraftGroupData> groupsByFilePath = new Dictionary<string, MinecraftGroupData>();
			int num = 0;
			foreach (ChunkRef item in chunkManager)
			{
				if (item.UsesPalette)
				{
					if (item.Status != "full" && item.Status != "minecraft:full")
					{
						continue;
					}
				}
				else if (item.Blocks == null || (item.Status != null && item.Status != "full") || item.Blocks.IsEmpty())
				{
					continue;
				}
				progress?.UpdateProgress(-1f, "Analyzing Minecraft Data", $"Chunk {item.X}x{item.Z}");
				num++;
				int num2 = 16;
				int num3 = 16;
				int x = item.X * num2;
				int y = item.Z * num3;
				Elements.Core.int2 globalChunkCoordinate = new Elements.Core.int2(x, y);
				if (data.ShouldUpdateChunk(globalChunkCoordinate, item.LastUpdate))
				{
					Elements.Core.int2 @int = data.ChunkCoordinateToGroup(globalChunkCoordinate);
					int num4 = @int.x * groupSize;
					int num5 = @int.y * groupSize;
					int groupEndX = num4 + groupSize;
					int groupEndZ = num5 + groupSize;
					if (!dictionary.TryGetValue(@int, out var value))
					{
						string text3 = $"{text}\\Group_{@int.x}x{@int.y}.obj";
						value = new MinecraftGroupData(@int, text3, num4, num5, groupEndX, groupEndZ, -64, 320);
						dictionary.Add(@int, value);
						groupsByFilePath.Add(text3, value);
					}
				}
			}
			progress?.UpdateProgress(-1f, "Writing export script", "");
			List<MinecraftGroupData> list = dictionary.Values.ToList();
			list.Sort((MinecraftGroupData a, MinecraftGroupData b) => a.distanceFromOrigin.CompareTo(b.distanceFromOrigin));
			foreach (MinecraftGroupData item2 in list)
			{
				item2.GenerateExportCommand(stringBuilder);
			}
			stringBuilder.AppendLine("Close");
			File.WriteAllText(text2, stringBuilder.ToString());
			progress?.UpdateProgress(-1f, "Exporting chunk geometry", "");
			ProcessStartInfo startInfo = new ProcessStartInfo(minewaysExe, "-s none \"" + text2 + "\"")
			{
				UseShellExecute = true
			};
			BufferBlock<MinecraftGroupData> bufferBlock = new BufferBlock<MinecraftGroupData>(new DataflowBlockOptions
			{
				EnsureOrdered = true
			});
			FileSystemWatcher watcher = new FileSystemWatcher(text);
			watcher.NotifyFilter = NotifyFilters.FileName;
			watcher.Filter = "*.obj";
			watcher.IncludeSubdirectories = false;
			watcher.Created += delegate(object sender, FileSystemEventArgs e)
			{
				bool isFinal = false;
				MinecraftGroupData groupData;
				lock (groupsByFilePath)
				{
					if (!groupsByFilePath.TryGetValue(e.FullPath, out groupData))
					{
						return;
					}
					groupsByFilePath.Remove(e.FullPath);
					isFinal = groupsByFilePath.Count == 0;
				}
				Task.Run(async delegate
				{
					await Task.Delay(TimeSpan.FromSeconds(10L));
					string materialPath = Path.ChangeExtension(e.FullPath, "mtl");
					while (!File.Exists(materialPath))
					{
						await Task.Delay(TimeSpan.FromMilliseconds(250L));
					}
					bufferBlock.Post(groupData);
					if (isFinal)
					{
						bufferBlock.Complete();
						watcher.Dispose();
					}
				});
			};
			watcher.EnableRaisingEvents = true;
			Process.Start(startInfo);
			return bufferBlock;
		}
	}
	public readonly struct MinecraftMaterialGroup : IEquatable<MinecraftMaterialGroup>
	{
		public readonly bool split;

		public readonly bool collision;

		public readonly AlphaHandling alphaHandling;

		public static MinecraftMaterialGroup Split()
		{
			return new MinecraftMaterialGroup(split: true);
		}

		private MinecraftMaterialGroup(bool split)
		{
			this.split = split;
			collision = false;
			alphaHandling = AlphaHandling.Opaque;
		}

		public MinecraftMaterialGroup(bool collision, AlphaHandling alphaHandling)
		{
			this.collision = collision;
			this.alphaHandling = alphaHandling;
			split = false;
		}

		public bool Equals(MinecraftMaterialGroup other)
		{
			if (collision == other.collision)
			{
				return alphaHandling == other.alphaHandling;
			}
			return false;
		}

		public override bool Equals(object obj)
		{
			if (obj is MinecraftMaterialGroup other)
			{
				return Equals(other);
			}
			return false;
		}

		public override int GetHashCode()
		{
			return (1847732829 * -1521134295 + collision.GetHashCode()) * -1521134295 + alphaHandling.GetHashCode();
		}

		public static bool operator ==(MinecraftMaterialGroup left, MinecraftMaterialGroup right)
		{
			return left.Equals(right);
		}

		public static bool operator !=(MinecraftMaterialGroup left, MinecraftMaterialGroup right)
		{
			return !(left == right);
		}

		public override string ToString()
		{
			return $"{alphaHandling}{(collision ? "_Collision" : "")}";
		}
	}
	public static class MinecraftMaterialClassifier
	{
		private static HashSet<string> _noCollisionClip = new HashSet<string>
		{
			"grass", "seagrass", "tallgrass", "mushroom", "fern", "bush", "kelp", "rose", "lily", "tulip",
			"daisy", "lilac", "sunflower", "flower", "peony", "dandelion", "poppy", "orchid", "bluet", "cornflower",
			"pitcher", "plant", "wildflowers", "allium", "eyeblossom", "petals", "sapling", "potato", "carrot", "wheat",
			"beet", "cane", "vines", "beetroot", "cocoa", "cobweb", "fire", "vines", "lichen", "leaf",
			"fungus", "blossom", "roots", "sprouts"
		};

		public static MinecraftMaterialGroup Classify(string name)
		{
			UniLog.Log("Classifying: " + name);
			switch (name.ToLowerInvariant())
			{
			case "bamboo":
			case "sculk_sensor":
				return MinecraftMaterialGroup.Split();
			case "ladder":
			case "cactus":
			case "azalea":
			case "mangrove_roots":
			case "sculk_shrieker":
			case "lily_pad":
			case "monster_spawner":
			case "iron_bars":
			case "flowering_azalea":
			case "end_rod":
			case "scaffolding":
				return new MinecraftMaterialGroup(collision: true, AlphaHandling.AlphaClip);
			default:
			{
				List<string> list = NameHeuristicsHelper.SplitName(name);
				UniLog.Log("Split names: " + string.Join(", ", list));
				if (list.Contains("door") || list.Contains("torch"))
				{
					return new MinecraftMaterialGroup(collision: false, AlphaHandling.AlphaClip);
				}
				if ((list.Contains("redstone") && list.Contains("wire")) || (list.Contains("bamboo") && list.Contains("leaves")) || (list.Contains("amethyst") && (list.Contains("bud") || list.Contains("cluster"))) || (list.Contains("melon") && list.Contains("stem")) || (list.Contains("nether") && list.Contains("wart")) || (list.Contains("skulk") && (list.Contains("veins") || list.Contains("tendril"))) || (list.Contains("hanging") && list.Contains("moss")) || (list.Contains("coral") && !list.Contains("block")))
				{
					return new MinecraftMaterialGroup(collision: false, AlphaHandling.AlphaClip);
				}
				if (list.Contains("glass") || list.Contains("rail") || list.Contains("leaves"))
				{
					return new MinecraftMaterialGroup(collision: true, AlphaHandling.AlphaClip);
				}
				if (list.Contains("water"))
				{
					return new MinecraftMaterialGroup(collision: false, AlphaHandling.AlphaBlend);
				}
				if (list.Contains("ice"))
				{
					return new MinecraftMaterialGroup(collision: true, AlphaHandling.AlphaBlend);
				}
				if (!list.Contains("block") && !list.Contains("path") && !list.Contains("ore"))
				{
					if (list.Any((string n) => _noCollisionClip.Contains(n)))
					{
						return new MinecraftMaterialGroup(collision: false, AlphaHandling.AlphaClip);
					}
					if (list.Contains("snow"))
					{
						return new MinecraftMaterialGroup(collision: false, AlphaHandling.Opaque);
					}
				}
