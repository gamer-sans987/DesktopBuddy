		private static async Task ImportSessionUrl(World world, Uri url, Transform transform)
		{
			switch ((await Settings.GetActiveSettingAsync<ImportSettings>()).SessionUrls.Value)
			{
			case OpenableUrlImportPreference.SpawnInterface:
			{
				SessionInfo info = world.Engine.Cloud.Sessions.TryGetInfo(url);
				if (info == null)
				{
					CloudResult<SessionInfo> cloudResult = await world.Engine.Cloud.Sessions.GetSession(url);
					if (cloudResult.IsOK)
					{
						info = cloudResult.Entity;
					}
				}
				if (info != null)
				{
					WorldOrb.SpawnSessionOrb(world, info, transform);
				}
				break;
			}
			case OpenableUrlImportPreference.SpawnUrl:
				SpawnUrl(CreateAndPositionSlotForImport(world, "Session URL", transform.position, transform.rotation, transform.scale), url);
				break;
			default:
				await Userspace.OpenWorld(new WorldStartSettings(url));
				break;
			}
		}

