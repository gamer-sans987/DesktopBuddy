		}

		private static void PreprocessScene(Scene scene)
		{
			Assimp.Matrix4x4 localToGlobal = Assimp.Matrix4x4.FromScaling(new Vector3D(-1f, 1f, 1f));
			Assimp.Matrix4x4 localToGlobal2 = Assimp.Matrix4x4.Identity;
			Vector3D vector3D = new Vector3D(-1f, 1f, 1f);
			Dictionary<Assimp.Node, Assimp.Matrix4x4> matrices = new Dictionary<Assimp.Node, Assimp.Matrix4x4>();
			Dictionary<Assimp.Bone, Assimp.Matrix4x4> bones = new Dictionary<Assimp.Bone, Assimp.Matrix4x4>();
			Dictionary<NodeAnimationChannel, Assimp.Matrix4x4[]> dictionary = new Dictionary<NodeAnimationChannel, Assimp.Matrix4x4[]>();
			Dictionary<NodeAnimationChannel, Assimp.Matrix4x4[]> dictionary2 = new Dictionary<NodeAnimationChannel, Assimp.Matrix4x4[]>();
			foreach (Assimp.Animation animation in scene.Animations)
			{
				foreach (NodeAnimationChannel nodeAnimationChannel in animation.NodeAnimationChannels)
				{
					Assimp.Node node = FindNode(nodeAnimationChannel.NodeName, scene.RootNode);
					Assimp.Matrix4x4 matrix4x = localToGlobal * GetLocalToGlobal(node.Parent);
					if (nodeAnimationChannel.HasPositionKeys)
					{
						Assimp.Matrix4x4[] array = new Assimp.Matrix4x4[nodeAnimationChannel.PositionKeys.Count];
