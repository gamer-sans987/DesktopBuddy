			int _key = asset.UnloadKey;
			Task.Run(async delegate
			{
				try
				{
					await Task.Delay(TimeSpan.FromSeconds(time)).ConfigureAwait(continueOnCapturedContext: false);
					lock (VariantLock)
					{
						if (asset.UnloadKey == _key && asset.ActiveRequestCount <= 0)
						{
							asset.QueueUnload();
						}
					}
				}
				catch (Exception ex)
				{
					UniLog.Error("Exception scheduling asset unload:\n" + ex);
				}
