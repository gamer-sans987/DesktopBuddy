					if (Engine.InputInterface.ScreenActive)
					{
						return SkyFrost.Base.OutputDevice.Screen;
					}
					if (Engine.InputInterface.VR_Active)
					{
						return SkyFrost.Base.OutputDevice.VR;
					}
				}
				return null;
			}
		}

		public EngineStatusSource(Engine engine, UserStatusManager status)
		{
			Engine = engine;
			Status = status;
			engine.RunPostInit(delegate
			{
				Cloud.Sessions.SessionUpdated += OnSessionUpdated;
				Cloud.Sessions.SessionAdded += OnSessionAdded;
				Cloud.Sessions.SessionRemoved += OnSessionRemoved;
			});
			Settings.RegisterValueChanges<OnlineStatusSettings>(OnSettingsChanged);
		}

		private void OnSettingsChanged(OnlineStatusSettings settings)
		{
			Status.AwayActivateSeconds = (float)settings.AutoAwayTimespan.Value;
		}

		private void OnSessionRemoved(SessionInfo session)
		{
			SessionChanged(session);
		}

		private void OnSessionAdded(SessionInfo session)
		{
			SessionChanged(session);
		}

		private void OnSessionUpdated(SessionInfo session)
		{
			SessionChanged(session);
		}

		private void SessionChanged(SessionInfo info)
		{
			if (Engine.WorldManager.GetWorld((World w) => string.Equals(w.SessionId, info.SessionId, StringComparison.OrdinalIgnoreCase)) != null)
			{
				LastSessionChangeTimestamp = DateTime.UtcNow;
			}
		}

		public bool BeginUpdate()
		{
			if ((DateTime.UtcNow - lastOnlineInstanceTime).TotalSeconds > (double)ONLINE_STATUS_SECONDS && (currentOnlineInstanceTask == null || currentOnlineInstanceTask.IsCompleted))
			{
				currentOnlineInstanceTask = Cloud.Stats.NotifyOnlineInstance(Engine.LocalDB.MachineID);
				lastOnlineInstanceTime = DateTime.UtcNow;
			}
			World focusedWorld = Engine.WorldManager.FocusedWorld;
			bool result = focusedWorld != _lastFocusedWorld;
			_lastFocusedWorld = focusedWorld;
			return result;
		}

		public bool UpdateSessions(UserStatus status, bool forceUpdate)
		{
			List<World> list = Pool.BorrowList<World>();
			List<SessionInfo> list2 = Pool.BorrowList<SessionInfo>();
			SessionInfo sessionInfo = null;
			Engine.WorldManager.GetWorlds(list);
			foreach (World item in list)
			{
				SessionInfo sessionInfo2 = Engine.SessionAnnouncer.GetSessionInfo(item);
				if (sessionInfo2 != null)
				{
					list2.Add(sessionInfo2);
					if (item.Focus == World.WorldFocus.Focused)
					{
						sessionInfo = sessionInfo2;
					}
				}
			}
			Pool.Return(ref list);
			list2.Sort((SessionInfo a, SessionInfo b) => string.CompareOrdinal(a.SessionId, b.SessionId));
			bool flag = false;
			if (forceUpdate)
			{
				flag = true;
			}
			else if (list2.Count != status.Sessions.Count)
			{
				flag = true;
			}
			else
			{
				for (int num = 0; num < list2.Count; num++)
				{
					SessionInfo sessionInfo3 = list2[num];
					UserSessionMetadata userSessionMetadata = status.Sessions[num];
					if (userSessionMetadata.AccessLevel != sessionInfo3.AccessLevel || userSessionMetadata.SessionHidden != sessionInfo3.HideFromListing || userSessionMetadata.BroadcastKey != sessionInfo3.BroadcastKey)
					{
						flag = true;
						break;
					}
				}
			}
			if (flag)
			{
				status.InitializeSessionList();
				foreach (SessionInfo item2 in list2)
				{
					status.AddSession(item2, item2 == sessionInfo);
				}
			}
