		public int FindAudioInputIndex(string name, bool caseSensitive, bool allowPartialMatch)
		{
			if (string.IsNullOrWhiteSpace(name))
			{
				return -1;
			}
			StringComparison comparisonType = (caseSensitive ? StringComparison.InvariantCulture : StringComparison.InvariantCultureIgnoreCase);
			for (int i = 0; i < AudioInputs.Count; i++)
			{
				AudioInput audioInput = AudioInputs[i];
				if (allowPartialMatch)
				{
					if (audioInput.Name.IndexOf(name, comparisonType) >= 0)
					{
						return i;
					}
				}
				else if (audioInput.Name.Equals(name, comparisonType))
				{
					return i;
				}
			}
			return -1;
		}

		public AudioInput FindAudioInput(string name, bool caseSensitive, bool allowPartialMatch)
		{
			int num = FindAudioInputIndex(name, caseSensitive, allowPartialMatch);
			if (num < 0)
			{
				return null;
			}
			return AudioInputs[num];
		}

