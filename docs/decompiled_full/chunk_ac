		private static void SetupPedestal(Slot s)
		{
			Slot slot = s.Parent.AddSlot(s.Name + " Holder");
			slot.GlobalPosition = s.GlobalPosition;
			s.SetParent(slot);
			slot.AttachComponent<Grabbable>().Scalable.Value = true;
			Slot slot2 = slot.AddSlot("Pedestal");
			Elements.Core.BoundingBox boundingBox = s.ComputeBoundingBox(includeInactive: true);
			slot2.GlobalPosition = boundingBox.Center + Elements.Core.float3.Down * 0.55f * boundingBox.Size.y;
			CylinderCollider cylinderCollider = slot2.AttachComponent<CylinderCollider>();
			PBS_Metallic pBS_Metallic = slot2.AttachComponent<PBS_Metallic>();
			pBS_Metallic.AlbedoColor.Value = Elements.Core.colorX.Red * 0.5f;
			CylinderMesh cylinderMesh = slot2.AttachMesh<CylinderMesh>(pBS_Metallic);
			cylinderCollider.Height.Value = 0.025f;
			cylinderCollider.Radius.Value *= 0.5f;
			cylinderMesh.Height.Value = 0.025f;
			cylinderMesh.Radius.Value *= 0.5f;
		}

		private static void GetDuration(ModelImportData data, Assimp.Animation anim, out float duration, out float timeScale)
		{
			duration = (float)anim.DurationInTicks;
			timeScale = 1f;
			if (anim.TicksPerSecond > 0.0 && !data.File.ToLower().Contains(".fbx"))
			{
				duration /= (float)anim.TicksPerSecond;
				timeScale = 1f / (float)anim.TicksPerSecond;
			}
			else
			{
				duration *= 0.001f;
				timeScale = 0.001f;
			}
		}

		private static IEnumerator<Context> ImportAnimations(ModelImportData data)
		{
			Scene scene = data.Scene;
			_ = data.assetsSlot;
			if (!scene.HasAnimations)
			{
				yield break;
			}
			bool flag = true;
			float num = -1f;
			foreach (Assimp.Animation animation2 in scene.Animations)
			{
				if (animation2.NodeAnimationChannelCount != 1)
				{
					flag = false;
					break;
				}
				GetDuration(data, animation2, out var duration, out var _);
				num = MathX.Max(duration, num);
			}
			List<AnimX> list = new List<AnimX>();
			if (flag)
			{
				AnimX item = new AnimX(num, data.File);
				list.Add(item);
			}
			for (int i = 0; i < scene.AnimationCount; i++)
			{
				Assimp.Animation animation = scene.Animations[i];
				data.Progress?.UpdateProgress(0f, animation.Name, null);
				if (animation.DurationInTicks <= 1.0 || !animation.HasNodeAnimations)
				{
					continue;
				}
				GetDuration(data, animation, out var duration2, out var timeScale2);
				UniLog.Log("Importing animation: " + animation.Name + ", nodeChannelCount: " + animation.NodeAnimationChannelCount + ", Duration in ticks: " + animation.DurationInTicks + ", TicksPerSecond: " + animation.TicksPerSecond + ", Duration: " + duration2 + ", TimeScale: " + timeScale2);
				AnimX animX;
				if (flag)
				{
					animX = list[0];
				}
				else
				{
					animX = new AnimX(duration2, animation.Name);
					list.Add(animX);
				}
				double num2 = 0.0;
				for (int j = 0; j < animation.NodeAnimationChannelCount; j++)
				{
					NodeAnimationChannel nodeAnimationChannel = animation.NodeAnimationChannels[j];
					foreach (VectorKey positionKey in nodeAnimationChannel.PositionKeys)
					{
						num2 = MathX.Min(positionKey.Time, num2);
					}
					foreach (QuaternionKey rotationKey in nodeAnimationChannel.RotationKeys)
					{
						num2 = MathX.Min(rotationKey.Time, num2);
					}
					foreach (VectorKey scalingKey in nodeAnimationChannel.ScalingKeys)
					{
						num2 = MathX.Min(scalingKey.Time, num2);
					}
				}
				if (num2 < 0.0)
				{
					UniLog.Warning("Minimum keyframe time before 0: " + num2 + ", offseting");
				}
				double num3 = MathX.Abs(num2);
				for (int k = 0; k < animation.NodeAnimationChannelCount; k++)
				{
					NodeAnimationChannel nodeAnimationChannel2 = animation.NodeAnimationChannels[k];
					if (nodeAnimationChannel2.PositionKeyCount > 0)
					{
						if (animX.FindTrack(nodeAnimationChannel2.NodeName, "Position") != null)
						{
							UniLog.Warning($"Position Animation track with duplicate name. Index: {k}, Node: {nodeAnimationChannel2.NodeName}, Anim: {animX.Name}");
						}
						CurveFloat3AnimationTrack curveFloat3AnimationTrack = animX.AddTrack<CurveFloat3AnimationTrack>();
						curveFloat3AnimationTrack.Node = nodeAnimationChannel2.NodeName;
						curveFloat3AnimationTrack.Property = "Position";
						foreach (VectorKey positionKey2 in nodeAnimationChannel2.PositionKeys)
						{
							curveFloat3AnimationTrack.InsertKeyFrame(positionKey2.Value.ToEngine(), (float)(positionKey2.Time + num3) * timeScale2);
						}
					}
					if (nodeAnimationChannel2.RotationKeyCount > 0)
					{
						if (animX.FindTrack(nodeAnimationChannel2.NodeName, "Rotation") != null)
						{
							UniLog.Warning($"Rotation Animation track with duplicate name. Index: {k}, Node: {nodeAnimationChannel2.NodeName}, Anim: {animX.Name}");
						}
						CurveFloatQAnimationTrack curveFloatQAnimationTrack = animX.AddTrack<CurveFloatQAnimationTrack>();
						curveFloatQAnimationTrack.Node = nodeAnimationChannel2.NodeName;
						curveFloatQAnimationTrack.Property = "Rotation";
						foreach (QuaternionKey rotationKey2 in nodeAnimationChannel2.RotationKeys)
						{
							curveFloatQAnimationTrack.InsertKeyFrame(rotationKey2.Value.ToEngine(), (float)(rotationKey2.Time + num3) * timeScale2);
						}
					}
					if (nodeAnimationChannel2.ScalingKeyCount <= 0)
					{
						continue;
					}
					if (animX.FindTrack(nodeAnimationChannel2.NodeName, "Scale") != null)
					{
						UniLog.Warning($"Scale Animation track with duplicate name. Index: {k}, Node: {nodeAnimationChannel2.NodeName}, Anim: {animX.Name}");
					}
					CurveFloat3AnimationTrack curveFloat3AnimationTrack2 = animX.AddTrack<CurveFloat3AnimationTrack>();
					curveFloat3AnimationTrack2.Node = nodeAnimationChannel2.NodeName;
					curveFloat3AnimationTrack2.Property = "Scale";
					foreach (VectorKey scalingKey2 in nodeAnimationChannel2.ScalingKeys)
					{
						curveFloat3AnimationTrack2.InsertKeyFrame(scalingKey2.Value.ToEngine(), (float)(scalingKey2.Time + num3) * timeScale2);
					}
				}
			}
			List<Uri> uris = new List<Uri>();
			foreach (AnimX item2 in list)
			{
				string tempFilePath = data.localDB.GetTempFilePath("animx");
				item2.SaveToFile(tempFilePath);
				uris.Add(data.localDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).Result);
			}
			yield return Context.ToWorld();
			foreach (Uri item3 in uris)
			{
				StaticAnimationProvider staticAnimationProvider = data.assetsSlot.AttachComponent<StaticAnimationProvider>();
				staticAnimationProvider.URL.Value = item3;
				data.animations.Add(staticAnimationProvider);
			}
		}

		private static IEnumerator<Context> ImportNode(Assimp.Node node, Slot targetSlot, ModelImportData data)
		{
			if (node.MeshCount > 0)
			{
				yield return Context.WaitFor(ImportMesh(node.MeshIndices, data));
			}
			IAssetProvider<Material>[] materialProviders = new IAssetProvider<Material>[node.MeshCount];
			IAssetProvider<Mesh> meshProvider = data.lastMesh;
			for (int i = 0; i < node.MeshCount; i++)
			{
				int index = node.MeshIndices[i];
				Assimp.Mesh assimpMesh = data.Scene.Meshes[index];
				if (!data.materials.TryGetValue(assimpMesh.MaterialIndex, out IAssetProvider<Material> value))
				{
					yield return Context.WaitFor(ImportMaterial(assimpMesh.MaterialIndex, data));
					value = data.materials[assimpMesh.MaterialIndex];
				}
				materialProviders[i] = value;
			}
			yield return Context.ToWorld();
			Slot nodeSlot = targetSlot.AddSlot(node.Name);
			node.Transform.ToEngine().Decompose(out var position, out var rotation, out var scale);
			nodeSlot.LocalScale = scale;
			nodeSlot.LocalRotation = rotation.Normalized;
			nodeSlot.LocalPosition = position;
			data.RegisterSlot(node, nodeSlot);
			if (node.MeshCount > 0)
			{
				MeshRenderer meshRenderer;
				if (data.lastMeshX.HasBoneBindings || data.lastMeshX.BlendShapeCount > 0)
				{
					SkinnedMeshRenderer skinnedMeshRenderer = nodeSlot.AttachComponent<SkinnedMeshRenderer>();
					skinnedMeshRenderer.BoundsComputeMethod.Value = SkinnedBounds.SlowRealtimeAccurate;
					meshRenderer = skinnedMeshRenderer;
					data.skinnedRenderers.Add(skinnedMeshRenderer);
				}
				else
				{
					meshRenderer = nodeSlot.AttachComponent<MeshRenderer>();
				}
				meshRenderer.Mesh.Target = meshProvider;
				for (int j = 0; j < materialProviders.Length; j++)
				{
					for (int k = 0; k < data.lastMeshSubmeshes[j]; k++)
					{
						IAssetProvider<Material> assetProvider = materialProviders[j];
						if (data.lastMeshX.HasColors)
						{
							UniLog.Log("MeshX has vertex colors");
							assetProvider = data.GetVertexColorVariant(assetProvider);
						}
						meshRenderer.Materials.Add().Target = assetProvider;
					}
				}
				if (data.settings.GenerateColliders && !data.lastMeshX.HasBoneBindings && data.lastMeshX.SubmeshCount > 0)
				{
					if (data.lastMeshX.GetSubmesh(0) is Elements.Assets.PointSubmesh)
					{
						nodeSlot.AttachComponent<ConvexHullCollider>().Mesh.Target = meshProvider;
					}
					else
					{
						nodeSlot.AttachComponent<MeshCollider>().Mesh.Target = meshProvider;
					}
				}
				if (data.settings.Center)
				{
					data.targetWorld.Coroutines.StartCoroutine(Center(data));
				}
			}
			yield return Context.ToBackground();
			if (!node.HasChildren)
			{
				yield break;
			}
			foreach (Assimp.Node child in node.Children)
			{
				yield return Context.WaitFor(ImportNode(child, nodeSlot, data));
			}
		}

		private static IEnumerator<Context> ImportMesh(List<int> indicies, ModelImportData data)
		{
			_ = data.Scene;
			data.lastMeshSubmeshes = new List<int>();
			Assimp.Mesh[] array = new Assimp.Mesh[indicies.Count];
			for (int i = 0; i < indicies.Count; i++)
			{
				array[i] = data.Scene.Meshes[indicies[i]];
			}
			int num = 0;
			bool flag = false;
			bool flag2 = false;
			bool flag3 = false;
			bool flag4 = false;
			bool flag5 = false;
			int[] array2 = null;
			Assimp.Mesh[] array3 = array;
			foreach (Assimp.Mesh mesh in array3)
			{
				flag |= mesh.HasNormals;
				flag2 |= mesh.HasTangentBasis;
				flag3 |= mesh.HasVertexColors(0);
				flag4 |= mesh.HasBones;
				flag5 |= mesh.HasMeshAnimationAttachments;
				array2 = array2.EnsureSize(mesh.TextureCoordinateChannelCount, keepData: true);
				for (int k = 0; k < mesh.TextureCoordinateChannelCount; k++)
				{
					array2[k] = MathX.Max(array2[k], mesh.UVComponentCount[k]);
				}
				num += mesh.VertexCount;
			}
			flag4 &= data.settings.ImportBones;
			flag3 &= data.settings.ImportVertexColors;
			MeshX meshx = new MeshX();
			meshx.IncreaseVertexCount(num);
			meshx.HasNormals = flag;
			meshx.HasTangents = flag2;
			meshx.HasColors = flag3;
			meshx.HasBoneBindings = flag4;
			for (int l = 0; l < ((array2 != null) ? array2.Length : 0); l++)
			{
				meshx.SetUV_Dimension(l, array2[l]);
			}
			int vertIndex = 0;
			array3 = array;
			foreach (Assimp.Mesh mesh2 in array3)
			{
				for (int m = 0; m < mesh2.VertexCount; m++)
				{
					Elements.Assets.Vertex vertex = meshx.GetVertex(vertIndex++);
					vertex.PositionUnsafe = mesh2.Vertices[m].ToEngine();
					if (flag && mesh2.HasNormals)
					{
						vertex.NormalUnsafe = mesh2.Normals[m].ToEngine();
						if (flag2 && mesh2.HasTangentBasis)
						{
							Elements.Core.float3 xyz = mesh2.Tangents[m].ToEngine();
							Elements.Core.float3 b = mesh2.BiTangents[m].ToEngine();
							vertex.Tangent4Unsafe = new Elements.Core.float4(in xyz, (MathX.Dot(MathX.Cross(in vertex.NormalUnsafe, in xyz), in b) <= 0f) ? 1 : (-1));
						}
					}
					for (int n = 0; n < mesh2.TextureCoordinateChannelCount; n++)
					{
						Elements.Core.float3 v = mesh2.TextureCoordinateChannels[n][m].ToEngine();
						switch (meshx.GetUV_Dimension(n))
						{
						case 2:
							meshx.GetRawUVs(n)[vertex.IndexUnsafe] = v.xy;
							break;
						case 3:
							meshx.GetRawUVs_3D(n)[vertex.IndexUnsafe] = v;
							break;
						case 4:
							meshx.GetRawUVs_4D(n)[vertex.IndexUnsafe] = v;
							break;
						default:
							throw new Exception("Unexpected UV dimension");
						}
					}
					if (flag3 && mesh2.HasVertexColors(0))
					{
						vertex.ColorUnsafe = mesh2.VertexColorChannels[0][m].ToEngine().LinearColor;
					}
				}
			}
			int num2 = 0;
			vertIndex = 0;
			array3 = array;
			foreach (Assimp.Mesh mesh3 in array3)
			{
				data.Progress?.UpdateProgress(0f, mesh3.Name, null);
				Elements.Assets.PointSubmesh pointSubmesh = null;
				Elements.Assets.TriangleSubmesh triangleSubmesh = null;
				if (data.settings.ForcePointCloud)
				{
					pointSubmesh = meshx.AddSubmesh<Elements.Assets.PointSubmesh>();
					pointSubmesh.IncreaseCount(mesh3.VertexCount);
					for (int num3 = 0; num3 < mesh3.VertexCount; num3++)
					{
						pointSubmesh.RawIndicies[num3] = vertIndex + num3;
					}
				}
				else
				{
					for (int num4 = 0; num4 < mesh3.FaceCount; num4++)
					{
						Face face = mesh3.Faces[num4];
						if (face.IndexCount == 1)
						{
							pointSubmesh = pointSubmesh ?? meshx.AddSubmesh<Elements.Assets.PointSubmesh>();
							pointSubmesh.AddPoint(face.Indices[0]);
						}
						else if (face.IndexCount == 3)
						{
							triangleSubmesh = triangleSubmesh ?? meshx.AddSubmesh<Elements.Assets.TriangleSubmesh>();
							if (data.settings.Winding != Winding.Invert)
							{
								Elements.Assets.Triangle triangle = triangleSubmesh.AddTriangle(vertIndex + face.Indices[0], vertIndex + face.Indices[1], vertIndex + face.Indices[2]);
								if (data.settings.Winding == Winding.AutoFix)
								{
									Elements.Core.float3 b2 = (triangle.Vertex0.Normal + triangle.Vertex1.Normal + triangle.Vertex2.Normal) / 3f;
									if (MathX.Dot(triangle.SurfaceNormal, in b2) < 0f)
									{
										triangle.ReverseWinding();
									}
								}
							}
							else
							{
								triangleSubmesh.AddTriangle(vertIndex + face.Indices[2], vertIndex + face.Indices[1], vertIndex + face.Indices[0]);
							}
						}
						else if (face.IndexCount == 4)
						{
							triangleSubmesh = triangleSubmesh ?? meshx.AddSubmesh<Elements.Assets.TriangleSubmesh>();
							triangleSubmesh.AddQuadAsTriangles(vertIndex + face.Indices[0], vertIndex + face.Indices[1], vertIndex + face.Indices[2], vertIndex + face.Indices[3], data.settings.Winding == Winding.Invert);
						}
						else if (face.IndexCount > 4)
						{
							triangleSubmesh = triangleSubmesh ?? meshx.AddSubmesh<Elements.Assets.TriangleSubmesh>();
							triangleSubmesh.AddTriangleFan(face.IndexCount, (int vi) => vertIndex + face.Indices[vi], data.settings.Winding == Winding.Invert);
						}
					}
				}
				int num5 = 0;
				if (pointSubmesh != null)
				{
					num5++;
				}
				if (triangleSubmesh != null)
				{
					num5++;
				}
				data.lastMeshSubmeshes.Add(num5);
				vertIndex += mesh3.VertexCount;
				num2++;
			}
			if (flag5)
			{
				for (int num6 = 0; num6 < array[0].MeshAnimationAttachmentCount; num6++)
				{
					MeshAnimationAttachment meshAnimationAttachment = array[0].MeshAnimationAttachments[num6];
					string text = meshAnimationAttachment.Name;
					while (meshx.HasBlendShape(text))
					{
						UniLog.Warning("Duplicate blendshape name: " + text);
						text += "_";
					}
					Elements.Assets.BlendShape blendShape = meshx.AddBlendShape(text);
					BlendShapeFrame blendShapeFrame = blendShape.AddFrame(1f);
					blendShape.HasNormals = meshAnimationAttachment.HasNormals;
					blendShape.HasTangents = meshAnimationAttachment.HasTangentBasis;
					int num7 = 0;
					array3 = array;
					for (int j = 0; j < array3.Length; j++)
					{
						MeshAnimationAttachment meshAnimationAttachment2 = array3[j].MeshAnimationAttachments[num6];
						for (int num8 = 0; num8 < meshAnimationAttachment2.VertexCount; num8++)
						{
							blendShapeFrame.RawPositions[num7] = meshAnimationAttachment2.Vertices[num8].ToEngine() - meshx.RawPositions[num7];
							if (blendShape.HasNormals)
							{
								blendShapeFrame.RawNormals[num7] = meshAnimationAttachment2.Normals[num8].ToEngine().Normalized - meshx.RawNormals[num7].Normalized;
							}
							if (blendShape.HasTangents)
							{
								blendShapeFrame.RawTangents[num7] = meshAnimationAttachment2.Tangents[num8].ToEngine().Normalized - meshx.RawTangents[num7].xyz.Normalized;
							}
							num7++;
						}
					}
					if (num7 != meshx.VertexCount)
					{
						UniLog.Warning("Number of blendshape vertices doesn't match number of vertices on the mesh. Mesh vertex count: " + meshx.VertexCount + ", decoded blendshape vertices: " + num7 + ", BlendShape: " + blendShape.Name + ", First Assimp Mesh: " + array[0].Name);
					}
				}
			}
			if (meshx.TotalTriangleCount > 0 && meshx.HasNormals)
			{
				for (int num9 = 0; num9 < meshx.SubmeshCount; num9++)
				{
					if (meshx.GetSubmesh(num9) is Elements.Assets.TriangleSubmesh)
					{
						Elements.Assets.Triangle triangle2 = meshx.GetTriangle(0, num9);
						Elements.Core.float3 b3 = triangle2.Vertex0.Normal + triangle2.Vertex1.Normal + triangle2.Vertex2.Normal;
						if (MathX.Dot(triangle2.SurfaceNormal, in b3) < 0f)
						{
							meshx.FlipNormals();
						}
						break;
					}
				}
			}
			Dictionary<string, Assimp.Node> boneMapping = new Dictionary<string, Assimp.Node>();
			if (flag4)
			{
				Dictionary<string, Elements.Assets.Bone> dictionary = new Dictionary<string, Elements.Assets.Bone>();
				vertIndex = 0;
				array3 = array;
				foreach (Assimp.Mesh mesh4 in array3)
				{
					if (mesh4.HasBones)
					{
						foreach (Assimp.Bone bone in mesh4.Bones)
						{
							string name = bone.Name;
							if (!dictionary.TryGetValue(name, out var value))
							{
								if (bone.Node != null)
								{
									boneMapping.Add(name, bone.Node);
								}
								value = meshx.AddBone(name);
								value.BindPose = bone.OffsetMatrix.ToEngine();
								dictionary.Add(name, value);
							}
							for (int num10 = 0; num10 < bone.VertexWeightCount; num10++)
							{
								VertexWeight vertexWeight = bone.VertexWeights[num10];
								Elements.Assets.Vertex vertex2 = meshx.GetVertex(vertexWeight.VertexID + vertIndex);
								BoneBinding boneBinding = vertex2.BoneBinding;
								boneBinding.AddBone(value, vertexWeight.Weight);
								vertex2.BoneBinding = boneBinding;
							}
						}
					}
					vertIndex += mesh4.VertexCount;
				}
				meshx.SortTrimAndNormalizeBoneWeights();
				meshx.FillInEmptyBindings(0);
			}
			if (data.settings.MakeDualSided)
			{
				meshx.MakeDualSided();
			}
			if (data.settings.MakeFlatShaded)
			{
				meshx.ConvertToFlatShading();
			}
			meshx.StripEmptyBlendshapes();
			if (data.settings.CalculateTangents)
			{
				meshx.RecalculateTangentsMikktspace();
			}
			string tempFilePath = data.localDB.GetTempFilePath("meshx");
			meshx.SaveToFile(tempFilePath);
			Uri url = data.localDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).Result;
			yield return Context.ToWorld();
			StaticMesh staticMesh = data.assetsSlot.AddSlot("Mesh").AttachComponent<StaticMesh>();
			staticMesh.URL.Value = url;
			if (boneMapping.Count > 0)
			{
				data.RegisterBoneMapping(staticMesh, boneMapping);
			}
			data.lastMesh = staticMesh;
			data.lastMeshX = meshx;
		}

		private static IEnumerator<Context> ImportMaterial(int index, ModelImportData data)
		{
			Scene scene = data.Scene;
			Assimp.Material assimpMat = scene.Materials[index];
			data.Progress?.UpdateProgress(0f, assimpMat.Name, null);
			yield return Context.ToWorld();
			Slot materialSlot = data.assetsSlot.AddSlot("Material: " + assimpMat.Name);
			yield return Context.ToBackground();
			TextureSlot[] textures = assimpMat.GetAllMaterialTextures();
			List<TextureMapping> textureMap = new List<TextureMapping>(textures.Length);
			for (int i = 0; i < textures.Length; i++)
			{
				TextureSlot tex = textures[i];
				if (!string.IsNullOrWhiteSpace(tex.FilePath))
				{
					TextureId id = new TextureId(tex.FilePath, tex.WrapModeU.ToEngine(), tex.WrapModeV.ToEngine(), data.settings.ForcePointFiltering);
					UniLog.Log($"WrapMode: {tex.WrapModeU} {tex.WrapModeV}, Flags: {tex.Flags}");
					if (!data.textureProviders.TryGetValue(id, out ITexture2DProvider value))
					{
						yield return Context.WaitFor(GenerateTextureProvider(id, data));
						value = data.textureProviders[id];
					}
					textureMap.Add(new TextureMapping(tex, value));
				}
			}
			if (data.settings.ImportExternalTextures)
			{
				string[] files = Directory.GetFiles(data.FileRoot);
				string[] array = files;
				foreach (string f in array)
				{
					if (AssetHelper.IdentifyClass(f) != AssetClass.Texture)
					{
						continue;
					}
					data.Progress?.UpdateProgress(-1f, Path.GetFileName(f), null);
					string name = data.settings.StripExternalName(Path.GetFileNameWithoutExtension(f));
					if (!data.settings.ImportExternal(name))
					{
						continue;
					}
					if (!data.extTextures.TryGetValue(f, out ITexture2DProvider provider))
					{
						Uri url;
						switch (Path.GetExtension(f).ToLower())
						{
						case ".jpg":
						case ".jpeg":
						case ".png":
							if (data.settings.MaxTextureSize <= 0 && data.settings.TextureConversion == TextureConversion.Auto)
							{
								url = data.localDB.ImportLocalAssetAsync(f, LocalDB.ImportLocation.Copy).Result;
								break;
							}
							goto default;
						default:
							switch (data.settings.TextureConversion)
							{
							case TextureConversion.PNG:
							{
								string tempFilePath = data.localDB.GetTempFilePath("png");
								TextureEncoder.ConvertToPNG(f, tempFilePath, data.settings.MaxTextureSize);
								url = data.localDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).Result;
								break;
							}
							case TextureConversion.JPEG:
							{
								string tempFilePath = data.localDB.GetTempFilePath("jpg");
								TextureEncoder.ConvertToJPG(f, tempFilePath, data.settings.MaxTextureSize);
								url = data.localDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).Result;
								break;
							}
							case TextureConversion.Auto:
							case TextureConversion.WEBP:
							{
								string tempFilePath = data.localDB.GetTempFilePath("webp");
								TextureEncoder.ConvertToWEBP(f, tempFilePath, data.settings.MaxTextureSize, 100);
								url = data.localDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).Result;
								break;
							}
							default:
								throw new Exception("Invalid conversion format: " + data.settings.TextureConversion);
							}
							break;
						}
						yield return Context.ToWorld();
						StaticTexture2D staticTexture2D = data.assetsSlot.AddSlot(Path.GetFileName(f)).AttachComponent<StaticTexture2D>();
						staticTexture2D.URL.Value = url;
						provider = staticTexture2D;
						data.extTextures.Add(f, provider);
						yield return Context.ToBackground();
					}
					textureMap.Add(new TextureMapping(name, provider));
					provider = null;
				}
			}
			yield return Context.ToWorld();
			IAssetProvider<Material> value2 = data.settings.MaterialMapper(materialSlot, assimpMat, textureMap);
			data.materials.Add(index, value2);
		}

		private static IEnumerator<Context> GenerateTextureProvider(TextureId id, ModelImportData data)
		{
			yield return Context.ToBackground();
			if (!data.textures.TryGetValue(id.filePath, out var _))
			{
				yield return Context.WaitFor(ImportTexture(id.filePath, data));
				_ = data.textures[id.filePath];
			}
			yield return Context.ToWorld();
			TextureData textureData = data.textures[id.filePath];
			if (textureData.url != null)
			{
				StaticTexture2D staticTexture2D = data.assetsSlot.AddSlot(textureData.name).AttachComponent<StaticTexture2D>();
				staticTexture2D.URL.Value = textureData.url;
				staticTexture2D.WrapModeU.Value = id.wrapU;
				staticTexture2D.WrapModeV.Value = id.wrapV;
				if (id.pointFiltering)
				{
					staticTexture2D.FilterMode.Value = TextureFilterMode.Point;
				}
				if (data.settings.ForceNoMipmaps)
				{
					staticTexture2D.MipMaps.Value = false;
				}
				if (data.settings.ForceCompression.HasValue)
				{
					staticTexture2D.PreferredFormat.Value = data.settings.ForceCompression;
				}
				data.textureProviders.Add(id, staticTexture2D);
			}
			else
			{
				data.textureProviders.Add(id, null);
			}
		}

		private static IEnumerator<Context> ImportTexture(string path, ModelImportData data)
		{
			yield return Context.ToBackground();
			data.Progress?.UpdateProgress(0f, Path.GetFileName(path), null);
			Scene scene = data.Scene;
			Uri url = null;
			EmbeddedTexture embeddedTexture = null;
			if (path[0] == '*')
			{
				int index = int.Parse(path.Substring(1));
				embeddedTexture = scene.Textures[index];
			}
			else
			{
				foreach (EmbeddedTexture texture in data.Scene.Textures)
				{
					if (path.EndsWith(texture.Filename) || texture.Filename.EndsWith(path))
					{
						embeddedTexture = texture;
						break;
					}
				}
			}
			string name;
			if (embeddedTexture != null)
			{
				EmbeddedTexture embeddedTexture2 = embeddedTexture;
				name = "Embedded Texture " + Path.GetFileName(embeddedTexture2.Filename);
				if (!embeddedTexture2.IsCompressed)
				{
					throw new Exception("Uncompressed embedded texture data aren't supproted at the moment");
				}
				string compressedFormatHint = embeddedTexture2.CompressedFormatHint;
				string tempFilePath;
				if ((compressedFormatHint != "jpg" && compressedFormatHint != "png" && compressedFormatHint != "webp") || data.settings.MaxTextureSize > 0 || data.settings.TextureConversion != TextureConversion.Auto)
				{
					using MemoryStream data2 = new MemoryStream(embeddedTexture2.CompressedData);
					switch (data.settings.TextureConversion)
					{
					case TextureConversion.PNG:
						tempFilePath = data.localDB.GetTempFilePath("png");
						TextureEncoder.ConvertToPNG(data2, tempFilePath, data.settings.MaxTextureSize);
						break;
					case TextureConversion.JPEG:
						tempFilePath = data.localDB.GetTempFilePath("jpg");
						TextureEncoder.ConvertToJPG(data2, tempFilePath, data.settings.MaxTextureSize);
						break;
					case TextureConversion.Auto:
					case TextureConversion.WEBP:
						tempFilePath = data.localDB.GetTempFilePath("webp");
						TextureEncoder.ConvertToWEBP(data2, tempFilePath, data.settings.MaxTextureSize, 100);
						break;
					default:
						throw new Exception("Invalid texture conversion format: " + data.settings.TextureConversion);
					}
				}
				else
				{
					tempFilePath = data.localDB.GetTempFilePath(embeddedTexture2.CompressedFormatHint);
					File.WriteAllBytes(tempFilePath, embeddedTexture2.CompressedData);
				}
				url = data.localDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).Result;
			}
			else
			{
				name = Path.GetFileName(path);
				string text;
				if (File.Exists(path))
				{
					text = path;
				}
				else
				{
					string fileName = Path.GetFileName(path);
					text = FileUtil.FindFile(fileName, data.FileRoot, 2);
					if (text == null)
					{
						try
						{
							text = FileUtil.FindFile(fileName, Path.GetDirectoryName(data.FileRoot), 2);
						}
						catch (Exception value)
						{
							UniLog.Warning($"Exception finding texture file: {data.FileRoot}\n{value}");
						}
					}
				}
				if (File.Exists(text))
				{
					string text2 = Path.GetExtension(text).Replace(".", "").ToLower();
					TextureConversion textureConversion = data.settings.TextureConversion;
					if (textureConversion == TextureConversion.Auto && ((text2 != "png" && text2 != "jpg" && text2 != "webp") || data.settings.MaxTextureSize > 0))
					{
						textureConversion = TextureConversion.WEBP;
					}
					switch (textureConversion)
					{
					case TextureConversion.Auto:
						url = data.localDB.ImportLocalAssetAsync(text, LocalDB.ImportLocation.Copy).Result;
						break;
					case TextureConversion.PNG:
					{
						string tempFilePath2 = data.localDB.GetTempFilePath("png");
						TextureEncoder.ConvertToPNG(text, tempFilePath2, data.settings.MaxTextureSize);
						url = data.localDB.ImportLocalAssetAsync(tempFilePath2, LocalDB.ImportLocation.Move).Result;
						break;
					}
					case TextureConversion.JPEG:
					{
						string tempFilePath2 = data.localDB.GetTempFilePath("jpeg");
						TextureEncoder.ConvertToJPG(text, tempFilePath2, data.settings.MaxTextureSize);
						url = data.localDB.ImportLocalAssetAsync(tempFilePath2, LocalDB.ImportLocation.Move).Result;
						break;
					}
					case TextureConversion.WEBP:
					{
						string tempFilePath2 = data.localDB.GetTempFilePath("webp");
						TextureEncoder.ConvertToWEBP(text, tempFilePath2, data.settings.MaxTextureSize, 100);
						url = data.localDB.ImportLocalAssetAsync(tempFilePath2, LocalDB.ImportLocation.Move).Result;
						break;
					}
					}
				}
				else
				{
					UniLog.Warning("Couldn't find texture file: " + path);
				}
			}
			data.textures.Add(path, new TextureData(url, name));
		}
	}
