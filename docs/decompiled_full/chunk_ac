					{
						meshAnimationAttachment.Vertices[l] *= vector3D;
					}
					if (meshAnimationAttachment.HasNormals)
					{
						for (int m = 0; m < meshAnimationAttachment.VertexCount; m++)
						{
							meshAnimationAttachment.Normals[m] *= vector3D;
						}
					}
					if (meshAnimationAttachment.HasTangentBasis)
					{
						for (int n = 0; n < meshAnimationAttachment.VertexCount; n++)
						{
							meshAnimationAttachment.Tangents[n] *= vector3D;
						}
					}
				}
			}
			foreach (Assimp.Animation animation2 in scene.Animations)
			{
				foreach (NodeAnimationChannel nodeAnimationChannel2 in animation2.NodeAnimationChannels)
				{
					Assimp.Matrix4x4 localToGlobal3 = GetLocalToGlobal(FindNode(nodeAnimationChannel2.NodeName, scene.RootNode).Parent);
					localToGlobal3.Inverse();
					Vector3D scaling;
					if (nodeAnimationChannel2.HasPositionKeys)
					{
						Assimp.Matrix4x4[] array3 = dictionary[nodeAnimationChannel2];
						for (int num = 0; num < nodeAnimationChannel2.PositionKeys.Count; num++)
						{
							Assimp.Matrix4x4 matrix4x4 = array3[num];
							matrix4x4 = localToGlobal3 * matrix4x4;
							matrix4x4 *= Assimp.Matrix4x4.FromScaling(new Vector3D(-1f, 1f, 1f));
							VectorKey value = nodeAnimationChannel2.PositionKeys[num];
							matrix4x4.Decompose(out scaling, out var _, out value.Value);
							nodeAnimationChannel2.PositionKeys[num] = value;
						}
					}
					if (!nodeAnimationChannel2.HasRotationKeys)
					{
						continue;
					}
					Assimp.Matrix4x4[] array4 = dictionary2[nodeAnimationChannel2];
					for (int num2 = 0; num2 < nodeAnimationChannel2.RotationKeys.Count; num2++)
					{
						Assimp.Matrix4x4 matrix4x5 = array4[num2];
						matrix4x5 = localToGlobal3 * matrix4x5;
						matrix4x5 *= Assimp.Matrix4x4.FromScaling(new Vector3D(-1f, 1f, 1f));
						QuaternionKey value2 = nodeAnimationChannel2.RotationKeys[num2];
						matrix4x5.DecomposeNoScaling(out var rotation2, out scaling);
						Assimp.Quaternion quaternion = new Assimp.Quaternion(0f - rotation2.W, 0f - rotation2.X, 0f - rotation2.Y, 0f - rotation2.Z);
						int index = MathX.Max(num2 - 1, 0);
						Assimp.Quaternion value3 = nodeAnimationChannel2.RotationKeys[index].Value;
						float num3 = MathX.Distance((Elements.Core.float4)value3.ToEngine(), (Elements.Core.float4)rotation2.ToEngine());
						float num4 = MathX.Distance((Elements.Core.float4)value3.ToEngine(), (Elements.Core.float4)quaternion.ToEngine());
						if (num3 < num4)
						{
							value2.Value = rotation2;
						}
						else
						{
							value2.Value = quaternion;
						}
						nodeAnimationChannel2.RotationKeys[num2] = value2;
					}
				}
			}
		}

		private static void SplitSubmeshes(Assimp.Node node)
		{
			while (node.MeshCount > 1)
			{
				Assimp.Node node2 = new Assimp.Node(node.Name, node.Parent);
				node.Parent.Children.Add(node2);
				node2.MeshIndices.Add(node.MeshIndices[1]);
				node2.Transform = node.Transform;
				node.MeshIndices.RemoveAt(1);
			}
			int childCount = node.ChildCount;
			for (int i = 0; i < childCount; i++)
			{
				SplitSubmeshes(node.Children[i]);
			}
		}

		private static void GetGlobalMatrices(Scene scene, Assimp.Node node, ref Assimp.Matrix4x4 localToGlobal, Dictionary<Assimp.Node, Assimp.Matrix4x4> matrices, Dictionary<Assimp.Bone, Assimp.Matrix4x4> bones)
		{
			Assimp.Matrix4x4 localToGlobal2 = localToGlobal * node.Transform;
			matrices.Add(node, localToGlobal2);
			foreach (int meshIndex in node.MeshIndices)
			{
				foreach (Assimp.Bone bone in scene.Meshes[meshIndex].Bones)
				{
					if (!bones.ContainsKey(bone))
					{
						Assimp.Matrix4x4 offsetMatrix = bone.OffsetMatrix;
						offsetMatrix.Inverse();
						offsetMatrix = localToGlobal2 * offsetMatrix;
						bones.Add(bone, offsetMatrix);
					}
				}
			}
			foreach (Assimp.Node child in node.Children)
			{
				GetGlobalMatrices(scene, child, ref localToGlobal2, matrices, bones);
			}
		}

		private static void AssignLocalMatrices(Scene scene, Assimp.Node node, ref Assimp.Matrix4x4 localToGlobal, Dictionary<Assimp.Node, Assimp.Matrix4x4> matrices, Dictionary<Assimp.Bone, Assimp.Matrix4x4> bones)
		{
			Assimp.Matrix4x4 matrix4x = matrices[node];
			Assimp.Matrix4x4 matrix4x2 = localToGlobal;
			matrix4x2.Inverse();
			Assimp.Matrix4x4 matrix4x3 = matrix4x2 * matrix4x;
			matrix4x3 *= Assimp.Matrix4x4.FromScaling(new Vector3D(-1f, 1f, 1f));
			node.Transform = matrix4x3;
			Assimp.Matrix4x4 localToGlobal2 = localToGlobal * matrix4x3;
			Assimp.Matrix4x4 matrix4x4 = localToGlobal2;
			matrix4x4.Inverse();
			foreach (int meshIndex in node.MeshIndices)
			{
				foreach (Assimp.Bone bone in scene.Meshes[meshIndex].Bones)
				{
					if (bones.ContainsKey(bone))
					{
						Assimp.Matrix4x4 matrix4x5 = bones[bone];
						bones.Remove(bone);
						matrix4x5 = matrix4x4 * matrix4x5;
						matrix4x5 *= Assimp.Matrix4x4.FromScaling(new Vector3D(-1f, 1f, 1f));
						matrix4x5.Inverse();
						bone.OffsetMatrix = matrix4x5;
					}
				}
			}
			foreach (Assimp.Node child in node.Children)
			{
				AssignLocalMatrices(scene, child, ref localToGlobal2, matrices, bones);
			}
		}

		private static Assimp.Node FindNode(string name, Assimp.Node root)
		{
			if (root.Name == name)
			{
				return root;
			}
			foreach (Assimp.Node child in root.Children)
			{
				Assimp.Node node = FindNode(name, child);
				if (node != null)
				{
					return node;
				}
			}
			return null;
		}

		private static Assimp.Matrix4x4 TransformFromTo(Assimp.Matrix4x4 matrix, Assimp.Node from, Assimp.Node to)
		{
			matrix = GetLocalToGlobal(from) * matrix;
			Assimp.Matrix4x4 localToGlobal = GetLocalToGlobal(to);
			localToGlobal.Inverse();
			matrix = localToGlobal * matrix;
			return matrix;
		}

		private static Assimp.Matrix4x4 GetLocalToGlobal(Assimp.Node node)
		{
			if (node == null)
			{
				return Assimp.Matrix4x4.Identity;
			}
			Assimp.Matrix4x4 matrix4x = node.Transform;
			while (node.Parent != null)
			{
				node = node.Parent;
				matrix4x = node.Transform * matrix4x;
			}
			return matrix4x;
		}

		private static IEnumerator<Context> Center(ModelImportData data)
		{
			yield return Context.ToWorld();
			while (data.CenteringRunning)
			{
				yield return Context.WaitForNextUpdate();
			}
			data.CenteringRunning = true;
			Slot target = data.targetSlot;
			Elements.Core.float3 center = data.LocalPosition;
			bool rescale = data.settings.Rescale;
			List<IBounded> bounded = target.GetComponentsInChildren<IBounded>();
			while (bounded.Any((IBounded b) => b.HasBoundingBox && !b.IsBoundingBoxAvailable))
			{
				yield return Context.WaitForNextUpdate();
			}
			yield return Context.WaitForNextUpdate();
			Elements.Core.BoundingBox boundingBox = Elements.Core.BoundingBox.Empty();
			foreach (IBounded item in bounded)
			{
				if (item.HasBoundingBox)
				{
					if (item is SkinnedMeshRenderer skinnedMeshRenderer)
					{
						boundingBox.Encapsulate(skinnedMeshRenderer.UnboundMeshGlobalBoundingBox);
					}
					else
					{
						boundingBox.Encapsulate(item.GlobalBoundingBox);
					}
				}
			}
			if (!boundingBox.IsValid)
			{
				data.CenteringRunning = false;
				yield break;
			}
			float num = ((!data.settings.RescaleByHeightOnly) ? MathX.MaxComponent(boundingBox.Size) : boundingBox.Size.y);
			num /= data.settings.Scale;
			if (num > 0f)
			{
				Elements.Core.float3 v = -target.Parent.GlobalPointToLocal(boundingBox.Center) + center;
				float num2 = boundingBox.Size.y;
				if (rescale)
				{
					num2 /= num;
					v /= num;
					target.LocalScale /= num;
				}
				if (data.settings.Ground)
				{
					v = v - center._y_ + new Elements.Core.float3(0f, num2 / 2f);
				}
				target.LocalPosition += v;
			}
			data.CenteringRunning = false;
		}

