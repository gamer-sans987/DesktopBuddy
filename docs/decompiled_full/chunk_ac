			AudioZitaReverb audioZitaReverb = slot.AttachComponent<AudioZitaReverb>();
			variable = SetupReverbZone(audioZitaReverb);
			variable.Radius.Value = maxDistance;
			variable.BlendDistance.Value = maxDistance - minDistance;
