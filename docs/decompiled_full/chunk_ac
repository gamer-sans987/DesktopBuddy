		private void ProcessMessage(ControlMessage message)
		{
			IConnection _sender = message.Sender;
			lock (transferManagerLock)
			{
				Uri requestedURL;
				string typeStr;
				AssetVariantType assetType;
				string json;
				switch (message.ControlMessageType)
				{
				case ControlMessage.Message.AssetRequest:
				{
					requestedURL = new Uri(message.Data.ExtractOrThrow<string>("URL"));
					ValueTask<string> valueTask;
					if (string.IsNullOrWhiteSpace(requestedURL.Query) || requestedURL.Scheme != "local")
					{
						valueTask = AssetManager.GatherAssetFile(requestedURL, 100f);
					}
					else
					{
						string[] array = requestedURL.Query.Split(new char[1] { '?' }, StringSplitOptions.RemoveEmptyEntries);
						if (array.Length != 3)
						{
							UniLog.Warning($"Malformed variant query: {requestedURL}");
							return;
						}
						string variantIdentifier = array[0];
						string identifier = array[1];
						typeStr = array[2];
						if (!Enum.TryParse<AssetVariantType>(typeStr, out assetType))
						{
							UniLog.Warning($"Unknown variant type: {typeStr} for {requestedURL}");
							return;
						}
						IAssetVariantDescriptor variantDescriptor = AssetVariantHelper.FromIdentifier(assetType, identifier);
						Uri assetURL = new Uri(requestedURL.OriginalString.Replace(requestedURL.Query, ""));
						valueTask = AssetManager.RequestVariant(assetURL, variantIdentifier, variantDescriptor, generateVariant: true);
					}
					valueTask.AsTask().ContinueWith(delegate(Task<string> pathTask)
					{
						string result = pathTask.Result;
						lock (transferManagerLock)
						{
							if (result != null)
							{
								Uri assetURI = requestedURL;
								IConnection target = _sender;
								SessionAssetTransferer sessionAssetTransferer = this;
								int num3 = outboundTranmissionIDPool;
								sessionAssetTransferer.outboundTranmissionIDPool = num3 + 1;
								FileTransmitJob item = new FileTransmitJob(result, assetURI, target, num3);
								transmitJobsToInitialize.Add(item);
								RefreshJobs();
							}
							else
							{
								ControlMessage controlMessage2 = new ControlMessage(ControlMessage.Message.AssetNotAvailable);
								controlMessage2.Data.Add("URL", requestedURL.ToString());
								controlMessage2.Targets.Add(_sender);
								EnqueueForTransmission(controlMessage2);
							}
						}
					});
					break;
				}
				case ControlMessage.Message.AssetTransmissionStart:
				{
					FileReceiveJob fileReceiveJob = new FileReceiveJob(message, World.Engine);
					receiveJobs.Add(ID(fileReceiveJob.Source, fileReceiveJob.ID), fileReceiveJob);
					EnqueueForTransmission(fileReceiveJob.NextChunkRequest());
					break;
				}
				case ControlMessage.Message.AssetChunk:
					try
					{
						JobID key = ID(message);
						FileReceiveJob fileReceiveJob = receiveJobs[key];
						fileReceiveJob.ApplyChunk(message);
						if (fileReceiveJob.IsDone)
						{
							string gatheredFile = fileReceiveJob.FinalizeAndGetFile();
							assetRequests[fileReceiveJob.AssetURL].onGathered(fileReceiveJob.AssetURL, gatheredFile, null);
							assetRequests.Remove(fileReceiveJob.AssetURL);
							receiveJobs.Remove(key);
						}
						else
						{
							assetRequests[fileReceiveJob.AssetURL].onProgress(fileReceiveJob.AssetURL, fileReceiveJob.TotalBytes, fileReceiveJob.ReceivedBytes);
							EnqueueForTransmission(fileReceiveJob.NextChunkRequest());
						}
					}
					catch (Exception exception2)
					{
						UniLog.Error("Exception during recieving asset chunk.\n" + DebugManager.PreprocessException(exception2));
					}
					break;
				case ControlMessage.Message.AssetNextChunkRequest:
				{
					JobID key = ID(message);
					if (!transmitJobs.TryGetValue(key, out FileTransmitJob value))
					{
						break;
					}
					int num = ((!value.FirstChunk) ? 1 : 32);
					try
					{
						for (int num2 = 0; num2 < num; num2++)
						{
							EnqueueForTransmission(value.GetChunk());
							if (value.IsDone)
							{
								value.Finish();
								transmitJobs.Remove(key);
								break;
							}
						}
					}
					catch (Exception exception)
					{
						UniLog.Error($"Exception enqueing asset chunk for transmission. AssetURL: {value.AssetURL}\n" + "\n" + DebugManager.PreprocessException(exception));
						ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.AssetNotAvailable);
						controlMessage.Data.Add("URL", value.AssetURL.ToString());
						controlMessage.Targets.Add(message.Sender);
						EnqueueForTransmission(controlMessage);
						transmitJobs.Remove(key);
						value.Cancel();
					}
					break;
				}
				case ControlMessage.Message.AssetNotAvailable:
				{
					string text = message.Data.ExtractOrDefault<string>("URL");
					Uri uri = null;
					if (text != null)
					{
						uri = new Uri(text);
					}
					if (uri != null && assetRequests.ContainsKey(uri))
					{
						assetRequests[uri].onGathered(uri, null, "Asset Not Available From Host");
						assetRequests.Remove(uri);
						UniLog.Log("Received AssetNotAvailable: " + uri);
					}
					break;
				}
				case ControlMessage.Message.AssetMetadataRequest:
					requestedURL = new Uri(message.Data.ExtractOrThrow<string>("URL"));
					typeStr = message.Data.ExtractOrThrow<string>("MetadataType");
					if (!Enum.TryParse<AssetVariantType>(typeStr, out assetType))
					{
						throw new Exception("Invalid asset type: " + typeStr);
					}
					Task.Run(async delegate
					{
						_ = 5;
						try
						{
							switch (assetType)
							{
							case AssetVariantType.Texture:
								json = System.Text.Json.JsonSerializer.Serialize(await AssetManager.RequestMetadata<BitmapMetadata>(requestedURL).ConfigureAwait(continueOnCapturedContext: false));
								break;
							case AssetVariantType.Cubemap:
								json = System.Text.Json.JsonSerializer.Serialize(await AssetManager.RequestMetadata<CubemapMetadata>(requestedURL).ConfigureAwait(continueOnCapturedContext: false));
								break;
							case AssetVariantType.Volume:
								json = System.Text.Json.JsonSerializer.Serialize(await AssetManager.RequestMetadata<VolumeMetadata>(requestedURL).ConfigureAwait(continueOnCapturedContext: false));
								break;
							case AssetVariantType.Mesh:
								json = System.Text.Json.JsonSerializer.Serialize(await AssetManager.RequestMetadata<MeshMetadata>(requestedURL).ConfigureAwait(continueOnCapturedContext: false));
								break;
							case AssetVariantType.Shader:
								json = System.Text.Json.JsonSerializer.Serialize(await AssetManager.RequestMetadata<ShaderMetadata>(requestedURL).ConfigureAwait(continueOnCapturedContext: false));
								break;
							case AssetVariantType.GaussianSplat:
								json = System.Text.Json.JsonSerializer.Serialize(await AssetManager.RequestMetadata<GaussianSplatMetadata>(requestedURL).ConfigureAwait(continueOnCapturedContext: false));
								break;
							default:
								UniLog.Warning("Invalid asset type for metadata: " + assetType);
								return;
							}
							ControlMessage controlMessage2 = new ControlMessage(ControlMessage.Message.AssetMetadata);
							controlMessage2.Data.Add("URL", requestedURL.OriginalString);
							controlMessage2.Data.Add("Metadata", json);
							controlMessage2.Data.Add("MetadataType", typeStr);
							controlMessage2.Targets.Add(_sender);
							EnqueueForTransmission(controlMessage2);
						}
						catch (Exception ex)
						{
							UniLog.Error("Exception when processing AssetMetadataRequest:\n" + ex);
						}
					});
					break;
				case ControlMessage.Message.AssetMetadata:
				{
					requestedURL = new Uri(message.Data.ExtractOrThrow<string>("URL"));
					json = message.Data.ExtractOrThrow<string>("Metadata");
					typeStr = message.Data.ExtractOrThrow<string>("MetadataType");
					if (!Enum.TryParse<AssetVariantType>(typeStr, out assetType))
					{
						throw new Exception("Invalid asset type: " + typeStr);
					}
					if (!metadataRequests.TryGetValue(requestedURL, out TaskCompletionSource<IAssetMetadata> metadataResult))
					{
						return;
					}
					metadataRequests.Remove(requestedURL);
					IAssetMetadata metadata = null;
					switch (assetType)
					{
					case AssetVariantType.Texture:
						metadata = System.Text.Json.JsonSerializer.Deserialize<BitmapMetadata>(json);
						break;
					case AssetVariantType.Cubemap:
						metadata = System.Text.Json.JsonSerializer.Deserialize<CubemapMetadata>(json);
						break;
					case AssetVariantType.Volume:
						metadata = System.Text.Json.JsonSerializer.Deserialize<VolumeMetadata>(json);
						break;
					case AssetVariantType.Mesh:
						metadata = System.Text.Json.JsonSerializer.Deserialize<MeshMetadata>(json);
						break;
					case AssetVariantType.Shader:
						metadata = System.Text.Json.JsonSerializer.Deserialize<ShaderMetadata>(json);
						break;
					case AssetVariantType.GaussianSplat:
						metadata = System.Text.Json.JsonSerializer.Deserialize<GaussianSplatMetadata>(json);
						break;
					default:
						UniLog.Warning("Invalid AssetVariantType: " + assetRequests);
						break;
					}
					Task.Run(delegate
					{
						metadataResult.SetResult(metadata);
					});
					break;
				}
				}
				message.Dispose();
				RefreshJobs();
			}
		}

		private void EnqueueForTransmission(ControlMessage msg)
		{
			Session.Messages.Outgoing.EnqueueForTransmission(msg, isOrigin: true, useBackgroundEncoder: true);
		}

		private void RefreshJobs()
		{
			int num = MathX.Max(OverrideMaxConcurrentTransfers ?? MaxConcurrentTranfers, 1);
			while (transmitJobs.Count < num && transmitJobsToInitialize.Count > 0)
			{
				int index = -1;
				int num2 = int.MaxValue;
				for (int i = 0; i < transmitJobsToInitialize.Count; i++)
				{
					FileTransmitJob fileTransmitJob = transmitJobsToInitialize[i];
					if (!connectionIndexes.TryGetValue(fileTransmitJob.Target, out var value))
					{
						value = -1;
					}
					if (value < num2)
					{
						index = i;
						num2 = value;
					}
				}
				FileTransmitJob fileTransmitJob2 = transmitJobsToInitialize.TakeOne(index);
				connectionIndexes.Remove(fileTransmitJob2.Target);
				connectionIndexes.Add(fileTransmitJob2.Target, globalConnectionIndex++);
				if (globalConnectionIndex == int.MaxValue)
				{
					globalConnectionIndex = 0;
				}
				JobID key = ID(fileTransmitJob2.Target, fileTransmitJob2.ID);
				transmitJobs.Add(key, fileTransmitJob2);
				EnqueueForTransmission(fileTransmitJob2.Initialize());
			}
		}

		private JobID ID(ControlMessage message)
		{
			return new JobID(message.Sender, message.Data.ExtractOrThrow<int>("ID"));
		}

		private JobID ID(IConnection connection, int id)
		{
			return new JobID(connection, id);
		}
