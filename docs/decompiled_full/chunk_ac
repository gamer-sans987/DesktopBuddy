		}

		public void Update()
		{
			if (EnsureActive())
			{
				ChangesBatch batch = _space.BeginChangesBatch();
				UpdateListeners(batch);
				UpdateAudioOutputs(batch);
				UpdateAudioEffects(batch);
				_space.FinishChangesBatch(batch);
			}
