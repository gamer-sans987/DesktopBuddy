		{
			OwnerType ownerType = IdUtil.GetOwnerType(record.OwnerId);
			await Engine.LocalDB.DeleteRecordAsync(record);
			if (ownerType != OwnerType.Machine)
			{
				CloudResult cloudResult = await Engine.Cloud.Records.DeleteRecord(record).ConfigureAwait(continueOnCapturedContext: false);
				if (cloudResult.IsError)
				{
