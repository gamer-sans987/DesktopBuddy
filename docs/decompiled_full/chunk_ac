		internal async Task Initialize(Engine engine, LaunchOptions options)
		{
			Engine = engine;
			engine.OnShutdown += Engine_OnShutdown;
			Simulator = new AudioSimulator(48000);
			PrimaryOutput = new AudioDeviceOutput(Simulator);
			StreamingOutput = new AudioDeviceOutput(Simulator);
			Simulator.RenderStarted += Simulator_RenderStarted;
			computedGroupVolumes = new float[Enum.GetValues(typeof(AudioTypeGroup)).Length];
			Settings.RegisterValueChanges<AudioInputDeviceSettings>(OnAudioInputDeviceChanged);
			Settings.RegisterValueChanges<AudioOutputDeviceSettings>(OnAudioOutputDeviceChanged);
			Settings.RegisterComponentChanges<AudioVolumeSettings>(OnVolumeChanged);
			Settings.RegisterComponentChanges<AudioAccessibilitySettings>(OnAccessibilityChanged);
			Settings.RegisterComponentChanges<AudioInputFilteringSettings>(OnInputChanged);
			Settings.RegisterValueChanges<AudioPerformanceSettings>(OnPerformanceChanged);
			Settings.GetActiveSetting<VoiceSettings>();
			if (engine.InputInterface.HeadOutputDevice != HeadOutputDevice.Headless)
			{
				if (engine.Platform == Platform.Linux || options.ForceAlternateAudio)
				{
					UniLog.Log("Initializing SoundFlow Audio Driver");
					SoundFlowAudioDriver.Initialize(engine.InputInterface);
				}
				else if (engine.Platform == Platform.Windows)
				{
					UniLog.Log("Initializing CSCore Audio Input Driver");
					CSCoreAudioInputDriver.Initialize(engine.InputInterface);
				}
			}
			audioThreadLoop = new AudioThreadLoopUpdater(Simulator);
			audioThreadLoop.StartThread();
			UpdateSampleRate();
			OVRLipSync = new OVRLipSyncInterface(SampleRate, SimulationFrameSize);
		}

		private void Engine_OnShutdown()
		{
			try
			{
				UniLog.Log("Shutting down audio system");
				audioThreadLoop.StopThread();
				(PrimaryOutput.Device as AudioOutputDriver)?.Stop();
				(StreamingOutput.Device as AudioOutputDriver)?.Stop();
				Simulator.Dispose();
			}
			catch (Exception ex)
			{
				UniLog.Error("Exception when shutting down audio system:\n" + ex, stackTrace: false);
			}
		}

