							matrix4x2 = matrix4x * matrix4x2;
							array[i] = matrix4x2;
						}
					}
					if (nodeAnimationChannel.HasRotationKeys)
					{
						Assimp.Matrix4x4[] array2 = new Assimp.Matrix4x4[nodeAnimationChannel.RotationKeys.Count];
						dictionary2.Add(nodeAnimationChannel, array2);
						for (int j = 0; j < nodeAnimationChannel.RotationKeys.Count; j++)
						{
							Assimp.Matrix4x4 matrix4x3 = nodeAnimationChannel.RotationKeys[j].Value.GetMatrix();
							matrix4x3 = matrix4x * matrix4x3;
							array2[j] = matrix4x3;
