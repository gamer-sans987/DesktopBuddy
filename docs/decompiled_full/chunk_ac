		private void Simulator_RenderStarted(AudioSimulator simulator)
		{
			Action result;
			while (_preRenderTasks.TryDequeue(out result))
			{
				try
				{
					result();
				}
				catch (Exception value)
				{
					UniLog.Log($"Exception in audio pre-render task:\n{value}");
				}
			}
			lock (_audioUpdateListeners)
			{
				foreach (Action audioUpdateListener in _audioUpdateListeners)
				{
					try
					{
						audioUpdateListener();
					}
					catch (Exception exception)
					{
						UniLog.Warning("Exception in audio update listener: " + DebugManager.PreprocessException(exception));
					}
				}
			}
		}
	}
	public class OpenLipSyncContext : IDisposable
	{
		private OpenLipSyncBackend backend;

		private uint _context;

		private OpenLipSync.Inference.OVRCompat.Frame _frame = new OpenLipSync.Inference.OVRCompat.Frame();

		public bool IsInitialized { get; private set; }

		public float Smoothing { get; private set; } = -1f;

		public OpenLipSyncContext(int sampleRate, int simulationFrameSize)
		{
			backend = new OpenLipSyncBackend();
			backend.DefaultModelPath = "RuntimeData/OpenLipSync/model.onnx";
			OpenLipSync.Inference.OVRCompat.Result result = backend.Initialize(sampleRate, simulationFrameSize);
			UniLog.Log($"OpenLipSync init {sampleRate} Hz (buffer length: {simulationFrameSize}) result: {result}");
			IsInitialized = result == OpenLipSync.Inference.OVRCompat.Result.Success;
			if (IsInitialized)
			{
				result = backend.CreateContext(ref _context, ContextProviders.Enhanced_with_Laughter, sampleRate, enableAcceleration: true);
				if (result != OpenLipSync.Inference.OVRCompat.Result.Success)
				{
					UniLog.Log($"Failed to create context for OpenLipSync: {result}");
					IsInitialized = false;
				}
			}
		}

		public void Update(float smoothing)
		{
			if (!(Math.Abs(smoothing - Smoothing) < 1E-06f))
			{
				Smoothing = smoothing;
				if (_context != 0)
				{
					int arg = MathX.Clamp(MathX.RoundToInt(Smoothing * 100f), 0, 100);
					backend.SendSignal(_context, Signals.VisemeSmoothing, arg);
				}
			}
		}

		public void Analyze(ReadOnlySpan<float> audioData, float[] analysis)
		{
			if (analysis == null)
			{
				throw new ArgumentNullException("analysis");
			}
			if (audioData.IsEmpty)
			{
				throw new ArgumentException("Is empty", "audioData");
			}
			if (!IsInitialized)
			{
				Array.Clear(analysis);
				return;
			}
			backend.ProcessFrameFloat(_context, audioData, stereo: false, ref _frame);
			int num = Math.Min(15, analysis.Length);
			for (int i = 0; i < num; i++)
			{
				analysis[i] = _frame.Visemes[i];
			}
			if (analysis.Length > 15)
			{
				analysis[15] = _frame.laughterScore;
			}
		}

		public void Dispose()
		{
			backend.Shutdown();
		}
	}
	public class OVRLipSyncContext : IDisposable
	{
		private readonly struct AnalysisTask
		{
			public readonly OVRLipSyncContext context;

			public readonly float[] buffer;

			public readonly float[] analysis;

			public readonly Action onDone;

			public AnalysisTask(OVRLipSyncContext context, float[] buffer, float[] analysis, Action onDone)
			{
				this.context = context;
				this.buffer = buffer;
				this.analysis = analysis;
				this.onDone = onDone;
			}
		}

		private static ActionBlock<AnalysisTask> processor = new ActionBlock<AnalysisTask>(delegate(AnalysisTask task)
		{
			task.context.RunAnalysis(in task);
		}, new ExecutionDataflowBlockOptions
		{
			MaxDegreeOfParallelism = 1,
			EnsureOrdered = false
		});

		private OVRLipSyncInterface ovrLipSync;

		private uint context;

		private OVRLipSyncInterface.Frame frame = new OVRLipSyncInterface.Frame();

		public bool IsInitialized => context != 0;

		public float Smoothing { get; private set; } = -1f;

		public OVRLipSyncContext(OVRLipSyncInterface ovrLipSync)
		{
			try
			{
				this.ovrLipSync = ovrLipSync;
				OVRLipSyncInterface.Result result = ovrLipSync.CreateContext(ref context, OVRLipSyncInterface.ContextProviders.Enhanced_with_Laughter, ovrLipSync.SampleRate, enableAcceleration: true);
				if (result != OVRLipSyncInterface.Result.Success)
				{
					context = 0u;
					UniLog.Error("Error initializing OVRLipSyncInterface: " + result);
				}
			}
			catch (Exception ex)
			{
				context = 0u;
				UniLog.Error("Exception initializing OVRLipSyncInterface: " + ex);
			}
		}

		public void Update(float smoothing)
		{
			if (smoothing == Smoothing)
			{
				return;
			}
			Smoothing = smoothing;
			lock (this)
			{
				if (context != 0)
				{
					int arg = MathX.Clamp((int)(Smoothing * 100f), 0, 100);
					OVRLipSyncInterface.Result result = ovrLipSync.SendSignal(context, OVRLipSyncInterface.Signals.VisemeSmoothing, arg, 0);
					if (result != OVRLipSyncInterface.Result.Success)
					{
						UniLog.Error("Error setting OVRLipSyncInterface smoothing: " + result, stackTrace: false);
					}
				}
			}
		}

		public void Dispose()
		{
			lock (this)
			{
				OVRLipSyncInterface.Result result = ovrLipSync.DestroyContext(context);
				context = 0u;
				if (result != OVRLipSyncInterface.Result.Success)
				{
					UniLog.Error("Error destroying OVRLipSyncInterface: " + result);
				}
			}
		}

		public void Analyze(float[] audioData, float[] analysis, Action onDone)
		{
			processor.Post(new AnalysisTask(this, audioData, analysis, onDone));
		}

		private void RunAnalysis(in AnalysisTask task)
		{
			try
			{
				lock (this)
				{
					if (context == 0)
					{
						return;
					}
					OVRLipSyncInterface.Result result = ovrLipSync.ProcessFrame(context, task.buffer, frame, stereo: false);
					if (result != OVRLipSyncInterface.Result.Success)
					{
						UniLog.Error("Error processing frame with OVRLipSyncInterface: " + result);
						return;
					}
					for (int i = 0; i < task.analysis.Length; i++)
					{
						task.analysis[i] = GetData((Viseme)i);
					}
				}
			}
			finally
			{
				task.onDone();
			}
		}

		private float GetData(Viseme v)
		{
			if (v == Viseme.Laughter)
			{
				return frame.laughterScore;
			}
			return frame.Visemes[(int)v];
		}
	}
