				}
				return LOCAL_CATEGORY;
			}
		}

		public void Initialize(Engine engine)
		{
			Engine = engine;
		}

		protected override Task RunDownload()
		{
			if (Engine.PrecachePath != null && base.URL.Scheme == Cloud.Assets.DBScheme)
			{
				string name = Cloud.Assets.DBFilename(base.URL);
				name = EngineAssetGatherer.PrecacheName(name);
				string text = Path.Combine(Engine.PrecachePath, name);
				if (File.Exists(text))
				{
					FinishGathering(text);
					return Task.CompletedTask;
				}
			}
			if (base.URL.Scheme == "local" || (ForceGatherFrom != null && !ForceGatherFrom.IsDestroyed))
			{
				return RunSessionDownload();
			}
			return base.RunDownload();
		}

		private async Task RunSessionDownload()
		{
			base.State = GatherJobState.Initiating;
			if (base.URL.Host == Engine.LocalDB.MachineID)
			{
				Fail("Asset owner is host", nonRecoverable: true);
				return;
			}
			_registeredWorld = Engine.AssetManager.GetBestWorldForLocal(base.URL);
			if (_registeredWorld != null)
			{
				_sessionGatherCompletionSource = new TaskCompletionSource<dummy>();
				SessionGatherCallbacks callbacks = new SessionGatherCallbacks(SessionAssetGathered, SessionGatherProgress);
				_registeredWorld.RunSynchronously(delegate
				{
					if (_registeredWorld.Session == null)
					{
						Fail("World Session is null!", nonRecoverable: true);
						_sessionGatherCompletionSource.TrySetResult(default(dummy));
					}
					else
					{
						_registeredWorld.Session.Assets.RequestAsset(base.URL, callbacks);
					}
				});
				_registeredWorld.WorldDestroyed += OnWorldDestroyed;
				await _sessionGatherCompletionSource.Task;
			}
			else
			{
				Fail("Couldn't find world with the owner of the asset", nonRecoverable: true);
			}
		}

		private void OnWorldDestroyed(World world)
		{
			Fail("The world of the asset owner has been destroyed", nonRecoverable: true);
			_sessionGatherCompletionSource.TrySetResult(default(dummy));
		}

		private void SessionAssetGathered(Uri assetURL, string filePath, string failReason)
		{
			if (filePath == null)
			{
				Fail(failReason, nonRecoverable: false);
			}
			else
			{
				FinishGathering(filePath);
			}
			_sessionGatherCompletionSource.SetResult(default(dummy));
			if (_registeredWorld != null)
			{
				_registeredWorld.WorldDestroyed -= OnWorldDestroyed;
				_registeredWorld = null;
			}
		}

		private void SessionGatherProgress(Uri assetURL, long totalBytes, long receivedBytes)
		{
			if (base.State != GatherJobState.Gathering)
			{
				StartGathering();
			}
			UpdateBytes(totalBytes, receivedBytes);
		}

		protected override async Task<string> FinishGather()
		{
			string text = await Engine.LocalDB.StoreCacheRecordAsync(base.URL, base.FilePath).ConfigureAwait(continueOnCapturedContext: false);
			if (Engine.GeneratePrecache && base.URL.Scheme == Cloud.Assets.DBScheme && File.Exists(text))
			{
				string name = Cloud.Assets.DBFilename(base.URL);
				name = EngineAssetGatherer.PrecacheName(name);
				string text2 = Path.Combine(Engine.PrecachePath, name);
				if (!File.Exists(text2))
				{
					File.Copy(base.FilePath, text2);
				}
			}
			return text;
		}
	}
