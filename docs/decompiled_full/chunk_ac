		public static void OnTextureTransparent(ITexture2DProvider tex, Action callback)
		{
			StaticTexture2D staticTex2D = tex as StaticTexture2D;
			if (staticTex2D != null)
			{
				staticTex2D.World.Coroutines.StartTask(async delegate
				{
					await DetectTextureTransparent(staticTex2D, callback);
				});
			}
		}

		private static async Task DetectTextureTransparent(StaticTexture2D tex, Action callback)
		{
			while (!tex.IsAssetAvailable && !tex.IsDestroyed)
			{
				await default(NextUpdate);
			}
			if (!tex.IsDestroyed && tex.Asset != null && (await tex.Asset.GetOriginalTextureData().ConfigureAwait(continueOnCapturedContext: false)).HasTransparentPixels())
			{
				await default(ToWorld);
				callback();
			}
		}

		public static void OnDetectNormalMap(ITexture2DProvider tex, Action callback)
		{
			StaticTexture2D staticTex2D = tex as StaticTexture2D;
			if (staticTex2D != null)
			{
				staticTex2D.World.Coroutines.StartTask(async delegate
				{
					await DetectNormalMap(staticTex2D, callback);
				});
			}
		}

		private static async Task DetectNormalMap(StaticTexture2D tex, Action callback)
		{
			while (!tex.IsAssetAvailable && !tex.IsDestroyed)
			{
				await default(NextUpdate);
			}
			if (!tex.IsDestroyed && tex.Asset != null)
			{
				Elements.Core.colorX colorX = (await tex.Asset.GetOriginalTextureData().ConfigureAwait(continueOnCapturedContext: false)).AverageColor((Elements.Core.color c) => c.a == 1f);
				if (MathX.Average(colorX.r, colorX.g) < colorX.b * 0.85f)
				{
					await default(ToWorld);
					callback();
				}
			}
		}

		public static ModelImportSettings Unlit(bool generateColliders = true, bool importBones = true, bool importAnimations = true, bool forceDualsided = false, bool billboard = false, BlendMode? forceBlendMode = null)
		{
			ModelImportSettings settings = new ModelImportSettings();
			settings.GenerateColliders = generateColliders;
			settings.CalculateNormals = false;
			settings.CalculateTangents = false;
			settings.ImportBones = importBones;
			settings.ImportAnimations = importAnimations;
			settings.MaterialMapper = delegate(Slot slot, Assimp.Material assimp, List<TextureMapping> textures)
			{
				UnlitMaterial unlit = slot.AttachComponent<UnlitMaterial>();
				if (billboard)
				{
					unlit.UseBillboardGeometry.Value = true;
					unlit.UseVertexColors.Value = true;
				}
				if (forceDualsided)
				{
					unlit.Sidedness.Value = Sidedness.Double;
				}
				if (forceBlendMode.HasValue)
				{
					unlit.BlendMode.Value = forceBlendMode.Value;
				}
				if (assimp.HasColorDiffuse && settings.ImportAlbedoColor)
				{
					unlit.TintColor.Value = assimp.ColorDiffuse.ToEngine();
				}
				if (settings.GenerateRandomMaterialColors)
				{
					unlit.TintColor.Value = RandomX.RGB;
				}
				foreach (TextureMapping texture in textures)
				{
					if (texture.IsExternal)
					{
						settings.GetExternalMapper(texture.external).mapper(unlit, texture.engineProvider);
					}
					else if (texture.assimp.TextureType == Assimp.TextureType.Diffuse)
					{
						unlit.Texture.Target = texture.engineProvider;
						if (settings.CalculateTextureAlpha)
						{
							OnTextureTransparent(texture.engineProvider, delegate
							{
								unlit.BlendMode.Value = BlendMode.Alpha;
							});
						}
					}
				}
				return unlit;
			};
			return settings;
		}

		public static ModelImportSettings XiexeToon(bool generateColliders = true, bool importBones = true, bool importAnimations = true, bool outline = false, BlendMode? forceBlendMode = null)
		{
			ModelImportSettings settings = new ModelImportSettings();
			settings.GenerateColliders = generateColliders;
			settings.CalculateNormals = false;
			settings.CalculateTangents = false;
			settings.ImportBones = importBones;
			settings.ImportAnimations = importAnimations;
			settings.MaterialMapper = delegate(Slot slot, Assimp.Material assimp, List<TextureMapping> textures)
			{
				XiexeToonMaterial xixe = slot.AttachComponent<XiexeToonMaterial>();
				if (forceBlendMode.HasValue)
				{
					xixe.BlendMode.Value = forceBlendMode.Value;
				}
				if (outline)
				{
					xixe.Outline.Value = XiexeToonMaterial.OutlineStyle.Emissive;
					xixe.OutlineColor.Value = Elements.Core.colorX.Black;
				}
				if (settings.GenerateRandomMaterialColors)
				{
					xixe.Color.Value = RandomX.RGB;
				}
				foreach (TextureMapping texture in textures)
				{
					if (texture.IsExternal)
					{
						settings.GetExternalMapper(texture.external).mapper(xixe, texture.engineProvider);
					}
					else
					{
						switch (texture.assimp.TextureType)
						{
						case Assimp.TextureType.Diffuse:
							xixe.MainTexture.Target = texture.engineProvider;
							if (settings.CalculateTextureAlpha)
							{
								OnTextureTransparent(texture.engineProvider, delegate
								{
									xixe.BlendMode.Value = BlendMode.Cutout;
								});
							}
							break;
						case Assimp.TextureType.Emissive:
							if (settings.ImportEmissive)
							{
								xixe.EmissionMap.Target = texture.engineProvider;
								xixe.EmissionColor.Value = Elements.Core.colorX.White;
							}
							break;
						case Assimp.TextureType.Normals:
							xixe.NormalMap.Target = texture.engineProvider;
							break;
						case Assimp.TextureType.Height:
						{
							ITexture2DProvider _tex = texture.engineProvider;
							OnDetectNormalMap(texture.engineProvider, delegate
							{
								if (xixe.NormalMap.Target == null)
								{
									xixe.NormalMap.Target = _tex;
								}
							});
							break;
						}
						}
					}
				}
				return xixe;
			};
			return settings;
		}

		public static ModelImportSettings Wireframe(bool generateColliders = true, bool importBones = true, bool importAnimations = true)
		{
			ModelImportSettings settings = new ModelImportSettings();
			settings.GenerateColliders = generateColliders;
			settings.CalculateNormals = true;
			settings.CalculateTangents = true;
			settings.ImportBones = importBones;
			settings.ImportAnimations = importAnimations;
			settings.MaterialMapper = delegate(Slot slot, Assimp.Material assimp, List<TextureMapping> textures)
			{
				WireframeMaterial wireframeMaterial = slot.AttachComponent<WireframeMaterial>();
				if (assimp.HasColorDiffuse && settings.ImportAlbedoColor)
				{
					wireframeMaterial.FillColor.Value = assimp.ColorDiffuse.ToEngine();
				}
				if (settings.GenerateRandomMaterialColors)
				{
					wireframeMaterial.FillColor.Value = RandomX.RGB;
				}
				wireframeMaterial.FillFarColor.Value = new Elements.Core.colorX(wireframeMaterial.FillColor.Value.rgb * 0.5f, wireframeMaterial.FillColor.Value.a);
				foreach (TextureMapping texture in textures)
				{
					if (texture.IsExternal)
					{
						settings.GetExternalMapper(texture.external).mapper(wireframeMaterial, texture.engineProvider);
					}
					else if (texture.assimp.TextureType == Assimp.TextureType.Diffuse)
					{
						wireframeMaterial.Texture.Target = texture.engineProvider;
					}
				}
				return wireframeMaterial;
			};
			return settings;
		}

		public static ModelImportSettings PBS(bool generateColliders = true, bool importBones = true, bool importAnimations = true, bool pbsUnlit = false, bool mapExternalTextures = false, bool preferSpecular = false)
		{
			return PBS<PBS_Metallic, PBS_Specular>(generateColliders, importBones, importAnimations, pbsUnlit, mapExternalTextures, preferSpecular);
		}

		public static ModelImportSettings PBS<METALLIC, SPECULAR>(bool generateColliders = true, bool importBones = true, bool importAnimations = true, bool pbsUnlit = false, bool mapExternalTextures = false, bool preferSpecular = false) where METALLIC : Component, IPBS_Metallic, new() where SPECULAR : Component, IPBS_Specular, new()
		{
			ModelImportSettings settings = new ModelImportSettings();
			settings.GenerateColliders = generateColliders;
			settings.CalculateNormals = true;
			settings.CalculateTangents = true;
			settings.ImportBones = importBones;
			settings.ImportAnimations = importAnimations;
			if (mapExternalTextures)
			{
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					((IPBS_Material)mat).AlbedoTexture = tex;
				}, "albedo", "diffuse"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					if (mat is PBS_Material pBS_Material)
					{
						pBS_Material.DetailAlbedoTexture.Target = tex;
					}
				}, "albedodetail", "diffusedetail"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					((IPBS_Material)mat).NormalMap = tex;
				}, "normal", "bump"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					if (mat is PBS_Material pBS_Material)
					{
						pBS_Material.DetailNormalMap.Target = tex;
					}
				}, "normaldetail", "bumpdetail"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					((IPBS_Material)mat).OcclusionMap = tex;
				}, "occlusion", "ao", "ambientocclusion"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					if (mat is PBS_Material pBS_Material)
					{
						pBS_Material.HeightMap.Target = tex;
					}
				}, "height", "heightmap", "disp", "displacement"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					if (settings.ImportEmissive)
					{
						IPBS_Material iPBS_Material = (IPBS_Material)mat;
						iPBS_Material.EmissiveMap = tex;
						if (iPBS_Material.EmissiveColor.rgb == Elements.Core.float3.Zero)
						{
							iPBS_Material.EmissiveColor = Elements.Core.colorX.White;
						}
					}
				}, "emission", "emissive"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					if (mat is IPBS_Specular iPBS_Specular)
					{
						iPBS_Specular.SpecularMap = tex;
					}
				}, "specular"));
				settings.ExternalTextureMappings.Add(new ExternalMapping(delegate(IAssetProvider<Material> mat, IAssetProvider<ITexture2D> tex)
				{
					if (mat is IPBS_Metallic iPBS_Metallic)
					{
						iPBS_Metallic.MetallicMap = tex;
					}
				}, "metallic", "metalness"));
			}
			settings.MaterialMapper = delegate(Slot slot, Assimp.Material assimp, List<TextureMapping> textures)
			{
				bool flag = textures.Any((TextureMapping t) => t.external == "specular");
				IPBS_Metallic engineMetallic = null;
				IPBS_Specular iPBS_Specular = null;
				IPBS_Material enginePBS;
				PBS_Material standardPBS;
				if (flag || preferSpecular)
				{
					iPBS_Specular = (IPBS_Specular)(enginePBS = slot.AttachComponent<SPECULAR>());
					standardPBS = enginePBS as PBS_Material;
				}
				else
				{
					engineMetallic = slot.AttachComponent<METALLIC>();
					enginePBS = engineMetallic;
					standardPBS = enginePBS as PBS_Material;
				}
				if (!mapExternalTextures)
				{
					if (assimp.HasColorDiffuse && settings.ImportAlbedoColor)
					{
						enginePBS.AlbedoColor = assimp.ColorDiffuse.ToEngine();
					}
					if (assimp.HasColorEmissive && settings.ImportEmissive)
					{
						enginePBS.EmissiveColor = assimp.ColorEmissive.ToEngine();
					}
					if (flag)
					{
						iPBS_Specular.SpecularColor = Elements.Core.colorX.Clear;
					}
					if (flag && pbsUnlit)
					{
						iPBS_Specular.SpecularColor = Elements.Core.colorX.Clear;
					}
					if (!flag && pbsUnlit)
					{
						engineMetallic.Metallic = 0f;
						engineMetallic.Smoothness = 0f;
					}
				}
				if (settings.GenerateRandomMaterialColors)
				{
					enginePBS.AlbedoColor = RandomX.RGB;
				}
				TextureMapping roughness = textures.FirstOrDefault((TextureMapping t) => !t.IsExternal && t.assimp.TextureType == Assimp.TextureType.Roughness);
				TextureMapping metallic = textures.FirstOrDefault((TextureMapping t) => !t.IsExternal && t.assimp.TextureType == Assimp.TextureType.Metalness);
				if (engineMetallic != null && (roughness.engineProvider != null || metallic.engineProvider != null))
				{
					engineMetallic.Slot.StartTask(async delegate
					{
						if (roughness.engineProvider != null)
						{
							while (!roughness.engineProvider.IsAssetAvailable)
							{
								await default(NextUpdate);
							}
						}
						if (metallic.engineProvider != null)
						{
							while (!metallic.engineProvider.IsAssetAvailable)
							{
								await default(NextUpdate);
							}
						}
						await default(ToBackground);
						Task<Bitmap2D> task = (roughness.engineProvider as StaticTexture2D)?.Asset?.GetOriginalTextureData();
						Task<Bitmap2D> metallicTexTask = (metallic.engineProvider as StaticTexture2D)?.Asset?.GetOriginalTextureData();
						Bitmap2D roughnessTex = null;
						Bitmap2D metallicTex = null;
						if (task != null)
						{
							roughnessTex = await task.ConfigureAwait(continueOnCapturedContext: false);
						}
						if (metallicTex != null)
						{
							metallicTex = await metallicTexTask.ConfigureAwait(continueOnCapturedContext: false);
						}
						Bitmap2D bitmap2D = new Bitmap2D(metallicTex?.Size.x ?? roughnessTex.Size.x, metallicTex?.Size.y ?? roughnessTex.Size.y, metallicTex?.Format ?? roughnessTex.Format, mipmaps: false, ColorProfile.Linear);
						bitmap2D.ForEachPixelUV(delegate(Elements.Core.float2 uv)
						{
							Elements.Core.float3 rgb = metallicTex?.SampleUV(in uv).rgb ?? Elements.Core.float3.Zero;
							float num4 = roughnessTex?.SampleUV(in uv).r ?? 1f;
							return new Elements.Core.color(in rgb, 1f - num4);
						});
						Uri uri = await engineMetallic.Slot.Engine.LocalDB.SaveAssetAsync(bitmap2D).ConfigureAwait(continueOnCapturedContext: false);
						await default(ToWorld);
						ITexture2DProvider texture2DProvider = metallic.engineProvider ?? roughness.engineProvider;
						((StaticTexture2D)texture2DProvider).URL.Value = uri;
						engineMetallic.MetallicMap = texture2DProvider;
					});
				}
				foreach (TextureMapping texture in textures)
				{
					if (texture.IsExternal)
					{
						settings.GetExternalMapper(texture.external)?.mapper(enginePBS, texture.engineProvider);
					}
					else
					{
						switch (texture.assimp.TextureType)
						{
						case Assimp.TextureType.Diffuse:
						case Assimp.TextureType.BaseColor:
							if (pbsUnlit)
							{
								enginePBS.EmissiveMap = texture.engineProvider;
								enginePBS.EmissiveColor = Elements.Core.colorX.White;
								enginePBS.AlbedoColor = Elements.Core.colorX.Black;
							}
							else
							{
								enginePBS.AlbedoTexture = texture.engineProvider;
								if (MathX.Approximately(enginePBS.AlbedoColor.rgb, Elements.Core.float3.Zero))
								{
									enginePBS.AlbedoColor = Elements.Core.colorX.White;
								}
								if (settings.CalculateTextureAlpha)
								{
									OnTextureTransparent(texture.engineProvider, delegate
									{
										enginePBS.BlendMode = BlendMode.Cutout;
									});
								}
							}
							break;
						case Assimp.TextureType.Normals:
						case Assimp.TextureType.NormalCamera:
							enginePBS.NormalMap = texture.engineProvider;
							break;
						case Assimp.TextureType.Emissive:
						case Assimp.TextureType.EmissionColor:
							if (settings.ImportEmissive)
							{
								enginePBS.EmissiveMap = texture.engineProvider;
								if (enginePBS.EmissiveColor.rgb == Elements.Core.float3.Zero)
								{
									enginePBS.EmissiveColor = Elements.Core.colorX.White;
								}
							}
							break;
						case Assimp.TextureType.Specular:
							if (iPBS_Specular != null)
							{
								iPBS_Specular.SpecularMap = texture.engineProvider;
							}
							else
							{
								UniLog.Log("Imported material has SpecularMap, but target material isn't PBS_Specuar");
							}
							break;
						case Assimp.TextureType.Height:
						{
							if (standardPBS != null)
							{
								standardPBS.HeightMap.Target = texture.engineProvider;
							}
							ITexture2DProvider _tex = texture.engineProvider;
							OnDetectNormalMap(_tex, delegate
							{
								if (enginePBS.NormalMap == null)
								{
									UniLog.Log("Height Map looks like Normal Map, fixing.");
									enginePBS.NormalMap = _tex;
									if (standardPBS != null)
									{
										standardPBS.HeightMap.Target = null;
									}
								}
							});
							break;
						}
						case Assimp.TextureType.Ambient:
						case Assimp.TextureType.AmbientOcclusion:
							enginePBS.OcclusionMap = texture.engineProvider;
							break;
						default:
						{
							UniLog.Log("Trying to use heuristic mapping: " + texture.assimp.TextureType.ToString() + ", Flags: " + texture.assimp.Flags + ", Path: " + texture.assimp.FilePath);
							string text = texture.assimp.FilePath.ToLower();
							if (settings.PBR_TextureFormat == PBR_TextureFormat.GLTF)
							{
								int num = text.IndexOf("metal");
								int num2 = text.IndexOf("roughness");
								int num3 = text.IndexOf("occlusion");
								if (num >= 0 && num2 >= 0 && engineMetallic != null)
								{
									if (num3 >= 0)
									{
										StaticTexture2D staticTexture2D = (StaticTexture2D)texture.engineProvider.Slot.DuplicateComponent((Component)texture.engineProvider);
										engineMetallic.OcclusionMap = staticTexture2D;
										staticTexture2D.ProcessPixels((Elements.Core.color c) => new Elements.Core.color(c.rrr));
									}
									engineMetallic.MetallicMap = texture.engineProvider;
									((StaticTexture2D)texture.engineProvider).ProcessPixels((Elements.Core.color c) => new Elements.Core.color(c.bbb, 1f - c.g));
								}
								else
								{
									UniLog.Log("Couldn't map texture");
								}
							}
							else if (text.Contains("metal") && engineMetallic != null)
							{
								UniLog.Log("Mapping as metallic");
								engineMetallic.MetallicMap = texture.engineProvider;
								if (text.Contains("roughness"))
								{
									UniLog.Log("Converting from roughness");
									((StaticTexture2D)texture.engineProvider).ProcessPixels((Elements.Core.color c) => new Elements.Core.color(c.rgb, 1f - c.a));
								}
							}
							else
							{
								UniLog.Log("Couldn't map texture");
							}
							break;
						}
						case Assimp.TextureType.Metalness:
						case Assimp.TextureType.Roughness:
							break;
						}
					}
				}
				return enginePBS;
			};
			return settings;
		}
	}
