	public abstract class Asset<V> : Asset where V : class, IEngineAssetVariantDescriptor<V>
	{
		private bool runningUpdate;

		private bool unload;

		private bool waitingForDowngrade;

		private Asset<V> relocatedAsset;

		protected Dictionary<IAssetRequester, V> requests = new Dictionary<IAssetRequester, V>();

		protected KeyCounter<V> variantCounter = new KeyCounter<V>();

		private bool relocatingRequests;

		public V LoadedVariant { get; private set; }

		public V TargetVariant { get; private set; }

		public bool ForceUpdate { get; private set; }

		public override IEngineAssetVariantDescriptor TargetVariantDescriptor => TargetVariant;

		public Asset<V> ForceLoadRequestingAsset { get; private set; }

		public override int ActiveRequestCount => requests.Count;

		private V GetNewTargetVariant(V newVariant)
		{
			if (requests.Count == 0)
			{
				if (TargetVariant != null && !TargetVariant.Equals(newVariant) && !TargetVariant.CanConvertTo(newVariant))
				{
					return null;
				}
				return newVariant;
			}
			V val = TargetVariant.CombineWith(newVariant);
			if (val == null)
			{
				return null;
			}
			if (!TargetVariant.Equals(val) && !TargetVariant.CanConvertTo(val))
			{
				return null;
			}
			return val;
		}

		internal override void ForceLoad(Asset requestingAsset, IEngineAssetVariantDescriptor variant)
		{
			CheckStatic();
			if (TargetVariant != null || requests.Count > 0)
			{
				throw new Exception("Cannot force load asset that already has active target variant or any requests");
			}
			ForceLoadRequestingAsset = (Asset<V>)requestingAsset;
			TargetVariant = (V)variant;
			RunUpdate();
		}

		internal override bool TryAddRequest(IAssetRequester requester, IEngineAssetVariantDescriptor variantDescriptor)
		{
			CheckStatic();
			if (!(variantDescriptor is V val))
			{
				throw new Exception("Invalid variant descriptor type: " + variantDescriptor?.GetType());
			}
			if (ForceLoadRequestingAsset != null)
			{
				return false;
			}
			if (relocatedAsset != null)
			{
				throw new Exception("Asset has been relocated, it's illegal to add new requests to the old variant");
			}
			V newTargetVariant = GetNewTargetVariant(val);
			if (newTargetVariant == null)
			{
				return false;
			}
			TargetVariant = newTargetVariant;
			requests.Add(requester, val);
			variantCounter.Increment(val);
			requester.AssignAsset(this);
			if (LoadedVariant == null || !LoadedVariant.Equals(TargetVariant))
			{
				RunUpdate();
			}
			else
			{
				requester.AssetLoadStateUpdated(this);
			}
			if (requests.Count == 1 && (base.LoadState == AssetLoadState.FullyLoaded || base.LoadState == AssetLoadState.Failed))
			{
				base.VariantManager.VariantLoaded(this);
			}
			return true;
		}

		internal override void RemoveRequest(IAssetRequester requester)
		{
			CheckStatic();
			lock (base.VariantManager.VariantLock)
			{
				if (relocatedAsset != null)
				{
					relocatedAsset.RemoveRequest(requester);
					return;
				}
				V key = requests[requester];
				requests.Remove(requester);
				if (requests.Count > 0)
				{
					if (variantCounter.Decrement(key) == 0)
					{
						CheckAndScheduleDowngrade();
					}
				}
				else
				{
					base.VariantManager.ScheduleUnload(this, UnloadDelay);
				}
			}
		}

		private void CheckAndScheduleDowngrade()
		{
			V val = CalculateMinimalTargetVariant();
			if (TargetVariant.Equals(val) || TargetVariant.CanConvertTo(val))
			{
				TargetVariant = val;
				RunUpdate();
			}
			else if (!waitingForDowngrade)
			{
				waitingForDowngrade = true;
				base.VariantManager.ForceLoad(this, val);
			}
		}

		internal override void VariantLoaded(Asset asset)
		{
			if (relocatingRequests)
			{
				return;
			}
			Asset<V> asset2 = (Asset<V>)asset;
			bool flag = false;
			if (asset2.ForceLoadRequestingAsset != null)
			{
				if (asset2.ForceLoadRequestingAsset != this)
				{
					return;
				}
				if (unload)
				{
					asset.QueueUnload();
					return;
				}
				flag = true;
			}
			if (asset2.TargetVariant.CombineWith(TargetVariant) != null && (asset2.TargetVariant.Equals(TargetVariant) || asset2.TargetVariant.CanConvertTo(TargetVariant)))
			{
				relocatingRequests = true;
				foreach (KeyValuePair<IAssetRequester, V> request in requests)
				{
					if (!asset2.TryAddRequest(request.Key, request.Value))
					{
						throw new Exception("Failed transferring asset request to a compatible variant");
					}
				}
				requests.Clear();
				relocatedAsset = asset2;
				QueueUnload();
				relocatingRequests = false;
			}
			else if (flag)
			{
				asset.QueueUnload();
				waitingForDowngrade = false;
				CheckAndScheduleDowngrade();
			}
		}

		private V CalculateMinimalTargetVariant()
		{
			V val = null;
			foreach (KeyValuePair<V, int> item in variantCounter)
			{
				if (val == null)
				{
					val = item.Key;
					continue;
				}
				val = val.CombineWith(item.Key);
				if (val != null)
				{
					continue;
				}
				StringBuilder stringBuilder = new StringBuilder();
				stringBuilder.AppendLine("Combining two existing requests resulted in null");
				foreach (KeyValuePair<V, int> item2 in variantCounter)
				{
					stringBuilder.AppendLine("Variant: " + item2);
				}
				throw new Exception(stringBuilder.ToString());
			}
			return val;
		}

		internal override void QueueUnload()
		{
			base.VariantManager.VariantRemoved(this);
			unload = true;
			RunUpdate();
		}

		protected override void OnLoadStateChanged()
		{
			if (base.LoadState == AssetLoadState.FullyLoaded || base.LoadState == AssetLoadState.Failed)
			{
				base.VariantManager.VariantLoaded(this);
			}
			if (base.LoadState == AssetLoadState.Unloaded)
			{
				return;
			}
			foreach (KeyValuePair<IAssetRequester, V> request in requests)
			{
				request.Key.AssetLoadStateUpdated(this);
			}
		}

		protected void ForceAssetUpdate()
		{
			lock (base.VariantManager.VariantLock)
			{
				if (base.LoadState != AssetLoadState.Failed && base.LoadState != AssetLoadState.Unloaded)
				{
					ForceUpdate = true;
					RunUpdate();
				}
			}
		}

		private void RunUpdate()
		{
			if (!runningUpdate)
			{
				runningUpdate = true;
				Task.Run((Func<Task?>)ProcessUpdate);
			}
		}

		private async Task ProcessUpdate()
		{
			try
			{
				if (base.LoadState == AssetLoadState.Created)
				{
					lock (base.VariantManager.VariantLock)
					{
						SetLoadState(AssetLoadState.LoadStarted);
					}
				}
				while (!unload)
				{
					V _targetVariant;
					lock (base.VariantManager.VariantLock)
					{
						_targetVariant = TargetVariant;
						if (!ForceUpdate && LoadedVariant != null && LoadedVariant.Equals(_targetVariant))
						{
							runningUpdate = false;
							break;
						}
					}
					await LoadTargetVariant(_targetVariant).ConfigureAwait(continueOnCapturedContext: false);
					LoadedVariant = _targetVariant;
					ForceUpdate = false;
					if (base.LoadState != AssetLoadState.FullyLoaded && base.LoadState != AssetLoadState.Failed)
					{
						lock (base.VariantManager.VariantLock)
						{
							SetLoadState(AssetLoadState.FullyLoaded);
						}
					}
					_targetVariant = null;
				}
				if (unload)
				{
					Unload();
					lock (base.VariantManager.VariantLock)
					{
						SetLoadState(AssetLoadState.Unloaded);
						return;
					}
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception processing update for asset {this}. AssetURL: {base.AssetURL}\n{value}");
				lock (base.VariantManager.VariantLock)
				{
					SetLoadState(AssetLoadState.Failed);
				}
			}
		}

		protected void SetPartiallyLoaded()
		{
			lock (base.VariantManager.VariantLock)
			{
				if (base.LoadState != AssetLoadState.PartiallyLoaded && base.LoadState != AssetLoadState.FullyLoaded)
				{
					SetLoadState(AssetLoadState.PartiallyLoaded);
				}
			}
		}

		protected abstract Task LoadTargetVariant(V variant);

		public override string ToString()
		{
			if (base.AssetType != AssetType.Static)
			{
				return $"{GetType().Name}. Dynamic Asset Owner: {base.Owner}. State: {base.LoadState}.";
			}
			return $"{GetType().Name}. Static Asset URL: {base.AssetURL}. State: {base.LoadState}.";
		}
	}
