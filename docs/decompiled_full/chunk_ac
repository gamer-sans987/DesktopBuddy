		private void ComputeCollision()
		{
			if (Simulator.HandRaycast == null)
			{
				return;
			}
			Elements.Core.float3 v = Rotation * Elements.Core.float3.Up;
			float num = 1f;
			Elements.Core.float3 origin = Position + v * (1f - Simulator.HandPalmDistance);
			Elements.Core.float3 direction = Rotation * Elements.Core.float3.Down;
			if (PhysicsManager.IsValidRaycast(in origin, in direction, num))
			{
				RaycastHit? raycastHit = Simulator.HandRaycast(origin, direction, num, this);
				if (raycastHit.HasValue)
				{
					RaycastHit value = raycastHit.Value;
					Position = value.Point + v * Simulator.HandPalmDistance;
				}
			}
		}

		private Elements.Core.float3 ClampArmLength(Elements.Core.float3 pos)
		{
			float magnitude;
			Elements.Core.float3 v = (pos - ActualShoulderPosition).GetNormalized(out magnitude);
			if (magnitude > ArmLength)
			{
				pos = ActualShoulderPosition + v * ArmLength;
			}
			return pos;
		}

		private void UpdateFingers(LocomotionSimulator.MoveData data)
		{
			_fingerPositions.Clear();
			_fingerRotations.Clear();
			if (!Simulator.FingersTracking(FingerChirality))
			{
				return;
			}
			float num = Params.FingerCurlSwaySpeed;
			float num2 = Params.FingerCurlVariationSpeed;
			float num3 = Params.FingerCurlSwayMagnitude;
			float num4 = Params.FingerCurlVariationMagnitude;
			float num5 = Params.FingerCurlOffset;
			float num6 = 0f;
			if (Simulator.AirLerp > 0f)
			{
				num = MathX.LerpUnclamped(num, Simulator.InAirFingerCurlSwaySpeed, Simulator.AirLerp);
				num2 = MathX.LerpUnclamped(num2, Simulator.InAirFingerCurlVariationSpeed, Simulator.AirLerp);
				num3 = MathX.LerpUnclamped(num3, Simulator.InAirFingerCurlSwayMagnitude, Simulator.AirLerp);
				num4 = MathX.LerpUnclamped(num4, Simulator.InAirFingerCurlVariationMagnitude, Simulator.AirLerp);
				num5 = MathX.LerpUnclamped(num5, Simulator.InAirFingerCurlOffset, Simulator.AirLerp);
				if (Simulator.SmoothVerticalVelocity > 0f)
				{
					float num7 = MathX.Clamp01(Simulator.SmoothVerticalVelocity / Simulator.InAirFingerUpwardsVelocityReference);
					num6 += Simulator.AirLerp * num7 * Simulator.InAirFingerUpwardsSplayMagnitude;
				}
				else
				{
					float num8 = MathX.Clamp01((0f - Simulator.SmoothVerticalVelocity) / Simulator.InAirFingerDownwardsVelocityReference);
					num6 += Simulator.AirLerp * num8 * Simulator.InAirFingerDownwardsSplayMagnitude;
				}
			}
			if (Simulator.FloatingLerp > 0f)
			{
				num = MathX.LerpUnclamped(num, Simulator.FloatingFingerCurlSwaySpeed, Simulator.FloatingLerp);
				num2 = MathX.LerpUnclamped(num2, Simulator.FloatingFingerCurlVariationSpeed, Simulator.FloatingLerp);
				num3 = MathX.LerpUnclamped(num3, Simulator.FloatingFingerCurlSwayMagnitude, Simulator.FloatingLerp);
				num4 = MathX.LerpUnclamped(num4, Simulator.FloatingFingerCurlVariationMagnitude, Simulator.FloatingLerp);
				num5 = MathX.LerpUnclamped(num5, Simulator.FloatingFingerCurlOffset, Simulator.FloatingLerp);
				float val = Simulator.SmoothVelocity / Simulator.FloatingFingerCurlSpeedReference;
				val = MathX.Clamp01(val);
				num5 += Simulator.FloatingFingerCurlSpeedMagnitude * val * Simulator.FloatingLerp;
				num6 += Simulator.FloatingFingerSplayOffset * Simulator.FloatingLerp;
			}
			_fingerCurlSwayProgress += data.deltaTime * num;
			_fingerCurlVariationProgress += data.deltaTime * num2;
			Span<float> span = stackalloc float[5];
			for (int i = 0; i < 5; i++)
			{
				float num9 = MathX.SimplexNoise(_fingerCurlVariationProgress + _fingerCurlVariationSeeds[i]);
				num9 *= num4;
				float pos = _fingerCurlSwayProgress + num9;
				span[i] = MathX.SimplexNoise(pos) * num3;
				span[i] += num5;
			}
			Simulator.GetBaseFingerData(FingerChirality, _fingerPositions, _fingerRotations);
			FingerPoseHelper.ModifyPose(_fingerPositions, _fingerRotations, span[0], span[1], span[2], span[3], span[4], 0f, 0f, 0f, 0f, 0f);
			if (!MathX.Approximately(num6, 0f))
			{
				FingerPoseHelper.ModifySplay(FingerChirality, _fingerPositions, _fingerRotations, num6);
			}
		}
	}
