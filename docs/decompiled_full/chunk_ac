		private class DynamicAtlas
		{
			private volatile bool _invalidated;

			public readonly Font Font;

			public readonly ConcurrentDictionary<StringRenderTree, GlyphPin> Pins = new ConcurrentDictionary<StringRenderTree, GlyphPin>();

			public readonly ConcurrentQueue<RenderTask> GlyphsToRender = new ConcurrentQueue<RenderTask>();

			private GlyphAtlasManager[] _atlases;

			public bool Invalidated => _invalidated;

			public int AtlasCount { get; private set; }

			public GlyphAtlasManager GetAtlas(int index)
			{
				if (index < 0 || index >= AtlasCount)
				{
					throw new ArgumentOutOfRangeException("index");
				}
				return _atlases[index];
			}

			public void AddAtlas(GlyphAtlasManager manager)
			{
				int num = AtlasCount + 1;
				if (_atlases == null || num > _atlases.Length)
				{
					GlyphAtlasManager[] atlases = _atlases;
					GlyphAtlasManager[] atlases2 = _atlases;
					_atlases = atlases.EnsureExactSize(MathX.Max(num, ((atlases2 != null) ? atlases2.Length : 0) * 2, 4), keepData: true);
				}
				_atlases[AtlasCount] = manager;
				AtlasCount = num;
			}

			public DynamicAtlas(Font font)
			{
				Font = font;
			}

			public async ValueTask UpdateTextureProperties()
			{
				GlyphAtlasManager[] atlases = _atlases;
				if (atlases == null)
				{
					return;
				}
				List<ValueTask> list = new List<ValueTask>();
				GlyphAtlasManager[] array = atlases;
				foreach (GlyphAtlasManager glyphAtlasManager in array)
				{
					if (glyphAtlasManager != null)
					{
						list.Add(glyphAtlasManager.UpdateTextureProperties(Font.LODBias));
					}
				}
				foreach (ValueTask item in list)
				{
					await item.ConfigureAwait(continueOnCapturedContext: false);
				}
			}

			public void Invalidate()
			{
				_invalidated = true;
				foreach (KeyValuePair<StringRenderTree, GlyphPin> pin in Pins)
				{
					pin.Value.InvalidateCallback();
				}
				RenderTask result;
				while (GlyphsToRender.TryDequeue(out result))
				{
					result.finishedTask.SetResult(result: false);
				}
			}

			public void Unload()
			{
				for (int i = 0; i < AtlasCount; i++)
				{
					GetAtlas(i).Unload();
				}
			}

			public bool RemovePin(StringRenderTree renderTree)
			{
				GlyphPin value;
				return Pins.TryRemove(renderTree, out value);
			}

			public async ValueTask<bool> AddPin(StringRenderTree renderTree, GlyphPin pin)
			{
				if (_invalidated)
				{
					return false;
				}
				Pins.TryAdd(renderTree, pin);
				if (_invalidated)
				{
					Pins.TryRemove(renderTree, out GlyphPin _);
					return false;
				}
				List<uint> list = null;
				foreach (uint glyph in pin.Glyphs)
				{
					bool flag = false;
					for (int i = 0; i < AtlasCount; i++)
					{
						GlyphAtlas atlas = GetAtlas(i).Atlas;
						if (atlas == null)
						{
							return false;
						}
						if (atlas.HasGlyphData(glyph))
						{
							flag = true;
							break;
						}
					}
					if (!flag)
					{
						if (list == null)
						{
							list = Pool.BorrowList<uint>();
						}
						list.Add(glyph);
					}
				}
				if (list != null)
				{
					if (_invalidated)
					{
						Pool.Return(ref list);
						return false;
					}
					TaskCompletionSource<bool> taskCompletionSource = new TaskCompletionSource<bool>();
					GlyphsToRender.Enqueue(new RenderTask(list, taskCompletionSource));
					Font.ScheduleGlyphRender();
					if (_invalidated)
					{
						return false;
					}
					return await taskCompletionSource.Task.ConfigureAwait(continueOnCapturedContext: false);
				}
				return true;
			}

			public override string ToString()
			{
				return $"Dynamic Atlas. Pins: {Pins?.Count}, ToRender: {GlyphsToRender?.Count}, Invalidated: {_invalidated}, AtlasCount: {AtlasCount}, HashCode: {GetHashCode()}";
			}
		}

		public const int MAX_ATLAS_SIZE = 4096;

		public GlyphRenderMethod RenderMethod = GlyphRenderMethod.MSDF;

		public int PixelRange = 4;

		public int Padding = 1;

		public int MaxFixedSize = 256;

		public int GlyphEmSize = 32;

		public float LODBias;

		public bool MipMaps = true;

		public Filtering MipMapFiltering;

		private int _atlasVersion;

		private ConcurrentDictionary<StringRenderTree, GlyphPin> _glyphPins = new ConcurrentDictionary<StringRenderTree, GlyphPin>();

		private volatile DynamicAtlas currentDynamicAtlas;

		private ConcurrentDictionary<DynamicAtlas, bool> _invalidatedAtlases = new ConcurrentDictionary<DynamicAtlas, bool>();

		private object _lock = new object();

		private volatile bool _renderScheduled;

		private volatile bool _renderRunning;

		private bool _dataLoaded;

		public FontX Data { get; private set; }

		public int CurrentActivePins => (currentDynamicAtlas?.Pins?.Count).GetValueOrDefault();

		public event Action OnAtlasesUpdated;

		public override void Unload()
