		private void UpdateMeshData(MeshX meshx, MeshUploadHint hint, Elements.Core.BoundingBox? overrideBounds, AssetIntegrated onUpdated)
		{
			Data = meshx;
			base.Version++;
			Elements.Core.BoundingBox boundingBox = overrideBounds ?? Bounds;
			_ = BoneMetadata;
			_ = ApproximateBoneBounds;
			if (boundingBox.Size.IsInfinity || boundingBox.Size.IsNaN)
			{
				if (!_invalidBoundsWarned)
				{
					_invalidBoundsWarned = true;
					string[] obj = new string[8] { "Invalid bounds: ", null, null, null, null, null, null, null };
					Elements.Core.BoundingBox boundingBox2 = boundingBox;
					obj[1] = boundingBox2.ToString();
					obj[2] = ", owner: ";
					obj[3] = base.Owner?.ToString();
					obj[4] = ", URL: ";
					obj[5] = base.AssetURL?.ToString();
					obj[6] = "\n";
					obj[7] = (base.Owner as Worker)?.MembersToString();
					UniLog.Warning(string.Concat(obj));
				}
				boundingBox = new Elements.Core.BoundingBox(Elements.Core.float3.Zero);
			}
			if (ComputeWeightedTriangleIndicies)
			{
				_weightedTriangleIndicies = meshx.ComputeWeightedTriangleList();
			}
			if (Manager != null)
			{
				if (meshBuffer == null)
				{
					meshBuffer = new MeshBuffer();
				}
				MeshBufferGenerator.UpdateMeshBufferData(meshx, meshBuffer, base.RenderSystem, ColorProfile.Linear, ref hint, Metadata, boundingBox, this);
				MeshUploadData meshUploadData = new MeshUploadData();
				meshUploadData.assetId = base.AssetId;
				meshUploadData.highPriority = HighPriorityIntegration;
				meshUploadData.uploadHint = hint;
				meshUploadData.bounds = boundingBox;
				meshBuffer.FillMeshBufferDefinition(meshUploadData);
				if (meshBuffer.Data == null)
				{
					meshUploadData.buffer = default(SharedMemoryBufferDescriptor<byte>);
				}
				else
				{
					meshUploadData.buffer = ((SharedMemoryBlockLease<byte>)meshBuffer.Data).Descriptor;
				}
				onAssetUpdated = onUpdated;
				base.RenderSystem.SendAssetUpdate(meshUploadData);
			}
			else
			{
				onUpdated(environmentInstanceChanged: false);
			}
		}

