							List<D> bestAlternateChain = variant.GetBestAlternateChain(list2, IsValidVariant);
							if (bestAlternateChain != null)
							{
								variant = UpdateVariantFromAlternate(variant, bestAlternateChain[0]);
								decodeFormat.format = variant.TextureCompression.ToFormat(ImageMetadata, IsThreeChannelSupported);
								foreach (D item2 in bestAlternateChain)
								{
									string alternativeIdentifier = item2.VariantIdentifier;
									int num = list2.FindIndex((D d) => d.VariantIdentifier == alternativeIdentifier);
									if (num >= 0)
									{
										alternativeIdentifier = list[num];
									}
									loadChain.Add(alternativeIdentifier);
								}
							}
						}
						if (loadChain.Count == 0)
						{
							if (base.Engine.SystemInfo.Platform == Platform.Android)
							{
								waitForCloud = true;
								variant.GenerateLoadChain(loadChain);
							}
							else
							{
								variant = GetOriginalVersionVariant(variant);
								loadChain.Add(null);
							}
						}
						allowFallback = false;
						i = loadChain.Count;
					}
					else
					{
						if (integrationTask == null)
						{
							await default(ToBackground);
						}
						else
						{
							await integrationTask.Task.ConfigureAwait(continueOnCapturedContext: false);
							await default(ToBackground);
							integrationTask = null;
							if (!isReadable)
							{
								decoded.Buffer.Dispose();
							}
							decoded = null;
							SetPartiallyLoaded();
						}
						allowFallback = false;
						try
						{
							decoded = DecodeFile(file, variant, i == 0 && (variant?.MipMaps ?? true), variantIdentifier == null, sharedMemory: true);
							if (variant.OriginalAsset)
							{
								decodeFormat = GetDecodeFormat(decoded, variant);
							}
						}
						catch (Exception ex)
						{
							UniLog.Error("Exception decoding texture asset: " + file + $"\nVariant: {variant}" + "\nVariantIdenfifier: " + variantIdentifier + "\n" + ex);
						}
						if ((object)decoded == TextureDecoder.ERRORTEXTURE || decoded == null)
						{
							if (!string.IsNullOrWhiteSpace(variantIdentifier))
							{
								await base.Engine.LocalDB.DeleteCacheRecordAsync(new Uri(base.AssetURL?.ToString() + "?" + variantIdentifier));
							}
							UniLog.Warning("Error decoding texture variant: " + variant?.ToString() + ", File: " + file + ", URL: " + base.AssetURL);
						}
						else
						{
							File = file;
							OriginalMimeType = decoded.OriginalFormat;
							loadedMips += decoded.MipMapLevels;
							isReadable = UpdateData(variant, decoded, loadedMips);
							if (!textureInitialized)
							{
								await InitializeTexture(variant, decodeFormat);
								await default(ToBackground);
								textureInitialized = true;
							}
							integrationTask = UploadTextureData(decoded, i);
						}
					}
				}
				Pool.Return(ref loadChain);
				if (integrationTask != null)
				{
					await integrationTask.Task.ConfigureAwait(continueOnCapturedContext: false);
				}
				if (!isReadable)
				{
					decoded.Buffer.Dispose();
				}
				await default(ToBackground);
				_dataLoaded = true;
			}
			else
			{
				await UpdateTextureProperties(variant).ConfigureAwait(continueOnCapturedContext: false);
			}
		}

