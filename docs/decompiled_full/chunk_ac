		{
			_initAudioTrackIndex = audioTrackIndex;
			ActivateAudioTrack(audioTrackIndex);
		}

		private void ActivateAudioTrack(int? audioTrackIndex)
		{
			if (_audioTracks != null && _audioTracks.Count != 0)
			{
				int num = audioTrackIndex ?? _defaultTrackIndex;
				if (num < 0 || num >= _audioTracks.Count)
				{
					num = 0;
				}
				if (num != _lastTrackIndex)
				{
					_lastTrackIndex = num;
					InitAudioTrack(_audioTracks[num]);
				}
			}
