				componentsInChild.Destroy();
			}
			foreach (MeshRenderer componentsInChild2 in base.Slot.GetComponentsInChildren((MeshRenderer r) => r.Enabled && r.Slot.IsActive))
			{
				if (!componentsInChild2.Slot.Parent.IsChildOf(slot))
				{
					componentsInChild2.Slot.Parent = slot;
				}
				for (int num = 0; num < componentsInChild2.Materials.Count; num++)
				{
					IAssetProvider<Material> assetProvider = componentsInChild2.Materials[num];
					if (assetProvider == null)
					{
						continue;
					}
					PBS_DisplaceMetallic pBS_DisplaceMetallic = slot.AttachComponent<PBS_DisplaceMetallic>();
					pBS_DisplaceMetallic.CopyProperties((Worker)assetProvider);
					if (assetProvider is ICommonMaterial commonMaterial)
					{
						pBS_DisplaceMetallic.AlbedoTexture.Target = commonMaterial.MainTexture;
						pBS_DisplaceMetallic.AlbedoColor.Value = commonMaterial.Color;
					}
					if (assetProvider is IPBS_Material iPBS_Material)
					{
						pBS_DisplaceMetallic.AlbedoTexture.Target = iPBS_Material.AlbedoTexture;
						pBS_DisplaceMetallic.AlbedoColor.Value = iPBS_Material.AlbedoColor;
						pBS_DisplaceMetallic.NormalMap.Target = iPBS_Material.NormalMap;
						pBS_DisplaceMetallic.NormalScale.Value = iPBS_Material.NormalScale;
						pBS_DisplaceMetallic.EmissiveColor.Value = iPBS_Material.EmissiveColor;
						pBS_DisplaceMetallic.EmissiveMap.Target = iPBS_Material.EmissiveMap;
					}
					if (pBS_DisplaceMetallic.AlbedoTexture.Target == null)
					{
						List<AssetRef<ITexture2D>> list2 = (from ar in ((Worker)assetProvider).GetSyncMembers<AssetRef<ITexture2D>>()
							where ar.Target != null
							select ar).ToList();
						if (list2.Count > 0)
						{
							pBS_DisplaceMetallic.AlbedoTexture.Target = list2[0].Target;
						}
					}
					componentsInChild2.Materials[num] = pBS_DisplaceMetallic;
					list.Add(pBS_DisplaceMetallic);
				}
			}
			slot.StartCoroutine(AprilFoolsExplode(slot, BloatMagnitude, list));
		}

		private static IEnumerator<Context> AprilFoolsExplode(Slot root, float magnitude, List<PBS_DisplaceMaterial> materials)
		{
			Slot explosion = root.World.AddSlot("Explosion");
			StaticAudioClip clip = explosion.AttachAudioClip(OfficialAssets.Common.Sound_Effect.Bloating);
			StaticAudioClip explosionClip = explosion.AttachAudioClip(OfficialAssets.Common.Sound_Effect.Explosion);
			explosionClip.ForceLoad();
			root.PlayOneShot(clip);
			explosion.PersistentSelf = false;
			FrooxEngine.PhotonDust.ParticleSystemHelper.ParticleSystemComponents<UnlitMaterial> particleSystemComponents = explosion.SetupParticleSystem<UnlitMaterial>(singleSlot: true, setupEmitter: false, setupRotation: false, setupGravity: true);
			particleSystemComponents.Material.UseVertexColors.Value = true;
			particleSystemComponents.Material.Texture.Target = explosion.AttachTexture(OfficialAssets.Common.Particles.Effects.Flame_Atlas8x8);
			FrooxEngine.PhotonDust.SphereEmitter pEmit = particleSystemComponents.System.AddEmitter<FrooxEngine.PhotonDust.SphereEmitter>(explosion);
			particleSystemComponents.Material.BlendMode.Value = BlendMode.Additive;
			pEmit.Rate.Value = 0f;
			pEmit.Enabled = false;
			pEmit.Radius.Value = 0.5f;
			pEmit.BurstOnActivatedMin.Value = 200f;
			pEmit.BurstOnActivatedMax.Value = 400f;
			particleSystemComponents.Gravity.Gravity.Value = 0.5f;
			particleSystemComponents.Speed.MinValue.Value = 0f;
			particleSystemComponents.Speed.MaxValue.Value = 15f;
			particleSystemComponents.Colors.MinValue.Value = Elements.Core.colorX.White;
			particleSystemComponents.Colors.MaxValue.Value = new Elements.Core.colorX(1f, 0.8f, 0.5f);
			particleSystemComponents.Size.MinValue.Value = 2f;
			particleSystemComponents.Size.MaxValue.Value = 4f;
			FrooxEngine.PhotonDust.TextureSheetAnimator textureSheetAnimator = particleSystemComponents.Style.AddModule<FrooxEngine.PhotonDust.TextureSheetAnimator>();
			textureSheetAnimator.TileGridSize.Value = new Elements.Core.int2(8, 8);
			textureSheetAnimator.AnimationType.Value = TextureSheetAnimationType.WholeSheet;
			particleSystemComponents.Lifetime.MinValue.Value = 2f;
			particleSystemComponents.Lifetime.MaxValue.Value = 5f;
			for (float f = 0f; f < 1f; f += root.Time.Delta)
			{
				yield return Context.WaitForNextUpdate();
				foreach (PBS_DisplaceMaterial material in materials)
				{
					material.VertexDisplaceBias.Value = f * magnitude;
				}
			}
			explosion.GlobalPosition = root.ComputeBoundingBox().Center;
			pEmit.Enabled = true;
			explosion.PlayOneShot(explosionClip);
			explosion.RunInSeconds(6f, explosion.Destroy);
			root.DestroyPreservingAssets();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			BloatMagnitude = new Sync<float>();
			_bloatingClip = new AssetRef<AudioClip>();
			_explosionClip = new AssetRef<AudioClip>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => BloatMagnitude, 
				4 => _bloatingClip, 
				5 => _explosionClip, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static ViolentAprilFoolsExplosion __New()
		{
			return new ViolentAprilFoolsExplosion();
		}
	}
