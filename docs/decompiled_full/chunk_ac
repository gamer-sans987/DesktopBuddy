		public void SetFromClip(AudioX clip)
		{
			Data = clip;
			BaseRate = (double)Data.SampleRate / (double)base.Engine.AudioSystem.SampleRate;
		}

		protected override async Task LoadTargetVariant(AudioClipVariantDescriptor variant)
		{
			GatherResult gatherResult = await base.AssetManager.GatherAsset(base.AssetURL, 0f).ConfigureAwait(continueOnCapturedContext: false);
			if (gatherResult.gatherJob != null)
			{
				gatherResult.gatherJob.ProgressUpdated += delegate(float progress)
				{
					base.DownloadProgress = progress;
				};
			}
			string text = await gatherResult.GetFile().ConfigureAwait(continueOnCapturedContext: false);
			if (!File.Exists(text))
			{
				FailLoad("Could not gather asset");
				return;
			}
			try
			{
				AudioLoadMode audioLoadMode = variant.LoadMode;
				AudioX audioX = ((audioLoadMode != AudioLoadMode.StreamFromMemory) ? new AudioX(text) : new AudioX(new MemoryStream(File.ReadAllBytes(text)), Path.GetExtension(text)));
				if (audioLoadMode == AudioLoadMode.Automatic && audioX.Duration <= 10.0)
				{
					audioLoadMode = AudioLoadMode.FullyDecode;
				}
				if (audioLoadMode == AudioLoadMode.FullyDecode)
				{
					audioX.FullyDecode();
					if (variant.SampleRateMode == SampleRateMode.Conform)
					{
						audioX.Resample(base.Engine.AudioSystem.SampleRate);
					}
				}
				SetFromClip(audioX);
			}
			catch (Exception exception)
			{
				UniLog.Warning($"Couldn't load audio file {text} ({base.AssetURL}):\n{DebugManager.PreprocessException(exception)}");
				FailLoad("Could not load audio file");
			}
		}

		public override void Unload()
		{
			Data?.Dispose();
			Data = null;
		}
	}
