	public class VideoTextureAudioReader<T> : VideoTextureAudioReader where T : unmanaged, IAudioSample<T>
	{
		public const int SAMPLES_CAPACITY = 16384;

		private string _queueName;

		private int _sampleRate;

		private int _capacity;

		private ISubscriber _subscriber;

		private CircularBufferWriteState<T> _writeState;

		private CircularAudioBuffer<StereoSample> _audioReadBuffer = new CircularAudioBuffer<StereoSample>(16384);

		private Memory<byte> _readBuffer;

		private int lastFrameIndex = -1;

		private long currentReadPosition;

		private long nextReadPosition;

		private double writeRate;

		private int sampleCountFloorIndex;

		private int[] sampleCountFloorData = new int[64];

		private T[] trimFadeData = new T[128];

		private bool trimmed;

		private bool dispose;

		public override string QueueName => _queueName;

		public override int SampleRate => _sampleRate;

		public override int QueueCapacity => _capacity;

		public VideoTextureAudioReader(string queueName, int sampleRate, AudioSimulator simulator)
		{
			_queueName = queueName;
			writeRate = (double)sampleRate / (double)simulator.SampleRate;
			QueueFactory queueFactory = new QueueFactory();
			_capacity = 16384 * default(T).ChannelCount * 4;
			QueueOptions options = new QueueOptions(queueName, _capacity, deleteOnDispose: false);
			_readBuffer = new byte[_capacity].AsMemory();
			_subscriber = queueFactory.CreateSubscriber(options);
			simulator.RegisterPreRenderParallelTask(PrepareNextFrame);
		}

		private void PrepareNextFrame(AudioSimulator simulator)
		{
			if (dispose)
			{
				_subscriber.Dispose();
				_subscriber = null;
				simulator.UnregisterPreRenderParallelTask(PrepareNextFrame);
				return;
			}
			trimmed = false;
			currentReadPosition = nextReadPosition;
			lastFrameIndex = simulator.AudioFrameIndex;
			int num = _audioReadBuffer.AvailableSamples(currentReadPosition);
			sampleCountFloorData[sampleCountFloorIndex++] = num;
			if (sampleCountFloorIndex == sampleCountFloorData.Length)
			{
				sampleCountFloorIndex = 0;
				int num2 = sampleCountFloorData.Min();
				if (num2 > simulator.FrameSize)
				{
					long globalPosition = currentReadPosition;
					_audioReadBuffer.Read(trimFadeData.AsSpan(), ref globalPosition);
					trimmed = true;
					currentReadPosition += num2;
					Array.Clear(sampleCountFloorData);
				}
			}
			ReadOnlyMemory<byte> message;
			while (_subscriber.TryDequeue(_readBuffer, CancellationToken.None, out message))
			{
				ReadOnlySpan<T> source = MemoryMarshal.Cast<byte, T>(message.Span);
				_audioReadBuffer.Put(source, ref _writeState, writeRate);
			}
		}

		public override void AudioRead<S>(Span<S> buffer, AudioSimulator simulator)
		{
			long globalPosition = currentReadPosition;
			if (_audioReadBuffer.AvailableSamples(globalPosition) < buffer.Length)
			{
				buffer.Clear();
				return;
			}
			_audioReadBuffer.Read(buffer, ref globalPosition);
			if (trimmed)
			{
				Span<S> target = stackalloc S[trimFadeData.Length];
				trimFadeData.AsSpan().CopySamples(target);
				float num = 1f / (float)target.Length;
				for (int i = 0; i < target.Length; i++)
				{
					buffer[i] = target[i].LerpTo(buffer[i], num * (float)i);
				}
			}
			nextReadPosition = globalPosition;
		}

		public override void Dispose()
		{
			dispose = true;
		}
	}
