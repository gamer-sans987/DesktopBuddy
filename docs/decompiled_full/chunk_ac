				if (bipedRig == null)
				{
					stringBuilder.AppendLine("\n\nHIERARCHY\n==========================\n\n");
					stringBuilder.AppendLine("<b><color=#f00>Missing Humanoid Bones:</color></b>");
					foreach (BodyNode item4 in list2)
					{
						stringBuilder.AppendLine("\t-" + item4);
					}
					stringBuilder.AppendLine();
					stringBuilder.AppendLine("<b>Bone Hiearchy:</b>");
					stringBuilder.AppendLine(item3.ToString(delegate(BoneNode b)
					{
						Elements.Core.colorX colorX = MathX.Lerp((b.boneType == BodyNode.NONE) ? Elements.Core.colorX.Red : Elements.Core.colorX.Green, Elements.Core.colorX.White, 0.5f);
						return $"{b.bone.Name} <color={colorX.ToHexString()}>{b.bone.Name}({b.boneType})</color>";
					}));
					if (bipedRig != null)
					{
						stringBuilder.AppendLine();
						stringBuilder.AppendLine("<b>Biped Bone Hiearchy:</b>");
						stringBuilder.AppendLine(bipedRig.GetBipedBoneHiearchy().ToString());
					}
					stringBuilder.AppendLine();
					stringBuilder.AppendLine("Bone List:");
					foreach (Slot bone in rig.Bones)
					{
						stringBuilder.AppendLine("\t-" + bone.Name);
					}
				}
				if (bipedRig != null && data.settings.SetupIK)
				{
					flag = true;
					slot.GetComponentInParents<Grabbable>()?.Destroy();
					VRIK vRIK = slot.AttachComponent<VRIK>();
					vRIK.Solver.SimulationSpace.Target = parent;
					vRIK.Solver.OffsetSpace.Target = parent;
					vRIK.Initiate();
					Slot slot2 = bipedRig[BodyNode.Head];
					Slot slot3 = bipedRig[BodyNode.Hips];
					Slot slot4 = bipedRig[BodyNode.LeftHand];
					Slot slot5 = bipedRig[BodyNode.RightHand];
					Slot slot6 = bipedRig[BodyNode.LeftFoot];
					Slot slot7 = bipedRig[BodyNode.RightFoot];
					Slot slot8 = bipedRig.TryGetBone(BodyNode.LeftToes);
					Slot slot9 = bipedRig.TryGetBone(BodyNode.RightToes);
					SetupDraggable(slot2, vRIK.Solver, vRIK.Solver.spine.IKPositionHead, vRIK.Solver.spine.IKRotationHead, vRIK.Solver.spine.PositionWeight);
					SetupDraggable(slot3, vRIK.Solver, vRIK.Solver.spine.IKPositionPelvis, vRIK.Solver.spine.IKRotationPelvis, vRIK.Solver.spine.PelvisPositionWeight);
					SetupDraggable(slot4, vRIK.Solver, vRIK.Solver.leftArm.IKPosition, vRIK.Solver.leftArm.IKRotation, vRIK.Solver.leftArm.PositionWeight);
					SetupDraggable(slot5, vRIK.Solver, vRIK.Solver.rightArm.IKPosition, vRIK.Solver.rightArm.IKRotation, vRIK.Solver.rightArm.RotationWeight);
					SetupDraggable(slot8 ?? slot6, vRIK.Solver, vRIK.Solver.leftLeg.IKPosition, vRIK.Solver.leftLeg.IKRotation, vRIK.Solver.leftLeg.PositionWeight);
					SetupDraggable(slot9 ?? slot7, vRIK.Solver, vRIK.Solver.rightLeg.IKPosition, vRIK.Solver.rightLeg.IKRotation, vRIK.Solver.rightLeg.PositionWeight);
					data.IK = vRIK;
