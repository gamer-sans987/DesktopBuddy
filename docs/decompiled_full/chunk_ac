		private void UpdateGlobalVolumes(bool changed = false)
		{
			if (_volumeSetting == null)
			{
				if (PrimaryOutput != null)
				{
					PrimaryOutput.Volume = 0f;
				}
				Array.Clear(computedGroupVolumes, 0, computedGroupVolumes.Length);
				return;
			}
			if (PrimaryOutput != null)
			{
				PrimaryOutput.Volume = _volumeSetting.ActualMasterVolume;
			}
			World world = Engine.WorldManager?.FocusedWorld;
			for (int i = 0; i < computedGroupVolumes.Length; i++)
			{
				AudioTypeGroup audioTypeGroup = (AudioTypeGroup)i;
				float num = _volumeSetting.GetVolume(audioTypeGroup);
				if (world != null)
				{
					if ((bool)world.LocalUser.recordingVoiceMessage)
					{
						float num2 = num;
						Sync<float> sync = _accessibilitySetting?.VoiceMessageVolume;
						num = num2 * ((sync != null) ? ((float)sync) : 1f);
					}
					else if (world.LocalUser.ActiveVoiceMode == VoiceMode.Whisper && audioTypeGroup != AudioTypeGroup.Voice)
					{
						float num3 = num;
						Sync<float> sync = _accessibilitySetting?.WhisperVolume;
						num = num3 * ((sync != null) ? ((float)sync) : 1f);
					}
				}
				if (!MathX.Approximately(computedGroupVolumes[i], num))
				{
					changed = true;
					computedGroupVolumes[i] = num;
				}
			}
			if (changed)
			{
				this.GlobalVolumesChanged?.Invoke();
			}
		}

		private void UpdateDefaultAudioInput()
		{
			if (_audioInputOverrideIndex.HasValue || _inputDevice == null)
			{
				return;
			}
			DevicePriorityEntry devicePriorityEntry = _inputDevice.FindPreferredDevice((DevicePriorityEntry d) => _audioInputDeviceIDs.Contains(d.EntryID));
			string preferredDeviceID;
			if (devicePriorityEntry != null)
			{
				preferredDeviceID = devicePriorityEntry.EntryID;
			}
			else
			{
				preferredDeviceID = AudioInputs.FirstOrDefault((AudioInput i) => i.IsSystemDefault && i.InputType == AudioInputType.CaptureDevice)?.DeviceID;
			}
			if (preferredDeviceID == null)
			{
				UniLog.Warning("Cannot find a preferred device ID");
			}
			else if (!(preferredDeviceID == DefaultAudioInput?.DeviceID))
			{
				_defaultAudioInputIndex = AudioInputs.FindIndex((AudioInput i) => i.DeviceID == preferredDeviceID);
				this.DefaultAudioInputChanged?.Invoke(DefaultAudioInput);
			}
		}

		private void RenderAudio()
		{
			if (Simulator.TryRenderAudio(RenderFinished))
			{
				_renderSignal.WaitOne();
			}
			else
			{
				_droppedAudioFrames++;
			}
		}

		private void RenderFinished()
		{
			_renderSignal.Set();
		}

		private void UpdateDefaultAudioOutput()
		{
			if (_outputDevice == null)
			{
				return;
			}
			DevicePriorityEntry devicePriorityEntry = _outputDevice.FindPreferredDevice((DevicePriorityEntry d) => _audioOutputDeviceIDs.Contains(d.EntryID));
			DevicePriorityEntry devicePriorityEntry2 = _outputDevice.FindStreamingPreferredDevice((DevicePriorityEntry d) => _audioOutputDeviceIDs.Contains(d.EntryID));
			string preferredDeviceID;
			if (devicePriorityEntry != null)
			{
				preferredDeviceID = devicePriorityEntry.EntryID;
			}
			else
			{
				preferredDeviceID = AudioOutputs.FirstOrDefault((AudioOutputDriver o) => o.IsSystemDefault && o.IsConnected)?.DeviceID;
			}
			if (preferredDeviceID == null)
			{
				UniLog.Warning("Cannot find a preferred device ID");
				return;
			}
			string preferredStreamingDeviceID = devicePriorityEntry2?.EntryID.Value;
			if (!(preferredDeviceID == DefaultAudioOutput?.DeviceID) || !(preferredStreamingDeviceID == StreamingAudioOutput?.DeviceID))
			{
				PrimaryOutput.Device = null;
				StreamingOutput.Device = null;
				AudioOutputDriver defaultAudioOutput = DefaultAudioOutput;
				AudioOutputDriver streamingAudioOutput = StreamingAudioOutput;
				if (defaultAudioOutput != null)
				{
					defaultAudioOutput.Stop();
					defaultAudioOutput.RenderAudio = null;
				}
				streamingAudioOutput?.Stop();
				_defaultAudioOutputIndex = AudioOutputs.FindIndex((AudioOutputDriver i) => i.DeviceID == preferredDeviceID);
				_streamingAudioOutputIndex = AudioOutputs.FindIndex((AudioOutputDriver i) => i.DeviceID == preferredStreamingDeviceID);
				if (_streamingAudioOutputIndex >= 0 && _streamingAudioOutputIndex == _defaultAudioOutputIndex)
				{
					_streamingAudioOutputIndex = -1;
				}
				AudioOutputDriver defaultAudioOutput2 = DefaultAudioOutput;
				AudioOutputDriver streamingAudioOutput2 = StreamingAudioOutput;
				audioThreadLoop.Supress = true;
				defaultAudioOutput2.RenderAudio = RenderAudio;
				defaultAudioOutput2.Start("Default Output");
				streamingAudioOutput2?.Start("Streaming Camera");
				PrimaryOutput.Device = defaultAudioOutput2;
				StreamingOutput.Device = streamingAudioOutput2;
				this.DefaultAudioOutputChanged?.Invoke(defaultAudioOutput2);
			}
		}

