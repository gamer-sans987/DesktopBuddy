		private static async Task ImportTask(AssetClass assetClass, IEnumerable<string> files, World world, Elements.Core.float3 position, Elements.Core.floatQ rotation, Elements.Core.float3 scale, bool silent = false)
		{
			await default(ToWorld);
			if (!world.CanSpawnObjects())
			{
				return;
			}
			List<string> list = files.Select((string s) => s?.Trim()).ToList();
			files = list;
			int count = list.Count;
			int rowSize = MathX.Max(1, MathX.CeilToInt(MathX.Sqrt(count)));
			_ = Elements.Core.float3.Zero;
			int index = 0;
			UniLog.Log($"Importing files with Asset Class {assetClass}:\n" + string.Join("\n", files));
			Uri url;
			Uri uri;
			switch (assetClass)
			{
			case AssetClass.Folder:
			{
				await default(ToWorld);
				Slot slot3 = CreateAndPositionSlotForImport(world, "ModelImporter", position, rotation, scale);
				FolderImportDialog folderImportDialog = slot3.AttachComponent<FolderImportDialog>();
				folderImportDialog.Path.Value = files.First();
				folderImportDialog.SetLocalUserAsImporting();
				break;
			}
			case AssetClass.Document:
				foreach (string file in files)
				{
					await default(ToBackground);
					if (File.Exists(file))
					{
						uri = await world.Engine.LocalDB.ImportLocalAssetAsync(file, LocalDB.ImportLocation.Original);
					}
					else if (!Uri.TryCreate(file, UriKind.Absolute, out uri))
					{
						continue;
					}
					await default(ToWorld);
					if (!(uri == null))
					{
						Elements.Core.float3 offset = GetOffset(rotation, scale, rowSize, ref index);
						Slot slot3 = CreateAndPositionSlotForImport(world, Path.GetFileName(file), position + offset, rotation, scale);
						(await slot3.SpawnEntity(FavoriteEntity.DocumentDisplay, delegate(Slot s)
						{
							StaticDocument staticDocument = s.AttachComponent<StaticDocument>();
							DocumentPageTexture documentPageTexture = s.AttachComponent<DocumentPageTexture>();
							DocumentInterface documentInterface = s.AttachComponent<DocumentInterface>();
							DocumentAssetMetadata documentAssetMetadata = s.AttachComponent<DocumentAssetMetadata>();
							documentPageTexture.Document.Target = staticDocument;
							documentAssetMetadata.Document.Target = staticDocument;
							documentInterface.URL.Target = staticDocument.URL;
							documentInterface.Page.Target = documentPageTexture.PageIndex;
							s.AttachComponent<Grabbable>().Scalable.Value = true;
							Canvas canvas = s.AddSlot("Canvas").AttachComponent<Canvas>();
							canvas.Slot.LocalScale = Elements.Core.float3.One * 0.001f;
							UIBuilder uIBuilder = new UIBuilder(canvas);
							canvas.Size.Value = new Elements.Core.float2(1000f, 1500f);
							uIBuilder.Panel(Elements.Core.colorX.Black, zwrite: true);
							uIBuilder.HorizontalFooter(64f, out RectTransform footer, out RectTransform content);
							uIBuilder.NestInto(footer);
							List<RectTransform> list2 = uIBuilder.SplitHorizontally(1f, 3f, 1f);
							uIBuilder.ForceNext = list2[0];
							ButtonValueShift<int> buttonValueShift = uIBuilder.Button((LocaleString)"<<<").Slot.AttachComponent<ButtonValueShift<int>>();
							uIBuilder.ForceNext = list2[2];
							ButtonValueShift<int> buttonValueShift2 = uIBuilder.Button((LocaleString)">>>").Slot.AttachComponent<ButtonValueShift<int>>();
							uIBuilder.ForceNext = list2[1];
							Text text4 = uIBuilder.Text((LocaleString)"---");
							text4.Color.Value = Elements.Core.colorX.White;
							uIBuilder.NestOutFrom(footer);
							uIBuilder.NestInto(content);
							uIBuilder.Image(s.AttachSprite(documentPageTexture));
							buttonValueShift.Delta.Value = -1;
							buttonValueShift2.Delta.Value = 1;
							buttonValueShift.TargetValue.Target = documentPageTexture.PageIndex;
							buttonValueShift2.TargetValue.Target = documentPageTexture.PageIndex;
							buttonValueShift.WrapAround.Value = true;
							buttonValueShift2.WrapAround.Value = true;
							buttonValueShift.MaxIsExclusive.Value = true;
							buttonValueShift2.MaxIsExclusive.Value = true;
							buttonValueShift.Min.Value = 0;
							buttonValueShift2.Min.Value = 0;
							buttonValueShift.Max.DriveFrom(documentAssetMetadata.PageCount);
							buttonValueShift2.Max.DriveFrom(documentAssetMetadata.PageCount);
							text4.Content.DriveFormatted("Page index: {0}, Page Count: {1}", documentPageTexture.PageIndex, documentAssetMetadata.PageCount);
							return documentInterface;
						})).SetSource(uri);
					}
				}
				break;
			case AssetClass.Unknown:
			{
				IPlatformProfile platform = world.Engine.Cloud.Platform;
				foreach (string file in files)
				{
					if (Uri.TryCreate(file, UriKind.Absolute, out url) && url.Scheme != "file")
					{
						Transform targetLocation = new Transform(position + GetOffset(rotation, scale, rowSize, ref index), in rotation, in scale);
						if (url.Scheme == platform.RecordScheme)
						{
							UniLog.Log("Fetching record: " + url);
							CloudResult<FrooxEngine.Store.Record> cloudResult = await world.Engine.Cloud.Records.GetRecord<FrooxEngine.Store.Record>(url);
							UniLog.Log("Record result: " + cloudResult);
							FrooxEngine.Store.Record entity = cloudResult.Entity;
							if (entity != null)
							{
								Slot slot3 = CreateAndPositionSlotForImport(world, Path.GetFileName(file), targetLocation);
								switch (entity.RecordType)
								{
								case "directory":
								case "link":
									SpawnInventoryLink(slot3, url, entity);
									break;
								case "object":
									await slot3.LoadObjectAsync(url);
									break;
								case "world":
									await ImportWorldRecord(world, entity, targetLocation);
									break;
								default:
									SpawnText(slot3, "Importer.UnsupportedRecordType.Heading".AsLocaleKey(), "Importer.UnsupportedRecordType.Description".AsLocaleKey(("recordType", entity.RecordType), ("url", url)));
									UniLog.Warning($"Error importing a record, Unsupported record type: {entity.RecordType} from {url}.");
									break;
								}
							}
						}
						else if (url.Scheme == platform.SessionScheme)
						{
							await ImportSessionUrl(world, url, targetLocation);
						}
						else if (world.Engine.NetworkManager.IsSupportedSessionScheme(url.Scheme))
						{
							await ImportNetworkUrl(world, url, targetLocation);
						}
						else
						{
							SpawnUrl(CreateAndPositionSlotForImport(world, "URL Interface", targetLocation), url);
						}
					}
					else if (!File.Exists(file))
					{
						Transform globalTransform = new Transform(position + GetOffset(rotation, scale, rowSize, ref index), in rotation, in scale);
						SpawnText(CreateAndPositionSlotForImport(world, "Clipboard Content", globalTransform), "Clipboard Content", file);
					}
					else
					{
						Transform globalTransform2 = new Transform(position + GetOffset(rotation, scale, rowSize, ref index), in rotation, in scale);
						await ImportRawFile(CreateAndPositionSlotForImport(world, Path.GetFileName(file), globalTransform2), new ImportItem(file));
					}
					url = null;
				}
				break;
			}
			case AssetClass.Text:
				foreach (string file in files)
				{
					await default(ToBackground);
					string extension = "";
					string text2;
					if (assetClass == AssetClass.Text)
					{
						text2 = File.ReadAllText(file);
						extension = Path.GetExtension(file);
					}
					else
					{
						text2 = file;
					}
					await default(ToWorld);
					Elements.Core.float3 offset = GetOffset(rotation, scale, rowSize, ref index);
					Slot root = CreateAndPositionSlotForImport(world, Path.GetFileName(file), position + offset, rotation, scale);
					string? fileName = Path.GetFileName(file);
					string text3 = text2;
					bool allowRTF = extension != ".log";
					SpawnText(root, fileName, text3, 16f, null, allowRTF);
				}
				break;
			case AssetClass.Package:
				foreach (string file in files)
				{
					UniLog.Log("Importing ResonitePackage: " + file);
					Elements.Core.float3 offset = GetOffset(rotation, scale, rowSize, ref index);
					Slot slot7 = CreateAndPositionSlotForImport(world, Path.GetFileName(file), position + offset, rotation, scale);
					Slot slot8 = world.LocalUserSpace.AddSlot("Indicator");
					slot8.CopyTransform(slot7);
					slot8.PersistentSelf = false;
					ProgressBarInterface progressBarInterface = await slot8.SpawnEntity<ProgressBarInterface, LegacySegmentCircleProgress>(FavoriteEntity.ProgressBar);
					progressBarInterface.Initialize(canBeHidden: false);
					progressBarInterface.UpdateProgress(-1f, "Waiting", "");
					await PackageImporter.ImportPackage(file, slot7, progressBarInterface);
					slot7.GlobalPosition = position + offset;
				}
				break;
			case AssetClass.Object:
				foreach (string file in files)
				{
					await default(ToBackground);
					DataTreeDictionary loadNode = ((File.Exists(file) || !Uri.TryCreate(file, UriKind.Absolute, out url)) ? DataTreeConverter.Load(file) : DataTreeConverter.Load(await world.Engine.AssetManager.GatherAssetFile(url, 100f), url));
					await default(ToWorld);
					if (loadNode.TryGetNode("Slots") != null)
					{
						UniLog.Log("Loading raw world from: " + file);
						Userspace.StartLocal(null, loadNode);
					}
					else
					{
						UniLog.Log("Loading raw object from: " + file);
						Slot slot6 = world.LocalUserSpace.AddSlot("Object");
						slot6.CreateSpawnUndoPoint();
						slot6.LoadObject(loadNode, null);
						slot6.SetGlobalTransform(new Transform(position + GetOffset(rotation, scale, rowSize, ref index), in rotation, in scale));
					}
					url = null;
				}
				break;
			case AssetClass.Audio:
				foreach (string file in files)
				{
					await default(ToWorld);
					Elements.Core.float3 offset = GetOffset(rotation, scale, rowSize, ref index);
					Slot slot7 = CreateAndPositionSlotForImport(world, Path.GetFileName(file), position + offset, rotation, scale);
					await default(ToBackground);
					if (File.Exists(file))
					{
						uri = await world.Engine.LocalDB.ImportLocalAssetAsync(file, LocalDB.ImportLocation.Original);
					}
					else if (!Uri.TryCreate(file, UriKind.Absolute, out uri))
					{
						continue;
					}
					await default(ToWorld);
					AudioPlayerInterface audioPlayer = await slot7.SpawnEntity<AudioPlayerInterface, LegacyAudioPlayer>(FavoriteEntity.AudioPlayer);
					audioPlayer.InitializeEntity(Path.GetFileName(file));
					audioPlayer.SetSource(uri);
					if (Path.GetExtension(file) == ".wav")
					{
						audioPlayer.SetType(AudioTypeGroup.SoundEffect, spatialize: true, 1f);
						continue;
					}
					AudioTypeGroup audioTypeGroup = await DetectAudioTypeGroup(slot7.GetComponentInChildren<IAssetProvider<AudioClip>>());
					bool flag = audioTypeGroup != AudioTypeGroup.Multimedia;
					audioPlayer.SetType(audioTypeGroup, !flag, flag ? 0f : 1f);
				}
				break;
			case AssetClass.Video:
			{
				await Task.Delay(TimeSpan.FromSeconds(0.25));
				Slot slot3 = CreateAndPositionSlotForImport(world, "VideoImporter", position, rotation, scale);
				VideoImportDialog videoImportDialog = slot3.AttachComponent<VideoImportDialog>();
				videoImportDialog.Paths.AddRange(files.Select((string f) => new ImportItem(f)));
				videoImportDialog.SetLocalUserAsImporting();
				if (silent)
				{
					videoImportDialog.RunImport();
				}
				break;
			}
			case AssetClass.Model:
			case AssetClass.PointCloud:
			{
				await Task.Delay(TimeSpan.FromSeconds(0.25));
				Slot slot3 = CreateAndPositionSlotForImport(world, "ModelImporter", position, rotation, scale);
				bool potentialGaussianSplat = files.Any((string f) => AssetHelper.IdentifyClass(f, primary: false) == AssetClass.GaussianSplat);
				ModelImportDialog modelImportDialog = slot3.AttachComponent(runOnAttachBehavior: true, delegate(ModelImportDialog d)
				{
					d.PotentialGaussianSplat.Value = potentialGaussianSplat;
				});
				modelImportDialog.Paths.AddRange(files.Select((string f) => new ImportItem(f)));
				modelImportDialog.SetLocalUserAsImporting();
				if (assetClass == AssetClass.PointCloud)
				{
					modelImportDialog.Preset_PointCloud();
				}
				if (silent)
				{
					modelImportDialog._autoScale.Value = true;
					modelImportDialog.RunImport();
				}
				break;
			}
			case AssetClass.Texture:
			{
