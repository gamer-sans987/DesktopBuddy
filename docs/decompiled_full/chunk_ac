		public void HandleClockError(VideoTextureClockErrorState state)
		{
			if (state.assetId != base.AssetId)
			{
				throw new ArgumentException("This state doesn't belong to this asset");
			}
			CurrentClockError = state.currentClockError;
		}

		public void HandleVideoReady(VideoTextureReady ready)
		{
			Length = ready.length;
			Size = ready.size;
			PlaybackEngine = ready.playbackEngine;
			HasAlpha = ready.hasAlpha;
			_audioTracks = new List<AudioTrackInfo>();
			if (ready.audioTracks != null)
			{
				foreach (VideoAudioTrack audioTrack in ready.audioTracks)
				{
					_audioTracks.Add(new AudioTrackInfo(audioTrack));
				}
				_defaultTrackIndex = _audioTracks.FindIndex((AudioTrackInfo track) => track.Name == null || !track.Name.Contains("disable", StringComparison.InvariantCultureIgnoreCase));
			}
			UniLog.Log($"Audio tracks:\n{string.Join("\n", _audioTracks)}, Default Index: {_defaultTrackIndex}");
			ActivateAudioTrack(_initAudioTrackIndex);
			IsLoaded = true;
			_onReady(ready.instanceChanged);
		}

		private void DisposeAudioReader()
		{
			VideoTextureAudioReader audioReader = _audioReader;
			_audioReader = null;
			if (audioReader != null)
			{
				base.Engine.AudioSystem.SchedulePreRenderTask(audioReader.Dispose);
			}
		}

		private void InitAudioTrack(AudioTrackInfo track)
		{
			if (base.RenderSystem.HasRenderer)
			{
				DisposeAudioReader();
				string queueName = RenderiteMessagingHost.GenerateQueueName();
				_audioReader = VideoTextureAudioReader.Create(queueName, track.ChannelCount, track.SampleRate, base.Engine.AudioSystem.Simulator);
				VideoTextureStartAudioTrack videoTextureStartAudioTrack = new VideoTextureStartAudioTrack();
				videoTextureStartAudioTrack.assetId = base.AssetId;
				videoTextureStartAudioTrack.audioTrackIndex = track.TrackIndex;
				videoTextureStartAudioTrack.queueCapacity = _audioReader.QueueCapacity;
				videoTextureStartAudioTrack.queueName = _audioReader.QueueName;
				base.RenderSystem.SendAssetUpdate(videoTextureStartAudioTrack);
			}
