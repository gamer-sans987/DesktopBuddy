		protected override Bitmap3D DecodeFile(string file, Texture3DVariantDescriptor variant, bool forceMips, bool loadingOriginal, bool sharedMemory)
		{
			base.ActualLoadedVariant = variant?.VariantIdentifier ?? base.ActualLoadedVariant;
			if (Manager == null)
			{
				sharedMemory = false;
			}
			object obj;
			if (!sharedMemory)
			{
				obj = null;
			}
			else
			{
				IBackingBufferAllocator renderSystem = base.RenderSystem;
				obj = renderSystem;
			}
			IBackingBufferAllocator allocator = (IBackingBufferAllocator)obj;
			Bitmap3D bitmap3D;
			try
			{
				bitmap3D = Bitmap3D.Load(file, allocator);
				if (loadingOriginal)
				{
					if (variant != null && bitmap3D.Profile != variant.Profile)
					{
						bitmap3D.ReinterpretProfile(variant.Profile);
					}
					if (bitmap3D.Format == TextureFormat.RGB24)
					{
						bitmap3D = bitmap3D.ConvertToAndDispose(TextureFormat.RGBA32, allocator);
					}
					if (bitmap3D.Format == TextureFormat.ARGB32)
					{
						bitmap3D = bitmap3D.ConvertToAndDispose(TextureFormat.RGBA32, allocator);
					}
					if (bitmap3D.Format == TextureFormat.ARGBHalf)
					{
						bitmap3D = bitmap3D.ConvertToAndDispose(TextureFormat.RGBAHalf, allocator);
					}
					if (bitmap3D.Format == TextureFormat.ARGBFloat)
					{
						bitmap3D = bitmap3D.ConvertToAndDispose(TextureFormat.RGBAFloat, allocator);
					}
				}
				if (!base.RenderSystem.SupportsTextureFormat(bitmap3D.Format))
				{
					TextureFormat? textureFormat = bitmap3D.Format.FindCompatibleFormat(base.RenderSystem.SupportsTextureFormat);
					if (!textureFormat.HasValue)
					{
						throw new InvalidOperationException($"Can't find compatible format for {bitmap3D.Format}");
					}
					UniLog.Warning($"Asset {base.AssetURL} is in incompatible format: {bitmap3D.Format}. Converting to: {textureFormat.Value}");
					Bitmap3D bitmap3D2 = bitmap3D.ConvertTo(textureFormat.Value, allocator);
					bitmap3D.Buffer.Dispose();
					bitmap3D = bitmap3D2;
				}
				if (variant != null && loadingOriginal)
				{
					if (variant.ColorPreprocess == ColorPreprocess.sRGB)
					{
						bitmap3D.ConvertTosRGB();
					}
					else if (variant.ColorPreprocess == ColorPreprocess.HDRsRGB)
					{
						bitmap3D.ConvertHDRToHDRsRGB();
					}
					if (variant.AlphaPreprocess == AlphaPreprocess.sRGB)
					{
						bitmap3D.AdjustAlphaGamma(2.2f);
					}
				}
				if (bitmap3D.Format.IsHDR() && bitmap3D.Profile != ColorProfile.Linear)
				{
					UniLog.Warning($"Texture3D {base.AssetURL} uses HDR format {bitmap3D.Format}, but ColorProfile is {bitmap3D.Profile}. Converting to linear...");
					bitmap3D.ConvertToProfile(ColorProfile.Linear);
				}
			}
			catch (Exception value)
			{
				UniLog.Warning($"Exception decoding texture:\n{value}");
				bitmap3D = null;
			}
			UniLog.Log($"Texture3D: {bitmap3D}, Variant: {variant?.VariantIdentifier} (Original: {variant?.OriginalAsset})");
			return bitmap3D ?? TextureDecoder.ERRORTEXTURE3D;
		}

		protected override bool UpdateData(Texture3DVariantDescriptor variant, Bitmap3D bitmap, int? overrideMips = null)
		{
			int num;
			if ((object)variant == null)
			{
				num = 0;
			}
			else
			{
				num = (variant.Readable ? 1 : 0);
				if (num != 0)
				{
