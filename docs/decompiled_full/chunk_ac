		private async ValueTask LoadFromStreamURL(Uri streamURL)
		{
			VideoTexture tex = CreateVideoTexture();
			_videoTex = tex;
			string mime = null;
			if (streamURL.OriginalString.Contains(".mp4"))
			{
				mime = "video/mp4";
			}
			if (mime == null && streamURL.Scheme == base.Cloud.Assets.DBScheme)
			{
