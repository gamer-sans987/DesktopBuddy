				legacyRangeMapper.BlendDistance.Target = sphereConstantReferenceSpatialVariable.BlendDistance;
				LegacyReverbHelper.UpgradeReverb(this, node, control);
				DataTreeDictionary dataTreeDictionary = (DataTreeDictionary)node;
				legacyRangeMapper.MinDistance.Load(dataTreeDictionary["MinDistance"], control);
