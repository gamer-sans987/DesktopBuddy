		public string Format(string key, Dictionary<string, object> arguments, bool returnNullIfNotFound = false)
		{
			if (string.IsNullOrWhiteSpace(key))
			{
				return null;
			}
			if (Data == null)
			{
				return null;
			}
			arguments = MergeGlobalArguments(arguments);
			try
			{
				return Data.Format(key, arguments) ?? (returnNullIfNotFound ? null : key);
			}
			catch (Exception ex)
			{
				UniLog.Error($"Exception formatting message {key}, Locale Code: {Data?.GetKeyLocaleCode(key)}:\n" + ((arguments != null) ? $"Arguments ({arguments?.Count}):\n{string.Join("\n", arguments?.Select((KeyValuePair<string, object> p) => $"\t{p.Key} = {p.Value}"))}\n" : "") + ex);
				return "ERROR!!!";
			}
		}

		public static void UpdateGlobalLocaleArguments(Engine engine)
		{
			GlobalLocaleArguments["appName"] = engine.AppName;
			GlobalLocaleArguments["studioNameShort"] = engine.Cloud.Platform.StudioNameShort;
			GlobalLocaleArguments["studioNameLong"] = engine.Cloud.Platform.StudioNameLong;
			GlobalLocaleArguments["supportUrl"] = engine.Cloud.Platform.SupportUrl;
			GlobalLocaleArguments["moderationUrl"] = engine.Cloud.Platform.ModerationUrl;
			GlobalLocaleArguments["bugUrl"] = engine.Cloud.Platform.GitHubIssuesRepository;
		}

		private Dictionary<string, object> MergeGlobalArguments(Dictionary<string, object>? arguments = null)
		{
			if (arguments == null || arguments.Count == 0)
			{
				return GlobalLocaleArguments;
			}
			foreach (KeyValuePair<string, object> globalLocaleArgument in GlobalLocaleArguments)
			{
				if (!arguments.ContainsKey(globalLocaleArgument.Key))
				{
					arguments.Add(globalLocaleArgument.Key, globalLocaleArgument.Value);
				}
			}
			return arguments;
		}
	}
