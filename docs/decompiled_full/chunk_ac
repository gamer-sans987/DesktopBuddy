	public class EngineRecordUploadTask : RecordUploadTaskBase<FrooxEngine.Store.Record>
	{
		private SavedGraph _graph;

		private Dictionary<string, string> _localFilesByHash = new Dictionary<string, string>();

		private Dictionary<Uri, AssetUploadData> _localAssets = new Dictionary<Uri, RecordUploadTaskBase<FrooxEngine.Store.Record>.AssetUploadData>();

		private Dictionary<string, List<Func<Task>>> _metadataUploadTasks = new Dictionary<string, List<Func<Task>>>();

		public new SkyFrostInterface Cloud => Engine.Cloud;

		public Engine Engine { get; private set; }

		public LocalDB DB => Engine.LocalDB;

		public EngineRecordUploadTask(Engine engine, FrooxEngine.Store.Record record, SavedGraph loadedGraph = null)
			: base((SkyFrostInterface)engine.Cloud, record, ensureFolder: true)
		{
			Engine = engine;
			_graph = loadedGraph;
		}

		protected override async Task<bool> PrepareRecord(CancellationToken cancelationToken)
		{
			if (!(await PrepareManifest(cancelationToken)))
			{
				return false;
			}
			if (!(await CollectAssets(cancelationToken)))
			{
				return false;
			}
			if (!(await UpdateMainAsset(cancelationToken)))
			{
				return false;
			}
			base.Record.Manifest.RemoveAll((string r) => string.IsNullOrEmpty(r));
			return true;
		}

		protected override ValueTask<SkyFrost.Base.AssetData> ReadFile(string signature)
		{
			return new ValueTask<SkyFrost.Base.AssetData>(File.OpenRead(_localFilesByHash[signature]));
		}

		protected override ValueTask UploadStarted(string signature)
		{
			if (_metadataUploadTasks.TryGetValue(signature, out List<Func<Task>> value))
			{
				foreach (Func<Task> item in value)
				{
					Engine.RecordManager.ScheduleVariantUpload(item);
				}
			}
			return default(ValueTask);
		}

		private async Task<bool> LoadGraph(CancellationToken cancellationToken)
		{
			if (_graph == null && (base.Record.RecordType == "world" || base.Record.RecordType == "object"))
			{
				try
				{
					Uri graphUrl = new Uri(base.Record.AssetURI);
					string text = await Engine.AssetManager.GatherAssetFile(graphUrl, -100f).ConfigureAwait(continueOnCapturedContext: false);
					if (cancellationToken.IsCancellationRequested)
					{
						Fail("Record upload task cancelled");
						return false;
					}
					if (!File.Exists(text))
					{
						Fail("Could not locate main asset: " + base.Record.AssetURI);
						return false;
					}
					DataTreeDictionary root = DataTreeConverter.Load(text, graphUrl);
					_graph = new SavedGraph(root);
				}
				catch (Exception value)
				{
					Fail($"Exception loading the object graph from asset {base.Record.AssetURI}:\n{value}");
					return false;
				}
			}
			return true;
		}

		private Uri MigrateUri(Uri uri)
		{
			uri = uri.MigrateLegacyURL(Cloud.Platform);
			if (Cloud.Assets.IsLegacyDB(uri))
			{
				string signature = Cloud.Assets.DBSignature(uri);
				uri = Cloud.Assets.GenerateURL(signature);
			}
			return uri;
		}

		private void BuildManifest()
		{
			if (_graph != null)
			{
				base.Record.Manifest = new List<string>((from node in _graph.URLNodes
					select node.Extract<Uri>() into u
					select MigrateUri(u) into u
					where u.Scheme != Cloud.Assets.DBScheme || Cloud.Assets.IsValidDBUri(u)
					select (!Cloud.Assets.IsValidDBUri(u)) ? u.ToString() : Cloud.Assets.FilterDatabaseURL(u).ToString()).Distinct());
			}
			else if (base.Record.Manifest == null)
			{
				base.Record.Manifest = new List<string>();
			}
			base.Record.Manifest.Add(base.Record.ThumbnailURI);
			HashSet<string> hashSet = Pool.BorrowHashSet<string>();
			for (int num = base.Record.Manifest.Count - 1; num >= 0; num--)
			{
				if (!hashSet.Add(base.Record.Manifest[num]))
				{
					base.Record.Manifest.RemoveAt(num);
				}
			}
			Pool.Return(ref hashSet);
			if (!string.IsNullOrEmpty(base.Record.AssetURI))
			{
				base.Record.Manifest.Remove(base.Record.AssetURI);
			}
		}

		private async Task<bool> CollectAssets(CancellationToken cancelationToken)
		{
			base.Record.AssetManifest = new List<DBAsset>();
			base.StageDescription = "Collecting all assets";
			for (int i = 0; i < base.Record.Manifest.Count; i++)
			{
				if (!Uri.IsWellFormedUriString(base.Record.Manifest[i], UriKind.Absolute))
				{
					continue;
				}
				Uri uri = MigrateUri(new Uri(base.Record.Manifest[i]));
				if (!(uri.Scheme == "local") && !(uri.Scheme == Cloud.Assets.DBScheme))
				{
					continue;
				}
				AssetRecord assetInfo = await DB.TryFetchAssetRecordWithMetadataAsync(uri).ConfigureAwait(continueOnCapturedContext: false);
				if (assetInfo == null)
				{
					if (uri.Scheme == Cloud.Assets.DBScheme)
					{
						CloudResult<AssetInfo> cloudResult = await Cloud.Assets.GetGlobalAssetInfo(Cloud.Assets.DBSignature(uri)).ConfigureAwait(continueOnCapturedContext: false);
						if (cancelationToken.IsCancellationRequested)
						{
							Fail("Record upload task cancelled");
							return false;
						}
						if (cloudResult.IsOK)
						{
							base.Record.AssetManifest.Add(new DBAsset
							{
								Hash = cloudResult.Entity.AssetHash,
								Bytes = cloudResult.Entity.Bytes
							});
							continue;
						}
					}
					UniLog.Log("WARNING: asset record doesn't exist for " + uri);
					base.Record.Manifest[i] = null;
					_localAssets.Add(uri, null);
					continue;
				}
				if (assetInfo.bytes == 0L)
				{
					UniLog.Warning("Zero-length asset! Excluding from manifest. Hash: " + assetInfo.signature + ", localFile: " + assetInfo.path + ", URL: " + uri);
					base.Record.Manifest[i] = null;
					_localAssets.Add(uri, null);
					continue;
				}
				AssetUploadData uploadData = new RecordUploadTaskBase<FrooxEngine.Store.Record>.AssetUploadData
				{
					appDBURL = Cloud.Assets.GenerateURLWithExtension(assetInfo.cloudsig, Path.GetExtension(assetInfo.path)),
					appDBSig = assetInfo.cloudsig,
					bytes = assetInfo.bytes,
					localFile = assetInfo.path
				};
				_localAssets.Add(uri, uploadData);
				await Engine.LocalDB.StoreAssetRecordAsync(uploadData.appDBURL, assetInfo.path);
				List<Func<Task>> tasks = null;
				if (!_metadataUploadTasks.ContainsKey(assetInfo.cloudsig))
				{
					tasks = new List<Func<Task>>();
					_metadataUploadTasks.Add(assetInfo.cloudsig, tasks);
				}
				IAssetMetadata metadata = await Engine.LocalDB.TryFetchAssetMetadataAsync(uri.ToString());
				if (metadata != null)
				{
					metadata.AssetIdentifier = assetInfo.cloudsig;
					await Engine.LocalDB.SaveAssetMetadataAsync(metadata);
					tasks?.Add(async delegate
					{
						await Cloud.Assets.StoreAssetMetadata(metadata);
					});
				}
				foreach (AssetRecord item in await Engine.LocalDB.GetAllVariantsAsync(uri))
				{
					Uri variantUrl = new Uri(item.url);
					string file = item.path;
					if (!File.Exists(file))
					{
						continue;
					}
					try
					{
						Uri dbVariantUrl = new Uri(uploadData.appDBURL, variantUrl.Query);
						_ = new FileInfo(file).Length;
						await Engine.LocalDB.StoreCacheRecordAsync(dbVariantUrl, file);
						if (metadata != null)
						{
							string variantIdentifier = dbVariantUrl.Query.Substring(1);
							if (metadata is BitmapMetadata)
							{
								Elements.Assets.Texture2DVariantDescriptor variantDescriptor = Elements.Assets.Texture2DVariantDescriptor.FromIdentifier(variantIdentifier);
								Engine.AssetManager.SeedMobileVariant(assetInfo.cloudsig, variantDescriptor);
							}
							if (metadata is GaussianSplatMetadata)
							{
								Elements.Assets.GaussianSplatVariantDescriptor variantDescriptor2 = Elements.Assets.GaussianSplatVariantDescriptor.FromIdentifier(variantIdentifier);
								Engine.AssetManager.SeedGaussianSplatVariants(assetInfo.cloudsig, variantDescriptor2);
							}
							tasks?.Add(async delegate
							{
								AssetUploadTask assetUploadTask = Cloud.Assets.CreateFileAssetUploadTask(base.Record.OwnerId, assetInfo.cloudsig, variantIdentifier, file);
								assetUploadTask.IsOptional = true;
								await assetUploadTask.UploadAssetData().ConfigureAwait(continueOnCapturedContext: false);
							});
						}
					}
					catch (Exception value)
					{
						UniLog.Error($"Exception when scheduling variant upload. Variant URL: {variantUrl}, File: {file}\n{value}");
					}
				}
				base.Record.AssetManifest.Add(new DBAsset
				{
					Hash = assetInfo.cloudsig,
					Bytes = assetInfo.bytes
				});
				if (base.Record.Manifest[i] == base.Record.ThumbnailURI)
				{
					base.Record.ThumbnailURI = uploadData.appDBURL.ToString();
				}
				base.Record.Manifest[i] = uploadData.appDBURL.ToString();
			}
			return true;
		}

		private async Task<bool> UpdateMainAsset(CancellationToken cancelationToken)
		{
			base.StageDescription = "Collecting & Updating main asset";
			if (base.Record.AssetURI == null)
			{
				return true;
			}
			string origAssetUri = base.Record.AssetURI;
			Uri recordAssetUri = new Uri(base.Record.AssetURI);
			if (recordAssetUri.Scheme == "local" || _graph?.URLNodes?.Any((DataTreeValue node) => node.Extract<Uri>().Scheme == "local") == true)
			{
				if (base.Record.RecordType == "world" || base.Record.RecordType == "object")
				{
					foreach (DataTreeValue uRLNode in _graph.URLNodes)
					{
						Uri uri = uRLNode.Extract<Uri>();
						if (_localAssets.TryGetValue(uri, out RecordUploadTaskBase<FrooxEngine.Store.Record>.AssetUploadData value))
						{
							if (value == null)
							{
								uRLNode.UpdateValue((Uri)null);
								continue;
							}
							uRLNode.UpdateValue(value.appDBURL);
							base.Record.ReplaceInTags(uri.ToString(), value.appDBURL.ToString());
						}
					}
					string tempFilePath = DB.GetTempFilePath("brson");
					DataTreeConverter.Save(_graph.Root, tempFilePath, DataTreeConverter.Compression.Brotli);
					recordAssetUri = await DB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).ConfigureAwait(continueOnCapturedContext: false);
					base.Record.AssetURI = recordAssetUri.ToString();
				}
				AssetRecord assetRecord = await DB.TryFetchAssetRecordWithMetadataAsync(recordAssetUri).ConfigureAwait(continueOnCapturedContext: false);
				RecordUploadTaskBase<FrooxEngine.Store.Record>.AssetUploadData assetUploadData = new RecordUploadTaskBase<FrooxEngine.Store.Record>.AssetUploadData();
				assetUploadData.appDBURL = Cloud.Assets.GenerateURLWithExtension(assetRecord.cloudsig, Path.GetExtension(assetRecord.path));
				assetUploadData.appDBSig = assetRecord.cloudsig;
				assetUploadData.bytes = assetRecord.bytes;
				assetUploadData.localFile = assetRecord.path;
				_localAssets.Add(recordAssetUri, assetUploadData);
				base.Record.AssetURI = assetUploadData.appDBURL.ToString();
				base.Record.AssetManifest.Add(new DBAsset
				{
					Hash = assetUploadData.appDBSig,
					Bytes = assetUploadData.bytes
				});
				if (base.Record.ThumbnailURI == origAssetUri)
				{
					base.Record.ThumbnailURI = base.Record.AssetURI;
				}
			}
			else if (recordAssetUri.Scheme == Cloud.Assets.DBScheme)
			{
				string hash = Cloud.Assets.DBSignature(recordAssetUri);
				base.Record.AssetManifest.Add(new DBAsset
				{
					Hash = hash,
					Bytes = 0L
				});
			}
			return true;
		}

		private async Task<bool> PrepareManifest(CancellationToken cancelationToken)
		{
			if (!(await LoadGraph(cancelationToken).ConfigureAwait(continueOnCapturedContext: false)))
			{
				return false;
			}
			BuildManifest();
			return true;
		}

		protected override Task<bool> PrepareFilesForUpload(CancellationToken cancellationToken)
		{
			base.StageDescription = "Matching local files";
			foreach (KeyValuePair<Uri, RecordUploadTaskBase<FrooxEngine.Store.Record>.AssetUploadData> localAsset in _localAssets)
			{
				if (localAsset.Value != null)
				{
					string key = localAsset.Value.appDBSig.ToLowerInvariant();
					if (!_localFilesByHash.ContainsKey(key))
					{
						_localFilesByHash.Add(key, localAsset.Value.localFile);
					}
				}
			}
			return Task.FromResult(result: true);
		}

