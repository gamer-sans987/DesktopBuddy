		/// <summary>
		/// Spawns an in-world representation of a folder or link to a folder.
		/// </summary>
		/// <param name="s">Slot to spawn the link on</param>
		/// <param name="url">The original URL used to retrieve the folder</param>
		/// <param name="record">Record loaded from the URL</param>
		private static void SpawnInventoryLink(Slot s, Uri url, IRecord record)
		{
			Uri uri = null;
			if (record.RecordType == "directory")
			{
				uri = url;
			}
			if (record.RecordType == "link" && Uri.IsWellFormedUriString(record.AssetURI, UriKind.Absolute))
			{
				uri = new Uri(record.AssetURI);
			}
			if (uri == null)
			{
				SpawnText(s, "Importer.Link.Invalid.Heading".AsLocaleKey(), "Importer.Link.Invalid.Description".AsLocaleKey("url", url));
				UniLog.Warning($"Error importing an inventory link, Invalid Link:{url}.");
			}
			else
			{
				s.Name = s.GetLocalized("Inventory.Link.LinkText".AsLocaleKey("name", record.Name));
				InventoryLink inventoryLink = s.AttachComponent<InventoryLink>();
				inventoryLink.TargetName.Value = record.Name;
				inventoryLink.Target.Value = uri;
			}
		}

