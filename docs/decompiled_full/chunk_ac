	{
		private static string[] formats = new string[4] { "PNG", "JPG", "EXR", "LUT" };

		public readonly AssetRef<Texture2D> Texture;

		public string ExportName
		{
			get
			{
				if (Texture.Target == null)
				{
					return null;
				}
				IItemMetadataSource componentInChildren = Texture.Target.Slot.GetComponentInChildren((IItemMetadataSource s) => s != this);
				if (componentInChildren != null)
				{
