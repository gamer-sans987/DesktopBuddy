		public void SetGaitParameters(List<LocomotionGaitParameters> parameters)
		{
			_parameters.Clear();
			_parameters.AddRange(parameters);
			_parameters.Sort((LocomotionGaitParameters a, LocomotionGaitParameters b) => a.ReferenceSpeed.CompareTo(b.ReferenceSpeed));
			for (int num = 1; num < _parameters.Count; num++)
			{
				float referenceSpeed = _parameters[num - 1].ReferenceSpeed;
				float referenceSpeed2 = _parameters[num].ReferenceSpeed;
				if (MathX.Approximately(referenceSpeed, referenceSpeed2))
				{
					_parameters.RemoveAt(num);
					num--;
				}
			}
		}

