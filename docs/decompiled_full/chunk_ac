		private bool EnsureActive()
		{
			bool flag = World.Focus == FrooxEngine.World.WorldFocus.Focused || World.Focus == FrooxEngine.World.WorldFocus.Overlay || World.Focus == FrooxEngine.World.WorldFocus.PrivateOverlay;
			if (_spaceActive != flag)
			{
				_spaceActive = flag;
				if (flag)
				{
					Simulator.ActivateSpace(_space);
				}
				else
				{
					Simulator.DeactivateSpace(_space);
				}
			}
			return flag;
		}

		private void UpdateListeners(ChangesBatch batch)
		{
			bool flag = false;
			bool flag2 = false;
			foreach (AudioListener listener2 in _listeners)
			{
				if (listener2.ShouldBeActive)
				{
					if (!listener2.IsRegistered)
					{
						Listener listener = Space.AddListener();
						listener2.LinkNativeListener(listener);
						_updateAllListenerExclusionLists = true;
					}
					listener2.UpdateNativeListener(batch);
					bool num = listener2 == World.LocalUser.Root?.PrimaryListener.Target;
					bool flag3 = false;
					if (num)
					{
						flag3 = true;
						flag = true;
					}
					else if (!flag && !flag2)
					{
						flag3 = true;
						flag2 = true;
					}
					if (flag3)
					{
						LastPrimaryEarPosition = listener2.Slot.GlobalPosition;
						LastPrimaryEarRotation = listener2.Slot.GlobalRotation;
						LastPrimaryEarScale = listener2.Slot.GlobalScale;
					}
				}
				else if (listener2.IsRegistered)
				{
					_space.RemoveListener(listener2.NativeListener);
					listener2.ClearNativeListener();
					_updateAllListenerExclusionLists = true;
				}
			}
		}

		private void UpdateAudioOutputs(ChangesBatch batch)
		{
			foreach (AudioOutput item in _outputsToAddOrRemove)
			{
				bool shouldBeEnabled = item.ShouldBeEnabled;
				if (shouldBeEnabled == item.IsRegistered)
				{
					item.ClearAdditionRemovalFlag();
					continue;
				}
				if (shouldBeEnabled)
				{
					item.LinkNativeOutput(_space.AddOutput());
					continue;
				}
				_space.RemoveOutput(item.NativeOutput);
				item.ClearNativeOutput();
			}
			foreach (AudioOutput item2 in _outputsToUpdate)
			{
				item2.UpdateNativeOutput(batch, !_updateAllListenerExclusionLists);
			}
			if (_updateAllListenerExclusionLists)
			{
				foreach (AudioOutput output in _outputs)
				{
					if (output.IsRegistered)
					{
						output.UpdateExcludedListeners(batch);
					}
				}
				_updateAllListenerExclusionLists = false;
			}
			_outputsToAddOrRemove.Clear();
			_outputsToUpdate.Clear();
		}

		private void UpdateAudioEffects(ChangesBatch batch)
		{
			foreach (AudioDSP_Effect item in _effectsToUpdate)
			{
				item.Update(batch);
			}
			_effectsToUpdate.Clear();
		}

		public void Dispose()
		{
			Simulator.RemoveSpace(_space);
		}
