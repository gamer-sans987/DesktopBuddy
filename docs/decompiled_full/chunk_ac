		private void RequestData<T>(ref T data, IMeshPhysicsDataRequester requester, Action<T> preInit = null) where T : class, IMeshPhysicsData, new()
		{
			if (data != null)
			{
				data.EnsureUpToDate(requester);
				return;
			}
			if (Data == null)
			{
				throw new InvalidOperationException("Can only request collider data after mesh is loaded");
			}
			T val = new T();
			T val2 = Interlocked.CompareExchange(ref data, val, null);
			if (val2 != null)
			{
				val2.EnsureUpToDate(requester);
				return;
			}
			preInit?.Invoke(val);
			val.Initialize(this);
			val.EnsureUpToDate(requester);
		}

		public void EnsureWeightedTriangleIndicies(Action computeCallback = null)
		{
			if (ComputeWeightedTriangleIndicies)
			{
				if (_weightedTriangleIndicies != null || computeCallback == null)
				{
					return;
				}
				bool flag = false;
				lock (this)
				{
					if (_weightedTriangleIndicies != null)
					{
						flag = true;
					}
					else
					{
						if (_weightedTriangleIndiciesRequests == null)
						{
							_weightedTriangleIndiciesRequests = new List<Action>();
						}
						_weightedTriangleIndiciesRequests.Add(computeCallback);
					}
				}
				if (flag)
				{
					computeCallback();
				}
				return;
			}
			ComputeWeightedTriangleIndicies = true;
			if (_weightedTriangleIndicies != null)
			{
				return;
			}
			Task.Run(async delegate
			{
				object _lock = new object();
				try
				{
					await RequestWriteLock(_lock);
					if (_weightedTriangleIndicies != null)
					{
						return;
					}
					_weightedTriangleIndicies = Data.ComputeWeightedTriangleList();
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception computing weighted triangle list:\n{value}");
				}
				finally
				{
					ReleaseWriteLock(_lock);
				}
				computeCallback?.Invoke();
				List<Action> list = null;
				lock (this)
				{
					list = _weightedTriangleIndiciesRequests;
					_weightedTriangleIndiciesRequests = null;
				}
				foreach (Action item in list)
				{
					item();
				}
			});
		}
	}
