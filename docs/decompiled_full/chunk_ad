	[Category(new string[] { "Cloud/Variables" })]
	public abstract class CloudVariableBase : Component
	{
		public readonly Sync<string> Path;

		protected CloudVariableProxy Proxy { get; private set; }

		protected abstract bool ShouldUpdate { get; }

		protected abstract string OwnerId { get; }

		protected bool CanRead
		{
			get
			{
				if (Proxy == null)
				{
					return false;
				}
				if (!Proxy.HasValidValue)
				{
					return false;
				}
				if (Proxy.PublicRead)
				{
					return true;
				}
				return base.World.IsUserspace();
			}
		}

		protected bool CanWrite
		{
			get
			{
				if (Proxy == null)
				{
					return false;
				}
				if (!Proxy.HasValidValue)
				{
					return false;
				}
				if (Proxy.PublicWrite)
				{
					return true;
				}
				if (Proxy.PrivateWrite)
				{
					return base.World.IsUserspace();
				}
				return false;
			}
		}

		protected abstract void ValueUpdated(CloudVariableProxy proxy);

		protected abstract void ValueReset(bool soft = false);

		protected override void OnChanges()
		{
			base.OnChanges();
			string text = null;
			string text2 = null;
			if (ShouldUpdate)
			{
				text = Path.Value;
				text2 = OwnerId;
			}
			if (Proxy?.Identity.path != text || Proxy?.Identity.ownerId != text2)
			{
				if (!CloudVariableHelper.IsValidPath(text))
				{
					text = null;
				}
				OwnerType ownerType = IdUtil.GetOwnerType(text2);
				if (ownerType != OwnerType.User && ownerType != OwnerType.Group && ownerType != OwnerType.Machine)
				{
					text2 = null;
				}
				Unregister();
				ValueReset(soft: true);
				if (text != null && text2 != null)
				{
					Proxy = base.Engine.Cloud.Variables.RegisterListener(text2, text, Proxy_ValueChanged);
				}
			}
			if (ShouldUpdate)
			{
				if (CanRead)
				{
					ValueUpdated(Proxy);
				}
				else
				{
					ValueReset();
				}
			}
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			base.Cloud.Session.UserUpdated += OnUserUpdated;
		}

		private void OnUserUpdated(SkyFrost.Base.User obj)
		{
			if (Proxy?.Identity.ownerId != OwnerId)
			{
				MarkChangeDirty();
			}
		}

		private void Unregister()
		{
			if (Proxy != null)
			{
				Proxy.Unregister(Proxy_ValueChanged);
				Proxy = null;
			}
		}

		private void Proxy_ValueChanged(CloudVariableProxy proxy)
		{
			MarkChangeDirty();
		}

		protected override void OnDispose()
		{
			base.Cloud.Session.UserUpdated -= OnUserUpdated;
			Unregister();
			base.OnDispose();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Path = new Sync<string>();
		}
	}
