			Elements.Core.bool3 edgeMask = Elements.Core.BoundingBox.GetEdgeMask(index);
			_ = TargetBox;
			Elements.Core.float3 edgePoint = TargetBox.GetEdgePoint(Elements.Core.BoundingBox.GetOppositeEdgeIndex(index));
