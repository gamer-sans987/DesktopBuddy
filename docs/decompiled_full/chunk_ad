		private async Task Generate(IButton button, ButtonEventData eventData)
		{
			if (button != null)
			{
				button.Enabled = false;
				button.LabelText = "Generating...";
			}
			base.Slot.DestroyChildren();
			await default(ToBackground);
			MazeWallData maze = new MazeWallData(Cells);
			Stack<Elements.Core.int2> stack = new Stack<Elements.Core.int2>();
			List<Elements.Core.int2> list = new List<Elements.Core.int2>();
			RandomXGenerator randomSource = new RandomXGenerator(Seed);
			stack.Push(Point0);
			maze.MarkVisited(Point0.Value.x, Point0.Value.y);
			while (stack.Count > 0)
			{
				Elements.Core.int2 a = stack.Peek();
				maze.GetUnvisitedNeighbors(a.x, a.y, list);
				if (list.Count == 0)
				{
					stack.Pop();
					continue;
				}
				Elements.Core.int2 b = list.GetRandom(randomSource);
				maze.RemoveWallBetween(in a, in b);
				if (b != Point1.Value)
				{
					stack.Push(b);
				}
				maze.MarkVisited(b.x, b.y);
				list.Clear();
			}
			await default(ToWorld);
			MaterialProvider material = Material.Target ?? base.Slot.GetComponentOrAttach<PBS_Metallic>();
			QuadMesh componentOrAttach = base.Slot.GetComponentOrAttach<QuadMesh>();
			Elements.Core.float2 v = WallSize.Value;
			Elements.Core.float2 @float = v * 0.5f;
			componentOrAttach.Size.Value = WallSize.Value;
			_ = v.xy / (Elements.Core.float2)Cells.Value;
			for (int i = 0; i < maze.Size.y; i++)
			{
				Slot slot = base.Slot.AddSlot("Row " + i);
				slot.LocalPosition = new Elements.Core.float3(0f, 0f, (float)i * v.x - @float.x);
				for (int j = 0; j < maze.Size.x; j++)
				{
					Slot slot2 = slot.AddSlot("Column " + j);
					slot2.LocalPosition = new Elements.Core.float3((float)j * v.x - @float.x);
					if (maze.HasWall(j, i, MazeWallData.Wall.Top))
					{
						AddWall(slot2, v, MazeWallData.Wall.Top, material, componentOrAttach);
					}
					if (maze.HasWall(j, i, MazeWallData.Wall.Bottom))
					{
						AddWall(slot2, v, MazeWallData.Wall.Bottom, material, componentOrAttach);
					}
					if (maze.HasWall(j, i, MazeWallData.Wall.Left))
					{
						AddWall(slot2, v, MazeWallData.Wall.Left, material, componentOrAttach);
					}
					if (maze.HasWall(j, i, MazeWallData.Wall.Right))
					{
						AddWall(slot2, v, MazeWallData.Wall.Right, material, componentOrAttach);
					}
				}
			}
			if (Bake.Value)
			{
				await base.Slot.BakeMeshes(destroyOriginal: true, undoable: false);
			}
			if (button != null && !button.IsDestroyed)
			{
				button.Enabled = true;
				button.LabelText = "Generate";
			}
		}

		private void AddWall(Slot root, Elements.Core.float2 wallSize, MazeWallData.Wall wall, IAssetProvider<Material> material, QuadMesh mesh)
		{
			Elements.Core.float3 v = wall switch
			{
				MazeWallData.Wall.Bottom => Elements.Core.float3.Forward, 
				MazeWallData.Wall.Left => Elements.Core.float3.Left, 
				MazeWallData.Wall.Right => Elements.Core.float3.Right, 
				MazeWallData.Wall.Top => Elements.Core.float3.Backward, 
				_ => throw new Exception("Invalid wall: " + wall), 
			};
			Slot slot = root.AddSlot(wall.ToString());
			slot.LocalPosition = v * wallSize.x * 0.5f + wallSize.y;
			slot.LocalRotation = Elements.Core.floatQ.LookRotation(in v, Elements.Core.float3.Up);
			slot.AttachMesh(mesh, material);
			BoxCollider boxCollider = slot.AttachComponent<BoxCollider>();
			boxCollider.Size.Value = wallSize.xy_;
			boxCollider.CharacterCollider.Value = true;
		}

