		[SyncMethod(typeof(Delegate), null)]
		private void RunAction(IButton button, ButtonEventData eventData, string path)
		{
			if (base.IsDestroyed)
			{
				UniLog.Warning("Calling RunAction() on a destroyed dialog", stackTrace: true);
				return;
			}
			int index = int.Parse(Path.GetFileName(path));
			path = PathUtility.GetDirectoryName(path);
			CategoryNode<CategoryItem> subcategory = root.GetSubcategory(path);
			if (subcategory != null)
			{
				CategoryItem element = subcategory.GetElement(index);
				base.World.BeginUndoBatch(element.name);
				Slot slot = base.LocalUserSpace.AddSlot(element.name);
				slot.CreateSpawnUndoPoint();
				slot.GlobalPosition = base.Slot.GlobalPosition;
				slot.PointAtUserHead(Elements.Core.float3.Backward, verticalAxisOnly: true);
				element.action(slot);
				base.World.EndUndoBatch();
				OnCreated.Target?.Invoke(this, slot);
				base.Slot.Destroy();
			}
		}

