		private void GetUsersInVicinity(User user, HashSet<User> group)
		{
			if (IgnoreUser(user))
			{
				return;
			}
			Elements.Core.float3 a = user.Root.HeadPosition;
			group.Add(user);
			foreach (User allUser in base.World.AllUsers)
			{
				if (!IgnoreUser(allUser) && !group.Contains(allUser) && MathX.Distance(in a, allUser.Root.HeadPosition) < (float)GroupSearchRadius * user.Root.GlobalScale)
				{
					group.Add(allUser);
					GetUsersInVicinity(allUser, group);
				}
			}
		}

		private bool IgnoreUser(User user)
		{
			if (user == null || user.HeadDevice == HeadOutputDevice.StaticCamera || user.HeadDevice == HeadOutputDevice.StaticCamera360 || user.IsDestroyed || user.Root == null)
			{
				return true;
			}
			return false;
		}

