		public readonly Sync<int> MaxClipAttempts;

		public readonly Sync<float> HeightmapExp;

		public readonly Sync<int> Seed;

		public readonly Sync<int> Points;

		public readonly RelayRef<AtlasInfo> Atlas;

		public readonly Sync<Elements.Core.float3> Scale;

		public readonly Sync<float> RangeExp;

		public readonly Sync<Elements.Core.float3> JitterRange;

		public readonly Sync<Elements.Core.colorX> Color0;

		public readonly Sync<Elements.Core.colorX> Color1;

		public readonly Sync<float> ColorLerpScale;

		public readonly Sync<float> ColorGap;

		public readonly Sync<Elements.Core.float3> SimplexNoiseScale;

		public readonly Sync<Elements.Core.float3> SimplexNoiseOffset;

		public readonly Sync<bool> UniformSize;

		public readonly Sync<Elements.Core.float2> MinSize;

		public readonly Sync<Elements.Core.float2> MaxSize;

		public readonly Sync<float> MinRotation;

		public readonly Sync<float> MaxRotation;

		public override int Version => 1;

		protected override bool UseAsyncUpdate => true;

		protected override void OnAwake()
		{
			Scale.Value = Elements.Core.float3.One;
			RangeExp.Value = 1f;
			Color0.Value = Elements.Core.colorX.White;
			Color1.Value = Elements.Core.colorX.White;
			ColorLerpScale.Value = 1f;
			UniformSize.Value = true;
			MinSize.Value = Elements.Core.float2.One * 0.001f;
			MaxSize.Value = Elements.Core.float2.One * 0.01f;
			MaxRotation.Value = 360f;
			SimplexNoiseScale.Value = Elements.Core.float3.One * 10f;
			TextureIntensityClip.Value = -1f;
			TextureAlphaClip.Value = 0.01f;
			MaxClipAttempts.Value = 10;
			HeightmapExp.Value = 1f;
		}

		protected override void OnAttach()
		{
			Seed.Value = RandomX.Int;
			SimplexNoiseOffset.Value = RandomX.Range(-Elements.Core.float3.One * 10000, Elements.Core.float3.One * 10000);
		}

		protected override void PrepareAssetUpdateData()
		{
		}

		protected override void ClearMeshData()
		{
		}

		protected override async Task UpdateMeshDataAsync(MeshX meshx)
		{
			int _points = MathX.Max(0, Points.Value);
			int _seed = Seed.Value;
			DistributionType _distribution = Distribution.Value;
			ColorMode _colors = Colors.Value;
			Elements.Core.float3 _scale = Scale.Value;
			float _rangeExp = RangeExp.Value;
			Elements.Core.float3 _jitterRange = JitterRange.Value;
			Elements.Core.colorX _color0 = Color0.Value;
			Elements.Core.colorX _color1 = Color1.Value;
			float _colorGap = ColorGap.Value;
			float _colorLerpScale = ColorLerpScale.Value;
			Elements.Core.float3 _simplexNoiseScale = SimplexNoiseScale.Value;
			Elements.Core.float3 _simplexNoiseOffset = SimplexNoiseOffset.Value;
			Elements.Core.float2 _minSize = MinSize.Value;
			Elements.Core.float2 _maxSize = MaxSize.Value;
			bool _uniformSize = UniformSize.Value;
			float _minRot = MinRotation.Value * (MathF.PI / 180f);
			float _maxRot = MaxRotation.Value * (MathF.PI / 180f);
			float _intensityClip = TextureIntensityClip.Value;
			float _alphaClip = TextureAlphaClip.Value;
			int _maxClipAttempts = MaxClipAttempts.Value;
			AtlasInfo _atlas = Atlas.Target;
			Bitmap2D _tex2D = null;
			Bitmap3D _tex3D = null;
			Asset _lockedTexture = null;
			Bitmap2D _heightmap = null;
			Asset _lockedHeightmap = null;
			float _heightExp = HeightmapExp.Value;
			Texture2D heightMapTex = HeightScaleSource.Asset;
			await default(ToBackground);
			if (heightMapTex != null)
			{
				await heightMapTex.RequestReadLock(this).ConfigureAwait(continueOnCapturedContext: false);
				_heightmap = await heightMapTex.GetOriginalTextureData().ConfigureAwait(continueOnCapturedContext: false);
				_lockedHeightmap = heightMapTex;
			}
			ITexture asset = TextureColorSource.Asset;
			if (!(asset is Texture2D texture2D))
			{
				if (asset is Texture3D texture3D)
				{
					await texture3D.RequestReadLock(this);
					_tex3D = texture3D.Data;
					_lockedTexture = texture3D;
				}
			}
			else if (_lockedHeightmap == texture2D)
			{
				_tex2D = _heightmap;
			}
			else
			{
				await texture2D.RequestReadLock(this).ConfigureAwait(continueOnCapturedContext: false);
				_tex2D = await texture2D.GetOriginalTextureData().ConfigureAwait(continueOnCapturedContext: false);
				_lockedTexture = texture2D;
			}
			meshx.SetVertexCount(_points);
			meshx.HasColors = true;
			meshx.HasNormals = true;
			meshx.HasUV0s = true;
			meshx.HasUV1s = true;
			RandomXGenerator randomXGenerator = new RandomXGenerator(_seed);
			for (int i = 0; i < _points; i++)
			{
				Elements.Core.colorX a = Elements.Core.colorX.White;
				int num = _maxClipAttempts;
				bool flag;
				Elements.Core.float3 a2;
				do
				{
					a2 = _distribution switch
					{
						DistributionType.Cube => randomXGenerator.InsideUnitCube, 
						DistributionType.CubeShell => randomXGenerator.OnUnitCube, 
						DistributionType.Sphere => randomXGenerator.InsideUnitSphere, 
						DistributionType.SphereShell => randomXGenerator.OnUnitSphere, 
						DistributionType.Ring => randomXGenerator.OnUnitCircle, 
						DistributionType.Circle => randomXGenerator.InsideUnitCircle, 
						DistributionType.Cluster => randomXGenerator.OnUnitSphere * MathX.Pow(randomXGenerator.Value, _rangeExp), 
						_ => Elements.Core.float3.Zero, 
					} + randomXGenerator.InsideUnitSphere * _jitterRange;
					if (_tex2D != null || _tex3D != null)
					{
						a = ((_tex2D == null) ? new Elements.Core.colorX(_tex3D.SampleUVW(a2.xyz + 0.5f), _tex3D.Profile) : new Elements.Core.colorX(_tex2D.SampleUV(a2.xy + 0.5f), _tex2D.Profile));
						flag = a.a > _alphaClip && MathX.AvgComponent(a.rgb) > _intensityClip;
					}
					else
					{
						flag = true;
					}
				}
				while (!flag && --num > 0);
				if (_heightmap != null)
				{
					float x = MathX.AvgComponent(_heightmap.SampleUV(a2.xy + 0.5f).rgb);
					a2 = new Elements.Core.float3(a2.xy, a2.z * MathX.Pow(x, _heightExp));
				}
				a2 *= _scale;
				switch (_colors)
				{
				case ColorMode.SolidColor:
					a *= _color0;
					break;
				case ColorMode.PerParticle:
					a *= MathX.Lerp(in _color0, in _color1, FilterColorLerp(randomXGenerator.Value, _colorLerpScale, _colorGap));
					break;
				case ColorMode.SimplexNoise:
					a *= MathX.Lerp(in _color0, in _color1, FilterColorLerp((MathX.SimplexNoise3D((a2 + _simplexNoiseOffset) * _simplexNoiseScale) + 1f) * 0.5f, _colorLerpScale, _colorGap));
					break;
				}
				meshx.RawPositions[i] = a2;
				meshx.RawColors[i] = a.ToProfile(meshx.Profile);
			}
			_lockedTexture?.ReleaseReadLock(this);
			_lockedHeightmap?.ReleaseReadLock(this);
			for (int j = 0; j < _points; j++)
			{
				Elements.Core.float2 xy = (_uniformSize ? MathX.Lerp(in _minSize, in _maxSize, randomXGenerator.Value) : randomXGenerator.Range(in _minSize, in _maxSize));
				float z = randomXGenerator.Range(_minRot, _maxRot);
				meshx.RawNormals[j] = new Elements.Core.float3(in xy, z);
				BoundingBox2D boundingBox2D = _atlas?.GetFrame(randomXGenerator.Range(_atlas.Frames)) ?? new BoundingBox2D(Elements.Core.float2.Zero, Elements.Core.float2.One);
				meshx.RawUV0s[j] = boundingBox2D.Center;
				meshx.RawUV1s[j] = boundingBox2D.Size;
			}
			meshx.TryGetSubmesh<Elements.Assets.PointSubmesh>().SetCountAndSequence(_points);
		}

		private static float FilterColorLerp(float value, float scale, float gap)
		{
			return MathX.Gap01(MathX.ScaleLerp01(value, scale), gap);
		}

		protected override void OnLoading(DataTreeNode node, LoadControl control)
		{
			base.OnLoading(node, control);
			if (control.GetTypeVersion(GetType()) == 0)
			{
				DataTreeNode dataTreeNode = (((DataTreeDictionary)node).TryGetNode("Range") as DataTreeDictionary)?.TryGetNode("Data");
				if (dataTreeNode != null)
				{
					float num = dataTreeNode.LoadFloat();
					Scale.Value = num * Elements.Core.float3.One;
				}
			}
		}

