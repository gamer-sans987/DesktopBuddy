	public static class FieldExtractor
	{
		public static List<FieldAccessor> ExtractFields(Type type)
		{
			List<FieldAccessor> list = new List<FieldAccessor>();
			switch (type.Name)
			{
			case "Boolean":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.BooleanParser(value, out var parsed);
					return parsed;
				}, null, typeof(bool)));
				break;
			case "SByte":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.SByteParser(value, out var parsed);
					return parsed;
				}, null, typeof(sbyte)));
				break;
			case "Int16":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.Int16Parser(value, out var parsed);
					return parsed;
				}, null, typeof(short)));
				break;
			case "Int32":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.Int32Parser(value, out var parsed);
					return parsed;
				}, null, typeof(int)));
				break;
			case "Int64":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.Int64Parser(value, out var parsed);
					return parsed;
				}, null, typeof(long)));
				break;
			case "Byte":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.ByteParser(value, out var parsed);
					return parsed;
				}, null, typeof(byte)));
				break;
			case "UInt16":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.UInt16Parser(value, out var parsed);
					return parsed;
				}, null, typeof(ushort)));
				break;
			case "UInt32":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.UInt32Parser(value, out var parsed);
					return parsed;
				}, null, typeof(uint)));
				break;
			case "UInt64":
				list.Add(new StringFieldAccessor((object target) => target.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.UInt64Parser(value, out var parsed);
					return parsed;
				}, null, typeof(ulong)));
				break;
			case "Single":
				list.Add(new StringFieldAccessor((object target) => ((float)target).ToString(CultureInfo.InvariantCulture), delegate(string value, object target)
				{
					PrimitiveTryParsers.SingleParser(value, out var parsed);
					return parsed;
				}, null, typeof(float)));
				break;
			case "Double":
				list.Add(new StringFieldAccessor((object target) => ((double)target).ToString(CultureInfo.InvariantCulture), delegate(string value, object target)
				{
					PrimitiveTryParsers.DoubleParser(value, out var parsed);
					return parsed;
				}, null, typeof(double)));
				break;
			case "floatQ":
				list.Add(new StringFieldAccessor((object target) => ((Elements.Core.floatQ)target).EulerAngles.x.ToString("F3"), delegate(string value, object target)
				{
					if (float.TryParse(value, out var result))
					{
						Elements.Core.float3 eulerAngles = ((Elements.Core.floatQ)target).EulerAngles;
						return Elements.Core.floatQ.Euler(result, eulerAngles.y, eulerAngles.z);
					}
					return (object)null;
				}, "x", typeof(float)));
				list.Add(new StringFieldAccessor((object target) => ((Elements.Core.floatQ)target).EulerAngles.y.ToString("F3"), delegate(string value, object target)
				{
					if (float.TryParse(value, out var result))
					{
						Elements.Core.float3 eulerAngles = ((Elements.Core.floatQ)target).EulerAngles;
						return Elements.Core.floatQ.Euler(eulerAngles.x, result, eulerAngles.z);
					}
					return (object)null;
				}, "y", typeof(float)));
				list.Add(new StringFieldAccessor((object target) => ((Elements.Core.floatQ)target).EulerAngles.z.ToString("F3"), delegate(string value, object target)
				{
					if (float.TryParse(value, out var result))
					{
						Elements.Core.float3 eulerAngles = ((Elements.Core.floatQ)target).EulerAngles;
						return Elements.Core.floatQ.Euler(eulerAngles.x, eulerAngles.y, result);
					}
					return (object)null;
				}, "z", typeof(float)));
				break;
			case "color":
				list.Add(new ColorFieldAccessor((object target) => (Elements.Core.color)target, (Elements.Core.color value, object target) => value));
				break;
			case "String":
				list.Add(new StringFieldAccessor((object target) => (string)target, (string value, object target) => value, null, typeof(string)));
				break;
			case "Uri":
				list.Add(new StringFieldAccessor((object target) => target?.ToString(), delegate(string value, object target)
				{
					PrimitiveTryParsers.UriParser(value, out var parsed);
					return parsed;
				}, null, typeof(Uri), 0, continuous: false));
				break;
			case "Type":
				list.Add(new StringFieldAccessor((object target) => target?.ToString(), (string value, object target) => value, null, typeof(Type), 0, continuous: false));
				break;
			default:
			{
				Stack<FieldInfo> info = new Stack<FieldInfo>();
				ProcessType(type, info, list);
				break;
			}
			}
			return list;
		}

		private static void GenerateAccessors(Type type, Stack<FieldInfo> hierarchy, List<FieldAccessor> accessors)
		{
		}

		private static void ProcessType(Type type, Stack<FieldInfo> info, List<FieldAccessor> accessors)
		{
			FieldInfo[] fields = type.GetFields(BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
			foreach (FieldInfo f in fields)
			{
				if (f.FieldType.IsPrimitive || f.FieldType == typeof(string) || f.FieldType == typeof(Uri))
				{
					FieldInfo field = f;
					List<FieldInfo> stack = new List<FieldInfo>(info);
					stack.Reverse();
					Func<object, string> convertor = GetPrimitiveToStringConverter(f.FieldType);
					PrimitiveTryParsers.TryParser parser = PrimitiveTryParsers.GetParser(f.FieldType.Name);
					accessors.Add(new StringFieldAccessor(delegate(object target)
					{
						for (int j = 0; j < stack.Count; j++)
						{
							target = stack[j].GetValue(target);
						}
						return convertor(field.GetValue(target));
					}, delegate(string value, object target)
					{
						if (!parser(value, out var parsed))
						{
							return (object)null;
						}
						Stack<object> stack2 = new Stack<object>();
						for (int j = 0; j < stack.Count; j++)
						{
							stack2.Push(target);
							target = stack[j].GetValue(target);
						}
						f.SetValue(target, parsed);
						for (int num = stack.Count - 1; num >= 0; num--)
						{
							object obj = stack2.Pop();
							stack[num].SetValue(obj, target);
							target = obj;
						}
						return target;
					}, f.Name, f.FieldType, stack.Count, f.FieldType != typeof(Uri)));
				}
				else
				{
					info.Push(f);
					ProcessType(f.FieldType, info, accessors);
					info.Pop();
				}
			}
		}

		private static Func<object, string> GetPrimitiveToStringConverter(Type primitiveType)
		{
			return primitiveType.Name switch
			{
				"Boolean" => (object o) => ((bool)o).ToString(CultureInfo.InvariantCulture), 
				"Single" => (object o) => ((float)o).ToString(CultureInfo.InvariantCulture), 
				"Double" => (object o) => ((double)o).ToString(CultureInfo.InvariantCulture), 
				"Decimal" => (object o) => ((decimal)o).ToString(CultureInfo.InvariantCulture), 
				_ => (object o) => o?.ToString(), 
			};
		}
	}
