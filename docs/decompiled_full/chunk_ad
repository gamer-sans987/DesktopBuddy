	{
		public static void DisplayNotice(this World world, LocaleString heading, LocaleString text, Uri icon = null, Elements.Core.color? color = null)
		{
			world.Coroutines.StartTask(async delegate
			{
				await default(ToWorld);
				await default(NextUpdate);
				Slot root = world.LocalUserSpace.AddSlot("Notice");
				root.PersistentSelf = false;
				root.AttachComponent<UserInterfacePositioner>().TargetUser.Target = world.LocalUser;
				Slot slot = root.AddSlot("Display");
				slot.LocalPosition = Elements.Core.float3.Forward * 1.5f;
				NoticeDisplayInterface obj = await slot.SpawnEntity(FavoriteEntity.NoticeDisplay, delegate(Slot s)
				{
					TextDisplayInterface textDisplayInterface = UniversalImporter.GenerateDefaultTextDisplay(s);
					NoticeDisplayInterface noticeDisplayInterface = textDisplayInterface.Slot.AttachComponent<NoticeDisplayInterface>();
					noticeDisplayInterface.Heading.Target = textDisplayInterface.Heading.Target;
					noticeDisplayInterface.Text.Target = textDisplayInterface.Text.Target;
					textDisplayInterface.Destroy();
					return noticeDisplayInterface;
				});
				obj.InitializeEntity(heading.content);
				obj.Slot.DestroyWhenDestroyed(root);
				obj.Set(heading, text, icon, color);
			});
		}
	}
