	public class DevModeController : Component
	{
		private const string KEY = "DevModeController";

		public readonly Sync<bool> DevModeEnabled;

		private bool _lastDevModeEnabled;

		public bool IsController => base.World.KeyOwner("DevModeController") == this;

		protected override void OnAttach()
		{
			base.World.RequestKey(this, "DevModeController", 0, onlyFree: true);
		}

		protected override void OnChanges()
		{
			if (!base.World.IsAuthority)
			{
				return;
			}
			if (IsController)
			{
				if (_lastDevModeEnabled == DevModeEnabled.Value)
				{
					return;
				}
				_lastDevModeEnabled = DevModeEnabled.Value;
				if (DevModeEnabled.Value)
				{
					base.World.ComponentAdded += OnComponentAdded;
					base.World.RootSlot.GetComponentsInChildren((IDevModeReceiver c) => c.Slot.ActiveUserRoot == null).ForEach(delegate(IDevModeReceiver c)
					{
						c.OnDevModeEnabled();
					});
					base.World.RootSlot.GetComponentsInChildren((Component c) => c.GizmoType != null && c.Slot.ActiveUserRoot == null && GizmoHelper.ShouldSpawnOnDevModeEnabled(c.GizmoType)).ForEach(delegate(Component c)
					{
						c.GetGizmo();
					});
				}
				else
				{
					base.World.ComponentAdded -= OnComponentAdded;
					base.World.RootSlot.GetComponentsInChildren<IDevModeReceiver>().ForEach(delegate(IDevModeReceiver c)
					{
						c.OnDevModeDisabled();
					});
					base.World.RootSlot.GetComponentsInChildren<SlotGizmo>().ForEach(delegate(SlotGizmo g)
					{
						g.Slot.Destroy();
					});
					base.World.RootSlot.GetComponentsInChildren((Component c) => c.GizmoType != null && GizmoHelper.ShouldSpawnOnDevModeEnabled(c.GizmoType)).ForEach(delegate(Component c)
					{
						c.TryGetGizmo()?.Slot.Destroy();
					});
				}
			}
			else
			{
				Destroy();
			}
		}

		private void OnComponentAdded(Slot slot, Component component)
		{
			if (!DevModeEnabled.Value || component.Slot.ActiveUserRoot != null)
			{
				return;
			}
			IDevModeReceiver devModeReceiver = component as IDevModeReceiver;
			devModeReceiver?.OnDevModeEnabled();
			bool spawnGizmo = component.GizmoType != null && GizmoHelper.ShouldSpawnOnDevModeEnabled(component.GizmoType);
			if (!spawnGizmo && devModeReceiver == null)
			{
				return;
			}
			RunSynchronously(delegate
			{
				devModeReceiver?.OnDevModeEnabled();
				if (spawnGizmo)
				{
					component.GetGizmo();
				}
			});
		}

		protected override void OnDestroy()
		{
			base.OnDestroy();
			if (_lastDevModeEnabled)
			{
				base.World.ComponentAdded -= OnComponentAdded;
				_lastDevModeEnabled = false;
			}
		}

		public static bool IsDevModeEnabled(World world)
		{
			return (world.KeyOwner("DevModeController") as DevModeController)?.DevModeEnabled.Value ?? false;
		}

		public static void EnableDevMode(World world)
		{
			GetDevModeController(world).DevModeEnabled.Value = true;
		}

		public static void DisableDevMode(World world)
		{
			GetDevModeController(world).DevModeEnabled.Value = false;
		}

		public static void ToggleDevMode(World world)
		{
			DevModeController devModeController = GetDevModeController(world);
			devModeController.DevModeEnabled.Value = !devModeController.DevModeEnabled.Value;
		}

		public static DevModeController GetDevModeController(World world)
		{
			if (world.KeyOwner("DevModeController") is DevModeController result)
			{
				return result;
			}
			return world.RootSlot.FindChildOrAdd("DevMode").AttachComponent<DevModeController>();
		}

