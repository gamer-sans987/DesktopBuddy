	public static class DynamicVariableHelper
	{
		public static DynamicVariableWriteResult WriteDynamicVariable<T>(this Slot slot, string path, T value)
		{
			ParsePath(path, out string spaceName, out string variableName);
			if (string.IsNullOrEmpty(variableName))
			{
				return DynamicVariableWriteResult.Failed;
			}
			return slot.FindSpace(spaceName)?.TryWriteValue(variableName, value) ?? DynamicVariableWriteResult.NotFound;
		}

		public static bool IsValidName(string name)
		{
			if (string.IsNullOrWhiteSpace(name))
			{
				return true;
			}
			foreach (char c in name)
			{
				switch (c)
				{
				case ' ':
				case '-':
				case '.':
				case '_':
					continue;
				}
				if (char.IsSymbol(c) || char.IsPunctuation(c) || char.IsWhiteSpace(c))
				{
					return false;
				}
			}
			return true;
		}

		public static void ParsePath(string path, out string spaceName, out string variableName)
		{
			if (string.IsNullOrWhiteSpace(path))
			{
				spaceName = null;
				variableName = null;
				return;
			}
			int num = path.IndexOf('/');
			if (num < 0)
			{
				spaceName = null;
				variableName = ProcessName(path);
			}
			else
			{
				spaceName = ProcessName(path.Substring(0, num));
				variableName = ProcessName(path.Substring(num + 1));
			}
		}

		public static string ProcessName(string name)
		{
			if (!IsValidName(name))
			{
				return null;
			}
			return name?.Trim();
		}

		public static DynamicVariableSpace FindSpace(this Slot slot, string spaceName)
		{
			if (string.IsNullOrWhiteSpace(spaceName))
			{
				return slot.GetComponentInParents((DynamicVariableSpace s) => !s.OnlyDirectBinding.Value);
			}
			return slot.GetComponentInParents((DynamicVariableSpace s) => s.CurrentName == spaceName);
		}

		public static bool CreateVariable<T>(this Slot slot, string name, T value, bool persistent = true)
		{
			if (DynamicValueVariable<T>.IsValidGenericType)
			{
				DynamicValueVariable<T> dynamicValueVariable = slot.AttachComponent<DynamicValueVariable<T>>();
				dynamicValueVariable.VariableName.Value = name;
				dynamicValueVariable.Value.Value = value;
				dynamicValueVariable.Persistent = persistent;
				dynamicValueVariable.UpdateLinking();
				return true;
			}
			if (typeof(IWorldElement).IsAssignableFrom(typeof(T)))
			{
				typeof(DynamicVariableHelper).GetGenericMethod("CreateReferenceVariable", BindingFlags.Static | BindingFlags.Public, typeof(T)).Invoke(null, new object[4] { slot, name, value, persistent });
				return true;
			}
			return false;
		}

		public static DynamicReferenceVariable<T> CreateReferenceVariable<T>(this Slot slot, string name, T value, bool persistent = true) where T : class, IWorldElement
		{
			DynamicReferenceVariable<T> dynamicReferenceVariable = slot.AttachComponent<DynamicReferenceVariable<T>>();
			dynamicReferenceVariable.VariableName.Value = name;
			dynamicReferenceVariable.Reference.Target = value;
			dynamicReferenceVariable.Persistent = persistent;
			return dynamicReferenceVariable;
		}
