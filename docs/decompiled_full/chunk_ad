	public class MazeWallData
	{
		[Flags]
		public enum Wall : byte
		{
			Left = 1,
			Top = 2,
			Right = 4,
			Bottom = 8,
			Visited = 0x10
		}

		public readonly Elements.Core.int2 Size;

		public readonly Wall[,] Cells;

		public MazeWallData(Elements.Core.int2 size)
		{
			Size = size;
			Cells = new Wall[size.x, size.y];
			for (int i = 0; i < size.y; i++)
			{
				for (int j = 0; j < size.x; j++)
				{
					Cells[j, i] = Wall.Left | Wall.Top | Wall.Right | Wall.Bottom;
				}
			}
		}

		public bool HasWall(int x, int y, Wall wall)
		{
			return (Cells[x, y] & wall) != 0;
		}

		public void RemoveWall(int x, int y, Wall wall)
		{
			Cells[x, y] &= (Wall)(byte)(~(int)wall);
		}

		public void MarkVisited(int x, int y)
		{
			Cells[x, y] |= Wall.Visited;
		}

		public bool IsVisited(int x, int y)
		{
			return (Cells[x, y] & Wall.Visited) != 0;
		}

		public void RemoveWallBetween(in Elements.Core.int2 a, in Elements.Core.int2 b)
		{
			if (a.x != b.x)
			{
				if (b.x > a.x)
				{
					RemoveWall(a.x, a.y, Wall.Right);
					RemoveWall(b.x, b.y, Wall.Left);
				}
				else
				{
					RemoveWall(a.x, a.y, Wall.Left);
					RemoveWall(b.x, b.y, Wall.Right);
				}
			}
			else if (b.y > a.y)
			{
				RemoveWall(a.x, a.y, Wall.Bottom);
				RemoveWall(b.x, b.y, Wall.Top);
			}
			else
			{
				RemoveWall(a.x, a.y, Wall.Top);
				RemoveWall(b.x, b.y, Wall.Bottom);
			}
		}

		public void GetUnvisitedNeighbors(int x, int y, List<Elements.Core.int2> neighbors)
		{
			AddUnvisitedNeighbor(x - 1, y, neighbors);
			AddUnvisitedNeighbor(x + 1, y, neighbors);
			AddUnvisitedNeighbor(x, y + 1, neighbors);
			AddUnvisitedNeighbor(x, y - 1, neighbors);
		}

		private void AddUnvisitedNeighbor(int x, int y, List<Elements.Core.int2> neighbors)
		{
			if (y >= 0 && y < Size.y && x >= 0 && x < Size.x && !IsVisited(x, y))
			{
				neighbors.Add(new Elements.Core.int2(x, y));
			}
		}
	}
