	[Category(new string[] { "Input/Controls" })]
	public class TrackedHand : Component
	{
		private const float CONTROLLER_DISTANCE_THRESHOLD = 0.15f;

		private const float GRAB_RADIUS = 0.02f;

		public readonly SyncRef<User> User;

		public readonly Sync<Chirality> HandChirality;

		protected readonly SyncRef<Grabber> _grabber;

		private bool? _lastTracking;

		private bool _lastGrab;

		private List<IGrabbable> grabbables = new List<IGrabbable>();

		private List<ICollider> colliders = new List<ICollider>();

		private List<IGrabbable> grabbedObjects = new List<IGrabbable>();

		private UserInfo _cachedUserInfo;

		protected override void OnStart()
		{
			_grabber.Target = base.Slot.GetComponentOrAttach<Grabber>();
			_grabber.Target.AutoUpdateUser.Target = base.Slot.ActiveUserRoot.ActiveUser;
		}

		protected override void OnCommonUpdate()
		{
			if (User.Target != base.World.LocalUser || base.World.Focus == FrooxEngine.World.WorldFocus.Background)
			{
				return;
			}
			List<Hand> list = Pool.BorrowList<Hand>();
			base.InputInterface.GetDevices(list);
			Hand hand = null;
			foreach (Hand item in list)
			{
				if (item.Chirality == HandChirality.Value && (hand == null || item.Wrist.Priority > hand.Wrist.Priority))
				{
					hand = item;
				}
			}
			if (hand == null)
			{
				return;
			}
			if (hand.IsTracking != _lastTracking)
			{
				if (!hand.IsTracking)
				{
					GrabRelease();
				}
				_lastTracking = hand.IsTracking;
			}
			bool flag = false;
			BodyNode node = ((HandChirality.Value == Chirality.Left) ? BodyNode.LeftController : BodyNode.RightController);
			ITrackedDevice bodyNode = base.InputInterface.GetBodyNode(node);
			if (bodyNode != null && MathX.Distance(bodyNode.Position, hand.Wrist.Position) < 0.15f)
			{
				flag = true;
			}
			if (hand.PinchStrength > 0.75f && hand.Confidence > 0.5f && !_lastGrab)
			{
				if (!flag)
				{
					Grab(hand);
				}
				_lastGrab = true;
			}
			if (hand.PinchStrength < 0.85f && _lastGrab)
			{
				GrabRelease();
				_lastGrab = false;
			}
		}

		private void Grab(Hand hand)
		{
			if (!TryGrab(hand.Index.Tip) && !TryGrab(hand.Index.Distal))
			{
				TryGrab(hand.Palm);
			}
		}

		private bool TryGrab(ITrackedDevice device)
		{
			if (!device.IsTracking)
			{
				return false;
			}
			return _grabber.Target.Grab(base.Slot.LocalPointToGlobal(device.Position), base.Slot.LocalScaleToGlobal(0.02f));
		}

		private void GrabRelease()
		{
			_grabber.Target?.Release();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			User = new SyncRef<User>();
			HandChirality = new Sync<Chirality>();
			_grabber = new SyncRef<Grabber>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => User, 
				4 => HandChirality, 
				5 => _grabber, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static TrackedHand __New()
		{
			return new TrackedHand();
		}
	}
