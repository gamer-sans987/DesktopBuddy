	public abstract class MemberEditor : Component
	{
		public static string NULL_STRING = "<i><alpha=#88>null</alpha></i>";

		public readonly Sync<bool> Continuous;

		protected readonly Sync<string> _path;

		protected readonly RelayRef<IField> _target;

		private Type lastType;

		private string lastPath;

		private StructMemberAccessor accessor;

		public static Elements.Core.colorX DRIVE_COLOR => MathX.Lerp(RadiantUI_Constants.BUTTON_COLOR, Elements.Core.colorX.Magenta, 0.3f);

		public static Elements.Core.colorX LINKED_COLOR => MathX.Lerp(RadiantUI_Constants.BUTTON_COLOR, Elements.Core.colorX.Cyan, 0.3f);

		public static Elements.Core.colorX NORMAL_COLOR => RadiantUI_Constants.BUTTON_COLOR;

		public static Elements.Core.colorX BROKEN_COLOR => Elements.Core.colorX.Gray;

		protected Elements.Core.colorX FieldColor => GetFieldColor(NORMAL_COLOR);

		public StructMemberAccessor Accessor
		{
			get
			{
				EnsureAccessor();
				return accessor;
			}
		}

		protected Elements.Core.colorX GetFieldColor(Elements.Core.colorX? normalColor = null)
		{
			return GetFieldColor(_target.Target as ISyncElement, normalColor);
		}

		public static Elements.Core.colorX GetFieldColor(ISyncElement worker, Elements.Core.colorX? normalColor = null)
		{
			if (worker == null)
			{
				return BROKEN_COLOR;
			}
			if (worker.IsDriven)
			{
				return DRIVE_COLOR;
			}
			if (worker.IsLinked)
			{
				return LINKED_COLOR;
			}
			return normalColor ?? NORMAL_COLOR;
		}

		public void Setup(IField target, string path, UIBuilder ui)
		{
			_target.Target = target;
			_path.Value = path;
			BuildUI(ui);
		}

		protected abstract void BuildUI(UIBuilder ui);

		public object GetMemberValue()
		{
			IField target = _target.Target;
			if (target == null)
			{
				return null;
			}
			EnsureAccessor();
			return accessor?.Get(target.BoxedValue);
		}

		public void SetMemberValue(object value)
		{
			IField target = _target.Target;
			if (target == null || (target is ConflictingSyncElement { DirectAccessOnly: not false } && !base.LocalUser.IsDirectlyInteracting()))
			{
				MarkChangeDirty();
				return;
			}
			EnsureAccessor();
			target.CreateUndoPoint();
			target.BoxedValue = accessor.Set(target.BoxedValue, value);
		}

		private void EnsureAccessor()
		{
			IField target = _target.Target;
			if (!(_path.Value != lastPath) && !(target?.ValueType != lastType))
			{
				return;
			}
			lastPath = _path.Value;
			lastType = target?.ValueType;
			if (lastType == null)
			{
				accessor = null;
				return;
			}
			try
			{
				accessor = new StructMemberAccessor(lastType, lastPath);
			}
			catch (StructFieldMissingException ex)
			{
				UniLog.Warning($"Field {ex.FieldName} is missing on type {ex.StructType}. Root Type: {ex.RootType}");
			}
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			Continuous = new Sync<bool>();
			_path = new Sync<string>();
			_target = new RelayRef<IField>();
		}
	}
