		{
			PreviousPage();
		}

		[SyncMethod(typeof(Action), new string[] { })]
		public void NextPage()
		{
			SkipItems.Value += ItemsPerPage.Value;
			RunInUpdateScope(Update);
		}

		[SyncMethod(typeof(Action), new string[] { })]
		public void PreviousPage()
		{
			SkipItems.Value -= ItemsPerPage.Value;
			RunInUpdateScope(Update);
		}

