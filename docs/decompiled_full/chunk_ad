	public class ScaledFingerSegment : Component
	{
		protected readonly FieldDrive<Elements.Core.float3> _scale;

		protected readonly FieldDrive<Elements.Core.float3> _offset;

		protected readonly SyncRef<Slot> _nextJoint;

		protected readonly Sync<BodyNode> _bodyNode;

		public readonly Sync<float> Width;

