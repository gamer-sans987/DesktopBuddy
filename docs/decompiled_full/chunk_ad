			InteractionElement.ColorDriver colorDriver = nameButton.ColorDrivers.Add();
			colorDriver.ColorDrive.Target = nameText.Color;
			colorDriver.NormalColor.Value = RadiantUI_Constants.TEXT_COLOR;
			colorDriver.HighlightColor.Value = RadiantUI_Constants.LABEL_COLOR;
			colorDriver.PressColor.Value = RadiantUI_Constants.HEADING_COLOR;
			ui.Style.FlexibleWidth = -1f;
			ui.NestOut();
			ui.Style.MinHeight = -1f;
		}

		private void RebuildUser()
		{
			base.Slot.DestroyChildren();
			UIBuilder uIBuilder = new UIBuilder(base.Slot);
			RadiantUI_Constants.SetupEditorStyle(uIBuilder);
			GenerateElement(uIBuilder, out Expander expander, out TextExpandIndicator expanderIndicator, out Button expandButton, out Text nameText, out Button nameButton);
			nameButton.SetupAction(OpenUser, 0.35f);
			_expander.Target = expander;
			_expanderIndicator.Target = expanderIndicator;
			_userNameText.Target = nameText;
			UpdateText();
			HorizontalLayout horizontalLayout = uIBuilder.HorizontalLayout(4f);
			uIBuilder.Style.MinWidth = 32f;
			uIBuilder.Empty("Spacer");
			uIBuilder.Style.FlexibleWidth = 100f;
			_childContainer.Target = uIBuilder.VerticalLayout(4f).Slot;
			expander.SectionRoot.Target = horizontalLayout.Slot;
			expanderIndicator.Text.Target = expandButton.Slot.GetComponentInChildren<Text>().Content;
			expanderIndicator.SectionRoot.Target = horizontalLayout.Slot;
			expanderIndicator.ChildrenRoot.Target = _childContainer.Target;
			uIBuilder.Style.FlexibleWidth = -1f;
			GenerateElement(uIBuilder, out Expander expander2, out TextExpandIndicator expanderIndicator2, out Button expandButton2, out nameText, out nameButton);
			nameText.Content.Value = "Components";
			nameButton.SetupAction(OpenComponents, 0.35f);
			foreach (StreamGroup group in _setupUser.StreamGroupManager.Groups)
			{
				GenerateElement(uIBuilder, out expander2, out expanderIndicator2, out expandButton2, out nameText, out nameButton);
				nameText.Content.Value = $"Stream Group {group.GroupIndex}";
				nameButton.SetupAction(OpenStream, group.GroupIndex, 0.35f);
			}
		}

