		public void Pressed(IButton button, ButtonEventData eventData)
		{
			if (base.World != Userspace.UserspaceWorld || base.Engine.Cloud.Session.CurrentUserID == null)
			{
				return;
			}
			Grabber localUserGrabberWithItems = base.World.GetLocalUserGrabberWithItems(eventData.source.Slot);
			UniLog.Log("Profile Icon Set: Grabber = " + localUserGrabberWithItems);
			if (localUserGrabberWithItems == null)
			{
				return;
			}
			using IEnumerator<IGrabbable> enumerator = localUserGrabberWithItems.GrabbedObjects.GetEnumerator();
			if (!enumerator.MoveNext())
			{
				return;
			}
			IGrabbable current = enumerator.Current;
			StaticTexture2D tex2D = current.Slot.GetComponentInChildren<AssetProxy<Texture2D>>()?.AssetReference.Target as StaticTexture2D;
			if (tex2D == null)
			{
				tex2D = (from r in current.Slot.GetComponentsInChildren<ReferenceProxy>()
					select r.Reference.Target as StaticTexture2D).FirstOrDefault((StaticTexture2D r) => r != null);
			}
			if (tex2D?.URL.Value == null)
			{
				return;
			}
			RunInUpdateScope(delegate
			{
				IsUpdating.Value = true;
			});
			StartTask(async delegate
			{
				try
				{
					foreach (UserLoginManager globallyRegisteredComponent in base.World.GetGloballyRegisteredComponents<UserLoginManager>())
					{
						globallyRegisteredComponent.CurrentProfileIcon.Value = tex2D.URL.Value;
					}
					Uri value = await base.Engine.Cloud.Profile.SetNewUserIcon(tex2D.Asset, base.Engine);
					foreach (UserLoginManager globallyRegisteredComponent2 in base.World.GetGloballyRegisteredComponents<UserLoginManager>())
					{
						globallyRegisteredComponent2.CurrentProfileIcon.Value = value;
					}
				}
				catch (Exception ex)
				{
					UniLog.Error("Profile Icon Set: Exception setting icon:\n" + ex);
				}
				RunInUpdateScope(delegate
				{
					IsUpdating.Value = false;
				});
			});
