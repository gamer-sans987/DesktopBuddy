		protected override void OnChanges()
		{
			base.OnChanges();
			FileMetadata target = MetadataSource.Target;
			string path = target?.Filename.Value;
			string fileNameWithoutExtension = Path.GetFileNameWithoutExtension(path);
			string text = Path.GetExtension(path);
			bool flag = target?.IsProcessing.Value ?? false;
			if (text != null)
			{
				text = text.Replace(".", "").ToUpper();
			}
			if (TypeLabel.Target != null)
			{
				TypeLabel.Target.Text.Value = text ?? "---";
			}
			if (NameLabel.Target != null)
			{
				NameLabel.Target.Text.Value = fileNameWithoutExtension ?? "---";
			}
			AssetClass assetClass = AssetHelper.ClassifyExtension(text);
			if (assetClass == AssetClass.Unknown)
			{
				assetClass = AssetHelper.ClassifyMime(target?.MIME.Value);
			}
			Elements.Core.colorX classColor = AssetHelper.GetClassColor(assetClass);
			if (OutlineMaterial.Target != null)
			{
				OutlineMaterial.Target.AlbedoColor.Value = classColor;
				Sync<Elements.Core.colorX> emissiveColor = OutlineMaterial.Target.EmissiveColor;
				Sync<bool> sync = target?.IsProcessing;
				emissiveColor.Value = ((sync != null && (bool)sync) ? classColor.MulSaturation(0.6f).SetValue(2.5f) : Elements.Core.colorX.Black);
			}
			if (TypeMaterial.Target != null)
			{
				TypeMaterial.Target.AlbedoColor.Value = classColor;
			}
			if (!flag && _wasProcessing && FillMaterial.Target != null)
			{
				FillMaterial.Target.EmissiveColor.TweenFromTo(classColor.MulSaturation(0.6f).SetValue(2.5f), Elements.Core.colorX.Black, 1f);
			}
			_wasProcessing = flag;
		}

