		{
			return world.SampleSpatialVariablePartialDerivative(name, in point, orientation * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Right), orientation * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Up), orientation * ILSpyHelper_AsRefReadOnly(Elements.Core.float3.Forward), samplingDistance, mode, baseValue);
