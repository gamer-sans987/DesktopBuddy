	[Category(new string[] { "Assets/Utility" })]
	public class ClipboardImporter : Component
	{
		private ClipboardInputs _input;

		private bool CanImport
		{
			get
			{
				if (base.World.IsUserspace())
				{
					return false;
				}
				if (base.World.Focus == FrooxEngine.World.WorldFocus.Background)
				{
					return false;
				}
				if (!base.World.CanSpawnObjects())
				{
					return false;
				}
				return true;
			}
		}

		protected override void OnStart()
		{
			if (!base.World.IsUserspace())
			{
				base.InputInterface.FilesDropped += FilesDropped;
				_input = new ClipboardInputs();
				base.Input.RegisterInputGroup(_input, this, OnInputUpdate);
			}
		}

		private void OnInputUpdate()
		{
			if (!base.Engine.InputInterface.IsClipboardSupported || !CanImport)
			{
				return;
			}
			if (_input.Paste.Pressed)
			{
				List<string> list = new List<string>();
				if (base.InputInterface.Clipboard.ContainsImage)
				{
					StartTask(async delegate
					{
						await default(ToBackground);
						Bitmap2D image = await base.InputInterface.Clipboard.GetImage();
						await default(ToWorld);
						Slot slot = base.LocalUserSpace.AddSlot("ImageImporter");
						slot.PositionInFrontOfUser(Elements.Core.float3.Backward);
						ImageImportDialog imageImportDialog = slot.AttachComponent<ImageImportDialog>();
						imageImportDialog.Paths.Add(new ImportItem(image, $"{base.LocalUser.UserName} clipboard image {DateTime.Now}"));
						imageImportDialog.SetLocalUserAsImporting();
					});
				}
				else
				{
					if (base.InputInterface.Clipboard.ContainsFiles)
					{
						list = base.InputInterface.Clipboard.GetFiles().Result;
					}
					else if (base.InputInterface.Clipboard.ContainsText)
					{
						list.Add(base.InputInterface.Clipboard.GetText().Result);
					}
					if (list.Count > 0)
					{
						ImportData(list);
					}
				}
			}
			if ((bool)_input.Paste)
			{
				_input.BlockInputs();
			}
		}

		protected override void OnDispose()
		{
			if (!base.World.IsUserspace())
			{
				base.InputInterface.FilesDropped -= FilesDropped;
				base.OnDispose();
			}
		}

		private void FilesDropped(List<string> files, Elements.Core.float2 point)
		{
			RunSynchronously(delegate
			{
				ImportData(files);
			});
		}

		private void ImportData(List<string> import)
		{
			if (!CanImport)
			{
				return;
			}
			if ((base.InputInterface.IsKeyVirtualPressed(Key.Control) || base.InputInterface.IsKeyVirtualPressed(Key.V)) && (!base.InputInterface.VirtualPressSource(Key.Control).IsUserspace() || !base.InputInterface.VirtualPressSource(Key.V).IsUserspace()))
			{
				foreach (string item in import)
				{
					if (Path.IsPathRooted(item) && (File.Exists(item) || Directory.Exists(item)))
					{
						return;
					}
				}
			}
			Slot slot = base.World.AddSlot("Batch import");
			slot.PersistentSelf = false;
			slot.PositionInFrontOfUser(Elements.Core.float3.Backward);
			BatchFolderImporter.BatchImport(slot, import, base.InputInterface.GetKey(Key.LeftShift));
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

