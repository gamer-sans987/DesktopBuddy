		private static T AttachComponentWithGrabbable<T>(Slot s) where T : Component, new()
		{
			s.AttachComponent<Grabbable>().Scalable.Value = true;
			return s.AttachComponent<T>();
		}

		private static void GenerateMaterialCategory(CategoryNode<Type> node, string path)
		{
			foreach (CategoryNode<Type> subcategory in node.Subcategories)
			{
				GenerateMaterialCategory(subcategory, path + "\\" + subcategory.Name);
			}
			foreach (Type mat in node.Elements)
			{
				AddAction(path, BeautifyMaterialName(mat.Name), delegate(Slot s)
				{
					SpawnMaterial(s, mat);
				});
			}
		}

		private static string BeautifyMaterialName(string name)
		{
			return name.BeautifyName().Replace("Material", "").Trim();
		}

		public static void SpawnEmpty(Slot slot)
		{
			OpenInspector(slot);
		}

		public static void OpenInspector(Slot slot)
		{
			Slot slot2 = slot.LocalUserSpace.AddSlot("Inspector");
			SceneInspector sceneInspector = slot2.AttachComponent<SceneInspector>();
			sceneInspector.Root.Target = slot;
			sceneInspector.ComponentView.Target = slot;
			slot2.PositionInFrontOfUser(Elements.Core.float3.Backward);
			slot2.GlobalPosition += slot2.Right * 0.5f * slot.LocalUserRoot.GlobalScale;
		}

		public static void SpawnParticleSystem(Slot slot)
		{
			FrooxEngine.PhotonDust.ParticleSystemHelper.ParticleSystemComponents<UnlitMaterial> particleSystemComponents = slot.SetupParticleSystem<UnlitMaterial>(singleSlot: false, setupEmitter: true, setupRotation: true);
			particleSystemComponents.Material.BlendMode.Value = BlendMode.Alpha;
			particleSystemComponents.Material.Texture.Target = particleSystemComponents.Material.Slot.AttachTexture(OfficialAssets.Common.Particles.Basic);
			Slot slot2 = particleSystemComponents.System.OpenInspectorForTarget();
			slot2.GlobalPosition = slot.GlobalPosition;
			slot2.PointAtUserHead(Elements.Core.float3.Backward);
			slot2.GlobalPosition += slot2.Right * 0.5f;
		}

		private static async void SpawnEntityOrComponent<C>(Slot slot, string path) where C : Component, new()
		{
			await slot.StartTask(async delegate
			{
				if (await EntityHelper.LoadEntity<C>(slot, slot.Engine.Cloud.Platform.GetInventoryItemUri(path)) == null)
				{
					slot.AttachComponent<C>();
					slot.PositionInFrontOfUser(Elements.Core.float3.Backward);
				}
			});
		}

		private static void SpawnComponent<T>(Slot slot) where T : Component, new()
		{
			slot.AttachComponent<T>();
		}

