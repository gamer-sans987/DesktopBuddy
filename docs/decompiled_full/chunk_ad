	public class PointClusterMesh : ProceduralMesh
	{
		public enum DistributionType
		{
			Cube,
			CubeShell,
			Sphere,
			SphereShell,
			Ring,
			Circle,
			Cluster
		}

		public enum ColorMode
		{
			SolidColor,
			PerParticle,
			SimplexNoise
		}

		public readonly Sync<DistributionType> Distribution;

		public readonly Sync<ColorMode> Colors;

		public readonly AssetRef<ITexture> TextureColorSource;

		public readonly AssetRef<Texture2D> HeightScaleSource;

		public readonly Sync<float> TextureIntensityClip;

