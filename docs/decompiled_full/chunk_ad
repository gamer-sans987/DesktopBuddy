	[Category(new string[] { "Data/Spatial/Samplers" })]
	public class CloningReferenceSpatialVariableCollector<T> : CloningReferenceSpatialVariableCollector where T : Component
	{
		private struct CloneData
		{
			public readonly T clone;

			public readonly CloneMode mode;

			public readonly SpatialVariableBlendDriver blendDriver;

			public CloneData(T clone, CloneMode mode, SpatialVariableBlendDriver blendDriver)
			{
				this.clone = clone;
				this.mode = mode;
				this.blendDriver = blendDriver;
			}

			public void SetBlend(float blend)
			{
				if (blendDriver != null && !blendDriver.IsRemoved)
				{
					blendDriver.SetBlend(blend);
				}
			}

			public void Cleanup()
			{
				switch (mode)
				{
				case CloneMode.Component:
					clone.Destroy();
					blendDriver?.Destroy();
					break;
				case CloneMode.Slot:
					clone.Slot.Destroy();
					break;
				default:
					throw new InvalidOperationException("Invalid clone mode: " + mode);
				}
			}
		}

		public readonly DriveRef<ISyncRefList<T>> ReferenceList;

		private Dictionary<T, CloneData> cloneMap = new Dictionary<T, CloneData>();

		private Slot localComponentContainer;

		public static bool IsValidGenericType => !typeof(ISpatialVariable).IsAssignableFrom(typeof(T));

		protected override void OnCommonUpdate()
		{
			base.OnCommonUpdate();
			if (!ReferenceList.IsLinkValid)
			{
				return;
			}
			Slot slot = CloneParent.Target ?? base.Slot;
			List<SpatialVariableResult<T>> list = Pool.BorrowList<SpatialVariableResult<T>>();
			HashSet<T> hashSet = Pool.BorrowHashSet<T>();
			foreach (KeyValuePair<T, CloneData> item in cloneMap)
			{
				hashSet.Add(item.Key);
			}
			base.World.SampleSpatialVariables(VariableName, base.Slot.GlobalPosition, list);
			ISyncRefList<T> target = ReferenceList.Target;
			for (int i = 0; i < list.Count; i++)
			{
				SpatialVariableResult<T> spatialVariableResult = list[i];
				T original = spatialVariableResult.value;
				if (original == null)
				{
					continue;
				}
				if (!cloneMap.TryGetValue(original, out var value))
				{
					CloneMode value2 = Mode.Value;
					T clone;
					SpatialVariableBlendDriver blendDriver;
					if (value2 != CloneMode.Component)
					{
						if (value2 != CloneMode.Slot)
						{
							continue;
						}
						Slot slot2 = original.Slot.Duplicate(slot, keepGlobalTransform: false, new DuplicationSettings
						{
							ComponentFilter = (Component c) => !(c is ISpatialVariable)
						}, MakeClonesLocal.Value);
						clone = slot2.GetComponent<T>();
						blendDriver = slot2.GetComponent<SpatialVariableBlendDriver>();
					}
					else
					{
						SpatialVariableBlendDriver component = original.Slot.GetComponent(delegate(SpatialVariableBlendDriver d)
						{
							IField<float> target2 = d.BlendWeight.Target;
							return ((target2 != null) ? target2.FindNearestParent<T>() : null) == original;
						});
						Slot slot3;
						if (MakeClonesLocal.Value)
						{
							if (localComponentContainer == null)
							{
								localComponentContainer = slot.AddLocalSlot("ClonedComponents");
							}
							slot3 = localComponentContainer;
						}
						else
						{
							slot3 = slot;
						}
						if (component == null)
						{
							clone = slot3.DuplicateComponent(original);
							blendDriver = null;
						}
						else
						{
							List<Component> list2 = Pool.BorrowList<Component>();
							List<Component> list3 = Pool.BorrowList<Component>();
							list2.Add(original);
							list2.Add(component);
							slot3.DuplicateComponents(list2, breakExternalReferences: false, list3);
							clone = (T)list3[0];
							blendDriver = (SpatialVariableBlendDriver)list3[1];
							Pool.Return(ref list2);
							Pool.Return(ref list3);
						}
					}
					value = new CloneData(clone, Mode, blendDriver);
					cloneMap.Add(original, value);
				}
				else
				{
					hashSet.Remove(original);
				}
				value.SetBlend(spatialVariableResult.blendWeight);
				if (target.Count == i)
				{
					target.Add(value.clone);
				}
				else
				{
					target[i] = value.clone;
				}
			}
			while (target.Count > list.Count)
			{
				target.RemoveAt(target.Count - 1);
			}
			Pool.Return(ref list);
			foreach (T item2 in hashSet)
			{
				cloneMap[item2].Cleanup();
				cloneMap.Remove(item2);
			}
			Pool.Return(ref hashSet);
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			localComponentContainer?.Destroy();
			localComponentContainer = null;
			foreach (KeyValuePair<T, CloneData> item in cloneMap)
			{
				item.Value.Cleanup();
			}
			cloneMap = null;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			ReferenceList = new DriveRef<ISyncRefList<T>>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => CloneParent, 
				4 => MakeClonesLocal, 
				5 => VariableName, 
				6 => Mode, 
				7 => ReferenceList, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

		public static CloningReferenceSpatialVariableCollector<T> __New()
		{
			return new CloningReferenceSpatialVariableCollector<T>();
		}
	}
