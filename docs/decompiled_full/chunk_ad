		public static async Task ImportSplatAsync(string file, Slot targetSlot, Elements.Core.int3 scale, bool encodeAsSPZ, IProgressIndicator progress = null)
		{
			await default(ToBackground);
			GaussianCloud cloud = GaussianCloud.LoadFromPLY(file, progress?.Remap(0f, 0.5f));
			progress?.UpdateProgress(1f, "Importer.Splat.Progress.Importing".AsLocaleKey(), "Importer.Splat.Progress.EncodingData".AsLocaleKey());
			Uri uri = await targetSlot.Engine.LocalDB.SaveAssetAsync(cloud, encodeAsSPZ ? "spz" : "frsplt", progress.Remap(0.5f, 1f));
			await default(ToWorld);
			StaticGaussianSplat staticGaussianSplat = targetSlot.AttachComponent<StaticGaussianSplat>();
			staticGaussianSplat.URL.Value = uri;
			UniversalImporter.SpawnGaussianSplat(targetSlot, staticGaussianSplat, scale);
			progress?.ProgressDone("General.Done".AsLocaleKey());
		}
	}
