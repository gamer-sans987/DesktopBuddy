	public class Perspective360Panner : Component, IButtonHoverReceiver, IComponent, IComponentBase, IDestroyable, IWorker, IWorldElement, IUpdatable, IChangeable, IAudioUpdatable, IInitializable, ILinkable
	{
		public const float IDLE_FOV = 110f;

		public const float HOVER_FOV = 120f;

		public const float PANNING_VELOCITY = 45f;

		public const float VERTICAL_PAN_RANGE = 35f;

		public readonly Sync<float> IdleFOV;

		public readonly Sync<float> HoverFOV;

		public readonly Sync<float> FOVSpeed;

		public readonly Sync<float> HorizontalPanningAcceleration;

		public readonly Sync<float> HorizontalPanningSpeed;

		public readonly Sync<float> VerticalPanningSpeed;

		public readonly Sync<float> VerticalRange;

		private bool _panningAnimationRunning;

		private Elements.Core.float2? _lastHover;

		public readonly Sync<Elements.Core.float2> AngleOffset;

		public readonly Sync<Elements.Core.float2> FOV;

		protected override void OnAwake()
		{
			base.OnAwake();
			IdleFOV.Value = 110f;
			HoverFOV.Value = 120f;
			FOVSpeed.Value = 4f;
			HorizontalPanningAcceleration.Value = 8f;
			HorizontalPanningSpeed.Value = 45f;
			VerticalPanningSpeed.Value = 4f;
			VerticalRange.Value = 35f;
			AngleOffset.Value = Elements.Core.float2.Zero;
			FOV.Value = Elements.Core.float2.One * 110f;
		}

		private async Task UpdatePanning()
		{
			_panningAnimationRunning = true;
			float velocity = 0f;
			_ = Elements.Core.float2.Zero;
			float angleYintermediate = 0f;
			float intermediateFov = FOV.Value.x;
			_ = Elements.Core.float2.Zero;
			Elements.Core.float2 target;
			Elements.Core.float2 angle;
			float fov;
			do
			{
				target = _lastHover ?? Elements.Core.float2.Zero;
				velocity = MathX.Lerp(velocity, target.x * (float)HorizontalPanningSpeed, base.Time.Delta * (float)HorizontalPanningAcceleration);
				angle = AngleOffset.Value + new Elements.Core.float2(velocity * base.Time.Delta);
				angle = new Elements.Core.float2(angle.x, MathX.SmoothLerp(angle.y, target.y * (float)VerticalRange, ref angleYintermediate, base.Time.Delta * (float)VerticalPanningSpeed));
				AngleOffset.Value = angle;
				fov = FOV.Value.x;
				fov = MathX.SmoothLerp(fov, _lastHover.HasValue ? HoverFOV : IdleFOV, ref intermediateFov, base.Time.Delta * (float)FOVSpeed);
				FOV.Value = fov * Elements.Core.float2.One;
				_lastHover = null;
				await default(NextUpdate);
			}
			while (MathX.Abs(velocity) > 0.01f || target != Elements.Core.float2.Zero || MathX.Abs(angle.y) > 0.01f || MathX.Abs(fov - 110f) > 0.01f);
			_panningAnimationRunning = false;
		}

