		public static void SpawnFogVolume(Slot slot, Action<FogBoxVolumeMaterial> configure)
		{
			BoxMesh boxMesh = slot.AttachComponent<BoxMesh>();
			FogBoxVolumeMaterial fogBoxVolumeMaterial = slot.AttachComponent<FogBoxVolumeMaterial>();
			configure?.Invoke(fogBoxVolumeMaterial);
			slot.AttachMesh(boxMesh, fogBoxVolumeMaterial);
			boxMesh.CreateCollider();
			slot.AttachComponent<Grabbable>().Scalable.Value = true;
			boxMesh.GetGizmo(isExplicit: true);
			fogBoxVolumeMaterial.GetGizmo(isExplicit: true);
		}

