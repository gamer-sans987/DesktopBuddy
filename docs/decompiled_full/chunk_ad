	public static class ConfirmationHandlerHelper
	{
		public static bool Confirm(this IButton button, string confirmLabel, float time = 2f, Elements.Core.colorX? confirmColor = null)
		{
			bool attached;
			ConfirmationHandler componentOrAttach = button.Slot.GetComponentOrAttach<ConfirmationHandler>(out attached);
			if (!attached)
			{
				componentOrAttach.Destroy();
				return true;
			}
			Button button2 = button as Button;
			if (button2 != null)
			{
				componentOrAttach.OriginalColor.Value = button2.BaseColor.Value;
			}
			if (!(button.LabelTextField?.FindNearestParent<Component>() is LocaleStringDriver localeStringDriver))
			{
				componentOrAttach.OriginalLabel.Value = button.LabelText;
				componentOrAttach.Label.Target = button.LabelTextField;
				button.LabelText = confirmLabel;
			}
			else
			{
				componentOrAttach.OriginalLabel.Value = localeStringDriver.Format;
				componentOrAttach.Label.Target = localeStringDriver.Format;
				localeStringDriver.Format.Value = confirmLabel;
			}
			if (confirmColor.HasValue && button2 != null)
			{
				componentOrAttach.Color.Target = button2.BaseColor;
				button2.BaseColor.Value = confirmColor.Value;
			}
			componentOrAttach.RevertTime.CurrentTime = 0f - time;
			return false;
		}
