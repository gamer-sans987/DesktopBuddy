				rect = Elements.Core.IntRect.FromMinMax(new Elements.Core.int2(extentMin.x, @int.x), new Elements.Core.int2(extentMax.x, @int.y));
				componentOrAttach.SetFixedRect(rect, new Elements.Core.float2(0f, 1f));
			}
		}

