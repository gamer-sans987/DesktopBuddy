		public void RunImport()
		{
			Elements.Core.float3 b = Elements.Core.float3.Zero;
			float num = base.LocalUserRoot?.GlobalScale ?? 1f;
			foreach (ImportItem item in Paths)
			{
				Slot s = base.LocalUserSpace.AddSlot(item.itemName);
				s.GlobalPosition = base.Slot.GlobalPosition + b;
				s.GlobalRotation = base.Slot.GlobalRotation;
				s.GlobalScale = num * Elements.Core.float3.One;
				b += base.Slot.Right;
				UniversalImporter.UndoableImport(s, async () => await ImportAsync(s, item, _videoType, _stereoLayout, _depthPreset));
			}
			base.Slot.Destroy();
		}

		private static async Task<Elements.Core.Result> ImportAsync(Slot slot, ImportItem item, VideoType type, StereoLayout stereo, DepthPreset depth)
		{
			Uri uri = ((!(item.assetUri != null)) ? new Uri(item.filePath) : item.assetUri);
			_ = slot.Engine;
			VideoPlayerInterface videoInterface = await slot.SpawnEntity<VideoPlayerInterface, LegacyVideoPlayer>(FavoriteEntity.VideoPlayer);
			videoInterface.InitializeEntity(item.itemName);
			slot = videoInterface.Slot.GetObjectRoot();
			if (uri.Scheme.Contains("file"))
			{
				await default(ToBackground);
				uri = await slot.World.Engine.LocalDB.ImportLocalAssetAsync(item.filePath, LocalDB.ImportLocation.Original).ConfigureAwait(continueOnCapturedContext: false);
				await default(ToWorld);
			}
			videoInterface.SetSource(uri, uri.Scheme == "http" || uri.Scheme == "https" || uri.Scheme == slot.Cloud.Assets.DBScheme || uri.Scheme == "rtp" || uri.Scheme == "mms" || uri.Scheme == "rtsp" || uri.Scheme == "local");
			videoInterface.SetStereo(stereo);
			switch (type)
			{
			case VideoType.Sphere360:
				if (!videoInterface.SetPanoramic(360f, 180f, PanoramicProjection.Equirectangular))
				{
					Slot slot5 = slot.AddSlot("360 Projection Sphere");
					slot5.GlobalPosition = slot.GlobalPosition + slot.Right;
					ImageImporter.Create360Sphere(slot5, slot.GetComponentInChildren<VideoTextureProvider>(), stereo);
					slot5.AttachComponent<Grabbable>().Scalable.Value = true;
					slot.DestroyWhenDestroyed(slot5);
				}
				break;
			case VideoType.Sphere180:
				if (!videoInterface.SetPanoramic(180f, 180f, PanoramicProjection.Equirectangular))
				{
					Slot slot4 = slot.World.AddSlot("180 Projection Sphere");
					slot4.GlobalPosition = slot.GlobalPosition + slot.Right;
					ImageImporter.Create360Sphere(slot4, slot.GetComponentInChildren<VideoTextureProvider>(), stereo, ImageProjection.Equirectangular180);
					slot4.AttachComponent<Grabbable>().Scalable.Value = true;
					slot.DestroyWhenDestroyed(slot4);
				}
				break;
			case VideoType.Depth:
			{
				VideoTextureProvider videoAsset = slot.GetComponentInChildren<VideoTextureProvider>();
				while (!videoAsset.IsAssetAvailable)
				{
					await default(NextUpdate);
				}
				Elements.Core.int2 v = videoAsset.Asset.Size;
				Slot slot2 = slot.World.AddSlot("Depth Projection");
				slot2.GlobalPosition = slot.GlobalPosition + slot.Right;
				slot2.AttachComponent<Grabbable>().Scalable.Value = true;
				Slot slot3 = slot2.AddSlot("Holder");
				slot3.LocalPosition = Elements.Core.float3.Down * 0.5f;
				slot3.AttachCylinder<PBS_Metallic>(0.25f, 0.05f);
				AttachedModel<GridMesh, DepthProjectionMaterial> attachedModel = slot2.AddSlot("Projection").AttachMesh<GridMesh, DepthProjectionMaterial>();
				attachedModel.mesh.Points.Value = v / 3;
				attachedModel.mesh.OverrideBoundingBox.Value = true;
				attachedModel.mesh.OverridenBoundingBox.Value = Elements.Core.BoundingBox.CenterSize(Elements.Core.float3.Zero, Elements.Core.float3.One * 1024);
				attachedModel.material.Color.Target = videoAsset;
				attachedModel.material.Depth.Target = videoAsset;
				switch (depth)
				{
				case DepthPreset.Default:
					attachedModel.material.ColorTextureScale.Value = new Elements.Core.float2(0.5f, 1f);
					attachedModel.material.ColorTextureOffset.Value = new Elements.Core.float2(0f, 0f);
					attachedModel.material.DepthTextureScale.Value = new Elements.Core.float2(0.5f, 1f);
					attachedModel.material.DepthTextureOffset.Value = new Elements.Core.float2(0.5f);
					break;
				case DepthPreset.Holofix:
					attachedModel.material.ColorTextureScale.Value = new Elements.Core.float2(0.5f, 0.666f);
					attachedModel.material.ColorTextureOffset.Value = new Elements.Core.float2(0.5f, 0.1666f);
					attachedModel.material.DepthTextureScale.Value = new Elements.Core.float2(0.5f, 0.666f);
					attachedModel.material.DepthTextureOffset.Value = new Elements.Core.float2(0f, 0.1666f);
					attachedModel.material.DepthFrom.Value = 0.4f;
					attachedModel.material.DepthTo.Value = 10f;
					attachedModel.material.DepthEncoding.Value = DepthEncoding.Grayscale;
					attachedModel.material.FieldOfView.Value = new Elements.Core.float2(40f, 30f);
					attachedModel.material.DiscardThreshold.Value = 0.05f;
					attachedModel.material.DiscardOffset.Value = 0.004f;
					break;
				case DepthPreset.PFCaptureVertical:
					SetupPFCapture(attachedModel.material, horizontal: false);
					break;
				case DepthPreset.PFCaptureHorizontal:
					SetupPFCapture(attachedModel.material, horizontal: true);
					break;
				}
				break;
			}
			}
			return Elements.Core.Result.Success();
		}

		private static void SetupPFCapture(DepthProjectionMaterial material, bool horizontal)
		{
			material.FieldOfView.Value = new Elements.Core.float2(60f, 45f);
			if (horizontal)
			{
				material.ColorTextureScale.Value = new Elements.Core.float2(0.5f, 1f);
				material.ColorTextureOffset.Value = new Elements.Core.float2(0.5f);
				material.DepthTextureScale.Value = new Elements.Core.float2(0.5f, 1f);
				material.DepthTextureOffset.Value = new Elements.Core.float2(0f, 0f);
				material.FieldOfView.Value = material.FieldOfView.Value.yx;
			}
			else
			{
				material.ColorTextureScale.Value = new Elements.Core.float2(1f, 0.5f);
				material.ColorTextureOffset.Value = new Elements.Core.float2(0f, 0.5f);
				material.DepthTextureScale.Value = new Elements.Core.float2(1f, 0.5f);
				material.DepthTextureOffset.Value = new Elements.Core.float2(0f, 0f);
			}
			material.DepthFrom.Value = 0f;
			material.DepthTo.Value = 20f;
			material.DepthEncoding.Value = DepthEncoding.RGBSpectrum;
			material.DiscardThreshold.Value = 0.05f;
			material.DiscardOffset.Value = 0.004f;
		}

