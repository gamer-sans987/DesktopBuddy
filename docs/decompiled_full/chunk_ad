	public static class HighlightHelper
	{
		public static Slot FlashHighlight(Slot root, Predicate<IHighlightable> filter, Elements.Core.colorX color, float duration = 0.5f, bool excludeDisabled = false, bool trackPosition = true)
		{
			List<IHighlightable> list = Pool.BorrowList<IHighlightable>();
			root.GetComponentsInChildren(list, filter, excludeDisabled);
			Slot result = FlashHighlight(list, color, duration, trackPosition);
			Pool.Return(ref list);
			return result;
		}

		public static Slot FlashHighlight(IEnumerable<IHighlightable> highlightables, Elements.Core.colorX color, float duration = 0.5f, bool trackPosition = true)
		{
			World world = highlightables.FirstOrDefault()?.World;
			if (world == null)
			{
				return null;
			}
			Slot slot = world.AddSlot("HighlightFlash");
			slot.PersistentSelf = false;
			OverlayFresnelMaterial overlayFresnelMaterial = slot.AttachComponent<OverlayFresnelMaterial>();
			overlayFresnelMaterial.OffsetFactor.Value = -1f;
			overlayFresnelMaterial.OffsetUnits.Value = -1f;
			overlayFresnelMaterial.BlendMode.Value = BlendMode.Additive;
			foreach (IHighlightable highlightable in highlightables)
			{
				highlightable.GenerateHighlight(slot, overlayFresnelMaterial, trackPosition);
			}
			if (duration < float.MaxValue)
			{
				overlayFresnelMaterial.FrontFarColor.TweenFromTo(color, Elements.Core.colorX.Black, duration);
				overlayFresnelMaterial.BehindFarColor.TweenFromTo(color.MulRGB(0.7f), Elements.Core.colorX.Black, duration);
				overlayFresnelMaterial.FrontNearColor.TweenFromTo(color.MulRGB(0.2f), Elements.Core.colorX.Black, duration);
				overlayFresnelMaterial.BehindNearColor.TweenFromTo(color.MulRGB(0.1f), Elements.Core.colorX.Black, duration);
				world.RunInSeconds(duration, slot.Destroy);
			}
			return slot;
		}
	}
