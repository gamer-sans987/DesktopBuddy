		private void SetCube(Elements.Core.float3 targetPoint, Elements.Core.float3 oppositePoint, Elements.Core.bool3 mask)
		{
			bool flag = base.World.GetUndoManager().GetUndoStep() != _lastUndoBatch || base.Time.WorldTime - _lastChangeTime > 0.5;
			_lastChangeTime = base.Time.WorldTime;
			if (flag)
			{
				_lastUndoBatch = base.World.BeginUndoBatch("Undo.ChangeBoxSize".AsLocaleKey());
			}
			Elements.Core.float3 masked = BoxSize.Target.Value;
			if (SizeOnly)
			{
				targetPoint -= BoxSizeSpace.Space.GlobalPointToLocal(BoxCenterSpace.Space.GlobalPosition);
				targetPoint *= 2;
				targetPoint = targetPoint.Mask(mask, in masked);
				targetPoint = MathX.Abs(in targetPoint);
				if (flag)
				{
					BoxSize.Target.CreateUndoPoint();
				}
				BoxSize.Target.Value = targetPoint;
			}
			else
			{
				Elements.Core.float3 spacePoint = (targetPoint + oppositePoint) * 0.5f;
				Elements.Core.float3 value = MathX.Abs(targetPoint - oppositePoint).Mask(mask, in masked);
				if (flag)
				{
					BoxSize.Target.CreateUndoPoint();
					BoxCenter.Target.CreateUndoPoint();
				}
				BoxSize.Target.Value = value;
				BoxCenter.Target.Value = BoxCenterSpace.Space.SpacePointToLocal(in spacePoint, BoxSizeSpace.Space);
			}
			if (flag)
			{
				base.World.EndUndoBatch();
			}
		}

