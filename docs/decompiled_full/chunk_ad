	{
		protected readonly SyncRef<ISyncList> _targetList;

		protected readonly SyncRef<Button> _addNewButton;

		protected bool setup;

		protected bool reindex;

		private ISyncList _registeredList;

		protected virtual float LabelSize => 0.15f;

		protected virtual FieldInfo FieldInfo => null;

		protected virtual bool ReorderButtons => true;

		protected virtual bool RemoveButton => true;

		protected virtual int MinLabelWidth => 24;

		public virtual void Setup(ISyncList target, Button button)
		{
			_targetList.Target = target;
			_addNewButton.Target = button;
			_addNewButton.Target.Pressed.Target = AddNewPressed;
		}

		protected override void OnChanges()
		{
			if (base.World.IsAuthority && _targetList.Target != null && !setup)
			{
				setup = true;
				_registeredList = _targetList.Target;
				base.Slot.DestroyChildren();
				_targetList.Target.ElementsAdded += Target_ElementsAdded;
				_targetList.Target.ElementsRemoved += Target_ElementsRemoved;
				_targetList.Target.ListCleared += Target_ListCleared;
				Target_ElementsAdded(_targetList.Target, 0, _targetList.Target.Count);
			}
			if (reindex)
			{
				Reindex();
				reindex = false;
			}
		}

		protected virtual void Reindex()
		{
			for (int i = 0; i < base.Slot.ChildrenCount; i++)
			{
				Text text = base.Slot[i][0]?.GetComponent<Text>();
				if (text != null)
				{
					text.Content.Value = GetElementName(_targetList.Target, i);
				}
			}
		}

		[SyncMethod(typeof(Delegate), null)]
		private void AddNewPressed(IButton button, ButtonEventData eventData)
		{
			if (!(_targetList.Target is ConflictingSyncElement { DirectAccessOnly: not false }) || base.LocalUser.IsDirectlyInteracting())
			{
				_targetList.Target.AddElement();
			}
		}

		protected override void OnDispose()
		{
			base.OnDispose();
			if (_registeredList != null)
			{
				_registeredList.ElementsAdded -= Target_ElementsAdded;
				_registeredList.ElementsRemoved -= Target_ElementsRemoved;
				_registeredList.ListCleared -= Target_ListCleared;
				_registeredList = null;
			}
		}

		private void Target_ListCleared(ISyncList list)
		{
			base.World?.RunSynchronously(delegate
			{
				base.Slot.DestroyChildren();
			});
		}

		private void Target_ElementsRemoved(ISyncList list, int startIndex, int count)
		{
			base.World?.RunSynchronously(delegate
			{
				List<Slot> list2 = Pool.BorrowList<Slot>();
				for (int i = startIndex; i < startIndex + count; i++)
				{
					if (i < base.Slot.ChildrenCount)
					{
						list2.Add(base.Slot[i]);
					}
				}
				foreach (Slot item in list2)
				{
					item.Destroy();
				}
				Pool.Return(ref list2);
				for (int j = startIndex; j < base.Slot.ChildrenCount; j++)
				{
					base.Slot[j].OrderOffset = j;
				}
				reindex = true;
				MarkChangeDirty();
			});
		}

		private void Target_ElementsAdded(ISyncList list, int startIndex, int count)
		{
			List<ISyncMember> elements = Pool.BorrowList<ISyncMember>();
			for (int i = startIndex; i < startIndex + count; i++)
			{
				elements.Add(list.GetElement(i));
			}
			base.World?.RunSynchronously(delegate
			{
				int count2 = list.Count;
				if (count2 != 0)
				{
					for (int num = base.Slot.ChildrenCount - 1; num >= startIndex; num--)
					{
						base.Slot[num].OrderOffset += count;
					}
					for (int j = 0; j < count2; j++)
					{
						if (elements[j] != null && !elements[j].IsRemoved)
						{
							Slot slot = base.Slot.AddSlot("Element");
							slot.OrderOffset = startIndex + j;
							BuildListItem(list, startIndex + j, elements[j], slot);
						}
					}
					Pool.Return(ref elements);
				}
			});
		}

		[SyncMethod(typeof(Delegate), null)]
		private void MoveUpPressed(IButton button, ButtonEventData eventData)
		{
			MoveElement(button, eventData, -1);
		}

		[SyncMethod(typeof(Delegate), null)]
		private void MoveDownPressed(IButton button, ButtonEventData eventData)
		{
			MoveElement(button, eventData, 1);
		}

		private void MoveElement(IButton button, ButtonEventData eventData, int offset)
		{
			if (_targetList.Target is ConflictingSyncElement { DirectAccessOnly: not false } && !base.LocalUser.IsDirectlyInteracting())
			{
				return;
			}
			int num = FindButtonIndex(button);
			if (num >= 0)
			{
				int num2 = num + offset;
				if (num2 >= 0 && !(num2 >= _targetList.Target?.Count))
				{
					_targetList.Target?.MoveElementToIndex(num, num2);
				}
			}
		}

		[SyncMethod(typeof(Delegate), null)]
		private void RemovePressed(IButton button, ButtonEventData eventData)
		{
			if (!(_targetList.Target is ConflictingSyncElement { DirectAccessOnly: not false }) || base.LocalUser.IsDirectlyInteracting())
			{
				int num = FindButtonIndex(button);
				if (num >= 0)
				{
					_targetList.Target?.RemoveElement(num);
				}
			}
		}

		private int FindButtonIndex(IButton button)
		{
			for (int i = 0; i < base.Slot.ChildrenCount; i++)
			{
				if (base.Slot[i].GetComponentsInChildren<Button>().Any((Button b) => b == button))
				{
					return i;
				}
			}
			return -1;
		}

		protected virtual void BuildListItem(ISyncList list, int index, ISyncMember listItem, Slot root)
		{
			root.AttachComponent<HorizontalLayout>().Spacing.Value = 4f;
			UIBuilder uIBuilder = new UIBuilder(root);
			RadiantUI_Constants.SetupEditorStyle(uIBuilder);
			uIBuilder.Style.RequireLockInToPress = true;
			uIBuilder.Style.MinWidth = -1f;
