	public readonly struct ImportItem
	{
		public readonly string itemName;

		public readonly string filePath;

		public readonly Uri assetUri;

		public readonly object inMemoryAsset;

		public readonly string extension;

		public ImportItem(object inMemoryAsset, string itemName)
		{
			this.inMemoryAsset = inMemoryAsset;
			this.itemName = itemName;
			assetUri = null;
			filePath = null;
			extension = null;
		}

		public ImportItem(string filePath)
		{
			this.filePath = filePath?.Trim();
			itemName = Path.GetFileName(this.filePath);
			extension = Path.GetExtension(this.filePath);
			assetUri = null;
			inMemoryAsset = null;
		}

		public ImportItem(Uri assetUri, string itemName)
		{
			this.assetUri = assetUri;
			this.itemName = itemName;
			filePath = null;
			inMemoryAsset = null;
			extension = null;
		}

		public override string ToString()
		{
			if (inMemoryAsset != null)
			{
				return $"Item {itemName}, Asset: {inMemoryAsset}";
			}
			if (filePath != null)
			{
				return "Item " + itemName + ", Path: " + filePath;
			}
			return $"Item {itemName}, URI: {assetUri}";
		}
	}
