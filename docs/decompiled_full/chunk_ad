			}
			Reference.Target.OpenInspectorForTarget(null, openWorkerOnly: true);
			IWorldElement target = Reference.Target;
			Slot slot;
			if (!(target is IAssetProvider<Font> font))
			{
				if (!(target is IAssetProvider<Material> material))
				{
					VideoTextureProvider videoTextureProvider = target as VideoTextureProvider;
					if (videoTextureProvider == null)
					{
						if (!(target is IAssetProvider<ITexture2D> assetProvider))
						{
							if (!(target is IAssetProvider<Cubemap> cubemap))
							{
								if (!(target is IAssetProvider<Mesh> mesh))
								{
									IAssetProvider<AudioClip> assetProvider2 = target as IAssetProvider<AudioClip>;
									if (assetProvider2 != null)
									{
										slot = base.LocalUserSpace.AddSlot($"AudioClip: {assetProvider2}");
										slot.GlobalPosition = base.Slot.GlobalPosition;
										slot.PointAtUserHead(Elements.Core.float3.Backward);
										base.World.Coroutines.StartTask(async delegate
										{
											(await slot.SpawnEntity<AudioPlayerInterface, LegacyAudioPlayer>(FavoriteEntity.AudioPlayer)).SetSource(assetProvider2);
										});
									}
								}
								else
								{
									MeshOrb.ConstructMeshOrb(mesh).GlobalPosition = base.Slot.GlobalPosition;
								}
							}
							else
							{
								slot = base.LocalUserSpace.AddSlot("Cubemap");
								slot.GlobalPosition = base.Slot.GlobalPosition;
								CubemapImporter.CreateSphere(slot, cubemap);
							}
						}
						else
						{
							slot = base.LocalUserSpace.AddSlot("Texture");
							slot.GlobalPosition = base.Slot.GlobalPosition;
							slot.PointAtUserHead(Elements.Core.float3.Backward);
							slot.LocalScale = Elements.Core.float3.One * 0.2f;
							slot.AttachComponent<Grabbable>().Scalable.Value = true;
							ImageImporter.CreateQuad(slot, assetProvider);
							if (assetProvider is IAssetProvider<Texture2D>)
							{
								ImageImporter.SetupTextureProxyComponents(slot, (IAssetProvider<Texture2D>)assetProvider, StereoLayout.None, ImageProjection.Perspective, setupPhotoMetadata: false);
							}
						}
					}
					else
					{
						slot = base.LocalUserSpace.AddSlot($"VideoTexture: {videoTextureProvider}");
						slot.GlobalPosition = base.Slot.GlobalPosition;
						slot.PointAtUserHead(Elements.Core.float3.Backward);
						slot.LocalScale = Elements.Core.float3.One * 0.2f;
						base.World.Coroutines.StartTask(async delegate
						{
							(await slot.SpawnEntity<VideoPlayerInterface, LegacyVideoPlayer>(FavoriteEntity.VideoPlayer)).SetSource(videoTextureProvider);
						});
					}
				}
				else
				{
					MaterialOrb.ConstructMaterialOrb(material).GlobalPosition = base.Slot.GlobalPosition;
				}
			}
			else
			{
				slot = base.LocalUserSpace.AddSlot("Font");
				slot.GlobalPosition = base.Slot.GlobalPosition;
				slot.PointAtUserHead(Elements.Core.float3.Backward);
				slot.LocalScale = Elements.Core.float3.One * 0.5f;
				UniversalImporter.SpawnFont(slot, font);
			}
			base.Slot.Destroy();
		}

