		public void OpenCategory(string path)
		{
			CategoryNode<CategoryItem> subcategory = root.GetSubcategory(path);
			if (subcategory == null)
			{
				subcategory = root;
				path = "";
			}
			_contentRoot.Target.DestroyChildren();
			UIBuilder uIBuilder = new UIBuilder(_contentRoot.Target);
			RadiantUI_Constants.SetupEditorStyle(uIBuilder, extraPadding: true);
			uIBuilder.Style.ButtonTextAlignment = Alignment.MiddleLeft;
			uIBuilder.Panel();
			uIBuilder.ScrollArea(Alignment.TopCenter);
			uIBuilder.VerticalLayout(4f, 0f, Alignment.TopCenter).ForceExpandHeight.Value = false;
			uIBuilder.FitContent(SizeFit.Disabled, SizeFit.MinSize);
			uIBuilder.Style.MinHeight = 32f;
			if (subcategory.Parent != null && path != CategoryRoot.Value)
			{
				uIBuilder.Button("CreateNew.Back".AsLocaleKey(), new Elements.Core.colorX?(RadiantUI_Constants.Sub.RED), ReturnToCategory, subcategory.Parent.GetPath(), 0.5f);
			}
			foreach (CategoryNode<CategoryItem> subcategory2 in subcategory.Subcategories)
			{
				uIBuilder.Button((LocaleString)GetLocalized(path, subcategory2.Name), new Elements.Core.colorX?(RadiantUI_Constants.Sub.YELLOW), NestIntoCategory, subcategory2.GetPath(), 0.5f);
			}
			string path2 = subcategory.GetPath();
			for (int i = 0; i < subcategory.ElementCount; i++)
			{
				CategoryItem element = subcategory.GetElement(i);
				if (!element.IsSpacer)
				{
					uIBuilder.Button((LocaleString)GetLocalized(path2, element.name), (Elements.Core.colorX?)null, RunAction, path2 + "/" + i, 0.5f);
				}
			}
		}

		private string GetLocalized(string path, string name)
		{
			string text = ConvertToLocalePath(path, name);
			string localized = this.GetLocalized(text);
			if (localized == text)
			{
				return name;
			}
			return localized;
		}

		private static string ConvertToLocalePath(string path, string name)
		{
			if (string.IsNullOrWhiteSpace(path))
			{
				return "CreateNew." + name;
			}
			path = path.Replace("/", ".");
			if (path.StartsWith("."))
			{
				path = path.Substring(1);
			}
			if (path.EndsWith("."))
			{
				path = path.Substring(0, path.Length - 1);
			}
			path = ((path.Length <= 0) ? name : (path + "." + name));
			return "CreateNew." + path;
		}

