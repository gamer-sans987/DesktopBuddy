			{
				return;
			}
			if (_displayTemplate != DisplayTemplate.Target)
			{
				base.Slot.DestroyChildren();
			}
			_displayTemplate = DisplayTemplate.Target;
			int num = int.MaxValue;
			int num2 = int.MinValue;
			for (int i = 0; i < base.InputInterface.DisplayCount; i++)
			{
				Display display = base.InputInterface.GetDisplay(i);
				num = MathX.Min(display.Resolution.y, num);
				num2 = MathX.Max(display.Resolution.y, num2);
			}
			int num3 = num2 - num;
			int j;
			for (j = 0; j < base.InputInterface.DisplayCount; j++)
			{
				Display display2 = base.InputInterface.GetDisplay(j);
				if (base.Slot.ChildrenCount <= j)
				{
					if (DisplayTemplate.Target == null)
					{
						base.Slot.AddSlot($"Display {j}");
					}
					else
					{
						Slot slot = DisplayTemplate.Target.Duplicate(base.Slot);
						slot.ActiveSelf = true;
						slot.Name = $"Display {j}";
						slot.ForeachComponentInChildren(delegate(IDisplayManagerComponent d)
