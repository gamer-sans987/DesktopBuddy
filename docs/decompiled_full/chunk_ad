	public class AccountMigrationsList : Component
	{
		public readonly Sync<int> TotalMigrations;

		public readonly Sync<int> WaitingMigrations;

		public readonly Sync<int> RunningMigrations;

		public readonly Sync<int> CompletedMigrations;

		public readonly SyncFieldList<string> MigrationTaskIds;

		protected override void OnCommonUpdate()
		{
			if (!base.World.IsUserspace())
			{
				return;
			}
			HashSet<string> hashSet = Pool.BorrowHashSet<string>();
			foreach (string migrationTaskId in MigrationTaskIds)
			{
				hashSet.Add(migrationTaskId);
			}
			int num = 0;
			int num2 = 0;
			int num3 = 0;
			int num4 = 0;
			foreach (AccountMigrationTask migrationTask in base.Cloud.Migration.MigrationTasks)
			{
				num++;
				switch (migrationTask.State)
				{
				case MigrationState.Waiting:
					num2++;
					break;
				case MigrationState.Migrating:
					num3++;
					break;
				case MigrationState.Completed:
					num4++;
					break;
				}
				if (!hashSet.Remove(migrationTask.TaskId))
				{
					MigrationTaskIds.Add(migrationTask.TaskId);
				}
			}
			foreach (string item in hashSet)
			{
				MigrationTaskIds.Remove(item);
			}
			Pool.Return(ref hashSet);
			TotalMigrations.Value = num;
			WaitingMigrations.Value = num2;
			RunningMigrations.Value = num3;
			CompletedMigrations.Value = num4;
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			TotalMigrations = new Sync<int>();
			WaitingMigrations = new Sync<int>();
			RunningMigrations = new Sync<int>();
			CompletedMigrations = new Sync<int>();
