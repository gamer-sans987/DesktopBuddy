		public static (T x, T y, T z) SampleSpatialVariablePartialDerivative<T>(this World world, string name, in Elements.Core.float3 point, Elements.Core.float3 right, Elements.Core.float3 up, Elements.Core.float3 forward, float samplingDistance, ValueSpatialVariableMode mode, T baseValue)
		{
			if (samplingDistance <= 0f)
			{
				T val = Coder<T>.Scale(default(T), float.NaN);
				return (x: val, y: val, z: val);
			}
			float num = samplingDistance * 0.5f;
			right *= num;
			up *= num;
			forward *= num;
			T a = world.SampleNumericValueSpatialVariable(name, point + right, mode, baseValue);
			T b = world.SampleNumericValueSpatialVariable(name, point - right, mode, baseValue);
			T a2 = world.SampleNumericValueSpatialVariable(name, point + up, mode, baseValue);
			T b2 = world.SampleNumericValueSpatialVariable(name, point - up, mode, baseValue);
			T a3 = world.SampleNumericValueSpatialVariable(name, point + forward, mode, baseValue);
			T b3 = world.SampleNumericValueSpatialVariable(name, point - forward, mode, baseValue);
			float s = 1f / samplingDistance;
			T item = Coder<T>.Scale(Coder<T>.Sub(a, b), s);
			T item2 = Coder<T>.Scale(Coder<T>.Sub(a2, b2), s);
			T item3 = Coder<T>.Scale(Coder<T>.Sub(a3, b3), s);
			return (x: item, y: item2, z: item3);
		}
	}
