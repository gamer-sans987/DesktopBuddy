		internal void SwitchGizmo(Worker worker)
		{
			if (_activeGizmo.Target == worker)
			{
				double num = base.Time.WorldTime - _lastSwitchGizmoTime;
				_lastSwitchGizmoTime = base.Time.WorldTime;
				if (num < 0.4000000059604645)
				{
					if (worker == _translationGizmo.Target)
					{
						_targetSlot.Target.Position_Field.UndoableSet(Elements.Core.float3.Zero, forceNew: true).Description = "Reset Local Position";
					}
					if (worker == _rotationGizmo.Target)
					{
						_targetSlot.Target.Rotation_Field.UndoableSet(Elements.Core.floatQ.Identity, forceNew: true).Description = "Reset Local Rotation";
					}
					if (worker == _scaleGizmo.Target)
					{
						_targetSlot.Target.Scale_Field.UndoableSet(Elements.Core.float3.One, forceNew: true).Description = "Reset Local Scale";
					}
				}
				return;
			}
			_translationGizmo.Target.Slot.ActiveSelf = false;
			_rotationGizmo.Target.Slot.ActiveSelf = false;
			_scaleGizmo.Target.Slot.ActiveSelf = false;
			foreach (Component component in _targetSlot.Target.Components)
			{
				if (!(component.GizmoType == null) && !(component is Collider))
				{
					component.DeactivateGizmo();
				}
			}
			if (worker == _translationGizmo.Target)
			{
				_translationGizmo.Target.Slot.ActiveSelf = true;
			}
			else if (worker == _rotationGizmo.Target)
			{
				_rotationGizmo.Target.Slot.ActiveSelf = true;
			}
			else if (worker == _scaleGizmo.Target)
			{
				_scaleGizmo.Target.Slot.ActiveSelf = true;
			}
			else
			{
				worker?.ActivateGizmo();
			}
			_activeGizmo.Target = worker;
		}

