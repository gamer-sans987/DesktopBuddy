		protected readonly FieldDrive<string> _label;

		protected readonly FieldDrive<bool> _previousEnabled;

		protected readonly FieldDrive<bool> _nextEnabled;

		protected override void OnAwake()
		{
			base.OnAwake();
			ItemsPerPage.Value = 50;
			TotalItems.Value = 0;
			HasMoreItems.Value = false;
			NoItemsLabel.Value = "---";
			PagingInfoLabel.Value = "{0} - {1}";
		}

		protected override void OnChanges()
		{
			base.OnChanges();
			Update();
		}

		private void Update()
		{
			int num = MathX.Max(TotalItems.Value, 0);
			int num2 = MathX.Max(ItemsPerPage.Value, 0);
			int num3 = 0;
			int num4 = 0;
			if (num2 > 0)
			{
				num4 = MathX.CeilToInt((float)num / (float)num2);
				num3 = num4 * num2;
			}
			int num5 = MathX.Max(num3 - num2, 0);
			if (HasMoreItems.Value)
			{
				num5 = int.MaxValue;
			}
			if (SkipItems.Value < 0)
			{
				SkipItems.Value = 0;
			}
			if (SkipItems.Value > num5)
			{
				SkipItems.Value = num5;
			}
			int num6 = num - SkipItems.Value;
			RemainingItems.Value = num6;
			TotalPages.Value = num4;
			bool value = SkipItems.Value > 0;
			bool value2 = num6 > num2 || (bool)HasMoreItems;
			if (_previousEnabled.IsLinkValid)
			{
				_previousEnabled.Target.Value = value;
			}
			if (_nextEnabled.IsLinkValid)
			{
				_nextEnabled.Target.Value = value2;
			}
			if (_label.IsLinkValid)
			{
				if (num <= 0)
				{
					_label.Target.Value = NoItemsLabel.Value;
					return;
				}
				string text = ((num2 <= num6) ? (SkipItems.Value + num2).ToString() : ((!HasMoreItems.Value) ? (SkipItems.Value + num6).ToString() : "?"));
				_label.Target.Value = string.Format(PagingInfoLabel.Value, SkipItems.Value, text, num, HasMoreItems.Value);
			}
		}

