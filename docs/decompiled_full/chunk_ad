		{
			base.OnAwake();
			Delta.Value = Coder<T>.Default;
			Min.Value = Coder<T>.MinValue;
			Max.Value = Coder<T>.MaxValue;
		}

		protected override void OnAttach()
		{
			base.OnAttach();
			if (!Coder<T>.SupportsAddSub)
			{
				UniLog.Warning($"Attaching ButtonValueShift with type {typeof(T)}. This type does not support add/sub operations.", stackTrace: true);
				Destroy();
			}
		}

		public void Pressed(IButton button, ButtonEventData eventData)
		{
			if (!Coder<T>.SupportsAddSub)
			{
				return;
			}
			IField<T> target = TargetValue.Target;
			if (target == null)
			{
				return;
			}
			T value = target.Value;
			if (typeof(T).IsQuaternionType())
			{
				value = Coder<T>.Mul(value, Delta.Value);
			}
			else
			{
				value = Coder<T>.Add(value, Delta.Value);
				if ((bool)WrapAround)
				{
					if (Coder<T>.SupportsRepeat)
					{
						T val = Coder<T>.Sub(Max.Value, Min.Value);
						if ((bool)MaxIsExclusive)
						{
							val = Coder<T>.Sub(val, Coder<T>.Abs(Delta.Value));
						}
						value = Coder<T>.Sub(value, Min.Value);
						value = Coder<T>.Repeat(value, val);
						value = Coder<T>.Add(value, Min.Value);
					}
				}
				else if (Coder<T>.SupportsMinMax)
				{
					T val2 = Max.Value;
					if ((bool)MaxIsExclusive)
					{
						val2 = Coder<T>.Sub(val2, Coder<T>.Abs(Delta.Value));
					}
					value = Coder<T>.Max(value, Min.Value);
					value = Coder<T>.Min(value, val2);
				}
			}
			target.Value = value;
		}

