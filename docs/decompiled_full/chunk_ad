	public static class InspectorHelper
	{
		public static Slot? OpenInspectorForTargetReference(this ISyncRef reference, bool openWorkerOnly = false)
		{
			if (!(reference.Target is ISyncRef syncRef))
			{
				return null;
			}
			return syncRef.Target.OpenInspectorForTarget(reference.FindNearestParent<Slot>(), openWorkerOnly);
		}

		public static Slot? OpenInspectorForTarget(this IWorldElement target, Slot source = null, bool openWorkerOnly = false)
		{
			if (target == null)
			{
				return null;
			}
			Slot slot = target.FindNearestParent<Slot>();
			User user = target.FindNearestParent<User>();
			Worker worker = (openWorkerOnly ? target.FindNearestParent<Worker>() : null);
			if (worker == slot || worker == user)
			{
				worker = null;
			}
			if (slot == null && user == null && worker == null)
			{
				UniLog.Warning("The target is neither on a Slot nor on an User.\n" + target.ParentHierarchyToString());
				return null;
			}
			Slot slot2 = target.World.LocalUserSpace.AddSlot("Inspector");
			Slot slot3 = source?.GetComponentInParents<SceneInspector>()?.Slot ?? source?.GetComponentInParents<UserInspector>()?.Slot ?? source?.GetComponentInParents<GenericUIContainer>()?.Slot;
			if (worker != null)
			{
				WorkerInspector.Create(slot2, worker);
			}
			else if (slot != null)
			{
				SceneInspector sceneInspector = slot2.AttachComponent<SceneInspector>();
				sceneInspector.Root.Target = slot;
				sceneInspector.ComponentView.Target = slot;
			}
			else if (user != null)
			{
				UserInspector userInspector = slot2.AttachComponent<UserInspector>();
				userInspector.ViewUser.Target = user;
				Stream stream = target.FindNearestParent<Stream>();
				if (stream != null)
				{
					userInspector.ViewGroup.Value = UserInspector.View.Streams;
					userInspector.ViewStreamGroup.Value = stream.GroupIndex;
				}
				else if (target.FindNearestParent<UserComponent>() != null)
				{
					userInspector.ViewGroup.Value = UserInspector.View.Components;
				}
				else
				{
					userInspector.ViewGroup.Value = UserInspector.View.User;
				}
			}
			if (slot3 != null)
			{
				slot2.CopyTransform(slot3);
				slot3.Position_Field.TweenTo(slot3.LocalPosition + slot3.LocalRotation * Elements.Core.float3.Forward * 0.1f, 0.2f);
			}
			else
			{
				slot2.PositionInFrontOfUser(Elements.Core.float3.Backward);
			}
			return slot2;
		}

