		public void RunImportAsGaussianSplat()
		{
			List<ImportItem> _paths = Paths;
			Elements.Core.float3 _globalPosition = base.Slot.GlobalPosition;
			Elements.Core.floatQ _globalRotation = base.Slot.GlobalRotation;
			World _world = base.World;
			float globalScale = _world.LocalUser?.Root?.GlobalScale ?? 1f;
			StartGlobalTask(async delegate
			{
				int count = _paths.Count;
				int rowSize = MathX.Max(1, MathX.CeilToInt(MathX.Sqrt(count)));
				int index = 0;
				foreach (ImportItem item in _paths)
				{
					Slot s = _world.LocalUserSpace.AddSlot(item.itemName);
					s.AttachComponent<ObjectRoot>();
					Elements.Core.float3 b = _globalRotation * ILSpyHelper_AsRefReadOnly(UniversalImporter.GridOffset(ref index, rowSize)) * globalScale;
					s.GlobalPosition = _globalPosition + b;
					s.GlobalScale = globalScale * Elements.Core.float3.One;
					Slot slot = _world.AddSlot("Import indicator");
					slot.PersistentSelf = false;
					slot.GlobalPosition = s.GlobalPosition;
					IProgressIndicator progress = await slot.SpawnProgressIndicator();
					await GaussianSplatImporter.ImportSplatAsync(item.filePath, s, _flipY.Value ? new Elements.Core.int3(1, -1, 1) : Elements.Core.int3.One, _encodeSPZ.Value, progress);
				}
				static ref readonly T ILSpyHelper_AsRefReadOnly<T>(in T temp)
				{
					//ILSpy generated this function to help ensure overload resolution can pick the overload using 'in'
					return ref temp;
				}
			});
			base.Slot.Destroy();
		}

		public void RunImport()
		{
			ModelImportSettings settings;
			if (_debugRig.Value)
			{
				settings = new ModelImportSettings();
				settings.CalculateNormals = true;
				settings.ImportBones = true;
				settings.MaterialMapper = delegate(Slot slot, Assimp.Material assimp, List<TextureMapping> textures)
				{
					FresnelMaterial fresnelMaterial = slot.AttachComponent<FresnelMaterial>();
					fresnelMaterial.BlendMode.Value = BlendMode.Alpha;
					fresnelMaterial.FarColor.Value = Elements.Core.colorX.White;
					fresnelMaterial.NearColor.Value = new Elements.Core.colorX(1f, 1f, 1f, 0f);
					return fresnelMaterial;
				};
			}
			else
			{
				switch (_material.Value)
				{
				case MaterialType.PBS:
					settings = ModelImportSettings.PBS(generateColliders: true, importBones: true, importAnimations: true, pbsUnlit: false, _externalTextures.Value, _preferSpecular.Value);
					break;
				case MaterialType.PBS_DualSided:
					settings = ModelImportSettings.PBS<PBS_DualSidedMetallic, PBS_DualSidedSpecular>(generateColliders: true, importBones: true, importAnimations: true, pbsUnlit: false, _externalTextures.Value, _preferSpecular.Value);
					break;
				case MaterialType.PBS_Triplanar:
					settings = ModelImportSettings.PBS<PBS_TriplanarMetallic, PBS_TriplanarSpecular>(generateColliders: true, importBones: true, importAnimations: true, pbsUnlit: false, _externalTextures.Value, _preferSpecular.Value);
					break;
				case MaterialType.PBS_Emissive:
					settings = ModelImportSettings.PBS(generateColliders: true, importBones: true, importAnimations: true, pbsUnlit: true, _externalTextures.Value, _preferSpecular.Value);
					break;
				case MaterialType.Unlit:
					settings = ModelImportSettings.Unlit();
					break;
				case MaterialType.UnlitDualSided:
					settings = ModelImportSettings.Unlit(generateColliders: true, importBones: true, importAnimations: true, forceDualsided: true);
					break;
				case MaterialType.UnlitBillboard:
					settings = ModelImportSettings.Unlit(generateColliders: true, importBones: true, importAnimations: true, forceDualsided: false, billboard: true);
					break;
				case MaterialType.XiexeToon:
					settings = ModelImportSettings.XiexeToon();
					break;
				case MaterialType.XiexeToonOutline:
					settings = ModelImportSettings.XiexeToon(generateColliders: true, importBones: true, importAnimations: true, outline: true);
					break;
				case MaterialType.Wireframe:
					settings = ModelImportSettings.Wireframe();
					break;
				default:
					throw new Exception("Unsupported Material Type");
				}
			}
			settings.CalculateNormals = _calculateNormals;
			settings.CalculateTangents = _calculateTangents;
			settings.ImportVertexColors = _importVertexColors;
			settings.ImportAlbedoColor = _importAlbedoColor;
			settings.ImportEmissive = _importEmissive;
			settings.ImportBones = _importBones;
			settings.ImportLights = _importLights;
			settings.CalculateTextureAlpha = _calculateTextureAlpha.Value;
			settings.Center = true;
			settings.Rescale = _autoScale.Value;
			settings.Scale = _scale.Value;
			settings.GenerateColliders = _colliders.Value;
			settings.GenerateSkeletonBones = true;
			settings.GenerateSkeletonBoneVisuals = _debugRig.Value;
			settings.SetupIK = _setupIK.Value;
			settings.ForceTpose = _forceTpose.Value;
			settings.ImportAnimations = _animations.Value;
			settings.GenerateSnappables = _snappable.Value;
			settings.GenerateTimelapse = _timelapse.Value;
			settings.ForcePointCloud = _asPointCloud.Value;
			settings.MaxTextureSize = _maxTextureSize.Value;
			settings.TextureConversion = _textureConversion.Value;
			settings.ImportImagesByName = _importImagesByName.Value;
			settings.MakeDualSided = _makeDualSided.Value;
			settings.MakeFlatShaded = _makeFlatShaded.Value;
			settings.DeduplicateInstances = _deduplicateInstances.Value;
			settings.OptimizeModel = _optimizeModel.Value;
			settings.SplitSubmeshes = _splitSubmeshes.Value;
			settings.GenerateRandomMaterialColors = _generateRandomColors.Value;
			settings.ForcePointFiltering = _forcePointFiltering.Value;
			settings.ForceNoMipmaps = _forceNoMipMaps.Value;
			if (_forceUncompressed.Value)
			{
				settings.ForceCompression = TextureCompression.RawRGBA;
			}
			settings.SpawnMaterialOrbs = _spawnMaterialOrbs.Value;
			switch (_importImageAlignment.Value)
			{
			case AlignmentAxis.PosX:
				settings.ImagesForwardAxis = new Elements.Core.float3(1f);
				break;
			case AlignmentAxis.PosY:
				settings.ImagesForwardAxis = new Elements.Core.float3(0f, 1f);
				break;
			case AlignmentAxis.PosZ:
				settings.ImagesForwardAxis = new Elements.Core.float3(0f, 0f, 1f);
				break;
			case AlignmentAxis.NegX:
				settings.ImagesForwardAxis = new Elements.Core.float3(-1f);
				break;
			case AlignmentAxis.NegY:
				settings.ImagesForwardAxis = new Elements.Core.float3(0f, -1f);
				break;
			case AlignmentAxis.NegZ:
				settings.ImagesForwardAxis = new Elements.Core.float3(0f, 0f, -1f);
				break;
			}
			List<ImportItem> _paths = Paths;
			Elements.Core.float3 _globalPosition = base.Slot.GlobalPosition;
			Elements.Core.floatQ _globalRotation = base.Slot.GlobalRotation;
			World _world = base.World;
			StartGlobalTask(async delegate
			{
				int count = _paths.Count;
				int rowSize = MathX.Max(1, MathX.CeilToInt(MathX.Sqrt(count)));
				int index = 0;
				foreach (ImportItem item in _paths)
				{
					Slot s = _world.LocalUserSpace.AddSlot(item.itemName);
					if (_grabbable.Value)
					{
						s.AttachComponent<Grabbable>().Scalable.Value = _scalable.Value;
					}
					s.AttachComponent<ObjectRoot>();
					float num = _world.LocalUser?.Root?.GlobalScale ?? 1f;
					if (!_importAtOrigin.Value)
					{
						Elements.Core.float3 b = _globalRotation * ILSpyHelper_AsRefReadOnly(UniversalImporter.GridOffset(ref index, rowSize)) * num;
						s.GlobalPosition = _globalPosition + b;
						s.GlobalScale = num * Elements.Core.float3.One;
					}
					Slot slot = _world.AddSlot("Import indicator");
					slot.PersistentSelf = false;
					slot.GlobalPosition = s.GlobalPosition;
					ProgressBarInterface progressBarInterface = await slot.SpawnEntity<ProgressBarInterface, LegacySegmentCircleProgress>(FavoriteEntity.ProgressBar);
					progressBarInterface.Initialize(canBeHidden: false);
					progressBarInterface.UpdateProgress(-1f, "Waiting", "");
					await ModelImporter.ImportModelAsync(item.filePath, s, settings, _assetsOnObject ? s.AddSlot("Assets") : null, progressBarInterface);
				}
				static ref readonly T ILSpyHelper_AsRefReadOnly<T>(in T temp)
				{
					//ILSpy generated this function to help ensure overload resolution can pick the overload using 'in'
					return ref temp;
				}
			});
			base.Slot.Destroy();
		}

