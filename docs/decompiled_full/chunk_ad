		[SyncMethod(typeof(Delegate), null)]
		private void EditingStarted(TextEditor editor)
		{
			if (_targetField.Target is ConflictingSyncElement { DirectAccessOnly: not false } && !base.LocalUser.IsDirectlyInteracting())
			{
				return;
			}
			int index = _textEditors.IndexOf(editor);
			if (_accessors[index].FieldType == typeof(bool))
			{
				bool flag = _accessors[index].GetField(_targetField.Target.BoxedValue) == "True";
				object boxedValue = _accessors[index].SetField(flag ? "False" : "True", _targetField.Target.BoxedValue);
				_targetField.Target.BoxedValue = boxedValue;
				base.World.RunSynchronously(delegate
				{
					editor.Defocus();
				});
			}
			else
			{
				_textDrives.GetElement(index).Target = null;
			}
		}

		[SyncMethod(typeof(Delegate), null)]
		private void EditingChanged(TextEditor editor)
		{
			if (!(_targetField.Target is ConflictingSyncElement { DirectAccessOnly: not false }) || base.LocalUser.IsDirectlyInteracting())
			{
				int index = _textEditors.IndexOf(editor);
				if (_textEditors[index].IsEditing && _accessors[index].Continuous)
				{
					ParseAndAssign(index);
				}
			}
		}

		[SyncMethod(typeof(Delegate), null)]
		private void EditingFinished(TextEditor editor)
		{
			if (!(_targetField.Target is ConflictingSyncElement { DirectAccessOnly: not false }) || base.LocalUser.IsDirectlyInteracting())
			{
				int index = _textEditors.IndexOf(editor);
				if (!_accessors[index].Continuous)
				{
					ParseAndAssign(index);
				}
				_textDrives.GetElement(index).Target = ((Text)editor.Text.Target).Content;
			}
		}

		private void TextChanged(IField<string> field, string value)
		{
			if (!(_targetField.Target is ConflictingSyncElement { DirectAccessOnly: not false }) || base.LocalUser.IsDirectlyInteracting())
			{
				int i;
				for (i = 0; i < _textDrives.Count && _textDrives.GetElement(i).Target != field; i++)
				{
				}
				if (!_textEditors[i].IsEditing)
				{
					_textEditors[i].Text.Target.Text = value;
					ParseAndAssign(i);
				}
			}
		}

		private void ParseAndAssign(int index)
		{
			if (!(_targetField.Target is ConflictingSyncElement { DirectAccessOnly: not false }) || base.LocalUser.IsDirectlyInteracting())
			{
				object obj = _accessors[index].SetField(_textEditors[index].Text.Target.Text, _targetField.Target.BoxedValue);
				if (obj != null)
				{
					_targetField.Target.BoxedValue = obj;
				}
			}
		}

