	public class SpatialVariableSpace<T> : SpatialVariableSpace
	{
		private SpatialCollection3D<ISpatialVariable<T>> variables = new SpatialCollection3D<ISpatialVariable<T>>();

		private bool variablesAdded;

		private List<ISpatialVariable<T>> dirtyVariables;

		public override int VariableCount => variables.Count;

		public SpatialVariableSpace(string name)
			: base(name)
		{
		}

		public int GetVariables(Elements.Core.float3 point, List<ISpatialVariable<T>> list)
		{
			UpdateTree();
			return variables.GetOverlaps(Elements.Core.BoundingBox.CenterSize(in point, Elements.Core.float3.Zero), list, (ISpatialVariable<T> v) => v.ContainsPoint(point));
		}

		public void RegisterVariable(ISpatialVariable<T> variable)
		{
			variables.Add(variable, variable.Bounds);
			variablesAdded = true;
			variable.BoundsChanged = VariableBoundsChanged;
			variable.ClearBoundsDirty();
			MarkTreeDirty();
		}

		public void UnregisterVariable(ISpatialVariable<T> variable)
		{
			if (!variables.Remove(variable))
			{
				throw new InvalidOperationException("This variable does not exist");
			}
			variable.BoundsChanged = null;
		}

		protected override void UpdateVariableBounds()
		{
			bool flag = variablesAdded;
			variablesAdded = false;
			if (dirtyVariables != null)
			{
				foreach (ISpatialVariable<T> dirtyVariable in dirtyVariables)
				{
					if (!dirtyVariable.IsRemoved && variables.UpdateBoundsIfExists(dirtyVariable, dirtyVariable.Bounds))
					{
						dirtyVariable.ClearBoundsDirty();
						flag = true;
					}
				}
				Pool.Return(ref dirtyVariables);
			}
			if (flag)
			{
				variables.RefitAndRefine();
			}
		}

		private void VariableBoundsChanged(ISpatialVariable<T> variable)
		{
			if (dirtyVariables == null)
			{
				dirtyVariables = Pool.BorrowList<ISpatialVariable<T>>();
			}
			dirtyVariables.Add(variable);
			MarkTreeDirty();
		}
	}
