		public void BuildUI(string path, bool genericType = false, string group = null, bool doNotGenerateBack = false)
		{
			if (path != null && path.StartsWith("/"))
			{
				path = path.Substring(1);
			}
			if (doNotGenerateBack)
			{
				_rootPath.Value = path;
			}
			else if (_rootPath.Value == path && group == null)
			{
				doNotGenerateBack = true;
			}
			_uiRoot.Target.DestroyChildren();
			_customGenericArguments.Clear();
			_genericType.Value = null;
			UIBuilder ui = new UIBuilder(_uiRoot.Target);
			RadiantUI_Constants.SetupEditorStyle(ui, extraPadding: true);
			ui.Style.TextAlignment = Alignment.MiddleLeft;
			ui.Style.ButtonTextAlignment = Alignment.MiddleLeft;
			ui.Style.MinHeight = 32f;
			if (genericType)
			{
				string text = PathUtility.GetDirectoryName(path).Replace('\\', '/');
				Type type = Type.GetType(PathUtility.GetFileName(path));
				_genericType.Value = type;
				if (!doNotGenerateBack)
				{
					if (group != null)
					{
						text = text + "?" + group;
					}
					ui.Button("ComponentSelector.Back".AsLocaleKey(), new Elements.Core.colorX?(RadiantUI_Constants.BUTTON_COLOR), OnOpenCategoryPressed, text, 0.35f);
				}
				ui.Text("ComponentSelector.CustomGenericArguments".AsLocaleKey());
				Type[] genericArguments = type.GetGenericArguments();
				for (int i = 0; i < genericArguments.Length; i++)
				{
					TextField textField = ui.HorizontalElementWithLabel((LocaleString)genericArguments[i].Name, 0.05f, () => ui.TextField("", undo: false, null, parseRTF: false));
					if (GenericArgumentPrefiller.Target != null)
					{
						textField.TargetString = GenericArgumentPrefiller.Target(type, genericArguments[i]);
					}
					_customGenericArguments.Add(textField);
				}
				Button button = ui.Button((LocaleString)"", new Elements.Core.colorX?(RadiantUI_Constants.BUTTON_COLOR), OnCreateCustomType, 0.35f);
				_customGenericTypeLabel.Target = button.Label.Content;
				_customGenericTypeColor.Target = button.BaseColor;
				ui.Text("ComponentSelector.CommonGenericTypes".AsLocaleKey());
				foreach (Type commonGenericType in WorkerInitializer.GetCommonGenericTypes(type))
				{
					try
					{
						if (!commonGenericType.IsValidGenericType(validForInstantiation: true) || !base.World.Types.IsSupported(commonGenericType))
						{
							continue;
						}
						goto IL_0348;
					}
					catch (Exception ex)
					{
						UniLog.Warning("Exception checking validity of a generic type: " + commonGenericType?.ToString() + "for " + type?.ToString() + "\n" + ex);
					}
					continue;
					IL_0348:
					ui.Button((LocaleString)commonGenericType.GetNiceName(), new Elements.Core.colorX?(RadiantUI_Constants.Sub.CYAN), OnAddComponentPressed, base.World.Types.EncodeType(commonGenericType), 0.35f).Label.ParseRichText.Value = false;
				}
			}
			else
			{
				CategoryNode<Type> categoryNode;
				if (string.IsNullOrEmpty(path) || path == "/")
				{
					categoryNode = WorkerInitializer.ComponentLibrary;
				}
				else
				{
					categoryNode = WorkerInitializer.ComponentLibrary.GetSubcategory(path);
					if (categoryNode == null)
					{
						categoryNode = WorkerInitializer.ComponentLibrary;
						path = "";
					}
				}
				if (categoryNode != WorkerInitializer.ComponentLibrary && !doNotGenerateBack)
				{
					ui.Button("ComponentSelector.Back".AsLocaleKey(), new Elements.Core.colorX?(RadiantUI_Constants.BUTTON_COLOR), OnOpenCategoryPressed, (group == null) ? categoryNode.Parent.GetPath() : path, 0.35f);
				}
				KeyCounter<string> keyCounter = null;
				HashSet<string> hashSet = null;
				if (group == null)
				{
					foreach (CategoryNode<Type> subcategory in categoryNode.Subcategories)
					{
						ui.Button((LocaleString)(subcategory.Name + " >"), new Elements.Core.colorX?(RadiantUI_Constants.Sub.YELLOW), OnOpenCategoryPressed, path + "/" + subcategory.Name, 0.35f).Label.ParseRichText.Value = false;
					}
					keyCounter = new KeyCounter<string>();
					hashSet = new HashSet<string>();
					foreach (Type element in categoryNode.Elements)
					{
						if (base.World.Types.IsSupported(element))
						{
							GroupingAttribute customAttribute = element.GetCustomAttribute<GroupingAttribute>();
							if (customAttribute != null)
							{
								keyCounter.Increment(customAttribute.GroupName);
							}
						}
					}
				}
				List<Button> list = Pool.BorrowList<Button>();
				foreach (Type element2 in categoryNode.Elements)
				{
					if (!base.World.Types.IsSupported(element2) || (ComponentFilter.Target != null && !ComponentFilter.Target(element2)))
					{
						continue;
					}
					GroupingAttribute customAttribute2 = element2.GetCustomAttribute<GroupingAttribute>();
					if (group != null && customAttribute2?.GroupName != group)
					{
						continue;
					}
					Button button2;
					if (group == null && customAttribute2 != null && keyCounter[customAttribute2.GroupName] > 1)
					{
						if (!hashSet.Add(customAttribute2.GroupName))
						{
							continue;
						}
						string text2 = customAttribute2.GroupName.Split('.')?.Last();
						button2 = ui.Button((LocaleString)text2, new Elements.Core.colorX?(RadiantUI_Constants.Sub.PURPLE), OpenGroupPressed, path + ":" + customAttribute2.GroupName, 0.35f);
						list.Add(button2);
					}
					else if (element2.IsGenericTypeDefinition)
					{
						string text3 = Path.Combine(path, element2.AssemblyQualifiedName);
						if (group != null)
						{
							text3 = text3 + "?" + group;
						}
						button2 = ui.Button((LocaleString)element2.GetNiceName(), new Elements.Core.colorX?(RadiantUI_Constants.Sub.GREEN), OpenGenericTypesPressed, text3, 0.35f);
						list.Add(button2);
					}
					else
					{
						button2 = ui.Button((LocaleString)element2.GetNiceName(), new Elements.Core.colorX?(RadiantUI_Constants.Sub.CYAN), OnAddComponentPressed, base.World.Types.EncodeType(element2), 0.35f);
					}
					button2.Label.ParseRichText.Value = false;
					list.Add(button2);
				}
				list.Sort((Button a, Button b) => a.LabelText.CompareTo(b.LabelText));
				for (int num = 0; num < list.Count; num++)
				{
					list[num].Slot.OrderOffset = 10 + num;
				}
			}
			ui.Button("General.Cancel".AsLocaleKey(), new Elements.Core.colorX?(RadiantUI_Constants.Sub.RED), OnCancelPressed, 0.35f).Slot.OrderOffset = 1000000L;
		}

