		public static T SampleNumericValueSpatialVariable<T>(this World world, string name, in Elements.Core.float3 point, ValueSpatialVariableMode mode, T baseValue)
		{
			List<SpatialVariableResult<T>> list = Pool.BorrowList<SpatialVariableResult<T>>();
			world.SampleSpatialVariables(name, in point, list);
			try
			{
				if (list.Count == 0)
				{
					return baseValue;
				}
				switch (mode)
				{
				case ValueSpatialVariableMode.HighestPriority:
					list.Sort();
					return list[0].value;
				case ValueSpatialVariableMode.PrioritySortedBlend:
				{
					list.Sort();
					T val2 = baseValue;
					for (int num = list.Count - 1; num >= 0; num--)
					{
						val2 = Coder<T>.Lerp(val2, list[num].value, list[num].blendWeight);
					}
					return val2;
				}
				case ValueSpatialVariableMode.Additive:
				{
					T val4 = baseValue;
					foreach (SpatialVariableResult<T> item in list)
					{
						val4 = Coder<T>.Add(val4, Coder<T>.Scale(item.value, MathX.Clamp01(item.blendWeight)));
					}
					return val4;
				}
				case ValueSpatialVariableMode.WeightedAverage:
				{
					float num2 = 0f;
					T val3 = default(T);
					foreach (SpatialVariableResult<T> item2 in list)
					{
						val3 = Coder<T>.Add(val3, Coder<T>.Scale(item2.value, item2.blendWeight));
						num2 += item2.blendWeight;
					}
					if (num2 < 1f)
					{
						return Coder<T>.Lerp(baseValue, val3, num2);
					}
					return Coder<T>.Scale(val3, 1f / num2);
				}
				case ValueSpatialVariableMode.Multiplicative:
				{
					T val = baseValue;
					foreach (SpatialVariableResult<T> item3 in list)
					{
						val = Coder<T>.Lerp(val, Coder<T>.Mul(val, item3.value), MathX.Clamp01(item3.blendWeight));
					}
					return val;
				}
				default:
					throw new ArgumentException("Invalid mode");
				}
			}
			finally
			{
				Pool.Return(ref list);
			}
		}

