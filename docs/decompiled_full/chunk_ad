			}
			ProgressKnown.TrySetTarget(value: true);
			Progress.TrySetTarget(1f);
			Stage.TrySetTarget(ProgressStage.Completed);
			HasCompleted.TrySetTarget(value: true);
			CompletionMessage.TrySetTarget(message);
