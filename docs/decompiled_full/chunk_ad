	public abstract class WizardForm : Component
	{
		protected readonly SyncDelegateList<Action<UIBuilder>> path;

		protected readonly SyncRef<Slot> _contentRoot;

		protected abstract LocaleString Title { get; }

		protected virtual Elements.Core.float2 CanvasSize => new Elements.Core.float2(300f, 700f);

		protected override void OnAttach()
		{
			UIBuilder uIBuilder = RadiantUI_Panel.SetupPanel(base.Slot, Title, CanvasSize);
			Slot slot = base.Slot;
			slot.LocalScale *= 0.0005f;
			RadiantUI_Constants.SetupEditorStyle(uIBuilder);
			uIBuilder.Panel();
			_contentRoot.Target = uIBuilder.Root;
			OpenRoot(uIBuilder);
		}

		protected abstract void OpenRoot(UIBuilder ui);

		protected void Open(Action<UIBuilder> builder)
		{
			path.Add(builder);
			_contentRoot.Target.DestroyChildren();
			UIBuilder uIBuilder = new UIBuilder(_contentRoot.Target);
			RadiantUI_Constants.SetupDefaultStyle(uIBuilder);
			builder(uIBuilder);
		}

		protected void Return()
		{
			_contentRoot.Target.DestroyChildren();
			path.RemoveAt(path.Count - 1);
			Action<UIBuilder> action = ((path.Count != 0) ? path[path.Count - 1] : new Action<UIBuilder>(OpenRoot));
			UIBuilder uIBuilder = new UIBuilder(_contentRoot.Target);
			RadiantUI_Constants.SetupDefaultStyle(uIBuilder);
			action(uIBuilder);
		}

		[SyncMethod(typeof(Delegate), null)]
		protected void Return(IButton button, ButtonEventData eventData)
		{
			Return();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			path = new SyncDelegateList<Action<UIBuilder>>();
			_contentRoot = new SyncRef<Slot>();
		}
	}
