			}
			if (_accessors == null)
			{
				_accessors = FieldExtractor.ExtractFields(_targetField.Target.ValueType).Cast<StringFieldAccessor>().ToList();
			}
			for (int i = 0; i < _accessors.Count; i++)
			{
				if (_textDrives.GetElement(i).IsLinkValid)
				{
					_textDrives.GetElement(i).Target.Value = _accessors[i].GetField(_targetField.Target.BoxedValue);
				}
			}
		}

