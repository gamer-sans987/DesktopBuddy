		[SyncMethod(typeof(Delegate), null)]
		private void CopyTexture(IButton button, ButtonEventData eventData)
		{
			if (!base.InputInterface.IsClipboardSupported)
			{
				return;
			}
			ITexture2D texture2D = _targetRef.Target?.Asset;
			Texture2D texture2D2 = texture2D as Texture2D;
			if (texture2D2 != null)
			{
				StartGlobalTask(async delegate
				{
					await default(ToBackground);
					Bitmap2D data = await texture2D2.GetOriginalTextureData().ConfigureAwait(continueOnCapturedContext: false);
					await default(ToWorld);
					base.InputInterface.Clipboard.SetBitmap(data);
				});
			}
		}

		[SyncMethod(typeof(Delegate), null)]
		private void PasteTexture(IButton button, ButtonEventData eventData)
		{
			if (!base.InputInterface.IsClipboardSupported)
			{
				return;
			}
			string origLabel = button.LabelText;
			button.Enabled = false;
			button.LabelText = "...";
			StartTask(async delegate
			{
				try
				{
					await default(ToBackground);
					if (!base.InputInterface.Clipboard.ContainsImage)
					{
						return;
					}
					Bitmap2D bitmap2D = await base.InputInterface.Clipboard.GetImage();
					if (bitmap2D == null)
					{
						return;
					}
					Uri uri = await base.Engine.LocalDB.SaveAssetAsync(bitmap2D).ConfigureAwait(continueOnCapturedContext: false);
					await default(ToWorld);
					AssetRef<ITexture2D> target = _targetRef.Target;
					if (target == null)
					{
						return;
					}
					Slot slot = base.World.AssetsSlot.AddSlot("Texture from " + base.LocalUser.UserName + "'s clipboard");
					StaticTexture2D newTexture = slot.AttachTexture(uri);
					if (target.Target is StaticTexture2D source)
					{
						newTexture.CopyProperties(source, includePrivate: false, (ISyncMember m) => m == newTexture.URL);
					}
					target.UndoableSet(newTexture, forceNew: true);
				}
				finally
				{
					await default(ToWorld);
					if (!button.IsDestroyed)
					{
						button.Enabled = true;
						button.LabelText = origLabel;
					}
				}
			});
		}

		[SyncMethod(typeof(Delegate), null)]
		private void SetTexture(IButton button, ButtonEventData eventData)
		{
			Grabber grabber = eventData.source.Slot.TryFindGrabberWithItems();
			if (grabber != null)
			{
				TryReceive(grabber.GrabbedObjects, grabber, null, grabber.Slot.GlobalPosition);
