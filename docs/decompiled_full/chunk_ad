		private static void GenerateMemberName(string path, UIBuilder ui)
		{
			if (!string.IsNullOrEmpty(path))
			{
				int num = path.LastIndexOf(".");
				string text = ((num >= 0) ? path.Substring(num + 1) : path);
				ui.Text((LocaleString)text, bestFit: true, Alignment.MiddleLeft, parseRTF: false);
			}
		}

		/// <summary>
		/// This method builds out a member editor for a given field of a specified type.
		/// </summary>
		/// <param name="field"></param>
		/// <param name="type"></param>
		/// <param name="path"></param>
		/// <param name="ui"></param>
		/// <param name="fieldInfo"></param>
		/// <param name="layoutElement"></param>
		/// <param name="generateName"></param>
		private static void BuildMemberEditors(IField field, Type type, string path, UIBuilder ui, FieldInfo fieldInfo, LayoutElement layoutElement, bool generateName = true)
		{
			if (type.IsPrimitive || type == typeof(string) || type == typeof(Uri) || type == typeof(Type) || type == typeof(decimal))
			{
				if (generateName)
				{
					GenerateMemberName(path, ui);
				}
				RangeAttribute rangeAttribute = fieldInfo?.GetCustomAttribute<RangeAttribute>();
				if (type == typeof(bool))
				{
					ui.BooleanMemberEditor(field, path);
					return;
				}
				if (rangeAttribute != null)
				{
					string format = rangeAttribute.TextFormat;
					if (type != typeof(float) && type != typeof(double) && type != typeof(decimal) && type != typeof(Half))
					{
						format = "0";
					}
					ui.SliderMemberEditor(rangeAttribute.Min, rangeAttribute.Max, field, path, format);
					return;
				}
				string format2 = fieldInfo?.GetCustomAttribute<FormatAttribute>()?.FormatString;
				bool flag = fieldInfo?.GetCustomAttribute<NoContinuousParsingAttribute>() != null;
				if (type == typeof(Uri))
				{
					flag = true;
				}
				ui.Style.FlexibleWidth = 10f;
				ui.PrimitiveMemberEditor(field, path, !flag, format2);
				ui.Style.FlexibleWidth = -1f;
			}
			else if (type == typeof(Elements.Core.color))
			{
				if (generateName)
				{
					GenerateMemberName(path, ui);
				}
				ui.ColorMemberEditor(field, path);
			}
			else if (type == typeof(Elements.Core.colorX))
			{
				if (layoutElement != null)
				{
					layoutElement.MinHeight.Value = 48f;
				}
				if (generateName)
				{
					GenerateMemberName(path, ui);
				}
				ui.ColorXMemberEditor(field, path);
			}
			else if (type == typeof(Elements.Core.floatQ) || type == typeof(Elements.Core.doubleQ))
			{
				if (generateName)
				{
					GenerateMemberName(path, ui);
				}
				ui.QuaternionMemberEditor(field, path);
			}
			else if (type == typeof(Elements.Core.bool2) || type == typeof(Elements.Core.bool3) || type == typeof(Elements.Core.bool4))
			{
				int vectorDimensions = type.GetVectorDimensions();
				for (int i = 0; i < vectorDimensions; i++)
				{
					string path2 = "xyzw"[i].ToString();
					GenerateMemberName(path2, ui);
					ui.BooleanMemberEditor(field, path2);
				}
			}
			else if (type.IsEnum)
			{
				if (generateName)
				{
					GenerateMemberName(path, ui);
				}
				ui.EnumMemberEditor(field, path);
			}
			else if (ReflectionExtensions.IsNullable(type))
			{
				ui.PushStyle();
				ui.Style.MinWidth = 24f;
				ui.Style.MinHeight = 24f;
				NullableMemberEditor nullableMemberEditor = ui.NullableMemberEditor(field, path);
				ui.PopStyle();
				nullableMemberEditor.NullableBaseType.Value = Nullable.GetUnderlyingType(type);
				FieldInfo field2 = type.GetField("value", BindingFlags.Instance | BindingFlags.NonPublic);
				BuildMemberEditors(field, field2.FieldType, path + ".value", ui, field2, layoutElement);
			}
			else
			{
				FieldInfo[] fields = type.GetFields(BindingFlags.Instance | BindingFlags.Public | BindingFlags.NonPublic);
				foreach (FieldInfo fieldInfo2 in fields)
				{
					BuildMemberEditors(path: (!string.IsNullOrEmpty(path)) ? (path + "." + fieldInfo2.Name) : fieldInfo2.Name, field: field, type: fieldInfo2.FieldType, ui: ui, fieldInfo: fieldInfo2, layoutElement: layoutElement);
				}
			}
		}

