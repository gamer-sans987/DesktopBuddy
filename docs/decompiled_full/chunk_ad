	public static class EntityHelper
	{
		private delegate Task<I> EntitySpawner<I>(Slot slot, FavoriteEntity favorite);

		public static async Task<I> SpawnEntity<I>(this Slot slot, FavoriteEntity favorite, Func<Slot, I> fallback) where I : class
		{
			_ = slot.Engine;
			I val = null;
			EntityInterfacePreference universeEntityPreference = Engine.Config.UniverseEntityPreference;
			EntitySpawner<I>[] array = null;
			if (slot.Engine.InUniverse)
			{
				switch (universeEntityPreference)
				{
				case EntityInterfacePreference.UniverseOnly:
					array = new EntitySpawner<I>[2] { SpawnUniverseEntity<I>, SpawnPlatformEntity<I> };
					break;
				case EntityInterfacePreference.UniversePreferred:
					array = new EntitySpawner<I>[3] { SpawnUniverseEntity<I>, SpawnEntityFromFavorite<I>, SpawnPlatformEntity<I> };
					break;
				case EntityInterfacePreference.UserPreferred:
					array = new EntitySpawner<I>[3] { SpawnEntityFromFavorite<I>, SpawnUniverseEntity<I>, SpawnPlatformEntity<I> };
					break;
				}
			}
			if (!slot.Engine.InUniverse || array == null)
			{
				array = new EntitySpawner<I>[2] { SpawnEntityFromFavorite<I>, SpawnPlatformEntity<I> };
			}
			EntitySpawner<I>[] array2 = array;
			for (int i = 0; i < array2.Length; i++)
			{
				val = await array2[i](slot, favorite);
				if (val != null)
				{
					break;
				}
			}
			if (val == null)
			{
				val = fallback(slot);
			}
			if (val is EntityInterface entityInterface)
			{
				entityInterface.MarkInstance();
			}
			return val;
		}

		private static async Task<I> SpawnEntityFromFavorite<I>(Slot slot, FavoriteEntity favorite) where I : class
		{
			Uri currentFavorite = slot.Engine.Cloud.Profile.GetCurrentFavorite(favorite);
			if (currentFavorite != null)
			{
				return await LoadEntity<I>(slot, currentFavorite);
			}
			return null;
		}

		private static async Task<I> SpawnUniverseEntity<I>(Slot slot, FavoriteEntity favorite) where I : class
		{
			if (!slot.Engine.InUniverse)
			{
				return null;
			}
			Uri spawnObjectUri = slot.Engine.Universe.GetSpawnObjectUri(favorite.ToString(), slot.Engine.PlatformProfile);
			if (spawnObjectUri != null)
			{
				return await LoadEntity<I>(slot, spawnObjectUri);
			}
			return null;
		}

		private static async Task<I> SpawnPlatformEntity<I>(Slot slot, FavoriteEntity favorite) where I : class
		{
			Uri spawnObjectUri = slot.Engine.Cloud.Platform.GetSpawnObjectUri(favorite.ToString());
			if (spawnObjectUri != null)
			{
				return await LoadEntity<I>(slot, spawnObjectUri);
			}
			return null;
		}

		public static async Task<I> LoadEntity<I>(Slot slot, Uri spawnUrl) where I : class
		{
			if (await slot.LoadObjectAsync(spawnUrl, null, null, preserveRootTransform: true))
			{
				slot = slot.UnpackInventoryItem(preservePosition: true);
				return slot.GetComponentInChildren<I>();
			}
			return null;
		}

		public static async Task<I> SpawnEntity<I, D>(this Slot slot, FavoriteEntity favorite) where I : class where D : Component, new()
		{
			return await slot.SpawnEntity(favorite, delegate(Slot s)
			{
				s.AttachComponent<D>();
				I component = s.GetComponent<I>();
				if (component is EntityInterface entityInterface)
				{
					entityInterface.MarkInstance();
				}
				return component;
			});
		}

