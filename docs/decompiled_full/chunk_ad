			uIBuilder.Style.FlexibleWidth = 0f;
			uIBuilder.Style.MinWidth = 24f;
			if (ReorderButtons)
			{
				uIBuilder.Button((LocaleString)"⮝").Pressed.Target = MoveUpPressed;
				uIBuilder.Button((LocaleString)"⮟").Pressed.Target = MoveDownPressed;
			}
			if (RemoveButton)
			{
				uIBuilder.Button((LocaleString)"X").Pressed.Target = RemovePressed;
			}
		}

