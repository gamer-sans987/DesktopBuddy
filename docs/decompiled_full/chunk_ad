		public static Elements.Core.float3? GetBestSnapPoint(World world, Elements.Core.float3 globalPoint, float checkRadius, out IPointSnappable snappable, Predicate<IPointSnappable> snappableFilter = null)
		{
			List<ICollider> list = Pool.BorrowList<ICollider>();
			world.Physics.SphereOverlap(in globalPoint, checkRadius, list);
			Elements.Core.float3? result = null;
			float num = float.MaxValue;
			snappable = null;
			foreach (ICollider item in list)
			{
				IPointSnappable componentInParentsOrChildren = item.Slot.GetComponentInParentsOrChildren<IPointSnappable>();
				if (componentInParentsOrChildren == null || (snappableFilter != null && !snappableFilter(componentInParentsOrChildren)))
				{
					continue;
				}
				componentInParentsOrChildren.Snap(globalPoint, out var snappedPoint, out var _);
				if (snappedPoint.HasValue)
				{
					float num2 = MathX.Distance(in globalPoint, snappedPoint.Value);
					if (!result.HasValue || num2 < num)
					{
						result = snappedPoint;
						snappable = componentInParentsOrChildren;
						num = num2;
					}
				}
			}
			Pool.Return(ref list);
			return result;
		}
	}
