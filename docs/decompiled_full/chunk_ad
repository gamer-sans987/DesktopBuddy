		public void RunImport()
		{
			int count = Paths.Count;
			int rowSize = MathX.Max(1, MathX.CeilToInt(MathX.Sqrt(count)));
			int index = 0;
			float num = base.LocalUserRoot?.GlobalScale ?? 1f;
			Elements.Core.floatQ globalRotation = Elements.Core.floatQ.LookRotation(base.LocalUser.Root.HeadFacingDirection, base.LocalUser.Root.Slot.Up);
			foreach (ImportItem item in Paths)
			{
				Slot s = base.LocalUserSpace.AddSlot(item.itemName);
				s.AttachComponent<Grabbable>().Scalable.Value = true;
				Elements.Core.float3 b = base.Slot.GlobalRotation * UniversalImporter.GridOffset(ref index, rowSize) * num;
				s.GlobalPosition = base.Slot.GlobalPosition + b;
				s.GlobalRotation = globalRotation;
				s.GlobalScale = num * Elements.Core.float3.One;
				if (_lut.Value)
				{
					UniversalImporter.UndoableImport(s, async delegate
					{
						Elements.Core.Result result = await ImageImporter.ImportLUT(item, s);
						if (result.IsFailure)
						{
							UniversalImporter.SpawnText(s, "Importer.LUT.Failure.Heading".AsLocaleKey("image", item.itemName), "Importer.LUT.Failure.Description".AsLocaleKey("error", result.Message));
						}
						return result;
					});
					continue;
				}
				bool stripMetadata = Settings.GetActiveSetting<MediaPrivacySettings>()?.StripImageFileMetadata.Value ?? false;
				UniversalImporter.UndoableImport(s, async delegate
				{
					ImportItem item2 = item;
					Slot targetSlot = s;
					ImageProjection projection = _projection;
					StereoLayout stereoLayout = _layout;
					bool stripMetadata2 = stripMetadata;
					bool setupScreenshotMetadata = _screenshot;
					bool value = _pointFiltering.Value;
					bool value2 = _uncompressed.Value;
					bool value3 = _alphaBleed.Value;
					Elements.Core.Result result = await ImageImporter.ImportImage(item2, targetSlot, addCollider: true, projection, stereoLayout, null, TextureConversion.Auto, setupScreenshotMetadata, value, value2, value3, stripMetadata2);
					if (result.IsFailure)
					{
						UniversalImporter.SpawnText(s, "Importer.Image.Failure.Heading".AsLocaleKey("image", item.itemName), "Importer.Image.Failure.Description".AsLocaleKey("error", result.Message));
					}
					return result;
				});
			}
			base.Slot.Destroy();
		}

		protected override void InitializeSyncMembers()
		{
			base.InitializeSyncMembers();
			_projection = new Sync<ImageProjection>();
			_layout = new Sync<StereoLayout>();
			_screenshot = new Sync<bool>();
			_pointFiltering = new Sync<bool>();
			_uncompressed = new Sync<bool>();
			_alphaBleed = new Sync<bool>();
			_lut = new Sync<bool>();
		}

		public override ISyncMember GetSyncMember(int index)
		{
			return index switch
			{
				0 => persistent, 
				1 => updateOrder, 
				2 => EnabledField, 
				3 => path, 
				4 => _contentRoot, 
				5 => _projection, 
				6 => _layout, 
				7 => _screenshot, 
				8 => _pointFiltering, 
				9 => _uncompressed, 
				10 => _alphaBleed, 
				11 => _lut, 
				_ => throw new ArgumentOutOfRangeException(), 
			};
		}

