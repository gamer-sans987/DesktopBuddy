		private void DoAction(PlaybackAction action)
		{
			IPlayable target = Playback.Target;
			if (target == null)
			{
				return;
			}
			switch (action)
			{
			case PlaybackAction.Play:
				target.Play();
				break;
			case PlaybackAction.Resume:
				target.Resume();
				break;
			case PlaybackAction.Pause:
				target.Pause();
				break;
			case PlaybackAction.Stop:
				target.Stop();
				break;
			case PlaybackAction.ToggleResumePause:
				if (target.IsPlaying)
