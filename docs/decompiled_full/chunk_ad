		{
			base.OnCommonUpdate();
			SkyFrost.Base.User currentUser = base.Cloud.Session.CurrentUser;
			IsLoggedIn.Value = currentUser != null;
			IsLoggingOut.Value = Userspace.IsLoggingOut;
			if (_lastUser != currentUser || !_initialized)
			{
				_lastUser = currentUser;
				if (currentUser != null)
				{
					CurrentUsername.SetLocalized(currentUser.Username);
					CurrentUserId.Value = currentUser.Id;
					CurrentAccountType.SetLocalized(currentUser.GetAccountName(base.Cloud.Platform.Name, out var color));
					CurrentAccountColorOverride.Value = color;
					Uri.TryCreate(currentUser?.Profile?.IconUrl, UriKind.Absolute, out Uri result);
					CurrentProfileIcon.Value = result;
				}
				else
				{
					CurrentUsername.SetLocalized("Account.Anonymous".AsLocaleKey("<i>{0}</i>"));
					CurrentUserId.Value = null;
					CurrentAccountType.SetLocalized(null);
					CurrentAccountColorOverride.Value = null;
					CurrentProfileIcon.Value = OfficialAssets.Graphics.Thumbnails.AnonymousHeadset;
				}
			}
			if (base.World != Userspace.UserspaceWorld)
			{
				return;
			}
			if (LoginLogoutButton.Target != null && (_lastLoggedIn != IsLoggedIn.Value || _lastLoggingOut != IsLoggingOut.Value || _confirmLogout != _lastConfirmLogout || !_initialized))
			{
				LocaleString localeString;
				if (Userspace.IsLoggingOut)
				{
					localeString = "Account.LoggingOut".AsLocaleKey();
				}
				localeString = (_confirmLogout ? "Account.LogoutConfirm".AsLocaleKey("<color=#f00>{0}</color>") : ((!IsLoggedIn.Value) ? "Account.LoginOrRegister".AsLocaleKey() : "Account.Logout".AsLocaleKey()));
				LoginLogoutButton.Target.Label.LocaleContent = localeString;
				_lastLoggedIn = IsLoggedIn;
				_lastLoggingOut = IsLoggingOut;
				_lastConfirmLogout = _confirmLogout;
			}
			if (!_initialized)
			{
				_initialized = true;
			}
