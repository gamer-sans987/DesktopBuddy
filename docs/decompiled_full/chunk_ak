		static LegacyProtoFluxLoader()
		{
			Type[] types = GenericTypesAttribute.GetTypes(GenericTypesAttribute.Group.EnginePrimitives);
			primitives = new List<TypePair>();
			foreach (Type type in types)
			{
				primitives.Add(new TypePair(type.GetNiceName(), type));
			}
			primitives.Add(new TypePair("dummy", typeof(dummy)));
			primitives.Add(new TypePair("object", typeof(object)));
			primitives.Sort((TypePair a, TypePair b) => -a.lowerCaseName.Length.CompareTo(b.lowerCaseName.Length));
			floatQEqualsBinding = ProtoFluxHelper.GetBindingForNode(typeof(ValueEquals<>)).MakeGenericType(typeof(Elements.Core.floatQ));
			doubleQEqualsBinding = ProtoFluxHelper.GetBindingForNode(typeof(ValueEquals<>)).MakeGenericType(typeof(Elements.Core.doubleQ));
			floatQNotEqualsBinding = ProtoFluxHelper.GetBindingForNode(typeof(ValueNotEquals<>)).MakeGenericType(typeof(Elements.Core.floatQ));
			doubleQNotEqualsBinding = ProtoFluxHelper.GetBindingForNode(typeof(ValueNotEquals<>)).MakeGenericType(typeof(Elements.Core.doubleQ));
