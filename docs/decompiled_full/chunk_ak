		bool IWorkerLoader.CanLoad(WorkerSaveLoad.WorkerData data)
		{
			if (data.workerTypename.Contains("PhotonDust"))
			{
				return false;
			}
			int num = data.workerTypename.IndexOf("FrooxEngine.");
			if (num < -1)
			{
				return false;
			}
			num += "FrooxEngine.".Length;
			if (data.workerTypename.StartsWith("Legacy", num))
			{
				num += "Legacy".Length;
			}
			if (data.workerTypename.StartsWith("ParticleSystem", num))
			{
				return true;
			}
			if (data.workerTypename.StartsWith("ParticleStyle", num))
			{
				return true;
			}
			int num2 = data.workerTypename.IndexOf("Emitter", num);
			if (num2 >= 0)
			{
				for (int i = num; i < num2; i++)
				{
					if (!char.IsLetter(data.workerTypename[i]))
					{
						return false;
					}
				}
				return true;
			}
			return false;
		}

		Type IWorkerLoader.FindType(WorkerSaveLoad.WorkerData data, LoadControl loadControl)
		{
			string workerTypename = data.workerTypename;
			workerTypename = workerTypename.Replace("Legacy", "");
			workerTypename = workerTypename.Replace("FrooxEngine.", "FrooxEngine.PhotonDust.");
			Type type = ((!loadControl.LegacyTypes) ? World.Types.GetDataModelType(workerTypename, allowAmbigious: false) : World.Types.DecodeLegacyType(workerTypename));
			if (type == null)
			{
				UniLog.Warning("Failed to map legacy particle system component: " + data.workerTypename);
			}
			return type;
		}
