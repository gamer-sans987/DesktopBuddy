	public class TimeController
	{
		public static readonly double MAX_WORLDTIME_LAG = 0.5;

		public static readonly double ADJUST_COOLDOWN = 5.0;

		public static readonly float MAX_TIMESTEP = 0.1f;

		private TimeSpan _lastDelta = TimeSpan.FromMilliseconds(10L);

		private Stopwatch _timeSinceLastUpdate = new Stopwatch();

		public World World { get; private set; }

		public DateTime AbsoluteWorldTime { get; private set; }

		public DateTime LocalSessionBeginTime { get; private set; }

		public DateTime LastTimeAdjustment { get; private set; }

		public double WorldTime { get; private set; }

		public float WorldTimeFloat { get; private set; }

		public float Delta { get; private set; }

		public float InvertedDelta { get; private set; }

		public float RawDelta { get; private set; }

		public float InvertedRawDelta { get; private set; }

		public float SmoothDelta { get; private set; }

		public float InvertedSmoothDelta { get; private set; }

		public int LocalUpdateIndex { get; private set; }

		public double LocalWorldTime => (DateTime.UtcNow - LocalSessionBeginTime).TotalSeconds;

		public float TimeSinceLastUpdate => (float)(_timeSinceLastUpdate.GetElapsedMilliseconds() * 0.0010000000474974513);

		public double RealWorldTime => WorldTime + (double)TimeSinceLastUpdate;

		public double LastDSP_Time { get; private set; }

		public float TimeSinceLastDSPSync => (float)(World.Engine.AudioSystem.DSPTime - LastDSP_Time);

		public double LastReceivedAuthorityTime { get; private set; } = -1.0;

		public DateTime LastReceivedAuthorityTimeTime { get; private set; }

		public double SecondsSinceLastAuthorityTime => (DateTime.UtcNow - LastReceivedAuthorityTimeTime).TotalSeconds;

		public double EstimatedAuthorityTime => LastReceivedAuthorityTime + SecondsSinceLastAuthorityTime;

		public double EstimatedAuthorityTimeError
		{
			get
			{
				if (!(LastReceivedAuthorityTime >= 0.0))
				{
					return 0.0;
				}
				return RealWorldTime - EstimatedAuthorityTime;
			}
		}

		public TimeController(World world)
		{
			World = world;
			AbsoluteWorldTime = DateTime.UtcNow;
			LocalSessionBeginTime = DateTime.UtcNow;
			WorldTime = 0.0;
			WorldTimeFloat = 0f;
			_timeSinceLastUpdate.Start();
		}

		public void Update()
		{
			LocalUpdateIndex++;
			DateTime utcNow = DateTime.UtcNow;
			TimeSpan lastDelta = utcNow - AbsoluteWorldTime;
			double totalSeconds = lastDelta.TotalSeconds;
			if (totalSeconds < 0.0)
			{
				lastDelta = _lastDelta;
			}
			_lastDelta = lastDelta;
			RawDelta = (float)lastDelta.TotalSeconds;
			Delta = MathX.Min(RawDelta, MAX_TIMESTEP);
			if (SmoothDelta == 0f)
			{
				SmoothDelta = Delta;
			}
			else
			{
				SmoothDelta = MathX.Clamp(Delta, SmoothDelta * 0.9f, SmoothDelta * 1.1f);
			}
			InvertedDelta = 1f / Delta;
			InvertedRawDelta = 1f / RawDelta;
			InvertedSmoothDelta = 1f / SmoothDelta;
			AbsoluteWorldTime = utcNow;
			LastDSP_Time = World.Engine.AudioSystem.DSPTime;
			_timeSinceLastUpdate.Restart();
			WorldTime += MathX.Max(totalSeconds, 0.0);
			if (LastReceivedAuthorityTime > 0.0)
			{
				double totalSeconds2 = (utcNow - LastReceivedAuthorityTimeTime).TotalSeconds;
				double num = LastReceivedAuthorityTime + totalSeconds2;
				if (MathX.Abs(num - WorldTime) > MAX_WORLDTIME_LAG && (utcNow - LastTimeAdjustment).TotalSeconds > ADJUST_COOLDOWN)
				{
					WorldTime = num;
					LastTimeAdjustment = utcNow;
				}
			}
			WorldTimeFloat = (float)WorldTime;
		}

		public void SyncWorldTime(double authorityWorldTime, float messageReceiveAge)
		{
			authorityWorldTime += (double)messageReceiveAge;
			if (!(authorityWorldTime < LastReceivedAuthorityTime))
			{
				LastReceivedAuthorityTime = authorityWorldTime;
				LastReceivedAuthorityTimeTime = DateTime.UtcNow;
				if (World.State == FrooxEngine.World.WorldState.Initializing)
				{
					WorldTime = authorityWorldTime;
					AbsoluteWorldTime = LastReceivedAuthorityTimeTime;
				}
			}
		}

		public float AdjustTimeOffset(float senderOffset, double senderWorldTime, float maxError)
		{
			if (RealWorldTime - senderWorldTime > (double)maxError)
			{
				return senderOffset;
			}
			return (float)(senderWorldTime + (double)senderOffset - RealWorldTime);
		}
	}
