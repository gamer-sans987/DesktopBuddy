	public abstract class BinaryMessageBatch : SyncMessage
	{
		private const int COMPRESSION_THRESHOLD = 150;

		private BinaryReaderX reader;

		private BinaryWriterX writer;

		private RecyclableMemoryStream memoryStream;

		private RawValueList<DataRecord> dataRecords;

		private double? _senderTime;

		public double SenderTime
		{
			get
			{
				if (!_senderTime.HasValue)
				{
					throw new Exception("Message doesn't contain sender time!");
				}
				return _senderTime.Value;
			}
		}

		public int DataRecordCount => dataRecords?.Count ?? (-1);

		public override bool ShouldCompress => memoryStream.Length >= 150;

		public BinaryMessageBatch(ulong hostTick, ulong selfTick, IConnection sender, BinaryMessageBatch copyData = null)
			: base(hostTick, selfTick, sender)
		{
			dataRecords = Pool.BorrowRawValueList<DataRecord>();
			memoryStream = (RecyclableMemoryStream)SyncMessage.StreamManager.GetStream();
			writer = Pool.BorrowBinaryWriter(memoryStream);
			reader = Pool.BorrowBinaryReader(memoryStream);
			if (copyData != null)
			{
				dataRecords.AddRange(copyData.dataRecords);
				copyData.memoryStream.WriteTo(memoryStream);
			}
		}

		public void SetSenderTime(double time)
		{
			if (_senderTime.HasValue)
			{
				throw new Exception("Sender time is already set");
			}
			_senderTime = time;
		}

		public BinaryWriter BeginNewDataRecord(RefID targetId)
		{
			if (targetId.IsLocalID)
			{
				throw new InvalidOperationException($"Cannot encode local reference id: {targetId}");
			}
			DataRecord item = new DataRecord(targetId, (int)memoryStream.Position, -1);
			dataRecords.Add(in item);
			return writer;
		}

		public void FinishDataRecord(RefID targetId)
		{
			DataRecord value = dataRecords[dataRecords.Count - 1];
			if (value.length != -1 || value.targetID != targetId)
			{
				throw new Exception("Finishing invalid data record!");
			}
			value.length = (int)memoryStream.Position - value.offset;
			dataRecords[dataRecords.Count - 1] = value;
		}

		public DataRecord GetDataRecord(int index)
		{
			return dataRecords[index];
		}

		public bool IsProcessed(int index)
		{
			return dataRecords[index].processed;
		}

		public int FindDataRecordIndex(RefID targetId)
		{
			return dataRecords.FindIndex((DataRecord r) => r.targetID == targetId);
		}

		public void InvalidateDataRecord(int index, bool conflict)
		{
			DataRecord value = dataRecords[index];
			if (conflict)
			{
				value.validity = MessageValidity.Conflict;
			}
			else
			{
				value.validity = MessageValidity.Ignore;
			}
			dataRecords[index] = value;
		}

		public void MarkDataRecordAsProcessed(int index)
		{
			DataRecord value = dataRecords[index];
			value.processed = true;
			dataRecords[index] = value;
		}

		public void RemoveInvalidRecords()
		{
			if (!dataRecords.Any((DataRecord r) => r.validity != MessageValidity.Valid))
			{
				return;
			}
			RawValueList<DataRecord> rawValueList = Pool.BorrowRawValueList<DataRecord>();
			RecyclableMemoryStream recyclableMemoryStream = (RecyclableMemoryStream)SyncMessage.StreamManager.GetStream();
			foreach (DataRecord dataRecord in dataRecords)
			{
				if (dataRecord.validity == MessageValidity.Valid)
				{
					rawValueList.Add(new DataRecord(dataRecord.targetID, (int)recyclableMemoryStream.Position, dataRecord.length));
					memoryStream.Seek(dataRecord.offset, SeekOrigin.Begin);
					recyclableMemoryStream.WriteFrom(memoryStream, dataRecord.length);
				}
			}
			memoryStream.Dispose();
			Pool.Return(ref dataRecords);
			memoryStream = recyclableMemoryStream;
			dataRecords = rawValueList;
			writer.TargetStream = memoryStream;
			reader.TargetStream = memoryStream;
		}

		public BinaryReaderX SeekDataRecord(int index)
		{
			DataRecord dataRecord = dataRecords[index];
			memoryStream.Seek(dataRecord.offset, SeekOrigin.Begin);
			return reader;
		}

		public int GetConflictingDataRecords(RawValueList<RefID> ids)
		{
			int num = 0;
			foreach (DataRecord dataRecord in dataRecords)
			{
				DataRecord current = dataRecord;
				if (current.validity == MessageValidity.Conflict)
				{
					ids.Add(in current.targetID);
					num++;
				}
			}
			return num;
		}

		protected override void EncodeData(BinaryWriter writer)
		{
			writer.Write(SenderTime);
			RawValueList<ulong> list = Pool.BorrowRawValueList<ulong>();
			foreach (DataRecord dataRecord in dataRecords)
			{
				list.Add((ulong)dataRecord.targetID);
			}
			writer.WriteDeltaCodedSequence(list);
			Pool.Return(ref list);
			foreach (DataRecord dataRecord2 in dataRecords)
			{
				if (dataRecord2.length < 0)
				{
					throw new Exception("Unfinished data record");
				}
				writer.Write7BitEncoded((ulong)dataRecord2.length);
			}
			byte[] buffer = memoryStream.GetBuffer();
			writer.BaseStream.Write(buffer, 0, (int)memoryStream.Length);
		}

		protected override void DecodeData(BinaryReader reader)
		{
			SetSenderTime(reader.ReadDouble());
			RawValueList<ulong> list = Pool.BorrowRawValueList<ulong>();
			reader.ReadDeltaCodedSequence(list);
			int num = 0;
			for (int i = 0; i < list.Count; i++)
			{
				int num2 = (int)reader.Read7BitEncoded();
				DataRecord item = new DataRecord(list[i], num, num2);
				num += num2;
				dataRecords.Add(in item);
			}
			Pool.Return(ref list);
			memoryStream.WriteFrom(reader.BaseStream, num);
		}

		public override void Dispose()
		{
			base.Dispose();
			Pool.Return(ref reader);
			Pool.Return(ref writer);
			memoryStream.Dispose();
			Pool.Return(ref dataRecords);
			dataRecords = null;
			reader = null;
			writer = null;
			memoryStream = null;
		}

		public override string ToString()
		{
			return base.ToString() + $", DataRecordCount: {DataRecordCount}, DataBytes: {memoryStream?.Length}";
		}
	}
