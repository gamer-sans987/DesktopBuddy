	public class FileReceiveJob
	{
		private FileStream stream;

		private long remainingBytes;

		private string filename;

		public Engine Engine { get; private set; }

		public Uri AssetURL { get; private set; }

		public int ID { get; private set; }

		public IConnection Source { get; private set; }

		public bool IsDone => remainingBytes == 0;

		public long TotalBytes { get; private set; }

		public long ReceivedBytes => TotalBytes - remainingBytes;

		public FileReceiveJob(ControlMessage message, Engine engine)
		{
			Engine = engine;
			if (message.ControlMessageType != ControlMessage.Message.AssetTransmissionStart)
			{
				throw new Exception("ControlMessage isn't of type AssetTransmissionStart and cannot be used to initialize the receive job");
			}
			Source = message.Sender;
			remainingBytes = message.Data.ExtractOrThrow<long>("Bytes");
			TotalBytes = remainingBytes;
			AssetURL = new Uri(message.Data.ExtractOrThrow<string>("URL"));
			ID = message.Data.ExtractOrThrow<int>("ID");
			Path.GetExtension(AssetURL.LocalPath);
			filename = Engine.LocalDB.GetTempFilePath();
			stream = new FileStream(filename, FileMode.CreateNew, FileAccess.Write, FileShare.None);
		}

		public void ApplyChunk(ControlMessage message)
		{
			if (message.ControlMessageType != ControlMessage.Message.AssetChunk)
			{
				throw new Exception("ControlMessage isn't an AssetChunk");
			}
			int num = (int)Math.Min(message.BinaryPayload.Length, remainingBytes);
			stream.Write(message.BinaryPayload, 0, num);
			remainingBytes -= num;
		}

		public ControlMessage NextChunkRequest()
		{
			ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.AssetNextChunkRequest);
			controlMessage.Data.Add("ID", ID);
			controlMessage.Targets.Add(Source);
			return controlMessage;
		}

		public string FinalizeAndGetFile()
		{
			stream.Dispose();
			return filename;
		}

		public void Cancel()
		{
			stream.Dispose();
			File.Delete(filename);
		}
	}
	public class FileTransmitJob
	{
		public const int CHUNK_SIZE = 32768;

		public const int CHUNK_TX_COUNT = 32;

		private FileStream fStream;

		private byte[][] buffer;

		private int chunkid;

		public bool IsInitialized { get; private set; }

		public Uri AssetURL { get; private set; }

		public int ID { get; private set; }

		public IConnection Target { get; private set; }

		public float Progress => (float)fStream.Position / (float)fStream.Length;

		public long RemainingBytes => fStream.Length - fStream.Position;

		public bool FirstChunk => fStream.Position == 0;

		public bool IsDone => fStream.Position == fStream.Length;

		public FileTransmitJob(string file, Uri assetURI, IConnection target, int id)
		{
			AssetURL = assetURI;
			ID = id;
			Target = target;
			fStream = new FileStream(file, FileMode.Open, FileAccess.Read, FileShare.Read);
			buffer = new byte[32][];
		}

		public ControlMessage Initialize()
		{
			ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.AssetTransmissionStart);
			controlMessage.Targets.Add(Target);
			controlMessage.Data.Add("Bytes", fStream.Length);
			controlMessage.Data.Add("URL", AssetURL.ToString());
			controlMessage.Data.Add("ID", ID);
			IsInitialized = true;
			return controlMessage;
		}

		public ControlMessage GetChunk()
		{
			if (!IsInitialized)
			{
				throw new Exception("FileTransmitJob is not initialized");
			}
			ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.AssetChunk);
			controlMessage.Targets.Add(Target);
			controlMessage.Data.Add("ID", ID);
			int num = (int)MathX.Min(32768L, RemainingBytes);
			if (num == 0)
			{
				UniLog.Warning("Asset chunk has zero read size! AssetURL: " + AssetURL, stackTrace: true);
			}
			buffer[chunkid] = buffer[chunkid].EnsureExactSize(num, keepData: false, allowZeroSize: true);
			fStream.Read(buffer[chunkid], 0, buffer[chunkid].Length);
			controlMessage.BinaryPayload = buffer[chunkid];
			chunkid++;
			chunkid %= 32;
			return controlMessage;
		}

		public void Finish()
		{
			fStream.Close();
			fStream.Dispose();
		}

		public void Cancel()
		{
			fStream.Close();
			fStream.Dispose();
		}
	}
