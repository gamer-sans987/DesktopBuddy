	public abstract class SyncMessage : IDisposable
	{
		protected class LZ4BufferAllocator : IBufferAllocator
		{
			public byte[] GetBuffer(int minSize)
			{
				return StreamManager.GetLargeBuffer(minSize, null);
			}

			public void ReturnBuffer(byte[] buffer)
			{
				StreamManager.ReturnLargeBuffer(buffer, null);
			}
		}

		public static readonly RecyclableMemoryStreamManager StreamManager = new RecyclableMemoryStreamManager(512, 262144, 10485760);

		protected static readonly LZ4BufferAllocator _lz4BufferAllocator = new LZ4BufferAllocator();

		private List<IConnection> _targets;

		protected bool isDiposed;

		public abstract MessageType SyncMessageType { get; }

		public ulong SenderStateVersion { get; private set; }

		public ulong SenderSyncTick { get; private set; }

		public IConnection Sender { get; private set; }

		public User SenderUser { get; private set; }

		public int EncodedSize { get; private set; }

		public List<IConnection> Targets => _targets;

		public abstract bool Reliable { get; }

		public virtual bool Background => false;

		public abstract bool ShouldCompress { get; }

		public DateTime ReceiveTime { get; private set; }

		public float SecondsSinceReceived => (float)(DateTime.UtcNow - ReceiveTime).TotalSeconds;

		public SyncMessage(ulong hostTick, ulong selfTick, IConnection sender)
		{
			SenderStateVersion = hostTick;
			SenderSyncTick = selfTick;
			Sender = sender;
			ReceiveTime = DateTime.UtcNow;
			_targets = Pool.BorrowList<IConnection>();
		}

		public void LinkSenderUser(User user)
		{
			SenderUser = user;
		}

		public RawOutMessage Encode()
		{
			RawOutMessage rawOutMessage = new RawOutMessage();
			rawOutMessage.UseReliable = Reliable;
			rawOutMessage.Background = Background;
			MemoryStream stream = StreamManager.GetStream();
			BinaryWriterX writer = Pool.BorrowBinaryWriter(stream);
			byte b = (byte)SyncMessageType;
			if (ShouldCompress)
			{
				b |= 0x80;
			}
			writer.Write(b);
			writer.Write7BitEncoded(SenderStateVersion);
			writer.Write7BitEncoded(SenderSyncTick);
			LZ4Stream lZ4Stream = null;
			if (ShouldCompress)
			{
				lZ4Stream = (LZ4Stream)(writer.TargetStream = new LZ4Stream(stream, LZ4StreamMode.Compress, LZ4StreamFlags.HighCompression | LZ4StreamFlags.IsolateInnerStream, 1048576, _lz4BufferAllocator));
			}
			EncodeData(writer);
			Pool.Return(ref writer);
			lZ4Stream?.Dispose();
			rawOutMessage.Data = stream;
			EncodedSize = (int)stream.Length;
			foreach (IConnection target in Targets)
			{
				rawOutMessage.Targets.Add(target);
			}
			return rawOutMessage;
		}

		public static SyncMessage Decode(RawInMessage raw)
		{
			MemoryStream memoryStream = new MemoryStream(raw.Data);
			memoryStream.Seek(raw.Offset, SeekOrigin.Begin);
			BinaryReaderX reader = Pool.BorrowBinaryReader(memoryStream);
			byte num = reader.ReadByte();
			bool flag = (num & 0x80) != 0;
			MessageType messageType = (MessageType)(byte)(num & 0x7F);
			ulong num2 = reader.Read7BitEncoded();
			ulong num3 = reader.Read7BitEncoded();
			LZ4Stream lZ4Stream = null;
			if (flag)
			{
				lZ4Stream = (LZ4Stream)(reader.TargetStream = new LZ4Stream(memoryStream, LZ4StreamMode.Decompress, LZ4StreamFlags.HighCompression | LZ4StreamFlags.IsolateInnerStream, 1048576, _lz4BufferAllocator));
			}
			SyncMessage syncMessage;
			switch (messageType)
			{
			case MessageType.Delta:
				syncMessage = new DeltaBatch(num2, num3, raw.Sender);
				break;
			case MessageType.FullInitialState:
			case MessageType.Full:
				syncMessage = new FullBatch(num2, num3, messageType == MessageType.FullInitialState, raw.Sender);
				break;
			case MessageType.Confirmation:
				syncMessage = new ConfirmationMessage(num2, num3, raw.Sender);
				break;
			case MessageType.Control:
				syncMessage = new ControlMessage(raw.Sender);
				break;
			case MessageType.Stream:
			case MessageType.AsyncStream:
				syncMessage = new StreamMessage(num2, num3, raw.Sender, messageType == MessageType.AsyncStream);
				break;
			case MessageType.Ping:
				syncMessage = new PingMessage(raw.Sender);
				break;
			default:
			{
				string text = null;
				try
				{
					text = Path.Combine(Path.GetTempPath(), Path.GetTempFileName());
					File.WriteAllBytes(text, raw.Data);
				}
				catch
				{
				}
				throw new Exception("Invalid Sync Message Type: " + messageType.ToString() + ", Data Dumped to: " + text);
			}
			}
			syncMessage.ReceiveTime = raw.ReceiveTime;
			syncMessage.DecodeData(reader);
			syncMessage.EncodedSize = raw.Data.Length;
			Pool.Return(ref reader);
			lZ4Stream?.Dispose();
			return syncMessage;
		}

		protected abstract void EncodeData(BinaryWriter writer);

		protected abstract void DecodeData(BinaryReader reader);

		public virtual void Dispose()
		{
			if (isDiposed)
			{
				throw new Exception("SyncMessage already disposed");
			}
			Pool.Return(ref _targets);
			isDiposed = true;
			GC.SuppressFinalize(this);
		}

		~SyncMessage()
		{
			if (!isDiposed)
			{
				UniLog.Warning("UNDISPOSED: " + this);
				Dispose();
			}
		}

		public override string ToString()
		{
			return $"SyncMessage: {SyncMessageType}, SenderStateVersion: {SenderStateVersion}, SenderSyncTick: {SenderSyncTick}, SenderUser: {SenderUser?.ToString()}, Targets.Count: {Targets?.Count}";
		}
	}
