		internal void FinalizeFrame()
		{
			if (logText != null)
			{
				Text(logText.ToString());
				Pool.Return(ref logText);
			}
			int num;
			foreach (KeyValuePair<Type, DebugMeshList> debugMesh2 in debugMeshes)
			{
				debugMesh2.Value.meshes.Sort((DebugMesh a, DebugMesh b) => -a.duration.CompareTo(b.duration));
				num = 0;
				for (int num2 = 0; num2 < debugMesh2.Value.meshes.Count; num2++)
				{
					DebugMesh debugMesh = debugMesh2.Value.meshes[num2];
					if (!(debugMesh.duration > 0f))
					{
						break;
					}
					num++;
					debugMesh.duration = MathX.Max(0f, debugMesh.duration - World.Time.Delta);
				}
				while (debugMesh2.Value.meshes.Count > debugMesh2.Value.used)
				{
					debugMesh2.Value.meshes.TakeLast().mesh.Slot.Destroy();
				}
				debugMesh2.Value.used = num;
			}
			debugTexts.Sort((DebugText a, DebugText b) => -a.duration.CompareTo(b.duration));
			num = 0;
			for (int num3 = 0; num3 < debugTexts.Count; num3++)
			{
				DebugText debugText = debugTexts[num3];
				if (!(debugText.duration > 0f))
				{
					break;
				}
				num++;
				debugText.duration = MathX.Max(0f, debugText.duration - World.Time.Delta);
			}
			while (debugTexts.Count > usedTexts)
			{
				debugTexts.TakeLast().text.Slot.Destroy();
			}
			usedTexts = num;
		}

