	public class ReferenceController : IDisposable
	{
		private struct AllocationBlock
		{
			public byte user;

			public ulong position;

			public ushort nestedLevels;
		}

		private Dictionary<RefID, IWorldElement> objects;

		private Dictionary<RefID, List<IWorldElementReceiver>> referencesToResolve;

		private AllocationBlock currentAllocationBlock;

		private AllocationBlock[] allocationBlocks = new AllocationBlock[16];

		private int topAllocationBlock;

		private ulong localAllocationPosition;

		private ulong[] latestUserPosition;

		public World World { get; private set; }

		internal bool AllocationsBlocked { get; private set; }

		public DictionaryEnumerableWrapper<RefID, IWorldElement> AllObjects { get; private set; }

		private void PushAllocationBlock()
		{
			topAllocationBlock++;
			allocationBlocks = allocationBlocks.EnsureSize(topAllocationBlock + 1, keepData: true);
			allocationBlocks[topAllocationBlock] = currentAllocationBlock;
		}

		private void PopAllocationBlock()
		{
			if (topAllocationBlock == 0)
			{
				throw new Exception("No allocation blocks on the stack, cannot pop!");
			}
			currentAllocationBlock = allocationBlocks[topAllocationBlock--];
		}

		public ulong GetLatestPosition(byte userID)
		{
			return latestUserPosition[userID];
		}

		public void AllocationBlockBegin(in RefID id)
		{
			id.ExtractIDs(out var position, out var user);
			AllocationBlockBegin(user, position);
		}

		public void AllocationBlockBegin(byte user, ulong position)
		{
			CheckAllocation();
			if (currentAllocationBlock.user == user && currentAllocationBlock.position == position)
			{
				currentAllocationBlock.nestedLevels++;
				return;
			}
			PushAllocationBlock();
			currentAllocationBlock.user = user;
			currentAllocationBlock.position = position;
			currentAllocationBlock.nestedLevels = 0;
		}

		public void AllocationBlockEnd()
		{
			if (currentAllocationBlock.nestedLevels == 0)
			{
				PopAllocationBlock();
			}
			else
			{
				currentAllocationBlock.nestedLevels--;
			}
		}

		public void LocalAllocationBlockBegin()
		{
			CheckAllocation();
			if (currentAllocationBlock.user == byte.MaxValue)
			{
				currentAllocationBlock.nestedLevels++;
				return;
			}
			PushAllocationBlock();
			currentAllocationBlock.user = byte.MaxValue;
			currentAllocationBlock.position = localAllocationPosition;
			currentAllocationBlock.nestedLevels = 0;
		}

		public void LocalAllocationBlockEnd()
		{
			if (currentAllocationBlock.user != byte.MaxValue)
			{
				throw new Exception("ReferenceController isn't currently in local allocation block, cannot end!");
			}
			if (currentAllocationBlock.nestedLevels == 0)
			{
				localAllocationPosition = currentAllocationBlock.position;
				PopAllocationBlock();
			}
			else
			{
				currentAllocationBlock.nestedLevels--;
			}
		}

		public RefID PeekID()
		{
			CheckAllocation();
			return RefID.Construct(currentAllocationBlock.position, currentAllocationBlock.user);
		}

		public RefID AllocateID()
		{
			CheckAllocation();
			RefID result = RefID.Construct(currentAllocationBlock.position, currentAllocationBlock.user);
			currentAllocationBlock.position++;
			return result;
		}

		public void SkipAhead(uint count)
		{
			CheckAllocation();
			currentAllocationBlock.position += count;
		}

		internal void BlockAllocations()
		{
			AllocationsBlocked = true;
		}

		internal void UnblockAllocations()
		{
			AllocationsBlocked = false;
		}

		public void CheckAllocation()
		{
			if (AllocationsBlocked)
			{
				throw new InvalidOperationException("New RefID allocations are currently blocked. Are you accidentally creating new objects in the wrong context?");
			}
		}

		private void UpdateLatestPosition(in RefID id)
		{
			id.ExtractIDs(out var position, out var user);
			if (position > latestUserPosition[user])
			{
				latestUserPosition[user] = position;
			}
		}

		public ReferenceController(World owner)
		{
			World = owner;
			objects = new Dictionary<RefID, IWorldElement>();
			referencesToResolve = new Dictionary<RefID, List<IWorldElementReceiver>>();
			AllObjects = new DictionaryEnumerableWrapper<RefID, IWorldElement>(objects);
			currentAllocationBlock.position = 1uL;
			currentAllocationBlock.user = 0;
			currentAllocationBlock.nestedLevels = 0;
			latestUserPosition = new ulong[MathX.MaxValueForBits(8) + 1];
			latestUserPosition[0] = 1uL;
		}

		public void Dispose()
		{
			World = null;
			AllObjects = default(DictionaryEnumerableWrapper<RefID, IWorldElement>);
			objects.Clear();
			referencesToResolve.Clear();
			objects = null;
			referencesToResolve = null;
		}

		public void RegisterReference(IWorldElement objectToRegister)
		{
			try
			{
				objects.Add(objectToRegister.ReferenceID, objectToRegister);
			}
			catch (Exception innerException)
			{
				IWorldElement objectOrNull = GetObjectOrNull(objectToRegister.ReferenceID);
				ulong tick;
				bool value = World.IsInTrash(objectToRegister.ReferenceID, out tick);
				throw new FatalWorldException($"Exception registering reference {objectToRegister.ReferenceID} as {objectToRegister.ParentHierarchyToString()} ({objectToRegister?.GetType()}). In World: {World.Name}. Already registered object: {objectOrNull?.ParentHierarchyToString()}. Is In Trash: {value}. Tick: {tick}", innerException);
			}
			if (referencesToResolve.Count > 0 && referencesToResolve.TryGetValue(objectToRegister.ReferenceID, out List<IWorldElementReceiver> value2))
			{
				foreach (IWorldElementReceiver item in value2)
				{
					item.OnWorldElementAvailable(objectToRegister);
				}
				referencesToResolve.Remove(objectToRegister.ReferenceID);
				Pool.Return(ref value2);
			}
			UpdateLatestPosition(objectToRegister.ReferenceID);
		}

		public void UnregisterReference(IWorldElement objectToUnregister)
		{
			objects.Remove(objectToUnregister.ReferenceID);
		}

		public void RequestObject(in RefID reference, IWorldElementReceiver receiver)
		{
			if (reference == RefID.Null)
			{
				throw new Exception("Cannot request null reference ID!");
			}
			if (objects.TryGetValue(reference, out IWorldElement value))
			{
				receiver.OnWorldElementAvailable(value);
				return;
			}
			if (!referencesToResolve.TryGetValue(reference, out List<IWorldElementReceiver> value2))
			{
				value2 = Pool.BorrowList<IWorldElementReceiver>();
				referencesToResolve.Add(reference, value2);
			}
			value2.Add(receiver);
		}

		public IWorldElement GetObjectOrThrow(in RefID reference)
		{
			if (reference == RefID.Null)
			{
				throw new Exception("Cannot request null reference ID!");
			}
			return objects[reference];
		}

		public IWorldElement GetObjectOrNull(in RefID reference)
		{
			if (reference == RefID.Null)
			{
				throw new Exception("Cannot request null reference ID!");
			}
			if (objects.TryGetValue(reference, out IWorldElement value))
			{
				return value;
			}
			return null;
		}
	}
	public class SyncController : IDisposable
	{
		public const float MAX_STREAM_PACKET_INTERVAL = 0.5f;

		private List<SyncElement> _dirtySyncElements = new List<SyncElement>();

		private volatile bool _collectingDeltaMessages;

		private DateTime _lastStreamMessageTime;

		private static Comparison<SyncElement> _compareSyncElements = CompareSyncElements;

		public Engine Engine => World.Engine;

		public World World { get; private set; }

		public ReferenceController ReferenceController { get; private set; }

		public IStream CurrentlyDecodingStream { get; private set; }

		public SyncController(World owner)
		{
			World = owner;
			ReferenceController = owner.ReferenceController;
		}

		public void Dispose()
		{
			World = null;
			ReferenceController = null;
			_dirtySyncElements.Clear();
		}

		public void AddDirtySyncElement(SyncElement element)
		{
			if (World.State != FrooxEngine.World.WorldState.Running && !World.IsAuthority)
			{
				throw new Exception("Cannot Process Dirty Elements when not Running");
			}
			if (_collectingDeltaMessages)
			{
				throw new Exception("Currently collecting delta messages, cannot register new sync element! SessionStage: " + World.Session.Sync.SyncLoopStage);
			}
			if (element.IsLocalElement)
			{
				throw new Exception("The element is local, cannot register as dirty! " + element);
			}
			_dirtySyncElements.Add(element);
		}

		private static int CompareSyncElements(SyncElement a, SyncElement b)
		{
			return a.ReferenceID.CompareTo(b.ReferenceID);
		}

		public DeltaBatch CollectDeltaMessages()
		{
			DeltaBatch deltaBatch = new DeltaBatch(World.StateVersion, World.SyncTick);
			deltaBatch.SetSenderTime(World.Time.WorldTime);
			_collectingDeltaMessages = true;
			_dirtySyncElements.Sort(_compareSyncElements);
			foreach (SyncElement dirtySyncElement in _dirtySyncElements)
			{
				if (!dirtySyncElement.IsDisposed)
				{
					BinaryWriter writer = deltaBatch.BeginNewDataRecord(dirtySyncElement.ReferenceID);
					dirtySyncElement.EncodeDelta(writer, deltaBatch);
					deltaBatch.FinishDataRecord(dirtySyncElement.ReferenceID);
				}
			}
			_dirtySyncElements.Clear();
			_collectingDeltaMessages = false;
			return deltaBatch;
		}

		public FullBatch EncodeFullBatch()
		{
			List<SyncElement> list = Pool.BorrowList<SyncElement>();
			foreach (KeyValuePair<RefID, IWorldElement> allObject in ReferenceController.AllObjects)
			{
				if (!allObject.Key.IsLocalID && allObject.Value is SyncElement item)
				{
					list.Add(item);
				}
			}
			FullBatch result = EncodeFullBatch(list, isInitialState: true);
			Pool.Return(ref list);
			return result;
		}

		public FullBatch EncodeFullBatch(List<SyncElement> elements, bool isInitialState = false)
		{
			FullBatch fullBatch = new FullBatch(World.StateVersion, World.SyncTick, isInitialState);
			fullBatch.SetSenderTime(World.Time.WorldTime);
			elements.Sort(_compareSyncElements);
			foreach (SyncElement element in elements)
			{
				if (element.ReferenceID.IsLocalID)
				{
					throw new InvalidOperationException($"Cannot encode local sync element: {element.ReferenceID}\n{element}");
				}
				try
				{
					BinaryWriter writer = fullBatch.BeginNewDataRecord(element.ReferenceID);
					element.EncodeFull(writer, fullBatch);
					fullBatch.FinishDataRecord(element.ReferenceID);
				}
				catch (Exception innerException)
				{
					throw new Exception($"Exception encoding element of type {element.GetType()}:\n{element}", innerException);
				}
			}
			return fullBatch;
		}

		public void EncodeFull(RefID id, BinaryMessageBatch syncMessage)
		{
			BinaryWriter writer = syncMessage.BeginNewDataRecord(id);
			((SyncElement)ReferenceController.GetObjectOrThrow(in id)).EncodeFull(writer, syncMessage);
			syncMessage.FinishDataRecord(id);
		}

		public void ValidateDeltaMessages(DeltaBatch batch)
		{
			ReferenceController referenceController = ReferenceController;
			List<ValidationGroup.Rule> list = Pool.BorrowList<ValidationGroup.Rule>();
			List<ValidationGroup> list2 = Pool.BorrowList<ValidationGroup>();
			for (int i = 0; i < batch.DataRecordCount; i++)
			{
				DataRecord dataRecord = batch.GetDataRecord(i);
				if (referenceController.GetObjectOrNull(in dataRecord.targetID) is SyncElement syncElement)
				{
					BinaryReaderX reader = batch.SeekDataRecord(i);
					MessageValidity messageValidity = syncElement.Validate(batch, reader, list);
					if (messageValidity != MessageValidity.Valid)
					{
						batch.InvalidateDataRecord(i, messageValidity == MessageValidity.Conflict);
					}
					if (list.Count > 0)
					{
						ValidationGroup validationGroup = Elements.Core.Pool<ValidationGroup>.Borrow();
						validationGroup.Set(i, syncElement, list);
						list2.Add(validationGroup);
						list = Pool.BorrowList<ValidationGroup.Rule>();
					}
				}
			}
			Dictionary<RefID, int> dictionary = Pool.BorrowDictionary<RefID, int>();
			RawValueList<int> list3 = Pool.BorrowRawValueList<int>();
			foreach (ValidationGroup item2 in list2)
			{
				foreach (ValidationGroup.Rule validationRule in item2.ValidationRules)
				{
					RefID otherMessage = validationRule.OtherMessage;
					if (!dictionary.ContainsKey(otherMessage))
					{
						dictionary.Add(otherMessage, batch.FindDataRecordIndex(otherMessage));
					}
				}
			}
			foreach (ValidationGroup item3 in list2)
			{
				bool flag = batch.GetDataRecord(item3.RequestingRecordIndex).validity == MessageValidity.Conflict;
				list3.Clear();
				foreach (ValidationGroup.Rule validationRule2 in item3.ValidationRules)
				{
					int item = dictionary[validationRule2.OtherMessage];
					if (item < 0)
					{
						if (validationRule2.MustExist)
						{
							flag = true;
						}
						continue;
					}
					DataRecord dataRecord2 = batch.GetDataRecord(item);
					list3.Add(in item);
					if (dataRecord2.validity == MessageValidity.Conflict)
					{
						flag = true;
					}
					if (validationRule2.CustomValidation != null)
					{
						BinaryReaderX arg = batch.SeekDataRecord(item);
						if (!validationRule2.CustomValidation(arg))
						{
							flag = true;
						}
					}
				}
				if (!flag)
				{
					continue;
				}
				batch.InvalidateDataRecord(item3.RequestingRecordIndex, conflict: true);
				item3.RequestingSyncElement.Invalidate();
				foreach (int item4 in list3)
				{
					batch.InvalidateDataRecord(item4, conflict: true);
					DataRecord dataRecord3 = batch.GetDataRecord(item4);
					(referenceController.GetObjectOrNull(in dataRecord3.targetID) as SyncElement)?.Invalidate();
				}
			}
			foreach (ValidationGroup item5 in list2)
			{
				ValidationGroup resource = item5;
				Elements.Core.Pool<ValidationGroup>.Return(ref resource);
			}
			Pool.Return(ref list);
			Pool.Return(ref list2);
			Pool.Return(ref dictionary);
			Pool.Return(ref list3);
		}

		public void ApplyConfirmations(IEnumerable<RefID> ids, ulong confirmTime)
		{
			ReferenceController referenceController = ReferenceController;
			foreach (RefID id in ids)
			{
				(referenceController.GetObjectOrNull(id) as SyncElement)?.Confirm(confirmTime);
			}
		}

		public bool DecodeDeltaMessage(int recordIndex, DeltaBatch batch)
		{
			return DecodeBinaryMessage(recordIndex, batch, isFull: false);
		}

		public bool DecodeFullMessage(int recordIndex, FullBatch batch)
		{
			return DecodeBinaryMessage(recordIndex, batch, isFull: true);
		}

		public bool DecodeCorrection(int recordIndex, ConfirmationMessage batch)
		{
			return DecodeBinaryMessage(recordIndex, batch, isFull: true);
		}

		private bool DecodeBinaryMessage(int recordIndex, BinaryMessageBatch message, bool isFull)
		{
			DataRecord dataRecord = message.GetDataRecord(recordIndex);
			if (ReferenceController.GetObjectOrNull(in dataRecord.targetID) is SyncElement syncElement)
			{
				BinaryReaderX reader = message.SeekDataRecord(recordIndex);
				try
				{
					if (!isFull)
					{
						syncElement.DecodeDelta(reader, message);
					}
					else
					{
						syncElement.DecodeFull(reader, message);
					}
				}
				catch (Exception exception)
				{
					UniLog.Error($"Exception in decoding element: {syncElement.ParentHierarchyToString()}.\n{DebugManager.PreprocessException(exception)}");
					throw;
				}
				return true;
			}
			return false;
		}

		public void GatherStreams(List<StreamMessage> messages)
		{
			bool flag = false;
			foreach (StreamGroup group in World.LocalUser.StreamGroupManager.Groups)
			{
				int num = 0;
				RecyclableMemoryStream recyclableMemoryStream = (RecyclableMemoryStream)SyncMessage.StreamManager.GetStream();
				BitBinaryWriterX writer = Pool.BorrowBitBinaryWriter(new BitWriterStream(recyclableMemoryStream));
				foreach (Stream stream in World.LocalUser.Streams)
				{
					if (stream.Active && stream.GroupIndex == group.GroupIndex && stream.IsImplicitUpdatePoint(World.SyncTick))
					{
						stream.Encode(writer);
						num++;
					}
				}
				RawValueList<ulong> list = Pool.BorrowRawValueList<ulong>();
				List<Stream> list2 = Pool.BorrowList<Stream>();
				foreach (Stream stream2 in World.LocalUser.Streams)
				{
					if (stream2.Active && stream2.GroupIndex == group.GroupIndex && stream2.IsExplicitUpdatePoint(World.SyncTick))
					{
						num++;
						list.Add((ulong)stream2.ReferenceID);
						list2.Add(stream2);
					}
				}
				writer.WriteDeltaCodedSequence(list);
				Pool.Return(ref list);
				foreach (Stream item3 in list2)
				{
					item3.Encode(writer);
				}
				Pool.Return(ref list2);
				Pool.Return(ref writer);
				if (num > 0)
				{
					flag = true;
					StreamMessage item = new StreamMessage(World.LocalUser.ReferenceID, group.LastConfigurationVersion, World.Time.WorldTime, group.GroupIndex, recyclableMemoryStream, World.StateVersion, World.SyncTick, async: false);
					messages.Add(item);
				}
				else
				{
					recyclableMemoryStream.Dispose();
				}
			}
			if (flag)
			{
				_lastStreamMessageTime = DateTime.UtcNow;
			}
			else if (World.IsAuthority && (DateTime.UtcNow - _lastStreamMessageTime).TotalSeconds >= 0.5)
			{
				_lastStreamMessageTime = DateTime.UtcNow;
				RecyclableMemoryStream data = (RecyclableMemoryStream)SyncMessage.StreamManager.GetStream();
				StreamMessage item2 = new StreamMessage(World.LocalUser.ReferenceID, 0u, World.Time.RealWorldTime, ushort.MaxValue, data, World.StateVersion, World.SyncTick, async: false);
				messages.Add(item2);
			}
		}

		public void AsyncStreamEncode(Stream stream)
		{
			RecyclableMemoryStream recyclableMemoryStream = (RecyclableMemoryStream)SyncMessage.StreamManager.GetStream();
			BitBinaryWriterX bitBinaryWriterX = Pool.BorrowBitBinaryWriter(new BitWriterStream(recyclableMemoryStream));
			StreamGroup streamGroup = World.LocalUser.StreamGroupManager.GetGroup(stream.GroupIndex);
			RefID referenceID = World.LocalUser.ReferenceID;
			uint lastConfigurationVersion = streamGroup.LastConfigurationVersion;
			double realWorldTime = World.Time.RealWorldTime;
			ushort groupIndex = stream.GroupIndex;
			ulong stateVersion = World.StateVersion;
			ulong syncTick = World.SyncTick;
			bitBinaryWriterX.Write7BitEncoded((ulong)stream.ReferenceID);
			bool flag = stream.AsyncEncode(bitBinaryWriterX);
			if (World.Session != null && flag)
			{
				StreamMessage stream2 = new StreamMessage(referenceID, lastConfigurationVersion, realWorldTime, groupIndex, recyclableMemoryStream, stateVersion, syncTick, async: true);
				World.Session.Messages.Outgoing.EnqueueStreamMessage(stream2, isOrigin: true);
				_lastStreamMessageTime = DateTime.UtcNow;
			}
			else
			{
				recyclableMemoryStream.Dispose();
			}
		}

		public void AsyncStreamDecodeAndDispose(StreamMessage message)
		{
			bool flag = false;
			BitBinaryReaderX bitBinaryReaderX = null;
			try
			{
				if (!message.IsAsynchronous)
				{
					throw new InvalidOperationException("StreamMessage is synchronous, expecting asynchronous");
				}
				User user = World.TryGetUser(message.UserID);
				if (user == null)
				{
					return;
				}
				if (user.IsHost)
				{
					World.Session.Sync.ScheduleSyncWorldTime(message);
				}
				if (user.StreamConfigurationVersion != message.StreamStateVersion)
				{
					return;
				}
				bitBinaryReaderX = Pool.BorrowBitBinaryReader(new BitReaderStream(message.GetData()));
				ulong num = bitBinaryReaderX.Read7BitEncoded();
				IStream stream = user.GetStream(num);
				if (stream.ReferenceID != num)
				{
					return;
				}
				try
				{
					stream.AsyncDecodeAndDispose(bitBinaryReaderX, message);
					flag = true;
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception running AsyncDecode on a stream: {stream}\nStreamID: {(RefID)num}\n{value}", stackTrace: false);
				}
				finally
				{
				}
			}
			finally
			{
				if (!flag)
				{
					bitBinaryReaderX?.BaseStream?.Dispose();
					message.Dispose();
				}
			}
		}

		public void ApplyStreams(StreamMessage message)
		{
			if (message.IsAsynchronous)
			{
				throw new InvalidOperationException("StreamMessage is asynchronous, expecting synchronous");
			}
			if (message.StreamTime - World.Time.WorldTime < -4.0)
			{
				return;
			}
			User user = World.TryGetUser(message.UserID);
			if (user == null)
			{
				return;
			}
			if (user.IsHost)
			{
				World.Time.SyncWorldTime(message.StreamTime, message.SecondsSinceReceived);
			}
			if (message.StreamGroup == ushort.MaxValue || user.StreamConfigurationVersion != message.StreamStateVersion)
			{
				return;
			}
			BitReaderStream bitReaderStream = new BitReaderStream(message.GetData());
			BitBinaryReaderX reader = Pool.BorrowBitBinaryReader(bitReaderStream);
			int num = 0;
			foreach (Stream stream2 in user.Streams)
			{
				if (stream2.Active && stream2.GroupIndex == message.StreamGroup && stream2.IsImplicitUpdatePoint(message.SenderSyncTick))
				{
					try
					{
						CurrentlyDecodingStream = stream2;
						stream2.Decode(reader, message);
						num++;
						CurrentlyDecodingStream = null;
					}
					catch (Exception value)
					{
						UniLog.Error($"Exception decoding implicit update point for stream: {stream2}\nGroupIndex: {stream2.GroupIndex}\nStream Message: {message}\n{value}", stackTrace: false);
						return;
					}
				}
			}
			RawValueList<ulong> list = Pool.BorrowRawValueList<ulong>();
			reader.ReadDeltaCodedSequence(list);
			foreach (ulong item in list)
			{
				IStream stream = user.GetStream(item);
				try
				{
					CurrentlyDecodingStream = stream;
					stream.Decode(reader, message);
					CurrentlyDecodingStream = null;
				}
				catch (Exception value2)
				{
					UniLog.Error($"Exception decoding explicit update point for stream: {stream}\nStream Sequence: {string.Join(", ", ((IEnumerable<ulong>)list).Select((Func<ulong, RefID>)((ulong s) => s)))}\nStream Message: {message}\n{value2}", stackTrace: false);
					return;
				}
			}
			bitReaderStream.Close();
			Pool.Return(ref list);
			Pool.Return(ref reader);
		}
