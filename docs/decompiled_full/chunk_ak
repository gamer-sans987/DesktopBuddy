		public string GenerateUnresolvedReferencesReport()
		{
			StringBuilder stringBuilder = new StringBuilder();
			Dictionary<Guid, List<ISyncRef>> unresolvedRequests = ReferenceTranslator.GetUnresolvedRequests();
			StringBuilder stringBuilder2 = stringBuilder;
			StringBuilder stringBuilder3 = stringBuilder2;
			StringBuilder.AppendInterpolatedStringHandler handler = new StringBuilder.AppendInterpolatedStringHandler(18, 1, stringBuilder2);
			handler.AppendLiteral("Unresolved count: ");
			handler.AppendFormatted(unresolvedRequests.Count);
			stringBuilder3.AppendLine(ref handler);
			foreach (KeyValuePair<Guid, List<ISyncRef>> item in unresolvedRequests)
			{
				stringBuilder2 = stringBuilder;
				StringBuilder stringBuilder4 = stringBuilder2;
				handler = new StringBuilder.AppendInterpolatedStringHandler(4, 2, stringBuilder2);
				handler.AppendLiteral("\t");
				handler.AppendFormatted(item.Key);
				handler.AppendLiteral(" (");
				handler.AppendFormatted(item.Value.Count);
				handler.AppendLiteral(")");
				stringBuilder4.AppendLine(ref handler);
				foreach (ISyncRef item2 in item.Value)
				{
					stringBuilder2 = stringBuilder;
					StringBuilder stringBuilder5 = stringBuilder2;
					handler = new StringBuilder.AppendInterpolatedStringHandler(2, 1, stringBuilder2);
					handler.AppendLiteral("\t\t");
