		private T DrawMesh<T>(in Elements.Core.float3 position, in Elements.Core.colorX color, float duration) where T : Component, IAssetProvider<Mesh>, new()
		{
			if (!debugMeshes.TryGetValue(typeof(T), out DebugMeshList value))
			{
				value = new DebugMeshList();
				debugMeshes.Add(typeof(T), value);
			}
			DebugMesh debugMesh;
			if (value.used < value.meshes.Count)
			{
				debugMesh = value.meshes[value.used++];
			}
			else
			{
				AttachedModel<T, OverlayFresnelMaterial> attachedModel = LocalDebugRoot.AddSlot("DebugMesh").AttachMesh<T, OverlayFresnelMaterial>();
				SetupDebugMaterial(attachedModel.material);
				debugMesh = new DebugMesh(attachedModel.mesh, attachedModel.material);
				value.meshes.Add(debugMesh);
				value.used++;
			}
			debugMesh.duration = duration;
			debugMesh.mesh.Slot.GlobalPosition = position;
			GizmoHelper.SetMaterialColor(debugMesh.material, color);
			return (T)debugMesh.mesh;
		}

