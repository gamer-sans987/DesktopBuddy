	public class PrioritySyncRefList<T> : SyncObject, IEnumerable<T>, IEnumerable where T : class, IWorldElement
	{
		public class ListItem : SyncObject
		{
			public readonly SyncRef<T> Target;

			public readonly Sync<int> Priority;

			protected override void InitializeSyncMembers()
			{
				base.InitializeSyncMembers();
				Target = new SyncRef<T>();
				Priority = new Sync<int>();
			}

			public override ISyncMember GetSyncMember(int index)
			{
				return index switch
				{
					0 => Target, 
					1 => Priority, 
					_ => throw new ArgumentOutOfRangeException(), 
				};
			}

			public static PrioritySyncRefList<T>.ListItem __New()
			{
				return new ListItem();
			}
		}

		private readonly struct ItemData
		{
			public readonly SyncRef<T> reference;

			public readonly int priority;

			public ItemData(SyncRef<T> reference, int priority)
			{
				this.reference = reference;
				this.priority = priority;
			}
		}

		public readonly SyncList<ListItem> Items;

		private bool _orderValid;

		private List<ItemData> _itemData = new List<ItemData>();

		public int Count => Items.Count;

		public SyncRef<T> this[int index]
		{
			get
			{
				EnsureValidOrder();
				return _itemData[index].reference;
			}
		}

		public void Add(T target, int priority)
		{
			ListItem listItem = Items.Add();
			listItem.Target.Target = target;
			listItem.Priority.Value = priority;
		}

		public bool Remove(T target)
		{
			int num = Items.FindIndex((ListItem i) => i.Target.Target == target);
			if (num < 0)
			{
				return false;
			}
			Items.RemoveAt(num);
			return true;
		}

		protected override void OnAwake()
		{
			base.OnAwake();
			Items.Changed += Items_Changed;
		}

		private void Items_Changed(IChangeable obj)
		{
			_orderValid = false;
		}

		public void EnsureValidOrder()
		{
			if (_orderValid)
			{
				return;
			}
			_itemData.Clear();
			foreach (ListItem item in Items)
			{
				_itemData.Add(new ItemData(item.Target, item.Priority));
			}
			_itemData.Sort(delegate(ItemData a, ItemData b)
			{
				int num = -a.priority.CompareTo(b.priority);
				return (num != 0) ? num : a.reference.ReferenceID.CompareTo(b.reference.ReferenceID);
			});
			_orderValid = true;
		}

		public IEnumerator<T> GetEnumerator()
		{
			EnsureValidOrder();
			foreach (ItemData itemDatum in _itemData)
			{
				yield return itemDatum.reference.Target;
			}
		}

		IEnumerator IEnumerable.GetEnumerator()
		{
			return GetEnumerator();
		}

		protected override void InitializeSyncMembers()
