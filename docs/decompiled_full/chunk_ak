		public async Task<Uri> SaveLocally(SavedGraph graph, Uri uri)
		{
			saveRoot = true;
			return await Process(graph, uri).ConfigureAwait(continueOnCapturedContext: false);
		}

		public async Task EnsurePermanentStorage(SavedGraph graph)
		{
			saveRoot = false;
			await Process(graph, null).ConfigureAwait(continueOnCapturedContext: false);
		}

		protected override async Task<string> Gather(Uri uri)
		{
			AssetRecord assetRecord = await LocalDB.TryFetchAssetRecordAsync(uri).ConfigureAwait(continueOnCapturedContext: false);
			if (assetRecord == null)
			{
				return await AssetManager.GatherAssetFile(uri, 100f).ConfigureAwait(continueOnCapturedContext: false);
			}
			return assetRecord.path;
		}

		protected override async Task PostprocessGraph(SavedGraph graph, Uri oldGraphUrl, Uri newGraphUrl)
		{
			if (!(oldGraphUrl == null) || saveRoot)
			{
				string tempFilePath = LocalDB.GetTempFilePath(Format);
				DataTreeConverter.Save(graph.Root, tempFilePath, (!UseHeavyCompression) ? DataTreeConverter.Compression.LZ4 : DataTreeConverter.Compression.Brotli);
				await LocalDB.ImportLocalAssetAsync(tempFilePath, FrooxEngine.Store.LocalDB.ImportLocation.Move, Path.GetFileNameWithoutExtension(newGraphUrl.AbsolutePath));
			}
		}

		protected override async Task<Uri> PreprocessGraph(SavedGraph graph, Uri oldGraphUrl)
		{
			return LocalDB.GenerateLocalURL(Format);
		}

		protected override async Task<Uri> ProcessAsset(Uri uri)
		{
			if (!File.Exists(await Gather(uri).ConfigureAwait(continueOnCapturedContext: false)))
			{
				UniLog.Warning($"Could not gather {uri}, cannot ensure permanent storage");
				return uri;
			}
			return await LocalDB.EnsurePermanentStorageAsync(uri).ConfigureAwait(continueOnCapturedContext: false);
		}

		protected override bool ShouldProcess(Uri uri)
		{
			if (uri.Scheme == "local")
			{
				return uri.Host != LocalDB.MachineID;
			}
			return false;
		}
	}
