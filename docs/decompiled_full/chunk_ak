			}
			else
			{
				TextRenderer text2 = LocalDebugRoot.AddSlot("DebugText").AttachComponent<TextRenderer>();
				debugText = new DebugText();
				debugText.text = text2;
				debugTexts.Add(debugText);
				usedTexts++;
			}
			debugText.duration = duration;
			debugText.text.Text.Value = text;
			debugText.text.Color.Value = color;
			debugText.text.Size.Value = size;
			debugText.text.Slot.GlobalPosition = position;
			debugText.text.Slot.GlobalRotation = Elements.Core.floatQ.LookRotation(position - World.LocalUserViewPosition, Elements.Core.float3.Up);
