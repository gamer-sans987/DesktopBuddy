		public static void FixReference(ISyncRef reference)
		{
			if (reference.Target != null || reference.Value == RefID.Null)
			{
				return;
			}
			IWorldElement worldElement = reference.World.ReferenceController.GetObjectOrNull(reference.Value);
			if (worldElement == null || worldElement is UnresolvedReferences.UnresolvedReference)
			{
				return;
			}
			try
			{
				IWorldElement remappedOutput = GetRemappedOutput(reference, worldElement);
				if (remappedOutput != worldElement && reference.TrySet(remappedOutput))
				{
					return;
				}
				worldElement = remappedOutput;
				Slot slot = reference.FindNearestParent<Slot>();
				Type type = worldElement.GetType();
				Type type2 = ExtractNodeValueOutputType(reference.TargetType);
				Type type3 = ExtractNodeObjectOutputType(reference.TargetType);
				Type type4 = null;
				if (type.IsGenericType)
				{
					type4 = type.GetGenericTypeDefinition();
				}
				if (worldElement is IDataModelStore dataModelStore)
				{
					reference.TrySet(dataModelStore.RootDataModelElement);
					return;
				}
				if (type4 == ProtoFluxHelper.GetBindingForNode(typeof(ValueSource<>)) || type4 == ProtoFluxHelper.GetBindingForNode(typeof(ObjectValueSource<>)))
				{
					Type type5 = ExtractNodeObjectOutputType(reference.TargetType);
					if (type5.IsGenericType)
					{
						Type genericTypeDefinition = type5.GetGenericTypeDefinition();
						if (genericTypeDefinition == typeof(IField<>) || genericTypeDefinition == typeof(IValue<>))
						{
							Slot slot2 = slot.Parent.AddSlot("INJECTED FieldSource");
							slot2.CopyTransform(slot);
							ISource source = (ISource)slot2.AttachComponent(ProtoFluxHelper.GetSourceNode(type5));
							source.TrySetRootSource(((ISource)worldElement).RootSourceReference.Target);
							reference.Target = source;
							return;
						}
					}
				}
				if (type3 != null && type3.IsGenericType && type3.GetGenericTypeDefinition() == typeof(IVariable<, >))
				{
					if (type == ProtoFluxHelper.GetBindingForNode(typeof(SlotRefSource)))
					{
						Slot slot3 = slot.Parent.AddSlot("INJECTED ReferenceAsVariable");
						slot3.CopyTransform(slot);
						ProtoFluxNode protoFluxNode = (ProtoFluxNode)slot3.AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(ReferenceAsVariable<>)).MakeGenericType(typeof(Slot)));
						protoFluxNode.NodeInputs.First().Target = GetRemappedOutput(reference, worldElement);
						reference.Target = protoFluxNode;
						return;
					}
					if (type == ProtoFluxHelper.GetBindingForNode(typeof(UserRefSource)))
					{
						Slot slot4 = slot.Parent.AddSlot("INJECTED UserRefAsVariable");
						slot4.CopyTransform(slot);
						ProtoFluxNode protoFluxNode2 = (ProtoFluxNode)slot4.AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(UserRefAsVariable)));
						protoFluxNode2.NodeInputs.First().Target = GetRemappedOutput(reference, worldElement);
						reference.Target = protoFluxNode2;
						return;
					}
					if (type4 == ProtoFluxHelper.GetBindingForNode(typeof(ElementSource<>)))
					{
						Type elementType = type.GenericTypeArguments[0];
						if (InjectAsVariable(reference, slot, elementType, worldElement))
						{
							return;
						}
					}
					foreach (Type item in type.EnumerateInterfacesRecursively())
					{
						if (item.IsGenericType && item.GetGenericTypeDefinition() == typeof(INodeObjectOutput<>))
						{
							Type elementType2 = item.GenericTypeArguments[0];
							if (InjectAsVariable(reference, slot, elementType2, worldElement))
							{
								return;
							}
						}
					}
				}
				if (worldElement is ISyncRef && type2 == typeof(RefID))
				{
					Slot slot5 = slot.Parent.AddSlot("INJECTED FieldSource");
					slot5.CopyTransform(slot);
					ISource source2 = (ISource)slot5.AttachComponent(ProtoFluxHelper.GetSourceNode(typeof(RefID)));
					source2.TrySetRootSource(worldElement);
					reference.Target = source2;
					return;
				}
				if (type2 != null && worldElement is IField field && field.ValueType == type2)
				{
					Slot slot6 = slot.Parent.AddSlot("INJECTED SOURCE");
					slot6.CopyTransform(slot);
					UniLog.Log($"INJECTING source for reference {reference.Name} ({reference.TargetType}) on {reference.Parent.Name}");
					ISource source3 = (ISource)slot6.AttachComponent(ProtoFluxHelper.GetSourceNode(type2));
					source3.RootSourceReference.TrySet(worldElement);
					reference.Target = source3;
					return;
				}
				if (type3 != null && worldElement is IField field2 && field2.ValueType == type3)
				{
					Slot slot7 = slot.Parent.AddSlot("INJECTED SOURCE");
					slot7.CopyTransform(slot);
					UniLog.Log($"INJECTING source for reference {reference.Name} ({reference.TargetType}) on {reference.Parent.Name}");
					ISource source4 = (ISource)slot7.AttachComponent(ProtoFluxHelper.GetSourceNode(type3));
					source4.RootSourceReference.TrySet(worldElement);
					reference.Target = source4;
					return;
				}
				if (worldElement is ProtoFluxNode protoFluxNode3)
				{
					Type type6 = protoFluxNode3.NodeType.EnumerateInterfacesRecursively().FirstOrDefault(delegate(Type t)
					{
						if (!t.IsGenericType)
						{
							return false;
						}
						return (t.GetGenericTypeDefinition() == typeof(IVariable<, >)) ? true : false;
					});
					if (type6 != null)
					{
						Slot slot8 = reference.FindNearestParent<Slot>();
						Slot slot9 = slot8.Parent.AddSlot("INJECTED ReferenceToProxy");
						slot9.CopyTransform(slot8);
						Type bindingForNode = ProtoFluxHelper.GetBindingForNode(typeof(ReferenceToOutput<>));
						bindingForNode = bindingForNode.MakeGenericType(type6);
						Component component = (Component)(reference.Target = slot9.AttachComponent(bindingForNode));
						((ISyncRef)component.GetSyncMember("Reference")).TrySet(worldElement);
						return;
					}
				}
				UniLog.Log("UNSUPPORTED RAW TARGET: " + worldElement?.ParentHierarchyToString() + $"\nRAW TARGET TYPE: {worldElement?.GetType()}\nREFERENCE: " + reference?.ParentHierarchyToString());
			}
			catch (Exception value)
			{
				UniLog.Error($"EXCEPTION FIXING REFERENCE: {reference.ParentHierarchyToString()}\nRawTarget: {worldElement}\n{value}");
			}
		}

		private static IWorldElement GetRemappedOutput(ISyncRef reference, IWorldElement rawTarget)
		{
			if (!typeof(INodeOutput).IsAssignableFrom(reference.TargetType))
			{
				return rawTarget;
			}
			if (!(rawTarget is ProtoFluxNode protoFluxNode))
			{
				return rawTarget;
			}
			if (protoFluxNode is INodeOutput)
			{
				return rawTarget;
			}
			if (ExtractNodeOutputType(reference.TargetType) == null)
			{
				return rawTarget;
			}
			if (protoFluxNode.NodeOutputCount == 1)
			{
				return protoFluxNode.NodeOutputs.First();
			}
			if (protoFluxNode.GetSyncMember("Output") != null)
			{
				return protoFluxNode.GetSyncMember("Output");
			}
			UniLog.Log("UNABLE TO DETERMINE NODE OUTPUT. " + string.Join(", ", protoFluxNode.NodeOutputs.Select((INodeOutput o) => o.Name)));
			return rawTarget;
		}

		private static bool InjectAsVariable(ISyncRef reference, Slot targetSlot, Type elementType, IWorldElement rawTarget)
		{
			UniLog.Log($"ElementSource: {elementType}");
			if (elementType == typeof(UserRef))
			{
				Slot slot = targetSlot.Parent.AddSlot("INJECTED UserRefAsVariable");
				slot.CopyTransform(targetSlot);
				ProtoFluxNode protoFluxNode = (ProtoFluxNode)slot.AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(UserRefAsVariable)));
