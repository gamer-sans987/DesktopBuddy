	public class SessionSyncManager : IDisposable
	{
		private ConcurrentQueue<SyncMessage> messagesToProcess = new ConcurrentQueue<SyncMessage>();

		private ConcurrentQueue<IConnection> closedConnections = new ConcurrentQueue<IConnection>();

		private Dictionary<ulong, HashSet<RefID>> changesToConfirm = new Dictionary<ulong, HashSet<RefID>>();

		private List<User> newUsersToInitialize = new List<User>();

		private FullBatch _initialState;

		private TaskCompletionSource<bool> _initialStateDecoded;

		private StreamMessage _syncWorldTime;

		private Thread syncThread;

		private ManualResetEventSlim lastProcessingStopped = new ManualResetEventSlim(initialState: true);

		private AutoResetEvent syncThreadEvent = new AutoResetEvent(initialState: false);

		private AutoResetEvent syncThreadInitEvent = new AutoResetEvent(initialState: false);

		private AutoResetEvent worldUpdateFinished = new AutoResetEvent(initialState: false);

		private SpinLock processingLoopLock = new SpinLock(enableThreadOwnerTracking: false);

		private volatile bool stopProcessing;

		public Session Session { get; private set; }

		public World World => Session.World;

		public SessionConnectionManager Connections => Session.Connections;

		public SessionMessageManager Messages => Session.Messages;

		public int LastGeneratedDeltaChanges { get; private set; }

		public int TotalCorrections { get; private set; }

		public int TotalProcessedMessages { get; private set; }

		public bool InitialStateLoaded { get; private set; }

		public int MessagesToProcessCount => messagesToProcess.Count;

		private bool HasMessagesToProcess
		{
			get
			{
				if (!InitialStateLoaded)
				{
					return _initialState != null;
				}
				return messagesToProcess.Count > 0;
			}
		}

		public SyncLoopStage SyncLoopStage { get; private set; }

		public SyncMessage CurrentlyProcessingSyncMessage { get; private set; }

		public bool StopProcessingFlag => stopProcessing;

		public SessionSyncManager(Session session)
		{
			Session = session;
			syncThread = new Thread(SyncLoopRunner);
			syncThread.IsBackground = true;
			syncThread.Priority = ThreadPriority.AboveNormal;
			syncThread.Name = "Message Processing";
		}

		internal void ScheduleUserToInitialize(User user)
		{
			newUsersToInitialize.Add(user);
		}

		internal void EnqueueForSyncProcessing(SyncMessage message)
		{
			messagesToProcess.Enqueue(message);
			syncThreadEvent.Set();
		}

		internal async Task<bool> DecodeInitialState(FullBatch fullBatch)
		{
			if (!fullBatch.IsInitialState)
			{
				throw new ArgumentException("Provided full batch is not initial state");
			}
			if (_initialState != null)
			{
				throw new ArgumentException("Initial state has already been provided");
			}
			_initialStateDecoded = new TaskCompletionSource<bool>();
			_initialState = fullBatch;
			syncThreadEvent.Set();
			return await _initialStateDecoded.Task;
		}

		internal void ScheduleSyncWorldTime(StreamMessage message)
		{
			_syncWorldTime = message;
		}

		internal void ResumeProcessing()
		{
			lastProcessingStopped.Wait();
			lastProcessingStopped.Reset();
			World.ConnectorManager.DataModelLock(syncThread);
			stopProcessing = false;
			worldUpdateFinished.Set();
		}

		internal void StopProcessing()
		{
			stopProcessing = true;
			bool lockTaken = false;
			processingLoopLock.TryEnter(TimeSpan.FromSeconds(15L), ref lockTaken);
			if (!lockTaken)
			{
				throw new Exception("Failed to take processing loop lock");
			}
			if (Session.IsDisposed)
			{
				throw new Exception("Session has been disposed");
			}
			World.ConnectorManager.DataModelUnlock();
			World.ConnectorManager.ImplementerLock(Thread.CurrentThread);
			SyncLoopStage = SyncLoopStage.ExitedMessageProcessing;
			if (World.IsAuthority)
			{
				World.IncrementStateVersion();
			}
			World.Coroutines.ExecuteSyncQueue();
			ProcessClosedConnections();
			syncThreadEvent.Set();
		}

		private void ProcessClosedConnections()
		{
			IConnection result;
			while (closedConnections.TryDequeue(out result))
			{
				if (World.IsAuthority && Connections.TryGetUser(result, out User user))
				{
					World.RemoveUser(user);
				}
				Connections.RemoveConnection(result);
			}
		}

		private void InitializeNewUsers()
		{
			if (newUsersToInitialize.Count != 0)
			{
				SyncLoopStage = SyncLoopStage.InitializingNewUsers;
				DateTime utcNow = DateTime.UtcNow;
				FullBatch fullBatch = World.SyncController.EncodeFullBatch();
				TimeSpan value = DateTime.UtcNow - utcNow;
				UniLog.Log($"World initial state captured in: {value}");
				Connections.GetConnections(newUsersToInitialize, fullBatch.Targets);
				Messages.Outgoing.EnqueueForTransmission(fullBatch, isOrigin: true, useBackgroundEncoder: true);
				newUsersToInitialize.Clear();
			}
		}

		internal void StartSyncLoop(bool isHost)
		{
			if (isHost)
			{
				InitialStateLoaded = true;
			}
			syncThread.Start();
			syncThreadInitEvent.WaitOne();
			syncThreadInitEvent.Dispose();
			syncThreadInitEvent = null;
		}

		private void SyncLoopRunner()
		{
			try
			{
				SyncLoop();
			}
			catch (Exception exception)
			{
				UniLog.Error($"Exception in running sync loop:\n\n{DebugManager.PreprocessException(exception)}");
				try
				{
					World?.Destroy();
				}
				catch
				{
				}
				try
				{
					Dispose();
				}
				catch
				{
				}
				try
				{
					processingLoopLock.Exit();
				}
				catch
				{
				}
			}
		}

		private void SyncLoop()
		{
			ulong lastDeltaSyncTime = 0uL;
			World.ConnectorManager.DataModelLock(Thread.CurrentThread);
			syncThreadInitEvent.Set();
			while (true)
			{
				RunMessageProcessing(lastDeltaSyncTime);
				worldUpdateFinished.WaitOne();
				SyncLoopStage = SyncLoopStage.ContinuingAfterRefreshFinished;
				if (Session.IsDisposed)
				{
					break;
				}
				GenerateDeltaBatchAndSend();
				GenerateCorrectionsAndSend();
				GenerateStreamsAndSend();
				SyncLoopStage = SyncLoopStage.FinishingSyncCycle;
				lastDeltaSyncTime = World.StateVersion;
				World.FinishSyncCycle();
				InitializeNewUsers();
				processingLoopLock.Exit();
				SyncLoopStage = SyncLoopStage.Finished;
			}
			processingLoopLock.Exit();
			worldUpdateFinished.Dispose();
		}

		private void RunMessageProcessing(ulong lastDeltaSyncTime)
		{
			bool runMessageProcessing = true;
			while (!stopProcessing)
			{
				SyncLoopStage = SyncLoopStage.WaitingForSyncThreadEvent;
				if (!runMessageProcessing || !HasMessagesToProcess)
				{
					syncThreadEvent.WaitOne();
				}
				if (Session.IsDisposed)
				{
					syncThreadEvent.Dispose();
					return;
				}
				if (stopProcessing)
				{
