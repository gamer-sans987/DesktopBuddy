		private static void FixImpulse(ProtoFluxNode node, ISyncRef impulse, DataTreeDictionary dict, LoadControl control)
		{
			if (impulse.Target == null && impulse.Value != RefID.Null)
			{
				IWorldElement objectOrNull = impulse.World.ReferenceController.GetObjectOrNull(impulse.Value);
				if (objectOrNull is ProtoFluxNode protoFluxNode)
				{
					if (!(protoFluxNode is IAsyncNodeOperation))
					{
						string text = ((DataTreeDictionary)dict["Data"]).ExtractOrDefault<string>("Method");
						if (text != null)
						{
							INodeOperation nodeOperation = null;
							int num = 0;
							foreach (INodeOperation nodeOperation2 in protoFluxNode.NodeOperations)
							{
								if (IsValidCandidate(text, nodeOperation2.Name) && (nodeOperation == null || nodeOperation2.Name.Length > num))
								{
									nodeOperation = nodeOperation2;
									num = nodeOperation2.Name.Length;
								}
							}
							if (nodeOperation != null)
							{
								impulse.Target = nodeOperation;
							}
							else
							{
								UniLog.Log($"FAILED TO REMAP IMPULSE {impulse.Name} on {node}\nRawTarget: {protoFluxNode}\nOperation: {text}");
							}
						}
					}
				}
				else if (objectOrNull is Component)
				{
					Slot slot = node.Slot.Parent.AddSlot("INJECTED SYNCMETHOD PROXY");
					ProtoFluxNode protoFluxNode2 = (ProtoFluxNode)slot.AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(SyncMethodProxy)));
					GlobalDelegate<Action> globalDelegate = slot.AttachComponent<GlobalDelegate<Action>>();
					try
					{
						control.AssociateReferences = false;
						globalDelegate.Delegate.Load(dict, control);
					}
					finally
					{
						control.AssociateReferences = true;
					}
					protoFluxNode2.GetGlobalRef(0).Target = globalDelegate;
					impulse.Target = protoFluxNode2;
				}
			}
			InjectStartAsyncTask(node, impulse);
		}

		public static void InjectStartAsyncTask(ProtoFluxNode node, ISyncRef impulse)
		{
			IAsyncNodeOperation targetAsyncOperation = GetTargetAsyncOperation(impulse);
			if (targetAsyncOperation != null)
			{
				Slot slot = node.Slot.Parent.AddSlot("INJECTED START ASYNC TASK");
				slot.CopyTransform(node.Slot);
				ProtoFluxNode protoFluxNode = (ProtoFluxNode)slot.AttachComponent(ProtoFluxHelper.GetBindingForNode(ProtoFluxHelper.StartAsyncTask));
				protoFluxNode.NodeImpulses.First().Target = targetAsyncOperation;
				impulse.Target = protoFluxNode;
				UniLog.Log("Injected Start Async Task " + impulse.Name + " -> " + targetAsyncOperation.Name);
			}
		}

		public static IAsyncNodeOperation GetTargetAsyncOperation(ISyncRef impulse)
		{
			if (impulse.Target is IAsyncNodeOperation result)
			{
