					RejectJoin("World.Error.UnhandledError");
				}
			});
		}

		private async Task PerformJoinHandshake(ControlMessage joinRequest)
		{
			if (BanManager.IsTempBanned(Connection))
			{
				throw new SessionRejectJoinException("World.Error.SecurityViolation", "User is temporarily banned");
			}
			if (!World.HasFreeUserCapacity)
			{
				throw new SessionRejectJoinException("World.Error.UserLimitReached", "World has ran out of capacity for users");
			}
			CheckExpectedSessionId(joinRequest);
			ExtractUserData(joinRequest);
			await SendJoinChallenge();
			await VerifyJoinIdentity(await ReceiveResponse(ControlMessage.Message.JoinAuthenticate));
			await default(ToSync);
			JoinGrant joinGrant = await World.VerifyJoinRequest(this);
			if (!joinGrant.granted)
			{
				throw new SessionRejectJoinException(joinGrant.rejectReason, "World has rejected user join request");
			}
			await default(ToSync);
			if (Connection.IsOpen)
			{
				if (!World.HasFreeUserCapacity)
				{
					throw new SessionRejectJoinException("World.Error.UserLimitReached", "World has no free user capacity");
				}
				UniLog.Log("Join Granted For UserID: " + UserID + ", Username: " + Username);
				GrantJoinAndCreateUser();
				await ReceiveResponse(ControlMessage.Message.JoinRequestStartStreams);
				User.StartTransmittingStreamData();
			}
		}

		private void CheckExpectedSessionId(ControlMessage joinRequest)
		{
			string text = joinRequest.Data.ExtractOrDefault<string>("ExpectedSessionId");
			if (text == null || World.SessionId.Equals(text, StringComparison.InvariantCultureIgnoreCase))
			{
				return;
			}
			throw new SessionRejectJoinException("World.Error.SessionEnded", "Expected session ID is different");
		}

		private void ExtractUserData(ControlMessage joinRequest)
		{
			try
			{
				MachineID = joinRequest.Data.ExtractOrThrow<string>("MachineID");
				MachinePublicKey = new RSAParameters
				{
					Exponent = Convert.FromBase64String(joinRequest.Data.ExtractOrThrow<string>("MachinePublicKeyExponent")),
					Modulus = Convert.FromBase64String(joinRequest.Data.ExtractOrThrow<string>("MachinePublicKeyModulus"))
				};
				UserID = joinRequest.Data.ExtractOrDefault<string>("UserID");
				UserSessionID = joinRequest.Data.ExtractOrDefault<string>("UserSessionID");
				Username = joinRequest.Data.ExtractOrDefault<string>("UserName");
				HeadDevice = joinRequest.Data.ExtractOrThrow<HeadOutputDevice>("HeadDevice");
				Platform = joinRequest.Data.ExtractOrThrow<Platform>("Platform");
				if (!VersionNumber.TryParse(joinRequest.Data.ExtractOrThrow<string>("EngineVersionNumber"), out var version) || (version != FrooxEngine.Engine.Version && !version.IsValid))
				{
					throw new Exception("Engine version number is not valid");
				}
				EngineVersionNumber = version;
				RendererName = joinRequest.Data.ExtractOrThrow<string>("RendererName");
				RuntimeVersion = joinRequest.Data.ExtractOrThrow<string>("RuntimeVersion");
				if (RendererName.Length > 256)
				{
					throw new Exception("Renderer name is too long");
				}
				if (RuntimeVersion.Length > 128)
				{
					throw new Exception("Runtime version is too long");
				}
				DeviceInfos = joinRequest.Data.TryGetList("Devices");
				if (UserID != null)
				{
					banAccessKey = joinRequest.Data.ExtractOrThrow<string>("BanAccessKeyId");
				}
				HasEyeTracking = joinRequest.Data.ExtractOrThrow<bool>("EyeTracking");
				HasPupilTracking = joinRequest.Data.ExtractOrThrow<bool>("PupilTracking");
				MouthTrackingParameters = (from n in joinRequest.Data.TryGetList("MouthTracking")
					select ((DataTreeValue)n).ExtractEnum<MouthParameterGroup>()).ToList();
				KioskMode = joinRequest.Data.ExtractOrDefault("KioskMode", def: false);
				hostVerificationToken = Convert.FromBase64String(joinRequest.Data.ExtractOrThrow<string>("HostVerificationToken"));
				ExtraIDs = new Dictionary<string, string>();
				DataTreeDictionary dataTreeDictionary = joinRequest.Data.TryGetDictionary("ExtraIds");
				if (dataTreeDictionary != null)
				{
					foreach (KeyValuePair<string, DataTreeNode> child in dataTreeDictionary.Children)
					{
						ExtraIDs.Add(child.Key, child.Value.LoadString());
					}
				}
			}
			catch (Exception ex)
			{
				throw new SessionRejectJoinException("World.Error.SecurityViolation", "Exception processing join request: " + ex.Message, tempBan: false, ex);
			}
			if (!IsUserDataValid())
			{
				BanManager.TempBanConnection(Connection);
				throw new SessionRejectJoinException("World.Error.SecurityViolation", "Invalid user data");
			}
			identityHash = CryptoHelper.GenerateCryptoBlob(64);
			if (UserID != null)
			{
				publicKeyTask = Cloud.Users.GetPublicKey(UserID, UserSessionID);
				userDataTask = Cloud.Users.GetUser(UserID, banAccessKey);
			}
		}

		private bool IsUserDataValid()
		{
			if (Username != null && Username.Length > 32)
			{
				return false;
			}
			if (!FrooxEngine.Store.LocalDB.IsValidMachineId(MachineID))
			{
				return false;
			}
			if (!HeadDevice.IsDefined())
			{
				return false;
			}
			if (!Platform.IsDefined())
			{
				return false;
			}
			if (UserID != null && string.IsNullOrWhiteSpace(banAccessKey))
			{
				return false;
			}
			return true;
		}

		private async Task SendJoinChallenge()
		{
			ControlMessage challenge = new ControlMessage(ControlMessage.Message.JoinChallenge);
			challenge.Targets.Add(Connection);
			challenge.Data.Add("IdentityHash", Convert.ToBase64String(identityHash));
			challenge.Data.Add("SessionID", World.SessionId);
			string val = Convert.ToBase64String(Crypto.SignMachineVerificationToken(hostVerificationToken, World.SessionId, host: true));
			challenge.Data.Add("HostMachineID", Engine.LocalDB.MachineID);
			challenge.Data.Add("MachinePublicKeyModulus", Convert.ToBase64String(Engine.LocalDB.PublicKeyModulus));
			challenge.Data.Add("MachinePublicKeyExponent", Convert.ToBase64String(Engine.LocalDB.PublicKeyExponent));
			challenge.Data.Add("MachineVerificationSignature", val);
			if (World.HostUser.UserID != null)
			{
				challenge.Data.Add("HostUserID", World.HostUser.UserID);
				challenge.Data.Add("HostUserSessionID", World.HostUser.UserSessionId);
				string val2 = Convert.ToBase64String(Crypto.SignCloudVerificationToken(hostVerificationToken, World.SessionId, host: true));
				challenge.Data.Add("CloudVerificationSignature", val2);
				CloudResult<OneTimeVerificationKey> cloudResult = await Engine.Cloud.Security.CreateKey(null, VerificationKeyUse.AccessBans).ConfigureAwait(continueOnCapturedContext: false);
				if (!cloudResult.IsOK)
				{
					throw new SessionRejectJoinException("World.Error.FailedFetchingAuthentication", $"Failed to generate ban access key. Result: {cloudResult}");
				}
				challenge.Data.Add("BanAccessKeyId", cloudResult.Entity.KeyId);
			}
			challenge.Data.Add("SystemCompatibilityHash", GlobalTypeRegistry.SystemCompatibilityHash);
			DataTreeList dataTreeList = new DataTreeList();
			foreach (AssemblyTypeRegistry allowedAssembly in World.Types.AllowedAssemblies)
			{
				if (!allowedAssembly.IsDependency)
				{
					DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
					dataTreeDictionary.Add("Name", allowedAssembly.AssemblyName);
					dataTreeDictionary.Add("CompatibilityHash", allowedAssembly.CompatibilityHash);
					dataTreeList.Add(dataTreeDictionary);
				}
			}
			challenge.Data.Add("DataModelAssemblies", dataTreeList);
			Messages.Outgoing.EnqueueForTransmission(challenge, isOrigin: true, useBackgroundEncoder: false);
		}

		private async Task VerifyJoinIdentity(ControlMessage authentication)
		{
			string text = authentication.Data.ExtractOrDefault<string>("MachineIdentitySignature");
			if (text != null)
			{
				machineIdentitySignature = Convert.FromBase64String(text);
			}
			string text2 = authentication.Data.ExtractOrDefault<string>("CloudIdentitySignature");
			if (text2 != null)
			{
				cloudIdentitySignature = Convert.FromBase64String(text2);
			}
			if (machineIdentitySignature == null || machineIdentitySignature.Length == 0)
			{
				throw new SessionRejectJoinException("World.Error.FailedMachineID", "MachineID verification data cannot be missing");
			}
			if (!FrooxEngine.Store.LocalDB.MachineIdMatches(MachineID, MachinePublicKey) || !Crypto.VerifyToken(identityHash, World.SessionId, host: false, machineIdentitySignature, MachinePublicKey))
			{
				throw new SessionRejectJoinException("World.Error.FailedAuthentication", "Failed to validate MachineID");
			}
			if (UserID != null)
			{
				CloudResult<RSAParametersData> publicKeyResult = await publicKeyTask;
				CloudResult<SkyFrost.Base.User> cloudResult = await userDataTask;
				if (cloudResult.Entity == null)
				{
					throw new SessionRejectJoinException("World.Error.FailedUserID", $"Failed to authenaticate UserId: {UserID}, UserSessionId: {UserSessionID}. KeyResult: {publicKeyResult}. UserResult: {cloudResult}");
				}
				CloudUser = cloudResult.Entity;
				if (CloudUser.Username != Username)
				{
					throw new SessionRejectJoinException("World.Error.SecurityViolation", "Username mismatch", tempBan: true);
				}
				if (cloudIdentitySignature == null || cloudIdentitySignature.Length == 0 || publicKeyResult.Entity == null)
				{
					throw new SessionRejectJoinException("World.Error.FailedUserID", "Failed to get cloud identity signature data");
				}
				RSAParametersData entity = publicKeyResult.Entity;
				if (entity.Modulus == null || entity.Exponent == null)
				{
					throw new SessionRejectJoinException("World.Error.FailedFetchingAuthentication", "Failed to fetch authentication data");
				}
				if (!Crypto.VerifyToken(identityHash, World.SessionId, host: false, cloudIdentitySignature, entity))
				{
					throw new SessionRejectJoinException("World.Error.FailedAuthentication", "Failed to verify user cloud identity");
				}
				IdentityVerified = true;
			}
		}

		private void RejectJoin(string reason)
		{
			if (!Connection.IsOpen)
			{
				return;
			}
			ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.JoinReject);
			controlMessage.Targets.Add(Connection);
			controlMessage.Data.Add("Reason", reason);
			Messages.Outgoing.EnqueueForTransmission(controlMessage, isOrigin: true, useBackgroundEncoder: false);
			Task.Run(async delegate
			{
				try
				{
					await Task.Delay(TimeSpan.FromSeconds(5L)).ConfigureAwait(continueOnCapturedContext: false);
					if (Connection.IsOpen)
					{
						UniLog.Warning($"Connection {Connection} is still open after rejecting join, closing forcibly");
						Connection.Close();
					}
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception forcibly closing connection after rejecting join:\n{value}");
				}
			});
		}

		private void GrantJoinAndCreateUser()
		{
			ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.JoinGrant);
			controlMessage.Targets.Add(Connection);
			User = World.CreateGuestUser();
			User.InitializingEnabled = true;
			User.MachineID = MachineID;
			User.UserID = UserID;
			User.UserSessionId = UserSessionID;
			User.UserName = Username ?? ("Guest " + User.AllocationID);
			User.HeadDevice = HeadDevice;
			User.Platform = Platform;
			User.EngineVersionNumber = EngineVersionNumber.ToString();
			User.RendererName = RendererName;
			User.RuntimeVersion = RuntimeVersion;
			User.SetupDeviceInfos(DeviceInfos);
			User.SetupEyeTracking(HasEyeTracking, HasPupilTracking);
			User.SetupMouthTracking(MouthTrackingParameters);
			User.SetupExtraIds(ExtraIDs);
			User.KioskMode = KioskMode;
			if (SpectatorBan)
			{
				User.DefaultSpectator = true;
			}
			if (MuteBan)
			{
				User.DefaultMute = true;
			}
			if (World.Permissions.IsSilenced(User))
			{
				User.IsSilenced = true;
			}
			if (RoleOverride != null)
			{
				PermissionSet permissionSet = World.Permissions.FindRoleByName(RoleOverride);
				PermissionSet permissionSet2 = World.Permissions.FilterRole(permissionSet);
				if (permissionSet2 != permissionSet)
				{
					UniLog.Log($"Cannot use role override {RoleOverride} for {UserID}, because it's higher than the host role.");
				}
				if (permissionSet2 != null)
				{
					User.Role = permissionSet;
				}
			}
			if (User.Role == null)
			{
				User.Role = World.Permissions.GetDefaultRole(User);
			}
			User.InitializingEnabled = false;
			Connections.LinkConnectionToUser(this);
			controlMessage.Data.Add("ReferenceID", (ulong)User.ReferenceID);
			controlMessage.Data.Add("RandomizationSeed", World.RandomizationSeed);
			controlMessage.Data.Add("OBFK", Convert.ToBase64String(World.Obfuscation_KEY));
			controlMessage.Data.Add("OBFI", Convert.ToBase64String(World.Obfuscation_IV));
			Messages.Outgoing.EnqueueForTransmission(controlMessage, isOrigin: true, useBackgroundEncoder: false);
			Sync.ScheduleUserToInitialize(User);
		}

		public void Dispose()
		{
			Connection.Close();
		}
	}
	public class SessionConnectionManager : IDisposable
	{
		private SessionJoiner? _joiner;

		private readonly object _lock = new object();

		private readonly Dictionary<IConnection, SessionConnection> _connections = new Dictionary<IConnection, SessionConnection>();

		private readonly Dictionary<User, SessionConnection> _connectionsByUser = new Dictionary<User, SessionConnection>();

		public Session Session { get; private set; }

		public World? World => Session.World;

		[MemberNotNullWhen(true, new string[] { "World", "Network" })]
		private bool IsWorldValid
		{
			[MemberNotNullWhen(true, new string[] { "World", "Network" })]
			get
			{
				if (World != null)
				{
					return !World.IsDisposed;
				}
				return false;
			}
		}

		public NetworkManager? Network => Session.NetworkManager;

		public SessionMessageManager Messages => Session.Messages;

		public SessionListener? Listener { get; private set; }

		public IConnection? HostConnection { get; private set; }

		public LocaleString ConnectionStatusDescription { get; private set; }

		public LocaleString ConnectionStatusDetail { get; private set; }

		internal RefID LocalUserID
		{
			get
			{
				if (_joiner == null)
				{
					throw new InvalidOperationException("LocalUserID can only be accessed when joining a session");
				}
				return _joiner.LocalUserID;
			}
		}

		internal string VerifiedHostUserId
		{
			get
			{
				if (_joiner == null)
				{
					throw new InvalidOperationException("VerifiedHostUserId can only be accessed when joining a session");
				}
				return _joiner.VerifiedHostUserId;
			}
		}

		public SessionConnectionManager(Session session)
		{
			Session = session;
		}

		internal User GetUser(IConnection connection)
		{
			if (TryGetUser(connection, out User user))
			{
				return user;
			}
			throw new ArgumentException($"There is no user associated with connection: {connection}");
		}

		internal IConnection GetConnection(User user)
		{
			lock (_lock)
			{
				return _connectionsByUser[user].Connection;
			}
		}

		internal bool TryGetConnection(User user, out IConnection? connection)
		{
			lock (_lock)
			{
				if (_connectionsByUser.TryGetValue(user, out SessionConnection value))
				{
					connection = value.Connection;
					return true;
				}
				connection = null;
				return false;
			}
		}

		internal User GetUser(SyncMessage message)
		{
			return GetUser(message.Sender);
		}

		internal bool TryGetUser(SyncMessage message, out User? user)
		{
			return TryGetUser(message.Sender, out user);
		}

		internal bool TryGetUser(IConnection connection, [NotNullWhen(true)] out User? user)
		{
			if (connection == null)
			{
				throw new ArgumentNullException("connection");
			}
			lock (_lock)
			{
				if (_connections.TryGetValue(connection, out SessionConnection value) && value.User != null)
				{
					user = value.User;
					return true;
				}
				user = null;
				return false;
			}
		}

		internal void GetConnections(List<User> users, List<IConnection> connections, bool skipUnvailable = false)
		{
			lock (_lock)
			{
				foreach (User user in users)
				{
					if (_connectionsByUser.TryGetValue(user, out SessionConnection value))
					{
						connections.Add(value.Connection);
					}
					else if (!skipUnvailable)
					{
						throw new Exception("Connection not available for user: " + user);
					}
				}
			}
		}

		internal void RemoveConnection(IConnection connection)
		{
			lock (_lock)
			{
				SessionConnection sessionConnection = _connections[connection];
				_connections.Remove(connection);
				if (sessionConnection.User != null)
				{
					_connectionsByUser.Remove(sessionConnection.User);
				}
				sessionConnection.Dispose();
			}
		}

		internal void TriggerLocalFatalFailure(string reason)
		{
			UniLog.Log("Local fatal failure: " + reason);
			if (IsWorldValid)
			{
				World.Destroy();
			}
		}

		internal void TriggerFatalFailure(IConnection connection, string reason)
		{
			UniLog.Log($"Fatal failure for connection: {connection} - {reason}");
			connection.Close();
		}

		internal bool StartListener(ushort port)
		{
			if (Listener != null)
			{
				throw new InvalidOperationException("Listener has already been started");
			}
			Listener = new SessionListener(this);
			return Listener.Start(port);
		}

		internal void LinkConnectionToUser(SessionConnection connection)
		{
			if (connection.User == null)
			{
				throw new InvalidOperationException("SessionConnection must have user associated with it on order to link");
			}
			lock (_lock)
			{
				_connectionsByUser.Add(connection.User, connection);
			}
		}

		internal void RouteJoinerFlowMessage(SyncMessage message)
		{
			if (_joiner == null || !_joiner.ProcessJoinMessage(message))
			{
				BanManager.TempBanConnection(message.Sender);
				TriggerFatalFailure(message.Sender, "Received illegal joiner flow message");
			}
		}

		internal void RouteJoiningUserFlowMessage(ControlMessage message)
		{
			if (!IsWorldValid)
			{
				return;
			}
			SessionConnection value;
			if (!World.IsAuthority)
			{
				BanManager.TempBanConnection(message.Sender);
				TriggerFatalFailure(message.Sender, "Received illegal join flow control message from the user");
			}
			else if (message.ControlMessageType == ControlMessage.Message.JoinRequest)
			{
				if (_connections.ContainsKey(message.Sender))
				{
					TriggerFatalFailure(message.Sender, "Received duplicate JoinRequest control message");
					return;
				}
				SessionConnection sessionConnection = new SessionConnection(this, message.Sender);
				_connections.Add(message.Sender, sessionConnection);
				sessionConnection.StartJoinHandshake(message);
			}
			else if (_connections.TryGetValue(message.Sender, out value))
			{
				value.ProcessJoinControlMessage(message);
			}
			else
			{
				TriggerFatalFailure(message.Sender, "Received message other than JoinRequest as the first join flow message");
			}
		}

		internal void UpdateConnectionStatus(LocaleString description, LocaleString detail)
		{
			ConnectionStatusDescription = description;
			ConnectionStatusDetail = detail;
		}

		internal void UpdateConnectionDescription(LocaleString description)
		{
			ConnectionStatusDescription = description;
			ConnectionStatusDetail = null;
		}

		internal void UpdateConnectionStatusDetail(LocaleString detail)
		{
			ConnectionStatusDetail = detail;
		}

		internal async Task<bool> ConnectToAsync(IEnumerable<Uri> addresses)
		{
			if (!IsWorldValid)
			{
				UpdateConnectionDescription("World.Error.SessionEnded".AsLocaleKey());
				return false;
			}
			UpdateConnectionDescription("World.Connection.EstablishingConnection".AsLocaleKey());
			string expectedSessionId;
			List<ConnectionConstructor> connectionConstructors = Network.GetConnectionConstructors(addresses, World, out expectedSessionId);
			if (connectionConstructors == null)
			{
				ConnectionFailure("World.Connection.NoProtocolsAvailable".AsLocaleKey());
				return false;
			}
			foreach (ConnectionConstructor item in connectionConstructors)
			{
				if (await TryConnect(item).ConfigureAwait(continueOnCapturedContext: false))
				{
					_joiner = new SessionJoiner(this);
					await _joiner.JoinSession(expectedSessionId);
					return true;
				}
			}
			ConnectionFailure("World.Connection.AllProtocolsFailed".AsLocaleKey());
			return false;
		}

		private void ConnectionFailure(LocaleString description)
		{
			UpdateConnectionDescription(description);
			string text = description.ToString();
			if (IsWorldValid)
			{
				text = World.GetLocalized(description);
			}
			UniLog.Warning("Connection failure due to: " + text);
		}

		private async Task<bool> TryConnect(ConnectionConstructor constructor)
		{
			UniLog.Log("Connecting to: " + constructor.uri);
			IConnection connection = constructor.CreateConnection();
			TaskCompletionSource<bool> task = new TaskCompletionSource<bool>();
			connection.Connected += delegate
			{
				UniLog.Log("Connected to: " + constructor.uri);
				task.SetResult(result: true);
			};
			connection.ConnectionFailed += delegate(IConnection c)
			{
				UniLog.Log($"Connection to {c.Address} failed: " + c.FailReason);
				task.SetResult(result: false);
			};
			connection.Closed += delegate(IConnection c)
			{
				UniLog.Log($"Connection to {c.Address} closed: " + c.FailReason);
				task.TrySetResult(result: false);
			};
			try
			{
				connection.Connect(UpdateConnectionStatusDetail);
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception when connecting to session at {connection.Address}:\n{value}");
				task.SetResult(result: false);
			}
			bool num = await task.Task.ConfigureAwait(continueOnCapturedContext: false);
			if (num)
			{
				HostConnection = connection;
				connection.NewData += OnNewHostData;
				connection.StatsUpdated += OnStatsUpdated;
				connection.Closed += OnHostConnectionClosed;
			}
			return num;
		}

		private void OnHostConnectionClosed(IConnection connection)
		{
			try
			{
				if (IsWorldValid)
				{
					World.HostConnectionClosed();
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception invoking HostConnectionClosed:\n{value}");
			}
		}

		internal void OnStatsUpdated(IConnection connection, Action<User> setStats)
		{
			if (!IsWorldValid || World.State != FrooxEngine.World.WorldState.Running)
			{
				return;
			}
			User user;
			if (World.IsAuthority)
			{
				if (!TryGetUser(connection, out user))
				{
					return;
				}
			}
			else
			{
				user = World.LocalUser;
			}
			World.RunSynchronously(delegate
			{
				if (World.State == FrooxEngine.World.WorldState.Running && user != null && !user.IsDisposed)
				{
					setStats(user);
				}
			});
		}

		private void OnNewHostData(RawInMessage rawMessage)
		{
			Messages.Incoming.EnqueueReceivedMessage(rawMessage);
		}

		public void Dispose()
		{
			try
			{
				GC.SuppressFinalize(this);
				Listener?.Dispose();
				foreach (KeyValuePair<IConnection, SessionConnection> connection in _connections)
				{
					connection.Value.Dispose();
				}
				HostConnection?.Dispose();
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception disposing {GetType().Name}:\n{value}");
			}
		}
	}
	public class SessionCryptoHelper
	{
		public Session Session { get; private set; }

		public Engine Engine => Session?.Engine;

		public LocalDB LocalDB => Engine?.LocalDB;

		public SessionCryptoHelper(Session session)
		{
			Session = session;
		}

		private static byte[] GetCompositeVerificationToken(byte[] nonce, string sessionId, bool host)
		{
			byte[] other = CryptoHelper.HashID(sessionId + (host ? "-Host" : "-User"));
			return CryptoHelper.HashData(nonce.Append(other));
		}

		internal byte[] SignCloudVerificationToken(byte[] nonce, string sessionId, bool host)
		{
			return Engine.Cloud.Security.SignHash(GetCompositeVerificationToken(nonce, sessionId, host));
		}

		internal byte[] SignMachineVerificationToken(byte[] nonce, string sessionId, bool host)
		{
			return Engine.LocalDB.SignHash(GetCompositeVerificationToken(nonce, sessionId, host));
		}

		internal bool VerifyToken(byte[] nonce, string sessionId, bool host, byte[] signature, RSAParametersData publicKey)
		{
			byte[] compositeVerificationToken = GetCompositeVerificationToken(nonce, sessionId, host);
			using RSACryptoServiceProvider rSACryptoServiceProvider = new RSACryptoServiceProvider();
			rSACryptoServiceProvider.ImportParameters(publicKey);
			return rSACryptoServiceProvider.VerifyHash(compositeVerificationToken, signature, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1);
		}
	}
	public class SessionIncomingMessageManager : IDisposable
	{
		private TransformBlock<RawInMessage, SyncMessage> rawMessageProcessor;

		private ActionBlock<SyncMessage> syncMessageProcessor;

		private ActionBlock<StreamMessage> asyncStreamMessageProcessor;

		private ActionBlock<ControlMessage> assetMessageProcessor;

		private CancellationTokenSource cancellationTokenSource;

		public SessionMessageManager Messages { get; private set; }

		public SessionConnectionManager Connections => Session.Connections;

		public Session Session => Messages.Session;

		public SessionSyncManager Sync => Session.Sync;

		public World World => Session.World;

		public Engine Engine => Session.Engine;

		public int TotalReceivedDeltas { get; private set; }

		public int TotalReceivedConfirmations { get; private set; }

		public int TotalReceivedFulls { get; private set; }

		public int TotalReceivedControls { get; private set; }

		public int TotalReceivedStreams { get; private set; }

		public SessionIncomingMessageManager(SessionMessageManager manager)
		{
			Messages = manager;
			cancellationTokenSource = new CancellationTokenSource();
			rawMessageProcessor = new TransformBlock<RawInMessage, SyncMessage>((Func<RawInMessage, SyncMessage>)ProcessRawInMessage, new ExecutionDataflowBlockOptions
			{
				MaxDegreeOfParallelism = MathX.Max(1, (Engine.PhysicalProcessorCount ?? Engine.ProcessorCount) - 1),
				EnsureOrdered = true
			});
			syncMessageProcessor = new ActionBlock<SyncMessage>((Action<SyncMessage>)ProcessSyncMessage, new ExecutionDataflowBlockOptions
			{
				MaxDegreeOfParallelism = 1,
				EnsureOrdered = true
			});
			rawMessageProcessor.LinkTo(syncMessageProcessor);
			asyncStreamMessageProcessor = new ActionBlock<StreamMessage>((Action<StreamMessage>)ProcessAsyncStreamMessage, new ExecutionDataflowBlockOptions
			{
				MaxDegreeOfParallelism = 1,
				EnsureOrdered = true
			});
		}

		internal void EnqueueReceivedMessage(RawInMessage message)
		{
			if (!Session.IsDisposed)
			{
				rawMessageProcessor.Post(message);
			}
		}

		private SyncMessage ProcessRawInMessage(RawInMessage message)
		{
			try
			{
				if (Session.IsDisposed)
				{
					return null;
				}
				return SyncMessage.Decode(message);
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception decoding sync message:\n{value}");
				Connections.TriggerFatalFailure(message.Sender, "Exception when decoding sync message");
				return null;
			}
			finally
			{
				try
				{
					message.Dispose();
				}
				catch (Exception value2)
				{
					UniLog.Error($"Exception disposing SyncMessage after decoding: {value2}");
				}
			}
		}

		private void ProcessSyncMessage(SyncMessage message)
		{
			if (message == null)
			{
				return;
			}
			if (Session.IsDisposed)
			{
				message.Dispose();
				return;
			}
			try
			{
				if (!(message is PingMessage ping))
				{
					User user;
					if (!(message is DeltaBatch deltaBatch))
					{
						if (!(message is FullBatch fullBatch))
						{
							if (!(message is ConfirmationMessage message2))
							{
								if (!(message is ControlMessage controlMessage))
								{
									if (!(message is StreamMessage stream))
									{
										throw new NotImplementedException($"Processing for messages of type {message?.GetType()} is not implemented");
									}
									TotalReceivedStreams++;
									ProcessStreamMessage(stream);
								}
								else
								{
									TotalReceivedControls++;
									if (World.IsAuthority && Connections.TryGetUser(controlMessage.Sender, out user))
									{
										user.ImmediateControlCount++;
									}
									ProcessControlMessage(controlMessage);
								}
							}
							else
							{
								TotalReceivedConfirmations++;
								Sync.EnqueueForSyncProcessing(message2);
							}
						}
						else
						{
							TotalReceivedFulls++;
							if (World.IsAuthority && Connections.TryGetUser(fullBatch.Sender, out user))
							{
								user.LastSyncMessage = DateTime.UtcNow;
							}
							ProcessFullBatch(fullBatch);
						}
					}
					else
					{
						TotalReceivedDeltas++;
						if (World.IsAuthority && Connections.TryGetUser(deltaBatch.Sender, out user))
						{
							user.ImmediateDeltaCount++;
							user.LastSyncMessage = DateTime.UtcNow;
						}
						Sync.EnqueueForSyncProcessing(deltaBatch);
					}
				}
				else
				{
					ProcessPingMessage(ping);
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception processing sync message: {message}\n{value}");
				Connections.TriggerFatalFailure(message.Sender, "Exception processing sync message");
			}
		}

		private void ProcessPingMessage(PingMessage ping)
		{
			if (ping.Response)
			{
				Session.Latency = DateTime.UtcNow - ping.Time;
				return;
			}
			ping.MarkResponse();
			ping.Targets.Add(ping.Sender);
			Messages.Outgoing.EnqueueForTransmission(ping, isOrigin: true, useBackgroundEncoder: false);
		}

		private void ProcessFullBatch(FullBatch full)
		{
			if (full.IsInitialState)
			{
				Connections.RouteJoinerFlowMessage(full);
			}
			else
			{
				Sync.EnqueueForSyncProcessing(full);
			}
		}

		private void ProcessStreamMessage(StreamMessage stream)
		{
			if (stream.IsOutdated || World.InitState != FrooxEngine.World.InitializationState.Finished)
			{
				stream.Dispose();
				return;
			}
			if (World.IsAuthority)
			{
				if (!Connections.TryGetUser(stream, out User user))
				{
					stream.Dispose();
					return;
				}
				StreamMessage streamMessage = new StreamMessage(stream);
				List<User> list = Pool.BorrowList<User>();
				list.Add(user);
				World.SwapForOthers(list, (User u) => u.ReceiveStreams);
				Connections.GetConnections(list, streamMessage.Targets, skipUnvailable: true);
				Pool.Return(ref list);
				Messages.Outgoing.EnqueueForTransmission(streamMessage, isOrigin: false, useBackgroundEncoder: false);
			}
			if (stream.IsAsynchronous)
			{
				asyncStreamMessageProcessor.Post(stream);
			}
			else
			{
				Sync.EnqueueForSyncProcessing(stream);
			}
		}

		private void ProcessControlMessage(ControlMessage control)
		{
			switch (control.ControlMessageType)
			{
			case ControlMessage.Message.JoinChallenge:
			case ControlMessage.Message.JoinContactChallenge:
			case ControlMessage.Message.JoinGrant:
			case ControlMessage.Message.JoinReject:
				Connections.RouteJoinerFlowMessage(control);
				return;
			case ControlMessage.Message.JoinRequest:
			case ControlMessage.Message.JoinAuthenticate:
			case ControlMessage.Message.JoinContactChallengeReady:
			case ControlMessage.Message.JoinRequestStartStreams:
				Connections.RouteJoiningUserFlowMessage(control);
				return;
			case ControlMessage.Message.AssetRequest:
			case ControlMessage.Message.AssetTransmissionStart:
			case ControlMessage.Message.AssetChunk:
			case ControlMessage.Message.AssetNextChunkRequest:
			case ControlMessage.Message.AssetNotAvailable:
			case ControlMessage.Message.AssetMetadataRequest:
			case ControlMessage.Message.AssetMetadata:
				Session.Assets.EnqueueAssetMessage(control);
				return;
			}
			UniLog.Warning($"Received unsupported control message type: {control.ControlMessageType}");
			Connections.TriggerFatalFailure(control.Sender, "Received unsupported control message type");
		}

		private void ProcessAsyncStreamMessage(StreamMessage message)
		{
			try
			{
				if (Session.IsDisposed)
				{
					message.Dispose();
				}
				else
				{
					World.SyncController.AsyncStreamDecodeAndDispose(message);
				}
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception processing async stream message:\n{value}");
			}
		}

		public void Dispose()
		{
			try
			{
				rawMessageProcessor.Complete();
				syncMessageProcessor.Complete();
				rawMessageProcessor.Complete();
				asyncStreamMessageProcessor.Complete();
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception disposing of {GetType().Name}\n{value}");
			}
		}
	}
	public class SessionJoiner
	{
		public enum State
		{
			NotStarted,
			JoinRequestSent,
			JoinAuthenticateSent,
			JoinGranted,
			InitialStateDecoded,
			FullyInitialized
		}

		private byte[] hostVerificationToken;

		private TaskCompletionSource<SyncMessage> _joinMessage;

		private bool contactChallengeRequested;

		public SessionConnectionManager Connections { get; private set; }

		public Engine Engine => Session.Engine;

		public Session Session => Connections.Session;

		public World World => Connections.World;

		public NetworkManager Network => Session.NetworkManager;

		public SessionMessageManager Messages => Connections.Messages;

		public SessionCryptoHelper Crypto => Session.Crypto;

		public SessionSyncManager Sync => Session.Sync;

		public State JoinState { get; private set; }

		public string ExpectedSessionId { get; private set; }

		public string VerifiedHostUserId { get; private set; }

		public RefID LocalUserID { get; private set; }

		public SessionJoiner(SessionConnectionManager connections)
		{
			Connections = connections;
			_joinMessage = new TaskCompletionSource<SyncMessage>();
		}

		internal async Task JoinSession(string expectedSessionId)
		{
			if (JoinState != State.NotStarted)
			{
				throw new InvalidOperationException("Join has already been started");
			}
			ExpectedSessionId = expectedSessionId;
			World.WaitForJoinGrant();
			Sync.StartSyncLoop(isHost: false);
			await SendJoinRequest().ConfigureAwait(continueOnCapturedContext: false);
			await SendJoinAuthenticate(await ReceiveControlResponse(ControlMessage.Message.JoinChallenge).ConfigureAwait(continueOnCapturedContext: false)).ConfigureAwait(continueOnCapturedContext: false);
			ProcessJoinGrant(await ReceiveControlResponse(ControlMessage.Message.JoinGrant).ConfigureAwait(continueOnCapturedContext: false));
			FullBatch fullBatch = await ReceiveResponse<FullBatch>().ConfigureAwait(continueOnCapturedContext: false);
			await Sync.DecodeInitialState(fullBatch);
			JoinState = State.InitialStateDecoded;
			Connections.UpdateConnectionDescription("World.Connection.Connected".AsLocaleKey());
			SendStartStreamsRequest();
			JoinState = State.FullyInitialized;
		}

		internal bool ProcessJoinMessage(SyncMessage message)
		{
			if (message is ControlMessage { ControlMessageType: ControlMessage.Message.JoinContactChallenge } controlMessage)
			{
				return ProcessContactChallenge(controlMessage);
			}
			return _joinMessage.TrySetResult(message);
		}

		private bool ProcessContactChallenge(ControlMessage control)
		{
			if (contactChallengeRequested || JoinState >= State.JoinGranted)
			{
				return false;
			}
			contactChallengeRequested = true;
			string keyBase = control.Data.ExtractOrThrow<string>("CheckContactKeyBase");
			if (string.IsNullOrWhiteSpace(keyBase) || keyBase.Length != CryptoHelper.CryptoTokenStringLength(64))
			{
				UniLog.Warning("Invalid challenge key base: " + keyBase, stackTrace: true);
				return false;
			}
			Task.Run(async delegate
			{
				try
				{
					CloudResult<OneTimeVerificationKey> cloudResult = await World.Engine.Cloud.Security.CreateKey(keyBase, VerificationKeyUse.CheckContact).ConfigureAwait(continueOnCapturedContext: false);
					ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.JoinContactChallengeReady);
					controlMessage.Targets.Add(Connections.HostConnection);
					controlMessage.Data.Add("CheckContactKeyId", cloudResult.Entity?.KeyId);
					Messages.Outgoing.EnqueueForTransmission(controlMessage, isOrigin: true, useBackgroundEncoder: false);
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception generating check contact key:\n{value}");
					Connections.TriggerFatalFailure(Connections.HostConnection, "Exception generating check contact key");
				}
			});
			return true;
		}

		private async Task<ControlMessage> ReceiveControlResponse(params ControlMessage.Message[] expectedTypes)
		{
			if (expectedTypes.Length == 0)
			{
				throw new ArgumentException("At least one expected type must be provided");
			}
			ControlMessage controlMessage = await ReceiveResponse<ControlMessage>();
			if (controlMessage.ControlMessageType == ControlMessage.Message.JoinReject)
			{
				string statusMessage = controlMessage.Data.ExtractOrDefault("Reason", "World.Error.Unknown");
				throw new SessionJoinException(FrooxEngine.World.FailReason.JoinRejected, statusMessage, "Join was rejected by the remote end");
			}
			if (!expectedTypes.Contains(controlMessage.ControlMessageType))
			{
				throw new SessionJoinException(FrooxEngine.World.FailReason.NetworkError, "World.Error.Handshake", $"Was expecting message of following types: {string.Join(", ", expectedTypes)}. Received {controlMessage.ControlMessageType} instead");
			}
			return controlMessage;
		}

		private async Task<T> ReceiveResponse<T>() where T : SyncMessage
		{
			SyncMessage syncMessage = await _joinMessage.Task.ConfigureAwait(continueOnCapturedContext: false);
			if (!(syncMessage is T))
			{
				throw new SessionJoinException(FrooxEngine.World.FailReason.NetworkError, "World.Error.Handshake", $"Was expecting message of type {typeof(T)}, but got {syncMessage.GetType()} instead");
			}
			_joinMessage = new TaskCompletionSource<SyncMessage>();
			return (T)syncMessage;
		}

		private async Task SendJoinRequest()
		{
			Connections.UpdateConnectionDescription("World.Connection.RequestingJoin".AsLocaleKey());
			string text = Engine.LocalUserName;
			if (text != null && text.Length > 32)
			{
				text = text.Substring(0, 32);
			}
			ControlMessage request = new ControlMessage(ControlMessage.Message.JoinRequest);
			request.Data.Add("MachineID", Engine.LocalDB.MachineID);
			request.Data.Add("MachinePublicKeyExponent", Convert.ToBase64String(Engine.LocalDB.PublicKeyExponent));
			request.Data.Add("MachinePublicKeyModulus", Convert.ToBase64String(Engine.LocalDB.PublicKeyModulus));
			request.Data.Add("UserName", text);
			request.Data.Add("HeadDevice", Engine.InputInterface.HeadOutputDevice);
			request.Data.Add("Platform", Engine.Platform);
			request.Data.Add("Devices", Engine.InputInterface.CollectDeviceInfos());
			request.Data.Add("UserID", Engine.Cloud.Session.CurrentUserID);
			request.Data.Add("UserSessionID", Engine.Cloud.Status?.UserSessionId);
			request.Data.Add("EngineVersionNumber", FrooxEngine.Engine.VersionNumber.ToString());
			request.Data.Add("RendererName", Engine.RenderSystem?.RendererName ?? "<null>");
			request.Data.Add("RuntimeVersion", Environment.Version.ToString());
			if (Engine.Cloud.Session.CurrentUserID != null)
			{
				CloudResult<OneTimeVerificationKey> cloudResult = await Engine.Cloud.Security.CreateKey(null, VerificationKeyUse.AccessBans).ConfigureAwait(continueOnCapturedContext: false);
				if (!cloudResult.IsOK)
				{
					throw new SessionJoinException(FrooxEngine.World.FailReason.AuthenticationError, "World.Error.FailedToCreateBanAccessKey", $"Could not create ban access key. Result: {cloudResult}");
				}
				request.Data.Add("BanAccessKeyId", cloudResult.Entity.KeyId);
			}
			Engine.InputInterface.GetEyeTracking(out var hasEyeTracking, out var hasPupilTracking);
			request.Data.Add("EyeTracking", hasEyeTracking);
			request.Data.Add("PupilTracking", hasPupilTracking);
			HashSet<MouthParameterGroup> mouthTrackingParameters = Engine.InputInterface.GetMouthTrackingParameters();
			DataTreeList dataTreeList = new DataTreeList();
			foreach (MouthParameterGroup item in mouthTrackingParameters)
			{
				dataTreeList.Add(DataTreeValue.FromEnum(item));
			}
			request.Data.Add("MouthTracking", dataTreeList);
			hostVerificationToken = CryptoHelper.GenerateCryptoBlob(64);
			request.Data.Add("HostVerificationToken", Convert.ToBase64String(hostVerificationToken));
			if (ExpectedSessionId != null)
			{
				request.Data.Add("ExpectedSessionId", ExpectedSessionId);
			}
			if (Userspace.KioskMode)
			{
				request.Data.Add("KioskMode", val: true);
			}
			DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
			foreach (KeyValuePair<string, string> extraUserId in Engine.PlatformInterface.GetExtraUserIds())
			{
				string key = extraUserId.Key;
				string id = extraUserId.Value;
				FrooxEngine.World.ProcessExtraId(ref key, ref id);
				dataTreeDictionary.Add(key, id);
			}
			request.Data.Add("ExtraIds", dataTreeDictionary);
			request.Targets.Add(Connections.HostConnection);
			Messages.Outgoing.EnqueueForTransmission(request, isOrigin: true, useBackgroundEncoder: false);
			JoinState = State.JoinRequestSent;
		}

		private async Task SendJoinAuthenticate(ControlMessage joinChallenge)
		{
			Connections.UpdateConnectionDescription("World.Connection.Authenticating".AsLocaleKey());
			ControlMessage authenticate = new ControlMessage(ControlMessage.Message.JoinAuthenticate)
			{
				Targets = { joinChallenge.Sender }
			};
			string targetSessionId = joinChallenge.Data.ExtractOrThrow<string>("SessionID");
			if (!string.IsNullOrEmpty(ExpectedSessionId) && targetSessionId != ExpectedSessionId)
			{
				throw new SessionJoinException(FrooxEngine.World.FailReason.AuthenticationError, "World.Error.FailedAuthentication", "TargetSessionID " + targetSessionId + " doesn't match expectedSessionID " + ExpectedSessionId);
			}
			ExpectedSessionId = targetSessionId;
			string text = joinChallenge.Data.ExtractOrThrow<string>("HostMachineID");
			byte[] signature = Convert.FromBase64String(joinChallenge.Data.ExtractOrThrow<string>("MachineVerificationSignature"));
			string hostUserId = joinChallenge.Data.ExtractOrDefault<string>("HostUserID");
			string hostUserSessionId = joinChallenge.Data.ExtractOrDefault<string>("HostUserSessionID");
			RSAParameters rSAParameters = new RSAParameters
			{
				Exponent = Convert.FromBase64String(joinChallenge.Data.ExtractOrThrow<string>("MachinePublicKeyExponent")),
				Modulus = Convert.FromBase64String(joinChallenge.Data.ExtractOrThrow<string>("MachinePublicKeyModulus"))
			};
			bool flag = LocalDB.MachineIdMatches(text, rSAParameters);
			if (!flag || !Crypto.VerifyToken(hostVerificationToken, ExpectedSessionId, host: true, signature, rSAParameters))
			{
				throw new SessionJoinException(FrooxEngine.World.FailReason.AuthenticationError, "World.Error.FailedAuthentication", $"Failed to verify host MachineID: {text}. ID matches public key: {flag}.");
			}
			if (hostUserId != null)
			{
				string banAccessKey = joinChallenge.Data.ExtractOrThrow<string>("BanAccessKeyId");
				if (string.IsNullOrWhiteSpace(banAccessKey))
				{
					throw new SessionJoinException(FrooxEngine.World.FailReason.SecurityIssue, "World.Error.FailedAuthentication", "Host provided invalid ban access key");
				}
				string s = joinChallenge.Data.ExtractOrThrow<string>("CloudVerificationSignature");
				byte[] cloudVerificationSignatureHash = Convert.FromBase64String(s);
				CloudResult<RSAParametersData> publicKeyResult = await Engine.Cloud.Users.GetPublicKey(hostUserId, hostUserSessionId).ConfigureAwait(continueOnCapturedContext: false);
				if (!publicKeyResult.IsOK)
				{
					throw new SessionJoinException(FrooxEngine.World.FailReason.NetworkError, "World.Error.FailedAuthentication", $"Failed to get public key for host UserID: {hostUserId}, UserSessionId: {hostUserSessionId}. Result: " + publicKeyResult);
				}
				if (!Crypto.VerifyToken(hostVerificationToken, ExpectedSessionId, host: true, cloudVerificationSignatureHash, publicKeyResult.Entity))
				{
					throw new SessionJoinException(FrooxEngine.World.FailReason.AuthenticationError, "World.Error.FailedAuthentication", "Failed to verify host identity. HostID: " + hostUserId);
				}
				CloudResult<SkyFrost.Base.User> cloudResult = await Engine.Cloud.Users.GetUser(hostUserId, banAccessKey).ConfigureAwait(continueOnCapturedContext: false);
				if (!cloudResult.IsOK)
				{
					throw new SessionJoinException(FrooxEngine.World.FailReason.NetworkError, "World.Error.FailedAuthentication", $"Failed to get user info for host: {hostUserId}, UserSessionId: {hostUserSessionId}. Result: " + publicKeyResult);
				}
				if (cloudResult.Entity.IsPublicBanned && cloudResult.Entity.PublicBanType == PublicBanType.Hard)
				{
					throw new SessionJoinException(FrooxEngine.World.FailReason.SecurityIssue, "World.Error.HostIsBanned", "Attempted to connect to hard public banned host: " + hostUserId);
				}
				VerifiedHostUserId = hostUserId;
			}
			string text2 = joinChallenge.Data.ExtractOrThrow<string>("SystemCompatibilityHash");
			DataTreeList dataTreeList = joinChallenge.Data.TryGetList("DataModelAssemblies");
			if (text2 != GlobalTypeRegistry.SystemCompatibilityHash)
			{
				throw IncompatibleException("System compatibility hash mismatch.");
			}
			if (dataTreeList == null)
			{
				throw IncompatibleException("Missing data model assembly manifest.");
			}
			List<AssemblyTypeRegistry> list = new List<AssemblyTypeRegistry>();
			foreach (DataTreeDictionary item in dataTreeList)
			{
				string text3 = item.ExtractOrThrow<string>("Name");
				string text4 = item.ExtractOrThrow<string>("CompatibilityHash");
				AssemblyTypeRegistry assemblyTypeRegistry = GlobalTypeRegistry.TryGetTypeRegistry(text3);
				if (assemblyTypeRegistry == null)
				{
					throw IncompatibleException("Session uses assembly " + text3 + " which is not available on this end.");
				}
				if (assemblyTypeRegistry.CompatibilityHash != text4)
				{
					throw IncompatibleException("Session assembly " + text3 + " isn't compatible with the same assembly on this end.");
				}
				list.Add(assemblyTypeRegistry);
			}
			World.Types.InitializeAssemblies(list);
			byte[] nonce = Convert.FromBase64String(joinChallenge.Data.ExtractOrThrow<string>("IdentityHash"));
			string val = Convert.ToBase64String(Crypto.SignMachineVerificationToken(nonce, targetSessionId, host: false));
			authenticate.Data.Add("MachineIdentitySignature", val);
			if (Engine.Cloud.Session.CurrentUserID != null)
			{
				string val2 = Convert.ToBase64String(Crypto.SignCloudVerificationToken(nonce, targetSessionId, host: false));
				authenticate.Data.Add("CloudIdentitySignature", val2);
			}
			Messages.Outgoing.EnqueueForTransmission(authenticate, isOrigin: true, useBackgroundEncoder: false);
			JoinState = State.JoinAuthenticateSent;
			static SessionJoinException IncompatibleException(string message)
			{
				return new SessionJoinException(FrooxEngine.World.FailReason.CompatibilityError, "World.Error.SessionIncompatible", message);
			}
		}

		private void ProcessJoinGrant(ControlMessage joinGrant)
		{
			Connections.UpdateConnectionDescription("World.Connection.SyncingInitialState".AsLocaleKey());
			LocalUserID = joinGrant.Data.ExtractOrThrow<ulong>("ReferenceID");
			int randomizationSeed = joinGrant.Data.ExtractOrThrow<int>("RandomizationSeed");
			byte[] obfuscationKey = Convert.FromBase64String(joinGrant.Data.ExtractOrThrow<string>("OBFK"));
			byte[] obfuscationIV = Convert.FromBase64String(joinGrant.Data.ExtractOrThrow<string>("OBFI"));
			World.StartDataModelInit(randomizationSeed, obfuscationKey, obfuscationIV);
			JoinState = State.JoinGranted;
		}

		private void SendStartStreamsRequest()
		{
			ControlMessage controlMessage = new ControlMessage(ControlMessage.Message.JoinRequestStartStreams);
			controlMessage.Targets.Add(Connections.HostConnection);
			Messages.Outgoing.EnqueueForTransmission(controlMessage, isOrigin: true, useBackgroundEncoder: false);
		}
