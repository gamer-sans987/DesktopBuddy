		public void LoadTypeData(DataTreeList typeList, DataTreeDictionary versionsDict)
		{
			if (typeList != null)
			{
				if (types == null)
				{
					types = new List<TypeData>();
				}
				foreach (DataTreeNode type3 in typeList)
				{
					string text = type3.LoadString();
					Type type = World.Types.DecodeType(text);
					if (type == null)
					{
						UniLog.Warning("Failed to decode type: " + text);
					}
					else if (!type.IsValidGenericType(validForInstantiation: false))
					{
						type = WorkerInitializer.ResolveReplacement(type, AppVersion, FeatureFlags);
						if (!type.IsValidGenericType(validForInstantiation: false))
						{
							UniLog.Warning("Loaded type is not valid generic instance: " + type);
							type = null;
						}
					}
					types.Add(new TypeData(type, text));
				}
			}
			if (versionsDict == null)
			{
				return;
			}
			if (typeVersions == null)
			{
				typeVersions = new Dictionary<Type, int>();
			}
			foreach (KeyValuePair<string, DataTreeNode> child in versionsDict.Children)
			{
				Type type2 = (LegacyTypes ? World.Types.DecodeLegacyType(child.Key) : World.Types.DecodeType(child.Key));
				int num = child.Value.LoadInt();
				if (legacyTypeVersions == null)
				{
					legacyTypeVersions = new Dictionary<string, int>();
				}
				legacyTypeVersions.Add(child.Key, num);
				if (!(type2 != null))
				{
					continue;
				}
				if (typeVersions.TryGetValue(type2, out var value))
				{
					UniLog.Warning("Version table contains multiple typenames that map to the same type. This usually means that a type has been mapped to another version. Highest version is going to be used. Loaders should take care to distinguish the version.\n" + $"Conflicting typename: {child.Key}. Type: {type2} Existing version: {value}. New Version: {num}");
					if (num > value)
					{
						typeVersions[type2] = num;
					}
				}
				else
				{
					typeVersions.Add(type2, num);
				}
			}
		}

