			Connections = connectionManager;
		}

		public bool Start(ushort port)
		{
			if (_listeners != null)
			{
				throw new InvalidOperationException("Listener has already been started");
			}
			_listeners = Network.RequestAllListeners(port, World);
			if (_listeners.Count == 0)
			{
				return false;
			}
			foreach (IListener listener in _listeners)
			{
				listener.NewData += OnNewData;
				listener.StatsUpdated += OnStatsUpdated;
			}
			return true;
		}

		private void OnStatsUpdated(IConnection connection, Action<User> setStats)
		{
			Connections.OnStatsUpdated(connection, setStats);
		}

		private void OnNewData(RawInMessage rawMessage)
		{
			Messages.Incoming.EnqueueReceivedMessage(rawMessage);
		}

		public void Dispose()
		{
			if (_listeners == null)
			{
				return;
			}
			foreach (IListener listener in _listeners)
			{
				listener.Close();
			}
			_listeners = null;
		}
	}
