		public void StoreUnresolvedReferences(World world)
		{
			Stopwatch stopwatch = Stopwatch.StartNew();
			Dictionary<Guid, List<ISyncRef>> unresolvedRequests = ReferenceTranslator.GetUnresolvedRequests();
			if (unresolvedRequests.Count > 0)
			{
				UnresolvedReferences componentOrAttach = world.RootSlot.GetComponentOrAttach<UnresolvedReferences>();
				foreach (KeyValuePair<Guid, List<ISyncRef>> item in unresolvedRequests)
				{
					foreach (ISyncRef item2 in item.Value)
					{
						RefID refID = componentOrAttach.TranslateReference(item.Key.ToString());
						if (item2 is IReadOnlyRef readOnlyRef)
						{
							readOnlyRef.Writeable = true;
							item2.Value = refID;
							readOnlyRef.Writeable = false;
						}
						else
						{
							item2.Value = refID;
						}
						componentOrAttach.TranslateReference(refID);
					}
				}
			}
			stopwatch.Stop();
			UniLog.Log("Unresolved count: " + unresolvedRequests.Count + ", Processed in: " + stopwatch.Elapsed);
		}

