	public class SessionOutgoingMessageManager : IDisposable
	{
		private TransformBlock<SyncMessage, RawOutMessage> messageEncoder;

		private TransformBlock<SyncMessage, RawOutMessage> backgroundMessageEncoder;

		private ActionBlock<RawOutMessage> messageTransmitter;

		public SessionMessageManager Manager { get; private set; }

		public SessionConnectionManager Connections => Session?.Connections;

		public Session Session => Manager?.Session;

		public World World => Session?.World;

		public Engine Engine => Session?.Engine;

		public NetworkManager Network => Session?.NetworkManager;

		public int TotalSentDeltas { get; private set; }

		public int TotalSentConfirmations { get; private set; }

		public int TotalSentFulls { get; private set; }

		public int TotalSentControls { get; private set; }

		public int TotalSentStreams { get; private set; }

		public int MessagesToTransmitCount => messageTransmitter.InputCount;

		public SessionOutgoingMessageManager(SessionMessageManager manager)
		{
			Manager = manager;
			messageEncoder = new TransformBlock<SyncMessage, RawOutMessage>((Func<SyncMessage, RawOutMessage>)EncodeSyncMessage, new ExecutionDataflowBlockOptions
			{
				MaxDegreeOfParallelism = MathX.Max(1, (Engine.PhysicalProcessorCount ?? Engine.ProcessorCount) - 1),
				EnsureOrdered = true
			});
			backgroundMessageEncoder = new TransformBlock<SyncMessage, RawOutMessage>((Func<SyncMessage, RawOutMessage>)EncodeSyncMessage, new ExecutionDataflowBlockOptions
			{
				MaxDegreeOfParallelism = MathX.Max(1, (Engine.PhysicalProcessorCount ?? Engine.ProcessorCount) - 1),
				EnsureOrdered = true
			});
			messageTransmitter = new ActionBlock<RawOutMessage>((Action<RawOutMessage>)TransmitMessage, new ExecutionDataflowBlockOptions
			{
				MaxDegreeOfParallelism = 1,
				EnsureOrdered = true
			});
			messageEncoder.LinkTo(messageTransmitter);
			backgroundMessageEncoder.LinkTo(messageTransmitter);
		}

		public void EnqueueStreamMessage(StreamMessage stream, bool isOrigin)
		{
			if (Session.IsDisposed)
			{
				stream.Dispose();
				return;
			}
			if (stream.Targets.Count > 0)
			{
				throw new ArgumentException("This method can be used to send stream messages that do not have any targets assigned yet");
			}
			World world = World;
			if (world == null)
			{
				return;
			}
			if (world.IsAuthority)
			{
				List<User> list = Pool.BorrowList<User>();
				world.GetUsers(list, (User u) => u.ReceiveStreams && !u.IsHost);
				Connections.GetConnections(list, stream.Targets, skipUnvailable: true);
				Pool.Return(ref list);
			}
			else
			{
				stream.Targets.Add(Connections.HostConnection);
			}
			EnqueueForTransmission(stream, isOrigin, useBackgroundEncoder: false);
		}

		public void EnqueueForTransmission(SyncMessage message, bool isOrigin, bool useBackgroundEncoder)
		{
			if (Session.IsDisposed)
			{
				message.Dispose();
				return;
			}
			(useBackgroundEncoder ? backgroundMessageEncoder : messageEncoder).Post(message);
			if (!isOrigin || !World.IsAuthority)
			{
				return;
			}
			if (!(message is DeltaBatch))
			{
				if (!(message is ControlMessage))
				{
					if (message is StreamMessage)
					{
						World.HostUser.ImmediateStreamCount++;
					}
				}
				else
				{
					World.HostUser.ImmediateControlCount++;
				}
			}
			else
			{
				World.HostUser.ImmediateDeltaCount++;
			}
		}

		private RawOutMessage EncodeSyncMessage(SyncMessage message)
		{
			try
			{
				if (Session.IsDisposed)
				{
					return null;
				}
				if (message.Targets.Count == 0)
				{
					return null;
				}
				CountSentMessage(message);
				return message.Encode();
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception encoding sync message:\n{value}");
				Connections.TriggerLocalFatalFailure("Exception encoding a sync message");
				throw;
			}
			finally
			{
				try
				{
					message.Dispose();
				}
				catch (Exception value2)
				{
					UniLog.Error($"Exception disposing SyncMessage after encoding: {value2}");
				}
			}
		}

		private void TransmitMessage(RawOutMessage message)
		{
			if (message == null)
			{
				return;
			}
			if (Session.IsDisposed)
			{
				message.Dispose();
				return;
			}
			try
			{
				Network.TransmitData(message);
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception transmitting message:\n{value}");
				Connections.TriggerLocalFatalFailure("Exception transmitting message");
				throw;
			}
		}

		private void CountSentMessage(SyncMessage message)
		{
			if (!(message is DeltaBatch))
			{
				if (!(message is FullBatch))
				{
					if (!(message is ConfirmationMessage))
					{
						if (!(message is ControlMessage))
						{
							if (message is StreamMessage)
							{
								TotalSentStreams++;
							}
						}
						else
						{
							TotalSentControls++;
						}
					}
					else
					{
						TotalSentConfirmations++;
					}
				}
				else
				{
					TotalSentFulls++;
				}
			}
			else
			{
				TotalSentDeltas++;
			}
		}

		public void Dispose()
		{
			try
			{
				messageEncoder.Complete();
				backgroundMessageEncoder.Complete();
				messageTransmitter.Complete();
			}
			catch (Exception value)
			{
				UniLog.Error($"Exception disposing of {GetType().Name}\n{value}");
			}
		}
	}
