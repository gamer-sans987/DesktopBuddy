	public class DataTreeSaver : DataTreeAssetProcessor
	{
		private const string LOCAL_FORMAT = "lz4bson";

		private const string HEAVY_FORMAT = "brson";

		public bool UseHeavyCompression;

		private bool saveRoot;

		public Engine Engine { get; private set; }

		public LocalDB LocalDB => Engine.LocalDB;

		public AssetManager AssetManager => Engine.AssetManager;

		private string Format
		{
			get
			{
				if (!UseHeavyCompression)
				{
					return "lz4bson";
				}
