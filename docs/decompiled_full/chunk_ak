	public class AssetLoadingData
	{
		private object _lock = new object();

		private Dictionary<IStaticAssetProvider, Asset> providers = new Dictionary<IStaticAssetProvider, Asset>();

		private HashSet<Asset> uniqueAssetsToLoad = new HashSet<Asset>();

		private HashSet<Asset> alreadyLoadedAssets = new HashSet<Asset>();

		public WorldAssetManager Manager { get; private set; }

		public Uri URL { get; private set; }

		public EngineAssetClass AssetClass { get; private set; }

		public AssetLoadingData(WorldAssetManager manager, Uri url, EngineAssetClass assetClass)
		{
			URL = url;
			Manager = manager;
			AssetClass = assetClass;
		}

		public void RegisterProvider(IStaticAssetProvider provider)
		{
			lock (_lock)
			{
				providers.Add(provider, null);
			}
		}

		public bool RegisterAsset(IStaticAssetProvider provider, Asset asset)
		{
			lock (_lock)
			{
				if (!providers.TryGetValue(provider, out Asset value))
				{
					throw new InvalidOperationException($"Provider is not registered with the data: {provider}");
				}
				if (value != null)
				{
					throw new InvalidOperationException($"Provider already has asset registered: {provider}\nURL: {URL}\nAsset: {asset}\nExisting Asset: {value}");
				}
				providers[provider] = asset;
				if (alreadyLoadedAssets.Contains(asset))
				{
					return false;
				}
				if (uniqueAssetsToLoad.Add(asset) && uniqueAssetsToLoad.Count > 1)
				{
					Manager.IncrementAssetsToLoad(AssetClass);
				}
				return true;
			}
		}

		public void RegisterFailed(IStaticAssetProvider provider, Asset asset)
		{
			RegisterFullyLoaded(provider, asset);
		}

		public void RegisterFullyLoaded(IStaticAssetProvider provider, Asset asset)
		{
			bool flag = false;
			lock (_lock)
			{
				if (uniqueAssetsToLoad.Remove(asset))
				{
					alreadyLoadedAssets.Add(asset);
					Manager.IncrementLoadedAssets(AssetClass);
				}
				providers.Remove(provider);
				if (providers.Count == 0)
				{
					flag = true;
				}
			}
			if (flag)
			{
				Manager.UnregisterLoadingData(URL);
			}
		}

		public void UnregisterProvider(IStaticAssetProvider provider)
		{
			bool flag = false;
			lock (_lock)
			{
				if (!providers.TryGetValue(provider, out Asset asset))
				{
					throw new InvalidOperationException($"Provider is not registered with the data: {provider}");
				}
				providers.Remove(provider);
				if (providers.Count == 0)
				{
					if (asset == null || !alreadyLoadedAssets.Contains(asset))
					{
						Manager.DecrementAssetsToLoad(AssetClass);
					}
					flag = true;
				}
				else if (asset != null && !providers.Any<KeyValuePair<IStaticAssetProvider, Asset>>((KeyValuePair<IStaticAssetProvider, Asset> p) => p.Value == asset) && uniqueAssetsToLoad.Remove(asset) && uniqueAssetsToLoad.Count > 0)
				{
					Manager.DecrementAssetsToLoad(AssetClass);
				}
			}
			if (flag)
			{
				Manager.UnregisterLoadingData(URL);
			}
		}

		public override string ToString()
		{
			return $"{URL} ({AssetClass}), UniqueAssetsToLoad: {uniqueAssetsToLoad.Count}, AlreadyLoadedAssets: {alreadyLoadedAssets.Count}, Providers: {providers.Count}\nProviders:\n{string.Join("\n", providers)}\n\nUniqueAssetsToLoad: {string.Join("\n", uniqueAssetsToLoad)}\n\nAlareadyLoadedAssets: {string.Join("\n", alreadyLoadedAssets)}";
		}
	}
	public class ConnectorManager : IDisposable
	{
		public enum LockOwner
		{
			None,
			DataModel,
			Implementer
		}

		private Thread lockingThread;

		public World Owner { get; private set; }

		public LockOwner Lock { get; private set; }

		public bool CanCurrentThreadModify
		{
			get
			{
				if (Thread.CurrentThread != lockingThread)
				{
					return Owner.State != World.WorldState.Running;
				}
				return true;
			}
		}

		public ConnectorManager(World owner)
		{
			Owner = owner;
		}

		public void Dispose()
		{
			Owner = null;
			Lock = LockOwner.None;
		}

		public void ThreadCheck()
		{
			if (!CanCurrentThreadModify)
			{
				throw new Exception("Modifications from a non-locking thread are disallowed! Current lock: " + Lock);
			}
		}

		public void DataModelLock(Thread ownerThread)
		{
			if (Lock != LockOwner.None)
			{
				throw new Exception("DataModel cannot lock Connectors, already locked!");
			}
			lockingThread = ownerThread;
			Lock = LockOwner.DataModel;
		}

		public void DataModelUnlock()
		{
			if (Lock != LockOwner.DataModel)
			{
				throw new Exception("DataModel cannot unlock Connectors, not locked by data model!");
			}
			lockingThread = null;
			Lock = LockOwner.None;
		}

		public void ImplementerLock(Thread ownerThread)
		{
			if (Lock != LockOwner.None)
			{
				throw new Exception("Implementer cannot lock Connectors, already locked!");
			}
			lockingThread = ownerThread;
			Lock = LockOwner.Implementer;
		}

		public void ImplementerUnlock()
		{
			if (Lock != LockOwner.Implementer)
			{
				throw new Exception("Implementer cannot unlock Connectors, not locked by implementer!");
			}
			lockingThread = null;
			Lock = LockOwner.None;
		}
	}
