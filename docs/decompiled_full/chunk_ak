	public static class WorkerHelper<T> where T : IWorker, new()
	{
		public static Func<T> New { get; private set; }

		static WorkerHelper()
		{
			if (!typeof(T).IsValidGenericType(validForInstantiation: true))
			{
				New = delegate
				{
					throw new InvalidOperationException("Invalid generic type: " + typeof(T));
				};
				return;
			}
			MethodInfo method = typeof(T).GetMethod("__New", BindingFlags.Static | BindingFlags.Public);
			if (method != null)
			{
				New = (Func<T>)Delegate.CreateDelegate(typeof(Func<T>), method);
				return;
			}
			New = () => new T();
		}
	}
