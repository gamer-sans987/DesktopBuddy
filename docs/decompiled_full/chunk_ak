	public class WorldAssetManager : IDisposable
	{
		public enum AssetChange
		{
			Created,
			Updated,
			Removed
		}

		private readonly struct AssetProviderChange
		{
			public readonly IAssetProvider provider;

			public readonly AssetChange change;

			public AssetProviderChange(IAssetProvider provider, AssetChange change)
			{
				this.provider = provider;
				this.change = change;
			}
		}

		private int[] _assetsToLoad;

		private int[] _assetsLoaded;

		private int _lastTotalAssetsLoaded;

		private DateTime _lastLoadedAssetsChange;

		private Dictionary<Uri, AssetLoadingData> activelyLoadingAssets = new Dictionary<Uri, AssetLoadingData>();

		private SpinQueue<AssetProviderChange> assetProviderChanges = new SpinQueue<AssetProviderChange>();

		private HashSet<Uri> _localAssets = new HashSet<Uri>();

		public World World { get; private set; }

		public float PercentLoaded { get; private set; }

		public int TotalAssetsToLoad { get; private set; }

		public int TotalAssetsLoaded { get; private set; }

		public bool TrackAssetLoading { get; private set; }

		public bool InitialAssetsLoaded { get; private set; }

		public int GetAssetsToLoad(EngineAssetClass assetClass)
		{
			return _assetsToLoad[(int)assetClass];
		}

		public int GetAssetsLoaded(EngineAssetClass assetClass)
		{
			return _assetsLoaded[(int)assetClass];
		}

		public WorldAssetManager(World world)
		{
			World = world;
			TrackAssetLoading = true;
			int memberCount = EnumsNET.Enums.GetMemberCount<EngineAssetClass>();
			_assetsToLoad = new int[memberCount];
			_assetsLoaded = new int[memberCount];
		}

		public void Update()
		{
			TotalAssetsToLoad = _assetsToLoad.Sum();
			TotalAssetsLoaded = _assetsLoaded.Sum();
			if (TotalAssetsLoaded != _lastTotalAssetsLoaded)
			{
				_lastTotalAssetsLoaded = TotalAssetsLoaded;
				_lastLoadedAssetsChange = DateTime.UtcNow;
			}
			if (!InitialAssetsLoaded)
			{
				PercentLoaded = (float)TotalAssetsLoaded / (float)TotalAssetsToLoad;
			}
			if (!InitialAssetsLoaded && World.Time.LocalWorldTime > 10.0 && (TotalAssetsLoaded >= TotalAssetsToLoad || ((DateTime.UtcNow - _lastLoadedAssetsChange).TotalMinutes >= 1.0 && PercentLoaded > 0.9f)))
			{
				InitialAssetsLoaded = true;
				PercentLoaded = 1f;
			}
			if (TrackAssetLoading && World.Time.LocalWorldTime > 10.0)
			{
				TrackAssetLoading = false;
			}
			if (!World.InputInterface.GetKeyDown(Key.F10))
			{
				return;
			}
			UniLog.Log("Actively Loading Assets for: " + World.RawName);
			lock (activelyLoadingAssets)
			{
				foreach (KeyValuePair<Uri, AssetLoadingData> activelyLoadingAsset in activelyLoadingAssets)
				{
					UniLog.Log(activelyLoadingAsset.Value);
				}
			}
		}

		public void Dispose()
		{
			_localAssets = null;
			World = null;
		}

		public AssetLoadingData RegisterLoadingAsset(Uri url, IStaticAssetProvider provider)
		{
			lock (activelyLoadingAssets)
			{
				if (!activelyLoadingAssets.TryGetValue(url, out AssetLoadingData value))
				{
					value = new AssetLoadingData(this, url, provider.AssetClass);
					activelyLoadingAssets.Add(url, value);
					IncrementAssetsToLoad(value.AssetClass);
				}
				value.RegisterProvider(provider);
				return value;
			}
		}

		internal void IncrementAssetsToLoad(EngineAssetClass assetClass)
		{
			Interlocked.Increment(ref _assetsToLoad[(int)assetClass]);
		}

		internal void DecrementAssetsToLoad(EngineAssetClass assetClass)
		{
			ref int reference = ref _assetsToLoad[(int)assetClass];
			if (reference == 0)
			{
				throw new InvalidOperationException($"Number of assets of type {assetClass} to load is 0, cannot decrement");
			}
			Interlocked.Decrement(ref reference);
		}

		internal void IncrementLoadedAssets(EngineAssetClass assetClass)
		{
			Interlocked.Increment(ref _assetsLoaded[(int)assetClass]);
		}

		internal void UnregisterLoadingData(Uri url)
		{
			lock (activelyLoadingAssets)
			{
				if (!activelyLoadingAssets.Remove(url))
				{
					throw new InvalidOperationException($"Data is not registered for asset: {url}");
				}
			}
		}

		public void RegisterLocalAsset(Uri uri)
		{
			_localAssets.Add(uri);
		}

		public bool HasLocalAsset(Uri uri)
		{
			return _localAssets?.Contains(uri) ?? false;
		}

		public void QueueAssetCreated(IAssetProvider provider)
		{
			assetProviderChanges.Enqueue(new AssetProviderChange(provider, AssetChange.Created));
		}

		public void QueueAssetUpdated(IAssetProvider provider)
		{
			assetProviderChanges.Enqueue(new AssetProviderChange(provider, AssetChange.Updated));
		}

		public void QueueAssetRemoved(IAssetProvider provider)
		{
			assetProviderChanges.Enqueue(new AssetProviderChange(provider, AssetChange.Removed));
		}

		public void SendAssetProviderChanges()
		{
			AssetProviderChange val;
			while (assetProviderChanges.TryDequeue(out val))
			{
				switch (val.change)
				{
				case AssetChange.Created:
					val.provider.SendAssetCreated();
					break;
				case AssetChange.Updated:
					val.provider.SendAssetUpdated();
					break;
				case AssetChange.Removed:
					val.provider.SendAssetRemoved();
					break;
				}
			}
		}
	}
	public abstract class DataTreeAssetProcessor
	{
		private Dictionary<Uri, Uri> processedAssets = new Dictionary<Uri, Uri>();

		protected async Task<Uri> Process(SavedGraph graph, Uri graphUrl)
		{
			Uri newGraphUrl = await PreprocessGraph(graph, graphUrl).ConfigureAwait(continueOnCapturedContext: false);
			foreach (DataTreeValue urlNode in graph.URLNodes)
			{
				Uri url = urlNode.Extract<Uri>();
				if (!ShouldProcess(url))
				{
					continue;
				}
				if (!processedAssets.TryGetValue(url, out Uri value))
				{
					if (DataTreeConverter.IsSupportedFormat(url.AbsolutePath))
					{
						string text = await Gather(url).ConfigureAwait(continueOnCapturedContext: false);
						if (text != null)
						{
							DataTreeDictionary root = DataTreeConverter.Load(text, url);
							value = await Process(new SavedGraph(root), url).ConfigureAwait(continueOnCapturedContext: false);
						}
						else
						{
							UniLog.Warning($"Could not gather file for URL: {url}, cannot process nested data tree");
							value = url;
						}
					}
					else
					{
						value = await ProcessAsset(url).ConfigureAwait(continueOnCapturedContext: false);
					}
				}
				urlNode.UpdateValue(value);
			}
			await PostprocessGraph(graph, graphUrl, newGraphUrl).ConfigureAwait(continueOnCapturedContext: false);
			return newGraphUrl;
		}

		protected abstract Task<Uri> PreprocessGraph(SavedGraph graph, Uri oldGraphUrl);

		protected abstract Task PostprocessGraph(SavedGraph graph, Uri oldGraphUrl, Uri newGraphUrl);

		protected abstract bool ShouldProcess(Uri uri);

		protected abstract Task<Uri> ProcessAsset(Uri uri);

		protected abstract Task<string> Gather(Uri uri);
	}
