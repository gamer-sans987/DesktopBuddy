		public void OnLoaded(Worker worker, Action action, int orderOffset = 0)
		{
			if (onLoaded == null)
			{
				onLoaded = Pool.BorrowDictionaryList<int, LoadedAction>();
			}
			onLoaded.Add(orderOffset, new LoadedAction(worker, action));
		}

		internal void FinishLoad()
		{
			if (onLoaded != null)
			{
				List<int> list = Pool.BorrowList<int>();
				foreach (KeyValuePair<int, List<LoadedAction>> item in onLoaded)
				{
					list.Add(item.Key);
				}
				list.Sort();
				foreach (int item2 in list)
				{
					foreach (LoadedAction item3 in onLoaded.TryGetList(item2))
					{
						if (item3.worker == null || !item3.worker.IsRemoved)
						{
							try
							{
								item3.action();
							}
							catch (Exception value)
							{
								UniLog.Error($"Exception when running post-load action. Worker:\n{item3.worker}\n\nOrderOffset: {item2}\nException:\n{value}");
							}
						}
					}
				}
				Pool.Return(ref onLoaded);
			}
			if (transferReferences == null)
			{
				return;
			}
			HashSet<IWorldElement> hashSet = null;
			if (transferReferenceCallbacks != null)
			{
				hashSet = Pool.BorrowHashSet<IWorldElement>();
			}
			World.ReplaceReferenceTargets(transferReferences, nullIfIncompatible: false, null, hashSet);
			if (hashSet != null)
			{
				foreach (KeyValuePair<IWorldElement, Action<bool>> transferReferenceCallback in transferReferenceCallbacks)
				{
					transferReferenceCallback.Value(hashSet.Contains(transferReferenceCallback.Key));
				}
			}
			if (hashSet != null)
			{
				Pool.Return(ref hashSet);
			}
		}
	}
