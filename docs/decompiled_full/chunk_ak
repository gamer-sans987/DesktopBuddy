			}
			if (elementType == typeof(ISyncRef<User>))
			{
				Slot slot2 = targetSlot.Parent.AddSlot("INJECTED ReferenceAsVariable");
				slot2.CopyTransform(targetSlot);
				ProtoFluxNode protoFluxNode2 = (ProtoFluxNode)slot2.AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(ReferenceInterfaceAsVariable<User>)));
				protoFluxNode2.NodeInputs.First().Target = rawTarget;
				reference.Target = protoFluxNode2;
				return true;
			}
			if (elementType.IsGenericType)
			{
				Type genericTypeDefinition = elementType.GetGenericTypeDefinition();
				if (genericTypeDefinition == typeof(SyncRef<>))
				{
					Type type = elementType.GenericTypeArguments[0];
					Slot slot3 = targetSlot.Parent.AddSlot("INJECTED ReferenceAsVariable");
					slot3.CopyTransform(targetSlot);
					ProtoFluxNode protoFluxNode3 = (ProtoFluxNode)slot3.AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(ReferenceAsVariable<>)).MakeGenericType(type));
					protoFluxNode3.NodeInputs.First().Target = rawTarget;
					reference.Target = protoFluxNode3;
					return true;
				}
				if (genericTypeDefinition == typeof(IValue<>) || genericTypeDefinition == typeof(IField<>))
				{
					Type type2 = elementType.GenericTypeArguments[0];
					Slot slot4 = targetSlot.Parent.AddSlot("INJECTED FieldAsVariable");
					slot4.CopyTransform(targetSlot);
					ProtoFluxNode protoFluxNode4 = (ProtoFluxNode)slot4.AttachComponent(ProtoFluxHelper.GetBindingForNode(typeof(FieldAsVariable<>)).MakeGenericType(type2));
					protoFluxNode4.NodeInputs.First().Target = rawTarget;
					reference.Target = protoFluxNode4;
					return true;
				}
			}
			return false;
		}

		bool IWorkerLoader.CanLoad(WorkerSaveLoad.WorkerData data)
		{
			if (data.workerTypename.Contains("ProtoFlux"))
			{
				return false;
			}
			if (data.workerTypename.Contains("DefaultUserScale") && data.workerTypename.Contains("FrooxEngine.CommonAvatar"))
			{
				return false;
			}
			SplitName(data.workerTypename, out string name, out string _, out string _);
			if (!LegacyProtoFluxMapping.ShouldMap(name))
			{
				return LegacyProtoFluxMapping.ShouldSupress(name);
			}
			return true;
		}

		Type IWorkerLoader.FindType(WorkerSaveLoad.WorkerData data, LoadControl loadControl)
		{
			string workerTypename = data.workerTypename;
			workerTypename = workerTypename.Replace("ToolTip", "Tool").Replace("Tooltip", "Tool");
			if (upgradeColorX)
			{
				if (!workerTypename.Contains(".colorX"))
				{
					workerTypename = workerTypename.Replace(".color", ".colorX");
				}
				if (!workerTypename.Contains("ColorX"))
				{
					workerTypename = workerTypename.Replace("Color", "ColorX");
				}
				if (!workerTypename.Contains("colorX"))
				{
					workerTypename = workerTypename.Replace("color", "colorX");
				}
			}
			workerTypename = workerTypename.Replace("RoundToInt", "LegacyRoundToInt").Replace("CeilToInt", "LegacyCeilToInt").Replace("FloorToInt", "LegacyFloorToInt");
			if ((workerTypename.Contains("Cast_float") || workerTypename.Contains("Cast_double")) && workerTypename.Contains("_To_int"))
			{
				workerTypename = workerTypename.Replace("Cast", "Legacy_Cast");
			}
			SplitName(workerTypename, out string name, out string genericParams, out string @namespace);
			if (LegacyProtoFluxMapping.ShouldSupress(name))
			{
				return typeof(void);
			}
			if (name.StartsWith("XNOR_") && !name.Contains("Multi") && loadControl.GetLegacyTypeVersion((string n) => n.Contains(name)) == 0)
			{
				name = name.Replace("XNOR_", "XOR_");
			}
			if (name == "IsUserPresent" && loadControl.GetLegacyTypeVersion((string n) => n.Contains(name)) == 0)
			{
				name = "IsUserPresentInWorld";
			}
			if (name == "CastClass")
			{
				string[] array = genericParams.Split(new string[1] { "],[" }, StringSplitOptions.RemoveEmptyEntries);
				if (array.Length != 2)
				{
					throw new Exception("Unsupported number of generic parameters for CastClass: " + genericParams);
				}
				Type type = loadControl.World.Types.DecodeLegacyType(array[0]);
				Type type2 = loadControl.World.Types.DecodeLegacyType(array[1]);
				if (type == null)
				{
					UniLog.Warning("UNSUPPORTED INPUT class type: " + array[0]);
					return null;
				}
				if (type2 == null)
				{
					UniLog.Warning("UNSUPPORTED INPUT class type: " + array[1]);
					return null;
				}
				if (type2 == typeof(object))
				{
					if (type.IsEnum || type.IsUnmanaged())
					{
						return ProtoFluxHelper.GetBindingForNode(typeof(ValueToObjectCast<>)).MakeGenericType(type);
					}
					if (ReflectionHelper.IsNullable(type))
					{
						return ProtoFluxHelper.GetBindingForNode(typeof(NullableToObjectCast<>).MakeGenericType(Nullable.GetUnderlyingType(type)));
					}
				}
				return ProtoFluxHelper.GetBindingForNode(typeof(ObjectCast<, >)).MakeGenericType(type, type2);
			}
			if (name.StartsWith("Cast_") && name.EndsWith("_To_object"))
			{
				Type type3 = ExtractBakedInType(name.Replace("Cast_", "").Replace("_To_object", ""));
				if (type3.IsValueType)
				{
					if (type3.IsUnmanaged())
					{
						return ProtoFluxHelper.GetBindingForNode(typeof(ValueToObjectCast<>)).MakeGenericType(type3);
					}
					if (ReflectionExtensions.IsNullable(type3))
					{
						return ProtoFluxHelper.GetBindingForNode(typeof(NullableToObjectCast<>).MakeGenericType(Nullable.GetUnderlyingType(type3)));
					}
					UniLog.Log($"UNSUPPORTED TO OBJECT CAST SOURCE TYPE. Name: {name} Generic: {genericParams} Namespace: {@namespace}, GenericArg: {type3}");
					return null;
				}
				return ProtoFluxHelper.GetBindingForNode(typeof(ObjectCast<, >)).MakeGenericType(type3, typeof(object));
			}
			ProtoFluxTypeMapping protoFluxTypeMapping = ProtoFluxHelper.MapNode(name, @namespace);
			if (protoFluxTypeMapping.IsNull)
			{
				UniLog.Log($"MISSING MAPPING. Name: {name} Generic: {genericParams} Namespace: {@namespace}");
				return null;
			}
			try
			{
				if (protoFluxTypeMapping.IsGenericDefinition)
				{
					protoFluxTypeMapping = MakeGenericType(protoFluxTypeMapping, name, genericParams, loadControl);
				}
			}
			catch (Exception value)
			{
				UniLog.Log($"INVALID GENERICS EXCEPTION. Name: {name}. BaseType: {protoFluxTypeMapping}. GenericParams: {genericParams}\nException: {value}");
				return null;
			}
			Type nodeType = protoFluxTypeMapping.GetNodeType();
			if (nodeType == floatQEqualsBinding)
			{
				return ProtoFluxHelper.GetBindingForNode(typeof(Approximately_FloatQ));
			}
			if (nodeType == doubleQEqualsBinding)
			{
				return ProtoFluxHelper.GetBindingForNode(typeof(Approximately_DoubleQ));
			}
			if (nodeType == floatQNotEqualsBinding)
			{
				return ProtoFluxHelper.GetBindingForNode(typeof(ApproximatelyNot_FloatQ));
			}
			if (nodeType == doubleQNotEqualsBinding)
			{
				return ProtoFluxHelper.GetBindingForNode(typeof(ApproximatelyNot_DoubleQ));
			}
			return nodeType;
		}

		public Type MakeGenericType(ProtoFluxTypeMapping mapping, string name, string genericParams, LoadControl control)
		{
			Type type = null;
			if (genericParams != null)
			{
				type = control.World.Types.DecodeLegacyType(genericParams);
				if (type.IsGenericType && type.GetGenericTypeDefinition() == typeof(IValue<>))
				{
					Type type2 = type.GetGenericArguments()[0];
					if (type2 == typeof(User))
					{
						type = typeof(ISyncRef<User>);
					}
					else if (typeof(IWorldElement).IsAssignableFrom(type2))
					{
						type = typeof(SyncRef<>).MakeGenericType(type2);
					}
				}
				if (type != null)
				{
					return mapping.MakeGenericType(type);
				}
			}
			Type type3 = ExtractBakedInType(name);
			if (type3 != null)
			{
				return mapping.MakeGenericType(type3);
			}
			UniLog.Log($"INVALID GENERICS. Name: {name}. Mapper: {mapping}.\nGenericParams: {genericParams}. Type: {type}");
			return mapping.GetNodeType();
		}

		public static Type ExtractBakedInType(string name)
		{
			string text = name.ToLower();
			for (int i = 0; i < primitives.Count; i++)
			{
				if (text.StartsWith(primitives[i].lowerCaseName) || text.EndsWith(primitives[i].lowerCaseName) || name.Contains(primitives[i].capitalizedName))
				{
					return primitives[i].type;
				}
			}
			return null;
		}

		public static void SplitName(string fullName, out string name, out string genericParams, out string @namespace)
		{
			int num = fullName.IndexOf('`');
			if (num >= 0)
			{
				genericParams = fullName.Substring(num + 2);
				genericParams = genericParams.Substring(2, genericParams.Length - 4);
				fullName = fullName.Substring(0, num);
			}
			else
			{
				genericParams = null;
			}
			int num2 = fullName.LastIndexOf('.');
			@namespace = fullName.Substring(0, num2);
			name = fullName.Substring(num2 + 1);
		}

		private static bool ExplicitlyRejectCandidate(Element element, Element candidate)
		{
			if (element.name == "FormatProvider" && candidate.name == "Str")
			{
				return true;
			}
			return false;
		}

		private static bool IsValidCandidate(Element element, Element candidate)
		{
			return IsValidCandidate(element.name, candidate.name);
		}

		private static bool IsValidCandidate(string element, string candidate)
		{
			if (element == candidate)
			{
				return true;
			}
			if (element.Length > candidate.Length)
			{
				if (element.StartsWith(candidate))
				{
					return true;
				}
				if (element.EndsWith(candidate))
				{
					return true;
				}
			}
			if (candidate.Length > element.Length)
			{
				if (candidate.StartsWith(element))
				{
					return true;
				}
				if (candidate.EndsWith(element))
				{
					return true;
				}
			}
			if (element == "Next")
			{
				if (!(candidate == "OnDone") && !(candidate == "Pulse"))
				{
					return candidate == "Impulse";
				}
				return true;
			}
			switch (candidate)
			{
			case "Operands":
				return element == "Inputs";
			case "DelayTime":
				return element == "DelaySeconds";
			case "Delay":
				return element == "Duration";
			case "Node":
				if (element == "Side")
				{
					return true;
				}
				break;
			}
			if (candidate == "VariableName" && element == "Path")
			{
				return true;
			}
			if ((candidate == "OnRead" || candidate == "OnWritten") && element == "OnDone")
			{
				return true;
			}
			if ((candidate == "OnReadRequest" || candidate == "OnWriteRequest") && element == "OnRequest")
			{
				return true;
			}
			if (candidate == "Tool" && element == "Tooltip")
			{
				return true;
			}
			string text = element.ToLower();
			string text2 = candidate.ToLower();
			if (text.Replace("uri", "url") == text2.Replace("uri", "url"))
			{
				return true;
			}
			return false;
		}
	}
