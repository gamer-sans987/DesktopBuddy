		private readonly struct TypePair
		{
			public readonly string lowerCaseName;

			public readonly string capitalizedName;

			public readonly Type type;

			public TypePair(string name, Type type)
			{
				lowerCaseName = name.ToLower();
				capitalizedName = name.Capitalize();
				this.type = type;
			}
		}

		private static List<TypePair> primitives;

		private static readonly Type floatQEqualsBinding;

		private static readonly Type doubleQEqualsBinding;

		private static readonly Type floatQNotEqualsBinding;

		private static readonly Type doubleQNotEqualsBinding;

