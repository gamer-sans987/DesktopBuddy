		internal IWorkerLoader FindLoader(WorkerSaveLoad.WorkerData data)
		{
			foreach (IWorkerLoader customWorkerLoader in customWorkerLoaders)
			{
				if (customWorkerLoader.CanLoad(data))
				{
					return customWorkerLoader;
				}
			}
			return defaultLoader;
		}

		public TypeData DecodeType(DataTreeNode node)
		{
			if (node == null)
			{
				return default(TypeData);
			}
			if (LegacyTypes)
			{
				string text = node.LoadString();
				if (string.IsNullOrEmpty(text))
				{
					return default(TypeData);
				}
				if (!GetFeatureFlag("ColorManagement").HasValue)
				{
					text = text.Replace(TypeManager.LegacyMatchColor, "Elements.Core.colorX");
				}
				return new TypeData(World.Types.DecodeLegacyType(text), text);
			}
			int num = node.LoadInt();
			if (num < 0)
			{
				return default(TypeData);
			}
			return types[num];
		}

		public void AssociateReference(RefID localReference, DataTreeNode globalReference, bool isAdditionalReference = false)
		{
			if (localReference == RefID.Null || !AssociateReferences)
			{
				return;
			}
			try
			{
				DataTreeValue dataTreeValue = (DataTreeValue)globalReference;
				Guid global = new Guid(dataTreeValue.Extract<string>());
				ReferenceTranslator.Associate(localReference, global, isAdditionalReference);
			}
			catch (ArgumentException)
			{
			}
		}

		public void RequestReference(DataTreeNode globalReference, ISyncRef requestee)
		{
			if (globalReference is DataTreeValue dataTreeValue)
			{
				if (dataTreeValue.IsNull)
				{
					requestee.Value = RefID.Null;
					return;
				}
				Guid global = new Guid(dataTreeValue.Extract<string>());
				ReferenceTranslator.Request(global, requestee);
			}
			else if (globalReference is DataTreeDictionary dataTreeDictionary)
			{
				DataTreeNode dataTreeNode = dataTreeDictionary.TryGetNode("Target");
				if (dataTreeNode != null)
				{
					RequestReference(dataTreeNode, requestee);
				}
			}
		}

		public void TryLoadVersion(DataTreeDictionary dict)
		{
			string text = null;
			DataTreeNode dataTreeNode = dict.TryGetNode("VersionNumber");
			if (dataTreeNode != null)
			{
				text = dataTreeNode.LoadString();
			}
			else
			{
				dataTreeNode = dict.Children.FirstOrDefault((KeyValuePair<string, DataTreeNode> k) => k.Key.EndsWith(" Version")).Value;
				if (dataTreeNode != null)
				{
					text = dataTreeNode.LoadString();
					text = text.Replace("Beta ", "").Trim();
				}
			}
			if (text != null)
			{
				try
				{
