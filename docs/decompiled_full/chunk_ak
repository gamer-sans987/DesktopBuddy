	public class RecordOwnerTransferer : RecursiveRecordProcessor
	{
		private Dictionary<string, string> _transferedRecords = new Dictionary<string, string>();

		public string SourceRootOwnerID { get; private set; }

		public OwnerType SourceRootOwnerType { get; private set; }

		public string TargetOwnerID { get; private set; }

		public OwnerType TargetOwnerType { get; private set; }

		protected override bool SaveProcessedGraphs => true;

		protected override bool SaveProcessedRecords => true;

		public RecordOwnerTransferer(Engine engine, string targetOwnerID, string sourceRootOwnerID = null)
			: base(engine)
		{
			TargetOwnerID = targetOwnerID;
			TargetOwnerType = IdUtil.GetOwnerType(targetOwnerID);
			SourceRootOwnerID = sourceRootOwnerID;
			SourceRootOwnerType = IdUtil.GetOwnerType(sourceRootOwnerID);
		}

		public async Task EnsureOwnerId(SavedGraph graph)
		{
			await ProcessInternal(graph);
		}

		public async Task TransferOwner(Uri recordUri)
		{
			await ProcessInternal(recordUri);
		}

		public async Task TransferOwner(FrooxEngine.Store.Record record)
		{
			await ProcessInternal(record);
		}

		protected override async Task ProcessRecord(FrooxEngine.Store.Record record, SavedGraph graph)
		{
			bool isAlreadyTransfered;
			Uri transferedRecordURL = GetTransferedRecordURL(record.GetUrl(base.Cloud.Platform), out isAlreadyTransfered);
			record.SetUrl(base.Cloud.Platform, transferedRecordURL);
			if (IdUtil.GetOwnerType(TargetOwnerID) != OwnerType.Machine)
			{
				return;
			}
			foreach (DataTreeValue urlNode in graph.URLNodes)
			{
				Uri url = urlNode.Extract<Uri>();
				bool flag = url.Scheme == "http" || url.Scheme == "https" || url.Scheme == base.Cloud.Assets.DBScheme;
				if (flag)
				{
					flag = await base.Engine.LocalDB.TryFetchAssetRecordAsync(url) != null;
				}
				if (flag)
				{
					DataTreeValue dataTreeValue = urlNode;
					dataTreeValue.UpdateValue(await base.Engine.LocalDB.EnsurePermanentStorageAsync(url));
				}
			}
		}

		protected override bool ShouldProcess(string ownerId, string recordId, bool isLinked)
		{
			return ShouldTransfer(ownerId, isLinked);
		}

		protected override bool CheckIsProcessed(string ownerId, string recordId, Uri url, DataTreeValue node)
		{
			bool isAlreadyTransfered;
			Uri transferedRecordURL = GetTransferedRecordURL(url, out isAlreadyTransfered);
			node.UpdateValue(transferedRecordURL);
			return isAlreadyTransfered;
		}

		public Uri GetTransferedRecordURL(Uri source)
		{
			lock (_transferedRecords)
			{
				string leftPart = source.GetLeftPart(UriPartial.Path);
				if (_transferedRecords.TryGetValue(leftPart, out string value))
				{
					return new Uri(value + source.Query);
				}
				return null;
			}
		}

		private Uri GetTransferedRecordURL(Uri source, out bool isAlreadyTransfered)
		{
			lock (_transferedRecords)
			{
				string leftPart = source.GetLeftPart(UriPartial.Path);
				if (_transferedRecords.TryGetValue(leftPart, out string value))
				{
					isAlreadyTransfered = true;
					return new Uri(value + source.Query);
				}
				isAlreadyTransfered = false;
				Uri recordUri = base.Cloud.Platform.GetRecordUri(TargetOwnerID, RecordHelper.GenerateRecordID());
				_transferedRecords.Add(leftPart, recordUri.GetLeftPart(UriPartial.Path));
				return new Uri(recordUri, source.Query);
			}
		}

		private bool ShouldTransfer(string ownerId, bool isLinked)
		{
			if (ownerId == TargetOwnerID)
			{
				return false;
			}
			if (ownerId == SourceRootOwnerID && isLinked)
			{
				return true;
			}
			OwnerType ownerType = IdUtil.GetOwnerType(ownerId);
			if (TargetOwnerType != OwnerType.Machine && ownerType == OwnerType.Machine)
			{
				return true;
			}
			return false;
		}
	}
	public class RecordPublisher : RecursiveRecordProcessor
	{
		private FrooxEngine.Store.Record root;

		protected override bool SaveProcessedGraphs => false;

		protected override bool SaveProcessedRecords => true;

		public static Task UpdateReferencedRecords(Engine engine, FrooxEngine.Store.Record root)
		{
			return new RecordPublisher(engine, root).Process();
		}

		private RecordPublisher(Engine engine, FrooxEngine.Store.Record root)
			: base(engine)
		{
			this.root = root;
		}

		private Task Process()
		{
			return ProcessInternal(root);
		}

		protected override Task ProcessRecord(FrooxEngine.Store.Record record, SavedGraph graph)
		{
			int isPublic;
			if (!root.IsPublic)
			{
				List<Submission> submissions = record.Submissions;
				isPublic = ((submissions != null && submissions.Any() && record.IsPublic) ? 1 : 0);
			}
			else
			{
				isPublic = 1;
			}
			record.IsPublic = (byte)isPublic != 0;
			record.IsForPatrons = root.IsForPatrons;
			return Task.CompletedTask;
		}

		protected override bool ShouldProcess(string ownerId, string recordId, bool isLinked)
		{
			return ownerId == root.OwnerId && isLinked;
		}
	}
	public abstract class RecursiveRecordProcessor
	{
		private HashSet<string> processedRecords = new HashSet<string>();

		public Engine Engine { get; private set; }

		public EngineSkyFrostInterface Cloud => Engine?.Cloud;

		protected abstract bool SaveProcessedGraphs { get; }

		protected abstract bool SaveProcessedRecords { get; }

		public RecursiveRecordProcessor(Engine engine)
		{
			Engine = engine;
		}

		protected async Task ProcessInternal(SavedGraph graph)
		{
			foreach (DataTreeValue urlNode in graph.URLNodes)
			{
				try
				{
					Uri uri = urlNode.TryExtractURL();
					if (Cloud.Records.ExtractRecordID(uri, out var ownerId, out var recordId, out var isLinked) && ShouldProcess(ownerId, recordId, isLinked) && !CheckIsProcessed(ownerId, recordId, uri, urlNode))
					{
						UniLog.Log("Processing internal: " + uri);
						await ProcessInternal(uri).ConfigureAwait(continueOnCapturedContext: false);
					}
				}
				catch (Exception)
				{
					UniLog.Error($"Exception processing URL node saved graph. Node Value: {urlNode.Value}");
				}
			}
		}

		protected async Task ProcessInternal(Uri recordURL)
		{
			UniLog.Log("Fetching record: " + recordURL);
			CloudResult<FrooxEngine.Store.Record> cloudResult = await Engine.RecordManager.FetchRecord(recordURL).ConfigureAwait(continueOnCapturedContext: false);
			if (!cloudResult.IsError)
			{
				await ProcessInternal(cloudResult.Entity).ConfigureAwait(continueOnCapturedContext: false);
			}
		}

		protected async Task ProcessInternal(FrooxEngine.Store.Record record)
		{
			UniLog.Log("Requesting gather: " + record.AssetURI);
			string file = await Engine.AssetManager.GatherAssetFile(new Uri(record.AssetURI), 0f).ConfigureAwait(continueOnCapturedContext: false);
			UniLog.Log("Gathered: " + record.AssetURI);
			DataTreeDictionary root = DataTreeConverter.Load(file);
			SavedGraph graph = new SavedGraph(root);
			await ProcessRecord(record, graph).ConfigureAwait(continueOnCapturedContext: false);
			await ProcessInternal(graph).ConfigureAwait(continueOnCapturedContext: false);
			if (SaveProcessedGraphs)
			{
				string tempFilePath = Engine.LocalDB.GetTempFilePath("lz4bson");
				DataTreeConverter.Save(graph.Root, tempFilePath, DataTreeConverter.Compression.LZ4);
				record.AssetURI = (await Engine.LocalDB.ImportLocalAssetAsync(tempFilePath, LocalDB.ImportLocation.Move).ConfigureAwait(continueOnCapturedContext: false)).ToString();
			}
			if (SaveProcessedRecords || SaveProcessedGraphs)
			{
				RecordManager.RecordSaveResult recordSaveResult = await Engine.RecordManager.SaveRecord(record, graph).ConfigureAwait(continueOnCapturedContext: false);
				if (recordSaveResult.task != null)
				{
					await recordSaveResult.task.Task.ConfigureAwait(continueOnCapturedContext: false);
				}
			}
		}

		protected abstract Task ProcessRecord(FrooxEngine.Store.Record record, SavedGraph graph);

		protected abstract bool ShouldProcess(string ownerId, string recordId, bool isLinked);

		protected virtual bool CheckIsProcessed(string ownerId, string recordId, Uri url, DataTreeValue node)
		{
			lock (processedRecords)
			{
				return !processedRecords.Add(url.GetLeftPart(UriPartial.Path));
			}
		}
	}
	public class SaveControl
	{
		private UnresolvedReferences unresolved;

		private Dictionary<Type, int> typeVersions = new Dictionary<Type, int>();

		private List<TypeData> types = new List<TypeData>();

		private Dictionary<Type, int> typeToIndex = new Dictionary<Type, int>();

		private Dictionary<string, int> typenameToIndex = new Dictionary<string, int>();

		private List<Action> onBeforeSaveStart;

		private List<Action> onSaved;

		public bool SaveNonPersistent;

		public Func<RefID, RefID> ReferenceFilter;

		public List<IAssetProvider> nonpersistentAssets = new List<IAssetProvider>();

		public ReferenceTranslator ReferenceTranslator { get; private set; }

		public World World { get; private set; }

		public IWorldElement SaveRoot { get; private set; }

		public DataTreeDictionary StoreFeatureFlags(Engine engine)
		{
			DataTreeDictionary dataTreeDictionary = new DataTreeDictionary();
			foreach (FeatureFlag featureFlag in engine.FeatureFlags)
			{
				dataTreeDictionary.Add(featureFlag.Feature, featureFlag.Version);
			}
			return dataTreeDictionary;
		}

		public void StoreTypeData(DataTreeList typeList, DataTreeDictionary typeVersionsDict)
		{
			foreach (TypeData type in types)
			{
				string text;
				if (type.type != null)
				{
					text = World.Types.EncodeType(type.type);
					if (text == null)
					{
						throw new InvalidOperationException($"Failed to encode type: {type.type}");
					}
				}
				else
				{
					text = type.typename;
				}
				typeList.Add(new DataTreeValue(text));
			}
			foreach (KeyValuePair<Type, int> typeVersion in typeVersions)
			{
				typeVersionsDict.Add(World.Types.EncodeType(typeVersion.Key), typeVersion.Value);
			}
		}

		public SaveControl(World world, IWorldElement saveRoot, ReferenceTranslator refTranslator, UnresolvedReferences unresolved)
		{
			World = world;
			SaveRoot = saveRoot;
			ReferenceTranslator = refTranslator;
			this.unresolved = unresolved;
		}

		public DataTreeValue SaveReference(RefID reference)
		{
			if (ReferenceFilter != null)
			{
				reference = ReferenceFilter(reference);
			}
			if (reference == RefID.Null)
			{
				return new DataTreeValue((string)null);
			}
			return new DataTreeValue(ReferenceToString(reference));
		}

		public DataTreeValue SaveType(Type type)
		{
			if (type == null)
			{
				return new DataTreeValue(-1);
			}
			if (!typeToIndex.TryGetValue(type, out var value))
			{
				value = types.Count;
				types.Add(new TypeData(type, null));
				typeToIndex.Add(type, value);
			}
			return new DataTreeValue(value);
		}

		public DataTreeValue SaveType(string typename)
		{
			if (string.IsNullOrEmpty(typename))
			{
				throw new ArgumentNullException("typename");
			}
			if (!typenameToIndex.TryGetValue(typename, out var value))
			{
				value = types.Count;
				types.Add(new TypeData(null, typename));
				typenameToIndex.Add(typename, value);
			}
			return new DataTreeValue(value);
		}

		public void RegisterTypeVersion(Type type, int version)
		{
			if (version > 0 && !typeVersions.ContainsKey(type))
			{
				typeVersions.Add(type, version);
			}
		}

		public string ReferenceToString(RefID reference)
		{
			return unresolved?.TranslateReference(reference) ?? ReferenceTranslator.Fetch(reference).ToString();
		}

		public void OnBeforeSaveStart(Action action)
		{
			if (onBeforeSaveStart == null)
			{
				onBeforeSaveStart = Pool.BorrowList<Action>();
			}
			onBeforeSaveStart.Add(action);
		}

		public void OnSaved(Action action)
		{
			if (onSaved == null)
			{
				onSaved = Pool.BorrowList<Action>();
			}
			onSaved.Add(action);
		}

		internal void StartSaving()
		{
			if (onBeforeSaveStart == null)
			{
				return;
			}
			foreach (Action item in onBeforeSaveStart)
			{
				try
				{
					item();
				}
				catch (Exception value)
				{
					UniLog.Error($"Exception when running OnBeforeSaveStart Action: {item}\n{value}", stackTrace: false);
				}
			}
			Pool.Return(ref onBeforeSaveStart);
		}

		internal void FinishSave()
		{
			if (onSaved == null)
			{
				return;
			}
			foreach (Action item in onSaved)
			{
				item();
			}
			Pool.Return(ref onSaved);
		}
	}
